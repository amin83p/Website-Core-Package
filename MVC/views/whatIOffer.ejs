<section class="pte-public-page projects-page offer-page-v2">
  <%
    const projectsPageContent = (typeof projectsContent !== 'undefined' && projectsContent && typeof projectsContent === 'object') ? projectsContent : {};
    const projectsHero = projectsPageContent.hero || {};
    const projectsHighlights = Array.isArray(projectsPageContent.highlights) ? projectsPageContent.highlights : [];
    const projectSection = projectsPageContent.projectSection || {};
    const projectItems = Array.isArray(projectsPageContent.projectItems) ? projectsPageContent.projectItems : [];
    const resumeContext = projectsPageContent.resumeContext || {};
    const resumePoints = Array.isArray(resumeContext.points) ? resumeContext.points : [];
    const servicePanel = projectsPageContent.servicePanel || {};
    const serviceTags = Array.isArray(servicePanel.tags) ? servicePanel.tags : [];
    const projectsFinalCta = projectsPageContent.finalCta || {};
  %>
  <section class="pte-hero-intro offer-hero reveal" aria-labelledby="projectsTitle">
    <div class="pte-hero-orbit" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="offer-hero-top pte-hero-copy">
      <span class="pte-eyebrow offer-kicker"><%= projectsHero.eyebrow || 'Projects' %></span>
      <h1 id="projectsTitle"><%= projectsHero.title || 'Projects' %></h1>
      <p>
        <%= projectsHero.subtitle || 'Selected engineering, automation, education, and software systems shaped for practical delivery. These examples are recent project samples, not the full portfolio.' %>
      </p>
    </div>

    <div class="pte-hero-actions offer-hero-actions">
      <a href="<%= projectsHero.primaryHref || '/contact' %>" class="btn pte-btn-primary offer-btn-main">
        <i class="bi bi-send me-2"></i>
        <%= projectsHero.primaryLabel || 'Discuss Your Project' %>
      </a>
      <a href="<%= projectsHero.secondaryHref || '/about' %>" class="btn pte-btn-secondary offer-btn-ghost">
        <i class="bi bi-person-workspace me-2"></i>
        <%= projectsHero.secondaryLabel || 'How I Work' %>
      </a>
    </div>

    <div class="pte-highlight-row offer-metrics" aria-label="Project highlights">
      <% projectsHighlights.forEach((item) => { %>
        <div class="pte-highlight-chip offer-chip">
          <strong><%= item.value %></strong>
          <span><%= item.label %></span>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="pte-section offer-workspace reveal delay-1" aria-label="Project examples and context">
    <div class="offer-grid">
      <article class="offer-card offer-panel offer-projects">
        <div class="pte-section-heading pte-section-heading-left offer-sectionTitle">
          <span><%= projectSection.eyebrow || 'Selected Work' %></span>
          <h2><%= projectSection.title || 'Recent Project Examples' %></h2>
          <p><%= projectSection.body || 'Representative samples from recent work across academic platforms, AI feedback, and industrial automation.' %></p>
        </div>

        <% projectItems.forEach((item, index) => { %>
          <div class="offer-item">
            <div class="offer-item-no"><%= item.step || String(index + 1).padStart(2, '0') %></div>
            <div>
              <h3><%= item.title %></h3>
              <p><%= item.body %></p>
            </div>
          </div>
        <% }) %>
      </article>

      <aside class="offer-card offer-panel offer-resume">
        <div class="offer-direct-header">
          <span class="offer-direct-mark" aria-hidden="true">
            <i class="bi <%= resumeContext.icon || 'bi-diagram-3' %>"></i>
          </span>
          <div>
            <span class="offer-direct-kicker"><%= resumeContext.kicker || 'Context' %></span>
            <h2><%= resumeContext.title || 'Resume Context' %></h2>
          </div>
        </div>
        <p class="offer-intro"><%= resumeContext.intro || 'Background areas that support the delivery style above.' %></p>

        <ul class="offer-points">
          <% resumePoints.forEach((point) => { %>
            <li><%= point %></li>
          <% }) %>
        </ul>

        <div class="offer-note">
          <h4><%= resumeContext.noteTitle || 'Current Focus' %></h4>
          <p>
            <%= resumeContext.noteBody || 'I am not currently developing the Review Manager product. Current development focus is integrated academic and industrial systems.' %>
          </p>
        </div>
      </aside>
    </div>
  </section>

  <section class="offer-card offer-panel offer-service-panel reveal delay-2">
    <div class="pte-section-heading pte-section-heading-left offer-sectionTitle">
      <span><%= servicePanel.eyebrow || 'Project Domains' %></span>
      <h2><%= servicePanel.title || 'Service Areas' %></h2>
    </div>
    <div class="offer-tags">
      <% serviceTags.forEach((tag) => { %>
        <span><%= tag %></span>
      <% }) %>
    </div>
  </section>

  <section class="offer-panel offer-cta reveal delay-3">
    <div>
      <h2><%= projectsFinalCta.title || 'Need execution-ready systems?' %></h2>
      <p><%= projectsFinalCta.body || 'Share your requirements and constraints to scope a practical implementation path.' %></p>
    </div>
    <div class="pte-hero-actions offer-cta-actions">
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="<%= projectsFinalCta.signedInPrimaryHref || '/dashboard' %>" class="btn pte-btn-primary">
          <i class="bi bi-speedometer2 me-2"></i><%= projectsFinalCta.signedInPrimaryLabel || 'Open Dashboard' %>
        </a>
      <% } else { %>
        <a href="<%= projectsFinalCta.guestPrimaryHref || '/login' %>" class="btn pte-btn-primary">
          <i class="bi bi-box-arrow-in-right me-2"></i><%= projectsFinalCta.guestPrimaryLabel || 'Sign In' %>
        </a>
        <a href="<%= projectsFinalCta.guestSecondaryHref || '/persons/join' %>" class="btn pte-btn-secondary"><%= projectsFinalCta.guestSecondaryLabel || 'Create Account' %></a>
      <% } %>
      <a href="<%= projectsFinalCta.contactHref || '/contact' %>" class="btn pte-btn-secondary">
        <i class="bi bi-chat-dots me-2"></i><%= projectsFinalCta.contactLabel || 'Talk to Our Team' %>
      </a>
    </div>
  </section>
</section>

<style>
