<%
  const key = String(typeof dashboardKey !== 'undefined' ? dashboardKey : 'dashboard').trim() || 'dashboard';
  const sectionsInput = (typeof dashboardSections !== 'undefined') ? dashboardSections : [];
  const sections = Array.isArray(sectionsInput) ? sectionsInput : [];
  const titleText = String(typeof dashboardTitle !== 'undefined' ? dashboardTitle : '').trim();
  const subtitleText = String(typeof dashboardSubtitle !== 'undefined' ? dashboardSubtitle : '').trim();
  const titleIcon = String(typeof dashboardTitleIcon !== 'undefined' ? dashboardTitleIcon : '').trim();
  const badgeText = String(typeof dashboardBadge !== 'undefined' ? dashboardBadge : '').trim();
  const badgeClass = String(typeof dashboardBadgeClass !== 'undefined' ? dashboardBadgeClass : 'bg-primary text-white border border-primary-subtle shadow-sm px-3 py-2').trim();
  const backHref = String(typeof dashboardBackHref !== 'undefined' ? dashboardBackHref : '').trim();
  const backLabel = String(typeof dashboardBackLabel !== 'undefined' ? dashboardBackLabel : '').trim();
  const previousLabel = String(typeof dashboardPreviousLabel !== 'undefined' ? dashboardPreviousLabel : 'Previous menu').trim();
  const showBannerActions = Boolean((backHref && backLabel) || badgeText);
  const pageBgIconClass = String(
    typeof dashboardPageBgIconClass !== 'undefined'
      ? dashboardPageBgIconClass
      : (titleIcon || 'bi-grid-fill')
  ).trim();
  const viewKey = `${key}DashboardView`;
  const sizeKey = `${key}DashboardIconSizePercent`;

  const ds = typeof dashboardSection !== 'undefined' ? dashboardSection : null;
  function buildSectionIconHtml(sourceSection, fallbackClass) {
    if (sourceSection && sourceSection.customIcon && sourceSection.customIcon.type && sourceSection.customIcon.value) {
      const type = String(sourceSection.customIcon.type).toLowerCase();
      const value = String(sourceSection.customIcon.value || '').trim();
      if (type === 'class' && value) return '<i class="' + value.replace(/"/g, '&quot;') + '"></i>';
      if (type === 'image' && value) return '<img src="' + value.replace(/"/g, '&quot;') + '" alt="icon">';
      if (type === 'raw' && value) return '<div class="raw-icon-container">' + value + '</div>';
    }
    return '<i class="bi ' + String(fallbackClass || 'bi-grid-fill').replace(/"/g, '&quot;') + '"></i>';
  }

  let bannerIconHtml = '';
  let pageWatermarkHtml = '';
  bannerIconHtml = buildSectionIconHtml(ds, (titleIcon || pageBgIconClass));
  pageWatermarkHtml = buildSectionIconHtml(ds, pageBgIconClass);
%>

<div class="sections-page <%= key %>-dashboard-page">
  <div class="<%= key %>-page-watermark" aria-hidden="true">
    <%- pageWatermarkHtml %>
  </div>
  <div class="<%= key %>-dashboard-banner mb-4">
    <div class="d-flex align-items-start justify-content-between gap-3 gap-md-4 w-100 <%= key %>-banner-row">
      <div class="d-flex align-items-start gap-3 gap-md-4 min-w-0 <%= key %>-banner-title-cluster">
        <div class="<%= key %>-banner-icon-wrap flex-shrink-0 align-self-start"><%- bannerIconHtml %></div>
        <div class="text-start min-w-0 <%= key %>-banner-text-block">
          <div class="<%= key %>-banner-heading-row">
            <h2 class="page-heading size-md m-0 text-start <%= key %>-banner-heading"><%= titleText %></h2>
            <% if (backHref && backLabel) { %>
              <div class="d-flex d-md-none align-items-center gap-2 <%= key %>-mobile-banner-actions" aria-label="Dashboard navigation actions">
                <a href="<%= backHref %>"
                  class="btn btn-light border border-secondary border-opacity-25 shadow-sm <%= key %>-mobile-banner-btn"
                  aria-label="<%= String(backLabel).replace(/"/g, '&quot;') %>"
                  title="<%= String(backLabel).replace(/"/g, '&quot;') %>">
                  <i class="bi bi-arrow-left-short" aria-hidden="true"></i>
                  <span class="visually-hidden"><%= backLabel %></span>
                </a>
                <button type="button"
                  class="btn btn-outline-secondary bg-white bg-opacity-75 shadow-sm <%= key %>-mobile-banner-btn <%= key %>-btn-previous-menu"
                  id="<%= key %>BtnPreviousMenuMobile"
                  aria-label="<%= String(previousLabel).replace(/&/g, '&amp;').replace(/"/g, '&quot;') %>"
                  title="Go to the previous page">
                  <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i>
                  <span class="visually-hidden"><%= previousLabel %></span>
                </button>
              </div>
            <% } %>
          </div>
          <% if (subtitleText) { %>
            <p class="mb-0 text-muted small opacity-90 text-start <%= key %>-banner-subtitle d-none d-md-block mt-2"><%= subtitleText %></p>
          <% } %>
          <% if (badgeText) { %>
            <span class="badge <%= badgeClass %> d-inline-flex d-md-none text-center mt-2"><%= badgeText %></span>
          <% } %>
        </div>
      </div>
      <% if (showBannerActions) { %>
      <div class="d-none d-md-flex flex-column align-items-stretch gap-2 flex-shrink-0 ms-md-auto <%= key %>-banner-actions <%= key %>-banner-nav">
        <% if (backHref && backLabel) { %>
          <a href="<%= backHref %>"
            class="btn <%= key %>-banner-btn <%= key %>-banner-btn-back btn-light border border-secondary border-opacity-25 shadow-sm fw-semibold"
            aria-label="<%= String(backLabel).replace(/"/g, '&quot;') %>">
            <i class="bi bi-arrow-left-short <%= key %>-banner-btn-icon flex-shrink-0" aria-hidden="true"></i><span class="<%= key %>-banner-btn-label"><%= backLabel %></span>
          </a>
          <button type="button"
            class="btn <%= key %>-banner-btn <%= key %>-banner-btn-prev <%= key %>-btn-previous-menu btn-outline-secondary bg-white bg-opacity-75 fw-semibold"
            id="<%= key %>BtnPreviousMenu"
            aria-label="<%= String(previousLabel).replace(/&/g, '&amp;').replace(/"/g, '&quot;') %>"
            title="Go to the last page in your browser history (e.g. parent sub-dashboard)">
            <i class="bi bi-arrow-counterclockwise <%= key %>-banner-btn-icon flex-shrink-0" aria-hidden="true"></i><span class="<%= key %>-banner-btn-label"><%= previousLabel %></span>
          </button>
        <% } %>
        <% if (badgeText) { %>
          <span class="badge <%= badgeClass %> align-self-center text-center mt-1"><%= badgeText %></span>
        <% } %>
      </div>
      <% } %>
    </div>
  </div>

  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3 <%= key %>-tools-row">
    <div class="d-flex align-items-center flex-wrap gap-2 <%= key %>-module-meta">
      <div class="small text-muted <%= key %>-module-count-wrap" id="<%= key %>ModuleCount">
        <i class="bi bi-grid-3x3-gap me-1"></i>
        <strong><%= sections.length %></strong> modules
      </div>
      <button
        type="button"
        id="<%= key %>SearchLauncher"
        class="btn btn-light border shadow-sm <%= key %>-search-launcher"
        aria-label="Search modules"
        aria-haspopup="dialog"
        aria-expanded="false">
        <i class="bi bi-search" aria-hidden="true"></i>
        <span id="<%= key %>SearchLauncherText">Search</span>
      </button>
    </div>
    <div class="d-flex align-items-center flex-wrap gap-2 <%= key %>-tools-controls">
      <div class="<%= key %>-tool-cluster <%= key %>-view-cluster">
        <button
          type="button"
          id="<%= key %>ViewToolsToggle"
          class="<%= key %>-tool-toggle-btn header-settings-toggle header-side-control-btn"
          aria-label="Open view mode controls"
          aria-expanded="false"
          title="View modes">
          <i class="bi bi-grid-3x3-gap-fill" aria-hidden="true"></i>
        </button>
        <div class="btn-group <%= key %>-view-btn-group shadow-sm <%= key %>-tool-panel <%= key %>-view-panel" role="group" aria-label="View Style">
          <button type="button" class="btn btn-outline-secondary <%= key %>-view-btn" data-view="card" title="Card View">
            <i class="bi bi-grid-fill"></i>
          </button>
          <button type="button" class="btn btn-outline-secondary <%= key %>-view-btn" data-view="compact" title="Compact View">
            <i class="bi bi-grid-3x3-gap-fill"></i>
          </button>
          <button type="button" class="btn btn-outline-secondary <%= key %>-view-btn" data-view="list" title="List View">
            <i class="bi bi-list-ul"></i>
          </button>
        </div>
      </div>
      <div class="<%= key %>-tool-cluster <%= key %>-zoom-cluster">
        <button
          type="button"
          id="<%= key %>ZoomToolsToggle"
          class="<%= key %>-tool-toggle-btn header-settings-toggle header-side-control-btn"
          aria-label="Open zoom controls"
          aria-expanded="false"
          title="Icon zoom">
          <i class="bi bi-zoom-in" aria-hidden="true"></i>
        </button>
        <div class="d-flex align-items-center gap-2 <%= key %>-icon-size-wrap <%= key %>-tool-panel <%= key %>-zoom-panel">
          <label for="<%= key %>IconSizeRange" class="small text-muted fw-bold m-0 d-inline-flex align-items-center gap-1 <%= key %>-icon-size-label">
            <i class="bi bi-zoom-in <%= key %>-icon-size-label-icon" aria-hidden="true"></i>
            <span class="<%= key %>-icon-size-label-text">Icon Size</span>
          </label>
          <input id="<%= key %>IconSizeRange" type="range" min="80" max="170" step="5" value="110" class="form-range <%= key %>-icon-range m-0">
          <span id="<%= key %>IconSizeValue" class="small fw-bold text-muted <%= key %>-icon-size-value">110%</span>
        </div>
      </div>
    </div>
  </div>

  <div class="<%= key %>-search-shell">
    <div id="<%= key %>SearchOverlay" class="<%= key %>-search-overlay" hidden>
      <div class="<%= key %>-search-overlay-backdrop" data-role="search-close" aria-hidden="true"></div>
      <div class="<%= key %>-search-overlay-panel">
        <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
          <div class="small fw-semibold text-primary-emphasis text-truncate">
            <i class="bi bi-grid-3x3-gap me-1"></i>
            <%= titleText || 'Dashboard' %> module search
          </div>
          <button type="button" id="<%= key %>SearchClose" class="btn btn-sm btn-outline-secondary px-2 py-1" aria-label="Close search">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
        <div class="position-relative">
          <i class="bi bi-search position-absolute text-muted <%= key %>-search-overlay-icon"></i>
          <input
            type="text"
            id="<%= key %>SearchInput"
            class="form-control <%= key %>-search-overlay-input"
            placeholder="Search modules..."
            autocomplete="off">
          <button type="button" id="<%= key %>SearchClear" class="btn btn-link btn-sm position-absolute text-muted p-0 d-none <%= key %>-search-overlay-clear" title="Clear search" aria-label="Clear search">
            <i class="bi bi-x-lg"></i>
          </button>
        </div>
        <div class="small text-muted mt-2">
          Type to filter modules instantly. Press <kbd>Esc</kbd> to close.
        </div>
      </div>
    </div>
  </div>

  <div id="<%= key %>DashboardContainer"></div>
</div>

<script id="<%= key %>DashboardData" type="application/json"><%- JSON.stringify(sections) %></script>

<style>
  .<%= key %>-dashboard-page {
    position: relative;
    overflow: hidden;
    isolation: isolate;
    /* Align module cards with index (.home-pro .home-card) */
    --ud-home-surface: #ffffff;
    --ud-home-border: #dbe3ee;
    --ud-home-ink: #17223b;
    --ud-home-muted: #5c687d;
    --ud-home-card-shadow: 0 10px 28px rgba(18, 44, 74, 0.07);
    --ud-home-card-shadow-hover: 0 16px 36px rgba(18, 44, 74, 0.12);
    /* Index .home-hero (block with main headline) */
    --ud-home-hero-shadow: 0 16px 40px rgba(17, 48, 79, 0.08);
  }
  .<%= key %>-dashboard-page .<%= key %>-module-card.card,
  .<%= key %>-dashboard-page .<%= key %>-compact-card.card {
    background: var(--ud-home-surface);
    border: 1px solid var(--ud-home-border) !important;
    border-radius: 18px;
    box-shadow: var(--ud-home-card-shadow);
  }
  .<%= key %>-dashboard-page .<%= key %>-card-heading {
    color: var(--ud-home-ink);
  }
  .<%= key %>-dashboard-page .<%= key %>-card-body-text {
    color: var(--ud-home-muted);
  }
  .<%= key %>-dashboard-page .list-group.<%= key %>-module-list {
    border: 1px solid var(--ud-home-border);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: var(--ud-home-card-shadow);
    background: var(--ud-home-surface);
  }
  .<%= key %>-dashboard-page .<%= key %>-module-list .list-group-item {
    border-color: #e2e9f3;
  }
  .<%= key %>-dashboard-page a.<%= key %>-compact-link {
    color: inherit;
  }
  .<%= key %>-dashboard-page a.<%= key %>-compact-link:hover,
  .<%= key %>-dashboard-page a.<%= key %>-compact-link:focus-visible {
    color: inherit;
  }
  /* Match index .home-hero (panel with “We build integrated software systems…”) */
  .<%= key %>-dashboard-banner {
    background:
      radial-gradient(circle at 90% 10%, rgba(10, 102, 194, 0.12), transparent 48%),
      linear-gradient(140deg, #f8fbff 0%, #edf4fb 58%, #e7f0fa 100%);
    border: 1px solid var(--ud-home-border);
    border-radius: 24px;
    box-shadow: var(--ud-home-hero-shadow);
    color: var(--ud-home-ink);
    padding: 1.25rem 1.5rem;
  }
  .<%= key %>-banner-icon-wrap {
    width: 96px;
    height: 96px;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Match index .home-icon.primary */
    background: rgba(10, 102, 194, 0.12);
    color: #0a66c2;
    border-radius: 12px;
    flex-shrink: 0;
  }
  .<%= key %>-banner-icon-wrap i {
    font-size: 3.5rem;
    line-height: 1;
    color: inherit;
  }
  .<%= key %>-banner-icon-wrap img,
  .<%= key %>-banner-icon-wrap .raw-icon-container {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  .<%= key %>-banner-icon-wrap .raw-icon-container {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .<%= key %>-banner-icon-wrap .raw-icon-container > * {
    max-width: 100%;
    max-height: 100%;
  }
  .<%= key %>-dashboard-banner .page-heading {
    color: var(--ud-home-ink) !important;
  }
  .<%= key %>-dashboard-banner .text-muted {
    color: var(--ud-home-muted) !important;
  }
  .<%= key %>-banner-row {
    align-items: flex-start;
  }
  @media (min-width: 768px) {
    .<%= key %>-banner-row {
      flex-direction: row;
      flex-wrap: nowrap;
      justify-content: space-between;
    }
  }
  @media (max-width: 767.98px) {
    .<%= key %>-banner-row {
      flex-direction: column !important;
      flex-wrap: nowrap;
      gap: 0.75rem;
      justify-content: flex-start !important;
    }
  }
  .<%= key %>-banner-title-cluster {
    flex: 1 1 0%;
    min-width: 0;
  }
  @media (max-width: 767.98px) {
    .<%= key %>-banner-title-cluster {
      flex: 0 0 auto;
      width: 100%;
    }
  }
  .<%= key %>-banner-nav {
    flex-shrink: 0;
  }
  @media (min-width: 768px) {
    .<%= key %>-banner-nav {
      width: 15.5rem;
      max-width: 15.5rem;
    }
  }
  @media (max-width: 767.98px) {
    .<%= key %>-banner-nav {
      width: 100%;
      max-width: none;
      flex-direction: row !important;
      flex-wrap: nowrap;
      align-items: stretch;
      align-self: stretch;
      gap: 0.5rem;
    }
    .<%= key %>-banner-nav .<%= key %>-banner-btn {
      flex: 1 1 0;
      min-width: 0;
      min-height: 2.125rem;
      padding: 0.35rem 0.5rem;
      font-size: 0.8125rem;
      justify-content: center;
      width: auto;
    }
    .<%= key %>-banner-nav .<%= key %>-banner-btn-icon {
      font-size: 1.2rem;
      line-height: 1;
    }
  }
  @media (min-width: 576px) and (max-width: 767.98px) {
    .<%= key %>-banner-nav .<%= key %>-banner-btn-icon {
      margin-inline-end: 0.45rem;
    }
  }
  @media (max-width: 575.98px) {
    .<%= key %>-dashboard-banner {
      padding: 1rem 1rem;
    }
    .<%= key %>-banner-nav .<%= key %>-banner-btn {
      min-height: 2.4rem;
    }
    .<%= key %>-banner-icon-wrap {
      width: 56px;
      height: 56px;
      border-radius: 10px;
    }
    .<%= key %>-banner-icon-wrap i {
      font-size: 1.85rem;
    }
    .<%= key %>-banner-heading {
      font-size: clamp(1.05rem, 4.5vw, 1.35rem);
      line-height: 1.25;
    }
    .<%= key %>-banner-nav .<%= key %>-banner-btn-icon {
      margin-inline-end: 0;
      font-size: 1.35rem;
    }
    .<%= key %>-banner-nav .<%= key %>-banner-btn-label {
      position: absolute !important;
      width: 1px !important;
      height: 1px !important;
      padding: 0 !important;
      margin: -1px !important;
      overflow: hidden !important;
      clip: rect(0, 0, 0, 0) !important;
      white-space: nowrap !important;
      border: 0 !important;
    }
  }
  .<%= key %>-banner-text-block {
    min-width: 0;
    flex: 1 1 0%;
    max-width: 100%;
  }
  .<%= key %>-banner-heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.55rem;
    min-width: 0;
  }
  .<%= key %>-banner-heading-row .<%= key %>-banner-heading {
    min-width: 0;
    flex: 1 1 auto;
  }
  .<%= key %>-mobile-banner-actions {
    flex-shrink: 0;
    margin-inline-start: auto;
  }
  .<%= key %>-mobile-banner-btn {
    width: 2.25rem;
    min-width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border-radius: 0.7rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1.25rem;
    line-height: 1;
  }
  .<%= key %>-banner-subtitle {
    white-space: pre-line;
    word-wrap: break-word;
    overflow-wrap: break-word;
    line-height: 1.5;
    max-width: 100%;
  }
  .<%= key %>-banner-btn {
    position: relative;
    width: 100%;
    min-height: 2.5rem;
    padding: 0.5rem 0.65rem;
    display: inline-flex !important;
    align-items: center;
    justify-content: flex-start;
    text-align: start;
    gap: 0;
    font-size: 0.875rem;
    line-height: 1.25;
    white-space: normal;
  }
  @media (min-width: 768px) {
    .<%= key %>-banner-btn-icon {
      font-size: 1.1rem;
      line-height: 1;
      margin-inline-end: 0.45rem;
    }
  }
  .<%= key %>-banner-btn-label {
    min-width: 0;
    flex: 1 1 auto;
    text-align: start;
    word-break: break-word;
  }
  .<%= key %>-page-watermark {
    position: absolute;
    right: -24px;
    top: 12px;
    width: 280px;
    height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.055;
    color: var(--bs-secondary);
    pointer-events: none;
    z-index: 0;
  }
  .<%= key %>-page-watermark i {
    font-size: 14rem;
    line-height: 1;
  }
  .<%= key %>-page-watermark img,
  .<%= key %>-page-watermark .raw-icon-container {
    width: 100%;
    height: 100%;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: flex;
    align-items: center;
    justify-content: center;
    filter: grayscale(1) saturate(0) contrast(0.86);
  }
  .<%= key %>-page-watermark .raw-icon-container > * {
    max-width: 100%;
    max-height: 100%;
  }
  .<%= key %>-dashboard-page > :not(.<%= key %>-page-watermark) {
    position: relative;
    z-index: 1;
  }

  .<%= key %>-module-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  .<%= key %>-card-watermark {
    position: absolute;
    right: -10px;
    bottom: -18px;
    width: 140px;
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.13;
    pointer-events: none;
    z-index: 0;
    color: var(--bs-secondary);
  }
  .<%= key %>-card-watermark i {
    font-size: 7rem;
    line-height: 1;
  }
  .<%= key %>-card-watermark img,
  .<%= key %>-card-watermark .raw-icon-container {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: grayscale(1) saturate(0) contrast(0.88);
  }
  .<%= key %>-card-content {
    position: relative;
    z-index: 1;
  }

  .<%= key %>-compact-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
  }
  .<%= key %>-compact-watermark {
    position: absolute;
    right: -6px;
    bottom: -10px;
    width: 84px;
    height: 84px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.11;
    pointer-events: none;
    z-index: 0;
    color: var(--bs-secondary);
  }
  .<%= key %>-compact-watermark i {
    font-size: 4.4rem;
    line-height: 1;
  }
  .<%= key %>-compact-watermark img,
  .<%= key %>-compact-watermark .raw-icon-container {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: grayscale(1) saturate(0) contrast(0.88);
  }
  .<%= key %>-compact-content {
    position: relative;
    z-index: 1;
  }

  .<%= key %>-dashboard-icon { overflow: hidden; flex-shrink: 0; }
  .<%= key %>-dashboard-icon-lg { width: 50px; height: 50px; font-size: 1.25rem; }
  .<%= key %>-dashboard-icon-sm { width: 42px; height: 42px; font-size: 1.05rem; }
  .<%= key %>-card-title {
    min-height: 2.6rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .<%= key %>-card-desc {
    min-height: 2.5rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .<%= key %>-hover-shadow { transition: transform 0.2s ease, box-shadow 0.2s ease; }
  .<%= key %>-hover-shadow:hover {
    transform: translateY(-3px);
    box-shadow: var(--ud-home-card-shadow-hover) !important;
  }
  .<%= key %>-list-item { transition: background-color 0.2s ease; }
  .<%= key %>-list-item:hover {
    background: linear-gradient(180deg, #ffffff, #f9fcff);
  }
  .<%= key %>-tools-controls {
    justify-content: flex-end;
  }
  .<%= key %>-tool-cluster {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .<%= key %>-tool-toggle-btn {
    display: none;
  }
  .<%= key %>-tool-panel {
    display: flex;
  }
  .<%= key %>-view-panel {
    display: inline-flex;
  }
  .<%= key %>-zoom-panel {
    display: flex;
  }
  .<%= key %>-icon-size-wrap { min-width: 240px; }
  .<%= key %>-icon-range { width: 120px; }
  .<%= key %>-compact-card { min-height: 88px; }
  .<%= key %>-view-btn-group .<%= key %>-view-btn {
    width: 2.75rem;
    height: 2.5rem;
    min-width: 2.75rem;
    padding: 0;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    line-height: 1;
  }
  .<%= key %>-view-btn-group .<%= key %>-view-btn:first-child {
    border-top-left-radius: 0.375rem;
    border-bottom-left-radius: 0.375rem;
  }
  .<%= key %>-view-btn-group .<%= key %>-view-btn:last-child {
    border-top-right-radius: 0.375rem;
    border-bottom-right-radius: 0.375rem;
  }
  @media (max-width: 767.98px) {
    .<%= key %>-dashboard-page {
      overflow: visible;
    }
    .<%= key %>-tools-row {
      position: relative;
      z-index: 2200;
      overflow: visible;
      align-items: center !important;
      justify-content: space-between !important;
      flex-wrap: nowrap;
      gap: 0.6rem;
    }
    .<%= key %>-tools-controls {
      position: static;
      z-index: auto;
      justify-content: flex-end !important;
      align-items: center !important;
      flex-direction: row;
      width: auto;
      gap: 0.5rem !important;
      order: 2;
      margin-left: auto;
      padding: 0;
      flex: 0 0 auto;
      position: relative;
      z-index: 2210;
      overflow: visible;
    }
    .<%= key %>-tool-cluster {
      position: relative;
      width: auto;
      justify-content: flex-end;
      gap: 0;
      z-index: 2220;
    }
    .<%= key %>-tool-toggle-btn {
      display: inline-flex;
    }
    .<%= key %>-tool-panel {
      position: absolute;
      top: auto;
      bottom: calc(100% + 8px);
      left: auto;
      right: 0;
      display: none !important;
      align-items: center;
      gap: 0.4rem;
      padding: 0.38rem;
      border-radius: 12px;
      border: 1px solid #d1d9e6;
      background: #ffffff;
      box-shadow: 0 8px 20px rgba(0, 0, 0, 0.14);
      z-index: 2300;
      max-width: calc(100vw - 16px);
      transform-origin: bottom right;
      will-change: transform;
      pointer-events: auto;
    }
    .<%= key %>-tool-cluster.is-open .<%= key %>-tool-panel {
      display: flex !important;
    }
    .<%= key %>-view-panel .<%= key %>-view-btn {
      width: 38px;
      min-width: 38px;
      height: 38px;
      border-radius: 8px !important;
    }
    .<%= key %>-module-meta {
      order: 1;
      margin-inline-start: 0;
      flex: 1 1 auto;
      min-width: 0;
    }
    .<%= key %>-module-count-wrap {
      order: 2;
      margin-inline-start: 0;
    }
    .<%= key %>-zoom-panel {
      min-width: 170px;
      max-width: min(210px, calc(100vw - 16px));
    }
    .<%= key %>-zoom-panel.<%= key %>-icon-size-wrap {
      min-width: 0;
      width: auto;
      gap: 0.42rem;
      flex-direction: row;
      align-items: center !important;
    }
    .<%= key %>-icon-range {
      width: 108px;
      height: 16px;
      transform: none;
      margin-block: 0;
    }
    .<%= key %>-icon-size-value {
      font-size: 0.72rem;
      line-height: 1.1;
    }
    .<%= key %>-icon-size-label-text {
      display: none;
    }
    .<%= key %>-icon-size-label-icon {
      font-size: 0.92rem;
      line-height: 1;
    }
  }
  @media (max-width: 575.98px) {
    .<%= key %>-tools-controls { gap: 0.45rem !important; }
  }

  .<%= key %>-search-shell {
    position: relative;
    z-index: 6;
  }
  .<%= key %>-module-meta {
    min-height: 38px;
  }
  .<%= key %>-search-launcher {
    height: 36px;
    min-width: 0;
    width: auto;
    padding: 0.35rem 0.75rem;
    border-radius: 999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    color: #475569;
    background:
      linear-gradient(120deg, rgba(255, 255, 255, 0.96), rgba(255, 255, 255, 0.84));
  }
  .<%= key %>-search-launcher:hover,
  .<%= key %>-search-launcher:focus-visible {
    color: #0f172a;
    border-color: rgba(13, 110, 253, 0.42);
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.14);
  }
  .<%= key %>-search-overlay {
    position: fixed;
    inset-inline: 0;
    top: var(--<%= key %>-search-overlay-top, 0px);
    bottom: 0;
    z-index: 1090;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    --<%= key %>-search-overlay-inline-pad: clamp(0.5rem, 2.4vw, 1.75rem);
    padding:
      clamp(0.5rem, 2vh, 1rem)
      var(--<%= key %>-search-overlay-inline-pad)
      max(0.75rem, env(safe-area-inset-bottom));
    pointer-events: none;
  }
  .<%= key %>-search-overlay[hidden] {
    display: none !important;
  }
  .<%= key %>-search-overlay.is-open {
    pointer-events: auto;
  }
  .<%= key %>-search-overlay-backdrop {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(920px 320px at 50% 110px, rgba(59, 130, 246, 0.15), rgba(59, 130, 246, 0)),
      linear-gradient(180deg, rgba(15, 23, 42, 0.10), rgba(15, 23, 42, 0.02));
    opacity: 0;
    transition: opacity 0.2s ease;
  }
  .<%= key %>-search-overlay-panel {
    position: relative;
    width: min(980px, calc(100vw - (2 * var(--<%= key %>-search-overlay-inline-pad))));
    max-width: calc(100vw - (2 * var(--<%= key %>-search-overlay-inline-pad)));
    min-width: 0;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.46);
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.93), rgba(255, 255, 255, 0.76));
    box-shadow: 0 26px 62px rgba(15, 23, 42, 0.26);
    backdrop-filter: blur(9px);
    -webkit-backdrop-filter: blur(9px);
    padding: 1rem 1rem 0.9rem;
    opacity: 0;
    transform: translateY(-16px) scale(0.92);
    transition: opacity 0.2s ease, transform 0.24s ease;
  }
  .<%= key %>-search-overlay-panel::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 22px;
    border: 1px solid rgba(255, 255, 255, 0.34);
    pointer-events: none;
  }
  .<%= key %>-search-overlay.is-open .<%= key %>-search-overlay-backdrop {
    opacity: 1;
  }
  .<%= key %>-search-overlay.is-open .<%= key %>-search-overlay-panel {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  .<%= key %>-search-overlay-icon {
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.05rem;
  }
  .<%= key %>-search-overlay-input {
    min-height: 58px;
    border-radius: 16px;
    font-size: clamp(1rem, 2.2vw, 1.16rem);
    padding-left: 2.65rem;
    padding-right: 2.1rem;
    border-color: rgba(148, 163, 184, 0.48);
  }
  .<%= key %>-search-overlay-input:focus {
    border-color: rgba(37, 99, 235, 0.55);
    box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.16);
  }
  .<%= key %>-search-overlay-clear {
    right: 11px;
    top: 50%;
    transform: translateY(-50%);
  }
  @media (max-width: 1199.98px) {
    .<%= key %>-search-overlay-panel {
      width: min(900px, calc(100vw - 1.6rem));
    }
  }
  @media (max-width: 991.98px) {
    .<%= key %>-search-overlay-panel {
      width: min(760px, calc(100vw - 1.2rem));
    }
  }
  @media (max-width: 767.98px) {
    .<%= key %>-search-overlay-panel {
      width: min(640px, calc(100vw - 1rem));
    }
  }
  @media (max-width: 575.98px) {
    .<%= key %>-search-launcher {
      height: 34px;
      padding-inline: 0.65rem;
    }
    .<%= key %>-search-overlay {
      --<%= key %>-search-overlay-inline-pad: 0.5rem;
      padding-top: clamp(0.4rem, 1.8vh, 0.85rem);
    }
    .<%= key %>-search-overlay-panel {
      width: calc(100vw - 1rem);
      max-width: calc(100vw - 1rem);
      padding: 0.85rem 0.8rem 0.75rem;
      border-radius: 18px;
    }
    .<%= key %>-search-overlay-panel::before {
      border-radius: 18px;
    }
    .<%= key %>-search-overlay-input {
      min-height: 52px;
      font-size: 1rem;
      border-radius: 14px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const dataEl = document.getElementById('<%= key %>DashboardData');
    const container = document.getElementById('<%= key %>DashboardContainer');
    const viewBtns = document.querySelectorAll('.<%= key %>-view-btn');
    const iconSizeRangeEl = document.getElementById('<%= key %>IconSizeRange');
    const iconSizeValueEl = document.getElementById('<%= key %>IconSizeValue');
    const searchLauncherEl = document.getElementById('<%= key %>SearchLauncher');
    const searchLauncherTextEl = document.getElementById('<%= key %>SearchLauncherText');
    const searchOverlayEl = document.getElementById('<%= key %>SearchOverlay');
    const searchCloseEl = document.getElementById('<%= key %>SearchClose');
    const searchInputEl = document.getElementById('<%= key %>SearchInput');
    const searchClearBtn = document.getElementById('<%= key %>SearchClear');
    const moduleCountEl = document.getElementById('<%= key %>ModuleCount');
    const toolsControlsEl = document.querySelector('.<%= key %>-tools-controls');
    const viewClusterEl = toolsControlsEl ? toolsControlsEl.querySelector('.<%= key %>-view-cluster') : null;
    const zoomClusterEl = toolsControlsEl ? toolsControlsEl.querySelector('.<%= key %>-zoom-cluster') : null;
    const viewToolsToggleEl = document.getElementById('<%= key %>ViewToolsToggle');
    const zoomToolsToggleEl = document.getElementById('<%= key %>ZoomToolsToggle');
    const VIEW_KEY = '<%= viewKey %>';
    const ICON_SIZE_KEY = '<%= sizeKey %>';
    const SEARCH_KEY = '<%= key %>DashboardSearch';

    const allModules = (() => {
      try { return JSON.parse(dataEl?.textContent || '[]'); } catch (_) { return []; }
    })();

    let currentView = localStorage.getItem(VIEW_KEY) || 'compact';
    let iconSizePercent = Number(localStorage.getItem(ICON_SIZE_KEY) || 110);
    let searchQuery = localStorage.getItem(SEARCH_KEY) || '';
    let searchOverlayCloseTimer = null;
    if (!Number.isFinite(iconSizePercent) || iconSizePercent < 80 || iconSizePercent > 170) iconSizePercent = 110;

    function updateSearchLauncher() {
      if (!searchLauncherTextEl) return;
      searchLauncherTextEl.textContent = 'Search';
    }

    function resolveSearchOverlayTopOffset() {
      const headerEl = document.getElementById('main-header');
      const fallbackTop = 8;
      if (!(headerEl instanceof HTMLElement)) return fallbackTop;
      if (headerEl.classList.contains('header-minimized')) return fallbackTop;
      const headerRect = headerEl.getBoundingClientRect();
      const headerBottom = Math.max(0, Number(headerRect.bottom || 0));
      const viewportHeight = Math.max(0, window.innerHeight || document.documentElement.clientHeight || 0);
      const clamped = Math.min(Math.round(headerBottom + 8), Math.max(0, viewportHeight - 80));
      return Number.isFinite(clamped) ? Math.max(fallbackTop, clamped) : fallbackTop;
    }

    function syncSearchOverlayLayout() {
      if (!searchOverlayEl) return;
      const topOffset = resolveSearchOverlayTopOffset();
      searchOverlayEl.style.setProperty('--<%= key %>-search-overlay-top', `${topOffset}px`);
    }

    function setClusterOpenState(clusterEl, toggleEl, open) {
      if (!clusterEl || !toggleEl) return;
      clusterEl.classList.toggle('is-open', Boolean(open));
      toggleEl.setAttribute('aria-expanded', open ? 'true' : 'false');
    }

    function closeAllToolClusters(except = null) {
      if (viewClusterEl && viewToolsToggleEl && viewClusterEl !== except) {
        setClusterOpenState(viewClusterEl, viewToolsToggleEl, false);
      }
      if (zoomClusterEl && zoomToolsToggleEl && zoomClusterEl !== except) {
        setClusterOpenState(zoomClusterEl, zoomToolsToggleEl, false);
      }
    }

    function bindMobileToolClusterToggle(toggleEl, clusterEl) {
      if (!toggleEl || !clusterEl) return;
      toggleEl.addEventListener('click', function (event) {
        event.preventDefault();
        event.stopPropagation();
        const nextOpen = !clusterEl.classList.contains('is-open');
        closeAllToolClusters(nextOpen ? clusterEl : null);
        setClusterOpenState(clusterEl, toggleEl, nextOpen);
        if (nextOpen) {
          window.requestAnimationFrame(() => {
            positionToolPanelWithinViewport(clusterEl);
          });
        }
      });
    }

    function positionToolPanelWithinViewport(clusterEl) {
      if (!clusterEl || !window.matchMedia || !window.matchMedia('(max-width: 767.98px)').matches) return;
      const panelEl = clusterEl.querySelector('.<%= key %>-tool-panel');
      if (!panelEl) return;
      const margin = 8;

      panelEl.style.left = 'auto';
      panelEl.style.right = '0';
      panelEl.style.top = 'auto';
      panelEl.style.bottom = 'calc(100% + 8px)';
      panelEl.style.transform = 'translate3d(0, 0, 0)';

      let panelRect = panelEl.getBoundingClientRect();
      let shiftX = 0;
      let shiftY = 0;
      const viewportWidth = window.innerWidth || document.documentElement.clientWidth || 0;
      const viewportHeight = window.innerHeight || document.documentElement.clientHeight || 0;
      let opensUpward = true;

      if (panelRect.top < margin) {
        const clusterRect = clusterEl.getBoundingClientRect();
        const spaceAbove = clusterRect.top - margin;
        const spaceBelow = viewportHeight - clusterRect.bottom - margin;
        if (spaceBelow > spaceAbove) {
          panelEl.style.top = 'calc(100% + 8px)';
          panelEl.style.bottom = 'auto';
          panelRect = panelEl.getBoundingClientRect();
          opensUpward = false;
        }
      }

      if (panelRect.right > (viewportWidth - margin)) {
        shiftX -= (panelRect.right - (viewportWidth - margin));
      }
      if (panelRect.left < margin) {
        shiftX += (margin - panelRect.left);
      }

      if (opensUpward) {
        if (panelRect.top < margin) {
          shiftY += (margin - panelRect.top);
        }
        if (panelRect.bottom > (viewportHeight - margin)) {
          shiftY -= (panelRect.bottom - (viewportHeight - margin));
        }
      } else {
        if (panelRect.bottom > (viewportHeight - margin)) {
          shiftY -= (panelRect.bottom - (viewportHeight - margin));
        }
        if (panelRect.top < margin) {
          shiftY += (margin - panelRect.top);
        }
      }

      panelEl.style.transform = `translate3d(${Math.round(shiftX)}px, ${Math.round(shiftY)}px, 0)`;
    }

    function openSearchOverlay() {
      if (!searchOverlayEl) return;
      syncSearchOverlayLayout();
      if (searchOverlayCloseTimer) {
        clearTimeout(searchOverlayCloseTimer);
        searchOverlayCloseTimer = null;
      }
      searchOverlayEl.hidden = false;
      window.requestAnimationFrame(() => {
        searchOverlayEl.classList.add('is-open');
      });
      if (searchLauncherEl) searchLauncherEl.setAttribute('aria-expanded', 'true');
      window.setTimeout(() => {
        if (searchInputEl) {
          searchInputEl.focus({ preventScroll: true });
          searchInputEl.select();
        }
      }, 55);
    }

    function closeSearchOverlay(options = {}) {
      if (!searchOverlayEl || searchOverlayEl.hidden) return;
      const shouldFocusLauncher = options && options.focusLauncher === true;
      searchOverlayEl.classList.remove('is-open');
      if (searchLauncherEl) searchLauncherEl.setAttribute('aria-expanded', 'false');
      if (searchOverlayCloseTimer) clearTimeout(searchOverlayCloseTimer);
      searchOverlayCloseTimer = window.setTimeout(() => {
        searchOverlayEl.hidden = true;
      }, 220);
      if (shouldFocusLauncher && searchLauncherEl) {
        window.setTimeout(() => searchLauncherEl.focus({ preventScroll: true }), 40);
      }
    }

    function getFilteredModules() {
      const q = String(searchQuery || '').trim().toLowerCase();
      if (!q) return allModules;
      return allModules.filter(m => {
        const title = String(m.title || '').toLowerCase();
        const desc = String(m.description || '').toLowerCase();
        return title.includes(q) || desc.includes(q);
      });
    }

    function updateModuleCount(filteredLen, totalLen) {
      if (!moduleCountEl) return;
      if (totalLen === 0) {
        moduleCountEl.innerHTML = '<i class="bi bi-grid-3x3-gap me-1"></i><strong>0</strong> modules';
      } else if (filteredLen < totalLen) {
        moduleCountEl.innerHTML = '<i class="bi bi-grid-3x3-gap me-1"></i><strong>' + filteredLen + '</strong> of <strong>' + totalLen + '</strong> modules';
      } else {
        moduleCountEl.innerHTML = '<i class="bi bi-grid-3x3-gap me-1"></i><strong>' + totalLen + '</strong> modules';
      }
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function renderIcon(section, iconSizeClass) {
      const subtleClass = section.subtleClass || '';
      const iconStyle = section.iconStyle || '';
      const defaultClass = section.icon || 'bi-grid-fill';
      const isLg = iconSizeClass === '<%= key %>-dashboard-icon-lg';
      const baseSize = isLg ? 50 : 42;
      const baseFont = isLg ? 1.25 : 1.05;
      const ratio = iconSizePercent / 100;
      const scaledPx = Math.round(baseSize * ratio);
      const scaledFontRem = (baseFont * ratio).toFixed(2);
      const dynamicStyle = `width:${scaledPx}px;height:${scaledPx}px;font-size:${scaledFontRem}rem;`;

      let iconContent = `<i class="bi ${escapeHtml(defaultClass)}"></i>`;
      if (section && section.customIcon) {
        const type = String(section.customIcon.type || '').toLowerCase();
        const val = String(section.customIcon.value || '').trim();
        if (type === 'class' && val) iconContent = `<i class="${escapeHtml(val)}"></i>`;
        else if (type === 'image' && val) iconContent = `<img src="${escapeHtml(val)}" alt="" style="width:100%;height:100%;object-fit:contain;">`;
        else if (type === 'raw' && val) iconContent = `<div class="raw-icon-container" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">${val}</div>`;
      }

      return `
        <div class="rounded-circle d-flex align-items-center justify-content-center <%= key %>-dashboard-icon ${iconSizeClass} ${subtleClass}" style="${dynamicStyle}${iconStyle}">
          ${iconContent}
        </div>
      `;
    }

    function renderWatermarkIcon(section, defaultClass) {
      if (section && section.customIcon) {
        const type = String(section.customIcon.type || '').toLowerCase();
        const val = String(section.customIcon.value || '').trim();
        if (type === 'class' && val) return `<i class="${escapeHtml(val)}"></i>`;
        if (type === 'image' && val) return `<img src="${escapeHtml(val)}" alt="" style="width:100%;height:100%;object-fit:contain;">`;
        if (type === 'raw' && val) return `<div class="raw-icon-container" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">${val}</div>`;
      }
      return `<i class="bi ${escapeHtml(section?.icon || defaultClass || 'bi-grid-fill')}"></i>`;
    }

    function renderCardView(modules) {
      return `
        <div class="row g-3">
          ${(modules || []).map(section => `
            <div class="col-md-6 col-xl-4">
              <div class="card h-100 <%= key %>-hover-shadow <%= key %>-module-card">
                <div class="<%= key %>-card-watermark" aria-hidden="true">${renderWatermarkIcon(section, 'bi-grid-fill')}</div>
                <div class="card-body p-3 d-flex flex-column <%= key %>-card-content">
                  <div class="d-flex align-items-center gap-3 mb-2">
                    ${renderIcon(section, '<%= key %>-dashboard-icon-lg')}
                    <h6 class="fw-bold mb-0 <%= key %>-card-title <%= key %>-card-heading" title="${escapeHtml(section.title)}">${escapeHtml(section.title)}</h6>
                  </div>
                  <p class="small mb-3 <%= key %>-card-desc <%= key %>-card-body-text" title="${escapeHtml(section.description)}">${escapeHtml(section.description || '')}</p>
                  <a href="${escapeHtml(section.href)}" class="${escapeHtml(section.buttonClass || 'btn btn-primary')} btn-sm mt-auto" style="${escapeHtml(section.buttonStyle || '')}">
                    ${escapeHtml(section.buttonLabel || 'Open')} <i class="bi bi-arrow-right ms-1"></i>
                  </a>
                </div>
              </div>
            </div>
          `).join('')}
        </div>
      `;
    }

    function renderCompactView(modules) {
      return `
        <div class="row g-2">
          ${(modules || []).map(section => `
            <div class="col-6 col-md-6 col-lg-4 col-xl-4 col-xxl-3">
              <a href="${escapeHtml(section.href)}" class="text-decoration-none d-block h-100 <%= key %>-compact-link">
                <div class="card h-100 <%= key %>-hover-shadow <%= key %>-compact-card">
                  <div class="<%= key %>-compact-watermark" aria-hidden="true">${renderWatermarkIcon(section, 'bi-grid-fill')}</div>
                  <div class="card-body p-3 d-flex align-items-center gap-3 <%= key %>-compact-content">
                    ${renderIcon(section, '<%= key %>-dashboard-icon-sm')}
                    <div class="fw-bold text-truncate <%= key %>-card-heading" style="font-size: 0.95rem;" title="${escapeHtml(section.title)}">${escapeHtml(section.title)}</div>
                  </div>
                </div>
              </a>
            </div>
          `).join('')}
        </div>
      `;
    }

    function renderListView(modules) {
      return `
        <div class="list-group rounded <%= key %>-module-list">
          ${(modules || []).map(section => `
            <a href="${escapeHtml(section.href)}" class="list-group-item list-group-item-action d-flex align-items-center gap-3 py-2 <%= key %>-list-item">
              ${renderIcon(section, '<%= key %>-dashboard-icon-sm')}
              <div class="flex-grow-1 min-w-0">
                <div class="fw-bold small text-truncate <%= key %>-card-heading" title="${escapeHtml(section.title)}">${escapeHtml(section.title)}</div>
                <div class="<%= key %>-card-body-text" style="font-size: 0.78rem; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden;">
                  ${escapeHtml(section.description || '')}
                </div>
              </div>
              <i class="bi bi-chevron-right text-muted"></i>
            </a>
          `).join('')}
        </div>
      `;
    }

    function updateViewButtons() {
      viewBtns.forEach(btn => {
        const active = btn.dataset.view === currentView;
        btn.classList.toggle('active', active);
        btn.classList.toggle('bg-secondary', active);
        btn.classList.toggle('text-white', active);
        btn.classList.toggle('btn-outline-secondary', !active);
      });
    }

    function updateIconSizeUI() {
      if (iconSizeRangeEl) iconSizeRangeEl.value = String(iconSizePercent);
      if (iconSizeValueEl) iconSizeValueEl.textContent = `${iconSizePercent}%`;
    }

    function render() {
      const modules = getFilteredModules();
      updateModuleCount(modules.length, allModules.length);

      if (!modules.length) {
        const msg = allModules.length > 0
          ? 'No modules match your search.'
          : 'No modules available.';
        container.innerHTML = '<div class="alert alert-light border text-center p-4">' + msg + '</div>';
        updateViewButtons();
        return;
      }
      if (currentView === 'list') container.innerHTML = renderListView(modules);
      else if (currentView === 'card') container.innerHTML = renderCardView(modules);
      else container.innerHTML = renderCompactView(modules);
      updateViewButtons();
    }

    viewBtns.forEach(btn => {
      btn.addEventListener('click', function () {
        currentView = btn.dataset.view || 'compact';
        localStorage.setItem(VIEW_KEY, currentView);
        render();
        if (window.matchMedia && window.matchMedia('(max-width: 767.98px)').matches) {
          closeAllToolClusters();
        }
      });
    });

    if (iconSizeRangeEl) {
      iconSizeRangeEl.addEventListener('input', function () {
        const next = Number(iconSizeRangeEl.value || 110);
        if (!Number.isFinite(next)) return;
        iconSizePercent = Math.min(170, Math.max(80, next));
        localStorage.setItem(ICON_SIZE_KEY, String(iconSizePercent));
        updateIconSizeUI();
        render();
      });
    }

    if (searchInputEl) {
      searchInputEl.value = searchQuery;
      searchInputEl.addEventListener('input', function () {
        searchQuery = searchInputEl.value.trim();
        localStorage.setItem(SEARCH_KEY, searchQuery);
        updateSearchLauncher();
        if (searchClearBtn) searchClearBtn.classList.toggle('d-none', !searchQuery);
        render();
      });
      searchInputEl.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') {
          event.preventDefault();
          closeSearchOverlay({ focusLauncher: true });
        }
      });
    }

    if (searchClearBtn) {
      searchClearBtn.classList.toggle('d-none', !searchQuery);
      searchClearBtn.addEventListener('click', function () {
        searchQuery = '';
        localStorage.removeItem(SEARCH_KEY);
        updateSearchLauncher();
        if (searchInputEl) { searchInputEl.value = ''; searchInputEl.focus(); }
        searchClearBtn.classList.add('d-none');
        render();
      });
    }

    if (searchLauncherEl) {
      searchLauncherEl.addEventListener('click', function () {
        openSearchOverlay();
      });
    }

    if (searchCloseEl) {
      searchCloseEl.addEventListener('click', function () {
        closeSearchOverlay({ focusLauncher: true });
      });
    }

    if (searchOverlayEl) {
      searchOverlayEl.addEventListener('click', function (event) {
        const target = event.target;
        if (!(target instanceof HTMLElement)) return;
        if (target.dataset.role === 'search-close') {
          closeSearchOverlay({ focusLauncher: true });
        }
      });
    }

    document.addEventListener('keydown', function (event) {
      if (event.key !== 'Escape') return;
      if (searchOverlayEl && !searchOverlayEl.hidden) {
        closeSearchOverlay({ focusLauncher: true });
        return;
      }
      closeAllToolClusters();
    });

    bindMobileToolClusterToggle(viewToolsToggleEl, viewClusterEl);
    bindMobileToolClusterToggle(zoomToolsToggleEl, zoomClusterEl);

    document.addEventListener('click', function (event) {
      const target = event.target;
      if (!(target instanceof Element)) return;
      if (toolsControlsEl && toolsControlsEl.contains(target)) return;
      closeAllToolClusters();
    });

    window.addEventListener('resize', function () {
      if (viewClusterEl && viewClusterEl.classList.contains('is-open')) {
        positionToolPanelWithinViewport(viewClusterEl);
      }
      if (zoomClusterEl && zoomClusterEl.classList.contains('is-open')) {
        positionToolPanelWithinViewport(zoomClusterEl);
      }
      if (searchOverlayEl && !searchOverlayEl.hidden) {
        syncSearchOverlayLayout();
      }
    });

    window.addEventListener('scroll', function () {
      if (searchOverlayEl && !searchOverlayEl.hidden) {
        syncSearchOverlayLayout();
      }
    }, { passive: true });

    updateSearchLauncher();
    updateIconSizeUI();
    syncSearchOverlayLayout();
    render();

    <% if (backHref && backLabel) { %>
    (function () {
      const prevBtns = document.querySelectorAll('.<%= key %>-btn-previous-menu');
      const fallbackHref = <%- JSON.stringify(backHref) %>;
      if (prevBtns && prevBtns.length) {
        prevBtns.forEach((prevBtn) => prevBtn.addEventListener('click', function () {
          if (window.history.length > 1) {
            window.history.back();
          } else {
            window.location.href = fallbackHref;
          }
        }));
      }
    })();
    <% } %>
  });
</script>
