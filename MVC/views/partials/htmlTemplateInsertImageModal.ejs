<%
  const modalId = String(htmlTemplateInsertImageModalId || 'htmlTemplateInsertImageModal').trim();
%>

<div class="modal fade" id="<%= modalId %>" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-light">
        <h5 class="modal-title d-flex align-items-center gap-2">
          <i class="bi bi-image text-primary"></i>
          Insert Image
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label small text-muted fw-bold text-uppercase">Image URL</label>
          <input type="text" class="form-control" id="htmlTemplateImageUrlInput" placeholder="https://... or /uploads/...">
        </div>
        <div class="mb-2">
          <label class="form-label small text-muted fw-bold text-uppercase">Alt Text (Optional)</label>
          <input type="text" class="form-control" id="htmlTemplateImageAltInput" placeholder="Describe this image">
        </div>
        <div class="small text-muted">
          Choose one method below to insert image into the template.
        </div>
      </div>
      <div class="modal-footer d-flex justify-content-end">
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-outline-primary" id="htmlTemplateInsertImageFromUrlBtn">
            <i class="bi bi-check2-circle me-1"></i>Insert From URL
          </button>
          <button type="button" class="btn btn-primary" id="htmlTemplateOpenSavedImageLibraryBtn">
            <i class="bi bi-collection-play me-1"></i>Insert From Saved Media Library
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
