<%
  const editorId = String(id || 'htmlTemplateEditor').trim();
  const fieldName = String(name || 'htmlTemplate').trim();
  const fieldId = String(sourceId || (editorId + 'Source')).trim();
  const labelText = String(label || 'HTML Template').trim();
  const initialValue = String(value == null ? '' : value);
  const tokenPlaceholder = String(tokenPlaceholderText || 'Type or paste a token (for example {{RESET_CODE}})').trim();
  const helperText = String(helper || '').trim();
  const rowsValue = Math.max(8, Number.parseInt(String(rows || 14), 10) || 14);
  const defaultMode = String(mode === 'code' ? 'code' : 'design');
%>

<style>
  .html-template-editor {
    border: 1px solid var(--bs-border-color);
    border-radius: 0.65rem;
    overflow: hidden;
    background: #fff;
  }
  .html-template-editor-toolbar {
    border-bottom: 1px solid var(--bs-border-color);
    background: var(--bs-light-bg-subtle, #f8f9fa);
    padding: 0.55rem 0.65rem;
  }
  .html-template-editor-toolbar .btn {
    --bs-btn-padding-y: 0.22rem;
    --bs-btn-padding-x: 0.45rem;
    --bs-btn-font-size: 0.8rem;
  }
  .html-template-editor-body {
    min-height: 520px;
  }
  .html-template-editor-main {
    min-width: 0;
  }
  .html-template-editor-visual {
    min-height: 500px;
    max-height: 72vh;
    overflow: auto;
    padding: 0.85rem;
    font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
    line-height: 1.55;
    font-size: 0.95rem;
    outline: none;
  }
  .html-template-editor-visual img {
    max-width: 100%;
    height: auto;
  }
  .html-template-editor-visual img.__hte-selected-image {
    outline: 2px solid #0d6efd;
    outline-offset: 2px;
  }
  .html-template-editor-visual:empty:before {
    content: attr(data-placeholder);
    color: #8b949e;
    pointer-events: none;
  }
  .html-template-editor-code {
    border: 0;
    border-radius: 0;
    min-height: 500px;
    resize: vertical;
    box-shadow: none !important;
    font-size: 0.86rem;
    line-height: 1.5;
  }
  .html-template-editor-footer {
    border-top: 1px solid var(--bs-border-color);
    background: var(--bs-light-bg-subtle, #f8f9fa);
    padding: 0.5rem 0.65rem;
  }
</style>

<div class="mb-3">
  <label class="form-label fw-bold small text-muted text-uppercase"><%= labelText %> <span class="text-danger">*</span></label>
  <div
    class="html-template-editor js-html-template-editor"
    id="<%= editorId %>"
    data-html-editor-id="<%= editorId %>"
    data-default-mode="<%= defaultMode %>"
  >
    <textarea
      class="d-none js-html-template-editor-source"
      id="<%= fieldId %>"
      name="<%= fieldName %>"
      rows="<%= rowsValue %>"
      required
    ><%= initialValue %></textarea>

    <div class="html-template-editor-toolbar d-flex flex-wrap gap-1 align-items-center">
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="undo" title="Undo"><i class="bi bi-arrow-counterclockwise"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="redo" title="Redo"><i class="bi bi-arrow-clockwise"></i></button>
      <div class="vr mx-1"></div>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="bold" title="Bold"><i class="bi bi-type-bold"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="italic" title="Italic"><i class="bi bi-type-italic"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="underline" title="Underline"><i class="bi bi-type-underline"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="strikeThrough" title="Strikethrough"><i class="bi bi-type-strikethrough"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="removeFormat" title="Clear format"><i class="bi bi-eraser"></i></button>

      <div class="vr mx-1"></div>

      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="formatBlock" data-html-editor-command-arg="h1" title="Heading 1">H1</button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="formatBlock" data-html-editor-command-arg="h2" title="Heading 2">H2</button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="formatBlock" data-html-editor-command-arg="p" title="Paragraph">P</button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="formatBlock" data-html-editor-command-arg="blockquote" title="Block quote"><i class="bi bi-blockquote-left"></i></button>

      <div class="vr mx-1"></div>

      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="insertUnorderedList" title="Bulleted list"><i class="bi bi-list-ul"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="insertOrderedList" title="Numbered list"><i class="bi bi-list-ol"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="outdent" title="Outdent"><i class="bi bi-text-indent-right"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="indent" title="Indent"><i class="bi bi-text-indent-left"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="createLink" title="Insert link"><i class="bi bi-link-45deg"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="insertImage" title="Insert image"><i class="bi bi-image"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-action="image-size" title="Set image size"><i class="bi bi-aspect-ratio"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-action="image-reset-size" title="Reset image size"><i class="bi bi-arrow-counterclockwise"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="insertHorizontalRule" title="Horizontal line"><i class="bi bi-hr"></i></button>

      <div class="vr mx-1"></div>

      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="justifyLeft" title="Align left"><i class="bi bi-text-left"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="justifyCenter" title="Align center"><i class="bi bi-text-center"></i></button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-command="justifyRight" title="Align right"><i class="bi bi-text-right"></i></button>

      <div class="vr mx-1"></div>

      <button type="button" class="btn btn-outline-secondary" data-html-editor-action="toggle-mode" aria-pressed="false" title="Switch to HTML code editor">Code</button>
      <button type="button" class="btn btn-outline-secondary" data-html-editor-action="toggle-preview" title="Open preview in a separate modal">Preview</button>
    </div>

    <div class="html-template-editor-body">
      <div class="html-template-editor-main">
        <div
          class="html-template-editor-visual js-html-template-editor-visual"
          contenteditable="true"
          spellcheck="false"
          data-placeholder="Write HTML template content..."
        ></div>
        <textarea
          class="form-control font-monospace html-template-editor-code js-html-template-editor-code d-none"
          rows="<%= rowsValue %>"
          spellcheck="false"
          placeholder="Write HTML..."
        ></textarea>
      </div>
    </div>

    <div class="html-template-editor-footer d-flex flex-wrap align-items-center gap-2">
      <input
        type="text"
        class="form-control form-control-sm font-monospace js-html-template-editor-token-input"
        style="max-width: 420px;"
        value=""
        placeholder="<%= tokenPlaceholder %>"
      >
      <button type="button" class="btn btn-sm btn-outline-secondary" data-html-editor-action="insert-token">
        <i class="bi bi-braces me-1"></i>Insert Token
      </button>
      <% if (helperText) { %>
        <span class="small text-muted ms-auto"><%= helperText %></span>
      <% } %>
    </div>
  </div>
</div>
