<!-- ============================
     ADMIN VERIFICATION MODAL
     ============================ -->
<div id="adminVerifyModal" class="modal fade" tabindex="-1" data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog" style="max-width:500px;">
    <div class="modal-content" style="animation: slideUp .3s ease;">
      <div class="modal-header">
        <h5 class="modal-title">Admin Approval Required</h5>
      </div>

      <div class="modal-body">
        <p class="text-muted">
          This action requires administrator verification. Enter the 6-digit code from Google Authenticator to continue.
          If you have not set one up yet, open your avatar menu → <strong>Authenticator</strong>.
        </p>

        <input
          type="text"
          id="adminVerifyInput"
          class="form-control"
          placeholder="Enter 6-digit authenticator code..."
          inputmode="numeric"
          maxlength="8"
          autocomplete="one-time-code"
        />
        <div id="adminVerifyError" class="text-danger mt-2" style="min-height:18px;"></div>
      </div>

      <div class="modal-footer">
        <button type="button" id="adminVerifyCancel" class="btn btn-secondary btn-filled">Cancel</button>
        <button type="button" id="adminVerifySubmit" class="btn btn-primary btn-filled">Verify</button>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const modal = document.getElementById('adminVerifyModal');
    const input = document.getElementById('adminVerifyInput');
    const errorBox = document.getElementById('adminVerifyError');
    const btnVerify = document.getElementById('adminVerifySubmit');
    const btnCancel = document.getElementById('adminVerifyCancel');

    if (!modal || !input || !errorBox || !btnVerify || !btnCancel || typeof bootstrap === 'undefined') {
      return;
    }

    const SAFETY_BUFFER_MS = 5000;
    let pendingAction = null;
    let pendingResolve = null;
    let pendingReject = null;
    let adminApprovedUntilMs = 0;
    let isVerifying = false;

    const bsModal = new bootstrap.Modal(modal, { focus: true, backdrop: 'static', keyboard: false });

    modal.addEventListener('shown.bs.modal', () => {
      setTimeout(() => {
        input.focus();
        input.select();
      }, 50);
    });

    function resetAdminApprovalCache() {
      adminApprovedUntilMs = 0;
    }

    function isLocalApprovalFresh() {
      return adminApprovedUntilMs > 0 && Date.now() < (adminApprovedUntilMs - SAFETY_BUFFER_MS);
    }

    function applyApprovalExpiry(expiresAt) {
      const expiresAtMs = Date.parse(expiresAt || '');
      if (Number.isFinite(expiresAtMs) && expiresAtMs > Date.now()) {
        adminApprovedUntilMs = expiresAtMs;
        return true;
      }
      resetAdminApprovalCache();
      return false;
    }

    async function showModalMessage(options) {
      if (typeof window.showMessageModal === 'function') {
        return window.showMessageModal(options);
      }
      return options?.buttons?.find((button) => /verify/i.test(button.text || ''))?.text || 'Verify';
    }

    async function fetchAdminStatus() {
      try {
        const response = await fetch('/verify-admin/status', {
          method: 'GET',
          credentials: 'same-origin',
          headers: {
            'Accept': 'application/json',
            'X-AJAX-Request': 'true'
          }
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok || data.status === 'error') {
          resetAdminApprovalCache();
          return { verified: false, reason: data.message || data.reason || 'status_request_failed' };
        }
        if (data.verified && applyApprovalExpiry(data.expiresAt)) {
          return { verified: true, expiresAt: data.expiresAt };
        }
        resetAdminApprovalCache();
        return { verified: false, reason: data.reason || 'not_verified' };
      } catch (error) {
        resetAdminApprovalCache();
        return { verified: false, reason: error.message || 'status_request_failed' };
      }
    }

    async function hasServerApproval() {
      // Always validate with the server before skipping the modal. The local
      // timestamp only avoids trusting stale browser state after expiration.
      if (!isLocalApprovalFresh()) {
        resetAdminApprovalCache();
      }
      const status = await fetchAdminStatus();
      return status.verified === true;
    }

    function createCancelError(message) {
      const error = new Error(message || 'Admin verification cancelled.');
      error.code = 'ADMIN_VERIFICATION_CANCELLED';
      return error;
    }

    function openModal() {
      errorBox.textContent = '';
      input.value = '';
      input.classList.remove('modal-error-wiggle');
      bsModal.show();
    }

    function closeModal() {
      bsModal.hide();
    }

    function rejectPending(message) {
      const reject = pendingReject;
      pendingAction = null;
      pendingResolve = null;
      pendingReject = null;
      if (reject) reject(createCancelError(message));
    }

    function resolvePending() {
      const actionToRun = pendingAction;
      const resolve = pendingResolve;
      pendingAction = null;
      pendingResolve = null;
      pendingReject = null;
      try {
        if (typeof actionToRun === 'function') actionToRun();
      } finally {
        if (resolve) resolve(true);
      }
    }

    function showError(message) {
      errorBox.textContent = message;
      input.classList.add('modal-error-wiggle');
      setTimeout(() => input.classList.remove('modal-error-wiggle'), 300);
    }

    async function verifyAdminCode() {
      if (isVerifying) return;
      const code = input.value.trim();
      if (!code) {
        showError('Please enter a code.');
        return;
      }

      isVerifying = true;
      btnVerify.disabled = true;
      try {
        const response = await fetch('/verify-admin', {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'X-AJAX-Request': 'true'
          },
          body: JSON.stringify({ code })
        });
        const data = await response.json().catch(() => ({}));

        if (!response.ok || data.status === 'error') {
          resetAdminApprovalCache();
          showError(data.message || 'Invalid code.');
          return;
        }

        applyApprovalExpiry(data.expiresAt);
        closeModal();
        resolvePending();
      } catch (error) {
        console.error(error);
        resetAdminApprovalCache();
        showError('Verification error. Please try again.');
      } finally {
        isVerifying = false;
        btnVerify.disabled = false;
      }
    }

    async function requestProtectedAction(actionFn) {
      if (await hasServerApproval()) {
        if (typeof actionFn === 'function') actionFn();
        return true;
      }

      const confirmVerify = await showModalMessage({
        title: 'Admin Operation',
        message: 'This operation requires <b>Administrator Privileges</b>.<br><br>You must verify your Admin Code to proceed.',
        icon: 'warning',
        buttons: [
          { text: 'Cancel', class: 'btn-secondary' },
          { text: 'Verify', class: 'btn-warning' }
        ]
      });

      if (confirmVerify !== 'Verify') {
        throw createCancelError();
      }

      return new Promise((resolve, reject) => {
        pendingAction = actionFn;
        pendingResolve = resolve;
        pendingReject = reject;
        openModal();
      });
    }

    async function wrapFetchForAdminRequired() {
      if (window.__adminVerificationFetchWrapped || typeof window.fetch !== 'function') return;
      const nativeFetch = window.fetch.bind(window);
      window.fetch = async function(...args) {
        const response = await nativeFetch(...args);
        if (response && response.status === 403) {
          response.clone().json().then((payload) => {
            if (payload && payload.status === 'admin_required') {
              resetAdminApprovalCache();
            }
          }).catch(() => {});
        }
        return response;
      };
      window.__adminVerificationFetchWrapped = true;
    }

    btnVerify.addEventListener('click', verifyAdminCode);
    btnCancel.addEventListener('click', () => {
      closeModal();
      resetAdminApprovalCache();
      rejectPending();
    });
    input.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' || event.code === 'NumpadEnter') {
        event.preventDefault();
        verifyAdminCode();
      }
    });

    wrapFetchForAdminRequired();
    window.requestProtectedAction = requestProtectedAction;
    window.resetAdminVerificationCache = resetAdminApprovalCache;
  });
</script>
