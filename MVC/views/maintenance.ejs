<div class="container py-5">

  <div class="dash-hero mb-4 d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
    <div>
      <h1 class="page-heading size-lg mb-1 text-warning">
        <i class="bi bi-cone-striped me-2"></i> Maintenance Mode
      </h1>
      <div class="text-muted" style="font-size:1.05rem;">
        We are currently performing scheduled system updates.
      </div>
    </div>

    <div class="d-flex gap-2">
      <button onclick="location.reload()" class="btn btn-outline-secondary btn-md">
        <i class="bi bi-arrow-clockwise me-1"></i> Check Status
      </button>
    </div>
  </div>

  <div class="row g-4 align-items-stretch">
    <div class="col-lg-5">
      <div class="module-card h-100 d-flex flex-column justify-content-center text-center p-5">
        <div class="module-accent bg-warning"></div>
        
        <div class="mb-3 text-warning opacity-75">
            <i class="bi bi-gear-wide-connected" style="font-size: 5rem;"></i>
        </div>

        <h2 class="display-4 fw-bold text-warning mb-0">503</h2>
        <div class="text-muted text-uppercase fw-bold small letter-spacing-1 mt-2">Service Unavailable</div>
      </div>
    </div>

    <div class="col-lg-7">
      <div class="module-card h-100">
        <div class="module-accent bg-warning"></div>

        <h4 class="fw-bold mb-3">What's happening?</h4>
        
        <div class="alert alert-warning border-0 bg-warning-subtle text-dark mb-4">
           <i class="bi bi-info-circle-fill me-2"></i>
           <strong><%- message || 'Our team is working on improvements.' %></strong>
        </div>

        <div class="p-3 border rounded bg-light">
            <h6 class="fw-bold mb-2">Estimated Duration</h6>
            <p class="small text-muted mb-0">
                Most maintenance windows last between <strong>15 to 60 minutes</strong>. 
                Please try refreshing the page in a few moments.
            </p>
        </div>

        <hr class="my-4 opacity-10">

        <div class="d-flex align-items-center justify-content-between">
            <div class="small text-muted">
                <i class="bi bi-shield-lock me-1"></i> Admin Access
            </div>
            <% if(user) { %>
                <a href="/dashboard" class="btn btn-sm btn-link text-decoration-none">Admin Bypass &rarr;</a>
            <% } else { %>
                <a href="/login" class="btn btn-sm btn-link text-decoration-none">Admin Login &rarr;</a>
            <% } %>
        </div>

      </div>
    </div>
  </div>
</div>

<script>
    // Auto-refresh every 60 seconds to check if site is back
    setTimeout(() => {
        location.reload();
    }, 60000);
</script>