<%- include('../partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print
}) %>

<%- include('../partials/tablePages-search', {
  placeholder: 'Search roles...',
  fields: []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="draggable" data-column="id">ID <span class="sort-icon"></span></th>
        <th class="draggable" data-column="key">Key <span class="sort-icon"></span></th>
        <th class="draggable" data-column="label">Label <span class="sort-icon"></span></th>
        <th class="draggable" data-column="domain">Domain <span class="sort-icon"></span></th>
        <th class="draggable" data-column="packageName">Package <span class="sort-icon"></span></th>
        <th class="draggable" data-column="aliases">Aliases <span class="sort-icon"></span></th>
        <th class="draggable text-center" data-column="active">Active <span class="sort-icon"></span></th>
        <th class="draggable text-center" data-column="system">System <span class="sort-icon"></span></th>
        <th class="draggable" data-column="createDateTime">Created <span class="sort-icon"></span></th>
        <th class="draggable" data-column="lastUpdateDateTime">Last Updated <span class="sort-icon"></span></th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% roles.forEach(role => { %>
        <% const audit = role.audit || {}; %>
        <tr>
          <td><%= role.id || '' %></td>
          <td class="fw-semibold"><%= role.key %></td>
          <td><%= role.label %></td>
          <td><span class="badge bg-light text-dark border"><%= role.domain || 'core' %></span></td>
          <td><span class="badge bg-info-subtle text-info border border-info-subtle"><%= role.packageName || 'CORE' %></span></td>
          <td class="small text-muted"><%= Array.isArray(role.aliases) ? role.aliases.join(', ') : '' %></td>
          <td class="text-center">
            <% if (role.active !== false) { %>
              <span class="badge bg-success">Active</span>
            <% } else { %>
              <span class="badge bg-secondary">Inactive</span>
            <% } %>
          </td>
          <td class="text-center">
            <% if (role.system === true) { %>
              <span class="badge bg-primary">Yes</span>
            <% } else { %>
              <span class="badge bg-light text-dark border">No</span>
            <% } %>
          </td>
          <td>
            <% if (audit.createDateTime) { %>
              <%= typeof formatOrgDateTime === 'function' ? formatOrgDateTime(audit.createDateTime) : new Date(audit.createDateTime).toLocaleString() %>
              <% if (audit.createUser) { %>
                <br><span class="text-muted small">by User <%= audit.createUser %></span>
              <% } %>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td>
            <% if (audit.lastUpdateDateTime) { %>
              <%= typeof formatOrgDateTime === 'function' ? formatOrgDateTime(audit.lastUpdateDateTime) : new Date(audit.lastUpdateDateTime).toLocaleString() %>
              <% if (audit.lastUpdateUser) { %>
                <br><span class="text-muted small">by User <%= audit.lastUpdateUser %></span>
              <% } %>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>
          <td class="table-actions text-end pe-4">
            <% if (role.system === true) { %>
              <span class="text-muted small fst-italic">Protected</span>
            <% } else { %>
              <div class="row-actions-wrap">
                <button
                  type="button"
                  class="btn btn-secondary btn-sm btn-row-actions-toggle"
                  data-row-actions-id="<%= role.id %>"
                  title="Row actions">
                  <i class="bi bi-three-dots-vertical"></i>
                </button>
                <div class="row-actions-menu d-none" data-row-actions-id="<%= role.id %>">
                  <a href="/roles/edit/<%= role.id %>" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-pencil-square me-2"></i>Edit
                  </a>
                  <button class="btn btn-outline-danger btn-sm delete-btn" data-id="<%= role.id %>">
                    <i class="bi bi-trash me-2"></i>Delete
                  </button>
                </div>
              </div>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/pagination', {
  pagination: pagination,
  filters: filters,
  baseUrlPath: newUrl
}) %>

<%- include('../partials/tablePages-end') %>
