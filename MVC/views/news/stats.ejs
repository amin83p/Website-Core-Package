<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<%
    const safeArticle = article && typeof article === 'object' ? article : {};
    const safeMeta = safeArticle.meta && typeof safeArticle.meta === 'object' ? safeArticle.meta : {};
    const safeStats = stats && typeof stats === 'object' ? stats : {};
    const articleTitle = safeMeta.title || safeArticle.title || safeArticle.name || 'Untitled News';
    const articleId = safeArticle.id || safeArticle._id || '-';
    const rawPublishDate = safeMeta.publishDate || safeArticle.createdAt || safeArticle.audit?.createDateTime || '';
    const publishDate = rawPublishDate ? new Date(rawPublishDate) : null;
    const publishedLabel = publishDate && !Number.isNaN(publishDate.getTime()) ? publishDate.toLocaleDateString() : '-';
    const totalViews = Number(safeStats.totalViews || 0);
    const uniqueUsers = Number(safeStats.uniqueUsers || 0);
    const readTime = safeStats.readTime || '0m';
    const wordCount = Number(safeStats.wordCount || 0);
    const safeChartData = chartData && typeof chartData === 'object' ? chartData : { dates: [], views: [] };
%>

<div class="sections-page">
    
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <div class="d-flex align-items-center gap-2 mb-1">
                <a href="/news/manage" class="text-decoration-none text-muted small"><i class="bi bi-arrow-left"></i> Back to List</a>
            </div>
            <h1 class="page-heading size-md m-0">Engagement Analytics</h1>
            <div class="text-muted">
                Report for: <span class="fw-bold text-dark">"<%= articleTitle %>"</span>
            </div>
        </div>
        <div class="text-end">
             <span class="badge bg-light text-secondary border px-3 py-2 d-block mb-1">
                Published: <%= publishedLabel %>
             </span>
             <small class="text-muted">ID: <%= articleId %></small>
        </div>
    </div>

    <div class="row g-3 mb-4">
        
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-uppercase text-muted small fw-bold mb-1">Total Views</div>
                            <div class="display-6 fw-bold text-primary"><%= totalViews %></div>
                        </div>
                        <div class="rounded-circle bg-primary-subtle text-primary p-2">
                            <i class="bi bi-eye fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-uppercase text-muted small fw-bold mb-1">Est. Unique Users</div>
                            <div class="display-6 fw-bold text-dark"><%= uniqueUsers %></div>
                        </div>
                        <div class="rounded-circle bg-success-subtle text-success p-2">
                            <i class="bi bi-people fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-uppercase text-muted small fw-bold mb-1">Est. Read Time</div>
                            <div class="display-6 fw-bold text-dark"><%= readTime %></div>
                        </div>
                        <div class="rounded-circle bg-warning-subtle text-warning-emphasis p-2">
                            <i class="bi bi-stopwatch fs-4"></i>
                        </div>
                    </div>
                     <div class="mt-3 small text-muted">
                        Based on <%= wordCount %> words
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <div class="text-uppercase text-muted small fw-bold mb-1">Impact Score</div>
                            <div class="display-6 fw-bold text-info">
                                <%= totalViews > 50 ? 'High' : (totalViews > 10 ? 'Med' : 'Low') %>
                            </div>
                        </div>
                        <div class="rounded-circle bg-info-subtle text-info p-2">
                            <i class="bi bi-graph-up-arrow fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h6 class="fw-bold m-0"><i class="bi bi-activity me-2"></i>Traffic Trend (Last 7 Days)</h6>
                </div>
                <div class="card-body">
                    <canvas id="viewsChart" style="max-height: 300px;"></canvas>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-white py-3 border-bottom-0">
                    <h6 class="fw-bold m-0"><i class="bi bi-pie-chart me-2"></i>Reader Segments</h6>
                </div>
                <div class="card-body d-flex align-items-center justify-content-center">
                    <canvas id="orgChart" style="max-height: 250px;"></canvas>
                </div>
                <div class="card-footer bg-white border-top-0 pb-4">
                    <div class="small text-muted text-center fst-italic">
                        Breakdown by User Type
                    </div>
                </div>
            </div>
        </div>

    </div>
    
    </div>

<script id="chartData" type="application/json"><%- JSON.stringify(safeChartData) %></script>

<script>
document.addEventListener('DOMContentLoaded', () => {
    
    // Parse the REAL data passed from the controller
    const data = JSON.parse(document.getElementById('chartData').textContent);

    // 1. Traffic Chart (Connected to Real Data)
    const ctxViews = document.getElementById('viewsChart');
    new Chart(ctxViews, {
        type: 'line',
        data: {
            labels: data.dates, // ["Mon", "Tue"...] from controller
            datasets: [{
                label: 'Views',
                data: data.views, // [5, 12, 0...] from controller
                borderColor: '#0d6efd',
                backgroundColor: 'rgba(13, 110, 253, 0.1)',
                tension: 0.4,
                fill: true,
                borderWidth: 2,
                pointBackgroundColor: '#fff',
                pointBorderColor: '#0d6efd',
                pointRadius: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { precision: 0 }, grid: { borderDash: [2, 4] } },
                x: { grid: { display: false } }
            }
        }
    });

    // 2. Segments Chart (Mocked for visual balance until user role data is aggregated)
    const ctxOrg = document.getElementById('orgChart');
    new Chart(ctxOrg, {
        type: 'doughnut',
        data: {
            labels: ['Logged In', 'Guest / Public'],
            datasets: [{
                data: [70, 30], 
                backgroundColor: ['#0d6efd', '#e9ecef'],
                borderWidth: 0,
                hoverOffset: 4
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
            }
        }
    });
});
</script>
