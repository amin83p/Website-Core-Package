<%
  const list = Array.isArray(newsList) ? newsList : [];
  const activeFilters = (typeof filters !== 'undefined' && filters && typeof filters === 'object') ? filters : {};
  const activeQuery = String(activeFilters.q || '').trim();
  const makeDate = (value) => {
    const d = value ? new Date(value) : null;
    return d && !Number.isNaN(d.getTime()) ? d : null;
  };
  const formatShortDate = (value) => {
    const d = makeDate(value);
    return d ? d.toLocaleDateString(undefined, { month: 'short', day: 'numeric', year: 'numeric' }) : 'Date unavailable';
  };
  const formatLongDate = (value) => {
    const d = makeDate(value);
    return d ? d.toLocaleDateString(undefined, { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' }) : 'Date unavailable';
  };
  const normalizeStory = (item) => {
    const row = item && typeof item === 'object' ? item : {};
    const meta = row.meta && typeof row.meta === 'object' ? row.meta : {};
    const content = row.content && typeof row.content === 'object' ? row.content : {};
    const author = meta.author && typeof meta.author === 'object' ? meta.author : {};
    const title = String(meta.title || 'Untitled News').trim();
    const category = String(meta.category || 'General').trim();
    const authorName = String(author.displayName || 'Editorial Team').trim();
    return {
      id: row.id || '',
      hrefToken: String(meta.slug || row.id || '').trim(),
      title,
      category,
      summary: String(content.summary || 'Open the full story for details, context, and the latest update.').trim(),
      image: String(content.featuredImage || '').trim(),
      authorName,
      authorInitial: (authorName.charAt(0) || 'E').toUpperCase(),
      dateLabel: formatShortDate(meta.publishDate),
      longDateLabel: formatLongDate(meta.publishDate),
      tags: Array.isArray(meta.tags) ? meta.tags.map((tag) => String(tag || '').trim()).filter(Boolean) : []
    };
  };
  const stories = list.map(normalizeStory).filter((story) => story.hrefToken);
  const spotlight = stories[0] || null;
  const otherStories = spotlight ? stories.slice(1) : stories;
  const topicSet = new Set();
  stories.forEach((story) => story.tags.forEach((tag) => topicSet.add(tag)));
  const topics = Array.from(topicSet).slice(0, 18);
  const currentPageCount = stories.length;
%>

<section class="news-public-page news-feed-page">
  <section class="news-hero" aria-labelledby="newsFeedTitle">
    <div class="news-hero-orbit" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="news-hero-copy">
      <div class="news-eyebrow">Newsroom</div>
      <h1 id="newsFeedTitle">Stories, updates, and signals from the learning space.</h1>
      <p>
        Follow announcements, product updates, events, and community notes in one polished editorial stream.
      </p>

      <form action="/news" method="GET" class="news-search-panel" aria-label="Search news">
        <i class="bi bi-search" aria-hidden="true"></i>
        <input type="text" name="q" value="<%= activeQuery %>" placeholder="Search news, tags, authors, or categories..." autocomplete="off">
        <button type="submit">Search</button>
        <% if (activeQuery) { %>
          <a href="/news" class="news-clear-link">Clear</a>
        <% } %>
      </form>
    </div>

    <div class="news-hero-metrics" aria-label="News summary">
      <div>
        <strong><%= currentPageCount %></strong>
        <span>Stories shown</span>
      </div>
      <div>
        <strong><%= topics.length %></strong>
        <span>Active topics</span>
      </div>
      <div>
        <strong><%= spotlight ? spotlight.dateLabel.split(',')[0] : '-' %></strong>
        <span>Latest update</span>
      </div>
    </div>
  </section>

  <section class="news-quick-row" aria-label="Browse news sections">
    <a href="/news" class="news-topic-pill <%= !activeQuery ? 'active' : '' %>"><i class="bi bi-grid-fill"></i>All Stories</a>
    <a href="/news?q=Announcements" class="news-topic-pill <%= activeQuery === 'Announcements' ? 'active' : '' %>"><i class="bi bi-megaphone-fill"></i>Announcements</a>
    <a href="/news?q=Events" class="news-topic-pill <%= activeQuery === 'Events' ? 'active' : '' %>"><i class="bi bi-calendar-event-fill"></i>Events</a>
    <a href="/news?q=Features" class="news-topic-pill <%= activeQuery === 'Features' ? 'active' : '' %>"><i class="bi bi-stars"></i>Product Updates</a>
    <% if (user) { %>
      <a href="/news/center" class="news-topic-pill news-topic-pill-admin"><i class="bi bi-shield-lock-fill"></i>News Center</a>
    <% } %>
  </section>

  <% if (activeQuery) { %>
    <div class="news-query-banner">
      <i class="bi bi-funnel-fill"></i>
      <span>Showing results for <strong><%= activeQuery %></strong></span>
    </div>
  <% } %>

  <% if (spotlight) { %>
    <section class="news-spotlight" aria-labelledby="newsSpotlightTitle">
      <a href="/news/article/<%= spotlight.hrefToken %>" class="news-spotlight-media" aria-label="Read <%= spotlight.title %>">
        <% if (spotlight.image) { %>
          <img src="<%= spotlight.image %>" alt="<%= spotlight.title %>">
        <% } else { %>
          <div class="news-image-fallback"><i class="bi bi-newspaper"></i></div>
        <% } %>
      </a>
      <div class="news-spotlight-copy">
        <div class="news-card-kicker">
          <span><%= spotlight.category %></span>
          <small><%= spotlight.longDateLabel %></small>
        </div>
        <h2 id="newsSpotlightTitle"><a href="/news/article/<%= spotlight.hrefToken %>"><%= spotlight.title %></a></h2>
        <p><%= spotlight.summary %></p>
        <div class="news-author-row">
          <span class="news-avatar"><%= spotlight.authorInitial %></span>
          <span>By <strong><%= spotlight.authorName %></strong></span>
          <a href="/news/article/<%= spotlight.hrefToken %>" class="news-read-link">Read spotlight <i class="bi bi-arrow-right"></i></a>
        </div>
      </div>
    </section>
  <% } %>

  <section class="news-feed-layout" aria-label="Latest news stories">
    <div class="news-feed-main">
      <div class="news-section-heading">
        <span>Latest Updates</span>
        <h2><%= activeQuery ? 'Filtered stories for your search.' : 'Fresh stories worth opening.' %></h2>
      </div>

      <% if (stories.length > 0) { %>
        <div class="news-card-grid">
          <% otherStories.forEach((story) => { %>
            <article class="news-story-card">
              <a href="/news/article/<%= story.hrefToken %>" class="news-story-image" aria-label="Read <%= story.title %>">
                <% if (story.image) { %>
                  <img src="<%= story.image %>" alt="<%= story.title %>">
                <% } else { %>
                  <div class="news-image-fallback"><i class="bi bi-newspaper"></i></div>
                <% } %>
                <span class="news-category-chip"><%= story.category %></span>
              </a>
              <div class="news-story-body">
                <div class="news-date-line"><i class="bi bi-calendar3"></i><%= story.dateLabel %></div>
                <h3><a href="/news/article/<%= story.hrefToken %>"><%= story.title %></a></h3>
                <p><%= story.summary %></p>
                <div class="news-story-footer">
                  <span><span class="news-avatar news-avatar-sm"><%= story.authorInitial %></span><%= story.authorName %></span>
                  <a href="/news/article/<%= story.hrefToken %>">Read <i class="bi bi-arrow-right"></i></a>
                </div>
              </div>
            </article>
          <% }) %>
        </div>

        <% if (otherStories.length === 0) { %>
          <div class="news-single-note">The spotlight story is the only update in this view.</div>
        <% } %>

        <% if (pagination) { %>
          <div class="news-pagination-wrap">
            <%- include('../partials/pagination', { pagination: pagination, filters: activeFilters, baseUrlPath: 'news' }) %>
          </div>
        <% } %>
      <% } else { %>
        <div class="news-empty-state">
          <i class="bi bi-search"></i>
          <h3>No updates found</h3>
          <p>We could not find any news matching your criteria. Try a different keyword or clear the filter.</p>
          <a href="/news" class="btn news-btn-primary">View All Stories</a>
        </div>
      <% } %>
    </div>

    <aside class="news-feed-side" aria-label="News topics and actions">
      <div class="news-glass-card">
        <div class="news-widget-title"><i class="bi bi-tags"></i>Trending Topics</div>
        <% if (topics.length) { %>
          <div class="news-topic-cloud">
            <% topics.forEach((tag) => { %>
              <a href="/news?q=<%= tag %>">#<%= tag %></a>
            <% }) %>
          </div>
        <% } else { %>
          <p class="news-muted">No active topics yet.</p>
        <% } %>
      </div>

      <% if (user) { %>
        <div class="news-glass-card news-admin-card">
          <div class="news-widget-title"><i class="bi bi-lightning-charge-fill"></i>Editor Tools</div>
          <p>Manage published stories, prepare announcements, and review the News Center.</p>
          <div class="d-grid gap-2">
            <a href="/news/center" class="btn news-btn-primary">Open News Center</a>
            <a href="/news/manage/new" class="btn news-btn-secondary">Submit Article</a>
          </div>
        </div>
      <% } %>
    </aside>
  </section>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

html.news-public-root,
html.news-public-root body.news-public-body {
  background:
    radial-gradient(circle at 8% 6%, rgba(29, 95, 184, 0.17), transparent 29%),
    radial-gradient(circle at 92% 7%, rgba(8, 127, 140, 0.17), transparent 27%),
    radial-gradient(circle at 9% 54%, rgba(29, 95, 184, 0.08), transparent 25%),
    radial-gradient(circle at 89% 78%, rgba(8, 127, 140, 0.10), transparent 28%),
    linear-gradient(135deg, #f8fbff 0%, #eef8f5 52%, #ffffff 100%);
  min-height: 100%;
}

body.news-public-body { background-attachment: fixed; }

main.news-public-main {
  margin-bottom: 0 !important;
  margin-top: 0 !important;
  padding-bottom: clamp(2.5rem, 5vw, 5rem);
  padding-top: 0;
  position: relative;
}

.news-public-page {
  --news-blue: #1d5fb8;
  --news-teal: #087f8c;
  --news-ink: #13222c;
  --news-muted: #53636f;
  --news-line: #d7e1e7;
  --news-surface: rgba(255, 255, 255, 0.82);
  --news-shadow: 0 26px 70px rgba(19, 34, 44, 0.14);
  font-family: 'Manrope', 'Segoe UI', sans-serif;
  isolation: isolate;
  padding-top: clamp(1.3rem, 3vw, 2.4rem);
  position: relative;
}

.news-public-page::before {
  background:
    linear-gradient(115deg, rgba(255,255,255,0.82), rgba(255,255,255,0.24)),
    radial-gradient(circle at 12% 18%, rgba(29, 95, 184, 0.12), transparent 25%),
    radial-gradient(circle at 86% 22%, rgba(8, 127, 140, 0.12), transparent 27%);
  border-radius: 0;
  content: "";
  inset: -2.5rem calc(50% - 50vw) -5rem;
  pointer-events: none;
  position: absolute;
  z-index: -1;
}

.news-hero {
  display: grid;
  gap: clamp(1.5rem, 4vw, 3rem);
  grid-template-columns: minmax(0, 1.6fr) minmax(260px, 0.65fr);
  margin-bottom: clamp(1.4rem, 4vw, 3rem);
  min-height: 360px;
  overflow: hidden;
  position: relative;
}

.news-hero-copy {
  align-self: center;
  max-width: 850px;
  padding: clamp(1rem, 3vw, 2rem) 0;
}

.news-eyebrow,
.news-section-heading span,
.news-widget-title {
  color: var(--news-teal);
  font-size: 0.78rem;
  font-weight: 800;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.news-hero h1 {
  color: var(--news-ink);
  font-size: clamp(2.6rem, 6vw, 5.8rem);
  font-weight: 800;
  letter-spacing: -0.07em;
  line-height: 0.93;
  margin: 0.75rem 0 1rem;
}

.news-hero p {
  color: var(--news-muted);
  font-size: clamp(1.02rem, 1.7vw, 1.28rem);
  line-height: 1.7;
  max-width: 720px;
}

.news-hero-orbit {
  inset: 0;
  pointer-events: none;
  position: absolute;
}

.news-hero-orbit span {
  border: 1px solid rgba(29, 95, 184, 0.18);
  border-radius: 999px;
  position: absolute;
}

.news-hero-orbit span:nth-child(1) { height: 290px; right: 5%; top: 4%; width: 290px; }
.news-hero-orbit span:nth-child(2) { height: 170px; right: 18%; top: 22%; width: 170px; }
.news-hero-orbit span:nth-child(3) { background: rgba(8,127,140,0.10); height: 70px; right: 9%; top: 45%; width: 70px; }

.news-search-panel {
  align-items: center;
  backdrop-filter: blur(18px);
  background: rgba(255, 255, 255, 0.78);
  border: 1px solid rgba(215, 225, 231, 0.9);
  border-radius: 999px;
  box-shadow: 0 18px 45px rgba(19, 34, 44, 0.10);
  display: flex;
  gap: 0.75rem;
  margin-top: 1.65rem;
  max-width: 760px;
  padding: 0.55rem 0.65rem 0.55rem 1.15rem;
}

.news-search-panel i { color: var(--news-blue); font-size: 1.2rem; }
.news-search-panel input { background: transparent; border: 0; flex: 1; min-width: 0; outline: 0; }
.news-search-panel button,
.news-btn-primary {
  background: linear-gradient(135deg, var(--news-blue), var(--news-teal));
  border: 0;
  border-radius: 999px;
  color: #fff;
  font-weight: 800;
  padding: 0.72rem 1.2rem;
  text-decoration: none;
}
.news-clear-link { color: #b42318; font-size: 0.85rem; font-weight: 800; padding-right: 0.5rem; text-decoration: none; }

.news-hero-metrics {
  align-self: end;
  display: grid;
  gap: 0.85rem;
  margin-bottom: 2rem;
  position: relative;
  z-index: 1;
}

.news-hero-metrics div,
.news-glass-card,
.news-spotlight,
.news-story-card,
.news-empty-state,
.news-query-banner,
.news-single-note {
  backdrop-filter: blur(18px);
  background: var(--news-surface);
  border: 1px solid rgba(215, 225, 231, 0.82);
  box-shadow: var(--news-shadow);
}

.news-hero-metrics div { border-radius: 24px; padding: 1.1rem 1.25rem; }
.news-hero-metrics strong { color: var(--news-blue); display: block; font-size: 2rem; font-weight: 800; line-height: 1; }
.news-hero-metrics span { color: var(--news-muted); font-size: 0.83rem; font-weight: 700; }

.news-quick-row { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 1.3rem; }
.news-topic-pill {
  align-items: center;
  background: rgba(255,255,255,0.68);
  border: 1px solid rgba(215,225,231,0.9);
  border-radius: 999px;
  color: var(--news-ink);
  display: inline-flex;
  font-weight: 800;
  gap: 0.5rem;
  padding: 0.78rem 1rem;
  text-decoration: none;
}
.news-topic-pill.active,
.news-topic-pill:hover { background: #fff; color: var(--news-blue); box-shadow: 0 14px 30px rgba(29,95,184,0.12); }
.news-topic-pill-admin { margin-left: auto; }

.news-query-banner,
.news-single-note { border-radius: 22px; color: var(--news-muted); font-weight: 700; margin: 0 0 1.4rem; padding: 1rem 1.2rem; }
.news-query-banner i { color: var(--news-teal); margin-right: 0.45rem; }

.news-spotlight {
  border-radius: 34px;
  display: grid;
  gap: 0;
  grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.05fr);
  margin-bottom: clamp(2rem, 5vw, 4rem);
  overflow: hidden;
}
.news-spotlight-media,
.news-story-image { background: #e9f3f8; display: block; overflow: hidden; position: relative; }
.news-spotlight-media { min-height: 410px; }
.news-spotlight-media img,
.news-story-image img { height: 100%; object-fit: cover; transition: transform 0.85s ease; width: 100%; }
.news-spotlight:hover img,
.news-story-card:hover img { transform: scale(1.045); }
.news-image-fallback { align-items: center; background: radial-gradient(circle at 30% 20%, rgba(29,95,184,0.22), transparent 32%), linear-gradient(135deg, #eaf4fb, #f8fbff); color: rgba(29,95,184,0.35); display: flex; font-size: 4rem; height: 100%; justify-content: center; min-height: 240px; }
.news-spotlight-copy { padding: clamp(1.6rem, 4vw, 3.25rem); }
.news-card-kicker { align-items: center; display: flex; flex-wrap: wrap; gap: 0.8rem; margin-bottom: 1rem; }
.news-card-kicker span,
.news-category-chip { background: rgba(8,127,140,0.12); border-radius: 999px; color: var(--news-teal); font-size: 0.74rem; font-weight: 800; letter-spacing: 0.08em; padding: 0.48rem 0.7rem; text-transform: uppercase; }
.news-card-kicker small,
.news-date-line { color: var(--news-muted); font-size: 0.82rem; font-weight: 700; }
.news-spotlight-copy h2 { font-size: clamp(2rem, 4vw, 3.4rem); font-weight: 800; letter-spacing: -0.055em; line-height: 1; margin-bottom: 1rem; }
.news-spotlight-copy h2 a,
.news-story-body h3 a { color: var(--news-ink); text-decoration: none; }
.news-spotlight-copy p { color: var(--news-muted); font-size: 1.03rem; line-height: 1.75; }
.news-author-row,
.news-story-footer { align-items: center; color: var(--news-muted); display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 1.4rem; }
.news-avatar { align-items: center; background: linear-gradient(135deg, var(--news-blue), var(--news-teal)); border-radius: 999px; color: #fff; display: inline-flex; font-weight: 800; height: 2.45rem; justify-content: center; width: 2.45rem; }
.news-avatar-sm { height: 1.9rem; margin-right: 0.45rem; width: 1.9rem; }
.news-read-link,
.news-story-footer a { color: var(--news-blue); font-weight: 800; margin-left: auto; text-decoration: none; }

.news-feed-layout { align-items: start; display: grid; gap: clamp(1.5rem, 3vw, 2.4rem); grid-template-columns: minmax(0, 1fr) 310px; }
.news-section-heading { margin-bottom: 1.25rem; }
.news-section-heading h2 { color: var(--news-ink); font-size: clamp(1.8rem, 3.5vw, 3rem); font-weight: 800; letter-spacing: -0.055em; margin: 0.35rem 0 0; }
.news-card-grid { display: grid; gap: 1.15rem; grid-template-columns: repeat(2, minmax(0, 1fr)); }
.news-story-card { border-radius: 30px; overflow: hidden; transition: transform 0.22s ease, box-shadow 0.22s ease; }
.news-story-card:hover { box-shadow: 0 30px 70px rgba(19,34,44,0.18); transform: translateY(-4px); }
.news-story-image { height: 230px; }
.news-category-chip { left: 1rem; position: absolute; top: 1rem; }
.news-story-body { padding: 1.35rem; }
.news-date-line { align-items: center; display: flex; gap: 0.4rem; margin-bottom: 0.75rem; }
.news-story-body h3 { font-size: 1.22rem; font-weight: 800; letter-spacing: -0.025em; line-height: 1.25; }
.news-story-body p { color: var(--news-muted); display: -webkit-box; font-size: 0.94rem; line-height: 1.65; margin: 0.8rem 0 0; overflow: hidden; -webkit-box-orient: vertical; -webkit-line-clamp: 3; }
.news-story-footer { border-top: 1px solid rgba(215,225,231,0.78); font-size: 0.84rem; margin-top: 1.1rem; padding-top: 1rem; }
.news-feed-side { display: grid; gap: 1rem; position: sticky; top: 1.5rem; }
.news-glass-card { border-radius: 28px; padding: 1.35rem; }
.news-widget-title { align-items: center; display: flex; gap: 0.45rem; margin-bottom: 1rem; }
.news-topic-cloud { display: flex; flex-wrap: wrap; gap: 0.6rem; }
.news-topic-cloud a { background: rgba(255,255,255,0.78); border: 1px solid rgba(215,225,231,0.9); border-radius: 999px; color: var(--news-muted); font-weight: 700; padding: 0.55rem 0.75rem; text-decoration: none; }
.news-topic-cloud a:hover { color: var(--news-blue); }
.news-admin-card p,
.news-muted { color: var(--news-muted); }
.news-btn-secondary { border: 1px solid rgba(29,95,184,0.24); border-radius: 999px; color: var(--news-blue); font-weight: 800; padding: 0.7rem 1rem; text-decoration: none; }
.news-pagination-wrap { margin-top: 2.1rem; }
.news-empty-state { border-radius: 34px; padding: clamp(2rem, 5vw, 4rem); text-align: center; }
.news-empty-state i { color: rgba(29,95,184,0.24); font-size: 4rem; }
.news-empty-state h3 { color: var(--news-ink); font-weight: 800; }
.news-empty-state p { color: var(--news-muted); }

@media (max-width: 1199.98px) {
  .news-feed-layout { grid-template-columns: 1fr; }
  .news-feed-side { position: static; }
}
@media (max-width: 991.98px) {
  .news-hero,
  .news-spotlight { grid-template-columns: 1fr; }
  .news-hero-metrics { grid-template-columns: repeat(3, minmax(0, 1fr)); margin-bottom: 0; }
  .news-spotlight-media { min-height: 320px; }
  .news-topic-pill-admin { margin-left: 0; }
}
@media (max-width: 767.98px) {
  .news-card-grid,
  .news-hero-metrics { grid-template-columns: 1fr; }
  .news-search-panel { align-items: stretch; border-radius: 28px; flex-direction: column; padding: 1rem; }
  .news-search-panel button,
  .news-clear-link { text-align: center; width: 100%; }
  .news-hero h1 { font-size: clamp(2.25rem, 13vw, 3.6rem); }
}
</style>
