<%
  const backend = runtimeBackend || {};
  const activeMode = String(backend.mode || 'json').trim().toLowerCase();
  const installedRows = Array.isArray(installedPackages) ? installedPackages : [];
  const localOptions = Array.isArray(localManifestOptions) ? localManifestOptions : [];
  const localWarnings = Array.isArray(localManifestWarnings) ? localManifestWarnings : [];
  const startupWarnings = Array.isArray(typeof startupPackageWarnings !== 'undefined' ? startupPackageWarnings : [])
    ? (typeof startupPackageWarnings !== 'undefined' ? startupPackageWarnings : [])
    : [];
  const actionStateValue = typeof actionStateId !== 'undefined' ? actionStateId : '';
  const storageRoot = String(typeof packageStorageRoot !== 'undefined' ? packageStorageRoot : '').trim();
  const storageRootSource = String(typeof packageStorageRootSource !== 'undefined' ? packageStorageRootSource : '').trim();
  const storageRootWarnings = Array.isArray(typeof packageStorageRootWarnings !== 'undefined' ? packageStorageRootWarnings : [])
    ? (typeof packageStorageRootWarnings !== 'undefined' ? packageStorageRootWarnings : [])
    : [];
  const orgRows = Array.isArray(typeof organizations !== 'undefined' ? organizations : [])
    ? (typeof organizations !== 'undefined' ? organizations : [])
    : [];
  const activeOrg = String(typeof activeOrgId !== 'undefined' ? activeOrgId : '').trim();
  const trustedZipKeysCount = Number.isFinite(Number(typeof zipTrustedKeysCount !== 'undefined' ? zipTrustedKeysCount : 0))
    ? Number(typeof zipTrustedKeysCount !== 'undefined' ? zipTrustedKeysCount : 0)
    : 0;
  const trustedZipKeysConfigured = Boolean(typeof zipTrustedKeysConfigured !== 'undefined'
    ? zipTrustedKeysConfigured
    : (trustedZipKeysCount > 0));
  const zipLimitValue = Number.isFinite(Number(typeof zipUploadLimitMb !== 'undefined' ? zipUploadLimitMb : 50))
    ? Number(typeof zipUploadLimitMb !== 'undefined' ? zipUploadLimitMb : 50)
    : 50;
%>

<div class="sections-page package-manager-page" data-floating-row-actions="true">
  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
      <h1 class="page-heading size-md text-start m-0">Package Manager</h1>
      <p class="text-muted mb-0 mt-1">Install and control package lifecycle from System Settings.</p>
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">PACKAGE LIFECYCLE</span>
      <span class="badge bg-light text-dark border">Runtime: <%= activeMode.toUpperCase() %></span>
      <% if (typeof localPackageDevModeEnabled !== 'undefined' && localPackageDevModeEnabled) { %>
        <a href="/systemSettings/packages/local-sync" class="btn btn-outline-primary btn-sm">
          <i class="bi bi-arrow-repeat me-1"></i>Package Sync Locally
        </a>
      <% } %>
      <a href="/systemSettings" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Settings Home
      </a>
    </div>
  </div>
  <% if (storageRoot) { %>
    <div class="alert alert-info border-0 shadow-sm py-2 px-3 mb-3 small">
      <strong>Package Storage Root:</strong> <code><%= storageRoot %></code>
      <% if (storageRootSource) { %>
        <span class="ms-2 text-muted">(source: <%= storageRootSource %>)</span>
      <% } %>
    </div>
  <% } %>
  <% if (storageRootWarnings.length) { %>
    <div class="alert alert-warning border-0 shadow-sm py-2 px-3 mb-3 small">
      <div class="fw-semibold mb-1">Package Root Warnings</div>
      <ul class="mb-0 ps-3">
        <% storageRootWarnings.forEach((msg) => { %>
          <li><%= msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>
  <% if (startupWarnings.length) { %>
    <div class="alert alert-warning border-0 shadow-sm py-2 px-3 mb-3 small">
      <div class="fw-semibold mb-1">Startup Package Load Warnings (Registry State Unchanged)</div>
      <ul class="mb-0 ps-3">
        <% startupWarnings.slice(0, 8).forEach((msg) => { %>
          <li><%= msg %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-bold small">Install / Enable Package</div>
    <div class="card-body p-3">
      <div class="row g-3">
        <div class="col-lg-3 col-md-6">
          <label class="form-label small fw-bold">Install Method</label>
          <select class="form-select" id="pkgInstallMethod">
            <option value="local">Local Discovered Manifest</option>
            <option value="path">Manual Manifest Path</option>
            <option value="json">Manifest JSON</option>
            <option value="zip">ZIP Upload (Signature Verified)</option>
          </select>
        </div>
        <div class="col-lg-3 col-md-6">
          <label class="form-label small fw-bold">Target Organization</label>
          <select class="form-select" id="pkgTargetOrgId">
            <option value="">Select organization</option>
            <% orgRows.forEach((org) => { %>
              <% const orgValue = String(org.id || org.orgId || '').trim(); %>
              <% if (!orgValue) return; %>
              <option value="<%= orgValue %>" <%= activeOrg && activeOrg === orgValue ? 'selected' : '' %>>
                <%= org.name || org.displayName || orgValue %> (<%= orgValue %>)
              </option>
            <% }) %>
          </select>
          <div class="small text-muted mt-1">Required when installing packages with org placeholders.</div>
        </div>
        <div class="col-lg-6 col-md-12">
          <div id="pkgInstallLocalPanel">
            <label class="form-label small fw-bold">Local Manifest</label>
            <select class="form-select" id="pkgLocalManifestPath">
              <option value="">Select local manifest</option>
              <% localOptions.forEach((row) => { %>
                <option value="<%= row.storedManifestPath %>"><%= row.packageId %> - <%= row.version %> (<%= row.storedManifestPath %>)</option>
              <% }) %>
            </select>
            <div class="small text-muted mt-1">
              Detected from
              <code><%= storageRoot || 'packages' %>/*/package.manifest.json</code>.
            </div>
          </div>
          <div id="pkgInstallPathPanel" class="d-none">
            <label class="form-label small fw-bold">Manifest Path</label>
            <input type="text" class="form-control" id="pkgManualManifestPath" placeholder="packages/pte/package.manifest.json or absolute path">
          </div>
          <div id="pkgInstallJsonPanel" class="d-none">
            <label class="form-label small fw-bold">Manifest JSON</label>
            <textarea class="form-control font-monospace small" id="pkgManifestJson" rows="8" placeholder='{"id":"my-package","name":"My Package","version":"1.0.0","mountPath":"/my-package"}'></textarea>
          </div>
          <div id="pkgInstallZipPanel" class="d-none">
            <label class="form-label small fw-bold">Package ZIP</label>
            <input type="file" class="form-control" id="pkgZipFile" accept=".zip,application/zip">
            <label class="form-label small fw-bold mt-2">Detached Signature (.sig)</label>
            <input type="file" class="form-control" id="pkgSigFile" accept=".sig,.txt,application/octet-stream,text/plain">
            <div class="small text-muted mt-1">Max upload size: <b><%= zipLimitValue %> MB</b> per file.</div>
            <% if (trustedZipKeysConfigured) { %>
              <div class="alert alert-success mt-2 mb-0 py-2 px-3 small">
                Trusted signature keys configured: <b><%= trustedZipKeysCount %></b>. ZIP upload will verify automatically.
              </div>
            <% } else { %>
              <div class="alert alert-warning mt-2 mb-0 py-2 px-3 small">
                No trusted signature key configured yet. Set <code>PACKAGE_INSTALL_ED25519_PUBLIC_KEYS</code> in core <code>.env</code>, then restart the app.
              </div>
            <% } %>
          </div>
        </div>
      </div>

      <% if (localWarnings.length) { %>
        <div class="alert alert-warning mt-3 mb-0 py-2 px-3">
          <div class="fw-semibold small mb-1">Some local manifests are invalid and cannot be selected:</div>
          <ul class="small mb-0 ps-3">
            <% localWarnings.slice(0, 8).forEach((row) => { %>
              <li><code><%= row.storedManifestPath || row.manifestPath %></code> - <%= row.error || 'Invalid manifest' %></li>
            <% }) %>
          </ul>
        </div>
      <% } %>

      <div class="d-flex align-items-center gap-2 flex-wrap mt-3">
        <button type="button" class="btn btn-primary btn-filled" id="pkgInstallBtn">
          <i class="bi bi-box-arrow-in-down-right me-1"></i>Install / Enable
        </button>
        <button type="button" class="btn btn-outline-danger" id="pkgCleanupFailedBtn">
          <i class="bi bi-trash3 me-1"></i>Clean Failed Attempts
        </button>
        <button type="button" class="btn btn-outline-secondary" id="pkgRefreshSnapshotBtn">
          <i class="bi bi-arrow-clockwise me-1"></i>Refresh Snapshot
        </button>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold small d-flex align-items-center justify-content-between gap-2 flex-wrap">
      <span>Installed Packages</span>
      <span class="text-muted fw-normal"><%= installedRows.length %> item(s)</span>
    </div>
    <div class="card-body p-3">
      <div class="table-scroll-wrapper" data-floating-row-actions="true">
        <table class="table-responsive size-md" id="packageManagerTable">
          <thead>
            <tr>
              <th>Package</th>
              <th>Version</th>
              <th>Status</th>
              <th>Manifest</th>
              <th>Updated</th>
              <th>Warnings</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (!installedRows.length) { %>
              <tr><td colspan="7" class="text-center text-muted py-4">No package registry rows found.</td></tr>
            <% } %>
            <% installedRows.forEach((row) => { %>
              <tr data-package-id="<%= row.packageId %>">
                <td>
                  <div class="fw-semibold"><%= row.packageId %></div>
                  <div class="small text-muted"><%= row.name || '' %></div>
                  <% if (row.mountPath) { %><div class="small"><code><%= row.mountPath %></code></div><% } %>
                </td>
                <td><%= row.version || '-' %></td>
                <td>
                  <span class="badge <%= row.enabled ? 'bg-success-subtle text-success-emphasis border border-success-subtle' : 'bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle' %>">
                    <%= row.enabled ? 'Enabled' : 'Disabled' %>
                  </span>
                  <div class="small text-muted mt-1"><%= row.installStatus || '' %></div>
                </td>
                <td class="small">
                  <% if (row.manifestPath) { %><code><%= row.manifestPath %></code><% } else { %>-<% } %>
                </td>
                <td class="small"><%= row.updatedAt || row.installedAt || '-' %></td>
                <td class="small">
                  <% const warnings = [] %>
                  <% if (row.lastWarning) warnings.push(row.lastWarning) %>
                  <% if (row.lastError) warnings.push(row.lastError) %>
                  <% if (Array.isArray(row.warnings)) warnings.push(...row.warnings) %>
                  <% if (!warnings.length) { %>
                    <span class="text-muted">-</span>
                  <% } else { %>
                    <span class="text-warning"><%= warnings[0] %></span>
                  <% } %>
                </td>
                <td class="table-actions text-end pe-4">
                  <div class="row-actions-wrap">
                    <button
                      type="button"
                      class="btn btn-secondary btn-sm btn-row-actions-toggle"
                      data-row-actions-id="<%= row.packageId %>"
                      title="Row actions">
                      <i class="bi bi-three-dots-vertical"></i>
                    </button>
                    <div class="row-actions-menu d-none" data-row-actions-id="<%= row.packageId %>">
                      <button type="button" class="btn btn-outline-success btn-sm pkg-action-btn" data-action="enable" data-package-id="<%= row.packageId %>">
                        <i class="bi bi-play-circle me-2"></i>Enable
                      </button>
                      <button type="button" class="btn btn-outline-warning btn-sm pkg-action-btn" data-action="pause" data-package-id="<%= row.packageId %>">
                        <i class="bi bi-pause-circle me-2"></i>Pause
                      </button>
                      <button type="button" class="btn btn-outline-primary btn-sm pkg-action-btn" data-action="sync" data-package-id="<%= row.packageId %>">
                        <i class="bi bi-arrow-repeat me-2"></i>Sync Declarations
                      </button>
                      <button type="button" class="btn btn-outline-secondary btn-sm pkg-action-btn" data-action="preview-remove" data-package-id="<%= row.packageId %>">
                        <i class="bi bi-exclamation-circle me-2"></i>Impact Preview
                      </button>
                      <button type="button" class="btn btn-outline-danger btn-sm pkg-action-btn" data-action="remove" data-package-id="<%= row.packageId %>">
                        <i class="bi bi-trash me-2"></i>Remove
                      </button>
                    </div>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mt-3">
    <div class="card-header bg-white fw-bold small d-flex align-items-center justify-content-between">
      <span>Operation Output</span>
      <button type="button" class="btn btn-outline-secondary btn-sm" id="pkgClearOutputBtn">Clear</button>
    </div>
    <div class="card-body">
      <pre id="pkgOutput" class="small bg-dark text-success p-3 rounded mb-0" style="max-height: 320px; overflow:auto;">Ready.</pre>
    </div>
  </div>

  <div class="card border-0 shadow-sm mt-3">
    <div class="card-header bg-white fw-bold small d-flex align-items-center justify-content-between">
      <span>Recent Lifecycle Transactions</span>
      <span class="text-muted fw-normal" id="pkgTxnLabel">Select a package row</span>
    </div>
    <div class="card-body p-3">
      <div class="table-scroll-wrapper">
        <table class="table-responsive size-md mb-0" id="pkgTransactionTable">
          <thead>
            <tr>
              <th>Transaction</th>
              <th>Action</th>
              <th>Status</th>
              <th>Phase</th>
              <th>Finished</th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="5" class="text-center text-muted py-3">No package selected.</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <input type="hidden" id="pkgActionStateId" value="<%= actionStateValue %>">
</div>

<script>
(() => {
  const actionStateId = document.getElementById('pkgActionStateId')?.value || '';
  const outputEl = document.getElementById('pkgOutput');
  const installMethodEl = document.getElementById('pkgInstallMethod');
  const targetOrgEl = document.getElementById('pkgTargetOrgId');
  const installBtn = document.getElementById('pkgInstallBtn');
  const cleanupFailedBtn = document.getElementById('pkgCleanupFailedBtn');
  const tableEl = document.getElementById('packageManagerTable');
  const transactionTableEl = document.getElementById('pkgTransactionTable');
  const transactionLabelEl = document.getElementById('pkgTxnLabel');

  const localPanel = document.getElementById('pkgInstallLocalPanel');
  const pathPanel = document.getElementById('pkgInstallPathPanel');
  const jsonPanel = document.getElementById('pkgInstallJsonPanel');
  const zipPanel = document.getElementById('pkgInstallZipPanel');

  const actionMap = {
    enable: { endpoint: (id) => `/systemSettings/packages/${encodeURIComponent(id)}/enable`, label: 'Enable' },
    pause: { endpoint: (id) => `/systemSettings/packages/${encodeURIComponent(id)}/pause`, label: 'Pause', dangerous: true },
    'preview-remove': { endpoint: (id) => `/systemSettings/packages/${encodeURIComponent(id)}/uninstall-preview`, label: 'Impact Preview', dangerous: true },
    remove: { endpoint: (id) => `/systemSettings/packages/${encodeURIComponent(id)}/remove`, label: 'Remove', dangerous: true },
    sync: { endpoint: (id) => `/systemSettings/packages/${encodeURIComponent(id)}/sync`, label: 'Sync Declarations' }
  };

  function setOutput(title, payload) {
    const stamp = new Date().toISOString();
    outputEl.textContent = `[${stamp}] ${title}\n${JSON.stringify(payload || {}, null, 2)}`;
  }

  function showInstallPanel(method) {
    localPanel.classList.toggle('d-none', method !== 'local');
    pathPanel.classList.toggle('d-none', method !== 'path');
    jsonPanel.classList.toggle('d-none', method !== 'json');
    zipPanel.classList.toggle('d-none', method !== 'zip');
  }

  async function showModal(options) {
    if (typeof window.showMessageModal === 'function') return window.showMessageModal(options);
    return options?.buttons?.[options.buttons.length - 1]?.text || 'OK';
  }

  async function requireAdminVerification() {
    if (typeof window.requestProtectedAction !== 'function') {
      throw new Error('Admin verification modal is unavailable. Refresh and try again.');
    }
    await window.requestProtectedAction();
  }

  async function fetchJson(url, options = {}) {
    const response = await fetch(url, options);
    const text = await response.text();
    let payload = {};
    try {
      payload = text ? JSON.parse(text) : {};
    } catch (_) {
      payload = { status: 'error', message: text || `Invalid response (${response.status})` };
    }
    if (!response.ok || payload.status === 'error') {
      const message = payload.message || `Request failed (${response.status}).`;
      const error = new Error(message);
      if (response.status === 403 && payload.status === 'admin_required') {
        error.code = 'ADMIN_REQUIRED';
      }
      if (payload?.code) error.code = payload.code;
      error.payload = payload;
      throw error;
    }
    return payload;
  }

  function renderTransactions(packageId, rows = []) {
    if (!transactionTableEl) return;
    const tbody = transactionTableEl.querySelector('tbody');
    if (!tbody) return;
    const list = Array.isArray(rows) ? rows : [];
    if (!list.length) {
      tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No transactions.</td></tr>';
      return;
    }
    tbody.innerHTML = list.slice(0, 20).map((row) => {
      const txId = String(row?.id || row?.transactionId || '');
      const action = String(row?.action || '-');
      const status = String(row?.status || '-');
      const phase = String(row?.phase || '-');
      const finishedAt = String(row?.finishedAt || row?.audit?.lastUpdateDateTime || '-');
      const txLabel = txId ? `<code>${txId}</code>` : '-';
      return `<tr><td>${txLabel}</td><td>${action}</td><td>${status}</td><td>${phase}</td><td class="small">${finishedAt}</td></tr>`;
    }).join('');
    if (transactionLabelEl) {
      transactionLabelEl.textContent = `${packageId} (${list.length})`;
    }
  }

  async function loadTransactions(packageId) {
    if (!packageId) return;
    try {
      const payload = await fetchJson(`/systemSettings/packages/${encodeURIComponent(packageId)}/transactions?limit=20`, {
        method: 'GET',
        credentials: 'same-origin',
        headers: {
          'Accept': 'application/json',
          'X-AJAX-Request': 'true'
        }
      });
      renderTransactions(packageId, payload.rows || []);
    } catch (error) {
      renderTransactions(packageId, []);
      setOutput('Transaction Load Failed', { packageId, message: error.message || 'Unknown error' });
    }
  }

  function clampProgress(value) {
    const numeric = Number(value);
    if (!Number.isFinite(numeric)) return null;
    return Math.max(0, Math.min(100, Math.round(numeric)));
  }

  function waitMs(ms) {
    return new Promise((resolve) => setTimeout(resolve, Math.max(0, Number(ms) || 0)));
  }

  function getInstallProgressSteps(method) {
    const normalizedMethod = String(method || '').trim().toLowerCase();
    const isZip = normalizedMethod === 'zip';
    return [
      {
        progress: 6,
        note: 'Validating request and access permissions...',
        operation: 'Validation'
      },
      {
        progress: 20,
        note: isZip ? 'Preparing ZIP and signature payload...' : 'Preparing install request payload...',
        operation: 'Preparation'
      },
      {
        progress: isZip ? 38 : 34,
        note: isZip ? 'Uploading package artifacts...' : 'Submitting package install request...',
        operation: isZip ? 'Upload' : 'Submission'
      },
      {
        progress: 58,
        note: 'Verifying manifest and security constraints...',
        operation: 'Verification'
      },
      {
        progress: 78,
        note: 'Applying package declarations and data...',
        operation: 'Apply'
      },
      {
        progress: 92,
        note: 'Finalizing installation...',
        operation: 'Finalize'
      }
    ];
  }

  function buildLoadingState(title, fallbackNote, fallbackOperation, step = null) {
    const state = {
      title: String(title || '').trim() || 'Please wait',
      note: String(fallbackNote || '').trim() || 'Processing your request...',
      operation: String(fallbackOperation || '').trim(),
      progress: null
    };
    if (!step || typeof step !== 'object') return state;
    if (typeof step.note === 'string' && step.note.trim()) state.note = step.note.trim();
    if (typeof step.operation === 'string' && step.operation.trim()) state.operation = step.operation.trim();
    const nextProgress = clampProgress(step.progress);
    if (nextProgress !== null) state.progress = nextProgress;
    return state;
  }

  async function runWithWaiting(title, fn, options = {}) {
    let token = null;
    const note = String(options?.note || 'Please wait while package lifecycle operation completes.').trim();
    const operation = String(options?.operation || 'Package Lifecycle').trim();
    const progressSteps = Array.isArray(options?.progressSteps) ? options.progressSteps.filter((item) => item && typeof item === 'object') : [];
    const stepIntervalMs = Math.max(450, Number(options?.stepIntervalMs) || 1400);
    let stepIndex = 0;
    let stepTimer = null;

    const applyStep = (index) => {
      if (!progressSteps.length) return;
      const safeIndex = Math.max(0, Math.min(progressSteps.length - 1, index));
      stepIndex = safeIndex;
      if (typeof window.updateLoading === 'function') {
        window.updateLoading(buildLoadingState(title, note, operation, progressSteps[safeIndex]));
      }
    };

    try {
      if (typeof window.showLoading === 'function') {
        if (progressSteps.length) {
          token = window.showLoading(buildLoadingState(title, note, operation, progressSteps[0]));
        } else {
          token = window.showLoading({
            title,
            note,
            operation
          });
        }
      }
      if (progressSteps.length > 1) {
        stepTimer = window.setInterval(() => {
          if (stepIndex >= progressSteps.length - 1) return;
          applyStep(stepIndex + 1);
        }, stepIntervalMs);
      }
      const result = await fn();
      if (progressSteps.length && typeof window.updateLoading === 'function') {
        window.updateLoading({
          title: String(title || '').trim() || 'Please wait',
          note: 'Operation completed successfully.',
          operation: 'Completed',
          progress: 100
        });
        await waitMs(220);
      }
      return result;
    } finally {
      if (stepTimer) {
        window.clearInterval(stepTimer);
      }
      if (typeof window.hideLoading === 'function' && token) {
        window.hideLoading(token);
      }
    }
  }

  function escapeHtml(value) {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatBytes(value) {
    const size = Number(value);
    if (!Number.isFinite(size) || size <= 0) return '-';
    if (size < 1024) return `${size} B`;
    if (size < 1024 * 1024) return `${(size / 1024).toFixed(1)} KB`;
    if (size < 1024 * 1024 * 1024) return `${(size / (1024 * 1024)).toFixed(1)} MB`;
    return `${(size / (1024 * 1024 * 1024)).toFixed(2)} GB`;
  }

  function createRemoveInventoryWizardState(packageId, preview = {}) {
    const inventory = preview && typeof preview === 'object' ? (preview.deletionInventory || {}) : {};
    const hasOwnSelectedFlag = (row) => row && typeof row === 'object' && Object.prototype.hasOwnProperty.call(row, 'selected');
    const defaultSelected = (row) => (hasOwnSelectedFlag(row) ? row.selected === true : true);

    return {
      packageId: String(packageId || '').trim(),
      modifiedCount: Array.isArray(preview?.modifiedRecords) ? preview.modifiedRecords.length : 0,
      criticalRows: (Array.isArray(inventory.critical) ? inventory.critical : [])
        .filter((row) => row && (row.id || row.label))
        .map((row) => ({
          id: String(row.id || '').trim(),
          label: String(row.label || row.id || 'Critical item')
        })),
      tableRows: (Array.isArray(inventory.tables) ? inventory.tables : [])
        .filter((row) => row && row.id && row.entityType)
        .map((row) => ({
          id: String(row.id || '').trim(),
          entityType: String(row.entityType || '').trim(),
          backendMode: String(row.backendMode || 'data').trim(),
          estimatedRowCount: Number(row.estimatedRowCount || 0) || 0,
          selected: defaultSelected(row)
        })),
      fileRows: (Array.isArray(inventory.files) ? inventory.files : [])
        .filter((row) => row && row.id)
        .map((row) => ({
          id: String(row.id || '').trim(),
          exists: row.exists === true,
          size: Number(row.size || 0) || 0,
          selected: defaultSelected(row)
        }))
    };
  }

  function getRemoveWizardStepModel(stepIndex = 0) {
    const steps = [
      { key: 'critical', title: 'Critical (Always Removed)', selectable: false },
      { key: 'table', title: 'Tables (Selectable)', selectable: true },
      { key: 'file', title: 'Files (Selectable)', selectable: true }
    ];
    return steps[Math.max(0, Math.min(steps.length - 1, Number(stepIndex) || 0))];
  }

  function setRemoveWizardSelection(state, kind, itemId, checked) {
    if (!state || !kind || !itemId) return;
    const key = String(kind || '').trim().toLowerCase();
    const id = String(itemId || '').trim();
    const nextChecked = checked === true;
    if (!id) return;
    if (key === 'table') {
      const row = state.tableRows.find((entry) => entry && entry.id === id);
      if (row) row.selected = nextChecked;
    }
    if (key === 'file') {
      const row = state.fileRows.find((entry) => entry && entry.id === id);
      if (row) row.selected = nextChecked;
    }
  }

  function setRemoveWizardSelectionAll(state, kind, checked) {
    if (!state || !kind) return;
    const key = String(kind || '').trim().toLowerCase();
    const nextChecked = checked === true;
    if (key === 'table') {
      state.tableRows.forEach((row) => {
        if (row && row.id) row.selected = nextChecked;
      });
    }
    if (key === 'file') {
      state.fileRows.forEach((row) => {
        if (row && row.id) row.selected = nextChecked;
      });
    }
  }

  function buildRemoveWizardItemsHtml(state, kind) {
    const key = String(kind || '').trim().toLowerCase();
    if (key === 'critical') {
      if (!Array.isArray(state.criticalRows) || state.criticalRows.length === 0) {
        return '<div class="small text-muted">No critical items were listed.</div>';
      }
      return state.criticalRows.map((row) => `
        <label class="d-flex align-items-start gap-2 small mb-2">
          <input type="checkbox" checked disabled>
          <span>${escapeHtml(row.label || row.id || 'Critical item')}</span>
        </label>
      `).join('');
    }

    if (key === 'table') {
      if (!Array.isArray(state.tableRows) || state.tableRows.length === 0) {
        return '<div class="small text-muted">No payload tables detected for this package.</div>';
      }
      return state.tableRows.map((row) => `
        <label class="d-flex align-items-start gap-2 small mb-2">
          <input
            class="pkg-remove-wizard-check"
            type="checkbox"
            data-kind="table"
            data-item-id="${escapeHtml(row.id)}"
            ${row.selected ? 'checked' : ''}>
          <span>
            <span class="fw-semibold">${escapeHtml(row.entityType)}</span>
            <span class="text-muted">(${escapeHtml(row.backendMode || 'data')} | rows: ${Number(row.estimatedRowCount || 0)})</span>
          </span>
        </label>
      `).join('');
    }

    if (!Array.isArray(state.fileRows) || state.fileRows.length === 0) {
      return '<div class="small text-muted">No payload files detected for this package.</div>';
    }
    return state.fileRows.map((row) => `
      <label class="d-flex align-items-start gap-2 small mb-2">
        <input
          class="pkg-remove-wizard-check"
          type="checkbox"
          data-kind="file"
          data-item-id="${escapeHtml(row.id)}"
          ${row.selected ? 'checked' : ''}>
        <span>
          <span class="fw-semibold">${escapeHtml(row.id)}</span>
          <span class="text-muted d-block">exists: ${row.exists ? 'yes' : 'no'} | size: ${escapeHtml(formatBytes(row.size))}</span>
        </span>
      </label>
    `).join('');
  }

  function buildRemoveWizardStepHtml(state, stepIndex = 0) {
    const stepModel = getRemoveWizardStepModel(stepIndex);
    const stepNumber = Math.max(1, Math.min(3, Number(stepIndex || 0) + 1));
    const stepHint = stepModel.key === 'critical'
      ? 'These items are mandatory and will always be removed.'
      : (stepModel.key === 'table'
        ? 'Choose package tables/collections to remove.'
        : 'Choose payload-copied files to remove.');
    const selectableControls = stepModel.selectable
      ? `
        <div class="d-flex gap-2 flex-wrap">
          <button type="button" class="btn btn-outline-secondary btn-sm pkg-remove-wizard-toggle-btn" data-kind="${escapeHtml(stepModel.key)}" data-mode="all">Select All</button>
          <button type="button" class="btn btn-outline-secondary btn-sm pkg-remove-wizard-toggle-btn" data-kind="${escapeHtml(stepModel.key)}" data-mode="none">Unselect All</button>
        </div>
      `
      : '';

    return `
      <div class="small">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
          <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">Step ${stepNumber} of 3</span>
          <span class="text-muted">Package: <code>${escapeHtml(state.packageId)}</code></span>
        </div>
        <p class="mb-2">
          Preview found <b>${Number(state.modifiedCount || 0)}</b> modified package-owned record(s).
        </p>
        <div class="border rounded p-2">
          <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
            <div>
              <div class="fw-semibold">${escapeHtml(stepModel.title)}</div>
              <div class="text-muted small">${escapeHtml(stepHint)}</div>
            </div>
            ${selectableControls}
          </div>
          <div class="border rounded p-2" style="height: 250px; overflow:auto;">
            ${buildRemoveWizardItemsHtml(state, stepModel.key)}
          </div>
        </div>
      </div>
    `;
  }

  function attachRemoveWizardStepHandlers(state, stepIndex = 0) {
    const stepModel = getRemoveWizardStepModel(stepIndex);
    if (!stepModel.selectable) return;
    const body = document.getElementById('messageModalBody');
    if (!body) return;

    body.querySelectorAll('.pkg-remove-wizard-check[type="checkbox"]').forEach((input) => {
      input.addEventListener('change', () => {
        const kind = String(input.getAttribute('data-kind') || '').trim().toLowerCase();
        const itemId = String(input.getAttribute('data-item-id') || '').trim();
        setRemoveWizardSelection(state, kind, itemId, input.checked === true);
      });
    });

    body.querySelectorAll('.pkg-remove-wizard-toggle-btn').forEach((button) => {
      button.addEventListener('click', (event) => {
        event.preventDefault();
        const kind = String(button.getAttribute('data-kind') || '').trim().toLowerCase();
        const mode = String(button.getAttribute('data-mode') || '').trim().toLowerCase();
        const selectAll = mode === 'all';
        setRemoveWizardSelectionAll(state, kind, selectAll);
        body.querySelectorAll(`.pkg-remove-wizard-check[data-kind="${kind}"]`).forEach((input) => {
          input.checked = selectAll;
        });
      });
    });
  }

  function collectDeleteSelectionFromWizardState(state) {
    return {
      tables: (Array.isArray(state?.tableRows) ? state.tableRows : [])
        .filter((row) => row && row.id && row.selected === true)
        .map((row) => row.id),
      files: (Array.isArray(state?.fileRows) ? state.fileRows : [])
        .filter((row) => row && row.id && row.selected === true)
        .map((row) => row.id)
    };
  }

  async function showRemoveInventoryWizard(packageId, preview = {}) {
    const state = createRemoveInventoryWizardState(packageId, preview);
    let stepIndex = 0;

    while (true) {
      const buttons = stepIndex === 0
        ? [
          { text: 'Cancel', class: 'btn-secondary' },
          { text: 'Next', class: 'btn-primary' }
        ]
        : (stepIndex === 1
          ? [
            { text: 'Cancel', class: 'btn-secondary' },
            { text: 'Back', class: 'btn-outline-secondary' },
            { text: 'Next', class: 'btn-primary' }
          ]
          : [
            { text: 'Cancel', class: 'btn-secondary' },
            { text: 'Back', class: 'btn-outline-secondary' },
            { text: 'Remove Package', class: 'btn-danger' }
          ]);

      const decisionPromise = showModal({
        title: 'Remove Package',
        icon: 'warning',
        size: 'lg',
        message: buildRemoveWizardStepHtml(state, stepIndex),
        buttons
      });

      attachRemoveWizardStepHandlers(state, stepIndex);
      const decision = await decisionPromise;

      if (decision === 'Cancel' || decision === 'closed') {
        return { status: 'cancelled', report: preview };
      }
      if (decision === 'Back') {
        stepIndex = Math.max(0, stepIndex - 1);
        continue;
      }
      if (decision === 'Next') {
        stepIndex = Math.min(2, stepIndex + 1);
        continue;
      }
      if (decision === 'Remove Package') {
        return {
          status: 'ready',
          report: preview,
          deleteSelection: collectDeleteSelectionFromWizardState(state)
        };
      }
      return { status: 'cancelled', report: preview };
    }
  }

  async function confirmDanger(actionLabel, packageId) {
    const selected = await showModal({
      title: `${actionLabel} Package`,
      icon: 'warning',
      message: `You are about to <b>${actionLabel.toLowerCase()}</b> package <code>${packageId}</code>. This is a destructive lifecycle action.`,
      buttons: [
        { text: 'Cancel', class: 'btn-secondary' },
        { text: actionLabel, class: 'btn-danger' }
      ]
    });
    return selected === actionLabel;
  }

  async function confirmCleanupFailedAttempts() {
    const selected = await showModal({
      title: 'Clean Failed Attempts',
      icon: 'warning',
      message: 'This removes failed package-install attempts and their leftover registry/files when possible. Continue?',
      buttons: [
        { text: 'Cancel', class: 'btn-secondary' },
        { text: 'Clean Failed Attempts', class: 'btn-danger' }
      ]
    });
    return selected === 'Clean Failed Attempts';
  }

  async function installPackage() {
    const installMethod = String(installMethodEl.value || '').trim();
    const targetOrgId = String(targetOrgEl?.value || '').trim();
    const progressSteps = getInstallProgressSteps(installMethod);
    await requireAdminVerification();
    if (installMethod === 'zip') {
      const zipFile = document.getElementById('pkgZipFile')?.files?.[0] || null;
      const sigFile = document.getElementById('pkgSigFile')?.files?.[0] || null;
      const formData = new FormData();
      formData.set('actionStateId', actionStateId);
      if (targetOrgId) formData.set('targetOrgId', targetOrgId);
      if (zipFile) formData.set('packageZip', zipFile);
      if (sigFile) formData.set('packageSig', sigFile);
      return runWithWaiting('Installing Package ZIP', async () => fetchJson('/systemSettings/packages/install-zip', {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Accept': 'application/json',
          'X-AJAX-Request': 'true'
        },
        body: formData
      }), {
        note: 'Preparing secure package upload...',
        operation: 'ZIP Install',
        progressSteps
      });
    }

    const payload = {
      installMethod,
      localManifestPath: document.getElementById('pkgLocalManifestPath').value || '',
      manifestPath: document.getElementById('pkgManualManifestPath').value || '',
      manifestJson: document.getElementById('pkgManifestJson').value || '',
      actionStateId
    };
    if (targetOrgId) payload.targetOrgId = targetOrgId;
    return runWithWaiting('Installing Package', async () => fetchJson('/systemSettings/packages/install', {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'Accept': 'application/json',
        'X-AJAX-Request': 'true'
      },
      body: new URLSearchParams(payload).toString()
    }), {
      note: 'Preparing package installation...',
      operation: 'Install',
      progressSteps
    });
  }

  async function runRowAction(action, packageId) {
    const config = actionMap[action];
    if (!config) throw new Error('Unknown action.');
    if (action === 'preview-remove') {
      await requireAdminVerification();
      const result = await runWithWaiting('Preview Uninstall Impact', async () => fetchJson(config.endpoint(packageId), {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'Accept': 'application/json',
          'X-AJAX-Request': 'true'
        },
        body: new URLSearchParams({ actionStateId }).toString()
      }));
      await loadTransactions(packageId);
      return result;
    }

    if (action === 'remove') {
      await requireAdminVerification();
      const previewResult = await runWithWaiting('Preview Uninstall Impact', async () => fetchJson(
        `/systemSettings/packages/${encodeURIComponent(packageId)}/uninstall-preview`,
        {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'Accept': 'application/json',
            'X-AJAX-Request': 'true'
          },
          body: new URLSearchParams({ actionStateId }).toString()
        }
      ));
      const preview = previewResult.report || {};
      let removeUrl = config.endpoint(packageId);
      const bodyPayload = {
        actionStateId,
        cleanupMode: 'full',
        previewTransactionId: preview.previewTransactionId || ''
      };

      if (preview.mode === 'blocked_missing_manifest') {
        const blockedText = Array.isArray(preview.blockedReasons) && preview.blockedReasons.length
          ? preview.blockedReasons.join(' ')
          : 'Manifest or builder payload is missing, so full cleanup remove is blocked.';
        throw new Error(blockedText);
      }

      const wizardResult = await showRemoveInventoryWizard(packageId, preview);
      if (wizardResult?.status !== 'ready') return { status: 'cancelled', report: preview };
      bodyPayload.deleteSelection = JSON.stringify(wizardResult.deleteSelection || { tables: [], files: [] });

      const removeResult = await runWithWaiting('Removing Package', async () => fetchJson(removeUrl, {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'Accept': 'application/json',
          'X-AJAX-Request': 'true'
        },
        body: new URLSearchParams(bodyPayload).toString()
      }));
      await loadTransactions(packageId);
      return removeResult;
    }

    if (config.dangerous) {
      const confirmed = await confirmDanger(config.label, packageId);
      if (!confirmed) return { status: 'cancelled' };
    }
    await requireAdminVerification();
    const response = await runWithWaiting(`${config.label} Package`, async () => fetchJson(config.endpoint(packageId), {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'Accept': 'application/json',
        'X-AJAX-Request': 'true'
      },
      body: new URLSearchParams({ actionStateId }).toString()
    }));
    await loadTransactions(packageId);
    return response;
  }

  async function cleanupFailedAttempts() {
    const confirmed = await confirmCleanupFailedAttempts();
    if (!confirmed) return { status: 'cancelled' };
    await requireAdminVerification();
    return runWithWaiting('Cleaning Failed Attempts', async () => fetchJson('/systemSettings/packages/cleanup-failed', {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'Accept': 'application/json',
        'X-AJAX-Request': 'true'
      },
      body: new URLSearchParams({ actionStateId }).toString()
    }), {
      note: 'Removing failed package attempts and stale package files...',
      operation: 'Cleanup Failed Attempts',
      progressSteps: [
        { progress: 15, note: 'Validating access and request token...', operation: 'Validation' },
        { progress: 40, note: 'Scanning installed package snapshot...', operation: 'Snapshot' },
        { progress: 70, note: 'Applying cleanup for failed package attempts...', operation: 'Cleanup' },
        { progress: 92, note: 'Finalizing cleanup report...', operation: 'Finalize' }
      ]
    });
  }

  async function showSuccess(message) {
    await showModal({
      title: 'Completed',
      icon: 'success',
      message,
      buttons: [{ text: 'OK', class: 'btn-success' }]
    });
  }

  async function showError(message) {
    await showModal({
      title: 'Operation Failed',
      icon: 'error',
      message,
      buttons: [{ text: 'Close', class: 'btn-danger' }]
    });
  }

  installMethodEl.addEventListener('change', () => showInstallPanel(installMethodEl.value));
  showInstallPanel(installMethodEl.value);

  installBtn.addEventListener('click', async () => {
    const original = installBtn.innerHTML;
    installBtn.disabled = true;
    installBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Running...';
    try {
      const result = await installPackage();
      setOutput('Install / Enable', result.report || result);
      await showSuccess(result.message || 'Package operation completed.');
      window.location.reload();
    } catch (error) {
      setOutput('Install Failed', {
        status: 'error',
        message: error.message || 'Unknown error',
        code: error?.code || '',
        details: error?.payload?.details || null
      });
      await showError(error.message || 'Package install failed.');
    } finally {
      installBtn.disabled = false;
      installBtn.innerHTML = original;
    }
  });

  cleanupFailedBtn?.addEventListener('click', async () => {
    const original = cleanupFailedBtn.innerHTML;
    cleanupFailedBtn.disabled = true;
    cleanupFailedBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Running...';
    try {
      const result = await cleanupFailedAttempts();
      if (result?.status === 'cancelled') {
        setOutput('Cancelled', { action: 'cleanup-failed-attempts' });
        return;
      }
      setOutput('Cleanup Failed Attempts', result.report || result);
      await showSuccess(result.message || 'Failed package attempts cleanup completed.');
      window.location.reload();
    } catch (error) {
      setOutput('Cleanup Failed Attempts Failed', {
        status: 'error',
        message: error.message || 'Unknown error',
        code: error?.code || '',
        details: error?.payload?.details || null
      });
      await showError(error.message || 'Failed package attempts cleanup failed.');
    } finally {
      cleanupFailedBtn.disabled = false;
      cleanupFailedBtn.innerHTML = original;
    }
  });

  document.addEventListener('click', async (event) => {
    const btn = event.target.closest('.pkg-action-btn');
    if (!btn) return;
    if (!btn.closest('.row-actions-menu')) return;
    const action = String(btn.dataset.action || '').trim();
    const packageId = String(btn.dataset.packageId || '').trim();
    if (!action || !packageId) return;
    if (!actionMap[action]) return;
    const original = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
    try {
      const result = await runRowAction(action, packageId);
      if (result?.status === 'cancelled') {
        setOutput('Cancelled', { action, packageId });
        return;
      }
      setOutput(`${actionMap[action]?.label || action} ${packageId}`, result.report || result);
      await showSuccess(result.message || 'Package operation completed.');
      if (action === 'preview-remove') return;
      window.location.reload();
    } catch (error) {
      setOutput('Action Failed', {
        action,
        packageId,
        message: error.message || 'Unknown error',
        code: error?.code || '',
        details: error?.payload?.details || null
      });
      await showError(error.message || 'Package action failed.');
    } finally {
      btn.disabled = false;
      btn.innerHTML = original;
    }
  });

  document.getElementById('pkgRefreshSnapshotBtn')?.addEventListener('click', () => {
    window.location.reload();
  });
  document.getElementById('pkgClearOutputBtn')?.addEventListener('click', () => {
    outputEl.textContent = 'Ready.';
  });

  const firstPackageRow = tableEl?.querySelector('tbody tr[data-package-id]');
  if (firstPackageRow?.dataset?.packageId) {
    loadTransactions(firstPackageRow.dataset.packageId);
  }
})();
</script>
