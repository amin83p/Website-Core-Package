<%
  const backend = runtimeBackend || {};
  const activeMode = String(backend.mode || 'json').trim().toLowerCase();
  const preflightReport = (typeof preflight !== 'undefined' && preflight && typeof preflight === 'object') ? preflight : {};
  const actionStateValue = typeof actionStateId !== 'undefined' ? actionStateId : '';
  const confirmTokenHintValue = typeof confirmTokenHint !== 'undefined' && confirmTokenHint ? String(confirmTokenHint) : 'RESET CORE';
%>

<div class="sections-page core-reset-page">
  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
      <h1 class="page-heading size-md text-start m-0">Core Reset + Re-Bootstrap</h1>
      <p class="text-muted mb-0 mt-1">Delete current core registry entities and immediately rebuild them from the Core Bootstrap baseline pack.</p>
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <span class="badge bg-danger-subtle text-danger-emphasis border border-danger-subtle">DESTRUCTIVE TOOL</span>
      <span class="badge bg-light text-dark border">Runtime: <%= activeMode.toUpperCase() %></span>
      <a href="/systemSettings/bootstrap/core" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Core Bootstrap</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-bold small">Reset Scope</div>
    <div class="card-body p-3">
      <div class="alert alert-warning py-2 px-3 small mb-3">
        <i class="bi bi-exclamation-triangle me-2"></i>
        This operation deletes core bootstrap entities only: sections, operations, roles, scopes, symbols, accesses, and access policies. It does not remove users, persons, organizations, or package domain data.
      </div>

      <div class="row g-3 align-items-end">
        <div class="col-md-6 col-lg-5">
          <label class="form-label small fw-bold">Type Confirmation Token</label>
          <input class="form-control" id="coreResetConfirmToken" placeholder="<%= confirmTokenHintValue %>">
          <div class="form-text">Required phrase: <code><%= confirmTokenHintValue %></code></div>
        </div>
        <div class="col-md-6 col-lg-7 d-flex align-items-center gap-2 flex-wrap">
          <button type="button" class="btn btn-outline-secondary" id="coreResetPreflightBtn">
            <i class="bi bi-search me-1"></i>Refresh Preflight
          </button>
          <button type="button" class="btn btn-danger btn-filled" id="coreResetApplyBtn">
            <i class="bi bi-arrow-repeat me-1"></i>Reset + Re-Bootstrap
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-bold small">Preflight Summary</div>
    <div class="card-body p-3">
      <div class="row g-3">
        <div class="col-md-3"><div class="small text-muted">Entity Count</div><div class="fs-5 fw-bold" id="coreResetEntityCount">0</div></div>
        <div class="col-md-3"><div class="small text-muted">Rows To Delete</div><div class="fs-5 fw-bold text-danger" id="coreResetRowsToDelete">0</div></div>
        <div class="col-md-3"><div class="small text-muted">Baseline ID</div><div class="fs-6 fw-bold text-break" id="coreResetBaselineId">-</div></div>
        <div class="col-md-3"><div class="small text-muted">Baseline Version</div><div class="fs-6 fw-bold" id="coreResetBaselineVersion">-</div></div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-bold small">Entity Breakdown</div>
    <div class="card-body p-3">
      <div class="table-scroll-wrapper">
        <table class="table-responsive size-md" id="coreResetEntityTable">
          <thead>
            <tr>
              <th>Entity</th>
              <th>Current Rows</th>
            </tr>
          </thead>
          <tbody>
            <tr><td colspan="2" class="text-center text-muted py-3">Run preflight to load rows.</td></tr>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold small d-flex align-items-center justify-content-between">
      <span>Operation Output</span>
      <button type="button" class="btn btn-outline-secondary btn-sm" id="coreResetClearOutputBtn">Clear</button>
    </div>
    <div class="card-body">
      <pre id="coreResetOutput" class="small bg-dark text-success p-3 rounded mb-0" style="max-height: 320px; overflow:auto;">Ready.</pre>
    </div>
  </div>

  <input type="hidden" id="coreResetActionStateId" value="<%= actionStateValue %>">
  <input type="hidden" id="coreResetConfirmHint" value="<%= confirmTokenHintValue %>">
</div>

<script>
(() => {
  const initialReport = <%- JSON.stringify(preflightReport || {}) %>;
  const actionStateId = document.getElementById('coreResetActionStateId')?.value || '';
  const confirmTokenHint = document.getElementById('coreResetConfirmHint')?.value || 'RESET CORE';
  const confirmInput = document.getElementById('coreResetConfirmToken');
  const preflightBtn = document.getElementById('coreResetPreflightBtn');
  const applyBtn = document.getElementById('coreResetApplyBtn');
  const outputEl = document.getElementById('coreResetOutput');
  const entityTableBody = document.querySelector('#coreResetEntityTable tbody');

  function setOutput(title, payload) {
    const stamp = new Date().toISOString();
    outputEl.textContent = `[${stamp}] ${title}\n${JSON.stringify(payload || {}, null, 2)}`;
  }

  function readSafeJson(response) {
    return response.json().catch(() => ({}));
  }

  function renderSummary(report) {
    const summary = report?.summary || {};
    const entities = Array.isArray(report?.entities) ? report.entities : [];
    document.getElementById('coreResetEntityCount').textContent = Number(summary.entityCount || entities.length || 0);
    document.getElementById('coreResetRowsToDelete').textContent = Number(summary.totalRows || 0);
    document.getElementById('coreResetBaselineId').textContent = String(report?.baseline?.id || '-');
    document.getElementById('coreResetBaselineVersion').textContent = String(report?.baseline?.version || '-');

    if (!entities.length) {
      entityTableBody.innerHTML = '<tr><td colspan="2" class="text-center text-muted py-3">No entity rows reported.</td></tr>';
      return;
    }

    entityTableBody.innerHTML = entities.map((row) => `
      <tr>
        <td><code>${String(row?.entityType || '-')}</code></td>
        <td class="fw-semibold text-danger">${Number(row?.rowCount || 0)}</td>
      </tr>
    `).join('');
  }

  async function runPreflight() {
    const response = await fetch('/systemSettings/core-reset/preflight', {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'Accept': 'application/json',
        'X-AJAX-Request': 'true'
      },
      body: new URLSearchParams({ actionStateId }).toString()
    });
    const payload = await readSafeJson(response);
    if (!response.ok || payload?.status === 'error') {
      throw new Error(payload?.message || `Preflight failed (${response.status}).`);
    }
    return payload;
  }

  async function runApply(confirmToken) {
    if (typeof window.requestProtectedAction === 'function') {
      await window.requestProtectedAction();
    }

    const response = await fetch('/systemSettings/core-reset/apply', {
      method: 'POST',
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'Accept': 'application/json',
        'X-AJAX-Request': 'true'
      },
      body: new URLSearchParams({ actionStateId, confirmToken }).toString()
    });
    const payload = await readSafeJson(response);
    if (response.status === 403 && payload?.status === 'admin_required') {
      if (typeof window.resetAdminVerificationCache === 'function') {
        window.resetAdminVerificationCache();
      }
      throw new Error(payload?.message || 'Admin approval required or session expired.');
    }
    if (!response.ok || payload?.status === 'error') {
      throw new Error(payload?.message || `Apply failed (${response.status}).`);
    }
    return payload;
  }

  async function withWait(title, fn) {
    let token = null;
    try {
      if (typeof window.showLoading === 'function') {
        token = window.showLoading({ title, note: 'Please wait while reset and bootstrap are running.', operation: 'Core Reset' });
      }
      return await fn();
    } finally {
      if (token && typeof window.hideLoading === 'function') {
        window.hideLoading(token);
      }
    }
  }

  async function onPreflightClick() {
    const original = preflightBtn.innerHTML;
    preflightBtn.disabled = true;
    preflightBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Checking...';
    try {
      const payload = await withWait('Running Reset Preflight', () => runPreflight());
      renderSummary(payload.report || {});
      setOutput('Preflight Completed', payload.report || payload);
    } catch (error) {
      setOutput('Preflight Failed', { status: 'error', message: error.message || 'Unknown error' });
      if (typeof showMessageModal === 'function') {
        await showMessageModal({ title: 'Preflight Failed', icon: 'error', message: error.message || 'Preflight failed.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
      }
    } finally {
      preflightBtn.disabled = false;
      preflightBtn.innerHTML = original;
    }
  }

  async function onApplyClick() {
    const tokenValue = String(confirmInput?.value || '').trim();
    if (tokenValue.toUpperCase() !== confirmTokenHint.toUpperCase()) {
      if (typeof showMessageModal === 'function') {
        await showMessageModal({
          title: 'Confirmation Required',
          icon: 'warning',
          message: `Type "${confirmTokenHint}" in the confirmation field to continue.`,
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
      }
      return;
    }

    const confirmText = 'Reset + Re-Bootstrap';
    let confirmed = true;
    if (typeof showMessageModal === 'function') {
      const selected = await showMessageModal({
        title: 'Confirm Core Reset',
        icon: 'warning',
        message: 'This will delete current core registry entities and immediately recreate defaults from baseline.',
        buttons: [{ text: 'Cancel', class: 'btn-secondary' }, { text: confirmText, class: 'btn-danger' }]
      });
      confirmed = selected === confirmText;
    }
    if (!confirmed) return;

    const original = applyBtn.innerHTML;
    applyBtn.disabled = true;
    applyBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Running...';
    try {
      const payload = await withWait('Running Core Reset', () => runApply(tokenValue));
      setOutput('Reset + Re-Bootstrap Completed', payload.report || payload);
      const preflightPayload = await withWait('Refreshing Preflight', () => runPreflight());
      renderSummary(preflightPayload.report || {});
      if (typeof showMessageModal === 'function') {
        await showMessageModal({ title: 'Operation Completed', icon: 'success', message: 'Core reset and re-bootstrap completed.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
      }
    } catch (error) {
      setOutput('Apply Failed', { status: 'error', message: error.message || 'Unknown error' });
      if (typeof showMessageModal === 'function') {
        await showMessageModal({ title: 'Operation Failed', icon: 'error', message: error.message || 'Core reset failed.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
      }
    } finally {
      applyBtn.disabled = false;
      applyBtn.innerHTML = original;
    }
  }

  document.getElementById('coreResetClearOutputBtn')?.addEventListener('click', () => {
    outputEl.textContent = 'Ready.';
  });
  preflightBtn?.addEventListener('click', () => {
    onPreflightClick().catch((error) => setOutput('Preflight Failed', { status: 'error', message: error.message || 'Unknown error' }));
  });
  applyBtn?.addEventListener('click', () => {
    onApplyClick().catch((error) => setOutput('Apply Failed', { status: 'error', message: error.message || 'Unknown error' }));
  });

  renderSummary(initialReport || {});
})();
</script>
