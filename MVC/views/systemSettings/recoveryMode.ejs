<%
  const status = (typeof backendStatus !== 'undefined' && backendStatus && typeof backendStatus === 'object')
    ? backendStatus
    : {};
  const runtime = status.runtime || {};
  const fallback = status.fallback || {};
  const mongo = status.mongo || {};
  const pageMessage = String(typeof message !== 'undefined' && message ? message : 'The app is running in database recovery mode.');
  const pathLabel = String(typeof attemptedPath !== 'undefined' && attemptedPath ? attemptedPath : '');
  const adminRecovery = Boolean(typeof isAdminRecoveryUser !== 'undefined' && isAdminRecoveryUser);
  const lastError = runtime.lastMongoError && runtime.lastMongoError.message ? String(runtime.lastMongoError.message) : '';
%>

<div class="container py-5">
  <div class="dash-hero mb-4 d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
    <div>
      <div class="text-uppercase fw-bold small text-warning mb-2">
        <i class="bi bi-database-exclamation me-1"></i> Database Recovery Mode
      </div>
      <h1 class="page-heading size-lg mb-2">MongoDB is not available</h1>
      <p class="text-muted mb-0" style="font-size:1.05rem; max-width: 820px;">
        <%= pageMessage %>
      </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <% if (adminRecovery) { %>
        <a href="/systemSettings/data-backend" class="btn btn-warning btn-md fw-bold">
          <i class="bi bi-database-gear me-1"></i> Backend Status
        </a>
        <a href="/systemSettings" class="btn btn-outline-secondary btn-md">
          System Settings
        </a>
      <% } else if (!user) { %>
        <a href="/login" class="btn btn-primary btn-filled btn-md">
          Sign In
        </a>
      <% } %>
      <% if (user) { %>
        <a href="/logout" class="btn btn-outline-danger btn-md">Logout</a>
      <% } %>
    </div>
  </div>

  <div class="row g-4">
    <div class="col-lg-7">
      <div class="module-card h-100">
        <div class="module-accent"></div>
        <h4 class="fw-bold mb-3">Runtime Backend Status</h4>
        <div class="row g-3">
          <div class="col-md-6">
            <div class="p-3 border rounded bg-light h-100">
              <div class="small text-muted text-uppercase fw-bold mb-1">Requested Backend</div>
              <div class="fs-5 fw-bold"><%= runtime.requestedMode || status.requested || 'mongo' %></div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 border rounded bg-light h-100">
              <div class="small text-muted text-uppercase fw-bold mb-1">Active Backend</div>
              <div class="fs-5 fw-bold text-warning"><%= status.mode || runtime.activeMode || 'json' %></div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 border rounded bg-light h-100">
              <div class="small text-muted text-uppercase fw-bold mb-1">Fallback Reason</div>
              <div class="fw-bold text-capitalize"><%= String(fallback.reason || 'unknown').replace(/_/g, ' ') %></div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="p-3 border rounded bg-light h-100">
              <div class="small text-muted text-uppercase fw-bold mb-1">Last Checked</div>
              <div class="fw-bold"><%= runtime.lastMongoCheckAt || fallback.startedAt || '-' %></div>
            </div>
          </div>
        </div>

        <% if (lastError) { %>
          <div class="alert alert-danger mt-3 mb-0">
            <div class="fw-bold mb-1"><i class="bi bi-bug me-1"></i> Last Mongo Error</div>
            <div class="small"><%= lastError %></div>
          </div>
        <% } %>
      </div>
    </div>

    <div class="col-lg-5">
      <div class="module-card h-100">
        <div class="module-accent"></div>
        <h4 class="fw-bold mb-3">What you can do</h4>
        <% if (adminRecovery) { %>
          <div class="d-grid gap-2">
            <a href="/systemSettings/data-backend" class="btn btn-warning fw-bold">
              Review backend configuration
            </a>
            <a href="/systemSettings/app" class="btn btn-outline-primary">
              Review app settings
            </a>
            <a href="/files" class="btn btn-outline-secondary">
              Open file manager
            </a>
            <a href="/debug" class="btn btn-outline-secondary">
              Open debug tools
            </a>
          </div>
          <p class="small text-muted mt-3 mb-0">
            If Railway variables need to change, update them in Railway, then restart or use the retry action on the backend status page.
          </p>
        <% } else { %>
          <div class="alert alert-warning mb-0">
            Normal user areas are paused while the app is in recovery mode. Please contact a system administrator.
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="module-card mt-4">
    <div class="module-accent"></div>
    <h5 class="fw-bold mb-3">Technical Details</h5>
    <div class="table-responsive">
      <table class="table align-middle mb-0">
        <tbody>
          <tr>
            <th style="width: 220px;">Attempted Page</th>
            <td><code><%= pathLabel || '-' %></code></td>
          </tr>
          <tr>
            <th>Mongo URI</th>
            <td><%= mongo.uriMasked || (mongo.ready ? 'Configured' : 'Missing') %></td>
          </tr>
          <tr>
            <th>Strict Mode</th>
            <td><%= status.strict && status.strict.enabled ? 'Enabled' : 'Disabled' %></td>
          </tr>
          <tr>
            <th>Recovery Started</th>
            <td><%= fallback.startedAt || '-' %></td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
