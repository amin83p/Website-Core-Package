<%
  const backend = runtimeBackend || {};
  const activeMode = String(backend.mode || 'json').trim().toLowerCase();
  const packageRows = Array.isArray(packages) ? packages : [];
  const packageWarningsRows = Array.isArray(packageWarnings) ? packageWarnings : [];
  const actionStateValue = typeof actionStateId !== 'undefined' ? actionStateId : '';
  const packageRoot = String(typeof packageStorageRoot !== 'undefined' ? packageStorageRoot : '').trim();
  const orgRows = Array.isArray(organizations) ? organizations : [];
  const activeOrgIdValue = String(typeof activeOrgId !== 'undefined' ? activeOrgId : '').trim();
  const activeOrgName = (() => {
    if (!activeOrgIdValue) return '';
    const org = orgRows.find((row) => String(row?.id || row?.orgId || '').trim() === activeOrgIdValue);
    const name = String(org?.name || org?.displayName || org?.identity?.displayName || org?.identity?.legalName || '').trim();
    return name ? `${name} (#${activeOrgIdValue})` : activeOrgIdValue;
  })();
%>

<style>
  .package-builder-page .wizard-step-rail {
    display: flex;
    gap: 0.5rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
    scrollbar-width: none;
  }
  .package-builder-page .wizard-step-rail::-webkit-scrollbar { display: none; }
  .package-builder-page .wizard-step-pill {
    flex: 0 0 auto;
    border: 1px solid #c8d1dc;
    background: #f8fafc;
    color: #17324d;
    border-radius: 999px;
    padding: 0.4rem 0.8rem;
    font-weight: 700;
    font-size: 0.9rem;
  }
  .package-builder-page .wizard-step-pill.active {
    background: #17324d;
    border-color: #17324d;
    color: #fff;
  }
  .package-builder-page .wizard-step-pill.completed {
    background: #e8f5ee;
    border-color: #95d5b2;
    color: #1b6f4a;
  }
  .package-builder-page .wizard-progress {
    height: 0.35rem;
    background: #e8edf3;
    border-radius: 999px;
    overflow: hidden;
  }
  .package-builder-page .wizard-progress-bar {
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, #17324d 0%, #2f5d8a 100%);
    transition: width 0.25s ease;
  }
  .package-builder-page .builder-step-panel { display: none; }
  .package-builder-page .builder-step-panel.active { display: block; }
  .package-builder-page .builder-scroll-box {
    min-height: 220px;
    max-height: 420px;
    overflow: auto;
  }
  .package-builder-page .builder-item-card {
    border: 1px solid #e5ebf1;
    border-radius: 0.55rem;
    background: #fff;
    padding: 0.7rem 0.8rem;
    margin-bottom: 0.55rem;
  }
  .package-builder-page .builder-item-card.removed {
    opacity: 0.62;
    background: #fff7f7;
    border-color: #f2c6c6;
  }
  .package-builder-page .builder-file-tree ul {
    list-style: none;
    padding-left: 1.2rem;
    margin-bottom: 0;
  }
  .package-builder-page .builder-file-node {
    padding: 0.2rem 0;
  }
  .package-builder-page .builder-output {
    max-height: 360px;
    overflow: auto;
  }
  .package-builder-page .builder-data-storage-upload-panel .builder-declaration-block {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    min-height: 0;
  }
  .package-builder-page .builder-data-storage-upload-panel .builder-declaration-list {
    flex: 1 1 auto;
    min-height: 0;
  }
</style>

<div class="sections-page package-builder-page">
  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
      <h1 class="page-heading size-md text-start m-0">Package Builder</h1>
      <p class="text-muted mb-0 mt-1">Create signed install packages with staged manifest review.</p>
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">PACKAGE BUILD</span>
      <span class="badge bg-light text-dark border">Runtime: <%= activeMode.toUpperCase() %></span>
      <a href="/systemSettings" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Settings Home
      </a>
    </div>
  </div>

  <% if (packageRoot) { %>
    <div class="alert alert-info border-0 shadow-sm py-2 px-3 mb-3 small">
      <strong>Package Storage Root:</strong> <code><%= packageRoot %></code>
      <div class="mt-1 text-muted">Discovery checks configured package storage, default <code>./packages</code>, and installed registry metadata.</div>
    </div>
  <% } %>

  <% if (packageWarningsRows.length) { %>
    <div class="alert alert-warning border-0 shadow-sm py-2 px-3 mb-3 small">
      <div class="fw-semibold mb-1">Some packages are unavailable for build:</div>
      <ul class="mb-0 ps-3">
        <% packageWarningsRows.slice(0, 8).forEach((row) => { %>
          <li><code><%= row.packageId || row.storedManifestPath || row.manifestPath %></code> - <%= row.warning || row.error || 'Missing or invalid manifest' %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
        <div>
          <div class="fw-bold text-primary">Package Build Wizard</div>
          <div class="text-muted">Review declarations, data, storage, and files before creating the signed package.</div>
        </div>
        <div class="d-flex align-items-center gap-2">
          <span class="badge bg-light text-dark border" id="builderStepBadge">Step 1 of 9</span>
          <span class="badge bg-primary-subtle text-primary border border-primary-subtle" id="builderProgressPct">0%</span>
        </div>
      </div>
      <div class="wizard-progress mb-3"><div class="wizard-progress-bar" id="builderProgressBar"></div></div>
      <div class="wizard-step-rail mb-3" id="builderStepRail"></div>

      <div class="builder-step-panel active" data-builder-step="setup">
        <div class="row g-3">
          <div class="col-lg-6">
            <label class="form-label small fw-bold">Package</label>
            <select id="builderPackageId" class="form-select">
              <option value="">Select package</option>
              <% packageRows.forEach((row) => { %>
                <% const isAvailable = row && row.valid === true && row.manifestResolved === true; %>
                <% const sourceLabel = row?.source ? String(row.source).replace(/_/g, ' ') : 'configured root'; %>
                <option value="<%= row.packageId %>" data-version="<%= row.version %>" <%= isAvailable ? '' : 'disabled' %>>
                  <%= row.packageId %> - <%= row.version || '-' %>
                  (<%= row.storedManifestPath || row.manifestPath || sourceLabel %>)
                  <%= isAvailable ? '' : ' [Unavailable: Missing/Invalid Manifest]' %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-lg-6">
            <label class="form-label small fw-bold">Origin Organization</label>
            <div class="input-group">
              <input type="hidden" id="builderOriginOrgId" value="<%= activeOrgIdValue %>">
              <input type="text" id="builderOriginOrgName" class="form-control size-md bg-white border-primary fw-bold" value="<%= activeOrgName %>" placeholder="Select organization..." readonly>
              <button type="button" class="btn btn-outline-primary" id="builderPickOriginOrgBtn"><i class="bi bi-search"></i></button>
              <button type="button" class="btn btn-outline-secondary" id="builderClearOriginOrgBtn" title="Clear selected organization"><i class="bi bi-x-lg"></i></button>
            </div>
          </div>
          <div class="col-lg-6">
            <label class="form-label small fw-bold">Manifest Source</label>
            <select id="builderManifestMode" class="form-select">
              <option value="static">Static manifest from package folder</option>
              <option value="live">Live backend manifest</option>
            </select>
            <div class="small text-muted mt-1">Live mode refreshes supported business declarations while preserving package runtime wiring.</div>
          </div>
        </div>
      </div>

      <div class="builder-step-panel" data-builder-step="sections">
        <%- renderDeclarationStep('sections', 'Sections', 'bi-collection', 'Add Section') %>
      </div>

      <div class="builder-step-panel" data-builder-step="operations">
        <%- renderDeclarationStep('operations', 'Operations', 'bi-gear', 'Add Operation') %>
      </div>

      <div class="builder-step-panel" data-builder-step="roles">
        <%- renderDeclarationStep('roles', 'Roles', 'bi-person-badge', 'Add Role') %>
      </div>

      <div class="builder-step-panel" data-builder-step="navigation">
        <div class="row g-3">
          <div class="col-xl-6"><%- renderDeclarationBlock('menuEntries', 'Menu Entries', 'bi-list', 'Add Menu') %></div>
          <div class="col-xl-6"><%- renderDeclarationBlock('dashboardEntries', 'Dashboard Entries', 'bi-speedometer2', 'Add Dashboard') %></div>
        </div>
      </div>

      <div class="builder-step-panel" data-builder-step="data-storage">
        <div class="row g-3 align-items-stretch">
          <div class="col-xl-6 d-flex">
            <div class="border rounded p-3 bg-white w-100 h-100 d-flex flex-column">
              <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
                <div>
                  <div class="fw-bold">Package-Owned Tables / Collections</div>
                  <div class="small text-muted">Rows are scoped to the selected origin organization during preflight/build.</div>
                </div>
                <div class="d-flex gap-2">
                  <button type="button" class="btn btn-outline-secondary btn-sm" id="builderSelectAllEntitiesBtn">Select All</button>
                  <button type="button" class="btn btn-outline-secondary btn-sm" id="builderClearEntitiesBtn">Clear</button>
                </div>
              </div>
              <div class="border rounded p-2 builder-scroll-box flex-grow-1" id="builderEntityList">
                <div class="small text-muted">Select package and origin organization, then run preflight.</div>
              </div>
            </div>
          </div>
          <div class="col-xl-6 d-flex">
            <div class="border rounded p-3 bg-white w-100 h-100 d-flex flex-column builder-data-storage-upload-panel">
              <%- renderDeclarationBlock('uploadFolders', 'Upload Folders', 'bi-folder2-open', 'Add Upload Folder') %>
            </div>
          </div>
        </div>
      </div>

      <div class="builder-step-panel" data-builder-step="advanced-manifest">
        <div class="row g-3">
          <div class="col-xl-6"><%- renderDeclarationBlock('quotaDefinitions', 'Quota Definitions', 'bi-activity', 'Add Quota') %></div>
          <div class="col-xl-6"><%- renderDeclarationBlock('mongoIndexes', 'Mongo Indexes', 'bi-database-gear', 'Add Index') %></div>
          <div class="col-xl-6"><%- renderDeclarationBlock('dataSchemas', 'Data Schemas', 'bi-diagram-3', 'Add Schema') %></div>
          <div class="col-xl-6"><%- renderDeclarationBlock('seeders', 'Seeders', 'bi-database-add', 'Add Seeder') %></div>
          <div class="col-xl-6"><%- renderDeclarationBlock('migrations', 'Migrations', 'bi-arrow-left-right', 'Add Migration') %></div>
          <div class="col-xl-6"><%- renderDeclarationBlock('upgradeGuards', 'Upgrade Guards', 'bi-shield-check', 'Add Guard') %></div>
          <div class="col-12"><%- renderDeclarationBlock('dependencies', 'Dependencies', 'bi-boxes', 'Add Dependency') %></div>
        </div>
      </div>

      <div class="builder-step-panel" data-builder-step="files">
        <details class="border rounded p-3 bg-white mb-3" open>
          <summary class="fw-bold"><i class="bi bi-stars me-1"></i> Symbols</summary>
          <div class="mt-3">
            <%- renderDeclarationBlock('symbols', 'Symbols', 'bi-stars', 'Add Symbol') %>
          </div>
        </details>

        <details class="border rounded p-3 bg-white mb-3" open>
          <summary class="fw-bold"><i class="bi bi-folder2-open me-1"></i> File Tree</summary>
          <div class="mt-3">
            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
              <div>
                <div class="fw-bold">File Tree</div>
                <div class="small text-muted">Detected upload and symbol files are grouped by folder. Uncheck files to exclude them from this build.</div>
              </div>
              <button type="button" class="btn btn-outline-secondary btn-sm" id="builderSelectAllFilesBtn">Select All Files</button>
            </div>
            <div class="border rounded p-2 builder-scroll-box builder-file-tree" id="builderFileTree">
              <div class="small text-muted">File tree loads after preflight.</div>
            </div>
          </div>
        </details>

        <details class="border rounded p-3 bg-white mb-3" open>
          <summary class="fw-bold"><i class="bi bi-table me-1"></i> File Fields By Table</summary>
          <div class="mt-3">
            <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
              <div>
                <div class="fw-bold">File Fields By Table</div>
                <div class="small text-muted">Selected fields are scanned for upload refs during preflight/build.</div>
              </div>
              <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" id="builderAddAllFileFieldsBtn">Add All Detected</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="builderClearSelectedFileFieldsBtn">Clear Selected</button>
              </div>
            </div>
            <div class="border rounded p-2 builder-scroll-box" id="builderFileFieldList">
              <div class="small text-muted">File field candidates load after entity preflight.</div>
            </div>
          </div>
        </details>

        <details class="border rounded p-3 bg-white">
          <summary class="fw-bold"><i class="bi bi-pencil-square me-1"></i> Manual File/Folder Refs (one per line)</summary>
          <div class="mt-3">
            <label class="form-label small fw-bold">Manual File/Folder Refs (one per line)</label>
            <textarea id="builderSelectedFileRefs" rows="6" class="form-control font-monospace small" placeholder="/uploads/ORG_900000/symbols/logo.png"></textarea>
          </div>
        </details>
      </div>

      <div class="builder-step-panel" data-builder-step="review">
        <div class="d-flex flex-column gap-3">
          <div class="border rounded p-3 bg-light" id="builderReviewSummary">Run preflight to prepare review summary.</div>
          <div class="border rounded p-3">
            <div class="fw-bold mb-2">Build Version And Note</div>
            <div class="row g-3">
              <div class="col-xl-6">
                <label class="form-label small fw-bold">Suggested Target Version</label>
                <div class="small text-muted border rounded px-3 py-2 bg-light" id="builderVersionHint">Select a package to suggest the next version.</div>
              </div>
              <div class="col-xl-6">
                <label class="form-label small fw-bold">Target Version</label>
                <input id="builderVersion" type="text" class="form-control" placeholder="1.0.1">
              </div>
              <div class="col-12">
                <label class="form-label small fw-bold">Build Note</label>
                <textarea id="builderBuildNote" rows="4" class="form-control" placeholder="Describe what changed in this package build..."></textarea>
                <div class="small text-muted mt-1">Saved into the package as <code>BUILD_NOTE.md</code>.</div>
              </div>
            </div>
          </div>
          <div class="d-flex align-items-center gap-2 flex-wrap">
            <button type="button" class="btn btn-outline-secondary" id="builderPreflightBtn"><i class="bi bi-search me-1"></i>Preflight</button>
            <button type="button" class="btn btn-primary btn-filled" id="builderBuildBtn"><i class="bi bi-box-arrow-down-right me-1"></i>Build Signed Package</button>
          </div>
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold small d-flex align-items-center justify-content-between">
              <span>Builder Output</span>
              <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" id="builderCopyOutputBtn"><i class="bi bi-clipboard me-1"></i>Copy</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="builderClearOutputBtn">Clear</button>
              </div>
            </div>
            <div class="card-body">
              <pre id="builderOutput" class="small bg-dark text-success p-3 rounded mb-0 builder-output">Ready.</pre>
              <div id="builderArtifactLinks" class="mt-3 d-none">
                <div class="small fw-semibold mb-1">Published Artifacts</div>
                <div id="builderArtifactHealthAlert" class="alert alert-warning py-2 px-3 small mb-2 d-none"></div>
                <div id="builderArtifactLinksList"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3 pt-3 border-top">
        <button type="button" class="btn btn-outline-secondary" id="builderPrevStepBtn"><i class="bi bi-arrow-left me-1"></i>Previous</button>
        <div class="d-flex gap-2">
          <button type="button" class="btn btn-outline-primary" id="builderRefreshPreflightBtn"><i class="bi bi-arrow-clockwise me-1"></i>Refresh Preflight</button>
          <button type="button" class="btn btn-primary" id="builderNextStepBtn">Next<i class="bi bi-arrow-right ms-1"></i></button>
        </div>
      </div>
    </div>
  </div>

  <input type="hidden" id="builderActionStateId" value="<%= actionStateValue %>">
</div>

<%- include('../partials/modal_GenericPicker', { user }) %>

<script>
(() => {
  const actionStateId = document.getElementById('builderActionStateId')?.value || '';
  const packageEl = document.getElementById('builderPackageId');
  const manifestModeEl = document.getElementById('builderManifestMode');
  const versionEl = document.getElementById('builderVersion');
  const versionHintEl = document.getElementById('builderVersionHint');
  const buildNoteEl = document.getElementById('builderBuildNote');
  const originOrgIdEl = document.getElementById('builderOriginOrgId');
  const originOrgNameEl = document.getElementById('builderOriginOrgName');
  const outputEl = document.getElementById('builderOutput');
  const artifactLinksWrapEl = document.getElementById('builderArtifactLinks');
  const artifactHealthAlertEl = document.getElementById('builderArtifactHealthAlert');
  const artifactLinksListEl = document.getElementById('builderArtifactLinksList');
  const entityListEl = document.getElementById('builderEntityList');
  const fileFieldListEl = document.getElementById('builderFileFieldList');
  const fileTreeEl = document.getElementById('builderFileTree');
  const fileRefsEl = document.getElementById('builderSelectedFileRefs');
  const stepRailEl = document.getElementById('builderStepRail');
  const stepBadgeEl = document.getElementById('builderStepBadge');
  const progressPctEl = document.getElementById('builderProgressPct');
  const progressBarEl = document.getElementById('builderProgressBar');
  const reviewSummaryEl = document.getElementById('builderReviewSummary');

  const steps = [
    { id: 'setup', title: 'Setup' },
    { id: 'sections', title: 'Sections' },
    { id: 'operations', title: 'Operations' },
    { id: 'roles', title: 'Roles' },
    { id: 'navigation', title: 'Navigation' },
    { id: 'data-storage', title: 'Data And Storage' },
    { id: 'advanced-manifest', title: 'Advanced Manifest' },
    { id: 'files', title: 'Files' },
    { id: 'review', title: 'Review And Build' }
  ];
  const manifestFields = [
    'sections',
    'operations',
    'roles',
    'symbols',
    'menuEntries',
    'dashboardEntries',
    'quotaDefinitions',
    'uploadFolders',
    'mongoIndexes',
    'dataSchemas',
    'seeders',
    'migrations',
    'upgradeGuards',
    'dependencies'
  ];

  const state = {
    currentStep: 0,
    entityCatalog: [],
    selectedFileFieldsByEntity: {},
    manifestSelection: {},
    fileSelection: { excludedRefs: [], selectedRefs: [] },
    entitySelectionTouched: false,
    lastReport: null
  };

  manifestFields.forEach((field) => {
    state.manifestSelection[field] = { excludedIds: [], selectedIds: [], addedRows: [] };
  });

  function escapeHtml(value = '') {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function parseLines(value) {
    return String(value || '').split(/\r?\n/).map((row) => row.trim()).filter(Boolean);
  }

  function setOutput(title, payload) {
    outputEl.textContent = `[${new Date().toISOString()}] ${title}\n${JSON.stringify(payload, null, 2)}`;
  }

  async function fetchJson(url, options = {}) {
    const response = await fetch(url, options);
    let payload = {};
    try { payload = await response.json(); } catch (_) {}
    if (!response.ok || payload.status === 'error') {
      const error = new Error(payload.message || `Request failed (${response.status}).`);
      error.code = payload.code || '';
      error.payload = payload;
      throw error;
    }
    return payload;
  }

  function showError(error) {
    const message = error?.message || 'Operation failed.';
    setOutput('Operation Failed', {
      status: 'error',
      message,
      code: error?.code || '',
      details: error?.payload?.details || null
    });
    if (typeof showMessageModal === 'function') {
      showMessageModal({
        title: 'Operation Failed',
        message,
        icon: 'error',
        buttons: [{ text: 'Close', class: 'btn-danger' }]
      });
    } else {
      alert(message);
    }
  }

  function suggestNextVersion(version) {
    const token = String(version || '').trim();
    const match = token.match(/^(\d+)\.(\d+)\.(\d+)(?:[-+].*)?$/);
    if (!match) return '1.0.0';
    return `${Number(match[1])}.${Number(match[2])}.${Number(match[3]) + 1}`;
  }

  function syncVersionSuggestion(force = false) {
    const selected = packageEl?.options?.[packageEl.selectedIndex];
    const currentVersion = String(selected?.getAttribute('data-version') || '').trim();
    const packageId = String(packageEl?.value || '').trim();
    const suggested = suggestNextVersion(currentVersion);
    if (versionHintEl) {
      versionHintEl.textContent = packageId
        ? `Current ${currentVersion || 'unknown'} -> suggested ${suggested}`
        : 'Select a package to suggest the next version.';
    }
    if (versionEl && packageId && (force || !versionEl.value.trim())) versionEl.value = suggested;
    if (manifestModeEl) {
      const supportsLiveManifest = ['school', 'pte', 'ielts', 'benchpath', 'credit'].includes(packageId.toLowerCase());
      Array.from(manifestModeEl.options).forEach((option) => {
        if (option.value === 'live') option.disabled = !supportsLiveManifest;
      });
      if (!supportsLiveManifest && manifestModeEl.value === 'live') manifestModeEl.value = 'static';
      if (supportsLiveManifest && force) manifestModeEl.value = 'live';
    }
  }

  function setBuilderOriginOrgSelection(orgId, orgName = '') {
    const normalizedOrgId = String(orgId || '').trim();
    if (originOrgIdEl) originOrgIdEl.value = normalizedOrgId;
    if (originOrgNameEl) originOrgNameEl.value = orgName || (normalizedOrgId ? `Organization #${normalizedOrgId}` : '');
  }

  function updateWizard() {
    const progress = ((state.currentStep + 1) / steps.length) * 100;
    stepBadgeEl.textContent = `Step ${state.currentStep + 1} of ${steps.length}`;
    progressPctEl.textContent = `${Math.round(progress)}%`;
    progressBarEl.style.width = `${progress}%`;
    stepRailEl.innerHTML = steps.map((step, index) => {
      const cls = index === state.currentStep ? 'active' : (index < state.currentStep ? 'completed' : '');
      return `<button type="button" class="wizard-step-pill ${cls}" data-step-index="${index}">${index + 1}. ${escapeHtml(step.title)}</button>`;
    }).join('');
    document.querySelectorAll('.builder-step-panel').forEach((panel) => {
      panel.classList.toggle('active', panel.getAttribute('data-builder-step') === steps[state.currentStep].id);
    });
    document.getElementById('builderPrevStepBtn').disabled = state.currentStep <= 0;
    document.getElementById('builderNextStepBtn').innerHTML = state.currentStep >= steps.length - 1
      ? 'Stay On Review<i class="bi bi-check2-circle ms-1"></i>'
      : 'Next<i class="bi bi-arrow-right ms-1"></i>';
  }

  function getSelectedEntities() {
    return Array.from(document.querySelectorAll('.builder-entity-checkbox:checked'))
      .map((node) => String(node.value || '').trim())
      .filter(Boolean);
  }

  function getSelectedEntitiesForPayload() {
    const selected = getSelectedEntities();
    if (state.entitySelectionTouched && selected.length === 0) return ['__none__'];
    return selected;
  }

  function getCurrentSelectedEntitySet() {
    return new Set(getSelectedEntities());
  }

  function normalizeFieldSelection(field, values = []) {
    const current = state.manifestSelection[field] || { excludedIds: [], selectedIds: [], addedRows: [] };
    current.excludedIds = Array.from(new Set(values.map((item) => String(item || '').trim()).filter(Boolean)));
    state.manifestSelection[field] = current;
  }

  function rowKey(row = {}, field = '') {
    if (typeof row === 'string') return row;
    if (field === 'quotaDefinitions') {
      if (row.key || row.middlewareKey || row.id) return String(row.key || row.middlewareKey || row.id);
      if (row.sectionId && row.operationId) return `${row.sectionId}::${row.operationId}`;
    }
    if (field === 'dataEntities' || field === 'dataSchemas') return String(row.entityType || row.table || row.id || row.name || '');
    if (field === 'dependencies') return String(row.id || row.packageId || row.name || '');
    return String(row.id || row.name || row.key || row.code || row.roleId || row.sectionId || row.operationId || row.href || '');
  }

  function getFieldSelection(field) {
    if (!state.manifestSelection[field]) {
      state.manifestSelection[field] = { excludedIds: [], selectedIds: [], addedRows: [] };
    }
    return state.manifestSelection[field];
  }

  function addManifestRow(field, row) {
    const selection = getFieldSelection(field);
    const key = rowKey(row?.row || row, field);
    if (!key) return;
    const exists = selection.addedRows.some((item) => rowKey(item, field) === key);
    if (!exists) selection.addedRows.push(row?.row || row);
    selection.excludedIds = selection.excludedIds.filter((item) => item !== key);
    runPreflight({ silent: true }).catch(showError);
  }

  function removeManifestRow(field, key, manuallyAdded) {
    const selection = getFieldSelection(field);
    if (manuallyAdded) {
      selection.addedRows = selection.addedRows.filter((row) => rowKey(row, field) !== key);
    } else if (!selection.excludedIds.includes(key)) {
      selection.excludedIds.push(key);
    }
    runPreflight({ silent: true }).catch(showError);
  }

  function restoreManifestRow(field, key) {
    const selection = getFieldSelection(field);
    selection.excludedIds = selection.excludedIds.filter((item) => item !== key);
    runPreflight({ silent: true }).catch(showError);
  }

  function renderManifestField(field) {
    const container = document.querySelector(`[data-manifest-list="${field}"]`);
    if (!container) return;
    const preview = state.lastReport?.manifestPreview?.[field];
    const rows = Array.isArray(preview?.rows) ? preview.rows : [];
    if (!rows.length) {
      container.innerHTML = '<div class="small text-muted">Run preflight to load this catalog.</div>';
      return;
    }
    container.innerHTML = rows.map((item) => {
      const key = String(item.key || item.id || '').trim();
      const removed = item.removed === true || item.selected === false;
      const source = item.manuallyAdded ? 'manual' : (item.source || 'auto');
      return `
        <div class="builder-item-card ${removed ? 'removed' : ''}">
          <div class="d-flex justify-content-between align-items-start gap-2">
            <div class="small">
              <div class="fw-bold">${escapeHtml(item.label || key)}</div>
              <div class="text-muted"><code>${escapeHtml(key)}</code> | ${escapeHtml(source)}${removed ? ' | excluded from build' : ''}</div>
            </div>
            <div class="d-flex gap-2">
              ${removed
                ? `<button type="button" class="btn btn-outline-success btn-sm builder-restore-manifest-btn" data-field="${field}" data-key="${escapeHtml(key)}">Restore</button>`
                : `<button type="button" class="btn btn-outline-danger btn-sm builder-remove-manifest-btn" data-field="${field}" data-key="${escapeHtml(key)}" data-manual="${item.manuallyAdded === true ? '1' : '0'}">Remove</button>`}
            </div>
          </div>
        </div>
      `;
    }).join('');
  }

  function renderEntityList(rows = []) {
    state.entityCatalog = Array.isArray(rows) ? rows : [];
    if (!entityListEl) return;
    if (!state.entityCatalog.length) {
      entityListEl.innerHTML = '<div class="small text-muted">No package-owned tables found.</div>';
      return;
    }
    entityListEl.innerHTML = state.entityCatalog.map((row) => {
      const entityType = String(row?.entityType || row?.id || '').trim();
      const rowCount = Number(row?.rowCount || 0);
      const uploadCount = Number(row?.detectedUploadRefCount || 0);
      const selected = row?.selected !== false;
      return `
        <label class="d-flex align-items-start gap-2 py-2 border-bottom">
          <input type="checkbox" class="form-check-input mt-1 builder-entity-checkbox" value="${escapeHtml(entityType)}" ${selected ? 'checked' : ''}>
          <span class="small">
            <span class="fw-semibold">${escapeHtml(entityType)}</span>
            <span class="text-muted ms-1">(${rowCount} row${rowCount === 1 ? '' : 's'})</span>
            <div class="text-muted">Upload refs: ${uploadCount} | File fields: ${Array.isArray(row.fileFieldCandidates) ? row.fileFieldCandidates.length : 0}</div>
          </span>
        </label>
      `;
    }).join('');
  }

  function getEntityCandidates(entityType) {
    const row = state.entityCatalog.find((item) => String(item?.entityType || item?.id || '') === entityType);
    return Array.isArray(row?.fileFieldCandidates) ? row.fileFieldCandidates : [];
  }

  function normalizeSelectedFileFields(entityType, fields = []) {
    const candidates = new Set(getEntityCandidates(entityType));
    return Array.from(new Set((fields || []).filter((field) => candidates.has(field))));
  }

  function renderFileFieldList() {
    const selectedEntities = getCurrentSelectedEntitySet();
    const rows = state.entityCatalog.filter((row) => selectedEntities.has(String(row?.entityType || row?.id || '')));
    const selectableRows = rows.filter((row) => getEntityCandidates(String(row?.entityType || row?.id || '')).length > 0);
    if (!selectableRows.length) {
      fileFieldListEl.innerHTML = '<div class="small text-muted">No upload-address fields detected in selected tables.</div>';
      return;
    }
    fileFieldListEl.innerHTML = selectableRows.map((row) => {
      const entityType = String(row?.entityType || row?.id || '').trim();
      const candidates = getEntityCandidates(entityType);
      const selected = normalizeSelectedFileFields(entityType, state.selectedFileFieldsByEntity[entityType] || row.fileFieldSelected || []);
      state.selectedFileFieldsByEntity[entityType] = selected;
      return `
        <div class="border rounded p-2 mb-2">
          <div class="d-flex justify-content-between align-items-start gap-2 flex-wrap">
            <div>
              <div class="small fw-semibold">${escapeHtml(entityType)}</div>
              <div class="small text-muted">${candidates.length} upload field candidate${candidates.length === 1 ? '' : 's'}</div>
            </div>
            <div class="d-flex gap-2 flex-wrap">
              <select class="form-select form-select-sm builder-file-field-picker" data-entity-type="${escapeHtml(entityType)}" style="min-width: 260px;">
                <option value="">Select upload field</option>
                ${candidates.map((field) => `<option value="${escapeHtml(field)}">${escapeHtml(field)}</option>`).join('')}
              </select>
              <button type="button" class="btn btn-outline-secondary btn-sm builder-file-field-add-btn" data-entity-type="${escapeHtml(entityType)}">Add</button>
              <button type="button" class="btn btn-outline-secondary btn-sm builder-file-field-add-all-btn" data-entity-type="${escapeHtml(entityType)}">Add All</button>
              <button type="button" class="btn btn-outline-secondary btn-sm builder-file-field-clear-btn" data-entity-type="${escapeHtml(entityType)}">Clear</button>
            </div>
          </div>
          <div class="d-flex flex-wrap gap-2 mt-2">
            ${selected.length ? selected.map((field) => `
              <span class="badge bg-light text-dark border">
                <code>${escapeHtml(field)}</code>
                <button type="button" class="btn btn-sm p-0 text-danger ms-1 builder-file-field-remove-btn" data-entity-type="${escapeHtml(entityType)}" data-field-path="${escapeHtml(field)}"><i class="bi bi-x-lg"></i></button>
              </span>
            `).join('') : '<span class="small text-muted">No selected file fields.</span>'}
          </div>
        </div>
      `;
    }).join('');
  }

  function renderFileTreeNode(node) {
    if (!node) return '';
    if (node.type === 'file') {
      const checked = node.selected !== false ? 'checked' : '';
      const missing = node.exists === false ? '<span class="badge bg-danger-subtle text-danger border ms-1">missing</span>' : '';
      return `
        <li class="builder-file-node">
          <label class="small d-flex align-items-center gap-2">
            <input type="checkbox" class="form-check-input builder-file-checkbox" data-ref="${escapeHtml(node.ref || '')}" ${checked}>
            <span><i class="bi bi-file-earmark me-1"></i>${escapeHtml(node.name || '')}${missing}</span>
          </label>
        </li>
      `;
    }
    const children = Array.isArray(node.children) ? node.children : [];
    return `
      <li class="builder-file-node">
        <details open>
          <summary class="small fw-semibold"><i class="bi bi-folder2-open me-1"></i>${escapeHtml(node.name || 'folder')} <span class="text-muted">(${Number(node.fileCount || 0)} files)</span></summary>
          <ul>${children.map(renderFileTreeNode).join('')}</ul>
        </details>
      </li>
    `;
  }

  function renderFileTree() {
    const tree = state.lastReport?.filePlan?.fileTree;
    if (!tree || !Array.isArray(tree.children) || !tree.children.length) {
      fileTreeEl.innerHTML = '<div class="small text-muted">No package file refs detected yet.</div>';
      return;
    }
    fileTreeEl.innerHTML = `<ul>${tree.children.map(renderFileTreeNode).join('')}</ul>`;
  }

  function renderReviewSummary() {
    if (!state.lastReport) {
      reviewSummaryEl.innerHTML = 'Run preflight to prepare review summary.';
      return;
    }
    const report = state.lastReport;
    const selectedDeclarations = Object.values(report.manifestPreview || {}).reduce((sum, group) => sum + Number(group?.selectedCount || 0), 0);
    const removedDeclarations = Object.values(report.manifestPreview || {}).reduce((sum, group) => sum + Number(group?.removedCount || 0), 0);
    const warnings = Array.isArray(report.warnings) ? report.warnings : [];
    reviewSummaryEl.innerHTML = `
      <div class="fw-bold mb-2">${escapeHtml(report.package?.packageId || '')} build review</div>
      <div class="small">Manifest source: <strong>${escapeHtml(report.manifestMode || '')}</strong></div>
      <div class="small">Selected declarations: <strong>${selectedDeclarations}</strong></div>
      <div class="small">Excluded declarations: <strong>${removedDeclarations}</strong></div>
      <div class="small">Selected tables: <strong>${Number(report.selectedDataEntities?.length || 0)}</strong></div>
      <div class="small">Selected rows: <strong>${Number(report.selectedRowCount || 0)}</strong></div>
      <div class="small">Selected files: <strong>${Number(report.filePlan?.selectedRefs?.length || 0)}</strong></div>
      <div class="small">Warnings: <strong>${warnings.length}</strong></div>
      ${warnings.length ? `<hr><div class="small text-warning fw-semibold mb-1">Warnings</div><ul class="small mb-0 ps-3">${warnings.slice(0, 8).map((warning) => `<li>${escapeHtml(warning)}</li>`).join('')}</ul>` : ''}
    `;
  }

  function renderArtifactLinks(report = {}) {
    const rows = Array.isArray(report?.publishedArtifacts?.files) ? report.publishedArtifacts.files : [];
    const links = rows.filter((row) => row?.fileName && row?.uploadsUrl);
    if (!links.length) {
      artifactLinksWrapEl.classList.add('d-none');
      artifactLinksListEl.innerHTML = '';
      return;
    }
    artifactLinksListEl.innerHTML = `<div class="list-group">${links.map((row) => `
      <div class="list-group-item d-flex justify-content-between align-items-center gap-2 flex-wrap">
        <div class="small"><div class="fw-semibold">${escapeHtml(row.fileName)}</div><div class="text-muted">${Number(row.size || 0)} bytes</div></div>
        <a class="btn btn-outline-primary btn-sm" href="${escapeHtml(row.uploadsUrl)}" target="_blank" rel="noopener"><i class="bi bi-download me-1"></i>Download</a>
      </div>
    `).join('')}</div>`;
    const selectedRefCount = Number(report?.fileSummary?.selectedRefCount || 0);
    const copiedCount = Number(report?.fileSummary?.copiedCount || 0);
    if (selectedRefCount > 0 && copiedCount === 0) {
      artifactHealthAlertEl.className = 'alert alert-warning py-2 px-3 small mb-2';
      artifactHealthAlertEl.textContent = 'No referenced upload files were copied into the package payload. Review warnings before install.';
      artifactHealthAlertEl.classList.remove('d-none');
    } else {
      artifactHealthAlertEl.classList.add('d-none');
      artifactHealthAlertEl.textContent = '';
    }
    artifactLinksWrapEl.classList.remove('d-none');
  }

  function renderAll() {
    manifestFields.forEach(renderManifestField);
    renderEntityList(state.entityCatalog);
    renderFileFieldList();
    renderFileTree();
    renderReviewSummary();
  }

  function getFileFieldSelection() {
    const map = {};
    getCurrentSelectedEntitySet().forEach((entityType) => {
      map[entityType] = normalizeSelectedFileFields(entityType, state.selectedFileFieldsByEntity[entityType] || []);
    });
    return map;
  }

  function buildRequestPayload() {
    return {
      packageId: String(packageEl?.value || '').trim(),
      manifestMode: manifestModeEl?.value || 'static',
      version: versionEl?.value || '',
      buildNote: buildNoteEl?.value || '',
      originOrgId: String(originOrgIdEl?.value || '').trim(),
      actionStateId,
      selectedDataEntities: getSelectedEntitiesForPayload(),
      selectedFileRefs: parseLines(fileRefsEl?.value || ''),
      fileFieldSelection: getFileFieldSelection(),
      manifestSelection: state.manifestSelection,
      fileSelection: state.fileSelection
    };
  }

  async function runWithWaiting(label, action) {
    let loadingToken = null;
    if (typeof showLoading === 'function') {
      loadingToken = showLoading({ title: label, note: 'Preparing request...', operation: 'Package Builder', progress: 10 });
    }
    try {
      return await action();
    } finally {
      if (typeof hideLoading === 'function') window.setTimeout(() => hideLoading(loadingToken || undefined), 180);
    }
  }

  async function runPreflight(options = {}) {
    const payload = buildRequestPayload();
    if (!payload.packageId) throw new Error('Select a package first.');
    if (!payload.originOrgId) throw new Error('Select origin organization first.');
    const response = await runWithWaiting('Running package preflight...', () => fetchJson('/systemSettings/package-builder/preflight', {
      method: 'POST',
      headers: { 'content-type': 'application/json', 'x-ajax-request': 'yes' },
      body: JSON.stringify(payload)
    }));
    state.lastReport = response.report || null;
    state.entityCatalog = Array.isArray(response?.report?.entityCatalog) ? response.report.entityCatalog : [];
    state.fileSelection.excludedRefs = Array.isArray(response?.report?.filePlan?.excludedRefs) ? response.report.filePlan.excludedRefs : state.fileSelection.excludedRefs;
    renderAll();
    if (!options.silent) setOutput('Preflight Result', response);
    return response;
  }

  async function buildPackage() {
    const payload = buildRequestPayload();
    if (!payload.packageId) throw new Error('Select a package first.');
    if (!payload.originOrgId) throw new Error('Select origin organization first.');
    if (!payload.version) throw new Error('Enter target version.');
    if (!getSelectedEntities().length) throw new Error('Select at least one table/collection to package.');
    if (typeof window.requestProtectedAction !== 'function') throw new Error('Admin verification modal is unavailable. Refresh and try again.');
    await window.requestProtectedAction();
    const response = await runWithWaiting('Building signed package...', () => fetchJson('/systemSettings/package-builder/build', {
      method: 'POST',
      headers: { 'content-type': 'application/json', 'x-ajax-request': 'yes' },
      body: JSON.stringify(payload)
    }));
    setOutput('Build Result', response);
    renderArtifactLinks(response.report || {});
    if (typeof showMessageModal === 'function') {
      showMessageModal({
        title: 'Build Completed',
        message: response.message || 'Package build completed successfully.',
        icon: 'success',
        buttons: [{ text: 'OK', class: 'btn-success' }]
      });
    }
  }

  function openManifestPicker(field) {
    const packageId = String(packageEl?.value || '').trim();
    if (!packageId) return showError(new Error('Select a package first.'));
    if (!window.GenericPicker) return showError(new Error('Generic picker is not ready yet.'));
    const common = {
      title: `Add ${field}`,
      multiselect: true,
      onSelect: (items) => {
        (Array.isArray(items) ? items : [items]).forEach((item) => addManifestRow(field, item?.row || item));
      }
    };
    if (field === 'sections' && window.GenericPickerPresets?.section) {
      window.GenericPicker.open(window.GenericPickerPresets.section({ ...common, title: 'Add Sections', context: window.GenericPickerContexts?.allOrganizations?.() }));
      return;
    }
    if (field === 'operations' && window.GenericPickerPresets?.operation) {
      window.GenericPicker.open(window.GenericPickerPresets.operation({ ...common, title: 'Add Operations', context: window.GenericPickerContexts?.allOrganizations?.() }));
      return;
    }
    const params = new URLSearchParams({
      packageId,
      manifestMode: manifestModeEl?.value || 'static',
      type: field
    });
    window.GenericPicker.open({
      ...common,
      title: `Add ${field.replace(/([A-Z])/g, ' $1')}`,
      icon: 'bi-plus-circle',
      apiEndpoint: `/systemSettings/package-builder/catalog?${params.toString()}`,
      placeholder: 'Search catalog...',
      renderer: (item) => {
        const key = item?.key || item?.id || '';
        return `<div class="fw-bold text-dark">${escapeHtml(item?.label || item?.name || key)}</div><small class="text-muted"><code>${escapeHtml(key)}</code> | ${escapeHtml(item?.source || 'catalog')}</small>`;
      }
    });
  }

  function clearArtifactLinks() {
    artifactLinksListEl.innerHTML = '';
    artifactLinksWrapEl.classList.add('d-none');
  }

  document.addEventListener('click', (event) => {
    const stepBtn = event.target.closest('[data-step-index]');
    if (stepBtn) {
      state.currentStep = Number(stepBtn.getAttribute('data-step-index') || 0);
      updateWizard();
      return;
    }
    const addManifestBtn = event.target.closest('[data-manifest-add]');
    if (addManifestBtn) {
      openManifestPicker(addManifestBtn.getAttribute('data-manifest-add'));
      return;
    }
    const removeManifestBtn = event.target.closest('.builder-remove-manifest-btn');
    if (removeManifestBtn) {
      removeManifestRow(removeManifestBtn.getAttribute('data-field'), removeManifestBtn.getAttribute('data-key'), removeManifestBtn.getAttribute('data-manual') === '1');
      return;
    }
    const restoreManifestBtn = event.target.closest('.builder-restore-manifest-btn');
    if (restoreManifestBtn) {
      restoreManifestRow(restoreManifestBtn.getAttribute('data-field'), restoreManifestBtn.getAttribute('data-key'));
      return;
    }
    const addFieldBtn = event.target.closest('.builder-file-field-add-btn');
    if (addFieldBtn) {
      const entityType = addFieldBtn.getAttribute('data-entity-type');
      const select = addFieldBtn.parentElement?.querySelector('.builder-file-field-picker');
      const field = String(select?.value || '').trim();
      if (!field) return;
      state.selectedFileFieldsByEntity[entityType] = Array.from(new Set([...(state.selectedFileFieldsByEntity[entityType] || []), field]));
      renderFileFieldList();
      return;
    }
    const addAllFieldBtn = event.target.closest('.builder-file-field-add-all-btn');
    if (addAllFieldBtn) {
      const entityType = addAllFieldBtn.getAttribute('data-entity-type');
      state.selectedFileFieldsByEntity[entityType] = getEntityCandidates(entityType);
      renderFileFieldList();
      return;
    }
    const removeFieldBtn = event.target.closest('.builder-file-field-remove-btn');
    if (removeFieldBtn) {
      const entityType = removeFieldBtn.getAttribute('data-entity-type');
      const field = removeFieldBtn.getAttribute('data-field-path');
      state.selectedFileFieldsByEntity[entityType] = (state.selectedFileFieldsByEntity[entityType] || []).filter((item) => item !== field);
      renderFileFieldList();
      return;
    }
    const clearFieldBtn = event.target.closest('.builder-file-field-clear-btn');
    if (clearFieldBtn) {
      state.selectedFileFieldsByEntity[clearFieldBtn.getAttribute('data-entity-type')] = [];
      renderFileFieldList();
    }
  });

  document.addEventListener('change', (event) => {
    if (event.target?.classList?.contains('builder-entity-checkbox')) {
      state.entitySelectionTouched = true;
      renderFileFieldList();
    }
    if (event.target?.classList?.contains('builder-file-checkbox')) {
      const ref = String(event.target.getAttribute('data-ref') || '').trim();
      if (!ref) return;
      const excluded = new Set(state.fileSelection.excludedRefs || []);
      if (event.target.checked) excluded.delete(ref);
      else excluded.add(ref);
      state.fileSelection.excludedRefs = Array.from(excluded);
    }
  });

  document.getElementById('builderPrevStepBtn')?.addEventListener('click', () => {
    state.currentStep = Math.max(0, state.currentStep - 1);
    updateWizard();
  });
  document.getElementById('builderNextStepBtn')?.addEventListener('click', () => {
    state.currentStep = Math.min(steps.length - 1, state.currentStep + 1);
    updateWizard();
  });
  document.getElementById('builderRefreshPreflightBtn')?.addEventListener('click', () => runPreflight().catch(showError));
  document.getElementById('builderPreflightBtn')?.addEventListener('click', () => runPreflight().catch(showError));
  document.getElementById('builderBuildBtn')?.addEventListener('click', () => buildPackage().catch(showError));
  document.getElementById('builderClearOutputBtn')?.addEventListener('click', () => {
    outputEl.textContent = 'Ready.';
    clearArtifactLinks();
  });
  document.getElementById('builderCopyOutputBtn')?.addEventListener('click', async () => {
    const text = String(outputEl?.textContent || '');
    if (!text) return;
    try {
      if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
        await navigator.clipboard.writeText(text);
      } else {
        const textarea = document.createElement('textarea');
        textarea.value = text;
        textarea.setAttribute('readonly', 'readonly');
        textarea.style.position = 'fixed';
        textarea.style.left = '-9999px';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        document.body.removeChild(textarea);
      }
      if (typeof showToast === 'function') {
        showToast('Builder output copied to clipboard.', 'success');
      }
    } catch (error) {
      showError(new Error(`Failed to copy builder output: ${error?.message || error}`));
    }
  });
  document.getElementById('builderSelectAllEntitiesBtn')?.addEventListener('click', () => {
    state.entitySelectionTouched = true;
    document.querySelectorAll('.builder-entity-checkbox').forEach((node) => { node.checked = true; });
    renderFileFieldList();
  });
  document.getElementById('builderClearEntitiesBtn')?.addEventListener('click', () => {
    state.entitySelectionTouched = true;
    document.querySelectorAll('.builder-entity-checkbox').forEach((node) => { node.checked = false; });
    renderFileFieldList();
  });
  document.getElementById('builderAddAllFileFieldsBtn')?.addEventListener('click', () => {
    getCurrentSelectedEntitySet().forEach((entityType) => {
      state.selectedFileFieldsByEntity[entityType] = getEntityCandidates(entityType);
    });
    renderFileFieldList();
  });
  document.getElementById('builderClearSelectedFileFieldsBtn')?.addEventListener('click', () => {
    state.selectedFileFieldsByEntity = {};
    renderFileFieldList();
  });
  document.getElementById('builderSelectAllFilesBtn')?.addEventListener('click', () => {
    state.fileSelection.excludedRefs = [];
    renderFileTree();
  });
  packageEl?.addEventListener('change', () => {
    state.lastReport = null;
    state.entityCatalog = [];
    state.fileSelection.excludedRefs = [];
    syncVersionSuggestion(true);
    renderAll();
    if (packageEl.value && originOrgIdEl.value) runPreflight({ silent: true }).catch(showError);
  });
  manifestModeEl?.addEventListener('change', () => {
    if (packageEl.value && originOrgIdEl.value) runPreflight({ silent: true }).catch(showError);
  });
  document.getElementById('builderPickOriginOrgBtn')?.addEventListener('click', () => {
    if (!window.GenericPicker || !window.GenericPickerPresets || !window.GenericPickerContexts) {
      showError(new Error('Generic organization picker is not ready yet.'));
      return;
    }
    window.GenericPicker.open(window.GenericPickerPresets.organization({
      title: 'Select Origin Organization',
      context: window.GenericPickerContexts.allOrganizations(),
      onSelect: (item) => {
        setBuilderOriginOrgSelection(item?.id, item?.identity?.displayName || item?.name || `Organization #${item?.id}`);
        if (packageEl?.value) runPreflight({ silent: true }).catch(showError);
      }
    }));
  });
  document.getElementById('builderClearOriginOrgBtn')?.addEventListener('click', () => {
    setBuilderOriginOrgSelection('', '');
    state.lastReport = null;
    state.entityCatalog = [];
    state.fileSelection.excludedRefs = [];
    renderAll();
  });

  updateWizard();
  syncVersionSuggestion(false);
})();
</script>

<% function renderDeclarationStep(field, title, icon, addLabel) {
  return `
    <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
      <div>
        <div class="fw-bold"><i class="bi ${icon} me-1"></i>${title}</div>
        <div class="small text-muted">Auto-included items can be removed for this build. Added items are included only in this package artifact.</div>
      </div>
      <button type="button" class="btn btn-outline-primary btn-sm" data-manifest-add="${field}"><i class="bi bi-plus-lg me-1"></i>${addLabel}</button>
    </div>
    <div class="border rounded p-2 builder-scroll-box" data-manifest-list="${field}">
      <div class="small text-muted">Run preflight to load ${String(title).toLowerCase()}.</div>
    </div>
  `;
} %>

<% function renderDeclarationBlock(field, title, icon, addLabel) {
  return `
    <div class="mb-3">
      <div class="d-flex justify-content-between align-items-center mb-2 flex-wrap gap-2">
        <div>
          <div class="fw-bold small"><i class="bi ${icon} me-1"></i>${title}</div>
        </div>
        <button type="button" class="btn btn-outline-primary btn-sm" data-manifest-add="${field}"><i class="bi bi-plus-lg me-1"></i>${addLabel}</button>
      </div>
      <div class="border rounded p-2 builder-scroll-box" data-manifest-list="${field}" style="max-height: 260px;">
        <div class="small text-muted">Run preflight to load ${String(title).toLowerCase()}.</div>
      </div>
    </div>
  `;
} %>
