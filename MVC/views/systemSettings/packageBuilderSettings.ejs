<%
  const backend = runtimeBackend || {};
  const activeMode = String(backend.mode || 'json').trim().toLowerCase();
  const packageRows = Array.isArray(packages) ? packages : [];
  const packageWarningsRows = Array.isArray(packageWarnings) ? packageWarnings : [];
  const actionStateValue = typeof actionStateId !== 'undefined' ? actionStateId : '';
  const packageRoot = String(typeof packageStorageRoot !== 'undefined' ? packageStorageRoot : '').trim();
  const orgRows = Array.isArray(organizations) ? organizations : [];
  const activeOrgIdValue = String(typeof activeOrgId !== 'undefined' ? activeOrgId : '').trim();
  const activeOrgName = (() => {
    if (!activeOrgIdValue) return '';
    const org = orgRows.find((row) => String(row?.id || row?.orgId || '').trim() === activeOrgIdValue);
    const name = String(org?.name || org?.displayName || org?.identity?.displayName || org?.identity?.legalName || '').trim();
    return name ? `${name} (#${activeOrgIdValue})` : activeOrgIdValue;
  })();
%>

<div class="sections-page package-builder-page">
  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
      <h1 class="page-heading size-md text-start m-0">Package Builder</h1>
      <p class="text-muted mb-0 mt-1">Create signed install packages from existing package modules.</p>
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <span class="badge bg-secondary-subtle text-secondary-emphasis border border-secondary-subtle">PACKAGE BUILD</span>
      <span class="badge bg-light text-dark border">Runtime: <%= activeMode.toUpperCase() %></span>
      <a href="/systemSettings" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>Settings Home
      </a>
    </div>
  </div>

  <% if (packageRoot) { %>
    <div class="alert alert-info border-0 shadow-sm py-2 px-3 mb-3 small">
      <strong>Package Storage Root:</strong> <code><%= packageRoot %></code>
      <div class="mt-1 text-muted">Discovery also checks default <code>./packages</code> and installed registry metadata to surface missing-package diagnostics.</div>
    </div>
  <% } %>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-bold small">Build Package</div>
    <div class="card-body p-3">
      <div class="row g-3">
        <div class="col-lg-6">
          <label class="form-label small fw-bold">Package</label>
          <select id="builderPackageId" class="form-select">
            <option value="">Select package</option>
            <% packageRows.forEach((row) => { %>
              <% const isAvailable = row && row.valid === true && row.manifestResolved === true; %>
              <% const sourceLabel = row?.source ? String(row.source).replace(/_/g, ' ') : 'configured root'; %>
              <option
                value="<%= row.packageId %>"
                data-version="<%= row.version %>"
                <%= isAvailable ? '' : 'disabled' %>>
                <%= row.packageId %> - <%= row.version || '-' %>
                (<%= row.storedManifestPath || row.manifestPath || sourceLabel %>)
                <%= isAvailable ? '' : ' [Unavailable: Missing/Invalid Manifest]' %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="col-lg-6">
          <label class="form-label small fw-bold">Origin Organization</label>
          <div class="input-group">
            <input type="hidden" id="builderOriginOrgId" value="<%= activeOrgIdValue %>">
            <input
              type="text"
              id="builderOriginOrgName"
              class="form-control size-md bg-white border-primary fw-bold"
              value="<%= activeOrgName %>"
              placeholder="Select organization..."
              readonly>
            <button type="button" class="btn btn-outline-primary" id="builderPickOriginOrgBtn">
              <i class="bi bi-search"></i>
            </button>
            <button type="button" class="btn btn-outline-secondary" id="builderClearOriginOrgBtn" title="Clear selected organization">
              <i class="bi bi-x-lg"></i>
            </button>
          </div>
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-lg-6">
          <label class="form-label small fw-bold">Manifest Source</label>
          <select id="builderManifestMode" class="form-select">
            <option value="static">Static manifest from package folder</option>
            <option value="live">Live backend manifest</option>
          </select>
          <div class="small text-muted mt-1">Live mode rebuilds supported package declarations from the active backend while keeping package routes, views, assets, upload folders, and data entities from the template manifest.</div>
        </div>
        <div class="col-lg-6">
          <label class="form-label small fw-bold">Suggested Target Version</label>
          <div class="small text-muted border rounded px-3 py-2 bg-light" id="builderVersionHint">Select a package to suggest the next version.</div>
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-12">
          <div class="card border-0 bg-light-subtle">
            <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between py-2">
              <button
                type="button"
                class="btn btn-link text-decoration-none text-dark fw-bold small p-0 d-inline-flex align-items-center gap-2"
                data-bs-toggle="collapse"
                data-bs-target="#builderEntitiesCollapse"
                aria-expanded="true"
                aria-controls="builderEntitiesCollapse">
                <i class="bi bi-chevron-down small"></i>
                <span>Package-Owned Tables / Collections</span>
              </button>
              <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" id="builderSelectAllEntitiesBtn">Select All</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="builderClearEntitiesBtn">Clear</button>
              </div>
            </div>
            <div class="collapse show" id="builderEntitiesCollapse">
              <div class="card-body pt-0">
                <div class="border rounded p-2" style="min-height: 300px; max-height: 360px; overflow:auto;" id="builderEntityList">
                  <div class="small text-muted">Select a package to load entity list.</div>
                </div>
                <div class="small text-muted mt-1">Select origin org first, then tables are discovered and scoped to that org (unscoped rows are included).</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-12">
          <div class="card border-0 bg-light-subtle">
            <div class="card-header bg-transparent border-0 d-flex align-items-center justify-content-between py-2">
              <button
                type="button"
                class="btn btn-link text-decoration-none text-dark fw-bold small p-0 d-inline-flex align-items-center gap-2"
                data-bs-toggle="collapse"
                data-bs-target="#builderFileFieldsCollapse"
                aria-expanded="true"
                aria-controls="builderFileFieldsCollapse">
                <i class="bi bi-chevron-down small"></i>
                <span>File Fields By Table</span>
              </button>
              <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm" id="builderAddAllFileFieldsBtn">Add All Detected</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="builderClearSelectedFileFieldsBtn">Clear Selected</button>
              </div>
            </div>
            <div class="collapse show" id="builderFileFieldsCollapse">
              <div class="card-body pt-0">
                <div class="border rounded p-2" style="min-height: 300px; max-height: 360px; overflow:auto;" id="builderFileFieldList">
                  <div class="small text-muted">File field candidates load after entity preflight.</div>
                </div>
                <div class="small text-muted mt-1">Only selected fields are scanned for upload refs during preflight/build.</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-12">
          <label class="form-label small fw-bold">Target Version</label>
          <input id="builderVersion" type="text" class="form-control" placeholder="1.0.1">
          <div class="small text-muted mt-1">The builder suggests the next patch version automatically. You can change it, but versions lower than the current package version are rejected.</div>
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-12">
          <label class="form-label small fw-bold">Build Note</label>
          <textarea id="builderBuildNote" rows="3" class="form-control" placeholder="Describe what changed in this package build..."></textarea>
          <div class="small text-muted mt-1">Saved into the package as <code>BUILD_NOTE.md</code> and included in builder payload metadata.</div>
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-12">
          <label class="form-label small fw-bold">Manual File/Folder Refs (one per line)</label>
          <textarea id="builderSelectedFileRefs" rows="4" class="form-control font-monospace small" placeholder="/uploads/ORG_900000/symbols/logo.png"></textarea>
          <div class="small text-muted mt-1">Auto-detected upload refs from selected data are included automatically.</div>
        </div>
      </div>

      <div class="d-flex align-items-center gap-2 flex-wrap mt-3">
        <button type="button" class="btn btn-outline-secondary" id="builderPreflightBtn">
          <i class="bi bi-search me-1"></i>Preflight
        </button>
        <button type="button" class="btn btn-primary btn-filled" id="builderBuildBtn">
          <i class="bi bi-box-arrow-down-right me-1"></i>Build Signed Package
        </button>
      </div>
    </div>
  </div>

  <% if (packageWarningsRows.length) { %>
    <div class="alert alert-warning border-0 shadow-sm py-2 px-3 mb-3 small">
      <div class="fw-semibold mb-1">Some packages are unavailable for build:</div>
      <ul class="mb-0 ps-3">
        <% packageWarningsRows.slice(0, 8).forEach((row) => { %>
          <li>
            <code><%= row.packageId || row.storedManifestPath || row.manifestPath %></code>
            - <%= row.warning || row.error || 'Missing or invalid manifest' %>
          </li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <div class="card border-0 shadow-sm mt-3">
    <div class="card-header bg-white fw-bold small d-flex align-items-center justify-content-between">
      <span>Builder Output</span>
      <button type="button" class="btn btn-outline-secondary btn-sm" id="builderClearOutputBtn">Clear</button>
    </div>
    <div class="card-body">
      <pre id="builderOutput" class="small bg-dark text-success p-3 rounded mb-0" style="max-height: 360px; overflow:auto;">Ready.</pre>
      <div id="builderArtifactLinks" class="mt-3 d-none">
        <div class="small fw-semibold mb-1">Published Artifacts</div>
        <div id="builderArtifactHealthAlert" class="alert alert-warning py-2 px-3 small mb-2 d-none"></div>
        <div id="builderArtifactLinksList"></div>
      </div>
    </div>
  </div>

  <input type="hidden" id="builderActionStateId" value="<%= actionStateValue %>">
</div>
<%- include('../partials/modal_GenericPicker', { user }) %>

<script>
(() => {
  const actionStateId = document.getElementById('builderActionStateId')?.value || '';
  const packageEl = document.getElementById('builderPackageId');
  const manifestModeEl = document.getElementById('builderManifestMode');
  const versionEl = document.getElementById('builderVersion');
  const versionHintEl = document.getElementById('builderVersionHint');
  const buildNoteEl = document.getElementById('builderBuildNote');
  const originOrgIdEl = document.getElementById('builderOriginOrgId');
  const originOrgNameEl = document.getElementById('builderOriginOrgName');
  const originOrgPickBtn = document.getElementById('builderPickOriginOrgBtn');
  const originOrgClearBtn = document.getElementById('builderClearOriginOrgBtn');
  const entityListEl = document.getElementById('builderEntityList');
  const fileFieldListEl = document.getElementById('builderFileFieldList');
  const fileRefsEl = document.getElementById('builderSelectedFileRefs');
  const outputEl = document.getElementById('builderOutput');
  const artifactLinksWrapEl = document.getElementById('builderArtifactLinks');
  const artifactHealthAlertEl = document.getElementById('builderArtifactHealthAlert');
  const artifactLinksListEl = document.getElementById('builderArtifactLinksList');
  let entityCatalog = [];
  let selectedFileFieldsByEntity = {};

  function escapeHtml(value = '') {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function formatBytes(value = 0) {
    const size = Number(value || 0);
    if (!Number.isFinite(size) || size <= 0) return '0 B';
    const units = ['B', 'KB', 'MB', 'GB', 'TB'];
    const power = Math.min(Math.floor(Math.log(size) / Math.log(1024)), units.length - 1);
    const scaled = size / (1024 ** power);
    const rounded = power === 0 ? scaled.toFixed(0) : scaled.toFixed(2);
    return `${rounded} ${units[power]}`;
  }

  function setOutput(title, payload) {
    const stamp = new Date().toISOString();
    outputEl.textContent = `[${stamp}] ${title}\n${JSON.stringify(payload, null, 2)}`;
  }

  async function fetchJson(url, options = {}) {
    const response = await fetch(url, options);
    let payload = {};
    try { payload = await response.json(); } catch (_) {}
    if (!response.ok || payload.status === 'error') {
      const message = payload.message || `Request failed (${response.status}).`;
      const error = new Error(message);
      if (payload?.code) error.code = payload.code;
      error.payload = payload;
      throw error;
    }
    return payload;
  }

  function parseLines(value) {
    return String(value || '')
      .split(/\r?\n/)
      .map((row) => row.trim())
      .filter(Boolean);
  }

  function suggestNextVersion(version) {
    const token = String(version || '').trim();
    const match = token.match(/^(\d+)\.(\d+)\.(\d+)(?:[-+].*)?$/);
    if (!match) return '1.0.0';
    const major = Number.parseInt(match[1], 10);
    const minor = Number.parseInt(match[2], 10);
    const patch = Number.parseInt(match[3], 10);
    if (![major, minor, patch].every(Number.isFinite)) return '1.0.0';
    return `${major}.${minor}.${patch + 1}`;
  }

  function syncVersionSuggestion(force = false) {
    const selected = packageEl?.options?.[packageEl.selectedIndex];
    const currentVersion = String(selected?.getAttribute('data-version') || '').trim();
    const packageId = String(packageEl?.value || '').trim();
    const suggested = suggestNextVersion(currentVersion);
    if (versionHintEl) {
      versionHintEl.textContent = packageId
        ? `Current ${currentVersion || 'unknown'} -> suggested ${suggested}`
        : 'Select a package to suggest the next version.';
    }
    if (versionEl && packageId && (force || !versionEl.value.trim())) {
      versionEl.value = suggested;
    }
    if (manifestModeEl) {
      const supportsLiveManifest = ['school', 'pte', 'ielts', 'benchpath'].includes(packageId.toLowerCase());
      Array.from(manifestModeEl.options).forEach((option) => {
        if (option.value === 'live') option.disabled = !supportsLiveManifest;
      });
      if (!supportsLiveManifest && manifestModeEl.value === 'live') manifestModeEl.value = 'static';
      if (supportsLiveManifest && force) manifestModeEl.value = 'live';
    }
  }

  function setBuilderOriginOrgSelection(orgId, orgName = '') {
    const normalizedOrgId = String(orgId || '').trim();
    if (originOrgIdEl) originOrgIdEl.value = normalizedOrgId;
    if (originOrgNameEl) {
      const fallbackName = normalizedOrgId ? `Organization #${normalizedOrgId}` : 'Select organization...';
      originOrgNameEl.value = String(orgName || fallbackName).trim();
    }
  }

  function getSelectedEntities() {
    return Array.from(document.querySelectorAll('.builder-entity-checkbox:checked'))
      .map((node) => String(node.value || '').trim())
      .filter(Boolean);
  }

  function setAllEntitiesChecked(checked) {
    document.querySelectorAll('.builder-entity-checkbox').forEach((node) => {
      node.checked = checked;
    });
    renderFileFieldList(entityCatalog);
  }

  function renderEntityList(rows = []) {
    entityCatalog = Array.isArray(rows) ? rows : [];
    if (!entityListEl) return;
    if (!entityCatalog.length) {
      entityListEl.innerHTML = '<div class="small text-muted">No package-owned tables found.</div>';
      return;
    }
    entityListEl.innerHTML = entityCatalog.map((row) => {
      const entityType = String(row?.entityType || row?.id || '').trim();
      const rowCount = Number(row?.rowCount || 0);
      const uploadCount = Number(row?.detectedUploadRefCount || 0);
      const remap = row?.remapCandidates || {};
      const remapFieldMap = row?.remapFieldMap || {};
      const orgFieldPaths = Array.isArray(remapFieldMap.orgFieldPaths) ? remapFieldMap.orgFieldPaths : [];
      const uploadUrlFieldPaths = Array.isArray(remapFieldMap.uploadUrlFieldPaths) ? remapFieldMap.uploadUrlFieldPaths : [];
      const remapOrgPathCount = orgFieldPaths.length;
      const remapUploadPathCount = uploadUrlFieldPaths.length;
      const orgFieldPathPreview = orgFieldPaths.slice(0, 3).join(', ');
      const uploadFieldPathPreview = uploadUrlFieldPaths.slice(0, 3).join(', ');
      const selected = row?.selected !== false;
      return `
        <label class="d-flex align-items-start gap-2 py-1 border-bottom">
          <input type="checkbox" class="form-check-input mt-1 builder-entity-checkbox" value="${entityType.replace(/"/g, '&quot;')}" ${selected ? 'checked' : ''}>
          <span class="small">
            <span class="fw-semibold">${entityType}</span>
            <span class="text-muted ms-1">(${rowCount} row${rowCount === 1 ? '' : 's'})</span>
            <div class="text-muted">
              Upload refs: ${uploadCount} | Remap fields: ${Number(remap.orgFieldCount || 0)} | Upload URLs: ${Number(remap.uploadUrlCount || 0)} | ORG tokens: ${Number(remap.exactOrgTokenCount || 0)}
            </div>
            <div class="text-muted">
              Remap path map: org fields ${remapOrgPathCount} | upload URL fields ${remapUploadPathCount}
            </div>
            ${orgFieldPathPreview ? `<div class="text-muted"><span class="fw-semibold">Org paths:</span> ${orgFieldPathPreview.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>` : ''}
            ${uploadFieldPathPreview ? `<div class="text-muted"><span class="fw-semibold">Upload URL paths:</span> ${uploadFieldPathPreview.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</div>` : ''}
          </span>
        </label>
      `;
    }).join('');
  }

  function getCurrentSelectedEntitySet() {
    const values = Array.from(document.querySelectorAll('.builder-entity-checkbox:checked'))
      .map((node) => String(node.value || '').trim())
      .filter(Boolean);
    return new Set(values);
  }

  function getEntityCandidates(entityType) {
    const row = entityCatalog.find((item) => String(item?.entityType || item?.id || '').trim() === entityType);
    return Array.isArray(row?.fileFieldCandidates) ? row.fileFieldCandidates.map((token) => String(token || '').trim()).filter(Boolean) : [];
  }

  function normalizeSelectedFileFields(entityType, fields) {
    const candidates = new Set(getEntityCandidates(entityType));
    return Array.from(new Set((Array.isArray(fields) ? fields : [])
      .map((token) => String(token || '').trim())
      .filter((token) => token && candidates.has(token))));
  }

  function seedSelectedFileFieldState(rows = []) {
    const next = {};
    const selectedEntities = getCurrentSelectedEntitySet();
    (Array.isArray(rows) ? rows : []).forEach((row) => {
      const entityType = String(row?.entityType || row?.id || '').trim();
      if (!entityType || !selectedEntities.has(entityType)) return;
      const current = Array.isArray(selectedFileFieldsByEntity[entityType]) ? selectedFileFieldsByEntity[entityType] : [];
      const fallback = Array.isArray(row?.fileFieldSelected) ? row.fileFieldSelected : [];
      next[entityType] = normalizeSelectedFileFields(entityType, current.length ? current : fallback);
    });
    selectedFileFieldsByEntity = next;
  }

  function addSelectedFileField(entityType, fieldPath) {
    const token = String(fieldPath || '').trim();
    if (!entityType || !token) return;
    const next = normalizeSelectedFileFields(entityType, [
      ...(Array.isArray(selectedFileFieldsByEntity[entityType]) ? selectedFileFieldsByEntity[entityType] : []),
      token
    ]);
    selectedFileFieldsByEntity[entityType] = next;
  }

  function removeSelectedFileField(entityType, fieldPath) {
    const token = String(fieldPath || '').trim();
    if (!entityType || !token) return;
    const rows = Array.isArray(selectedFileFieldsByEntity[entityType]) ? selectedFileFieldsByEntity[entityType] : [];
    selectedFileFieldsByEntity[entityType] = rows.filter((row) => row !== token);
  }

  function clearSelectedFileFields(entityType) {
    if (!entityType) return;
    selectedFileFieldsByEntity[entityType] = [];
  }

  function addAllDetectedFileFields() {
    const selectedEntities = getCurrentSelectedEntitySet();
    selectedEntities.forEach((entityType) => {
      selectedFileFieldsByEntity[entityType] = normalizeSelectedFileFields(entityType, getEntityCandidates(entityType));
    });
    renderFileFieldList(entityCatalog);
  }

  function clearAllSelectedFileFields() {
    const selectedEntities = getCurrentSelectedEntitySet();
    selectedEntities.forEach((entityType) => {
      selectedFileFieldsByEntity[entityType] = [];
    });
    renderFileFieldList(entityCatalog);
  }

  function renderFileFieldList(rows = []) {
    if (!fileFieldListEl) return;
    const catalog = Array.isArray(rows) ? rows : [];
    seedSelectedFileFieldState(catalog);
    const selectedEntities = getCurrentSelectedEntitySet();
    const selectedRows = catalog.filter((row) => {
      const entityType = String(row?.entityType || row?.id || '').trim();
      return entityType && selectedEntities.has(entityType);
    });
    if (!selectedRows.length) {
      fileFieldListEl.innerHTML = '<div class="small text-muted">Select at least one table above to configure file field extraction.</div>';
      return;
    }
    const selectableRows = selectedRows.filter((row) => {
      const entityType = String(row?.entityType || row?.id || '').trim();
      return entityType && getEntityCandidates(entityType).length > 0;
    });
    if (!selectableRows.length) {
      fileFieldListEl.innerHTML = '<div class="small text-muted">No upload-address fields detected in selected tables. Use Manual File/Folder Refs if needed.</div>';
      return;
    }

    const cards = selectableRows.map((row) => {
      const entityType = String(row?.entityType || row?.id || '').trim();
      const rowCount = Number(row?.rowCount || 0);
      const candidates = getEntityCandidates(entityType);
      const selected = Array.isArray(selectedFileFieldsByEntity[entityType]) ? selectedFileFieldsByEntity[entityType] : [];
      const hasCandidates = candidates.length > 0;
      const selectedMarkup = selected.length
        ? selected.map((fieldPath) => `
          <span class="badge bg-light text-dark border d-inline-flex align-items-center gap-2">
            <code>${fieldPath.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</code>
            <button
              type="button"
              class="btn btn-sm p-0 text-danger builder-file-field-remove-btn"
              data-entity-type="${entityType.replace(/"/g, '&quot;')}"
              data-field-path="${fieldPath.replace(/"/g, '&quot;')}"
              title="Remove field">
              <i class="bi bi-x-lg"></i>
            </button>
          </span>
        `).join('')
        : '<span class="small text-muted">No selected file fields.</span>';

      return `
        <div class="border rounded p-2 mb-2" data-file-field-card="${entityType.replace(/"/g, '&quot;')}">
          <div class="d-flex align-items-start justify-content-between gap-2 flex-wrap">
            <div>
              <div class="small fw-semibold">${entityType}</div>
              <div class="small text-muted">${rowCount} row${rowCount === 1 ? '' : 's'} | ${candidates.length} upload field candidate${candidates.length === 1 ? '' : 's'}</div>
            </div>
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <select class="form-select form-select-sm builder-file-field-picker" data-entity-type="${entityType.replace(/"/g, '&quot;')}" style="min-width: 320px;" ${hasCandidates ? '' : 'disabled'}>
                ${hasCandidates
                  ? (`<option value="">Select upload field</option>${candidates.map((fieldPath) => `<option value="${fieldPath.replace(/"/g, '&quot;')}">${fieldPath.replace(/</g, '&lt;').replace(/>/g, '&gt;')}</option>`).join('')}`)
                  : '<option value="">No upload fields detected</option>'}
              </select>
              <button type="button" class="btn btn-outline-secondary btn-sm builder-file-field-add-btn" data-entity-type="${entityType.replace(/"/g, '&quot;')}" ${hasCandidates ? '' : 'disabled'}>Add</button>
              <button type="button" class="btn btn-outline-secondary btn-sm builder-file-field-clear-btn" data-entity-type="${entityType.replace(/"/g, '&quot;')}">Clear</button>
            </div>
          </div>
          <div class="d-flex flex-wrap gap-2 mt-2">${selectedMarkup}</div>
        </div>
      `;
    });
    fileFieldListEl.innerHTML = cards.join('');
  }

  function getFileFieldSelection() {
    const map = {};
    const selectedEntities = getCurrentSelectedEntitySet();
    selectedEntities.forEach((entityType) => {
      const rows = normalizeSelectedFileFields(entityType, selectedFileFieldsByEntity[entityType] || []);
      map[entityType] = rows;
    });
    return map;
  }

  function clearArtifactLinks() {
    if (!artifactLinksWrapEl || !artifactLinksListEl) return;
    artifactLinksListEl.innerHTML = '';
    if (artifactHealthAlertEl) {
      artifactHealthAlertEl.classList.add('d-none');
      artifactHealthAlertEl.textContent = '';
    }
    artifactLinksWrapEl.classList.add('d-none');
  }

  function renderArtifactLinks(report = {}) {
    if (!artifactLinksWrapEl || !artifactLinksListEl) return;
    const rows = Array.isArray(report?.publishedArtifacts?.files) ? report.publishedArtifacts.files : [];
    const links = rows
      .map((row) => ({
        fileName: String(row?.fileName || '').trim(),
        url: String(row?.uploadsUrl || '').trim(),
        size: Number(row?.size || 0),
        sha256: String(row?.sha256 || '').trim()
      }))
      .filter((row) => row.fileName && row.url);
    if (!links.length) {
      clearArtifactLinks();
      return;
    }
    artifactLinksListEl.innerHTML = `
      <div class="list-group">
        ${links.map((row) => `
          <div class="list-group-item d-flex align-items-center justify-content-between gap-2 flex-wrap">
            <div class="small">
              <div class="fw-semibold">${escapeHtml(row.fileName)}</div>
              <div class="text-muted">Size: ${escapeHtml(formatBytes(row.size))}${row.sha256 ? ` | SHA-256: <code>${escapeHtml(row.sha256)}</code>` : ''}</div>
            </div>
            <a class="btn btn-outline-primary btn-sm" href="${escapeHtml(row.url)}" target="_blank" rel="noopener">
              <i class="bi bi-download me-1"></i>Download
            </a>
          </div>
        `).join('')}
      </div>
    `;
    const selectedRefCount = Number(report?.fileSummary?.selectedRefCount || 0);
    const copiedCount = Number(report?.fileSummary?.copiedCount || 0);
    if (artifactHealthAlertEl) {
      if (selectedRefCount > 0 && copiedCount === 0) {
        artifactHealthAlertEl.className = 'alert alert-warning py-2 px-3 small mb-2';
        artifactHealthAlertEl.textContent = 'No referenced upload files were copied into the package payload. Check upload paths or gateway availability, then rebuild.';
        artifactHealthAlertEl.classList.remove('d-none');
      } else if (selectedRefCount > copiedCount) {
        artifactHealthAlertEl.className = 'alert alert-info py-2 px-3 small mb-2';
        artifactHealthAlertEl.textContent = `Only ${copiedCount} of ${selectedRefCount} referenced upload file(s) were copied. Review warnings before install.`;
        artifactHealthAlertEl.classList.remove('d-none');
      } else {
        artifactHealthAlertEl.classList.add('d-none');
        artifactHealthAlertEl.textContent = '';
      }
    }
    artifactLinksWrapEl.classList.remove('d-none');
  }

  async function runWithWaiting(label, action, options = {}) {
    const config = options && typeof options === 'object' ? options : {};
    const initialProgress = Number.isFinite(Number(config.initialProgress))
      ? Math.max(0, Math.min(100, Number(config.initialProgress)))
      : 8;
    const maxProgress = Number.isFinite(Number(config.maxProgress))
      ? Math.max(initialProgress, Math.min(99, Number(config.maxProgress)))
      : 88;
    const progressStep = Number.isFinite(Number(config.progressStep))
      ? Math.max(1, Math.min(20, Number(config.progressStep)))
      : 3;
    const tickMs = Number.isFinite(Number(config.tickMs))
      ? Math.max(200, Number(config.tickMs))
      : 700;

    let loadingToken = null;
    let progressTimer = null;
    let currentProgress = initialProgress;
    if (typeof showLoading === 'function') {
      loadingToken = showLoading({
        title: label || 'Please wait...',
        note: config.initialNote || 'Preparing request...',
        operation: config.operation || 'Package Builder',
        progress: currentProgress
      });
      progressTimer = window.setInterval(() => {
        currentProgress = Math.min(maxProgress, currentProgress + progressStep);
        if (typeof updateLoading === 'function') {
          updateLoading({
            note: config.runningNote || 'Processing package request...',
            progress: currentProgress
          });
        } else if (typeof setLoadingProgress === 'function') {
          setLoadingProgress(currentProgress);
        }
      }, tickMs);
    }
    try {
      if (typeof updateLoading === 'function') {
        updateLoading({
          note: config.startNote || 'Sending request...',
          progress: Math.min(maxProgress, initialProgress + progressStep)
        });
      }
      return await action();
    } finally {
      if (progressTimer) window.clearInterval(progressTimer);
      if (typeof updateLoading === 'function') {
        updateLoading({
          note: config.finishNote || 'Finalizing response...',
          progress: 100
        });
      } else if (typeof setLoadingProgress === 'function') {
        setLoadingProgress(100);
      }
      if (typeof hideLoading === 'function') {
        window.setTimeout(() => hideLoading(loadingToken || undefined), 180);
      }
    }
  }

  function showError(error) {
    const message = error?.message || 'Operation failed.';
    setOutput('Operation Failed', {
      status: 'error',
      message,
      code: error?.code || '',
      details: error?.payload?.details || null
    });
    if (typeof showMessageModal === 'function') {
      showMessageModal({
        title: 'Operation Failed',
        message,
        icon: 'error',
        buttons: [{ text: 'Close', class: 'btn-danger' }]
      });
      return;
    }
    alert(message);
  }

  async function requireAdminVerification() {
    if (typeof window.requestProtectedAction !== 'function') {
      throw new Error('Admin verification modal is unavailable. Refresh and try again.');
    }
    await window.requestProtectedAction();
  }

  async function preflightBuild() {
    const packageId = String(packageEl?.value || '').trim();
    const originOrgId = String(originOrgIdEl?.value || '').trim();
    if (!packageId) {
      showError(new Error('Select a package first.'));
      return;
    }
    if (!originOrgId) {
      showError(new Error('Select origin organization first.'));
      return;
    }
    const selectedDataEntities = getSelectedEntities();
    if (!selectedDataEntities.length) {
      showError(new Error('Select at least one table/collection to package.'));
      return;
    }
    const payload = await runWithWaiting('Running package preflight...', async () => fetchJson('/systemSettings/package-builder/preflight', {
      method: 'POST',
      headers: {
        'content-type': 'application/json',
        'x-ajax-request': 'yes'
      },
      body: JSON.stringify({
        packageId,
        manifestMode: manifestModeEl?.value || 'static',
        originOrgId,
        actionStateId,
        selectedDataEntities,
        selectedFileRefs: parseLines(fileRefsEl?.value || ''),
        fileFieldSelection: getFileFieldSelection()
      })
    }), {
      initialNote: 'Preparing preflight payload...',
      runningNote: 'Evaluating selected tables and upload references...',
      finishNote: 'Preparing preflight report...',
      initialProgress: 10,
      maxProgress: 86
    });
    if (Array.isArray(payload?.report?.entityCatalog)) {
      renderEntityList(payload.report.entityCatalog);
      renderFileFieldList(payload.report.entityCatalog);
    }
    clearArtifactLinks();
    setOutput('Preflight Result', payload);
    if (typeof showMessageModal === 'function') {
      const blocking = payload?.report?.scopeValidation?.blocking === true;
      showMessageModal({
        title: blocking ? 'Preflight Blocked' : 'Preflight Complete',
        message: blocking
          ? 'Blocking scope violations were found. Review Builder Output and fix violations before build.'
          : (payload.message || 'Preflight completed successfully.'),
        icon: blocking ? 'warning' : 'success',
        buttons: [{ text: 'OK', class: blocking ? 'btn-warning' : 'btn-success' }]
      });
    }
  }

  async function buildPackage() {
    const packageId = String(packageEl?.value || '').trim();
    const version = String(versionEl?.value || '').trim();
    const originOrgId = String(originOrgIdEl?.value || '').trim();
    if (!packageId) {
      showError(new Error('Select a package first.'));
      return;
    }
    if (!originOrgId) {
      showError(new Error('Select origin organization first.'));
      return;
    }
    if (!version) {
      showError(new Error('Enter target version.'));
      return;
    }
    const selectedDataEntities = getSelectedEntities();
    if (!selectedDataEntities.length) {
      showError(new Error('Select at least one table/collection to package.'));
      return;
    }
    await requireAdminVerification();
    const payload = await runWithWaiting('Building signed package...', async () => fetchJson('/systemSettings/package-builder/build', {
      method: 'POST',
      headers: {
        'content-type': 'application/json',
        'x-ajax-request': 'yes'
      },
      body: JSON.stringify({
        packageId,
        manifestMode: manifestModeEl?.value || 'static',
        version,
        buildNote: buildNoteEl?.value || '',
        originOrgId,
        actionStateId,
        selectedDataEntities,
        selectedFileRefs: parseLines(fileRefsEl?.value || ''),
        fileFieldSelection: getFileFieldSelection()
      })
    }), {
      initialNote: 'Preparing package build request...',
      runningNote: 'Building package payload and publishing artifacts...',
      finishNote: 'Completing build response...',
      initialProgress: 12,
      maxProgress: 92,
      progressStep: 2,
      tickMs: 800
    });
    setOutput('Build Result', payload);
    renderArtifactLinks(payload?.report || {});
    if (typeof showMessageModal === 'function') {
      showMessageModal({
        title: 'Build Completed',
        message: payload.message || 'Package build completed successfully.',
        icon: 'success',
        buttons: [{ text: 'OK', class: 'btn-success' }]
      });
    }
  }

  async function loadEntityCatalog() {
    const packageId = String(packageEl?.value || '').trim();
    const originOrgId = String(originOrgIdEl?.value || '').trim();
    if (!packageId) {
      selectedFileFieldsByEntity = {};
      renderEntityList([]);
      renderFileFieldList([]);
      return;
    }
    if (!originOrgId) {
      selectedFileFieldsByEntity = {};
      renderEntityList([]);
      renderFileFieldList([]);
      if (entityListEl) {
        entityListEl.innerHTML = '<div class="small text-muted">Select origin org to load package tables.</div>';
      }
      return;
    }
    const payload = await runWithWaiting('Loading package tables...', async () => fetchJson('/systemSettings/package-builder/preflight', {
      method: 'POST',
      headers: {
        'content-type': 'application/json',
        'x-ajax-request': 'yes'
      },
      body: JSON.stringify({
        packageId,
        manifestMode: manifestModeEl?.value || 'static',
        originOrgId,
        actionStateId,
        selectedDataEntities: [],
        selectedFileRefs: parseLines(fileRefsEl?.value || ''),
        fileFieldSelection: getFileFieldSelection()
      })
    }), {
      initialNote: 'Loading table catalog...',
      runningNote: 'Reading package-owned entities...',
      finishNote: 'Finalizing table list...',
      initialProgress: 10,
      maxProgress: 84
    });
    const catalog = (Array.isArray(payload?.report?.entityCatalog) && payload.report.entityCatalog.length)
      ? payload.report.entityCatalog
      : (Array.isArray(payload?.report?.availableDataEntities) ? payload.report.availableDataEntities : []);
    renderEntityList(catalog);
    renderFileFieldList(catalog);
    clearArtifactLinks();
    setOutput('Entity Catalog Loaded', payload);
  }

  document.getElementById('builderPreflightBtn')?.addEventListener('click', () => {
    preflightBuild().catch(showError);
  });
  document.getElementById('builderBuildBtn')?.addEventListener('click', () => {
    buildPackage().catch(showError);
  });
  document.getElementById('builderSelectAllEntitiesBtn')?.addEventListener('click', () => setAllEntitiesChecked(true));
  document.getElementById('builderClearEntitiesBtn')?.addEventListener('click', () => setAllEntitiesChecked(false));
  document.getElementById('builderAddAllFileFieldsBtn')?.addEventListener('click', () => addAllDetectedFileFields());
  document.getElementById('builderClearSelectedFileFieldsBtn')?.addEventListener('click', () => clearAllSelectedFileFields());
  entityListEl?.addEventListener('change', (event) => {
    if (!event.target?.classList?.contains('builder-entity-checkbox')) return;
    renderFileFieldList(entityCatalog);
  });
  fileFieldListEl?.addEventListener('click', (event) => {
    const addBtn = event.target.closest('.builder-file-field-add-btn');
    if (addBtn) {
      const entityType = String(addBtn.getAttribute('data-entity-type') || '').trim();
      if (!entityType) return;
      const card = addBtn.closest('[data-file-field-card]');
      const selectNode = card?.querySelector('.builder-file-field-picker');
      const fieldPath = String(selectNode?.value || '').trim();
      if (!fieldPath) return;
      addSelectedFileField(entityType, fieldPath);
      renderFileFieldList(entityCatalog);
      return;
    }

    const removeBtn = event.target.closest('.builder-file-field-remove-btn');
    if (removeBtn) {
      const entityType = String(removeBtn.getAttribute('data-entity-type') || '').trim();
      const fieldPath = String(removeBtn.getAttribute('data-field-path') || '').trim();
      removeSelectedFileField(entityType, fieldPath);
      renderFileFieldList(entityCatalog);
      return;
    }

    const clearBtn = event.target.closest('.builder-file-field-clear-btn');
    if (clearBtn) {
      const entityType = String(clearBtn.getAttribute('data-entity-type') || '').trim();
      clearSelectedFileFields(entityType);
      renderFileFieldList(entityCatalog);
    }
  });
  document.getElementById('builderClearOutputBtn')?.addEventListener('click', () => {
    outputEl.textContent = 'Ready.';
    clearArtifactLinks();
  });
  packageEl?.addEventListener('change', () => {
    syncVersionSuggestion(true);
    loadEntityCatalog().catch(showError);
  });
  manifestModeEl?.addEventListener('change', () => {
    loadEntityCatalog().catch(showError);
  });
  originOrgPickBtn?.addEventListener('click', () => {
    if (!window.GenericPicker || !window.GenericPickerPresets || !window.GenericPickerContexts) {
      showError(new Error('Generic organization picker is not ready yet.'));
      return;
    }
    window.GenericPicker.open(window.GenericPickerPresets.organization({
      title: 'Select Origin Organization',
      context: window.GenericPickerContexts.allOrganizations(),
      onSelect: (item) => {
        setBuilderOriginOrgSelection(
          item?.id,
          item?.identity?.displayName || item?.name || `Organization #${item?.id}`
        );
        if (packageEl?.value) loadEntityCatalog().catch(showError);
      }
    }));
  });
  originOrgClearBtn?.addEventListener('click', () => {
    setBuilderOriginOrgSelection('', '');
    entityCatalog = [];
    selectedFileFieldsByEntity = {};
    renderEntityList([]);
    renderFileFieldList([]);
    fileRefsEl.value = '';
  });
  if (packageEl?.value) {
    syncVersionSuggestion(false);
    loadEntityCatalog().catch(showError);
  } else {
    syncVersionSuggestion(false);
  }
})();
</script>
