<%
  const pageData = (typeof data !== 'undefined' && data && typeof data === 'object') ? data : {};
  const content = pageData.content && typeof pageData.content === 'object' ? pageData.content : {};
  const defaults = pageData.defaults && typeof pageData.defaults === 'object' ? pageData.defaults : {};
  const appSettings = settings && settings.app ? settings.app : {};
  const brand = appSettings.brand || {};
  const contactPage = appSettings.contactPage || {};
  const publicMenu = appSettings.publicMenu && typeof appSettings.publicMenu === 'object' ? appSettings.publicMenu : {};
  const publicMenuItems = Array.isArray(publicMenu.items) ? publicMenu.items : [];
  const publicMenuJson = JSON.stringify(publicMenuItems).replace(/</g, '\\u003c');
  const publicDefaultHomePath = typeof publicMenu.defaultHomePath === 'string' && publicMenu.defaultHomePath.trim()
    ? publicMenu.defaultHomePath.trim()
    : '/';
  const rowValue = (row, key) => row && typeof row === 'object' ? String(row[key] || row.value || '').trim() : '';
  const rowTitle = (row, fallback) => row && typeof row === 'object' ? String(row.title || row.label || fallback || '').trim() : (fallback || '');
  const fallbackContactHighlights = [
    { title: 'Clear Context', body: 'Share goals, files, links, and constraints in one place.' },
    { title: 'Follow-Up Code', body: 'Track your submitted message later with your private code.' },
    { title: 'Direct Route', body: 'Use email if your request is urgent or already documented.' }
  ];
  const fallbackContactProcessImages = [
    {
      imageUrl: '/uploads/GLOBAL/misc/Engineering.jpg',
      alt: 'Mega dust collector system with high efficiency fan.',
      caption: 'Mega dust collector system with a high-efficiency fan for lower energy consumption.'
    },
    {
      imageUrl: '/uploads/GLOBAL/misc/Software.jpeg',
      alt: 'Industrial software interface.',
      caption: 'Industrial and heavy-duty software packages.'
    }
  ];
  const contactPageHighlights = Array.isArray(contactPage.highlights) && contactPage.highlights.length ? contactPage.highlights : fallbackContactHighlights;
  const contactPageProcessImages = Array.isArray(contactPage.processImages) && contactPage.processImages.length ? contactPage.processImages : fallbackContactProcessImages;
  const endpointOptionsFromServer = (typeof publicMenuEndpointOptions !== 'undefined' && Array.isArray(publicMenuEndpointOptions)) ? publicMenuEndpointOptions : [];
  const endpointOptions = endpointOptionsFromServer.length ? endpointOptionsFromServer : [
    { label: 'Home', href: '/', icon: 'bi-house', visibility: 'all', target: '_self', category: 'Core' },
    { label: 'What I Offer', href: '/whatIOffer', icon: 'bi-stars', visibility: 'all', target: '_self', category: 'Core' },
    { label: 'News', href: '/news', icon: 'bi-newspaper', visibility: 'all', target: '_self', category: 'Core' },
    { label: 'Biography', href: '/biography', icon: 'bi-person-badge', visibility: 'all', target: '_self', category: 'Core' },
    { label: 'Contact', href: '/contact', icon: 'bi-envelope', visibility: 'all', target: '_self', category: 'Core' },
    { label: 'About', href: '/about', icon: 'bi-info-circle', visibility: 'all', target: '_self', category: 'Core' },
    { label: 'Sign In', href: '/login', icon: 'bi-box-arrow-in-right', visibility: 'guest', target: '_self', category: 'Account' }
  ];
  const endpointOptionsJson = JSON.stringify(endpointOptions).replace(/</g, '\\u003c');
  const headerShowBuyMeACoffee = brand.headerShowBuyMeACoffee !== false;
  const headerBuyMeACoffeeUrl = String(brand.headerBuyMeACoffeeUrl || 'https://www.buymeacoffee.com/paknejad').trim();
  const headerBuyMeACoffeeLabel = String(brand.headerBuyMeACoffeeLabel || 'Support').trim();
  const headerBuyMeACoffeeText = String(brand.headerBuyMeACoffeeText || 'Buy me a coffee').trim();
  const headerBuyMeACoffeeTitle = String(brand.headerBuyMeACoffeeTitle || 'Support the work - one coffee at a time.').trim();
  const contentJson = JSON.stringify(content).replace(/</g, '\\u003c');
  const defaultsJson = JSON.stringify(defaults).replace(/</g, '\\u003c');
%>

<div class="sections-page public-page-content-settings">
