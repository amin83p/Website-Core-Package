<%
  const pageData = (typeof data !== 'undefined' && data && typeof data === 'object') ? data : {};
  const content = pageData.content && typeof pageData.content === 'object' ? pageData.content : {};
  const defaults = pageData.defaults && typeof pageData.defaults === 'object' ? pageData.defaults : {};
  const contentJson = JSON.stringify(content).replace(/</g, '\\u003c');
  const defaultsJson = JSON.stringify(defaults).replace(/</g, '\\u003c');
%>

<div class="sections-page public-page-content-settings">
  <div class="d-flex align-items-center justify-content-between gap-3 mb-4">
    <div>
      <h1 class="page-heading size-md text-start m-0"><i class="bi bi-window-sidebar me-2"></i>Public Page Content</h1>
      <div class="text-muted small mt-1">Manage editable content for Home, Projects, and About without changing the page design.</div>
    </div>
    <div class="d-flex align-items-center gap-2">
      <% if (pageData.updatedAt) { %>
        <span class="badge bg-light text-dark border">Updated <%= new Date(pageData.updatedAt).toLocaleString() %></span>
      <% } %>
      <a href="/" class="btn btn-outline-secondary btn-sm" target="_blank" rel="noopener noreferrer">
        <i class="bi bi-box-arrow-up-right me-1"></i>View Site
      </a>
    </div>
  </div>

  <form id="publicPageContentForm" action="/systemSettings/public-pages" method="POST" class="form-container wide" style="max-width: 1440px;">
    <input type="hidden" name="actionStateId" value="<%= typeof actionStateId !== 'undefined' ? actionStateId : '' %>">
    <input type="hidden" name="contentJson" id="publicPageContentJson" value="<%= contentJson %>">

    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
      <ul class="nav nav-tabs" id="publicPageContentTabs" role="tablist">
        <li class="nav-item" role="presentation">
          <button class="nav-link active fw-semibold" id="home-content-tab" data-bs-toggle="tab" data-bs-target="#home-content-pane" type="button" role="tab" aria-controls="home-content-pane" aria-selected="true">
            <i class="bi bi-house me-1"></i>Home
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link fw-semibold" id="projects-content-tab" data-bs-toggle="tab" data-bs-target="#projects-content-pane" type="button" role="tab" aria-controls="projects-content-pane" aria-selected="false">
            <i class="bi bi-stars me-1"></i>Projects
          </button>
        </li>
        <li class="nav-item" role="presentation">
          <button class="nav-link fw-semibold" id="about-content-tab" data-bs-toggle="tab" data-bs-target="#about-content-pane" type="button" role="tab" aria-controls="about-content-pane" aria-selected="false">
            <i class="bi bi-person-workspace me-1"></i>About
          </button>
        </li>
      </ul>

      <div class="d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="publicPageContentReloadBtn">
          <i class="bi bi-arrow-clockwise me-1"></i>Reload
        </button>
        <button type="submit" class="btn btn-primary btn-sm fw-semibold" id="publicPageContentSaveBtn">
          <i class="bi bi-save me-1"></i>Save Public Content
        </button>
      </div>
    </div>

    <div class="tab-content pt-2" id="publicPageContentTabContent">
      <div class="tab-pane fade show active" id="home-content-pane" role="tabpanel" aria-labelledby="home-content-tab" tabindex="0">
        <div class="settings-grid">
          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-magic text-primary me-2"></i>Home Hero</h2>
                <p>Top headline, intro copy, and primary actions.</p>
              </div>
            </div>
            <div class="settings-card-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold">Eyebrow</label>
                  <input type="text" class="form-control" data-content-path="home.hero.eyebrow">
                </div>
                <div class="col-md-8">
                  <label class="form-label fw-bold">Title</label>
                  <input type="text" class="form-control" data-content-path="home.hero.title">
                </div>
                <div class="col-12">
                  <label class="form-label fw-bold">Subtitle</label>
                  <textarea class="form-control" rows="3" data-content-path="home.hero.subtitle"></textarea>
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-bold">Primary Label</label>
                  <input type="text" class="form-control" data-content-path="home.hero.primaryLabel">
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-bold">Primary Link</label>
                  <input type="text" class="form-control font-monospace" data-content-path="home.hero.primaryHref">
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-bold">Secondary Label</label>
                  <input type="text" class="form-control" data-content-path="home.hero.secondaryLabel">
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-bold">Secondary Link</label>
                  <input type="text" class="form-control font-monospace" data-content-path="home.hero.secondaryHref">
                </div>
              </div>
            </div>
          </section>

          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-images text-primary me-2"></i>Image Showcase</h2>
                <p>Optional saved slides. If empty, the Home page uses the existing upload-folder slideshow fallback.</p>
              </div>
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="home.imageShowcase">
                <i class="bi bi-plus-lg me-1"></i>Add Slide
              </button>
            </div>
            <div class="settings-card-body repeatable-body" id="homeImageShowcaseRows"></div>
          </section>

          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-bar-chart text-primary me-2"></i>Highlight Chips</h2>
                <p>Short metrics below the Home hero.</p>
              </div>
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="home.highlights">
                <i class="bi bi-plus-lg me-1"></i>Add Highlight
              </button>
            </div>
            <div class="settings-card-body repeatable-body" id="homeHighlightRows"></div>
          </section>

          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-grid-3x3-gap text-primary me-2"></i>Feature Cards</h2>
                <p>Section heading and cards that describe the value proposition.</p>
              </div>
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="home.features">
                <i class="bi bi-plus-lg me-1"></i>Add Feature
              </button>
            </div>
            <div class="settings-card-body">
              <div class="row g-3 mb-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold">Section Eyebrow</label>
                  <input type="text" class="form-control" data-content-path="home.featureSection.eyebrow">
                </div>
                <div class="col-md-8">
                  <label class="form-label fw-bold">Section Title</label>
                  <input type="text" class="form-control" data-content-path="home.featureSection.title">
                </div>
                <div class="col-12">
                  <label class="form-label fw-bold">Section Body</label>
                  <textarea class="form-control" rows="2" data-content-path="home.featureSection.body"></textarea>
                </div>
              </div>
              <div class="repeatable-body" id="homeFeatureRows"></div>
            </div>
          </section>

          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-diagram-3 text-primary me-2"></i>Solutions And Scope</h2>
                <p>Core solutions, service tags, and current focus note.</p>
              </div>
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="home.solutions.items">
                <i class="bi bi-plus-lg me-1"></i>Add Solution
              </button>
            </div>
            <div class="settings-card-body">
              <div class="row g-3 mb-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold">Solutions Eyebrow</label>
                  <input type="text" class="form-control" data-content-path="home.solutions.eyebrow">
                </div>
                <div class="col-md-8">
                  <label class="form-label fw-bold">Solutions Title</label>
                  <input type="text" class="form-control" data-content-path="home.solutions.title">
                </div>
                <div class="col-md-4">
                  <label class="form-label fw-bold">Scope Eyebrow</label>
                  <input type="text" class="form-control" data-content-path="home.serviceScope.eyebrow">
                </div>
                <div class="col-md-8">
                  <label class="form-label fw-bold">Scope Title</label>
                  <input type="text" class="form-control" data-content-path="home.serviceScope.title">
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold">Service Tags</label>
                  <textarea class="form-control" rows="5" data-content-list-path="home.serviceScope.tags"></textarea>
                  <div class="form-text">One tag per line.</div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold">Current Focus Title</label>
                  <input type="text" class="form-control mb-2" data-content-path="home.serviceScope.noteTitle">
                  <label class="form-label fw-bold">Current Focus Body</label>
                  <textarea class="form-control" rows="3" data-content-path="home.serviceScope.noteBody"></textarea>
                </div>
              </div>
              <div class="repeatable-body" id="homeSolutionRows"></div>
            </div>
          </section>

          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-life-preserver text-primary me-2"></i>Support Cards</h2>
                <p>Bottom support/contact cards.</p>
              </div>
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="home.supportCards">
                <i class="bi bi-plus-lg me-1"></i>Add Card
              </button>
            </div>
            <div class="settings-card-body repeatable-body" id="homeSupportCardRows"></div>
          </section>

          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-megaphone text-primary me-2"></i>Home Final CTA</h2>
                <p>Final call-to-action block.</p>
              </div>
            </div>
            <div class="settings-card-body">
              <%- include('./publicPageContentSettingsFields/finalCta', { prefix: 'home.finalCta', includeEyebrow: true }) %>
            </div>
          </section>
        </div>
      </div>

      <div class="tab-pane fade" id="projects-content-pane" role="tabpanel" aria-labelledby="projects-content-tab" tabindex="0">
        <div class="settings-grid">
          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-stars text-primary me-2"></i>Projects Hero</h2>
                <p>Top Projects page content and actions.</p>
              </div>
            </div>
            <div class="settings-card-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold">Eyebrow</label>
                  <input type="text" class="form-control" data-content-path="projects.hero.eyebrow">
                </div>
                <div class="col-md-8">
                  <label class="form-label fw-bold">Title</label>
                  <input type="text" class="form-control" data-content-path="projects.hero.title">
                </div>
                <div class="col-12">
                  <label class="form-label fw-bold">Subtitle</label>
                  <textarea class="form-control" rows="3" data-content-path="projects.hero.subtitle"></textarea>
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-bold">Primary Label</label>
                  <input type="text" class="form-control" data-content-path="projects.hero.primaryLabel">
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-bold">Primary Link</label>
                  <input type="text" class="form-control font-monospace" data-content-path="projects.hero.primaryHref">
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-bold">Secondary Label</label>
                  <input type="text" class="form-control" data-content-path="projects.hero.secondaryLabel">
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-bold">Secondary Link</label>
                  <input type="text" class="form-control font-monospace" data-content-path="projects.hero.secondaryHref">
                </div>
              </div>
            </div>
          </section>

          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-bar-chart text-primary me-2"></i>Projects Highlights</h2>
                <p>Hero chips for project positioning.</p>
              </div>
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="projects.highlights">
                <i class="bi bi-plus-lg me-1"></i>Add Highlight
              </button>
            </div>
            <div class="settings-card-body repeatable-body" id="projectsHighlightRows"></div>
          </section>

          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-kanban text-primary me-2"></i>Project Examples</h2>
                <p>Heading and repeatable project cards.</p>
              </div>
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="projects.projectItems">
                <i class="bi bi-plus-lg me-1"></i>Add Project
              </button>
            </div>
            <div class="settings-card-body">
              <div class="row g-3 mb-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold">Section Eyebrow</label>
                  <input type="text" class="form-control" data-content-path="projects.projectSection.eyebrow">
                </div>
                <div class="col-md-8">
                  <label class="form-label fw-bold">Section Title</label>
                  <input type="text" class="form-control" data-content-path="projects.projectSection.title">
                </div>
                <div class="col-12">
                  <label class="form-label fw-bold">Section Body</label>
                  <textarea class="form-control" rows="2" data-content-path="projects.projectSection.body"></textarea>
                </div>
              </div>
              <div class="repeatable-body" id="projectsProjectRows"></div>
            </div>
          </section>

          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-person-badge text-primary me-2"></i>Resume Context</h2>
                <p>Side-card context, bullets, and note.</p>
              </div>
            </div>
            <div class="settings-card-body">
              <div class="row g-3">
                <div class="col-md-3">
                  <label class="form-label fw-bold">Icon</label>
                  <input type="text" class="form-control font-monospace" data-content-path="projects.resumeContext.icon">
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-bold">Kicker</label>
                  <input type="text" class="form-control" data-content-path="projects.resumeContext.kicker">
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold">Title</label>
                  <input type="text" class="form-control" data-content-path="projects.resumeContext.title">
                </div>
                <div class="col-12">
                  <label class="form-label fw-bold">Intro</label>
                  <textarea class="form-control" rows="2" data-content-path="projects.resumeContext.intro"></textarea>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold">Points</label>
                  <textarea class="form-control" rows="6" data-content-list-path="projects.resumeContext.points"></textarea>
                  <div class="form-text">One point per line.</div>
                </div>
                <div class="col-md-6">
                  <label class="form-label fw-bold">Note Title</label>
                  <input type="text" class="form-control mb-2" data-content-path="projects.resumeContext.noteTitle">
                  <label class="form-label fw-bold">Note Body</label>
                  <textarea class="form-control" rows="4" data-content-path="projects.resumeContext.noteBody"></textarea>
                </div>
              </div>
            </div>
          </section>

          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-tags text-primary me-2"></i>Service Areas</h2>
                <p>Project domains shown as tags.</p>
              </div>
            </div>
            <div class="settings-card-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold">Eyebrow</label>
                  <input type="text" class="form-control" data-content-path="projects.servicePanel.eyebrow">
                </div>
                <div class="col-md-8">
                  <label class="form-label fw-bold">Title</label>
                  <input type="text" class="form-control" data-content-path="projects.servicePanel.title">
                </div>
                <div class="col-12">
                  <label class="form-label fw-bold">Tags</label>
