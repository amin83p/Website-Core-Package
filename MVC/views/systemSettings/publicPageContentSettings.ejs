      <div class="tab-pane fade" id="about-content-pane" role="tabpanel" aria-labelledby="about-content-tab" tabindex="0">
        <div class="settings-grid">
          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-person-workspace text-primary me-2"></i>About Hero</h2>
                <p>Portfolio hero, intro, and actions.</p>
              </div>
            </div>
            <div class="settings-card-body">
              <div class="row g-3">
                <div class="col-md-4">
                  <label class="form-label fw-bold">Eyebrow</label>
                  <input type="text" class="form-control" data-content-path="about.hero.eyebrow">
                </div>
                <div class="col-md-8">
                  <label class="form-label fw-bold">Title</label>
                  <input type="text" class="form-control" data-content-path="about.hero.title">
                </div>
                <div class="col-12">
                  <label class="form-label fw-bold">Subtitle</label>
                  <textarea class="form-control" rows="3" data-content-path="about.hero.subtitle"></textarea>
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-bold">Primary Label</label>
                  <input type="text" class="form-control" data-content-path="about.hero.primaryLabel">
                </div>
                <div class="col-md-3">
                  <label class="form-label fw-bold">Primary Link</label>
                  <input type="text" class="form-control font-monospace" data-content-path="about.hero.primaryHref">
