                  <label class="form-label fw-bold">Section Body</label>
                  <textarea class="form-control" rows="2" data-content-path="about.experienceSection.body"></textarea>
                </div>
              </div>
              <div class="repeatable-body" id="aboutExperienceRows"></div>
            </div>
          </section>

          <section class="settings-card">
            <div class="settings-card-header">
              <div>
                <h2><i class="bi bi-megaphone text-primary me-2"></i>About Footer CTA</h2>
