<script type="application/json" id="aqLedgerFilterState"><%- JSON.stringify(stateFilters || {}).replace(/</g, '\\u003c').replace(/\u2028/g, '\\u2028').replace(/\u2029/g, '\\u2029').replace(/&/g, '\\u0026') %></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
  const actionStateRef = document.getElementById('actionStateIdRef');
  const actionStateId = actionStateRef ? String(actionStateRef.getAttribute('data-id') || '').trim() : '';
  const selectAllNode = document.getElementById('aqLedgerSelectAll');
  const selectAllHeader = document.getElementById('aqLedgerSelectAllHeader');
  const rowCheckboxes = Array.from(document.querySelectorAll('.aq-ledger-row-select'));
  const bulkToolbar = document.getElementById('aqLedgerBulkToolbar');
  const bulkSelectedCount = document.getElementById('aqLedgerBulkSelectedCount');
  const bulkDeleteBtn = document.getElementById('aqLedgerBulkDeleteBtn');
  const tableBody = document.querySelector('#first-table tbody');
  const ledgerTableColumnCount = <%= canDelete ? 9 : 8 %>;

  function initCollapseToggleIcon(options = {}) {
    const collapseEl = document.getElementById(String(options.collapseId || ''));
    const buttonEl = document.getElementById(String(options.buttonId || ''));
    const iconEl = document.getElementById(String(options.iconId || ''));
    if (!collapseEl || !buttonEl || !iconEl) return;

    const openIcon = String(options.openIcon || 'bi-chevron-down');
    const closeIcon = String(options.closeIcon || 'bi-chevron-up');

    const setState = (expanded) => {
      iconEl.classList.remove(openIcon, closeIcon);
      iconEl.classList.add(expanded ? closeIcon : openIcon);
      buttonEl.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      buttonEl.setAttribute('aria-label', expanded ? 'Close filters' : 'Open filters');
    };

    setState(collapseEl.classList.contains('show'));
    collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
    collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
  }

  initCollapseToggleIcon({
    collapseId: 'aqLedgerFilterCollapse',
    buttonId: 'aqLedgerFilterToggleBtn',
    iconId: 'aqLedgerFilterToggleIcon',
    openIcon: 'bi-chevron-down',
    closeIcon: 'bi-chevron-up'
  });

  async function showMessage(title, message, icon = 'info') {
    if (typeof window.showMessageModal === 'function') {
      await window.showMessageModal({
        title,
        message,
        icon,
        buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : 'btn-primary' }]
      });
      return;
    }
    window.alert([title, message].filter(Boolean).join('\n\n'));
  }

  async function showConfirm(title, message, confirmText = 'Delete', confirmClass = 'btn-danger') {
    if (typeof window.showMessageModal === 'function') {
      const decision = await window.showMessageModal({
        title,
        message,
        icon: 'warning',
        buttons: [
          { text: 'Cancel', class: 'btn-secondary' },
          { text: confirmText, class: confirmClass }
        ]
      });
      return String(decision || '').trim().toLowerCase() === String(confirmText || '').trim().toLowerCase();
    }
    return window.confirm(message || title || 'Are you sure?');
  }

  function setButtonBusy(button, isBusy, busyLabel = 'Working...') {
    if (!button) return;
    if (!button.dataset.defaultHtml) {
      button.dataset.defaultHtml = button.innerHTML;
    }
    if (isBusy) {
      button.disabled = true;
      button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + String(busyLabel || 'Working...');
      return;
    }
    button.disabled = false;
    button.innerHTML = button.dataset.defaultHtml || button.innerHTML;
  }

  function getSelectedLedgerIds() {
    return rowCheckboxes
      .filter((checkbox) => checkbox && checkbox.checked)
      .map((checkbox) => String(checkbox.value || '').trim())
      .filter(Boolean);
  }

  function syncSelectionToolbar() {
    const selectedCount = getSelectedLedgerIds().length;
    if (bulkSelectedCount) bulkSelectedCount.textContent = String(selectedCount);
    if (bulkToolbar) {
      bulkToolbar.classList.toggle('d-none', selectedCount <= 0);
    }
    if (selectAllNode) {
      const totalCount = rowCheckboxes.length;
      selectAllNode.checked = totalCount > 0 && selectedCount === totalCount;
      selectAllNode.indeterminate = selectedCount > 0 && selectedCount < totalCount;
    }
  }

  function clearSelection() {
    rowCheckboxes.forEach((checkbox) => {
      checkbox.checked = false;
    });
    syncSelectionToolbar();
  }

  function bindRowCheckboxListeners() {
    rowCheckboxes.forEach((checkbox) => {
      if (!checkbox || checkbox.dataset.aqLedgerBound === '1') return;
      checkbox.dataset.aqLedgerBound = '1';
      checkbox.addEventListener('change', syncSelectionToolbar);
    });
  }

  function ensureEmptyRowIfNeeded() {
    const realRows = Array.from(document.querySelectorAll('#first-table tbody tr[data-ledger-row="1"]'));
    const existingEmpty = document.getElementById('aqLedgerEmptyRow');
    if (realRows.length > 0) {
      if (existingEmpty) existingEmpty.remove();
      return;
    }
    if (existingEmpty || !tableBody) return;
    const tr = document.createElement('tr');
    tr.id = 'aqLedgerEmptyRow';
    tr.innerHTML = '<td colspan="' + ledgerTableColumnCount + '" class="text-center py-4 text-muted">No ledger entries found for these filters.</td>';
    tableBody.appendChild(tr);
  }

  function getDatasetValue(row, key, fallback = '-') {
    if (!row || !row.dataset) return fallback;
    const value = String(row.dataset[key] || '').trim();
    return value || fallback;
  }

  function formatDetailNumber(value) {
    const numeric = Number(value || 0);
    if (!Number.isFinite(numeric)) return '0';
    return numeric.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 6 });
  }

  function setTextById(id, value) {
    const node = document.getElementById(id);
    if (!node) return;
    node.textContent = String(value == null ? '' : value);
  }

  function initRowDetailModal() {
    const modalEl = document.getElementById('aqLedgerRowDetailModal');
    const tableEl = document.getElementById('first-table');
    if (!modalEl || !tableEl || !window.bootstrap) return;
    // Move modal to <body> to avoid stacking-context issues that can hide it behind backdrop.
    if (modalEl.parentElement !== document.body) {
      document.body.appendChild(modalEl);
    }
    const modal = new window.bootstrap.Modal(modalEl);

    tableEl.querySelectorAll('tbody tr[data-ledger-row="1"]').forEach((row) => {
      row.setAttribute('tabindex', '0');
      row.setAttribute('role', 'button');
      row.setAttribute('title', 'Click to view details');

      const open = () => {
        setTextById('aqLedgerDetailDateTime', getDatasetValue(row, 'ledgerDatetime'));
        setTextById('aqLedgerDetailId', getDatasetValue(row, 'ledgerId'));
        setTextById('aqLedgerDetailEntryType', getDatasetValue(row, 'ledgerEntryType'));
        setTextById('aqLedgerDetailOrgId', getDatasetValue(row, 'ledgerOrgId'));
        setTextById('aqLedgerDetailUserName', getDatasetValue(row, 'ledgerUserName'));
        setTextById('aqLedgerDetailUserId', getDatasetValue(row, 'ledgerUserId'));
        setTextById('aqLedgerDetailCreatorName', getDatasetValue(row, 'ledgerCreatorName'));
        setTextById('aqLedgerDetailCreatorId', getDatasetValue(row, 'ledgerCreatorId'));
        setTextById('aqLedgerDetailSectionName', getDatasetValue(row, 'ledgerSectionName'));
        setTextById('aqLedgerDetailSectionId', getDatasetValue(row, 'ledgerSectionId'));
        setTextById('aqLedgerDetailOperationName', getDatasetValue(row, 'ledgerOperationName'));
        setTextById('aqLedgerDetailOperationId', getDatasetValue(row, 'ledgerOperationId'));
        setTextById('aqLedgerDetailCall', formatDetailNumber(getDatasetValue(row, 'ledgerCall', '0')));
        setTextById('aqLedgerDetailAmount', formatDetailNumber(getDatasetValue(row, 'ledgerAmount', '0')));
        setTextById('aqLedgerDetailToken', formatDetailNumber(getDatasetValue(row, 'ledgerToken', '0')));
        setTextById('aqLedgerDetailVolume', formatDetailNumber(getDatasetValue(row, 'ledgerVolume', '0')));
        setTextById('aqLedgerDetailSourceType', getDatasetValue(row, 'ledgerSourceEventType'));
        setTextById('aqLedgerDetailSourceEventId', getDatasetValue(row, 'ledgerSourceEventId'));
        setTextById('aqLedgerDetailSourceModule', getDatasetValue(row, 'ledgerSourceModule'));
        setTextById('aqLedgerDetailIdempotencyKey', getDatasetValue(row, 'ledgerSourceIdempotencyKey'));
        modal.show();
      };

      row.addEventListener('click', (event) => {
        if (event.target.closest('button, a, input, select, textarea, label')) return;
        open();
      });
      row.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          open();
        }
      });
    });
  }

  initRowDetailModal();

  bindRowCheckboxListeners();

  if (selectAllHeader) {
    selectAllHeader.addEventListener('click', (event) => {
      if (event.target.closest('input, label')) return;
      if (!selectAllNode) return;
      const nextState = !selectAllNode.checked || selectAllNode.indeterminate;
      selectAllNode.checked = nextState;
      selectAllNode.dispatchEvent(new Event('change', { bubbles: true }));
    });
    selectAllHeader.addEventListener('keydown', (event) => {
      if (event.key !== 'Enter' && event.key !== ' ') return;
      event.preventDefault();
      if (!selectAllNode) return;
      const nextState = !selectAllNode.checked || selectAllNode.indeterminate;
      selectAllNode.checked = nextState;
      selectAllNode.dispatchEvent(new Event('change', { bubbles: true }));
    });
  }

  if (selectAllNode) {
    selectAllNode.addEventListener('change', () => {
      const checked = Boolean(selectAllNode.checked);
      rowCheckboxes.forEach((checkbox) => {
        checkbox.checked = checked;
      });
      syncSelectionToolbar();
    });
  }

  if (bulkDeleteBtn) {
    bulkDeleteBtn.addEventListener('click', async () => {
      const ids = getSelectedLedgerIds();
      if (!ids.length) {
        await showMessage('No Selection', 'Select at least one ledger entry first.', 'warning');
        return;
      }

      const confirmed = await showConfirm(
        'Delete Selected Ledger Entries',
        'Delete ' + ids.length + ' selected ledger entr' + (ids.length === 1 ? 'y' : 'ies') + '? This action cannot be undone.',
        'Delete',
        'btn-danger'
      );
      if (!confirmed) return;

      const endpoint = '/activity-quota/ledger/bulk-delete?actionStateId=' + encodeURIComponent(actionStateId || '');
      setButtonBusy(bulkDeleteBtn, true, 'Deleting...');
      try {
        const response = await fetch(endpoint, {
          method: 'POST',
          credentials: 'same-origin',
          headers: {
            'Content-Type': 'application/json',
            'X-Ajax-Request': 'true',
            Accept: 'application/json'
          },
          body: JSON.stringify({ ids })
        });

        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload.status !== 'success') {
          throw new Error(payload.message || 'Bulk delete failed.');
        }

        const removedIds = Array.isArray(payload?.results?.removedIds) ? payload.results.removedIds : ids;
        const removeSet = new Set(removedIds.map((id) => String(id || '').trim()).filter(Boolean));
        rowCheckboxes.forEach((checkbox) => {
          const id = String(checkbox.value || '').trim();
          if (!id || !removeSet.has(id)) return;
          const row = checkbox.closest('tr[data-ledger-row="1"]');
          if (row) row.remove();
        });

        rowCheckboxes.splice(0, rowCheckboxes.length, ...Array.from(document.querySelectorAll('.aq-ledger-row-select')));
        bindRowCheckboxListeners();
        clearSelection();
        ensureEmptyRowIfNeeded();
        await showMessage('Deleted', payload.message || 'Selected ledger entries were deleted successfully.', 'success');
      } catch (error) {
        await showMessage('Delete Failed', error.message || 'Failed to delete selected ledger entries.', 'error');
      } finally {
        setButtonBusy(bulkDeleteBtn, false);
      }
    });
  }

  syncSelectionToolbar();

  if (!window.GenericPicker) return;

  function parseJsonScript(id, fallback) {
    try {
      const node = document.getElementById(id);
      if (!node) return fallback;
      return JSON.parse(node.textContent || '{}');
    } catch (_) {
      return fallback;
    }
  }

  function escapeHtml(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function toList(raw) {
    if (Array.isArray(raw)) return raw.map((item) => String(item || '').trim()).filter(Boolean);
    const token = String(raw || '').trim();
    if (!token) return [];
    return token.split(',').map((item) => String(item || '').trim()).filter(Boolean);
  }

  const filterState = parseJsonScript('aqLedgerFilterState', {});
  const contexts = window.GenericPickerContexts || {};
  const activeOrgContext = (typeof contexts.activeOrganizationScope === 'function')
    ? contexts.activeOrganizationScope({ label: 'Active Organization Scope' })
    : null;

  const fieldConfig = {
    users: {
      key: 'userIds',
      fallback: 'userId',
      inputId: 'aqLedgerUserInput',
      summaryId: 'aqLedgerUserSummary',
      listId: 'aqLedgerUserList',
      pickBtnId: 'aqLedgerPickUserBtn',
      clearBtnId: 'aqLedgerClearUserBtn',
      placeholder: 'No users selected',
      picker: () => window.GenericPickerPresets.user({
        title: 'Select Target Users',
        icon: 'bi-people',
        apiEndpoint: '/activity-quota/ledger/picker/users',
        searchFields: 'id,username,email,name',
        placeholder: 'Search users by id, username, or email...',
        multiselect: true,
        context: activeOrgContext
      })
    },
    sections: {
      key: 'sectionIds',
      fallback: 'section',
      inputId: 'aqLedgerSectionInput',
      summaryId: 'aqLedgerSectionSummary',
      listId: 'aqLedgerSectionList',
      pickBtnId: 'aqLedgerPickSectionBtn',
      clearBtnId: 'aqLedgerClearSectionBtn',
      placeholder: 'No sections selected',
      picker: () => window.GenericPickerPresets.section({
        title: 'Select Sections',
        icon: 'bi-collection',
        apiEndpoint: '/activity-quota/ledger/picker/sections',
        searchFields: 'id,name,description,category',
        placeholder: 'Search sections...',
        multiselect: true,
        context: activeOrgContext
      })
    },
    operations: {
      key: 'operationIds',
      fallback: 'operation',
      inputId: 'aqLedgerOperationInput',
      summaryId: 'aqLedgerOperationSummary',
      listId: 'aqLedgerOperationList',
      pickBtnId: 'aqLedgerPickOperationBtn',
      clearBtnId: 'aqLedgerClearOperationBtn',
      placeholder: 'No operations selected',
      picker: () => window.GenericPickerPresets.operation({
        title: 'Select Operations',
        icon: 'bi-gear',
        apiEndpoint: '/activity-quota/ledger/picker/operations',
        searchFields: 'id,name,description',
        placeholder: 'Search operations...',
        multiselect: true,
        context: activeOrgContext
      })
    },
    creators: {
      key: 'creatorUserIds',
      fallback: 'creatorUserId',
      inputId: 'aqLedgerCreatorInput',
      summaryId: 'aqLedgerCreatorSummary',
      listId: 'aqLedgerCreatorList',
      pickBtnId: 'aqLedgerPickCreatorBtn',
      clearBtnId: 'aqLedgerClearCreatorBtn',
      placeholder: 'No creators selected',
      picker: () => window.GenericPickerPresets.user({
        title: 'Select Creator Users',
        icon: 'bi-person-badge',
        apiEndpoint: '/activity-quota/ledger/picker/users',
        searchFields: 'id,username,email,name',
        placeholder: 'Search creator users...',
        multiselect: true,
        context: activeOrgContext
      })
    }
  };

  const state = {};

  Object.keys(fieldConfig).forEach((fieldName) => {
    const cfg = fieldConfig[fieldName];
    const initial = toList(filterState[cfg.key]).concat(toList(filterState[cfg.fallback]));
    const unique = Array.from(new Set(initial));
    state[fieldName] = unique.map((id) => ({ id, name: id }));
  });

  function renderField(fieldName) {
    const cfg = fieldConfig[fieldName];
    const inputEl = document.getElementById(cfg.inputId);
    const summaryEl = document.getElementById(cfg.summaryId);
    const listEl = document.getElementById(cfg.listId);
    if (!inputEl || !summaryEl || !listEl) return;

    const selected = Array.isArray(state[fieldName]) ? state[fieldName] : [];
    inputEl.value = selected.map((item) => String(item.id || '').trim()).filter(Boolean).join(',');
    summaryEl.value = selected.length ? (selected.length + ' selected') : '';
    summaryEl.placeholder = cfg.placeholder;

    if (!selected.length) {
      listEl.innerHTML = '<div class="text-muted small py-1">' + escapeHtml(cfg.placeholder) + '</div>';
      return;
    }

    listEl.innerHTML = selected.map((item) => {
      const id = String(item.id || '').trim();
      const name = String(item.name || id).trim() || id;
      return ''
        + '<div class="d-flex align-items-center justify-content-between gap-2 border rounded bg-white px-2 py-1 mb-1">'
        + '  <div class="overflow-hidden">'
        + '    <div class="small fw-bold text-truncate">' + escapeHtml(name) + '</div>'
        + '    <div class="x-small text-muted font-monospace text-truncate">' + escapeHtml(id) + '</div>'
        + '  </div>'
        + '  <button type="button" class="btn btn-outline-danger btn-sm" data-ledger-remove="' + escapeHtml(fieldName) + '" data-ledger-remove-id="' + escapeHtml(id) + '"><i class="bi bi-x-lg"></i></button>'
        + '</div>';
    }).join('');
  }

  function upsertFieldItems(fieldName, items) {
    const list = Array.isArray(items) ? items : [items];
    const current = Array.isArray(state[fieldName]) ? state[fieldName] : [];
    const byId = new Map(current.map((item) => [String(item.id || '').trim(), item]));
    list.forEach((raw) => {
      const item = raw && typeof raw === 'object' ? raw : { id: raw };
      const id = String(item.id || '').trim();
      if (!id) return;
      byId.set(id, {
        id,
        name: String(item.name || item.label || item.title || id).trim() || id
      });
    });
    state[fieldName] = Array.from(byId.values());
    renderField(fieldName);
  }

  function clearField(fieldName) {
    state[fieldName] = [];
    renderField(fieldName);
  }

  function removeFieldItem(fieldName, id) {
    const token = String(id || '').trim();
    state[fieldName] = (Array.isArray(state[fieldName]) ? state[fieldName] : [])
      .filter((item) => String(item.id || '').trim() !== token);
    renderField(fieldName);
  }

  function openPicker(fieldName) {
    const cfg = fieldConfig[fieldName];
    if (!cfg) return;
    const pickerConfig = cfg.picker();
    pickerConfig.multiselect = true;
    pickerConfig.onSelect = (items) => {
      upsertFieldItems(fieldName, items);
    };
    window.GenericPicker.open(pickerConfig);
  }

  Object.keys(fieldConfig).forEach((fieldName) => {
    renderField(fieldName);
    const cfg = fieldConfig[fieldName];
    const pickBtn = document.getElementById(cfg.pickBtnId);
    const clearBtn = document.getElementById(cfg.clearBtnId);
    if (pickBtn) pickBtn.addEventListener('click', () => openPicker(fieldName));
    if (clearBtn) clearBtn.addEventListener('click', () => clearField(fieldName));
  });

  document.addEventListener('click', (event) => {
    const button = event.target.closest('[data-ledger-remove]');
    if (!button) return;
    const fieldName = String(button.getAttribute('data-ledger-remove') || '').trim();
    const id = String(button.getAttribute('data-ledger-remove-id') || '').trim();
    if (!fieldName || !id) return;
    removeFieldItem(fieldName, id);
  });
});
</script>

<%- include('../../partials/pagination', {
  pagination: pagination,
  filters: filters,
  baseUrlPath: newUrl
}) %>

<%- include('../../partials/tablePages-end') %>
<%- include('../../partials/modal_GenericPicker') %>
