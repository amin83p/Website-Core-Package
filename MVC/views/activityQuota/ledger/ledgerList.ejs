<%
  const ui = accessUi || {};
  const canDelete = ui.canDelete === true;
  const stateFilters = (filterState && typeof filterState === 'object')
    ? filterState
    : ((filters && typeof filters === 'object') ? filters : {});
  const stateStats = (stats && typeof stats === 'object') ? stats : {};
  const DEFAULT_LEDGER_MAX_ROWS = 5000;

  function formatDateTime(value) {
    const token = String(value || '').trim();
    if (!token) return '-';
    if (typeof formatOrgDateTime === 'function') return formatOrgDateTime(token);
    const date = new Date(token);
    if (Number.isNaN(date.getTime())) return token;
    return date.toLocaleString();
  }

  function formatMetric(value) {
    const num = Number(value || 0);
    if (!Number.isFinite(num)) return '0';
    return num.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 6 });
  }

  function toCsv(input) {
    if (Array.isArray(input)) return input.map((item) => String(item || '').trim()).filter(Boolean).join(',');
    return String(input || '').trim();
  }

  function toList(input) {
    if (Array.isArray(input)) return input.map((item) => String(item || '').trim()).filter(Boolean);
    const token = String(input || '').trim();
    if (!token) return [];
    return token.split(',').map((item) => String(item || '').trim()).filter(Boolean);
  }

  const hasCustomMaxRows = (() => {
    const raw = String(stateFilters.maxRows ?? '').trim();
    if (!raw) return false;
    const parsed = Number.parseInt(raw, 10);
    return Number.isFinite(parsed) && parsed > 0 && parsed !== DEFAULT_LEDGER_MAX_ROWS;
  })();

  const hasLedgerFiltersApplied = Boolean(
    String(stateFilters.fromDate || '').trim()
    || String(stateFilters.toDate || '').trim()
    || String(stateFilters.entryType || '').trim()
    || toList(stateFilters.userIds || stateFilters.userId).length
    || toList(stateFilters.sectionIds || stateFilters.section).length
    || toList(stateFilters.operationIds || stateFilters.operation).length
    || toList(stateFilters.creatorUserIds || stateFilters.creatorUserId).length
    || toList(stateFilters.sourceEventTypes || stateFilters.sourceEventType).length
    || toList(stateFilters.sourceEventIds || stateFilters.sourceEventId).length
    || hasCustomMaxRows
  );
%>

<%- include('../../partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print: true,
  manageBtns: Array.isArray(manageBtns) ? manageBtns : []
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
    <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter Ledger</div>
    <button
      id="aqLedgerFilterToggleBtn"
      type="button"
      class="btn btn-outline-secondary btn-sm px-2"
      data-bs-toggle="collapse"
      data-bs-target="#aqLedgerFilterCollapse"
      aria-expanded="<%= hasLedgerFiltersApplied ? 'true' : 'false' %>"
      aria-controls="aqLedgerFilterCollapse"
      aria-label="<%= hasLedgerFiltersApplied ? 'Close filters' : 'Open filters' %>">
      <i id="aqLedgerFilterToggleIcon" class="bi <%= hasLedgerFiltersApplied ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
    </button>
  </div>
  <div class="collapse<%= hasLedgerFiltersApplied ? ' show' : '' %>" id="aqLedgerFilterCollapse">
    <form method="GET" action="/activity-quota/ledger" class="card-body p-3">
    <div class="row g-3 align-items-end">
      <div class="col-md-6 col-xl-3">
        <label class="form-label">From Date</label>
        <input type="date" name="fromDate" class="form-control size-md" value="<%= stateFilters.fromDate || '' %>">
      </div>
      <div class="col-md-6 col-xl-3">
        <label class="form-label">To Date</label>
        <input type="date" name="toDate" class="form-control size-md" value="<%= stateFilters.toDate || '' %>">
      </div>
      <div class="col-md-6 col-xl-3">
        <label class="form-label">Entry Type</label>
        <select name="entryType" class="form-select size-md">
          <option value="" <%= !stateFilters.entryType ? 'selected' : '' %>>All</option>
          <option value="credit" <%= stateFilters.entryType === 'credit' ? 'selected' : '' %>>Credit</option>
          <option value="consumption" <%= stateFilters.entryType === 'consumption' ? 'selected' : '' %>>Consumption</option>
          <option value="adjustment" <%= stateFilters.entryType === 'adjustment' ? 'selected' : '' %>>Adjustment</option>
        </select>
      </div>
      <div class="col-md-6 col-xl-3">
        <label class="form-label">Max Rows</label>
        <input type="number" name="maxRows" class="form-control size-md" value="<%= Number(stateFilters.maxRows || 5000) %>" min="100" max="50000" step="100">
      </div>
    </div>

    <div class="row g-3 align-items-start mt-1">
      <div class="col-12 col-xl-4">
        <label class="form-label">Target Users</label>
        <div class="input-group">
          <input type="text" id="aqLedgerUserSummary" class="form-control size-md bg-light" value="" readonly placeholder="No users selected">
          <button type="button" class="btn btn-outline-primary" id="aqLedgerPickUserBtn"><i class="bi bi-search me-1"></i>Pick</button>
          <button type="button" class="btn btn-outline-secondary" id="aqLedgerClearUserBtn">Clear</button>
        </div>
        <input type="hidden" name="userId" id="aqLedgerUserInput" value="<%= toCsv(stateFilters.userIds || stateFilters.userId) %>">
        <div id="aqLedgerUserList" class="border rounded bg-light-subtle mt-2 p-2"></div>
      </div>
      <div class="col-12 col-xl-4">
        <label class="form-label">Sections</label>
        <div class="input-group">
          <input type="text" id="aqLedgerSectionSummary" class="form-control size-md bg-light" value="" readonly placeholder="No sections selected">
          <button type="button" class="btn btn-outline-primary" id="aqLedgerPickSectionBtn"><i class="bi bi-search me-1"></i>Pick</button>
          <button type="button" class="btn btn-outline-secondary" id="aqLedgerClearSectionBtn">Clear</button>
        </div>
        <input type="hidden" name="section" id="aqLedgerSectionInput" value="<%= toCsv(stateFilters.sectionIds || stateFilters.section) %>">
        <div id="aqLedgerSectionList" class="border rounded bg-light-subtle mt-2 p-2"></div>
      </div>
      <div class="col-12 col-xl-4">
        <label class="form-label">Operations</label>
        <div class="input-group">
          <input type="text" id="aqLedgerOperationSummary" class="form-control size-md bg-light" value="" readonly placeholder="No operations selected">
          <button type="button" class="btn btn-outline-primary" id="aqLedgerPickOperationBtn"><i class="bi bi-search me-1"></i>Pick</button>
          <button type="button" class="btn btn-outline-secondary" id="aqLedgerClearOperationBtn">Clear</button>
        </div>
        <input type="hidden" name="operation" id="aqLedgerOperationInput" value="<%= toCsv(stateFilters.operationIds || stateFilters.operation) %>">
        <div id="aqLedgerOperationList" class="border rounded bg-light-subtle mt-2 p-2"></div>
      </div>
    </div>

    <div class="row g-3 align-items-start mt-1">
      <div class="col-12 col-xl-4">
        <label class="form-label">Creator Users</label>
        <div class="input-group">
          <input type="text" id="aqLedgerCreatorSummary" class="form-control size-md bg-light" value="" readonly placeholder="No creators selected">
          <button type="button" class="btn btn-outline-primary" id="aqLedgerPickCreatorBtn"><i class="bi bi-search me-1"></i>Pick</button>
          <button type="button" class="btn btn-outline-secondary" id="aqLedgerClearCreatorBtn">Clear</button>
        </div>
        <input type="hidden" name="creatorUserId" id="aqLedgerCreatorInput" value="<%= toCsv(stateFilters.creatorUserIds || stateFilters.creatorUserId) %>">
        <div id="aqLedgerCreatorList" class="border rounded bg-light-subtle mt-2 p-2"></div>
      </div>
      <div class="col-12 col-xl-4">
        <label class="form-label">Source Event Types</label>
        <input
          type="text"
          name="sourceEventType"
          class="form-control size-md"
          value="<%= toCsv(stateFilters.sourceEventTypes || stateFilters.sourceEventType) %>"
          placeholder="e.g. practice_attempt, package_credit">
        <div class="form-text">Use comma-separated values for multiple types.</div>
      </div>
      <div class="col-12 col-xl-4">
        <label class="form-label">Source Event IDs</label>
        <input
          type="text"
          name="sourceEventId"
          class="form-control size-md"
          value="<%= toCsv(stateFilters.sourceEventIds || stateFilters.sourceEventId) %>"
          placeholder="e.g. ATTEMPT-2026-001, AQL-EVT-12345">
        <div class="form-text">Use comma-separated values for multiple IDs.</div>
      </div>
    </div>

    <div class="row g-3 align-items-start mt-1">
      <div class="col-12 d-flex justify-content-xl-end gap-2 pt-xl-2">
        <a href="/activity-quota/ledger" class="btn btn-outline-secondary btn-md">Reset</a>
        <button type="submit" class="btn btn-filled btn-primary btn-md">
          <i class="bi bi-funnel me-1"></i> Apply
        </button>
      </div>
    </div>
    </form>
  </div>
</div>

<% if (stateStats.truncated) { %>
  <div class="alert alert-warning border shadow-sm mb-3">
    Results are capped at <b><%= Number(stateStats.maxRows || 0).toLocaleString() %></b> rows. Apply narrower filters for full precision.
  </div>
<% } %>

