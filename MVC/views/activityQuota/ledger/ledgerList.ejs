        <tr id="aqLedgerEmptyRow">
          <td colspan="<%= canDelete ? 9 : 8 %>" class="text-center py-4 text-muted">No ledger entries found for these filters.</td>
        </tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <% const display = item.display || {}; %>
        <% const source = item.source || {}; %>
        <tr
          data-ledger-row="1"
          data-ledger-id="<%= item.id || '' %>"
          data-ledger-datetime="<%= item.dateTime || '' %>"
          data-ledger-entry-type="<%= item.entryType || '' %>"
          data-ledger-org-id="<%= item.orgId || '' %>"
          data-ledger-user-id="<%= item.userId || '' %>"
          data-ledger-user-name="<%= display.userName || '' %>"
          data-ledger-section-id="<%= item.section || '' %>"
          data-ledger-section-name="<%= display.sectionName || '' %>"
          data-ledger-operation-id="<%= item.operation || '' %>"
          data-ledger-operation-name="<%= display.operationName || '' %>"
          data-ledger-call="<%= item.call || 0 %>"
          data-ledger-amount="<%= item.amount || 0 %>"
          data-ledger-token="<%= item.token || 0 %>"
          data-ledger-volume="<%= item.volume || 0 %>"
          data-ledger-source-module="<%= source.module || '' %>"
          data-ledger-source-event-type="<%= source.eventType || '' %>"
          data-ledger-source-event-id="<%= source.eventId || '' %>"
          data-ledger-source-idempotency-key="<%= source.idempotencyKey || '' %>"
          data-ledger-creator-name="<%= display.creatorName || '' %>"
          data-ledger-creator-id="<%= (item.creator && item.creator.userId) ? item.creator.userId : ((item.creator && item.creator.type === 'system') ? 'System' : '-') %>"
          style="cursor: pointer;">
          <% if (canDelete) { %>
            <td class="text-center ps-4">
              <input type="checkbox" class="form-check-input aq-ledger-row-select session-checkbox" value="<%= item.id %>" aria-label="Select ledger entry <%= item.id || '-' %>">
            </td>
          <% } %>
          <td class="ps-4">
            <div class="fw-bold text-dark"><%= formatDateTime(item.dateTime) %></div>
            <div class="x-small text-muted font-monospace"><%= item.id || '-' %></div>
          </td>
          <td>
            <span class="badge <%= item.entryType === 'credit' ? 'text-bg-success' : (item.entryType === 'consumption' ? 'text-bg-warning' : 'text-bg-info') %>">
              <%= item.entryType || '-' %>
            </span>
          </td>
          <td>
            <div class="fw-bold text-dark"><%= display.userName || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.userId || '-' %></div>
          </td>
          <td>
            <div class="small text-dark font-monospace"><%= item.orgId || '-' %></div>
          </td>
          <td>
            <div class="small fw-bold text-dark"><%= display.sectionName || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.section || '-' %></div>
            <div class="small fw-bold text-dark mt-1"><%= display.operationName || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.operation || '-' %></div>
          </td>
          <td>
            <div class="small text-dark">Call: <span class="fw-bold"><%= formatMetric(item.call) %></span></div>
            <div class="x-small text-muted">Amount: <%= formatMetric(item.amount) %></div>
            <div class="x-small text-muted">Token: <%= formatMetric(item.token) %></div>
            <div class="x-small text-muted">Volume: <%= formatMetric(item.volume) %></div>
          </td>
          <td>
            <div class="small fw-bold text-dark"><%= source.eventType || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= source.eventId || '-' %></div>
            <div class="x-small text-muted"><%= source.module || '-' %></div>
          </td>
          <td>
            <div class="small fw-bold text-dark"><%= display.creatorName || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.creator && item.creator.userId ? item.creator.userId : (item.creator && item.creator.type === 'system' ? 'System' : '-') %></div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

