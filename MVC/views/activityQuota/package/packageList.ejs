<%
  const ui = accessUi || {};
  const canUpdate = ui.canUpdate === true;
  const canDelete = ui.canDelete === true;
  const hasRowActions = canUpdate || canDelete;
%>
<%- include('../../partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print: true,
  manageBtns: Array.isArray(manageBtns) ? manageBtns : []
}) %>

<%- include('../../partials/tablePages-search', {
  placeholder: 'Search packages by id, name, category, section, operation, access profile, or creator...',
  fields: searchableFields || []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Package</th>
        <th>Organization</th>
        <th>Price / Visibility</th>
        <th>Validity</th>
        <th>Profiles / Banned Users</th>
        <th>Sections / Operations</th>
        <th>Creator</th>
        <th class="text-end pe-4">Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || data.length === 0) { %>
        <tr>
          <td colspan="8" class="text-center py-4 text-muted">No packages found.</td>
        </tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <% const summary = item.summary || {}; %>
        <% const creator = item.creator || {}; %>
        <% const validity = item.validity || {}; %>
        <% const price = item.price || {}; %>
        <% const accessProfiles = Array.isArray(item.accessProfiles) ? item.accessProfiles : []; %>
        <% const eligibleRoles = Array.isArray(item.eligibleRoles) ? item.eligibleRoles : []; %>
        <% const bannedUsers = Array.isArray(item.bannedUsers) ? item.bannedUsers : []; %>
        <% const sections = Array.isArray(item.sections) ? item.sections : []; %>
        <% const operationLabels = []; %>
        <% sections.slice(0, 2).forEach((section) => { %>
          <% const ops = Array.isArray(section.operations) ? section.operations : []; %>
          <% ops.slice(0, 2).forEach((op) => { %>
            <% const opDisplay = op.label || op.name || op.id; %>
            <% operationLabels.push(opDisplay ? (opDisplay + ' (' + op.id + ')') : op.id); %>
          <% }); %>
        <% }); %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-dark"><%= item.name || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.id || '-' %></div>
            <div class="x-small mt-1">
              <span class="badge <%= item.active !== false ? 'text-bg-success' : 'text-bg-secondary' %>"><%= item.active !== false ? 'Active' : 'Inactive' %></span>
              <span class="badge text-bg-light border ms-1"><%= item.category ? ('Category: ' + item.category) : 'Category: -' %></span>
            </div>
          </td>
          <td>
            <div class="small font-monospace text-dark">
              <%= item.orgName ? `${item.orgName} (#${item.orgId || '-'})` : (item.orgId || '-') %>
            </div>
          </td>
          <td>
            <div class="small text-dark"><span class="fw-bold"><%= Number(price.amount || 0) %></span> <%= price.currencyCode || 'USD' %></div>
            <div class="x-small text-muted text-capitalize">Visibility: <%= item.visibility || 'internal' %></div>
          </td>
          <td>
            <% if (validity.mode === 'date_range') { %>
              <div class="small text-dark fw-bold">Date Range</div>
              <div class="x-small text-muted"><%= validity.startDate || '-' %> to <%= validity.endDate || '-' %></div>
            <% } else { %>
              <div class="small text-dark fw-bold">Duration</div>
              <div class="x-small text-muted"><%= Number(validity.years || 0) %>y, <%= Number(validity.months || 0) %>m, <%= Number(validity.days || 0) %>d</div>
            <% } %>
          </td>
          <td>
            <div class="small text-dark"><%= Number(summary.accessProfileCount || accessProfiles.length || 0) %> profile(s)</div>
            <div class="x-small text-muted">
              <% if (accessProfiles.length === 0) { %>
                -
              <% } else { %>
                <%= accessProfiles.slice(0, 2).map((row) => (row.name ? (row.name + ' (' + row.id + ')') : row.id)).join(', ') %><%= accessProfiles.length > 2 ? ', ...' : '' %>
              <% } %>
            </div>
            <div class="small text-dark mt-1"><%= Number(summary.bannedUserCount || bannedUsers.length || 0) %> banned user(s)</div>
            <div class="x-small text-muted">
              <% if (bannedUsers.length === 0) { %>
                -
              <% } else { %>
                <%= bannedUsers.slice(0, 2).map((row) => (row.name ? (row.name + ' (' + row.id + ')') : row.id)).join(', ') %><%= bannedUsers.length > 2 ? ', ...' : '' %>
              <% } %>
            </div>
            <div class="small text-dark mt-1"><%= Number(summary.eligibleRoleCount || eligibleRoles.length || 0) %> eligible role(s)</div>
            <div class="x-small text-muted">
              <% if (eligibleRoles.length === 0) { %>
                Unrestricted
              <% } else { %>
                <%= eligibleRoles.slice(0, 4).join(', ') %><%= eligibleRoles.length > 4 ? ', ...' : '' %>
              <% } %>
            </div>
          </td>
          <td>
            <div class="small text-dark"><%= Number(summary.sectionCount || sections.length || 0) %> section(s)</div>
            <div class="x-small text-muted">
              <% if (sections.length === 0) { %>
                -
              <% } else { %>
                <%= sections.slice(0, 2).map((row) => (row.name ? (row.name + ' (' + row.id + ')') : row.id)).join(', ') %><%= sections.length > 2 ? ', ...' : '' %>
              <% } %>
            </div>
            <div class="x-small text-muted mt-1">
              <%= Number(summary.operationCount || 0) %> operation(s)
              <% if (operationLabels.length) { %>
                | <%= operationLabels.join(', ') %><%= Number(summary.operationCount || 0) > operationLabels.length ? ', ...' : '' %>
              <% } %>
            </div>
          </td>
          <td>
            <div class="small fw-bold text-dark"><%= creator.displayName || (creator.type === 'system' ? 'System' : '-') %></div>
            <div class="x-small text-muted font-monospace"><%= creator.userId || 'System' %></div>
          </td>
          <td class="table-actions text-end pe-4">
            <% if (hasRowActions) { %>
              <div class="row-actions-wrap">
                <button
                  type="button"
                  class="btn btn-secondary btn-sm btn-row-actions-toggle"
                  data-row-actions-id="<%= item.id %>"
                  title="Row actions">
                  <i class="bi bi-three-dots-vertical"></i>
                </button>
                <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                  <% if (canUpdate) { %>
                    <a href="/activity-quota/packages/edit/<%= item.id %>" class="btn btn-outline-primary btn-sm">
                      <i class="bi bi-pencil-square me-2"></i>Edit
                    </a>
                  <% } %>
                  <% if (canDelete) { %>
                    <button class="btn btn-outline-danger btn-sm delete-btn" data-id="<%= item.id %>" data-delete-url="/activity-quota/packages/delete/<%= item.id %>">
                      <i class="bi bi-trash me-2"></i>Delete
                    </button>
                  <% } %>
                </div>
              </div>
            <% } else { %>
              <span class="text-muted">-</span>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../../partials/pagination', {
  pagination: pagination,
  filters: filters,
  baseUrlPath: newUrl
}) %>

<%- include('../../partials/tablePages-end') %>
