    if (!window.GenericPicker || !window.GenericPickerPresets) return;
    window.GenericPicker.open(window.GenericPickerPresets.normalizeConfig({
      title: 'Select Eligible Roles',
      icon: 'bi-person-badge',
      apiEndpoint: '/activity-quota/packages/picker/roles',
      searchFields: 'id,name',
      placeholder: 'Search role tokens...',
      multiselect: true,
      onSelect: (items) => {
        const list = Array.isArray(items) ? items : [items];
        list.forEach((item) => upsertEligibleRole(item));
        renderEligibleRoles();
      }
    }));
  }

  function openBannedUsersPicker() {
    if (!window.GenericPicker || !window.GenericPickerPresets) return;
