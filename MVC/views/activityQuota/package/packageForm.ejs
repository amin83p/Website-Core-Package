    const context = (typeof contexts.activeOrganizationScope === 'function')
      ? contexts.activeOrganizationScope({ label: 'Active Organization Scope' })
      : null;
    window.GenericPicker.open(window.GenericPickerPresets.user({
      title: 'Select Banned Users',
      icon: 'bi-people',
      apiEndpoint: '/activity-quota/packages/picker/users',
      searchFields: 'id,username,email,name',
      placeholder: 'Search users by id, username, or email...',
      multiselect: true,
      context: context,
      onSelect: (items) => {
        const list = Array.isArray(items) ? items : [items];
        list.forEach((item) => upsertBannedUser(item));
        renderBannedUsers();
      }
    }));
  }

  function openSectionsPicker() {
    if (!window.GenericPicker || !window.GenericPickerPresets) return;
    const contexts = window.GenericPickerContexts || {};
    const context = (typeof contexts.activeOrganizationScope === 'function')
      ? contexts.activeOrganizationScope({ label: 'Visible Section Scope' })
      : null;
    window.GenericPicker.open(window.GenericPickerPresets.section({
      title: 'Select Sections',
      icon: 'bi-collection',
      apiEndpoint: '/activity-quota/packages/picker/sections',
      searchFields: 'id,name,description,category',
      placeholder: 'Search sections...',
      multiselect: true,
      context: context,
      onSelect: (items) => {
        const list = Array.isArray(items) ? items : [items];
        let firstNewSectionId = '';
        list.forEach((item) => {
          const created = upsertSection(item, { focus: false });
          if (created && !firstNewSectionId) {
            firstNewSectionId = String((item && (item.id || item.sectionId)) || '').trim();
          }
        });
        if (firstNewSectionId) {
          state.expandedSectionId = firstNewSectionId;
        }
        renderSections();
      }
    }));
  }

  function openOperationsPicker(sectionId) {
    if (!window.GenericPicker || !window.GenericPickerPresets) return;
    const targetSection = state.sections.find((row) => row.id === String(sectionId || '').trim());
    if (!targetSection) return;

    window.GenericPicker.open(window.GenericPickerPresets.operation({
      title: 'Select Operations (' + (targetSection.name || targetSection.id) + ')',
      icon: 'bi-gear',
      apiEndpoint: '/activity-quota/packages/picker/operations?sectionId=' + encodeURIComponent(targetSection.id),
      searchFields: 'id,name,description',
      placeholder: 'Search operations for this section...',
      multiselect: true,
      context: {
        label: 'Selected Section',
        value: String(targetSection.name || targetSection.id),
        icon: 'bi bi-grid'
      },
      onSelect: (items) => {
        const list = Array.isArray(items) ? items : [items];
        list.forEach((item) => upsertOperation(targetSection.id, item));
        state.expandedSectionId = targetSection.id;
        renderSections();
      }
    }));
  }

  async function openCopyPackagePicker() {
    if (!window.GenericPicker || !window.GenericPickerPresets) return;
    window.GenericPicker.open(window.GenericPickerPresets.section({
      title: 'Copy from Saved Package',
      icon: 'bi-box-seam',
      apiEndpoint: '/activity-quota/packages/picker/packages',
      searchFields: 'id,name',
      placeholder: 'Search saved packages...',
      multiselect: false,
      onSelect: async (item) => {
        const id = String((item && item.id) || '').trim();
        if (!id) return;
        try {
          const response = await fetch('/activity-quota/packages/api/template/' + encodeURIComponent(id), {
            headers: {
              'X-AJAX-Request': 'true',
              'Accept': 'application/json'
            },
            credentials: 'include'
          });
          const data = await response.json();
          if (!response.ok || !data || data.status !== 'success' || !data.results) {
            throw new Error((data && data.message) || 'Failed to load package template.');
          }
          applyTemplate(data.results, { appendCopySuffix: true });
          await showNotice('Template Loaded', 'Saved package data was loaded as draft.', 'success');
        } catch (error) {
          await showNotice('Copy Failed', error.message || 'Unable to load package template.', 'error');
        }
      }
    }));
  }

  function applyTemplate(template, options) {
    const source = (template && typeof template === 'object') ? template : {};
    const appendCopySuffix = !!(options && options.appendCopySuffix);

    const sourceName = String(source.name || '').trim();
    if (sourceName) {
      nameInput.value = appendCopySuffix ? (sourceName + ' (Copy)') : sourceName;
    }
    setCategoryValue(source.category || defaults.category || '');
    descriptionInput.value = String(source.description || '').trim();

    const price = (source.price && typeof source.price === 'object') ? source.price : {};
    priceAmountInput.value = Number(price.amount || 0);
    currencyInput.value = String(price.currencyCode || defaults.currencyCode || 'CAD').toUpperCase();

    visibilitySelect.value = normalizeVisibility(source.visibility || defaults.visibility || 'internal');
    activeInput.checked = source.active !== false;

    const validity = (source.validity && typeof source.validity === 'object') ? source.validity : {};
    validityModeSelect.value = normalizeValidityMode(validity.mode || defaults.validityMode || 'duration');
    startDateInput.value = String(validity.startDate || '').trim();
    endDateInput.value = String(validity.endDate || '').trim();
    yearsInput.value = integerValue(validity.years || 0);
    monthsInput.value = integerValue(validity.months || 0);
    daysInput.value = integerValue(validity.days || 0);
    toggleValidityInputs();

    state.accessProfiles = [];
    (Array.isArray(source.accessProfiles) ? source.accessProfiles : []).forEach((row) => upsertAccessProfile(row));
    renderAccessProfiles();

    state.eligibleRoles = [];
    (Array.isArray(source.eligibleRoles) ? source.eligibleRoles : []).forEach((role) => upsertEligibleRole(role));
    renderEligibleRoles();

    state.bannedUsers = [];
    (Array.isArray(source.bannedUsers) ? source.bannedUsers : []).forEach((row) => upsertBannedUser(row));
    renderBannedUsers();

    state.sections = [];
    let firstSectionId = '';
    (Array.isArray(source.sections) ? source.sections : []).forEach((section) => {
      const sectionId = String((section && section.id) || '').trim();
      if (!sectionId) return;
      const created = upsertSection(section, { focus: false });
      if ((created || !firstSectionId) && !firstSectionId) firstSectionId = sectionId;
      const targetSection = state.sections.find((row) => row.id === sectionId);
      if (!targetSection) return;
      targetSection.operations = [];
      (Array.isArray(section.operations) ? section.operations : []).forEach((operation) => {
        const operationId = String((operation && operation.id) || '').trim();
        if (!operationId) return;
        targetSection.operations.push({
          id: operationId,
          name: String(operation.name || operationId).trim(),
          label: String(operation.label || '').trim(),
          call: numberValue(operation.call),
          amount: numberValue(operation.amount),
          token: numberValue(operation.token),
          volume: numberValue(operation.volume)
        });
      });
    });
    state.expandedSectionId = firstSectionId || '';
    renderSections();
  }

  function hasPositiveMetric(operation) {
    return ['call', 'amount', 'token', 'volume'].some((field) => Number((operation && operation[field]) || 0) > 0);
  }

  async function validateBeforeSubmit() {
    const name = String(nameInput.value || '').trim();
    if (!name) {
      await showNotice('Validation', 'Package name is required.', 'warning');
      return false;
    }

    const amount = numberValue(priceAmountInput.value);
    if (amount < 0) {
      await showNotice('Validation', 'Price amount must be zero or positive.', 'warning');
      return false;
    }

    const currencyCode = String(currencyInput.value || '').trim().toUpperCase();
    if (!/^[A-Z]{3}$/.test(currencyCode)) {
      await showNotice('Validation', 'Currency must be a 3-letter code (for example CAD).', 'warning');
      return false;
    }
    const category = String((categorySelect && categorySelect.value) || '').trim();
    if (!category) {
      await showNotice('Validation', 'Package category is required.', 'warning');
      return false;
    }

    const mode = normalizeValidityMode(validityModeSelect.value);
    if (mode === 'date_range') {
      const start = String(startDateInput.value || '').trim();
      const end = String(endDateInput.value || '').trim();
      if (!start || !end) {
        await showNotice('Validation', 'Date range mode requires both start and end dates.', 'warning');
        return false;
      }
      if (end < start) {
        await showNotice('Validation', 'End date must be the same day or after the start date.', 'warning');
        return false;
      }
    } else {
      const total = integerValue(yearsInput.value) + integerValue(monthsInput.value) + integerValue(daysInput.value);
      if (total <= 0) {
        await showNotice('Validation', 'Duration mode requires at least one positive value in years, months, or days.', 'warning');
        return false;
      }
    }

    if (!state.sections.length) {
      await showNotice('Validation', 'Select at least one section.', 'warning');
      return false;
    }

    for (const section of state.sections) {
      if (!Array.isArray(section.operations) || section.operations.length === 0) {
        await showNotice('Validation', 'Section "' + (section.name || section.id) + '" must include at least one operation.', 'warning');
        return false;
      }
      for (const operation of section.operations) {
        if (!hasPositiveMetric(operation)) {
          await showNotice('Validation', 'Operation "' + (operation.label || operation.name || operation.id) + '" in section "' + (section.name || section.id) + '" must include at least one positive metric.', 'warning');
          return false;
        }
      }
    }

    return true;
  }

  function buildPayload() {
    const mode = normalizeValidityMode(validityModeSelect.value);
    const validity = mode === 'date_range'
      ? {
        mode: 'date_range',
        startDate: String(startDateInput.value || '').trim(),
        endDate: String(endDateInput.value || '').trim(),
        years: 0,
        months: 0,
        days: 0
      }
      : {
        mode: 'duration',
        startDate: '',
        endDate: '',
        years: integerValue(yearsInput.value),
        months: integerValue(monthsInput.value),
        days: integerValue(daysInput.value)
      };

    return {
      name: String(nameInput.value || '').trim(),
      category: String((categorySelect && categorySelect.value) || '').trim(),
      description: String(descriptionInput.value || '').trim(),
      price: {
        amount: numberValue(priceAmountInput.value),
        currencyCode: String(currencyInput.value || defaults.currencyCode || 'CAD').trim().toUpperCase()
      },
      active: activeInput.checked,
      visibility: normalizeVisibility(visibilitySelect.value),
      validity: validity,
      accessProfiles: state.accessProfiles.map((row) => ({
        id: row.id,
        name: row.name || row.id,
        orgId: row.orgId || ''
      })),
      eligibleRoles: state.eligibleRoles.map((role) => String(role || '').trim().toLowerCase()).filter(Boolean),
      bannedUsers: state.bannedUsers.map((row) => ({
        id: row.id,
        name: row.name || row.id,
        username: row.username || '',
        email: row.email || '',
        orgId: row.orgId || ''
      })),
      sections: state.sections.map((section) => ({
        id: section.id,
        name: section.name || section.id,
        operations: (Array.isArray(section.operations) ? section.operations : []).map((operation) => ({
          id: operation.id,
          name: operation.name || operation.id,
          label: String(operation.label || '').trim(),
          call: numberValue(operation.call),
          amount: numberValue(operation.amount),
          token: numberValue(operation.token),
          volume: numberValue(operation.volume)
        }))
      }))
    };
  }

  accessProfilesContainer.addEventListener('click', (event) => {
    const removeBtn = event.target.closest('[data-aq-remove-access-profile]');
    if (!removeBtn) return;
    removeAccessProfile(removeBtn.getAttribute('data-aq-remove-access-profile'));
  });

  eligibleRolesContainer.addEventListener('click', (event) => {
    const removeBtn = event.target.closest('[data-aq-remove-eligible-role]');
    if (!removeBtn) return;
    removeEligibleRole(removeBtn.getAttribute('data-aq-remove-eligible-role'));
  });

  bannedUsersContainer.addEventListener('click', (event) => {
    const removeBtn = event.target.closest('[data-aq-remove-banned-user]');
    if (!removeBtn) return;
    removeBannedUser(removeBtn.getAttribute('data-aq-remove-banned-user'));
  });

  sectionsContainer.addEventListener('click', (event) => {
    const removeSectionBtn = event.target.closest('[data-aq-remove-section]');
    if (removeSectionBtn) {
      removeSection(removeSectionBtn.getAttribute('data-aq-remove-section'));
      return;
    }

    const addOperationsBtn = event.target.closest('[data-aq-add-operations]');
    if (addOperationsBtn) {
      openOperationsPicker(addOperationsBtn.getAttribute('data-aq-add-operations'));
      return;
    }

    const removeOperationBtn = event.target.closest('[data-aq-remove-operation]');
    if (removeOperationBtn) {
      removeOperation(
        removeOperationBtn.getAttribute('data-aq-remove-operation'),
        removeOperationBtn.getAttribute('data-aq-operation-id')
      );
    }
  });

  sectionsContainer.addEventListener('input', (event) => {
    const labelInput = event.target.closest('[data-aq-label]');
    if (labelInput) {
      setOperationLabel(
        labelInput.getAttribute('data-aq-section-id'),
        labelInput.getAttribute('data-aq-operation-id'),
        labelInput.value
      );
      return;
    }

    const input = event.target.closest('[data-aq-metric]');
    if (!input) return;
    setOperationMetric(
      input.getAttribute('data-aq-section-id'),
      input.getAttribute('data-aq-operation-id'),
      input.getAttribute('data-aq-metric'),
      input.value
    );
  });

  pickAccessProfilesBtn.addEventListener('click', openAccessProfilePicker);
  pickEligibleRolesBtn.addEventListener('click', openEligibleRolesPicker);
  pickBannedUsersBtn.addEventListener('click', openBannedUsersPicker);
  pickSectionsBtn.addEventListener('click', openSectionsPicker);
  copyFromSavedBtn.addEventListener('click', openCopyPackagePicker);

  addManualRoleBtn.addEventListener('click', () => {
    const token = normalizeRoleToken(manualRoleTokenInput.value || '');
    if (!token) return;
    upsertEligibleRole(token);
    manualRoleTokenInput.value = '';
    renderEligibleRoles();
  });

  manualRoleTokenInput.addEventListener('keydown', (event) => {
    if (event.key !== 'Enter') return;
    event.preventDefault();
    addManualRoleBtn.click();
  });

  validityModeSelect.addEventListener('change', toggleValidityInputs);

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (isSubmitting) return;
    const valid = await validateBeforeSubmit();
    if (!valid) {
      restoreActionButtons();
      return;
    }
    isSubmitting = true;
    setButtonBusy(saveBtn, 'Saving...');
    if (cancelBtn) cancelBtn.disabled = true;
    packagePlanInput.value = JSON.stringify(buildPayload());
    try {
      const response = await fetch(form.action, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'X-AJAX-Request': 'true',
          'Accept': 'application/json'
        },
        credentials: 'include',
        body: new URLSearchParams(new FormData(form)).toString()
      });

      let result = null;
      try {
        result = await response.json();
      } catch (_) {
        result = null;
      }

      if (!response.ok || !result || result.status !== 'success') {
        throw new Error((result && result.message) || ('Request failed with status ' + response.status + '.'));
      }

      await showNotice('Success', result.message || 'Package saved successfully.', 'success');
      window.location.href = '/activity-quota/packages';
    } catch (error) {
      await showNotice('Save Failed', error.message || 'Unexpected save error.', 'error');
      restoreActionButtons();
    }
  });

  if (cancelBtn) {
    cacheButtonHtml(cancelBtn);
    cancelBtn.addEventListener('click', (event) => {
      if (isSubmitting) {
        event.preventDefault();
        return;
      }
      setButtonBusy(cancelBtn, 'Cancelling...');
      if (saveBtn) saveBtn.disabled = true;
    });
  }

  cacheButtonHtml(saveBtn);

  function initializeControlDefaults() {
    setCategoryValue(initial.category || defaults.category || '');
    visibilitySelect.value = normalizeVisibility(initial.visibility || defaults.visibility || 'internal');
    validityModeSelect.value = normalizeValidityMode((initial.validity && initial.validity.mode) || defaults.validityMode || 'duration');
    currencyInput.value = String((initial.price && initial.price.currencyCode) || defaults.currencyCode || 'CAD').toUpperCase();
  }

  currencyInput.addEventListener('input', () => {
    currencyInput.value = String(currencyInput.value || '').replace(/[^A-Za-z]/g, '').slice(0, 3).toUpperCase();
  });

  initializeControlDefaults();
  applyTemplate(initial, { appendCopySuffix: false });
  toggleValidityInputs();
});
</script>
