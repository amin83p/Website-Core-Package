<script type="application/json" id="aqCreditCheckState"><%- JSON.stringify(payload || {}).replace(/</g, '\\u003c').replace(/\u2028/g, '\\u2028').replace(/\u2029/g, '\\u2029').replace(/&/g, '\\u0026') %></script>
<script>
document.addEventListener('DOMContentLoaded', () => {
  function initCollapseToggleIcon(options = {}) {
    const collapseEl = document.getElementById(String(options.collapseId || ''));
    const buttonEl = document.getElementById(String(options.buttonId || ''));
    const iconEl = document.getElementById(String(options.iconId || ''));
    if (!collapseEl || !buttonEl || !iconEl) return;

    const openIcon = String(options.openIcon || 'bi-chevron-down');
    const closeIcon = String(options.closeIcon || 'bi-chevron-up');
    const openLabel = String(options.openLabel || 'Open filters');
    const closeLabel = String(options.closeLabel || 'Close filters');

    const setState = (expanded) => {
      iconEl.classList.remove(openIcon, closeIcon);
      iconEl.classList.add(expanded ? closeIcon : openIcon);
      buttonEl.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      buttonEl.setAttribute('aria-label', expanded ? closeLabel : openLabel);
    };

    setState(collapseEl.classList.contains('show'));
    collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
    collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
  }

  initCollapseToggleIcon({
    collapseId: 'aqCreditCheckFilterCollapse',
    buttonId: 'aqCreditCheckFilterToggleBtn',
    iconId: 'aqCreditCheckFilterToggleIcon',
    openIcon: 'bi-chevron-down',
    closeIcon: 'bi-chevron-up',
    openLabel: 'Open filters',
    closeLabel: 'Close filters'
  });

  initCollapseToggleIcon({
    collapseId: 'aqCreditCheckHistoryCollapse',
    buttonId: 'aqCreditCheckHistoryToggleBtn',
    iconId: 'aqCreditCheckHistoryToggleIcon',
    openIcon: 'bi-chevron-down',
    closeIcon: 'bi-chevron-up',
    openLabel: 'Open consumption history',
    closeLabel: 'Close consumption history'
  });

  const stateNode = document.getElementById('aqCreditCheckState');
  if (!stateNode) return;
  let state = {};
  try {
    state = JSON.parse(stateNode.textContent || '{}');
  } catch (_) {
    state = {};
  }
  const visibility = (state && state.visibility && typeof state.visibility === 'object') ? state.visibility : {};
  if (!visibility.canSwitchUser) return;
  if (!window.GenericPicker || !window.GenericPickerPresets) return;

  const input = document.getElementById('aqCreditCheckUserIdInput');
  const summary = document.getElementById('aqCreditCheckUserSummary');
  const pickBtn = document.getElementById('aqCreditCheckPickUserBtn');
  const resetBtn = document.getElementById('aqCreditCheckResetUserBtn');
  const defaultUser = (state && state.targetUser && typeof state.targetUser === 'object') ? state.targetUser : {};

  if (!input || !summary || !pickBtn || !resetBtn) return;

  pickBtn.addEventListener('click', () => {
    window.GenericPicker.open(window.GenericPickerPresets.user({
      title: 'Select Target User',
      icon: 'bi-people',
      apiEndpoint: '/activity-quota/credit-check/picker/users',
      searchFields: 'id,username,email,name',
      placeholder: 'Search users by id, username, or email...',
      multiselect: false,
      onSelect: (item) => {
        if (!item || typeof item !== 'object') return;
        const id = String(item.id || '').trim();
        const name = String(item.name || item.username || item.email || id).trim() || id;
        if (!id) return;
        input.value = id;
        summary.value = name;
      }
    }));
  });

  resetBtn.addEventListener('click', () => {
    input.value = String(defaultUser.id || '').trim();
    summary.value = String(defaultUser.name || '-').trim();
  });
});
</script>

