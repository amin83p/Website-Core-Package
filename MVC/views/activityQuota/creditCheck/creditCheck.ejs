<%
  const payload = (creditCheck && typeof creditCheck === 'object') ? creditCheck : {};
  const visibility = (payload.visibility && typeof payload.visibility === 'object') ? payload.visibility : {};
  const targetUser = (payload.targetUser && typeof payload.targetUser === 'object') ? payload.targetUser : {};
  const filtersState = (payload.filters && typeof payload.filters === 'object') ? payload.filters : {};
  const stats = (payload.stats && typeof payload.stats === 'object') ? payload.stats : {};
  const totals = (payload.totals && typeof payload.totals === 'object') ? payload.totals : {};
  const validity = (payload.validity && typeof payload.validity === 'object') ? payload.validity : {};
  const remainingTotals = (totals.remaining && typeof totals.remaining === 'object') ? totals.remaining : {};
  const consumptionTotals = (totals.consumption && typeof totals.consumption === 'object') ? totals.consumption : {};
  const remainingRows = Array.isArray(payload.remainingRows) ? payload.remainingRows : [];
  const historyRows = Array.isArray(payload.historyRows) ? payload.historyRows : [];
  const consumptionRows = Array.isArray(payload.consumptionRows) ? payload.consumptionRows : historyRows;
  const pager = (payload.pagination && typeof payload.pagination === 'object') ? payload.pagination : null;
  const actions = Array.isArray(pageActions) ? pageActions : [];
  const dashboardAction = actions.find((action) => action.key === 'dashboard') || null;
  const navActions = actions.filter((action) => action.key !== 'dashboard');
  const buildConsumptionCategoryKey = (sectionId = '', operationId = '') => `${String(sectionId || '').trim()}::${String(operationId || '').trim()}`;
  const consumptionCategoryDefs = [];
  const consumptionCategoryKeySet = new Set();
  remainingRows.forEach((row) => {
    const sectionId = String(row?.sectionId || '').trim();
    const operationId = String(row?.operationId || '').trim();
    const label = String(row?.label || '-').trim() || '-';
    const key = buildConsumptionCategoryKey(sectionId, operationId);
    if (!sectionId || !operationId || !key || consumptionCategoryKeySet.has(key)) return;
    consumptionCategoryKeySet.add(key);
    consumptionCategoryDefs.push({
      key,
      sectionId,
      operationId,
      label
    });
  });
  const dailyConsumptionMap = new Map();
  consumptionRows.forEach((row) => {
    const rawDate = String(row?.dateTime || '').trim();
    const dateKey = rawDate ? rawDate.slice(0, 10) : '';
    if (!dateKey) return;
    const categoryKey = buildConsumptionCategoryKey(row?.sectionId, row?.operationId);
    if (!consumptionCategoryKeySet.has(categoryKey)) return;
    const volumeValue = Number(row?.volume || 0);
    const safeVolume = Number.isFinite(volumeValue) ? volumeValue : 0;
    if (!dailyConsumptionMap.has(dateKey)) {
      dailyConsumptionMap.set(dateKey, { dateKey, volume: 0, entryCount: 0, categories: new Map() });
    }
    const bucket = dailyConsumptionMap.get(dateKey);
    bucket.volume += safeVolume;
    bucket.entryCount += 1;
    bucket.categories.set(categoryKey, (bucket.categories.get(categoryKey) || 0) + safeVolume);
  });
  const dailyConsumptionRows = Array.from(dailyConsumptionMap.values())
    .sort((a, b) => String(a.dateKey || '').localeCompare(String(b.dateKey || '')));
  const maxDailyConsumptionVolume = dailyConsumptionRows.reduce((max, row) => {
    const values = consumptionCategoryDefs.map((category) => Number(row?.categories?.get?.(category.key) || 0));
    const dayMax = values.reduce((innerMax, item) => {
      const safeItem = Number.isFinite(item) ? item : 0;
      return safeItem > innerMax ? safeItem : innerMax;
    }, 0);
    const value = Number(dayMax || 0);
    const safe = Number.isFinite(value) ? value : 0;
    return safe > max ? safe : max;
  }, 0);
  const canSwitchUser = visibility.canSwitchUser === true;
  const DEFAULT_CREDIT_CHECK_LIMIT = 20;

  function formatMetric(value) {
    const num = Number(value || 0);
    if (!Number.isFinite(num)) return '0';
    return num.toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 6 });
  }

  function getMetricBreakdown(row, field) {
    const totals = (row && row.currentLotTotals && typeof row.currentLotTotals === 'object') ? row.currentLotTotals : {};
    const credit = (totals.credit && typeof totals.credit === 'object') ? totals.credit : {};
    const consumption = (totals.consumption && typeof totals.consumption === 'object') ? totals.consumption : {};
    const out = {
      credit: Number(credit[field] || 0),
      consumption: Number(consumption[field] || 0)
    };
    out.hasAny = Boolean(out.credit || out.consumption);
    return out;
  }

  function formatDateTime(value) {
    const token = String(value || '').trim();
    if (!token) return '-';
    const date = new Date(token);
    if (Number.isNaN(date.getTime())) return token;
    return date.toLocaleString();
  }

  function formatDateOnly(value) {
    const token = String(value || '').trim();
    if (!token) return '-';
    const date = new Date(token + 'T00:00:00Z');
    if (Number.isNaN(date.getTime())) return token;
    return date.toLocaleDateString();
  }

  function validityBadgeClass(value) {
    const token = String(value || '').trim().toLowerCase();
    if (token === 'active') return 'text-bg-success';
    if (token === 'upcoming') return 'text-bg-warning';
    if (token === 'expired') return 'text-bg-danger';
    return 'text-bg-secondary';
  }

  const hasCustomCreditCheckLimit = (() => {
    const raw = String(filtersState.limit ?? '').trim();
    if (!raw) return false;
    const parsed = Number.parseInt(raw, 10);
    return Number.isFinite(parsed) && parsed > 0 && parsed !== DEFAULT_CREDIT_CHECK_LIMIT;
  })();

  const hasCreditCheckFiltersApplied = Boolean(
    String(filtersState.fromDate || '').trim()
    || String(filtersState.toDate || '').trim()
    || (canSwitchUser && String(filtersState.userId || '').trim())
    || hasCustomCreditCheckLimit
  );
%>

<div class="sections-page">
  <div class="mb-4">
    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
      <h1 class="page-heading size-md m-0">Activity Quota Credit Check</h1>
      <% if (dashboardAction) { %>
        <a href="<%= dashboardAction.href %>" class="<%= String(dashboardAction.className || 'btn btn-filled btn-secondary btn-md').replace(/\bmb-2\b/g, '') %>">
          <i class="bi <%= dashboardAction.icon || 'bi-speedometer2' %> me-1"></i> <%= dashboardAction.label %>
        </a>
      <% } %>
    </div>
    <div class="d-flex align-items-center justify-content-end gap-2 flex-wrap">
      <% navActions.forEach((action) => { %>
        <a href="<%= action.href %>" class="btn btn-outline-primary btn-md">
          <i class="bi <%= action.icon || 'bi-arrow-right' %> me-1"></i> <%= action.label %>
        </a>
      <% }) %>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
      <div class="fw-bold text-dark d-flex align-items-center gap-2 flex-wrap">
        <span><i class="bi bi-funnel me-2"></i>Filter Credit Check</span>
        <% if (hasCreditCheckFiltersApplied) { %>
          <span class="badge text-bg-info">Filters applied</span>
        <% } %>
      </div>
      <button
        id="aqCreditCheckFilterToggleBtn"
        type="button"
        class="btn btn-outline-secondary btn-sm px-2"
        data-bs-toggle="collapse"
        data-bs-target="#aqCreditCheckFilterCollapse"
        aria-expanded="false"
        aria-controls="aqCreditCheckFilterCollapse"
        aria-label="Open filters">
        <i id="aqCreditCheckFilterToggleIcon" class="bi bi-chevron-down"></i>
      </button>
    </div>
    <div class="collapse" id="aqCreditCheckFilterCollapse">
      <form method="GET" action="/activity-quota/credit-check" class="card-body p-3">
        <div class="row g-3 align-items-end">
          <% if (canSwitchUser) { %>
            <div class="col-lg-6">
              <label class="form-label">Target User</label>
              <div class="input-group">
                <input type="text" id="aqCreditCheckUserSummary" class="form-control size-md bg-light" value="<%= targetUser.name || '-' %>" readonly>
                <button type="button" class="btn btn-outline-primary" id="aqCreditCheckPickUserBtn">
                  <i class="bi bi-search me-1"></i>Pick
                </button>
                <button type="button" class="btn btn-outline-secondary" id="aqCreditCheckResetUserBtn">Me</button>
              </div>
              <input type="hidden" name="userId" id="aqCreditCheckUserIdInput" value="<%= targetUser.id || '' %>">
            </div>
          <% } %>

          <div class="<%= canSwitchUser ? 'col-md-4 col-lg-2' : 'col-md-4' %>">
            <label class="form-label">From Date</label>
            <input type="date" name="fromDate" class="form-control size-md" value="<%= filtersState.fromDate || '' %>">
          </div>
          <div class="<%= canSwitchUser ? 'col-md-4 col-lg-2' : 'col-md-4' %>">
            <label class="form-label">To Date</label>
            <input type="date" name="toDate" class="form-control size-md" value="<%= filtersState.toDate || '' %>">
          </div>
          <div class="<%= canSwitchUser ? 'col-md-4 col-lg-2' : 'col-md-4' %>">
            <label class="form-label">Page Size</label>
            <select name="limit" class="form-select size-md">
              <% [10, 20, 50, 100, 200].forEach((value) => { %>
                <option value="<%= value %>" <%= Number(filtersState.limit || 20) === value ? 'selected' : '' %>><%= value %></option>
              <% }) %>
            </select>
          </div>
        </div>

        <div class="row g-3 align-items-end mt-1">
          <div class="col-12 d-flex justify-content-end gap-2">
            <a href="/activity-quota/credit-check" class="btn btn-outline-secondary btn-md">Reset</a>
            <button type="submit" class="btn btn-filled btn-primary btn-md">
              <i class="bi bi-funnel me-1"></i> Apply
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <section class="aq-credit-snapshot mb-3" aria-label="Credit snapshot">
    <div class="aq-credit-snapshot-main">
      <div class="aq-credit-snapshot-kicker"><i class="bi bi-person-badge me-1"></i>Target Account</div>
      <div class="aq-credit-snapshot-name"><%= targetUser.name || '-' %></div>
      <div class="aq-credit-snapshot-id"><%= targetUser.id || '-' %></div>
      <% if (targetUser.linkedPerson && targetUser.linkedPerson.id) { %>
        <div class="aq-credit-person-link">
          <span>Person</span>
          <strong><%= targetUser.linkedPerson.name || 'Linked person not found' %></strong>
          <small><%= targetUser.linkedPerson.id %></small>
        </div>
      <% } %>
    </div>
    <div class="aq-credit-metric-grid">
      <div class="aq-credit-metric">
        <span class="aq-credit-metric-icon"><i class="bi bi-stack"></i></span>
        <div>
          <div class="aq-credit-metric-label">Quota Rows</div>
          <div class="aq-credit-metric-value"><%= Number(stats.remainingRowCount || 0).toLocaleString() %></div>
          <div class="aq-credit-metric-note">Available rules for this account</div>
        </div>
      </div>
      <div class="aq-credit-metric">
        <span class="aq-credit-metric-icon volume"><i class="bi bi-speedometer2"></i></span>
        <div>
          <div class="aq-credit-metric-label">Remaining Volume</div>
          <div class="aq-credit-metric-value"><%= formatMetric(remainingTotals.volume) %></div>
          <div class="aq-credit-metric-note">Call <%= formatMetric(remainingTotals.call) %> | Token <%= formatMetric(remainingTotals.token) %></div>
        </div>
      </div>
      <div class="aq-credit-metric">
        <span class="aq-credit-metric-icon consumption"><i class="bi bi-activity"></i></span>
        <div>
          <div class="aq-credit-metric-label">Filtered Consumption</div>
          <div class="aq-credit-metric-value"><%= Number(stats.historyTotalItems || 0).toLocaleString() %></div>
          <div class="aq-credit-metric-note">Volume used <%= formatMetric(consumptionTotals.volume) %></div>
        </div>
      </div>
    </div>
  </section>

  <section class="aq-validity-panel mb-3" aria-label="Credit validity">
    <div class="aq-validity-header">
      <div>
        <div class="aq-validity-kicker"><i class="bi bi-calendar-check me-1"></i>Credit Validity</div>
        <h2 class="aq-validity-title">Validity window and lot status</h2>
      </div>
      <div class="aq-validity-asof">
        <span>As of</span>
        <strong><%= formatDateOnly(validity.asOfDate) %></strong>
        <small><%= validity.asOfTimezone || 'UTC' %></small>
      </div>
    </div>
    <div class="aq-validity-layout">
      <div class="aq-validity-status-grid">
        <div class="aq-validity-status active">
          <span>Active</span>
          <strong><%= Number(validity.activeLotCount || 0).toLocaleString() %></strong>
        </div>
        <div class="aq-validity-status perpetual">
          <span>Perpetual</span>
          <strong><%= Number(validity.perpetualLotCount || 0).toLocaleString() %></strong>
        </div>
        <div class="aq-validity-status upcoming">
          <span>Upcoming</span>
          <strong><%= Number(validity.upcomingLotCount || 0).toLocaleString() %></strong>
        </div>
        <div class="aq-validity-status expired">
          <span>Expired</span>
          <strong><%= Number(validity.expiredLotCount || 0).toLocaleString() %></strong>
        </div>
      </div>
      <div class="aq-validity-date-grid">
        <div class="aq-validity-date-card">
          <span class="aq-validity-date-icon"><i class="bi bi-hourglass-split"></i></span>
          <div>
            <div class="small text-muted">Nearest Expiry</div>
            <div class="fw-bold"><%= validity.nearestExpiryDate ? formatDateOnly(validity.nearestExpiryDate) : 'No expiry scheduled' %></div>
          </div>
        </div>
        <div class="aq-validity-date-card">
          <span class="aq-validity-date-icon next"><i class="bi bi-calendar-plus"></i></span>
          <div>
            <div class="small text-muted">Next Activation</div>
            <div class="fw-bold"><%= validity.nextActivationDate ? formatDateOnly(validity.nextActivationDate) : 'No upcoming activation' %></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
      <h5 class="fw-bold mb-3"><i class="bi bi-stack me-2"></i>Remaining Quota</h5>
      <div class="small text-muted mb-2">
        Bold values are current remaining quota. Small values show credited quota versus total consumed plus expired quota.
      </div>
      <div class="table-responsive">
        <table class="table table-sm align-middle">
          <thead class="table-light">
            <tr>
              <th>Operation Label</th>
              <th class="text-end">Call</th>
              <th class="text-end">Amount</th>
              <th class="text-end">Token</th>
              <th class="text-end">Volume</th>
              <th>Validity</th>
              <th>Active Window</th>
              <th>Last Evaluated</th>
            </tr>
          </thead>
          <tbody>
            <% if (!remainingRows.length) { %>
              <tr>
                <td colspan="8" class="text-center text-muted py-3">No remaining quota rows.</td>
              </tr>
            <% } %>
            <% remainingRows.forEach((row) => { %>
              <tr>
                <td>
                  <div class="fw-bold"><%= row.label || '-' %></div>
                </td>
                <% ['call', 'amount', 'token', 'volume'].forEach((metricKey) => {
                  const breakdown = getMetricBreakdown(row, metricKey);
                %>
                  <td class="text-end">
                    <div class="fw-bold"><%= formatMetric(row[metricKey]) %></div>
                    <% if (breakdown.hasAny) { %>
                      <div class="aq-metric-breakdown">
                        <span class="text-success">+<%= formatMetric(breakdown.credit) %></span>
                        <span class="text-danger">-<%= formatMetric(breakdown.consumption) %></span>
                      </div>
                    <% } %>
                  </td>
                <% }) %>
                <td>
                  <span class="badge <%= validityBadgeClass(row.validityStatus) %>">
                    <%= row.validityStatusLabel || 'Not Set' %>
                  </span>
                  <% if (row.validityDetailText) { %>
                    <div class="x-small text-muted mt-1"><%= row.validityDetailText %></div>
                  <% } %>
                </td>
                <td>
                  <div class="small">
                    Until: <span class="fw-bold"><%= row.validityUntil ? formatDateOnly(row.validityUntil) : '-' %></span>
                  </div>
                  <div class="x-small text-muted">
                    Next: <%= row.validityNextFrom ? formatDateOnly(row.validityNextFrom) : '-' %> (<%= row.validityTimezone || 'UTC' %>)
                  </div>
                </td>
                <td><%= row.lastEvaluatedDate || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
      <h5 class="fw-bold mb-3"><i class="bi bi-bar-chart-line me-2"></i>Daily Consumption Volume</h5>
      <% if (!consumptionCategoryDefs.length) { %>
        <div class="text-muted">No remaining quota rows are available to define chart categories.</div>
      <% } else if (!dailyConsumptionRows.length) { %>
        <div class="text-muted">No consumption history for selected filters.</div>
      <% } else { %>
        <div class="aq-consumption-chart-shell">
          <div class="aq-consumption-chart-legend">
            <% const chartPalette = ['#fdba74', '#60a5fa', '#34d399', '#fca5a5', '#c4b5fd', '#f9a8d4', '#67e8f9', '#86efac', '#fcd34d', '#a5b4fc', '#fb7185', '#22d3ee']; %>
            <% consumptionCategoryDefs.forEach((category, categoryIndex) => { %>
              <span title="<%= category.label %>">
                <i class="aq-legend-swatch" style="background: <%= chartPalette[categoryIndex % chartPalette.length] %>; border-color: <%= chartPalette[categoryIndex % chartPalette.length] %>;"></i>
                <%= category.label %>
              </span>
            <% }) %>
            <span class="ms-auto">Scale Max: <%= formatMetric(maxDailyConsumptionVolume) %></span>
          </div>
          <div class="aq-consumption-chart-scroll">
            <div class="aq-consumption-chart" style="--aq-chart-cols: <%= dailyConsumptionRows.length %>;">
              <% dailyConsumptionRows.forEach((row) => {
                const safeDailyTotal = Number.isFinite(Number(row.volume || 0)) ? Number(row.volume || 0) : 0;
                const label = formatDateOnly(row.dateKey);
              %>
                <div class="aq-consumption-col">
                  <div class="aq-consumption-bars">
                    <% consumptionCategoryDefs.forEach((category, categoryIndex) => {
                      const rawCategoryValue = Number(row?.categories?.get?.(category.key) || 0);
                      const safeCategoryValue = Number.isFinite(rawCategoryValue) ? rawCategoryValue : 0;
                      const heightPct = maxDailyConsumptionVolume > 0 ? Math.max(3, Math.round((safeCategoryValue / maxDailyConsumptionVolume) * 100)) : 0;
                      const barColor = chartPalette[categoryIndex % chartPalette.length];
                      const barTitle = `${label} | ${category.label}: ${formatMetric(safeCategoryValue)} | Entries: ${Number(row.entryCount || 0).toLocaleString()}`;
                    %>
                      <div
                        class="aq-consumption-bar"
                        title="<%= barTitle %>"
                        aria-label="<%= barTitle %>"
                        style="height: <%= heightPct %>%; background: <%= barColor %>; border-color: <%= barColor %>;">
                      </div>
                    <% }) %>
                  </div>
                  <div class="aq-consumption-values"><%= formatMetric(safeDailyTotal) %></div>
                  <div class="aq-consumption-label" title="<%= label %>"><%= label %></div>
                </div>
              <% }) %>
            </div>
          </div>
        </div>
      <% } %>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
      <h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2"></i>Consumption History</h5>
      <button
        id="aqCreditCheckHistoryToggleBtn"
        type="button"
        class="btn btn-outline-secondary btn-sm px-2"
        data-bs-toggle="collapse"
        data-bs-target="#aqCreditCheckHistoryCollapse"
        aria-expanded="false"
        aria-controls="aqCreditCheckHistoryCollapse"
        aria-label="Open consumption history">
        <i id="aqCreditCheckHistoryToggleIcon" class="bi bi-chevron-down"></i>
      </button>
    </div>
    <div class="collapse" id="aqCreditCheckHistoryCollapse">
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-sm align-middle">
            <thead class="table-light">
              <tr>
                <th>Date / Entry</th>
                <th>Operation Label</th>
                <th class="text-end">Call</th>
                <th class="text-end">Amount</th>
                <th class="text-end">Token</th>
                <th class="text-end">Volume</th>
                <th>Source</th>
              </tr>
            </thead>
            <tbody>
              <% if (!historyRows.length) { %>
                <tr>
                  <td colspan="7" class="text-center text-muted py-3">No consumption history for selected filters.</td>
                </tr>
              <% } %>
              <% historyRows.forEach((row) => { %>
                <tr>
                  <td>
                    <div class="fw-bold"><%= formatDateTime(row.dateTime) %></div>
                    <div class="x-small text-muted font-monospace"><%= row.id || '-' %></div>
                  </td>
                  <td>
                    <div class="fw-bold"><%= row.label || '-' %></div>
                  </td>
                  <td class="text-end"><%= formatMetric(row.call) %></td>
                  <td class="text-end"><%= formatMetric(row.amount) %></td>
                  <td class="text-end"><%= formatMetric(row.token) %></td>
                  <td class="text-end"><%= formatMetric(row.volume) %></td>
                  <td>
                    <div class="small"><%= row.source.eventType || '-' %></div>
                    <div class="x-small text-muted font-monospace"><%= row.source.eventId || '-' %></div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
  <% if (pager) { %>
    <%- include('../../partials/pagination', {
      pagination: pager,
      filters: {
        userId: filtersState.userId || '',
        fromDate: filtersState.fromDate || '',
        toDate: filtersState.toDate || '',
        limit: filtersState.limit || 20
      },
      baseUrlPath: 'activity-quota/credit-check'
    }) %>
  <% } %>
</div>

<style>
  .aq-credit-snapshot,
  .aq-validity-panel {
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 1.15rem;
    background: #fff;
    box-shadow: 0 18px 46px rgba(15, 23, 42, 0.08);
  }
  .aq-credit-snapshot {
    display: grid;
    grid-template-columns: minmax(220px, 0.8fr) minmax(0, 1.2fr);
    gap: 1rem;
    padding: 1rem;
    background:
      radial-gradient(circle at 0 0, rgba(14, 165, 233, 0.16), transparent 18rem),
      linear-gradient(135deg, #ffffff 0%, #f8fafc 100%);
  }
  .aq-credit-snapshot-main {
    border-radius: 0.95rem;
    padding: 1rem;
    background: linear-gradient(135deg, #0f172a 0%, #1d4ed8 100%);
    color: #fff;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }
  .aq-credit-snapshot-kicker,
  .aq-validity-kicker {
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .aq-credit-snapshot-kicker {
    color: rgba(255, 255, 255, 0.72);
  }
  .aq-credit-snapshot-name {
    font-size: clamp(1.35rem, 2.4vw, 2rem);
    font-weight: 900;
    line-height: 1.08;
    margin-top: 0.5rem;
  }
  .aq-credit-snapshot-id {
    margin-top: 0.45rem;
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    color: rgba(255, 255, 255, 0.72);
    word-break: break-word;
  }
  .aq-credit-person-link {
    margin-top: 0.85rem;
    padding-top: 0.8rem;
    border-top: 1px solid rgba(255, 255, 255, 0.18);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem;
