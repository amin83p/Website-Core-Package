<%- include('../partials/tablePages-start', {
  title,
  newUrl,              // e.g. 'contact'
  newLabel,            // e.g. 'New Message' (optional; you can hide if not used)
  user,
  tableName,           // e.g. 'Contact_Messages'
  print,
  btn_export: true,
  optionalBtns: [`
    <button type="button"
            id="changeToTask"
            class="btn btn-primary text-white me-2"
      <i class="bi bi-ticket me-1" aria-hidden="true"></i>
      Make a task
    </button>
`]
}) %>

<%- include('../partials/tablePages-search', {
  placeholder: 'Search contact messages...',
  fields: [
    { name: 'status', label: 'Status', type: 'select', options: ['All','Unread','Under view','Done'] }
  ]
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="draggable" data-column="id">ID <span class="sort-icon"></span></th>
        <th class="draggable" data-column="status">Status <span class="sort-icon"></span></th>
        <th class="draggable" data-column="name">Name <span class="sort-icon"></span></th>
        <th class="draggable" data-column="email">Email <span class="sort-icon"></span></th>
        <th class="draggable" data-column="subject">Subject <span class="sort-icon"></span></th>
        <th class="draggable" data-column="type">Type <span class="sort-icon"></span></th>
        <th class="draggable" data-column="createDateTime">Received <span class="sort-icon"></span></th>
        <th>Attachments</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% (messages || []).forEach(m => { %>
        <% const audit = m.audit || {}; %>
        <% const status = m.status || 'Unread'; %>
        <% const files = m.attachments || []; %>

        <tr>
          <td><%= m.id %></td>

          <td>
            <% if (status === 'Unread') { %>
              <span class="badge bg-danger-subtle text-danger border shadow-sm">Unread</span>
            <% } else if (status === 'Under view') { %>
              <span class="badge bg-warning-subtle text-warning-emphasis border shadow-sm">Under view</span>
            <% } else { %>
              <span class="badge bg-success-subtle text-success border shadow-sm">Done</span>
            <% } %>
          </td>

          <td class="fw-bold"><%= m.name || '—' %></td>

          <td>
            <% if (m.email) { %>
              <a href="mailto:<%= m.email %>" class="text-decoration-none"><%= m.email %></a>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>

          <td>
            <span class="text-muted small text-truncate d-block" style="max-width: 260px;">
              <%= m.subject || '—' %>
            </span>
          </td>

          <td>
            <span class="badge bg-light text-dark border shadow-sm">
              <%= m.type || '—' %>
            </span>
          </td>

          <td>
            <% if (audit.createDateTime) { %>
              <%= typeof formatOrgDateTime === 'function' ? formatOrgDateTime(audit.createDateTime) : new Date(audit.createDateTime).toLocaleString() %>
            <% } else { %>
              <span class="text-muted">—</span>
            <% } %>
          </td>

          <td>
            <% if (files.length) { %>
              <span class="badge bg-primary-subtle text-primary border shadow-sm">
                <%= files.length %>
              </span>
            <% } else { %>
              <span class="text-muted">0</span>
            <% } %>
          </td>

          <td class="table-actions">
            <a href="/contact/messages/<%= m.id %>" class="btn btn-sm btn-filled btn-edit">
              View
            </a>

            <button class="btn btn-sm btn-filled btn-delete delete-btn" data-id="<%= m.id %>">
              Delete
            </button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/pagination', {
  pagination,
  filters,
  baseUrlPath: '/contact/messages'
}) %>

<%- include('../partials/tablePages-end') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const table = document.getElementById('first-table');
  if (!table) return;

  table.addEventListener('click', async (e) => {
    if (!e.target.classList.contains('delete-btn')) return;

    const btn = e.target;
    const id = btn.dataset.id;

    if (!confirm('Are you sure you want to delete this message?')) return;

    const originalText = btn.textContent;
    btn.disabled = true;
    btn.textContent = 'Deleting...';

    try {
      const res = await fetch(`/contact/messages/delete/${id}`, {
        method: 'GET',
        headers: { 'X-AJAX-Request': 'true' }
      });

      const result = await res.json().catch(() => ({}));

      if (result.status === 'success') {
        const row = btn.closest('tr');
        row.style.opacity = '0';
        setTimeout(() => row.remove(), 300);
      } else {
        alert(result.message || 'Failed to delete.');
        btn.disabled = false;
        btn.textContent = originalText;
      }
    } catch (err) {
      console.error('Delete Error:', err);
      alert('Delete failed.');
      btn.disabled = false;
      btn.textContent = originalText;
    }
  });
});
</script>
