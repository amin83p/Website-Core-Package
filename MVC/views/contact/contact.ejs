<%
  const publicContact = (typeof appContact !== 'undefined' && appContact && typeof appContact === 'object') ? appContact : {};
  const contactPage = (typeof appContactPage !== 'undefined' && appContactPage && typeof appContactPage === 'object') ? appContactPage : {};
  const fallbackContactHighlights = [
    { title: 'Clear Context', body: 'Share goals, files, links, and constraints in one place.' },
    { title: 'Follow-Up Code', body: 'Track your submitted message later with your private code.' },
    { title: 'Direct Route', body: 'Use email if your request is urgent or already documented.' }
  ];
  const fallbackContactProcessImages = [
    {
      imageUrl: '/uploads/GLOBAL/misc/Engineering.jpg',
      alt: 'Mega dust collector system with high efficiency fan.',
      caption: 'Mega dust collector system with a high-efficiency fan for lower energy consumption.'
    },
    {
      imageUrl: '/uploads/GLOBAL/misc/Software.jpeg',
      alt: 'Industrial software interface.',
      caption: 'Industrial and heavy-duty software packages.'
    }
  ];
  const contactText = (key, fallback = '') => (
    Object.prototype.hasOwnProperty.call(contactPage, key)
      ? String(contactPage[key] ?? '')
      : fallback
  );
  const contactHighlights = Array.isArray(contactPage.highlights) ? contactPage.highlights : fallbackContactHighlights;
  const contactProcessImages = Array.isArray(contactPage.processImages) ? contactPage.processImages : fallbackContactProcessImages;
  const cleanContactRows = (rows, valueKey, legacyRows = []) => {
    const source = Array.isArray(rows) ? rows : legacyRows;
    return source
      .map((row) => {
        const item = row && typeof row === 'object' ? row : {};
        const title = String(item.title || item.label || '').trim();
        const value = String(item[valueKey] || item.value || '').trim();
        return value ? { title, value } : null;
      })
      .filter(Boolean);
  };
  const contactEmails = cleanContactRows(publicContact.emails, 'email', publicContact.email ? [{ title: 'Email', email: publicContact.email }] : []);
  const contactPhones = cleanContactRows(publicContact.phones, 'number', publicContact.phone ? [{ title: 'Phone', number: publicContact.phone }] : []);
  const contactFaxes = cleanContactRows(publicContact.faxes, 'number', publicContact.fax ? [{ title: 'Fax', number: publicContact.fax }] : []);
  const contactAddresses = cleanContactRows(publicContact.addresses, 'address', publicContact.address ? [{ title: 'Address', address: publicContact.address }] : []);
  const primaryEmail = contactEmails[0]?.value || '';
  const contactEmailHref = primaryEmail ? `mailto:${encodeURIComponent(primaryEmail)}` : '#';
  const contactRows = [
    ...contactEmails.map((row) => ({ label: row.title || 'Email', value: row.value, href: `mailto:${encodeURIComponent(row.value)}` })),
    ...contactPhones.map((row) => ({ label: row.title || 'Phone', value: row.value, href: row.value ? `tel:${row.value.replace(/[^+\d]/g, '')}` : '' })),
    ...contactFaxes.map((row) => ({ label: row.title || 'Fax', value: row.value, href: row.value ? `tel:${row.value.replace(/[^+\d]/g, '')}` : '' })),
    ...contactAddresses.map((row) => ({ label: row.title || 'Address', value: row.value, href: '' }))
  ].filter((row) => row.value);
  const getContactRowMeta = (row) => {
    const label = String(row?.label || '').toLowerCase();
    const href = String(row?.href || '').toLowerCase();
    if (href.startsWith('mailto:') || label.includes('email')) {
      return { icon: 'bi-envelope-paper', tone: 'email', action: contactText('directContactEmailActionLabel', 'Send email') };
    }
    if (href.startsWith('tel:') && label.includes('fax')) {
      return { icon: 'bi-printer', tone: 'fax', action: contactText('directContactFaxActionLabel', 'Call fax number') };
    }
    if (href.startsWith('tel:') || label.includes('phone') || label.includes('mobile')) {
      return { icon: 'bi-telephone-outbound', tone: 'phone', action: contactText('directContactPhoneActionLabel', 'Call now') };
    }
    if (label.includes('address') || label.includes('office') || label.includes('location')) {
      return { icon: 'bi-geo-alt', tone: 'address', action: '' };
    }
    return { icon: 'bi-chat-square-text', tone: 'other', action: row?.href ? contactText('directContactDefaultActionLabel', 'Open') : '' };
  };
%>
<section class="pte-public-page contact-page">

  <!-- HERO -->
  <section class="pte-hero-intro contact-hero-intro" aria-labelledby="contactLandingTitle">
    <div class="pte-hero-orbit" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="pte-hero-copy contact-hero-copy">
      <div class="pte-eyebrow"><%= contactText('heroEyebrow', 'Contact And Support') %></div>
      <h1 id="contactLandingTitle"><%= contactText('heroTitle', 'Tell us what you need next.') %></h1>
      <p>
        <%= contactText('heroSubtitle', 'Send a message and we will reply with a recommended approach, timeline, and the details needed to move the work forward.') %>
      </p>

      <div class="pte-hero-actions">
        <a href="#contact-form" class="btn pte-btn-primary">
          <i class="bi bi-send me-2"></i>
          <%= contactText('primaryCtaLabel', 'Go To Form') %>
        </a>
        <% if (primaryEmail) { %>
          <a href="<%= contactEmailHref %>" class="btn pte-btn-secondary">
            <i class="bi bi-envelope me-2"></i>
            <%= contactText('emailCtaLabel', 'Email Directly') %>
          </a>
        <% } %>

        <button type="button" id="contactTrackBtn" class="btn pte-btn-secondary">
          <i class="bi bi-search me-2"></i>
          <%= contactText('followUpCtaLabel', 'Follow Up') %>
        </button>
      </div>
    </div>

    <div class="pte-highlight-row contact-highlight-row" aria-label="Contact process highlights">
      <% contactHighlights.forEach((item) => { %>
        <div class="pte-highlight-chip">
          <strong><%= item.title || '' %></strong>
          <span><%= item.body || '' %></span>
        </div>
      <% }) %>
    </div>
  </section>

  <!-- CONTENT -->
  <section class="pte-section contact-workspace" aria-label="Contact form and contact details">
  <div class="row g-4 mb-4 contact-main-grid">
    <!-- FORM -->
    <div class="col-lg-7" id="contact-form">
      <div class="contact-panel contact-formCard">
        <div class="pte-section-heading pte-section-heading-left contact-sectionTitle">
          <span><%= contactText('formEyebrow', 'Message Details') %></span>
          <h2><%= contactText('formTitle', 'Project / inquiry form') %></h2>
          <p><%= contactText('formSubtitle', 'Share enough context for a useful first reply.') %></p>
        </div>

        <!-- Adjust action to your route -->
        <form id="contactForm" method="POST" action="/contact/api/submit" class="contact-form">
          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="name">Name</label>
              <input class="form-control" id="name" name="name" required placeholder="Your name" />
            </div>

            <div class="col-md-6">
              <label class="form-label" for="email">Email</label>
              <input class="form-control" id="email" name="email" type="email" required placeholder="name@example.com" />
            </div>

            <div class="col-md-6">
              <label class="form-label" for="type">Inquiry type</label>
              <select class="form-select" id="type" name="type" required>
                <option value="" selected disabled>Select one</option>
                <option value="engineering">Engineering / simulation</option>
                <option value="research">Research / academic</option>
                <option value="software">Software / automation</option>
                <option value="training">Training / coaching</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label" for="timeline">Timeline</label>
              <select class="form-select" id="timeline" name="timeline">
                <option value="asap">ASAP</option>
                <option value="2-4-weeks">2-4 weeks</option>
                <option value="1-3-months">1-3 months</option>
                <option value="flexible" selected>Flexible</option>
              </select>
            </div>

            <div class="col-12">
              <label class="form-label" for="subject">Subject</label>
              <input class="form-control" id="subject" name="subject" required placeholder="One line summary" />
            </div>

            <div class="col-12">
              <label class="form-label" for="message">Message</label>
              <textarea class="form-control contact-message" id="message" name="message" rows="6" required
                placeholder="What are you trying to achieve? What do you have already? What constraints matter (time, budget, data, stakeholders)?"></textarea>
            </div>
            <div class="col-12">
              <label class="form-label" for="attachments">Attachments (optional)</label>
              <input class="form-control"
                    id="attachments"
                    name="files"
                    type="file"
                    multiple
                    accept=".pdf,.doc,.docx,.txt,.png,.jpg,.jpeg,.zip" />
              <div class="text-muted small" style="margin-top:8px;">
                You can attach multiple files (PDF, images, docs, zip).
              </div>
              <div id="attachmentList" class="contact-attachmentList"></div>
            </div>

            <div class="col-12">
              <div id="contactStatus" class="contact-status" aria-live="polite"></div>
            </div>
            <div class="col-12 d-flex gap-2 justify-content-center justify-content-md-start flex-wrap mt-2">
              <button id="contactSubmitBtn" type="submit" class="btn pte-btn-primary">
                <i class="bi bi-send-check me-2"></i>
                Send Message
              </button>
              <a href="/" class="btn pte-btn-secondary">
                <i class="bi bi-house me-2"></i>
                Back To Home
              </a>
            </div>

            <p class="text-muted small mb-0 contact-hint">
              <%= contactText('formHint', 'Tip: If you include links, screenshots, or a short description of the decision you need to make, I can respond faster.') %>
            </p>
          </div>
        </form>
      </div>
    </div>

    <!-- CONTACT OPTIONS -->
    <div class="col-lg-5">
      <div class="row g-4">
        <% if (contactRows.length) { %>
          <div class="col-12">
            <div class="contact-panel contact-tile contact-direct-card contact-direct-title-card text-start">
              <div class="contact-direct-header">
                <span class="contact-direct-mark" aria-hidden="true">
                  <i class="bi bi-person-lines-fill"></i>
                </span>
                <div>
                  <span class="contact-direct-kicker"><%= contactText('directContactKicker', 'Reach Us') %></span>
                  <h4 class="fw-bold mb-0"><%= contactText('directContactTitle', 'Direct Contact') %></h4>
                </div>
              </div>
              <p class="contact-direct-lead">
                <%= contactText('directContactLead', 'Choose the route that fits your request best. Email is usually the clearest option for detailed project context.') %>
              </p>
            </div>
          </div>

          <div class="col-12">
            <div class="contact-panel contact-tile contact-direct-methods-card text-start">
              <div class="contact-method-heading">
                <h5><%= contactText('directContactMethodsTitle', 'Contact Options') %></h5>
                <p><%= contactText('directContactMethodsSubtitle', 'Use the saved contact details below to reach the right inbox, phone line, or location.') %></p>
              </div>
              <div class="contact-method-list">
                <% contactRows.forEach((row) => {
                  const meta = getContactRowMeta(row);
                %>
                  <div class="contact-method-item contact-method-<%= meta.tone %>">
                    <div class="contact-method-icon" aria-hidden="true">
                      <i class="bi <%= meta.icon %>"></i>
                    </div>
                    <div class="contact-method-body">
                      <div class="contact-method-label"><%= row.label %></div>
                      <div class="contact-method-value">
                        <% if (row.href) { %>
                          <a href="<%= row.href %>"><%= row.value %></a>
                        <% } else { %>
                          <%= row.value %>
                        <% } %>
                      </div>
                    </div>
                    <% if (row.href && meta.action) { %>
                      <a class="contact-method-action" href="<%= row.href %>" aria-label="<%= meta.action %>: <%= row.label %>">
                        <span><%= meta.action %></span>
                        <i class="bi bi-arrow-up-right"></i>
                      </a>
                    <% } %>
                  </div>
                <% }) %>
              </div>
            </div>
          </div>
        <% } %>

        <div class="col-12">
          <div class="contact-panel contact-tile text-center">
            <div class="mb-3 text-primary">
              <i class="bi bi-eyeglasses" style="font-size: 3rem;"></i>
            </div>
            <h4 class="fw-bold"><%= contactText('aboutCardTitle', 'About Me') %></h4>
            <p class="text-muted small mb-2"><%= contactText('aboutCardBody', 'Best for detailed project context.') %></p>
            <a class="btn pte-btn-secondary" href="<%= contactPage.aboutCardHref || '/about/' %>">
              <i class="bi bi-eyeglasses me-2"></i><%= contactText('aboutCardButtonLabel', 'Read About Me') %>
            </a>
          </div>
        </div>

      </div>
    </div>
  </div>

  <div class="contact-panel contact-tile contact-experience-panel">
    <div class="contact-experience-header">
      <div class="pte-section-heading pte-section-heading-left contact-sectionTitle">
        <span><%= contactText('processEyebrow', 'Experience') %></span>
        <h2><i class="bi bi-fan me-2 text-warning"></i><%= contactText('processTitle', 'I Know The Process') %></h2>
      </div>
    </div>
    <div class="contact-experience-grid">
      <% contactProcessImages.forEach((image) => { %>
        <figure class="contact-experience-item">
          <div class="contact-mapFrame">
            <% if (image.imageUrl) { %>
              <img class="bio-inlineImage"
                  src="<%= image.imageUrl %>"
                  alt="<%= image.alt || image.caption || 'Contact page image' %>"
                  loading="lazy" />
            <% } %>
          </div>
          <% if (image.caption) { %>
            <figcaption>
              <%= image.caption %>
            </figcaption>
          <% } %>
        </figure>
      <% }) %>
    </div>
  </div>
  </section>

</section>
<div class="modal fade" id="trackModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-md modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">
          <i class="bi bi-ticket-detailed me-2 text-primary"></i>
          Follow up on a message
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body">
        <form id="trackForm" class="row g-3">
          <div class="col-12">
            <label class="form-label" for="trackCode">Message code</label>
            <input class="form-control" id="trackCode" placeholder="e.g. CNT1007" required />
            <div class="form-text">This is the reference code shown after you submit.</div>
          </div>

          <div class="col-12">
            <label class="form-label" for="trackEmail">Email</label>
            <input class="form-control" id="trackEmail" type="email" placeholder="The email you used" required />
          </div>

          <div class="col-12">
            <div class="form-text">
              For privacy, the code must match the email you used when submitting the message.
            </div>
          </div>


          <div class="col-12">
            <div id="trackResult" class="contact-status" aria-live="polite"></div>
          </div>

          <div class="col-12 d-flex gap-2 justify-content-end">
            <button type="submit" class="btn btn-primary btn-filled" id="trackSubmitBtn">Check status</button>
            <button type="button" class="btn btn-secondary btn-filled" data-bs-dismiss="modal">Close</button>
          </div>
        </form>
      </div>

    </div>
  </div>
</div>
<script>
(() => {
  const form = document.getElementById('contactForm');
  const fileInput = document.getElementById('attachments');
  const listEl = document.getElementById('attachmentList');
  const statusEl = document.getElementById('contactStatus');
  const submitBtn = document.getElementById('contactSubmitBtn');

  if (!form) return;

  // Enable remove-from-selection using DataTransfer
  let dt = new DataTransfer();

  function formatBytes(bytes){
    if (!Number.isFinite(bytes)) return '';
    const units = ['B','KB','MB','GB'];
    let i = 0, v = bytes;
    while (v >= 1024 && i < units.length - 1){ v /= 1024; i++; }
    return `${v.toFixed(i === 0 ? 0 : 1)} ${units[i]}`;
  }

  function setStatus(type, msg){
    if (!statusEl) return;
    statusEl.dataset.type = type || '';
    statusEl.textContent = msg || '';
  }

  function renderFiles(){
    if (!listEl) return;
    listEl.innerHTML = '';
    const files = dt.files;
    if (!files || files.length === 0) return;

    [...files].forEach((f, idx) => {
      const row = document.createElement('div');
      row.className = 'contact-fileRow';
      row.innerHTML = `
        <div class="contact-fileMeta">
          <div class="contact-fileName">${f.name}</div>
          <div class="contact-fileSize">${formatBytes(f.size)}</div>
        </div>
        <button type="button" class="btn btn-danger btn-filled btn-sm contact-fileRemove">Remove</button>
      `;
      row.querySelector('.contact-fileRemove').addEventListener('click', () => {
        const next = new DataTransfer();
        [...dt.files].forEach((ff, j) => { if (j !== idx) next.items.add(ff); });
        dt = next;
        fileInput.files = dt.files;
        renderFiles();
      });
      listEl.appendChild(row);
    });
  }

  fileInput?.addEventListener('change', () => {
    // merge newly selected files into dt
    const incoming = fileInput.files ? [...fileInput.files] : [];
    incoming.forEach(f => dt.items.add(f));
    fileInput.files = dt.files;
    renderFiles();
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    setStatus('', '');

    const payload = {
      name: (document.getElementById('name')?.value || '').trim(),
      email: (document.getElementById('email')?.value || '').trim(),
      type: (document.getElementById('type')?.value || '').trim(),
      timeline: (document.getElementById('timeline')?.value || '').trim(),
      subject: (document.getElementById('subject')?.value || '').trim(),
      message: (document.getElementById('message')?.value || '').trim(),
      meta: {
        page: window.location.pathname,
        ts: new Date().toISOString()
      }
    };

    // quick client-side check
    if (!payload.name || !payload.email || !payload.subject || !payload.message){
      setStatus('error', 'Please fill in Name, Email, Subject, and Message.');
      return;
    }

    const hasFiles = dt.files && dt.files.length > 0;

    submitBtn?.setAttribute('disabled', 'disabled');
    const originalBtnHtml = submitBtn ? submitBtn.innerHTML : '';
    if (submitBtn) submitBtn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Sending...`;

    try {
      let res;

      // If attachments exist: send multipart, with JSON inside "payload"
      if (hasFiles){
        const fd = new FormData();
        fd.append('payload', JSON.stringify(payload));
        [...dt.files].forEach(f => fd.append('files', f)); // must match .array('files', ...)
        res = await fetch('/contact/api/submit', {
          method: 'POST',
          headers: { 'x-ajax-request': '1' },
          body: fd
        });
      } else {
        // No files: pure JSON
        res = await fetch('/contact/api/submit', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'x-ajax-request': '1'
          },
          body: JSON.stringify(payload)
        });
      }

      const data = await res.json().catch(() => ({}));

      if (!res.ok || data.status !== 'success'){
        throw new Error(data.message || 'Unable to submit your message.');
      }
      const refId = data?.result?.id;
      setStatus('success', data.message || 'Message sent successfully.');

      if (refId && typeof window.showMessageModal === 'function') {
        await showMessageModal({
          title: 'Message received',
          icon: 'success',
          size: 'md',
          message: `
            <div class="text-center">
              <div class="text-muted mb-2">Your follow-up code</div>
              <div class="contact-refCode">${refId}</div>
              <div class="mt-3 text-danger fw-bold">Save this code.</div>
              <div class="text-muted small">
                You will need it to follow up and check status later.
              </div>
            </div>
          `,
          buttons: [{ text: 'OK', class: 'btn-success' }]
        });
      } else if (refId) {
        alert(`Your follow-up code is: ${refId}\n\nSave it to check status later.`);
      }


      form.reset();
      dt = new DataTransfer();
      if (fileInput) fileInput.files = dt.files;
      renderFiles();

      // Optional: if you have a global modal helper, you can call it here.
      // if (window.showMessageModal) await showMessageModal({ title: 'Sent', icon: 'success', message: 'Thanks! I will reply soon.' });

    } catch (err){
      setStatus('error', err.message || 'Submission failed.');
    } finally {
      submitBtn?.removeAttribute('disabled');
      if (submitBtn) submitBtn.innerHTML = originalBtnHtml;
    }
  });
})();
</script>
<script>
  const trackBtn = document.getElementById('contactTrackBtn');
const trackModalEl = document.getElementById('trackModal');
const trackForm = document.getElementById('trackForm');
const trackResult = document.getElementById('trackResult');
const trackSubmitBtn = document.getElementById('trackSubmitBtn');

function setTrackStatus(type, msg){
  if (!trackResult) return;
  trackResult.dataset.type = type || '';
  trackResult.textContent = msg || '';
}

let trackModal = null;
function getTrackModal(){
  if (trackModal) return trackModal;
  if (!trackModalEl || !window.bootstrap?.Modal) return null;
  trackModal = new bootstrap.Modal(trackModalEl);
  return trackModal;
}

trackBtn?.addEventListener('click', () => {
  setTrackStatus('', '');
  const modal = getTrackModal();
  if (modal) {
    modal.show();
    return;
  }
  setTrackStatus('error', 'The tracking window is still loading. Please try again in a moment.');
});

trackForm?.addEventListener('submit', async (e) => {
  e.preventDefault();
  setTrackStatus('', '');

  const code = (document.getElementById('trackCode')?.value || '').trim();
  const email = (document.getElementById('trackEmail')?.value || '').trim();

  if (!code || !email) {
    setTrackStatus('error', 'Please provide your message code and email.');
    return;
  }

  const original = trackSubmitBtn?.innerHTML || '';
  if (trackSubmitBtn) {
    trackSubmitBtn.disabled = true;
    trackSubmitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Checking...';
  }

  try {
    const res = await fetch('/contact/api/track', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-ajax-request': '1'
      },
      body: JSON.stringify({ code, email })
    });

    const data = await res.json().catch(() => ({}));
    if (!res.ok || data.status !== 'success') throw new Error(data.message || 'Lookup failed.');


    const received = data.result?.receivedAt ? ((window.AppOrgDateTime && AppOrgDateTime.formatInstant) ? AppOrgDateTime.formatInstant(data.result.receivedAt) : new Date(data.result.receivedAt).toLocaleString()) : '-';
    const updated = data.result?.lastUpdatedAt ? ((window.AppOrgDateTime && AppOrgDateTime.formatInstant) ? AppOrgDateTime.formatInstant(data.result.lastUpdatedAt) : new Date(data.result.lastUpdatedAt).toLocaleString()) : '-';
    const note = (data.result?.userNote || '').trim();

    setTrackStatus(
      'success',
      `Status: ${data.result?.status || '-'} - Received: ${received} - Updated: ${updated}` + (note ? `\nNote: ${note}` : '')
    );

    // // Example: show status + received date
    // const received = data.result?.receivedAt ? new Date(data.result.receivedAt).toLocaleString() : '-';
    // setTrackStatus('success', `Status: ${data.result?.status || '-'} - Received: ${received}`);
  } catch (err) {
    setTrackStatus('error', err.message || 'Lookup failed.');
  } finally {
    if (trackSubmitBtn) {
      trackSubmitBtn.disabled = false;
      trackSubmitBtn.innerHTML = original;
    }
  }
});
</script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

.contact-page {
  --contact-primary: #0a66c2;
  --contact-primary-dark: #094d92;
  --contact-ink: #17223b;
  --contact-muted: #5c687d;
  --contact-border: #dbe3ee;
  --contact-surface: #ffffff;
  --contact-soft: #f4f8fc;
  --pte-ink: #13222c;
  --pte-muted: #53636f;
  --pte-line: #d7e1e7;
  --pte-surface: #ffffff;
  --pte-soft: #f5f8fa;
  --pte-teal: #087f8c;
  --pte-blue: #1d5fb8;
  --pte-amber: #f0b84e;
  font-family: 'Manrope', 'Segoe UI', sans-serif;
  isolation: isolate;
  padding-bottom: clamp(2rem, 5vw, 4.5rem);
  position: relative;
}

html.pte-public-root,
