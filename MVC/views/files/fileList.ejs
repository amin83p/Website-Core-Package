  }

  .file-folder-dropzone.is-ready {
    border-color: rgba(25, 135, 84, 0.85);
    background: rgba(25, 135, 84, 0.08);
  }

  .file-entry-selected {
    box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.2) inset;
