<% if (canUseOrgBackups) { %>
<div class="modal fade" id="orgBackupModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-shield-check me-2"></i>Org / Global File Backup</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="backend-notice backend-notice-warning mb-3">
          <div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle me-1"></i>Files only</div>
          <div class="small">
            Download and restore the selected upload folder. Restore replaces all files under
            <code>/uploads/GLOBAL/</code> or <code>/uploads/ORG_&lt;orgId&gt;/</code> and does not change Mongo or JSON records.
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-semibold">Organization</label>
          <select class="form-select" id="orgBackupOrgId" <%= orgBackupRows.length ? '' : 'disabled' %>>
