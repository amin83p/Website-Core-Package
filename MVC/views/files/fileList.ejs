<div class="sections-page">
  <input type="hidden" name="actionStateId" value="<%= typeof actionStateId !== 'undefined' ? actionStateId : '' %>">
  <%
    const canUseOrgBackups = Boolean(typeof canManageOrgBackups !== 'undefined' && canManageOrgBackups);
    const orgBackupRows = Array.isArray(typeof orgBackupOrganizations !== 'undefined' ? orgBackupOrganizations : [])
      ? orgBackupOrganizations
      : [];
    const orgBackupRestoreMaxMb = Number.isFinite(Number(typeof orgBackupRestoreMaxUploadMb !== 'undefined' ? orgBackupRestoreMaxUploadMb : NaN))
      ? Number(orgBackupRestoreMaxUploadMb)
      : 500;
    const IMAGE_EXT = /\.(jpe?g|png|gif|webp|svg|bmp|ico|tiff?)$/i;
    const AUDIO_EXT = /\.(mp3|wav|m4a|aac|ogg|webm|flac)$/i;
    const VIDEO_EXT = /\.(mp4|mov|avi|mkv|webm|m4v)$/i;

    function previewUrlFromPath(filePath) {
      return '/uploads/' + String(filePath || '').split('/').filter(Boolean).map(encodeURIComponent).join('/');
    }

    function getKindByName(fileName) {
      const token = String(fileName || '').trim().toLowerCase();
      if (IMAGE_EXT.test(token)) return 'image';
      if (AUDIO_EXT.test(token)) return 'audio';
      if (VIDEO_EXT.test(token)) return 'video';
      return 'file';
    }

    function getKindIcon(kind, isDir) {
      if (isDir) return 'bi-folder-fill text-warning';
      if (kind === 'image') return 'bi-file-earmark-image text-info';
      if (kind === 'audio') return 'bi-file-earmark-music text-success';
      if (kind === 'video') return 'bi-file-earmark-play text-danger';
      return 'bi-file-earmark text-secondary';
    }
  %>
  <div class="d-flex align-items-center justify-content-between mb-3">
    <h1 class="page-heading size-md m-0">File Manager</h1>

    <div class="d-flex align-items-center gap-2">
      <% if (canUseOrgBackups) { %>
        <button class="btn btn-outline-dark btn-sm" data-bs-toggle="modal" data-bs-target="#orgBackupModal">
          <i class="bi bi-shield-check me-1"></i> Org / Global Backup
        </button>
      <% } %>
      <% if (!isRoot) { %>
        <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createFolderModal">
          <i class="bi bi-folder-plus me-1"></i> Create Folder
        </button>
        <button class="btn btn-primary btn-filled btn-sm" data-bs-toggle="modal" data-bs-target="#uploadModal">
          <i class="bi bi-cloud-upload me-1"></i> Upload Here
        </button>
      <% } %>
    </div>
  </div>

  <nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb bg-light p-2 rounded shadow-sm border">
      <li class="breadcrumb-item">
        <a href="/files" class="fw-bold"><i class="bi bi-hdd-network me-1"></i> Root</a>
      </li>
      <% if (typeof breadcrumbs !== 'undefined') { %>
      <% breadcrumbs.forEach((b, idx) => { %>
      <% if (idx === breadcrumbs.length - 1) { %>
      <li class="breadcrumb-item active" aria-current="page"><%= b.name %></li>
      <% } else { %>
      <li class="breadcrumb-item"><a href="/files?path=<%= b.path %>"><%= b.name %></a></li>
      <% } %>
      <% }) %>
      <% } %>
    </ol>
  </nav>

  <div class="alert alert-info py-2 px-3 mb-4 small">
    <strong>Upload destination:</strong> Files are saved to <code>app.uploadsPath</code> from System Settings.
    Railway uses volume only when that path points to the mounted volume path. Local development writes to local disk.
  </div>

  <% if (isRoot) { %>
  <div class="row g-3">
    <% drives.forEach(drive => { %>
    <div class="col-md-4 col-sm-6">
      <a href="/files?path=<%= drive.id %>" class="text-decoration-none text-dark">
        <div class="card h-100 border-0 shadow-sm text-center p-4 hover-lift">
          <i class="bi <%= drive.icon %> display-4 text-primary mb-3"></i>
          <h5 class="fw-bold"><%= drive.name %></h5>
          <div class="text-muted small"><%= drive.id %></div>
        </div>
      </a>
    </div>
    <% }) %>
  </div>
  <% } else { %>
  <div class="d-flex justify-content-between align-items-center mb-3 gap-2 flex-wrap">
    <div class="small text-muted">
      Current folder items: <span class="fw-semibold"><%= files.length %></span>
    </div>
    <div class="btn-group btn-group-sm" role="group" aria-label="File view modes">
      <button type="button" class="btn btn-outline-secondary active file-view-btn" data-file-view="detail" title="Detail view">
        <i class="bi bi-table"></i>
      </button>
      <button type="button" class="btn btn-outline-secondary file-view-btn" data-file-view="file" title="File list view">
        <i class="bi bi-list-ul"></i>
      </button>
      <button type="button" class="btn btn-outline-secondary file-view-btn" data-file-view="tile" title="Tile view">
        <i class="bi bi-grid-3x2-gap"></i>
      </button>
      <button type="button" class="btn btn-outline-secondary file-view-btn" data-file-view="thumbs" title="Thumbnail view">
        <i class="bi bi-grid-3x3-gap"></i>
      </button>
    </div>
  </div>
  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-3 d-flex justify-content-between align-items-center gap-2 flex-wrap">
      <div class="small text-muted">
        Selected items: <span class="fw-semibold text-dark" id="fileBulkSelectedCount">0</span>
      </div>
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <button type="button" class="btn btn-outline-secondary btn-sm" id="fileBulkSelectVisibleBtn">
          <i class="bi bi-check2-square me-1"></i>Select visible
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="fileBulkUnselectVisibleBtn">
          <i class="bi bi-square me-1"></i>Unselect visible
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="fileBulkClearBtn" disabled>
          <i class="bi bi-x-circle me-1"></i>Clear
        </button>
        <button type="button" class="btn btn-outline-primary btn-sm" id="fileBulkCopyBtn" disabled>
          <i class="bi bi-files me-1"></i>Copy Selected
        </button>
        <button type="button" class="btn btn-primary btn-filled btn-sm" id="fileBulkMoveBtn" disabled>
          <i class="bi bi-arrows-move me-1"></i>Move Selected
        </button>
      </div>
    </div>
  </div>

  <div class="file-view-pane" data-file-view-pane="detail">
    <div class="card border-0 shadow-sm">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th style="width: 40px;" class="text-center"></th>
              <th style="width: 50px;"></th>
              <th>Name</th>
              <th>Size</th>
              <th>Modified</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (files.length === 0) { %>
            <tr>
              <td colspan="6" class="text-center py-5 text-muted">This folder is empty.</td>
            </tr>
            <% } %>

            <% files.forEach((f, idx) => { %>
            <% const fileUrl = '/files/download/dummy?path=' + encodeURIComponent(f.path); %>
            <% const previewUrl = previewUrlFromPath(f.path); %>
            <% const kind = getKindByName(f.name); %>
            <tr class="<%= f.isDir ? 'bg-light' : '' %> file-entry" data-file-path="<%= f.path %>" data-file-name="<%= f.name %>" data-file-is-dir="<%= f.isDir ? '1' : '0' %>">
              <td class="text-center">
                <input type="checkbox" class="form-check-input file-select-check" data-file-path="<%= f.path %>" aria-label="Select <%= f.name %>">
              </td>
              <td class="text-center text-secondary">
                <i class="bi <%= getKindIcon(kind, f.isDir) %> fs-4"></i>
              </td>
              <td>
                <% if (f.isDir) { %>
                <a href="/files?path=<%= f.path %>" class="fw-bold text-dark text-decoration-none"><%= f.name %></a>
                <% } else { %>
                <a href="#"
                  class="fw-bold text-primary text-decoration-none text-truncate d-block file-preview-trigger"
                  style="max-width: 320px;"
                  data-preview-url="<%= previewUrl %>"
                  data-download-url="<%= fileUrl %>"
                  data-name="<%= f.name %>"
                  data-kind="<%= kind %>"
                  data-index="<%= idx %>">
                  <%= f.name %>
                </a>
                <% } %>
              </td>
              <td><%= f.size %></td>
              <td><%= typeof formatOrgDateTime === 'function' ? formatOrgDateTime(f.modified, { month: 'short', day: 'numeric', year: 'numeric' }) : new Date(f.modified).toLocaleDateString() %></td>
              <td class="text-end">
                <% if (!f.isDir) { %>
                <button class="btn btn-sm btn-outline-secondary border-0 file-preview-trigger"
                  data-preview-url="<%= previewUrl %>"
                  data-download-url="<%= fileUrl %>"
                  data-name="<%= f.name %>"
                  data-kind="<%= kind %>"
                  data-index="<%= idx %>"
                  title="Preview">
                  <i class="bi bi-eye"></i>
                </button>
                <a href="<%= fileUrl %>" class="btn btn-sm btn-outline-secondary border-0" title="Download">
                  <i class="bi bi-download"></i>
                </a>
                <% } %>
                <button class="btn btn-sm btn-outline-secondary border-0 file-rename-item" data-no-wait="true" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Rename">
                  <i class="bi bi-pencil-square"></i>
                </button>
                <button class="btn btn-sm btn-outline-secondary border-0 file-transfer-item" data-no-wait="true" data-operation="copy" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Copy">
                  <i class="bi bi-files"></i>
                </button>
                <button class="btn btn-sm btn-outline-secondary border-0 file-transfer-item" data-no-wait="true" data-operation="move" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Move">
                  <i class="bi bi-arrows-move"></i>
                </button>
                <button class="btn btn-sm btn-outline-danger border-0 delete-item" data-no-wait="true" data-path="<%= f.path %>" title="Delete">
                  <i class="bi bi-trash"></i>
                </button>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="file-view-pane d-none" data-file-view-pane="file">
    <div class="card border-0 shadow-sm">
      <div class="list-group list-group-flush">
        <% if (files.length === 0) { %>
          <div class="list-group-item py-5 text-center text-muted">This folder is empty.</div>
        <% } %>
        <% files.forEach((f, idx) => { %>
          <% const fileUrl = '/files/download/dummy?path=' + encodeURIComponent(f.path); %>
          <% const previewUrl = previewUrlFromPath(f.path); %>
          <% const kind = getKindByName(f.name); %>
          <div class="list-group-item d-flex align-items-center justify-content-between gap-3 file-entry" data-file-path="<%= f.path %>" data-file-name="<%= f.name %>" data-file-is-dir="<%= f.isDir ? '1' : '0' %>">
            <div class="d-flex align-items-center gap-3 overflow-hidden">
              <input type="checkbox" class="form-check-input file-select-check flex-shrink-0" data-file-path="<%= f.path %>" aria-label="Select <%= f.name %>">
              <i class="bi <%= getKindIcon(kind, f.isDir) %> fs-4 flex-shrink-0"></i>
              <div class="overflow-hidden">
                <% if (f.isDir) { %>
                  <a href="/files?path=<%= f.path %>" class="fw-semibold text-dark text-decoration-none text-truncate d-block"><%= f.name %></a>
                <% } else { %>
                  <a href="#" class="fw-semibold text-primary text-decoration-none text-truncate d-block file-preview-trigger"
                    data-preview-url="<%= previewUrl %>"
                    data-download-url="<%= fileUrl %>"
                    data-name="<%= f.name %>"
                    data-kind="<%= kind %>"
                    data-index="<%= idx %>"><%= f.name %></a>
                <% } %>
                <div class="small text-muted">
                  <%= f.isDir ? 'Folder' : f.size %> - <%= typeof formatOrgDateTime === 'function' ? formatOrgDateTime(f.modified) : new Date(f.modified).toLocaleString() %>
                </div>
              </div>
            </div>
            <div class="d-flex align-items-center gap-1 flex-shrink-0">
              <% if (!f.isDir) { %>
                <button class="btn btn-sm btn-outline-secondary border-0 file-preview-trigger"
                  data-preview-url="<%= previewUrl %>"
                  data-download-url="<%= fileUrl %>"
                  data-name="<%= f.name %>"
                  data-kind="<%= kind %>"
                  data-index="<%= idx %>"
                  title="Preview"><i class="bi bi-eye"></i></button>
                <a href="<%= fileUrl %>" class="btn btn-sm btn-outline-secondary border-0" title="Download"><i class="bi bi-download"></i></a>
              <% } %>
              <button class="btn btn-sm btn-outline-secondary border-0 file-rename-item" data-no-wait="true" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Rename"><i class="bi bi-pencil-square"></i></button>
              <button class="btn btn-sm btn-outline-secondary border-0 file-transfer-item" data-no-wait="true" data-operation="copy" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Copy"><i class="bi bi-files"></i></button>
              <button class="btn btn-sm btn-outline-secondary border-0 file-transfer-item" data-no-wait="true" data-operation="move" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Move"><i class="bi bi-arrows-move"></i></button>
              <button class="btn btn-sm btn-outline-danger border-0 delete-item" data-no-wait="true" data-path="<%= f.path %>" title="Delete"><i class="bi bi-trash"></i></button>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <div class="file-view-pane d-none" data-file-view-pane="tile">
    <div class="row g-3">
      <% if (files.length === 0) { %>
      <div class="col-12">
        <div class="card border-0 shadow-sm text-center py-5 text-muted">This folder is empty.</div>
      </div>
      <% } %>
      <% files.forEach((f, idx) => { %>
      <% const fileUrl = '/files/download/dummy?path=' + encodeURIComponent(f.path); %>
      <% const previewUrl = previewUrlFromPath(f.path); %>
      <% const kind = getKindByName(f.name); %>
      <div class="col-12 col-sm-6 col-lg-4 col-xl-3 file-entry" data-file-path="<%= f.path %>" data-file-name="<%= f.name %>" data-file-is-dir="<%= f.isDir ? '1' : '0' %>">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body d-flex flex-column">
            <div class="d-flex justify-content-end mb-2">
              <input type="checkbox" class="form-check-input file-select-check" data-file-path="<%= f.path %>" aria-label="Select <%= f.name %>">
            </div>
            <div class="d-flex align-items-center gap-2 mb-3">
              <i class="bi <%= getKindIcon(kind, f.isDir) %> fs-3"></i>
              <div class="small text-muted"><%= f.isDir ? 'Folder' : kind.toUpperCase() %></div>
            </div>
            <% if (f.isDir) { %>
              <a href="/files?path=<%= f.path %>" class="fw-semibold text-dark text-decoration-none text-truncate"><%= f.name %></a>
            <% } else { %>
              <a href="#" class="fw-semibold text-primary text-decoration-none text-truncate file-preview-trigger"
                data-preview-url="<%= previewUrl %>"
                data-download-url="<%= fileUrl %>"
                data-name="<%= f.name %>"
                data-kind="<%= kind %>"
                data-index="<%= idx %>"><%= f.name %></a>
            <% } %>
            <div class="small text-muted mt-1"><%= f.isDir ? '-' : f.size %></div>
            <div class="small text-muted mb-3"><%= typeof formatOrgDateTime === 'function' ? formatOrgDateTime(f.modified, { month: 'short', day: 'numeric', year: 'numeric' }) : new Date(f.modified).toLocaleDateString() %></div>
            <div class="mt-auto d-flex gap-1">
              <% if (!f.isDir) { %>
                <button class="btn btn-sm btn-outline-secondary file-preview-trigger"
                  data-preview-url="<%= previewUrl %>"
                  data-download-url="<%= fileUrl %>"
                  data-name="<%= f.name %>"
                  data-kind="<%= kind %>"
                  data-index="<%= idx %>"><i class="bi bi-eye"></i></button>
                <a href="<%= fileUrl %>" class="btn btn-sm btn-outline-secondary"><i class="bi bi-download"></i></a>
              <% } %>
              <button class="btn btn-sm btn-outline-secondary file-rename-item" data-no-wait="true" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Rename"><i class="bi bi-pencil-square"></i></button>
              <button class="btn btn-sm btn-outline-secondary file-transfer-item" data-no-wait="true" data-operation="copy" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Copy"><i class="bi bi-files"></i></button>
              <button class="btn btn-sm btn-outline-secondary file-transfer-item" data-no-wait="true" data-operation="move" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Move"><i class="bi bi-arrows-move"></i></button>
              <button class="btn btn-sm btn-outline-danger delete-item" data-no-wait="true" data-path="<%= f.path %>"><i class="bi bi-trash"></i></button>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>

  <div class="file-view-pane d-none" data-file-view-pane="thumbs">
    <div class="row g-3">
      <% if (files.length === 0) { %>
      <div class="col-12">
        <div class="card border-0 shadow-sm text-center py-5 text-muted">This folder is empty.</div>
      </div>
      <% } %>
      <% files.forEach((f, idx) => { %>
      <% const fileUrl = '/files/download/dummy?path=' + encodeURIComponent(f.path); %>
      <% const previewUrl = previewUrlFromPath(f.path); %>
      <% const kind = getKindByName(f.name); %>
      <div class="col-6 col-sm-4 col-md-3 col-xl-2 file-entry" data-file-path="<%= f.path %>" data-file-name="<%= f.name %>" data-file-is-dir="<%= f.isDir ? '1' : '0' %>">
        <div class="card border-0 shadow-sm h-100">
          <div class="thumb-frame bg-light">
            <% if (f.isDir) { %>
              <a href="/files?path=<%= f.path %>" class="d-flex align-items-center justify-content-center h-100 text-warning text-decoration-none">
                <i class="bi bi-folder-fill fs-1"></i>
              </a>
            <% } else if (kind === 'image') { %>
              <a href="#" class="d-block h-100 file-preview-trigger"
                data-preview-url="<%= previewUrl %>"
                data-download-url="<%= fileUrl %>"
                data-name="<%= f.name %>"
                data-kind="<%= kind %>"
                data-index="<%= idx %>">
                <img src="<%= previewUrl %>" alt="<%= f.name %>" class="thumb-image">
              </a>
            <% } else { %>
              <button class="btn btn-link text-decoration-none text-secondary w-100 h-100 d-flex align-items-center justify-content-center file-preview-trigger"
                data-preview-url="<%= previewUrl %>"
                data-download-url="<%= fileUrl %>"
                data-name="<%= f.name %>"
                data-kind="<%= kind %>"
                data-index="<%= idx %>">
                <i class="bi <%= kind === 'audio' ? 'bi-file-earmark-music' : (kind === 'video' ? 'bi-file-earmark-play' : 'bi-file-earmark') %> fs-1"></i>
              </button>
            <% } %>
          </div>
          <div class="card-body p-2">
            <div class="d-flex justify-content-end mb-1">
              <input type="checkbox" class="form-check-input file-select-check" data-file-path="<%= f.path %>" aria-label="Select <%= f.name %>">
            </div>
            <div class="small text-truncate fw-semibold" title="<%= f.name %>"><%= f.name %></div>
            <div class="d-flex justify-content-between mt-2">
              <% if (!f.isDir) { %>
              <a href="<%= fileUrl %>" class="btn btn-sm btn-outline-secondary border-0"><i class="bi bi-download"></i></a>
              <% } else { %>
              <span></span>
              <% } %>
              <button class="btn btn-sm btn-outline-secondary border-0 file-rename-item" data-no-wait="true" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Rename"><i class="bi bi-pencil-square"></i></button>
              <button class="btn btn-sm btn-outline-secondary border-0 file-transfer-item" data-no-wait="true" data-operation="copy" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Copy"><i class="bi bi-files"></i></button>
              <button class="btn btn-sm btn-outline-secondary border-0 file-transfer-item" data-no-wait="true" data-operation="move" data-path="<%= f.path %>" data-name="<%= f.name %>" title="Move"><i class="bi bi-arrows-move"></i></button>
              <button class="btn btn-sm btn-outline-danger border-0 delete-item" data-no-wait="true" data-path="<%= f.path %>"><i class="bi bi-trash"></i></button>
            </div>
          </div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
  <% } %>
</div>

<% if (!isRoot) { %>
<div class="modal fade" id="createFolderModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <form id="createFolderForm" action="/files/create-folder" method="POST">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Create Folder</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" name="path" value="<%= currentPath %>">
          <div class="mb-2">
            <label class="form-label">Folder Name</label>
            <input type="text" class="form-control" name="folderName" maxlength="120" required placeholder="New folder name">
          </div>
          <div class="form-text">Folder will be created in: <code><%= currentPath %></code></div>
        </div>
        <div class="modal-footer">
          <button type="submit" class="btn btn-primary btn-filled">Create Folder</button>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="modal fade" id="uploadModal" tabindex="-1">
  <div class="modal-dialog">
    <form id="fileUploadForm" action="/files/upload" method="POST" enctype="multipart/form-data">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title">Upload to Current Folder</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <input type="hidden" name="path" value="<%= currentPath %>">
          <input type="hidden" name="relativePathsJson" id="relativePathsJsonInput" value="">

          <div class="btn-group w-100 mb-3" role="group">
            <input type="radio" class="btn-check" name="uploadMode" id="uploadModeFiles" value="files" autocomplete="off" checked>
            <label class="btn btn-outline-primary" for="uploadModeFiles">Files</label>

            <input type="radio" class="btn-check" name="uploadMode" id="uploadModeFolder" value="folder" autocomplete="off">
            <label class="btn btn-outline-primary" for="uploadModeFolder">Folder</label>
          </div>

          <div id="uploadFilesPane">
            <label class="form-label">Select Files</label>
            <input type="file" id="uploadFilesInput" name="files" class="form-control" multiple>
          </div>

          <div id="uploadFolderPane" class="d-none">
            <label class="form-label">Select Folder</label>
            <input type="file" id="uploadFolderInput" name="files" class="form-control" webkitdirectory directory multiple>
            <div class="file-folder-dropzone mt-3" id="folderDropZone">
              <div class="fw-semibold"><i class="bi bi-folder-symlink me-1"></i> Drag and drop a folder here</div>
