              <option value="<%= org.id %>"><%= org.label %> (<%= org.scope %>)</option>
            <% }) %>
          </select>
          <% if (!orgBackupRows.length) { %>
            <div class="form-text text-danger">No upload folders are available for backup.</div>
          <% } else { %>
            <div class="form-text">Backups cannot be restored into a different organization or system folder.</div>
          <% } %>
        </div>

        <div class="row g-3">
          <div class="col-lg-6">
            <div class="border rounded-3 p-3 h-100">
              <h6 class="fw-bold mb-2"><i class="bi bi-cloud-download me-1"></i>Download Backup</h6>
              <p class="small text-muted">Creates a compressed <code>.tar.gz</code> backup with a manifest and all files for the selected folder.</p>
              <button type="button" class="btn btn-success btn-filled btn-sm" id="orgBackupDownloadBtn" <%= orgBackupRows.length ? '' : 'disabled' %>>
                <i class="bi bi-download me-1"></i> Download Backup
              </button>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="border rounded-3 p-3 h-100">
              <h6 class="fw-bold mb-2"><i class="bi bi-cloud-upload me-1"></i>Restore Backup</h6>
              <p class="small text-muted">Upload a backup created by this tool. Existing files for the selected folder will be replaced.</p>
              <div class="small text-muted mb-2">Maximum upload size: <b><%= orgBackupRestoreMaxMb %> MB</b></div>
              <form id="orgBackupRestoreForm" method="POST" action="/files/org-backup/restore" enctype="multipart/form-data">
                <input type="file" class="form-control form-control-sm mb-2" id="orgBackupFileInput" name="backupFile" accept=".gz,.tgz,.tar.gz,application/gzip">
                <button type="submit" class="btn btn-danger btn-sm" id="orgBackupRestoreBtn" <%= orgBackupRows.length ? '' : 'disabled' %>>
                  <i class="bi bi-arrow-counterclockwise me-1"></i> Restore Backup
                </button>
              </form>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<% } %>

<%- include('../partials/modal_ImageViewer') %>
<%- include('../partials/modal_AudioPreview') %>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const uploadForm = document.getElementById('fileUploadForm');
    const createFolderForm = document.getElementById('createFolderForm');
    const filesInput = document.getElementById('uploadFilesInput');
    const folderInput = document.getElementById('uploadFolderInput');
    const folderDropZone = document.getElementById('folderDropZone');
    const summaryEl = document.getElementById('uploadSelectionSummary');
    const relativePathsInput = document.getElementById('relativePathsJsonInput');
    const modeFiles = document.getElementById('uploadModeFiles');
    const modeFolder = document.getElementById('uploadModeFolder');
    const filesPane = document.getElementById('uploadFilesPane');
    const folderPane = document.getElementById('uploadFolderPane');
    const viewButtons = Array.from(document.querySelectorAll('.file-view-btn'));
    const viewPanes = Array.from(document.querySelectorAll('.file-view-pane'));
    const previewTriggers = Array.from(document.querySelectorAll('.file-preview-trigger'));
    const transferModalEl = document.getElementById('fileTransferModal');
    const transferModal = transferModalEl && window.bootstrap && window.bootstrap.Modal
      ? new window.bootstrap.Modal(transferModalEl)
      : null;
    const transferForm = document.getElementById('fileTransferForm');
    const transferTitle = document.getElementById('fileTransferTitle');
    const transferSourcePath = document.getElementById('fileTransferSourcePath');
    const transferSourcePathsJson = document.getElementById('fileTransferSourcePathsJson');
    const transferSourceName = document.getElementById('fileTransferSourceName');
    const transferDestinationPath = document.getElementById('fileTransferDestinationPath');
    const transferDestinationHint = document.getElementById('fileTransferDestinationHint');
    const transferOperation = document.getElementById('fileTransferOperation');
    const transferSubmitBtn = document.getElementById('fileTransferSubmitBtn');
    const transferBrowseDestinationBtn = document.getElementById('fileTransferBrowseDestinationBtn');
    const folderPickerModalEl = document.getElementById('folderPickerModal');
    const folderPickerModal = folderPickerModalEl && window.bootstrap && window.bootstrap.Modal
      ? new window.bootstrap.Modal(folderPickerModalEl)
      : null;
    const folderPickerDriveSelect = document.getElementById('folderPickerDriveSelect');
    const folderPickerUpBtn = document.getElementById('folderPickerUpBtn');
    const folderPickerCurrentPathLabel = document.getElementById('folderPickerCurrentPathLabel');
    const folderPickerFolderList = document.getElementById('folderPickerFolderList');
    const folderPickerEmptyState = document.getElementById('folderPickerEmptyState');
    const folderPickerApplyBtn = document.getElementById('folderPickerApplyBtn');
    const bulkSelectedCountEl = document.getElementById('fileBulkSelectedCount');
    const bulkCopyBtn = document.getElementById('fileBulkCopyBtn');
    const bulkMoveBtn = document.getElementById('fileBulkMoveBtn');
    const bulkClearBtn = document.getElementById('fileBulkClearBtn');
    const bulkSelectVisibleBtn = document.getElementById('fileBulkSelectVisibleBtn');
    const bulkUnselectVisibleBtn = document.getElementById('fileBulkUnselectVisibleBtn');
    const fileSelectionInputs = Array.from(document.querySelectorAll('.file-select-check'));
    const fileEntryNodes = Array.from(document.querySelectorAll('.file-entry[data-file-path]'));
    const renameModalEl = document.getElementById('fileRenameModal');
    const renameModal = renameModalEl && window.bootstrap && window.bootstrap.Modal
      ? new window.bootstrap.Modal(renameModalEl)
      : null;
    const renameForm = document.getElementById('fileRenameForm');
    const renameSourcePath = document.getElementById('fileRenameSourcePath');
    const renameSourceName = document.getElementById('fileRenameSourceName');
    const renameNewName = document.getElementById('fileRenameNewName');
    const renameSubmitBtn = document.getElementById('fileRenameSubmitBtn');
    const orgBackupOrgId = document.getElementById('orgBackupOrgId');
    const orgBackupDownloadBtn = document.getElementById('orgBackupDownloadBtn');
    const orgBackupRestoreForm = document.getElementById('orgBackupRestoreForm');
    const orgBackupFileInput = document.getElementById('orgBackupFileInput');
    const orgBackupRestoreBtn = document.getElementById('orgBackupRestoreBtn');
    const ORG_FILE_BACKUP_RESTORE_MAX_MB = <%= orgBackupRestoreMaxMb %>;
    const ORG_FILE_BACKUP_RESTORE_MAX_BYTES = ORG_FILE_BACKUP_RESTORE_MAX_MB * 1024 * 1024;

    const VIEW_STORAGE_KEY = 'fileManager.viewMode';
    const allowedViews = new Set(['detail', 'file', 'tile', 'thumbs']);
    const selectedFilePaths = new Set();
    const folderPickerState = {
      currentPath: '',
      parentPath: '',
      drives: [],
      folders: []
    };
    let droppedFolderFiles = [];

    function ajaxHeaders(extra = {}) {
      return {
        'X-AJAX-Request': 'true',
        'X-Action-State-Id': '',
        ...(extra || {})
      };
    }

    function showFileManagerMessage(options = {}) {
      if (typeof showMessageModal === 'function') {
        return showMessageModal(options);
      }
      console.warn('[FileManager] Message modal is not available.', options);
      return Promise.resolve('closed');
    }

    function escapeHtml(value = '') {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    function getBackupScopeLabel(orgId = '') {
      const token = String(orgId || '').trim();
      if (token.toUpperCase() === 'GLOBAL' || token.toUpperCase() === 'SYSTEM') return 'GLOBAL';
      return `ORG_${token.replace(/^ORG[_-]/i, '')}`;
    }

    function parseDownloadFileName(response, fallbackName = 'org-upload-backup.tar.gz') {
      const disposition = response.headers.get('content-disposition') || '';
      const utfMatch = disposition.match(/filename\*=UTF-8''([^;]+)/i);
      if (utfMatch && utfMatch[1]) return decodeURIComponent(utfMatch[1].trim());
      const match = disposition.match(/filename="?([^"]+)"?/i);
      return (match && match[1] ? match[1].trim() : fallbackName) || fallbackName;
    }

    function looksLikeHtmlResponse(value = '') {
      const token = String(value || '').trim();
      return /^<!doctype html/i.test(token) || /^<html[\s>]/i.test(token);
    }

    function summarizeHtmlError(status = 0, fallbackMessage = 'Operation failed.') {
      if (Number(status) === 404) {
        return 'Backup route was not found. If you are using Railway proxy mode, deploy the latest gateway changes and restart the app.';
      }
      return `The server returned an HTML error page (${status || 'unknown status'}). Please check the server logs.`;
    }

    async function readErrorPayload(response, fallbackMessage = 'Operation failed.') {
      const contentType = response.headers.get('content-type') || '';
      if (contentType.includes('application/json')) {
        const data = await response.json().catch(() => ({}));
        return data.message || fallbackMessage;
      }
      const text = await response.text().catch(() => '');
      if (looksLikeHtmlResponse(text)) return summarizeHtmlError(response.status, fallbackMessage);
      return text ? (text.length > 500 ? `${text.slice(0, 500)}...` : text) : fallbackMessage;
    }

    function normalizeFilePath(value = '') {
      return String(value || '').trim().replace(/\\/g, '/');
    }

    function getVisiblePaneEntries() {
      const pane = viewPanes.find((item) => !item.classList.contains('d-none'));
      if (!pane) return [];
      return Array.from(pane.querySelectorAll('.file-entry[data-file-path]'));
    }

    function setSelectedPath(pathValue, isSelected) {
      const normalized = normalizeFilePath(pathValue);
      if (!normalized) return;
      if (isSelected) selectedFilePaths.add(normalized);
      else selectedFilePaths.delete(normalized);
    }

    function syncFileSelectionUi() {
      fileSelectionInputs.forEach((input) => {
        const pathValue = normalizeFilePath(input.dataset.filePath);
        const checked = pathValue && selectedFilePaths.has(pathValue);
        input.checked = Boolean(checked);
      });

      fileEntryNodes.forEach((entry) => {
        const pathValue = normalizeFilePath(entry.dataset.filePath);
        const selected = pathValue && selectedFilePaths.has(pathValue);
        if (entry.tagName === 'TR') {
          entry.classList.toggle('table-active', Boolean(selected));
        } else {
          entry.classList.toggle('file-entry-selected', Boolean(selected));
        }
      });

      const selectedCount = selectedFilePaths.size;
      if (bulkSelectedCountEl) bulkSelectedCountEl.textContent = String(selectedCount);
      if (bulkCopyBtn) bulkCopyBtn.disabled = selectedCount <= 0;
      if (bulkMoveBtn) bulkMoveBtn.disabled = selectedCount <= 0;
      if (bulkClearBtn) bulkClearBtn.disabled = selectedCount <= 0;
    }

    function getSelectionSummaryLabels(paths = []) {
      const rows = Array.isArray(paths) ? paths : [];
      return rows.map((pathValue) => {
        const token = normalizeFilePath(pathValue);
        return token.split('/').filter(Boolean).pop() || token;
      });
    }

    function openTransferModalForPaths(operation = 'move', sourcePaths = []) {
      if (!transferForm || !transferModal) return;
      const normalized = Array.from(new Set((Array.isArray(sourcePaths) ? sourcePaths : [])
        .map((row) => normalizeFilePath(row))
        .filter(Boolean)));
      if (!normalized.length) return;

      const labels = getSelectionSummaryLabels(normalized);
      const isCopy = operation === 'copy';
      if (transferOperation) transferOperation.value = isCopy ? 'copy' : 'move';
      if (transferSourcePath) transferSourcePath.value = normalized.length === 1 ? normalized[0] : '';
      if (transferSourcePathsJson) transferSourcePathsJson.value = JSON.stringify(normalized);
      if (transferSourceName) transferSourceName.value = labels.join('\n');
      if (transferDestinationPath) {
        const fallbackPath = normalizeFilePath('<%= currentPath %>');
        transferDestinationPath.value = normalizeFilePath(transferDestinationPath.value) || fallbackPath;
      }
      if (transferDestinationHint) {
        transferDestinationHint.textContent = 'Choose a destination folder from the browser modal.';
      }
      if (transferTitle) transferTitle.textContent = isCopy ? 'Copy Selected Items' : 'Move Selected Items';
      if (transferSubmitBtn) transferSubmitBtn.textContent = isCopy ? 'Copy Selected' : 'Move Selected';
      transferForm.action = isCopy ? '/files/copy' : '/files/move';
      transferModal.show();
    }

    async function fetchFolderLibrary(pathValue = '') {
      const queryPath = normalizeFilePath(pathValue);
      const endpoint = queryPath
        ? `/files/folder-library?path=${encodeURIComponent(queryPath)}`
        : '/files/folder-library';
      const response = await fetch(endpoint, {
        method: 'GET',
        headers: ajaxHeaders({
          'Accept': 'application/json'
        })
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok || payload.status !== 'success') {
        throw new Error(payload.message || `Unable to load folders (${response.status}).`);
      }
      return payload;
    }

    function renderFolderPicker() {
      const currentPath = normalizeFilePath(folderPickerState.currentPath);
      if (folderPickerCurrentPathLabel) {
        folderPickerCurrentPathLabel.textContent = currentPath || 'Root';
      }
      if (folderPickerUpBtn) {
        folderPickerUpBtn.disabled = !normalizeFilePath(folderPickerState.parentPath);
      }
      if (folderPickerApplyBtn) {
        folderPickerApplyBtn.disabled = !currentPath;
      }

      if (folderPickerDriveSelect) {
        const existing = Array.from(folderPickerDriveSelect.options).map((opt) => String(opt.value || ''));
        (Array.isArray(folderPickerState.drives) ? folderPickerState.drives : []).forEach((drive) => {
          if (existing.includes(String(drive.id || ''))) return;
          const option = document.createElement('option');
          option.value = String(drive.id || '');
          option.textContent = `${drive.name || drive.id} (${drive.id})`;
          folderPickerDriveSelect.appendChild(option);
        });
        const rootId = currentPath.split('/').filter(Boolean)[0] || '';
        if (rootId) folderPickerDriveSelect.value = rootId;
      }

      if (!folderPickerFolderList) return;
      folderPickerFolderList.innerHTML = '';
      const folders = Array.isArray(folderPickerState.folders) ? folderPickerState.folders : [];
      folders.forEach((folder) => {
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'list-group-item list-group-item-action d-flex justify-content-between align-items-center';
        button.setAttribute('data-folder-picker-open', normalizeFilePath(folder.path));
        button.innerHTML = `
          <span class="text-truncate"><i class="bi bi-folder-fill text-warning me-2"></i>${escapeHtml(folder.name || folder.path)}</span>
          <i class="bi bi-chevron-right text-muted"></i>
        `;
        folderPickerFolderList.appendChild(button);
      });
      if (folderPickerEmptyState) {
        folderPickerEmptyState.classList.toggle('d-none', folders.length > 0);
      }
    }

    async function loadFolderPicker(pathValue = '', options = {}) {
      const requestedPath = normalizeFilePath(pathValue);
      try {
        if (!options.silent && typeof showLoading === 'function') {
          showLoading({
            title: 'Loading folders',
            note: 'Please wait...',
            operation: 'Fetching folder list',
            progress: 55
          });
        }
        const payload = await fetchFolderLibrary(requestedPath);
        folderPickerState.currentPath = normalizeFilePath(payload.currentPath || requestedPath);
        folderPickerState.parentPath = normalizeFilePath(payload.parentPath);
        folderPickerState.drives = Array.isArray(payload.drives) ? payload.drives : [];
        folderPickerState.folders = Array.isArray(payload.folders) ? payload.folders : [];
        renderFolderPicker();
      } finally {
        if (!options.silent && typeof hideLoading === 'function') hideLoading({ force: true });
      }
    }

    function clearDroppedFolderFiles() {
      droppedFolderFiles = [];
      if (folderDropZone) folderDropZone.classList.remove('is-ready');
    }

    function normalizeDroppedPath(pathValue = '', fallbackName = '') {
      const parts = String(pathValue || fallbackName || '')
        .replace(/\\/g, '/')
        .split('/')
        .map((part) => part.trim())
        .filter(Boolean);
      return parts.join('/');
    }

    function getUploadSelection() {
      if (modeFolder && modeFolder.checked) {
        if (droppedFolderFiles.length > 0) {
          return {
            files: droppedFolderFiles.map((row) => row.file),
            relativePaths: droppedFolderFiles.map((row) => normalizeDroppedPath(row.relativePath, row.file?.name)),
            source: 'drop'
          };
        }

        const files = Array.from((folderInput && folderInput.files) || []);
        return {
          files,
          relativePaths: files.map((file) => {
            const rel = typeof file.webkitRelativePath === 'string' ? file.webkitRelativePath.trim() : '';
            return normalizeDroppedPath(rel, file.name);
          }),
          source: 'picker'
        };
      }

      const files = Array.from((filesInput && filesInput.files) || []);
      return {
        files,
        relativePaths: files.map(() => ''),
        source: 'files'
      };
    }

    function readFileEntry(entry) {
      return new Promise((resolve, reject) => {
        entry.file(resolve, reject);
      });
    }

    function readDirectoryEntries(reader) {
      const entries = [];
      return new Promise((resolve, reject) => {
        const readBatch = () => {
          reader.readEntries((batch) => {
            if (!batch.length) {
              resolve(entries);
              return;
            }
            entries.push(...batch);
            readBatch();
          }, reject);
        };
        readBatch();
      });
    }

    async function collectEntryFiles(entry, parentPath = '') {
      if (!entry) return [];

      if (entry.isFile) {
        const file = await readFileEntry(entry);
        return [{
          file,
          relativePath: normalizeDroppedPath([parentPath, file.name].filter(Boolean).join('/'), file.name)
        }];
      }

      if (entry.isDirectory) {
        const nextParent = normalizeDroppedPath([parentPath, entry.name].filter(Boolean).join('/'), entry.name);
        const reader = entry.createReader();
        const children = await readDirectoryEntries(reader);
        const output = [];
        for (const child of children) {
          // eslint-disable-next-line no-await-in-loop
          output.push(...await collectEntryFiles(child, nextParent));
        }
        return output;
      }

      return [];
    }

    async function collectDroppedUploadFiles(dataTransfer) {
      const transferItems = Array.from((dataTransfer && dataTransfer.items) || []);
      const entries = transferItems
        .map((item) => (typeof item.webkitGetAsEntry === 'function' ? item.webkitGetAsEntry() : null))
        .filter(Boolean);

      if (entries.length > 0) {
        const output = [];
        for (const entry of entries) {
          // eslint-disable-next-line no-await-in-loop
          output.push(...await collectEntryFiles(entry, ''));
        }
        return output;
      }

      return Array.from((dataTransfer && dataTransfer.files) || []).map((file) => ({
        file,
        relativePath: normalizeDroppedPath(file.webkitRelativePath || file.name, file.name)
      }));
    }

    const imageGallery = previewTriggers
      .filter((el) => String(el.dataset.kind || '').trim().toLowerCase() === 'image')
      .reduce((acc, el) => {
        const idx = Number.parseInt(String(el.dataset.index || ''), 10);
        if (!Number.isFinite(idx) || idx < 0) return acc;
        if (!acc.some((row) => row.index === idx)) {
          acc.push({
            index: idx,
            url: String(el.dataset.previewUrl || '').trim(),
            name: String(el.dataset.name || 'Image').trim(),
            mimeType: 'image/*'
          });
        }
        return acc;
      }, [])
      .sort((a, b) => a.index - b.index);

    function applyViewMode(requestedView = 'detail') {
      const selected = allowedViews.has(requestedView) ? requestedView : 'detail';
      viewButtons.forEach((btn) => {
        const active = btn.dataset.fileView === selected;
        btn.classList.toggle('active', active);
      });
      viewPanes.forEach((pane) => {
        pane.classList.toggle('d-none', pane.dataset.fileViewPane !== selected);
      });
      try {
        window.localStorage.setItem(VIEW_STORAGE_KEY, selected);
      } catch (_) {}
      syncFileSelectionUi();
    }

    function openPreview(triggerEl) {
      if (!triggerEl) return;
      const kind = String(triggerEl.dataset.kind || 'file').trim().toLowerCase();
      const previewUrl = String(triggerEl.dataset.previewUrl || '').trim();
      const downloadUrl = String(triggerEl.dataset.downloadUrl || '').trim();
      const fileName = String(triggerEl.dataset.name || 'File').trim() || 'File';
      const itemIndex = Number.parseInt(String(triggerEl.dataset.index || ''), 10);
      const targetUrl = previewUrl || downloadUrl;
      if (!targetUrl) return;

      if (kind === 'image' && window.ImageViewer && typeof window.ImageViewer.open === 'function') {
        const galleryIndex = imageGallery.findIndex((row) => row.index === itemIndex);
        window.ImageViewer.open(
          targetUrl,
          fileName,
          'image/*',
          {
            gallery: imageGallery.map((row) => ({ url: row.url, name: row.name, mimeType: row.mimeType })),
            index: galleryIndex >= 0 ? galleryIndex : 0
          }
        );
        return;
      }

      if (kind === 'audio' && window.AudioPreviewModal && typeof window.AudioPreviewModal.open === 'function') {
        window.AudioPreviewModal.open(targetUrl, fileName, 'audio/*');
        return;
      }

      window.open(targetUrl, '_blank', 'noopener');
    }

    viewButtons.forEach((btn) => {
      btn.addEventListener('click', () => {
        applyViewMode(String(btn.dataset.fileView || '').trim());
      });
    });

    previewTriggers.forEach((trigger) => {
      trigger.addEventListener('click', (event) => {
        event.preventDefault();
        openPreview(trigger);
      });
    });

    fileSelectionInputs.forEach((input) => {
      input.addEventListener('change', () => {
        setSelectedPath(input.dataset.filePath, input.checked);
        syncFileSelectionUi();
      });
    });

    bulkSelectVisibleBtn?.addEventListener('click', () => {
      getVisiblePaneEntries().forEach((entry) => {
        setSelectedPath(entry.dataset.filePath, true);
      });
      syncFileSelectionUi();
    });

    bulkUnselectVisibleBtn?.addEventListener('click', () => {
      getVisiblePaneEntries().forEach((entry) => {
        setSelectedPath(entry.dataset.filePath, false);
      });
      syncFileSelectionUi();
    });

    bulkClearBtn?.addEventListener('click', () => {
      selectedFilePaths.clear();
      syncFileSelectionUi();
    });

    bulkCopyBtn?.addEventListener('click', () => {
      openTransferModalForPaths('copy', Array.from(selectedFilePaths.values()));
    });

    bulkMoveBtn?.addEventListener('click', () => {
      openTransferModalForPaths('move', Array.from(selectedFilePaths.values()));
    });

    const savedView = (() => {
      try {
        return String(window.localStorage.getItem(VIEW_STORAGE_KEY) || '').trim();
      } catch (_) {
        return '';
      }
    })();
    applyViewMode(savedView || 'detail');
    syncFileSelectionUi();

    const updateMode = () => {
      if (!modeFiles || !modeFolder || !filesPane || !folderPane) return;
      const folderMode = modeFolder.checked;
      filesPane.classList.toggle('d-none', folderMode);
      folderPane.classList.toggle('d-none', !folderMode);
      if (folderMode) {
        if (filesInput) filesInput.value = '';
      } else {
        clearDroppedFolderFiles();
        if (folderInput) folderInput.value = '';
      }
      updateSelectionSummary();
    };

    const updateSelectionSummary = () => {
      if (!summaryEl) return;
      const selection = getUploadSelection();
      const selected = selection.files;

      if (!selected.length) {
        summaryEl.textContent = 'No items selected.';
        return;
      }

      const totalBytes = selected.reduce((sum, file) => sum + (Number(file.size) || 0), 0);
      const totalMB = (totalBytes / (1024 * 1024)).toFixed(2);
      const sourceText = selection.source === 'drop' ? ' from dropped folder' : '';
      summaryEl.textContent = `${selected.length} file(s) selected${sourceText}, total ${totalMB} MB.`;
    };

    if (modeFiles) modeFiles.addEventListener('change', updateMode);
    if (modeFolder) modeFolder.addEventListener('change', updateMode);
    if (filesInput) filesInput.addEventListener('change', () => {
      updateSelectionSummary();
    });
    if (folderInput) folderInput.addEventListener('change', () => {
      clearDroppedFolderFiles();
      updateSelectionSummary();
    });
    if (folderDropZone) {
      ['dragenter', 'dragover'].forEach((eventName) => {
        folderDropZone.addEventListener(eventName, (event) => {
          event.preventDefault();
          event.stopPropagation();
          folderDropZone.classList.add('is-dragging');
        });
      });
      ['dragleave', 'drop'].forEach((eventName) => {
        folderDropZone.addEventListener(eventName, (event) => {
          event.preventDefault();
          event.stopPropagation();
          folderDropZone.classList.remove('is-dragging');
        });
      });
      folderDropZone.addEventListener('drop', async (event) => {
        try {
          const files = await collectDroppedUploadFiles(event.dataTransfer);
          droppedFolderFiles = files.filter((row) => row && row.file);
          if (folderInput) folderInput.value = '';
          folderDropZone.classList.toggle('is-ready', droppedFolderFiles.length > 0);
          updateSelectionSummary();
          if (!droppedFolderFiles.length) {
            await showFileManagerMessage({
              title: 'No Files Found',
              icon: 'warning',
              message: 'No files were found in the dropped item. Please drop a folder or files.',
              buttons: [{ text: 'OK', class: 'btn-warning' }]
            });
          }
        } catch (error) {
          clearDroppedFolderFiles();
          updateSelectionSummary();
          await showFileManagerMessage({
            title: 'Folder Read Failed',
            icon: 'error',
            message: error.message || 'Unable to read the dropped folder.',
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        }
      });
    }
    updateMode();

    if (orgBackupDownloadBtn && orgBackupOrgId) {
      orgBackupDownloadBtn.addEventListener('click', async () => {
        const orgId = orgBackupOrgId.value || '';
        const scopeLabel = getBackupScopeLabel(orgId);
        if (!orgId) {
          await showFileManagerMessage({
            title: 'Folder Required',
            icon: 'warning',
            message: 'Select an upload folder before downloading a backup.',
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
          return;
        }

        const loadingToken = typeof showLoading === 'function'
          ? showLoading({ title: 'Preparing backup', note: 'Compressing organization files...', operation: 'Creating archive', progress: 20 })
          : null;
        orgBackupDownloadBtn.disabled = true;

        try {
          const body = new URLSearchParams({ orgId });
          const response = await fetch('/files/org-backup/download', {
            method: 'POST',
            headers: ajaxHeaders({
              'Accept': 'application/gzip, application/json',
              'Content-Type': 'application/x-www-form-urlencoded'
            }),
            body: body.toString()
          });
          if (!response.ok) {
            throw new Error(await readErrorPayload(response, 'Backup download failed.'));
          }
          if (typeof updateLoading === 'function') {
            updateLoading({ operation: 'Starting download', progress: 90 });
          }
          const blob = await response.blob();
          const fileName = parseDownloadFileName(response, `org-upload-backup-${scopeLabel}.tar.gz`);
          const url = URL.createObjectURL(blob);
          const link = document.createElement('a');
          link.href = url;
          link.download = fileName;
          document.body.appendChild(link);
          link.click();
          link.remove();
          URL.revokeObjectURL(url);
          await showFileManagerMessage({
            title: 'Backup Ready',
            icon: 'success',
            message: `Backup download started for <code>${escapeHtml(scopeLabel)}</code>.`,
            buttons: [{ text: 'OK', class: 'btn-success' }]
          });
        } catch (error) {
          await showFileManagerMessage({
            title: 'Backup Failed',
            icon: 'error',
            message: escapeHtml(error.message || 'Unable to download organization backup.'),
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        } finally {
          orgBackupDownloadBtn.disabled = false;
          if (typeof hideLoading === 'function') hideLoading(loadingToken || { force: true });
        }
      });
    }

    if (orgBackupRestoreForm && orgBackupOrgId && orgBackupFileInput) {
      orgBackupRestoreForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const orgId = orgBackupOrgId.value || '';
        const scopeLabel = getBackupScopeLabel(orgId);
        const file = orgBackupFileInput.files && orgBackupFileInput.files[0];
        if (!orgId) {
          await showFileManagerMessage({
            title: 'Folder Required',
            icon: 'warning',
            message: 'Select an upload folder before restoring a backup.',
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
          return;
        }
        if (!file) {
          await showFileManagerMessage({
            title: 'Backup Required',
            icon: 'warning',
            message: 'Select a compressed organization backup file first.',
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
          return;
        }
        if (Number(file.size || 0) > ORG_FILE_BACKUP_RESTORE_MAX_BYTES) {
          await showFileManagerMessage({
            title: 'Backup File Too Large',
            icon: 'warning',
            message: `Selected file is too large. Maximum upload size is <b>${ORG_FILE_BACKUP_RESTORE_MAX_MB} MB</b>.`,
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
          return;
        }

        const selectedLabel = orgBackupOrgId.selectedOptions && orgBackupOrgId.selectedOptions[0]
          ? orgBackupOrgId.selectedOptions[0].textContent
          : scopeLabel;
        const choice = await showFileManagerMessage({
          title: 'Replace Organization Files?',
          icon: 'warning',
          message: `This will permanently replace all current files under <code>${escapeHtml(scopeLabel)}</code> with the contents of <code>${escapeHtml(file.name)}</code>.<br><br>Selected folder: <b>${escapeHtml(selectedLabel)}</b>`,
          buttons: [
            { text: 'Cancel', class: 'btn-secondary' },
            { text: 'Restore Backup', class: 'btn-danger' }
          ]
        });
        if (choice !== 'Restore Backup') return;

        let loadingToken = null;
        if (orgBackupRestoreBtn) orgBackupRestoreBtn.disabled = true;

        try {
          if (typeof window.requestProtectedAction !== 'function') {
            throw new Error('Admin verification system is not loaded. Please refresh the page and try again.');
          }
          await window.requestProtectedAction();

          loadingToken = typeof showLoading === 'function'
            ? showLoading({
              title: 'Restoring backup',
              note: 'Uploading archive and replacing organization files...',
              operation: 'Uploading backup',
              progress: 15
            })
            : null;

          const formData = new FormData();
          formData.append('orgId', orgId);
          formData.append('backupFile', file);
          const response = await fetch('/files/org-backup/restore', {
            method: 'POST',
            headers: ajaxHeaders({ 'Accept': 'application/json' }),
            body: formData
          });
          const data = await response.json().catch(() => ({}));
          if (!response.ok || data.status !== 'success') {
            throw new Error(data.message || 'Backup restore failed.');
          }
          if (typeof updateLoading === 'function') {
            updateLoading({ operation: 'Refreshing', progress: 95 });
          }
          await showFileManagerMessage({
            title: 'Restore Complete',
            icon: 'success',
            message: data.message || 'Organization files restored successfully.',
            buttons: [{ text: 'OK', class: 'btn-success' }]
          });
          window.location.reload();
        } catch (error) {
          if (error && error.code === 'ADMIN_VERIFICATION_CANCELLED') return;
          const rawMessage = String(error?.message || 'Unable to restore organization backup.');
          let displayMessage = rawMessage;
          const remoteLimitMatch = rawMessage.match(/Maximum upload size is\s+(\d+)\s*MB/i);
          if (remoteLimitMatch) {
            const remoteLimitMb = Number.parseInt(remoteLimitMatch[1], 10);
            if (Number.isFinite(remoteLimitMb) && remoteLimitMb !== ORG_FILE_BACKUP_RESTORE_MAX_MB) {
              displayMessage = `${rawMessage}<br><br><span class="text-muted">This browser is configured for <b>${ORG_FILE_BACKUP_RESTORE_MAX_MB} MB</b>, but the restore endpoint currently enforces <b>${remoteLimitMb} MB</b>. Update <code>ORG_FILE_BACKUP_RESTORE_MAX_MB</code> on the active gateway/app service and restart it.</span>`;
            }
          }
          await showFileManagerMessage({
            title: 'Restore Failed',
            icon: 'error',
            message: displayMessage,
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        } finally {
          if (orgBackupRestoreBtn) orgBackupRestoreBtn.disabled = false;
          if (typeof hideLoading === 'function') hideLoading(loadingToken || { force: true });
        }
      });
    }

    if (createFolderForm) {
      createFolderForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new URLSearchParams(new FormData(createFolderForm));
        const submitBtn = createFolderForm.querySelector('button[type="submit"]');
        const loadingToken = typeof showLoading === 'function'
          ? showLoading({ title: 'Creating folder', note: 'Please wait...', operation: 'Validating', progress: 10 })
          : null;

        if (submitBtn) submitBtn.disabled = true;

        try {
          if (typeof updateLoading === 'function') {
            updateLoading({ operation: 'Creating folder', progress: 55 });
          }
          const resp = await fetch('/files/create-folder', {
            method: 'POST',
            headers: ajaxHeaders({
              'Accept': 'application/json',
              'Content-Type': 'application/x-www-form-urlencoded'
            }),
            body: formData.toString()
          });
          const data = await resp.json();
          if (!resp.ok || data.status !== 'success') {
            throw new Error(data.message || 'Failed to create folder.');
          }
          if (typeof updateLoading === 'function') {
            updateLoading({ operation: 'Refreshing', progress: 95 });
          }
          await showFileManagerMessage({
            title: 'Folder Created',
            icon: 'success',
            message: data.message || 'Folder created successfully.',
            buttons: [{ text: 'OK', class: 'btn-success' }]
          });
          window.location.reload();
        } catch (error) {
          await showFileManagerMessage({
            title: 'Create Folder Failed',
            icon: 'error',
            message: error.message || 'Unable to create folder.',
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        } finally {
          if (submitBtn) submitBtn.disabled = false;
          if (typeof hideLoading === 'function') hideLoading(loadingToken || { force: true });
        }
      });
    }

    if (uploadForm) {
      uploadForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const submitBtn = uploadForm.querySelector('button[type="submit"]');
        const uploadSelection = getUploadSelection();
        const selectedFiles = uploadSelection.files;

        if (!selectedFiles.length) {
          await showFileManagerMessage({
            title: 'No Files Selected',
            icon: 'warning',
            message: 'Please choose files or a folder to upload.',
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
          return;
        }

        const relativePaths = uploadSelection.relativePaths;
        if (relativePathsInput) {
          relativePathsInput.value = JSON.stringify(relativePaths);
        }

        const formData = new FormData();
        const currentPathInput = uploadForm.querySelector('input[name="path"]');
        formData.append('path', currentPathInput ? currentPathInput.value : '');
        formData.append('relativePathsJson', JSON.stringify(relativePaths));
        selectedFiles.forEach((file) => {
          formData.append('files', file, file.name);
        });

        if (submitBtn) submitBtn.disabled = true;
        const totalCount = selectedFiles.length;
        const loadingToken = typeof showLoading === 'function'
          ? showLoading({
            title: 'Uploading files',
            note: `Preparing ${totalCount} file(s)...`,
            operation: `Preparing (0/${totalCount})`,
            progress: 5
          })
          : null;

        try {
          if (typeof updateLoading === 'function') {
            updateLoading({
              operation: `Creating folders (${totalCount} file target(s))`,
              progress: 15
            });
          }

          const result = await new Promise((resolve, reject) => {
            const xhr = new XMLHttpRequest();
            xhr.open('POST', '/files/upload', true);
            xhr.setRequestHeader('X-AJAX-Request', 'true');

            xhr.upload.onprogress = (eventProgress) => {
              if (!eventProgress.lengthComputable || typeof updateLoading !== 'function') return;
              const ratio = eventProgress.total > 0 ? (eventProgress.loaded / eventProgress.total) : 0;
              const progress = Math.min(90, Math.max(20, Math.round(ratio * 90)));
              updateLoading({
                operation: `Uploading (${totalCount} file(s))`,
                progress
              });
            };

            xhr.onload = () => {
              let body = {};
              try {
                body = JSON.parse(xhr.responseText || '{}');
              } catch (_) {
                body = {};
              }
              if (xhr.status >= 200 && xhr.status < 300) {
                resolve(body);
              } else {
                const rawText = String(xhr.responseText || '').replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
                const detail = rawText && rawText.length < 260 ? ` ${rawText}` : '';
                reject(new Error(body.message || `Upload failed (${xhr.status || 'network'}).${detail}`));
              }
            };

            xhr.onerror = () => reject(new Error('Network error during upload.'));
            xhr.send(formData);
          });

          if (typeof updateLoading === 'function') {
            updateLoading({ operation: 'Finalizing', progress: 98 });
          }

          const uploadedCount = Number(result.uploadedCount || 0);
          const renamedCount = Number(result.renamedCount || 0);
          const skippedCount = Number(result.skippedCount || 0);
          const statusLine = `Uploaded: ${uploadedCount}, Renamed: ${renamedCount}, Skipped: ${skippedCount}`;

          let details = statusLine;
          if (Array.isArray(result.renamedFiles) && result.renamedFiles.length > 0) {
            const renamedPreview = result.renamedFiles
              .slice(0, 8)
              .map((row) => `${row.from} -> ${row.to}`)
              .join('<br>');
            details += `<br><br><strong>Renamed files:</strong><br>${renamedPreview}`;
            if (result.renamedFiles.length > 8) {
              details += `<br>...and ${result.renamedFiles.length - 8} more.`;
            }
          }

          if (Array.isArray(result.errors) && result.errors.length > 0) {
            const errorPreview = result.errors
              .slice(0, 5)
              .map((row) => `${row.fileName || 'File'}: ${row.message}`)
              .join('<br>');
            details += `<br><br><strong>Errors:</strong><br>${errorPreview}`;
          }

          await showFileManagerMessage({
            title: result.status === 'partial' ? 'Upload Completed with Warnings' : 'Upload Completed',
            icon: result.status === 'partial' ? 'warning' : 'success',
            message: details,
            buttons: [{ text: 'OK', class: result.status === 'partial' ? 'btn-warning' : 'btn-success' }]
          });

          window.location.reload();
        } catch (error) {
          await showFileManagerMessage({
            title: 'Upload Failed',
            icon: 'error',
            message: error.message || 'Unable to upload files.',
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        } finally {
          if (submitBtn) submitBtn.disabled = false;
          if (typeof hideLoading === 'function') hideLoading(loadingToken || { force: true });
        }
      });
    }

    transferBrowseDestinationBtn?.addEventListener('click', async () => {
      const requestedPath = normalizeFilePath(transferDestinationPath?.value || '<%= currentPath %>');
      try {
        await loadFolderPicker(requestedPath, { silent: false });
        folderPickerModal?.show();
      } catch (error) {
        await showFileManagerMessage({
          title: 'Folder Browser Failed',
          icon: 'error',
          message: error.message || 'Unable to load destination folders.',
          buttons: [{ text: 'OK', class: 'btn-danger' }]
        });
      }
    });

    folderPickerDriveSelect?.addEventListener('change', async () => {
      const driveId = normalizeFilePath(folderPickerDriveSelect.value);
      if (!driveId) return;
      try {
        await loadFolderPicker(driveId, { silent: true });
      } catch (error) {
        await showFileManagerMessage({
          title: 'Folder Browser Failed',
          icon: 'error',
          message: error.message || 'Unable to switch drive.',
          buttons: [{ text: 'OK', class: 'btn-danger' }]
        });
      }
    });

    folderPickerUpBtn?.addEventListener('click', async () => {
      const parentPath = normalizeFilePath(folderPickerState.parentPath);
      if (!parentPath) return;
      try {
        await loadFolderPicker(parentPath, { silent: true });
      } catch (error) {
        await showFileManagerMessage({
          title: 'Folder Browser Failed',
          icon: 'error',
          message: error.message || 'Unable to open parent folder.',
          buttons: [{ text: 'OK', class: 'btn-danger' }]
        });
      }
    });

    folderPickerFolderList?.addEventListener('click', async (event) => {
      const button = event.target.closest('[data-folder-picker-open]');
      if (!button) return;
      const nextPath = normalizeFilePath(button.getAttribute('data-folder-picker-open'));
      if (!nextPath) return;
      try {
        await loadFolderPicker(nextPath, { silent: true });
      } catch (error) {
        await showFileManagerMessage({
          title: 'Folder Browser Failed',
          icon: 'error',
          message: error.message || 'Unable to open selected folder.',
          buttons: [{ text: 'OK', class: 'btn-danger' }]
        });
      }
    });

    folderPickerApplyBtn?.addEventListener('click', () => {
      const selectedPath = normalizeFilePath(folderPickerState.currentPath);
      if (!selectedPath || !transferDestinationPath) return;
      transferDestinationPath.value = selectedPath;
      if (transferDestinationHint) {
        transferDestinationHint.textContent = `Destination selected: ${selectedPath}`;
      }
      folderPickerModal?.hide();
    });

    document.querySelectorAll('.file-transfer-item').forEach((btn) => {
      btn.addEventListener('click', () => {
        const operation = String(btn.dataset.operation || 'move').trim().toLowerCase() === 'copy' ? 'copy' : 'move';
        const sourcePath = String(btn.dataset.path || '').trim();
        if (!sourcePath) return;
        openTransferModalForPaths(operation, [sourcePath]);
      });
    });

    if (transferForm) {
      transferForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const operation = String(transferOperation?.value || 'move').trim().toLowerCase() === 'copy' ? 'copy' : 'move';
        const endpoint = operation === 'copy' ? '/files/copy' : '/files/move';
        const formData = new URLSearchParams(new FormData(transferForm));
        const loadingToken = typeof showLoading === 'function'
          ? showLoading({
            title: operation === 'copy' ? 'Copying items' : 'Moving items',
            note: 'Please wait...',
            operation: operation === 'copy' ? 'Copying items' : 'Moving items',
            progress: 55
          })
          : null;

        if (transferSubmitBtn) transferSubmitBtn.disabled = true;

        try {
          const resp = await fetch(endpoint, {
            method: 'POST',
            headers: ajaxHeaders({
              'Accept': 'application/json',
              'Content-Type': 'application/x-www-form-urlencoded'
            }),
            body: formData.toString()
          });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || !['success', 'partial'].includes(String(data.status || ''))) {
            throw new Error(data.message || (operation === 'copy' ? 'Failed to copy items.' : 'Failed to move items.'));
          }
          if (typeof updateLoading === 'function') {
            updateLoading({ operation: 'Refreshing', progress: 95 });
          }
          if (transferModal) transferModal.hide();
          let message = data.message || (operation === 'copy' ? 'Items copied successfully.' : 'Items moved successfully.');
          if (data.summary && typeof data.summary === 'object') {
            const requested = Number(data.summary.requested || 0);
            const succeeded = Number(data.summary.succeeded || 0);
            const failed = Number(data.summary.failed || 0);
            message += `<br><br><strong>Summary:</strong> ${succeeded}/${requested} succeeded, ${failed} failed.`;
          }
          if (Array.isArray(data.results) && data.results.length > 0 && String(data.status || '') === 'partial') {
            const failures = data.results
              .filter((row) => String(row?.status || '') === 'error')
              .slice(0, 8)
              .map((row) => `${escapeHtml(String(row.sourcePath || 'Item'))}: ${escapeHtml(String(row.message || 'Error'))}`)
              .join('<br>');
            if (failures) {
              message += `<br><br><strong>Failures:</strong><br>${failures}`;
            }
          }
          await showFileManagerMessage({
            title: operation === 'copy' ? 'Copy Completed' : 'Move Completed',
            icon: String(data.status || '') === 'partial' ? 'warning' : 'success',
            message,
            buttons: [{ text: 'OK', class: String(data.status || '') === 'partial' ? 'btn-warning' : 'btn-success' }]
          });
          selectedFilePaths.clear();
          syncFileSelectionUi();
          window.location.reload();
        } catch (error) {
          await showFileManagerMessage({
            title: operation === 'copy' ? 'Copy Failed' : 'Move Failed',
            icon: 'error',
            message: error.message || (operation === 'copy' ? 'Unable to copy items.' : 'Unable to move items.'),
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        } finally {
          if (transferSubmitBtn) transferSubmitBtn.disabled = false;
          if (typeof hideLoading === 'function') hideLoading(loadingToken || { force: true });
        }
      });
    }

    document.querySelectorAll('.file-rename-item').forEach((btn) => {
      btn.addEventListener('click', () => {
        const sourcePath = String(btn.dataset.path || '').trim();
        const sourceName = String(btn.dataset.name || sourcePath.split('/').pop() || 'Item').trim();
        if (!sourcePath || !renameForm) return;

        if (renameSourcePath) renameSourcePath.value = sourcePath;
        if (renameSourceName) renameSourceName.value = sourceName;
        if (renameNewName) renameNewName.value = sourceName;
        if (renameModal) renameModal.show();
        if (renameNewName) {
          setTimeout(() => {
            renameNewName.focus({ preventScroll: true });
            renameNewName.select();
          }, 160);
        }
      });
    });

    if (renameForm) {
      renameForm.addEventListener('submit', async (event) => {
        event.preventDefault();
        const formData = new URLSearchParams(new FormData(renameForm));
        const loadingToken = typeof showLoading === 'function'
          ? showLoading({
            title: 'Renaming item',
            note: 'Please wait...',
            operation: 'Renaming item',
            progress: 55
          })
          : null;

        if (renameSubmitBtn) renameSubmitBtn.disabled = true;

        try {
          const resp = await fetch('/files/rename', {
            method: 'POST',
            headers: ajaxHeaders({
              'Accept': 'application/json',
              'Content-Type': 'application/x-www-form-urlencoded'
            }),
            body: formData.toString()
          });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || data.status !== 'success') {
            throw new Error(data.message || 'Failed to rename item.');
          }
          if (typeof updateLoading === 'function') {
            updateLoading({ operation: 'Refreshing', progress: 95 });
          }
          if (renameModal) renameModal.hide();
          await showFileManagerMessage({
            title: 'Item Renamed',
            icon: 'success',
            message: data.message || 'Item renamed successfully.',
            buttons: [{ text: 'OK', class: 'btn-success' }]
          });
          window.location.reload();
        } catch (error) {
          await showFileManagerMessage({
            title: 'Rename Failed',
            icon: 'error',
            message: error.message || 'Unable to rename item.',
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        } finally {
          if (renameSubmitBtn) renameSubmitBtn.disabled = false;
          if (typeof hideLoading === 'function') hideLoading(loadingToken || { force: true });
        }
      });
    }

    document.querySelectorAll('.delete-item').forEach((btn) => {
      btn.addEventListener('click', async (event) => {
        const targetPath = event.currentTarget.dataset.path;
        if (!targetPath) return;

        const result = await showFileManagerMessage({
          title: 'Delete Item',
          message: 'Are you sure you want to delete this item permanently?<br>This cannot be undone.',
          icon: 'warning',
          buttons: [
            { text: 'Cancel', class: 'btn-secondary', value: false },
            { text: 'Delete', class: 'btn-danger', value: true }
          ]
        });
        const confirmed = (result === 'Delete');
        if (!confirmed) return;

        const loadingToken = typeof showLoading === 'function'
          ? showLoading({ title: 'Deleting item', note: 'Please wait...', operation: 'Deleting item', progress: 65 })
          : null;

        try {
          const resp = await fetch(`/files/delete/dummy?path=${encodeURIComponent(targetPath)}`, {
            method: 'POST',
            headers: ajaxHeaders({ 'Accept': 'application/json' })
          });
          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || data.status !== 'success') {
            throw new Error(data.message || 'Failed to delete item.');
          }
          if (typeof updateLoading === 'function') {
            updateLoading({ operation: 'Refreshing', progress: 95 });
          }
          window.location.reload();
        } catch (error) {
          await showFileManagerMessage({
            title: 'Delete Failed',
            message: error.message || 'Unable to delete item.',
            icon: 'error',
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        } finally {
          if (typeof hideLoading === 'function') hideLoading(loadingToken || { force: true });
        }
      });
    });
  });
</script>

