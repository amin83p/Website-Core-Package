<%- include('../partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print
}) %>

<%- include('../partials/tablePages-search', {
  placeholder: 'Search organizations...',
  fields: searchableFields || [
    'id',
    'identity.displayName',
    'identity.legalName',
    'identity.type',
    'contact.email',
    'contact.address.city',
    'contact.address.country',
    'billing.plan',
    'billing.status',
    'domain.primaryDomain',
    'notes'
  ]
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4 draggable" data-column="id">ID <span class="sort-icon"></span></th>
        <th class="draggable" data-column="name">Organization <span class="sort-icon"></span></th>
        <th class="draggable" data-column="plan">Plan <span class="sort-icon"></span></th>
        <th class="draggable" data-column="contracts">Contracts <span class="sort-icon"></span></th>
        <th class="draggable" data-column="email">Contact <span class="sort-icon"></span></th>
        <th class="draggable" data-column="active">Active <span class="sort-icon"></span></th>
        <th class="draggable" data-column="createDateTime">Created <span class="sort-icon"></span></th>
        <th class="draggable" data-column="lastUpdateDateTime">Updated <span class="sort-icon"></span></th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (data && data.length > 0) { %>
        <% data.forEach(org => { %>
          <tr>
            <td class="ps-4">
              <span class="font-monospace"><%= org.id %></span>
            </td>

            <td>
              <div class="fw-bold text-dark"><%= org.identity?.displayName || 'N/A' %></div>
              <% if (org.identity?.legalName && org.identity.legalName !== org.identity.displayName) { %>
                <div class="text-muted x-small"><%= org.identity.legalName %></div>
              <% } %>
              <% if (org.identity?.type) { %>
                <div class="x-small text-muted mt-1"><%= org.identity.type %></div>
              <% } %>
            </td>

            <td>
              <% const plan = org.billing?.plan || 'free'; %>
              <span class="badge <%= plan === 'enterprise' || plan === 'paid' ? 'bg-primary' : 'bg-light text-dark border' %>">
                <%= plan.toUpperCase() %>
              </span>
              <div class="x-small text-muted mt-1"><%= org.billing?.status || 'n/a' %></div>
            </td>

            <td>
              <% const count = Number(org.contractCount || 0); %>
              <span class="badge <%= count > 0 ? 'bg-success' : 'bg-light text-dark border' %>"><%= count %></span>
              <% if (count > 0) { %>
                <div class="x-small mt-1">
                  <a href="/contracts?q=<%= encodeURIComponent(org.id) %>&type=exact_match&searchFields=orgId">View</a>
                </div>
              <% } %>
            </td>

            <td>
              <div><%= org.contact?.email || 'N/A' %></div>
              <% if (org.contact?.phone) { %>
                <div class="x-small text-muted"><%= org.contact.phone %></div>
              <% } %>
            </td>

            <td>
              <% if (org.active) { %>
                <span class="badge bg-success">Active</span>
              <% } else { %>
                <span class="badge bg-secondary">Inactive</span>
              <% } %>
            </td>

            <% const audit = org.audit || {}; %>
            <td>
              <% if (audit.createDateTime) { %>
                <%= typeof formatOrgDateTime === 'function' ? formatOrgDateTime(audit.createDateTime) : new Date(audit.createDateTime).toLocaleString() %>
                <% if (audit.createUser) { %>
                  <div class="text-muted x-small">by <%= audit.createUser %></div>
                <% } %>
              <% } else { %>
                <span class="text-muted">N/A</span>
              <% } %>
            </td>

            <td>
              <% if (audit.lastUpdateDateTime) { %>
                <%= typeof formatOrgDateTime === 'function' ? formatOrgDateTime(audit.lastUpdateDateTime) : new Date(audit.lastUpdateDateTime).toLocaleString() %>
                <% if (audit.lastUpdateUser) { %>
                  <div class="text-muted x-small">by <%= audit.lastUpdateUser %></div>
                <% } %>
              <% } else { %>
                <span class="text-muted">N/A</span>
              <% } %>
            </td>

            <td class="table-actions text-end pe-4">
              <div class="row-actions-wrap">
                <button
                  type="button"
                  class="btn btn-secondary btn-sm btn-row-actions-toggle"
                  data-row-actions-id="<%= org.id %>"
                  title="Row actions">
                  <i class="bi bi-three-dots-vertical"></i>
                </button>
                <div class="row-actions-menu d-none" data-row-actions-id="<%= org.id %>">
                  <a href="/<%=newUrl%>/edit/<%= org.id %>" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-pencil-square me-2"></i>Edit
                  </a>
                  <button
                    type="button"
                    class="btn btn-outline-danger btn-sm org-purge-btn"
                    data-id="<%= org.id %>"
                    data-name="<%= org.identity?.displayName || org.identity?.legalName || org.name || org.id %>">
                    <i class="bi bi-trash me-2"></i>Delete
                  </button>
                </div>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="9" class="text-center py-4 text-muted">
            No organizations found.
          </td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/pagination', {
    pagination: pagination,
    filters: filters,
    baseUrlPath: newUrl
}) %>

<%- include('../partials/tablePages-end') %>

<div class="modal fade" id="orgPurgeModal" tabindex="-1" aria-labelledby="orgPurgeModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header border-danger-subtle">
        <h5 class="modal-title" id="orgPurgeModalLabel">
          <i class="bi bi-exclamation-triangle text-danger me-2"></i>Delete Organization
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="small text-muted mb-3">
          Organization: <strong id="orgPurgeOrgName">-</strong>
          <span class="font-monospace text-muted ms-2" id="orgPurgeOrgId"></span>
        </div>

        <ul class="nav nav-pills gap-1 mb-3 small" id="orgPurgeSteps">
          <li class="nav-item"><span class="nav-link disabled py-1 px-2 active" data-step="1">1. Scan</span></li>
          <li class="nav-item"><span class="nav-link disabled py-1 px-2" data-step="2">2. Review</span></li>
          <li class="nav-item"><span class="nav-link disabled py-1 px-2" data-step="3">3. Confirm</span></li>
          <li class="nav-item"><span class="nav-link disabled py-1 px-2" data-step="4">4. Delete</span></li>
        </ul>

        <div class="org-purge-pane" data-pane="1">
          <div class="text-center py-5" id="orgPurgeScanState">
            <div class="spinner-border text-danger mb-3" role="status"></div>
            <div class="fw-semibold">Scanning collections, files, and memberships…</div>
            <div class="small text-muted mt-1">This may take a moment for large organizations.</div>
          </div>
          <div class="alert alert-danger d-none" id="orgPurgeScanError"></div>
        </div>

        <div class="org-purge-pane d-none" data-pane="2">
          <div class="alert alert-warning">
            <div class="fw-semibold">The following org-scoped data will be permanently deleted.</div>
            <div class="small mb-0" id="orgPurgeTotals">-</div>
          </div>
          <div id="orgPurgeCategoryList" class="d-flex flex-column gap-2"></div>
        </div>

        <div class="org-purge-pane d-none" data-pane="3">
          <div class="alert alert-danger">
            <div class="fw-bold">This cannot be undone.</div>
            <div class="small mb-0">
              Type the organization name exactly to continue:
              <span class="fw-semibold" id="orgPurgeConfirmExpected"></span>
            </div>
          </div>
          <label class="form-label fw-semibold" for="orgPurgeConfirmInput">Organization name</label>
          <input type="text" class="form-control" id="orgPurgeConfirmInput" autocomplete="off">
          <div class="form-check mt-3">
            <input class="form-check-input" type="checkbox" id="orgPurgeConfirmCheck">
            <label class="form-check-label" for="orgPurgeConfirmCheck">
              I understand this permanently deletes the organization and all listed related data.
            </label>
          </div>
          <div class="alert alert-warning mt-3 mb-0 small">
            <i class="bi bi-shield-lock me-1"></i>
            Deleting will also require admin verification (authenticator / admin code) before the purge runs.
          </div>
        </div>

        <div class="org-purge-pane d-none" data-pane="4">
          <div id="orgPurgeProgressList" class="d-flex flex-column gap-2"></div>
          <div class="alert mt-3 d-none" id="orgPurgeResultAlert"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" id="orgPurgeCloseBtn">Cancel</button>
        <button type="button" class="btn btn-outline-primary d-none" id="orgPurgeBackBtn">Back</button>
        <button type="button" class="btn btn-primary d-none" id="orgPurgeNextBtn">Continue</button>
        <button type="button" class="btn btn-danger d-none" id="orgPurgeExecuteBtn" disabled>Delete permanently</button>
      </div>
    </div>
  </div>
</div>
