<div class="sections-page">
  <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-4">
    <div>
      <h1 class="page-heading size-md m-0 text-start"><i class="bi bi-sliders me-2"></i> Attendance matrix thresholds</h1>
      <p class="text-muted small mb-0 mt-1">
        These values apply to the <strong>time-based efficiency %</strong> on the Attendance Matrix for your active organization
        <span class="badge bg-light text-secondary border ms-1">Org: <%= policyOrgKey %></span>
      </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <a href="/school/attendances" class="school-navigator-dashboard btn btn-outline-secondary btn-sm">
        <i class="bi bi-grid-3x3 me-1"></i> Attendance Matrix
      </a>
      <a href="<%= schoolSectionDashboardHref %>" class="school-navigator-dashboard btn btn-filled btn-secondary btn-sm">
        <i class="bi bi-speedometer2 me-1"></i> Dashboard
      </a>
    </div>
  </div>

  <% if (typeof saved !== 'undefined' && saved) { %>
    <div class="alert alert-success border-0 shadow-sm">Settings saved. They are used immediately for new matrix loads.</div>
  <% } %>
  <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
    <div class="alert alert-danger border-0 shadow-sm"><%= errorMessage %></div>
  <% } %>

  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <form method="post" action="/school/attendances/settings" class="row g-4">
        <% if (typeof actionStateId !== 'undefined' && actionStateId) { %>
          <input type="hidden" name="actionStateId" value="<%= actionStateId %>">
        <% } %>

        <div class="col-12">
          <label class="form-label fw-bold" for="scheduledMinutes">Default scheduled minutes (fallback)</label>
          <input type="number" class="form-control" id="scheduledMinutes" name="scheduledMinutes" min="1" max="1440" step="1"
            value="<%= policy.scheduledMinutes %>">
          <div class="form-text">Each session normally uses its <code>startTime</code>/<code>endTime</code> or <code>durationHours</code> from the class session. This value is used only when those are missing or invalid.</div>
        </div>

        <div class="col-md-6">
          <label class="form-label fw-bold" for="disqualifyLateMinutes">Disqualify if late ≥ (minutes)</label>
          <input type="number" class="form-control" id="disqualifyLateMinutes" name="disqualifyLateMinutes" min="0" max="1440" step="1"
            value="<%= policy.disqualifyLateMinutes %>">
          <div class="form-text">Session credit becomes 0% if lateness reaches or exceeds this (independent rule).</div>
        </div>

        <div class="col-md-6">
          <label class="form-label fw-bold" for="disqualifyEarlyLeaveMinutes">Disqualify if early leave ≥ (minutes)</label>
          <input type="number" class="form-control" id="disqualifyEarlyLeaveMinutes" name="disqualifyEarlyLeaveMinutes" min="0" max="1440" step="1"
            value="<%= policy.disqualifyEarlyLeaveMinutes %>">
          <div class="form-text">Session credit becomes 0% if early departure reaches or exceeds this (independent rule).</div>
        </div>

        <div class="col-12">
          <div class="form-check mb-2">
            <input class="form-check-input" type="checkbox" id="useCombinedThreshold" name="useCombinedThreshold" value="on"
              <%= policy.disqualifyCombinedMissedMinutes != null ? 'checked' : '' %>>
            <label class="form-check-label fw-bold" for="useCombinedThreshold">
              Also disqualify when combined late + early leave exceeds a limit
            </label>
          </div>
          <label class="form-label" for="disqualifyCombinedMissedMinutes">Combined missed minutes threshold</label>
          <input type="number" class="form-control" style="max-width: 220px;" id="disqualifyCombinedMissedMinutes" name="disqualifyCombinedMissedMinutes"
            min="1" max="1440" step="1"
            value="<%= policy.disqualifyCombinedMissedMinutes != null ? policy.disqualifyCombinedMissedMinutes : '' %>"
            placeholder="e.g. 45">
          <div class="form-text">If enabled, when <code>late + early leave</code> ≥ this value, the session scores 0%. Leave unchecked to disable.</div>
        </div>

        <div class="col-12 border-top pt-3">
          <button type="submit" class="btn btn-primary fw-bold">
            <i class="bi bi-save me-1"></i> Save settings
          </button>
        </div>
      </form>
    </div>
  </div>

  <div class="card border-0 bg-light mt-4">
    <div class="card-body small text-muted">
      <div class="fw-bold text-secondary mb-1">How this is applied</div>
      <ul class="mb-0 ps-3">
        <li>Class-level <code>attendancePolicy</code> on a class record still overrides these org defaults when set (including this fallback length).</li>
        <li>Absent → 0%; excused → full session weight; present/late → proportional minutes unless a cutoff applies.</li>
      </ul>
    </div>
  </div>
</div>
