<%- include('../../partials/tablePages-start', {
  title,
  newUrl: 'school/teachers/archived',
  newLabel: 'Recover Teacher',
  user,
  tableName,
  btn_export: true,
  print,
  manageBtns: [
    `<a href="/school/teachers" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-arrow-left me-1"></i> Teacher Directory</a>`
  ]
}) %>

<%- include('../../partials/tablePages-search', {
  placeholder: 'Search archived teachers...',
  fields: [
    { name: 'employmentType', label: 'Employment', type: 'select', options: ['Full-Time', 'Part-Time', 'Contract', 'Sessional', 'Substitute'] }
  ]
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Teacher</th>
        <th>Contact</th>
        <th>Department</th>
        <th>Employment</th>
        <th class="text-center">Status</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length === 0) { %>
         <tr><td colspan="6" class="text-center py-4 text-muted">No archived teachers found.</td></tr>
      <% } %>
      <% data.forEach(item => { %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-primary"><%= item.firstName %> <%= item.lastName %></div>
            <div class="small text-muted font-monospace"><i class="bi bi-person-badge me-1"></i><%= item.id %></div>
          </td>
          <td class="small text-muted">
            <div><i class="bi bi-envelope me-1"></i><%= item.email %></div>
            <div><i class="bi bi-telephone me-1"></i><%= item.phone %></div>
          </td>
          <td class="small"><%= item.departmentName || '-' %></td>
          <td class="small"><%= item.employmentType || '-' %></td>
          <td class="text-center"><span class="badge bg-secondary">ARCHIVED</span></td>
          <td class="table-actions text-end pe-4">
            <button class="btn btn-sm btn-filled btn-edit recover-btn" data-id="<%= item.id %>">
              <i class="bi bi-arrow-counterclockwise me-1"></i>Recover
            </button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/teachers/archived" hidden></span>
<span id="actionStateRef" data-id="<%= actionStateId || '' %>" hidden></span>
<%- include('../../partials/pagination', { pagination, filters, baseUrlPath: 'school/teachers/archived' }) %>
<%- include('../../partials/tablePages-end') %>

<script>
(function () {
  function showMsg(opts) {
    if (typeof showMessageModal === 'function') return showMessageModal(opts);
    alert(opts?.message || 'Done');
    return Promise.resolve('OK');
  }

  function askConfirm(message) {
    if (typeof showMessageModal !== 'function') return Promise.resolve(confirm(message.replace(/<[^>]+>/g, '')));
    return showMessageModal({
      title: 'Recover Teacher',
      icon: 'question',
      message,
      buttons: [
        { text: 'Cancel', class: 'btn-secondary' },
        { text: 'Recover', class: 'btn-success' }
      ]
    }).then(v => v === 'Recover');
  }

  document.addEventListener('DOMContentLoaded', function () {
    const token = document.getElementById('actionStateRef')?.dataset?.id || '';
    document.querySelectorAll('.recover-btn').forEach((btn) => {
      btn.addEventListener('click', async function () {
        const id = btn.dataset.id;
        if (!id) return;
        const ok = await askConfirm('Recover this archived teacher and reactivate linked account?');
        if (!ok) return;

        const original = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Recovering...';

        try {
          const response = await fetch(`/school/teachers/recover/${encodeURIComponent(id)}?actionStateId=${encodeURIComponent(token)}`, {
            method: 'POST',
            headers: { 'X-AJAX-Request': 'true' }
          });
          const result = await response.json().catch(() => null);
          const guarded = (result && typeof window.applyGuardedApiResult === 'function')
            ? await window.applyGuardedApiResult(result, { busyTitle: 'Recovery In Progress', replayTitle: 'Recovery Already Processed' })
            : { stop: false };
          if (guarded.stop) {
            btn.disabled = false;
            btn.innerHTML = original;
            return;
          }
          if (!response.ok || !result || result.status !== 'success') throw new Error(result?.message || 'Recovery failed.');

          await showMsg({ title: 'Recovered', icon: 'success', message: result.message || 'Teacher recovered.', buttons: [{ text: 'OK', class: 'btn-success' }] });
          window.location.reload();
        } catch (err) {
          btn.disabled = false;
          btn.innerHTML = original;
          await showMsg({ title: 'Error', icon: 'error', message: err.message || 'Failed to recover teacher.', buttons: [{ text: 'OK', class: 'btn-danger' }] });
        }
      });
    });
  });
})();
</script>
