<%
  const isEditMode = isEdit === true;
  const form = (typeof allocationFormData !== 'undefined' && allocationFormData) ? allocationFormData : {};
  const formPostAction = String(formAction || '').trim() || '/school/exams/allocations/new';
  const allocationLabel = allocation?.id ? `${allocation.id}` : '';

  const selectedTemplateId = String(form.templateId || template?.id || '').trim();
  const selectedTemplateTitle = String(template?.title || '').trim();
  const selectedRevisionId = String(form.revisionId || revision?.id || '').trim();
  const selectedRevisionLabel = revision
    ? `R${Number(revision?.revisionNo || 0)} | ${String(revision?.title || revision?.id || '').trim()}`
    : '';

  const selectedClassId = String(form.classId || selectedClass?.id || '').trim();
  const selectedClassTitle = String(selectedClass?.title || selectedClass?.name || '').trim();

  const selectedSessionId = String(form.sessionId || allocation?.extensions?.sourceSession?.sessionId || '').trim();
  const selectedSessionDate = String(form.sessionDate || allocation?.extensions?.sourceSession?.sessionDate || '').trim();
  const selectedSessionStart = String(form.sessionStartTime || allocation?.extensions?.sourceSession?.startTime || '').trim();
  const selectedSessionEnd = String(form.sessionEndTime || allocation?.extensions?.sourceSession?.endTime || '').trim();
  const selectedSessionLabel = String(form.sessionLabel || '').trim()
    || (selectedSessionId
      ? `${selectedSessionDate || '-'} | ${selectedSessionStart || '--:--'}-${selectedSessionEnd || '--:--'} | ${selectedSessionId}`
      : '');

  const forceSessionWindowDefault = form.forceSessionWindow !== false;
  const selectedWindowPolicy = String(
    form.windowPolicy
    || allocation?.windowPolicy
    || template?.settings?.defaultWindowPolicy
    || 'strict_fixed_window'
  ).trim().toLowerCase();
  const selectedQuestionPresentationMode = String(
    form.questionPresentationMode
    || allocation?.questionPresentationMode
    || template?.settings?.defaultQuestionPresentationMode
    || 'all_questions_on_one_page'
  ).trim().toLowerCase();
  const selectedCountsInFinalScore = form.countsInFinalScore !== undefined && form.countsInFinalScore !== null
    ? form.countsInFinalScore !== false
    : (allocation?.countsInFinalScore !== false);
  const formHeading = isEditMode ? 'Edit Exam Allocation' : 'New Exam Allocation';
  const examNameHeading = String(selectedTemplateTitle || template?.title || '').trim()
    || String(form.allocationName || allocation?.allocationName || '').trim()
    || 'Exam';
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h1 class="page-heading size-md m-0">
        <i class="bi bi-calendar2-plus me-2"></i><%= formHeading %>
      </h1>
      <h6 class="fw-semibold text-primary mt-2 mb-0"><%= examNameHeading %></h6>
      <div class="text-muted small mt-1">
        <% if (isEditMode && allocationLabel) { %>
          Allocation ID: <strong class="font-monospace"><%= allocationLabel %></strong>
        <% } else { %>
          Select class, scheduled session, and published exam template.
        <% } %>
      </div>
    </div>
    <div class="d-flex flex-column align-items-end gap-2">
      <div class="d-flex gap-2">
        <a href="/school/exams" class="btn btn-outline-secondary btn-sm"><i class="bi bi-house me-1"></i>Exam Home</a>
        <a href="/school/exams/allocations" class="btn btn-outline-primary btn-sm"><i class="bi bi-arrow-left me-1"></i>Allocations</a>
      </div>
      <% if (isEditMode && allocationLabel) { %>
        <span class="badge bg-primary border font-monospace">ID: <%= allocationLabel %></span>
      <% } %>
    </div>
  </div>

  <form method="POST" id="allocationForm" action="<%= formPostAction %>">
    <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
    <input type="hidden" name="templateId" id="templateIdInput" value="<%= selectedTemplateId %>">
    <input type="hidden" name="revisionId" id="revisionIdInput" value="<%= selectedRevisionId %>">
    <input type="hidden" name="classId" id="classIdInput" value="<%= selectedClassId %>">
    <input type="hidden" name="sessionId" id="sessionIdInput" value="<%= selectedSessionId %>">

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-3">
        <div class="row g-3">
          <div class="col-md-5">
            <label class="form-label fw-bold">Exam Template *</label>
            <div class="input-group">
              <input type="text" id="templateTitleInput" class="form-control bg-white" value="<%= selectedTemplateTitle %>" placeholder="Pick published template..." readonly required>
              <% if (!isEditMode) { %>
                <button class="btn btn-outline-primary" type="button" id="btnPickTemplate"><i class="bi bi-search"></i></button>
                <button class="btn btn-outline-secondary" type="button" id="btnClearTemplate"><i class="bi bi-x-lg"></i></button>
              <% } %>
            </div>
            <div class="form-text">
              <% if (isEditMode) { %>
                Template/revision is immutable after allocation creation.
              <% } else { %>
                Uses published templates only.
              <% } %>
            </div>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Published Revision</label>
            <input type="text" class="form-control bg-white" id="revisionLabelInput" value="<%= selectedRevisionLabel %>" placeholder="Select template first" readonly>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Status</label>
            <select class="form-select" name="status">
              <% (allocationStatuses || []).forEach((st) => { %>
                <option value="<%= st %>" <%= String(st) === String(form.status || 'scheduled') ? 'selected' : '' %>><%= st %></option>
              <% }); %>
            </select>
          </div>

          <div class="col-md-5">
            <label class="form-label fw-bold">Class *</label>
            <div class="input-group">
              <input type="text" id="classTitleInput" class="form-control bg-white" value="<%= selectedClassTitle %>" placeholder="Pick class..." readonly required>
              <% if (!isEditMode) { %>
                <button class="btn btn-outline-primary" type="button" id="btnPickClass"><i class="bi bi-search"></i></button>
                <button class="btn btn-outline-secondary" type="button" id="btnClearClass"><i class="bi bi-x-lg"></i></button>
              <% } %>
            </div>
            <div class="form-text">
              <% if (isEditMode) { %>
                Class is immutable after allocation creation.
              <% } else { %>
                <% if (isAdminViewer) { %>
                  Showing all classes in active org.
                <% } else { %>
                  Showing classes where you are the Primary Instructor.
                <% } %>
              <% } %>
            </div>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Scheduled Session *</label>
            <div class="input-group">
              <input type="text" id="sessionLabelInput" class="form-control bg-white" value="<%= selectedSessionLabel %>" placeholder="Pick scheduled session..." readonly required>
              <% if (!isEditMode) { %>
                <button class="btn btn-outline-primary" type="button" id="btnPickSession"><i class="bi bi-search"></i></button>
                <button class="btn btn-outline-secondary" type="button" id="btnClearSession"><i class="bi bi-x-lg"></i></button>
              <% } %>
            </div>
            <div class="form-text">
              <% if (isEditMode) { %>
                Session is immutable after allocation creation.
              <% } else { %>
                Choose one scheduled session from the selected class.
              <% } %>
            </div>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Timezone</label>
            <input type="text" class="form-control" name="timezone" id="timezoneInput" value="<%= form.timezone || template?.settings?.defaultTimezone || 'UTC' %>" placeholder="UTC">
          </div>

          <div class="col-md-12">
            <label class="form-check">
              <input class="form-check-input" type="checkbox" name="forceSessionWindow" id="forceSessionWindowInput" value="true" <%= forceSessionWindowDefault ? 'checked' : '' %>>
              <span class="form-check-label">Force allocation window to selected session date/time</span>
            </label>
            <div class="form-text">When enabled, start/end date/time follow the selected session window.</div>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Start Date *</label>
            <input type="date" class="form-control" name="windowStartLocalDate" id="windowStartLocalDateInput" value="<%= form.windowStartLocalDate || '' %>" required>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Start Time *</label>
            <input type="time" class="form-control" name="windowStartLocalTime" id="windowStartLocalTimeInput" value="<%= form.windowStartLocalTime || '' %>" required>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">End Date *</label>
            <input type="date" class="form-control" name="windowEndLocalDate" id="windowEndLocalDateInput" value="<%= form.windowEndLocalDate || '' %>" required>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">End Time *</label>
            <input type="time" class="form-control" name="windowEndLocalTime" id="windowEndLocalTimeInput" value="<%= form.windowEndLocalTime || '' %>" required>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Duration (minutes)</label>
            <input type="number" class="form-control" min="1" max="1440" name="durationMinutes" value="<%= Number(form.durationMinutes || revision?.durationMinutes || template?.settings?.defaultDurationMinutes || 60) %>">
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Max Attempts</label>
            <input type="number" class="form-control" min="1" max="20" name="maxAttemptsPerStudent" value="<%= Number(form.maxAttemptsPerStudent || 1) %>">
          </div>

          <div class="col-md-6">
            <label class="form-label fw-bold">Allocation Name</label>
            <input type="text" class="form-control" name="allocationName" maxlength="220" value="<%= form.allocationName || '' %>" placeholder="Example: Midterm - Class A">
          </div>

          <div class="col-md-9">
            <label class="form-label fw-bold">Instructions for Students</label>
            <textarea class="form-control" rows="3" name="instructionsForStudents" maxlength="12000"><%= form.instructionsForStudents || '' %></textarea>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Tags (CSV)</label>
            <input type="text" class="form-control" name="tags" placeholder="midterm, unit1" value="<%= form.tags || '' %>">
          </div>

          <div class="col-12">
            <div class="d-flex flex-wrap gap-3">
              <label class="form-check">
                <input class="form-check-input" type="checkbox" name="autoSubmitOnExpire" value="true" <%= form.autoSubmitOnExpire !== false ? 'checked' : '' %>>
                <span class="form-check-label">Auto submit on expire</span>
              </label>
              <label class="form-check">
                <input class="form-check-input" type="checkbox" name="allowLateStart" value="true" <%= form.allowLateStart === true ? 'checked' : '' %>>
                <span class="form-check-label">Allow late start</span>
              </label>
              <label class="form-check">
                <input class="form-check-input" type="checkbox" name="shuffleQuestions" value="true" <%= form.shuffleQuestions === true ? 'checked' : '' %>>
                <span class="form-check-label">Shuffle questions</span>
              </label>
            </div>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Window Policy</label>
            <select class="form-select" name="windowPolicy" id="windowPolicyInput">
              <% (windowPolicyOptions || ['strict_fixed_window', 'suggested_window']).forEach((option) => { %>
                <option value="<%= option %>" <%= String(option) === selectedWindowPolicy ? 'selected' : '' %>>
                  <%= option === 'suggested_window' ? 'Suggested (guidance)' : 'Strict fixed window' %>
                </option>
              <% }); %>
            </select>
            <div class="form-text">Choose whether exam time is strict or only a recommendation.</div>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Question Presentation</label>
            <select class="form-select" name="questionPresentationMode" id="questionPresentationModeInput">
              <% (questionPresentationModeOptions || ['sequential_one_by_one', 'all_questions_on_one_page']).forEach((option) => { %>
                <option value="<%= option %>" <%= String(option) === selectedQuestionPresentationMode ? 'selected' : '' %>>
                  <%= option === 'sequential_one_by_one' ? 'One by one (save then next)' : 'All questions in one page' %>
                </option>
              <% }); %>
            </select>
            <div class="form-text">Controls how students navigate and answer questions.</div>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Include In Final Score</label>
            <select class="form-select" name="countsInFinalScore" id="countsInFinalScoreInput">
              <option value="true" <%= selectedCountsInFinalScore ? 'selected' : '' %>>Yes</option>
              <option value="false" <%= selectedCountsInFinalScore ? '' : 'selected' %>>No</option>
            </select>
            <div class="form-text">If No, this exam is excluded from final-score aggregation.</div>
          </div>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white">
        <h5 class="m-0 fw-bold">Class Roster Preview</h5>
      </div>
      <div class="card-body p-3">
        <div class="row g-2">
          <div class="col-md-4">
            <div class="small text-muted">Selected Class</div>
            <div class="fw-bold" id="previewClassName"><%= selectedClassTitle || '-' %></div>
          </div>
          <div class="col-md-4">
            <div class="small text-muted">Expected Student Count</div>
            <div class="fw-bold" id="previewStudentCount"><%= Number(rosterPreview?.expectedStudentCount || 0) %></div>
          </div>
          <div class="col-md-4">
            <div class="small text-muted">Roster Source</div>
            <div class="fw-bold" id="previewRosterSource"><%= String(rosterPreview?.source || '-').replaceAll('_', ' ') %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2">
      <button type="submit" class="btn btn-primary" id="saveAllocationBtn"><%= isEditMode ? 'Save Changes' : 'Create Allocation' %></button>
      <a href="/school/exams/allocations" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </form>
</div>

<%- include('../../partials/modal_GenericPicker') %>

<script>
  (function () {
    const formEl = document.getElementById('allocationForm');
    const templateIdInput = document.getElementById('templateIdInput');
    const templateTitleInput = document.getElementById('templateTitleInput');
    const revisionIdInput = document.getElementById('revisionIdInput');
    const revisionLabelInput = document.getElementById('revisionLabelInput');
    const classIdInput = document.getElementById('classIdInput');
    const classTitleInput = document.getElementById('classTitleInput');
    const sessionIdInput = document.getElementById('sessionIdInput');
    const sessionLabelInput = document.getElementById('sessionLabelInput');
    const forceSessionWindowInput = document.getElementById('forceSessionWindowInput');
    const btnPickTemplate = document.getElementById('btnPickTemplate');
    const btnClearTemplate = document.getElementById('btnClearTemplate');
    const btnPickClass = document.getElementById('btnPickClass');
    const btnClearClass = document.getElementById('btnClearClass');
    const btnPickSession = document.getElementById('btnPickSession');
    const btnClearSession = document.getElementById('btnClearSession');
    const saveBtn = document.getElementById('saveAllocationBtn');
    const previewClassName = document.getElementById('previewClassName');
    const previewStudentCount = document.getElementById('previewStudentCount');
    const previewRosterSource = document.getElementById('previewRosterSource');
    const startDateInput = document.getElementById('windowStartLocalDateInput');
    const startTimeInput = document.getElementById('windowStartLocalTimeInput');
    const endDateInput = document.getElementById('windowEndLocalDateInput');
    const endTimeInput = document.getElementById('windowEndLocalTimeInput');
    const windowPolicyInput = document.getElementById('windowPolicyInput');
    const questionPresentationModeInput = document.getElementById('questionPresentationModeInput');
    const countsInFinalScoreInput = document.getElementById('countsInFinalScoreInput');
    const isEditMode = <%- JSON.stringify(isEditMode) %> === true;

    let selectedSessionMeta = null;

    function showWarning(message) {
      if (typeof showMessageModal === 'function') {
        return showMessageModal({
          title: 'Validation',
          icon: 'warning',
          message,
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
      }
      alert(message);
      return Promise.resolve();
    }

    function updatePreview() {
      previewClassName.textContent = String(classTitleInput?.value || '').trim() || '-';
      const count = Number(previewStudentCount.dataset.enrollmentCount || 0);
      previewStudentCount.textContent = count > 0 ? String(count) : '-';
      previewRosterSource.textContent = String(classIdInput?.value || '').trim() ? 'class enrollment' : '-';
    }

    function applyWindowFromSessionMeta(sessionMeta) {
      if (!sessionMeta || forceSessionWindowInput?.checked !== true) return;
      const date = String(sessionMeta.date || '').trim();
      const start = String(sessionMeta.startTime || '').trim();
      const end = String(sessionMeta.endTime || '').trim() || start;
      if (date) {
        if (startDateInput) startDateInput.value = date;
        if (endDateInput) endDateInput.value = date;
      }
      if (start && startTimeInput) startTimeInput.value = start.slice(0, 5);
      if (end && endTimeInput) endTimeInput.value = end.slice(0, 5);
    }

    btnPickTemplate?.addEventListener('click', function () {
      if (!window.GenericPicker) return;
      GenericPicker.open(GenericPickerPresets.normalizeConfig({
        title: 'Select Exam Template',
        icon: 'bi-journal-richtext',
        apiEndpoint: '/school/exams/api/published-allocation-templates',
        placeholder: 'Search published templates...',
        searchFields: 'id,title,code,revisionTitle,revisionNo',
        onSelect: function (item) {
          const templateId = String(item?.id || '').trim();
          if (!templateId) return;
          templateIdInput.value = templateId;
          templateTitleInput.value = String(item?.title || templateId);
          revisionIdInput.value = String(item?.revisionId || '').trim();
          const revisionNo = Number(item?.revisionNo || 0);
          const revisionTitle = String(item?.revisionTitle || item?.revisionId || '').trim();
          revisionLabelInput.value = revisionIdInput.value ? `R${revisionNo} | ${revisionTitle}` : '';
          if (windowPolicyInput && !isEditMode && item?.defaultWindowPolicy) {
            windowPolicyInput.value = String(item.defaultWindowPolicy).trim().toLowerCase();
          }
          if (questionPresentationModeInput && !isEditMode && item?.defaultQuestionPresentationMode) {
            questionPresentationModeInput.value = String(item.defaultQuestionPresentationMode).trim().toLowerCase();
          }
          if (countsInFinalScoreInput && !isEditMode && typeof item?.defaultCountsInFinalScore === 'boolean') {
            countsInFinalScoreInput.value = item.defaultCountsInFinalScore ? 'true' : 'false';
          }
        }
      }));
    });

    btnClearTemplate?.addEventListener('click', function () {
      templateIdInput.value = '';
      templateTitleInput.value = '';
      revisionIdInput.value = '';
      revisionLabelInput.value = '';
    });

    btnPickClass?.addEventListener('click', function () {
      if (!window.GenericPicker) return;
      GenericPicker.open(GenericPickerPresets.normalizeConfig({
        title: 'Select Class',
        icon: 'bi-easel-fill',
        apiEndpoint: '/school/exams/api/eligible-allocation-classes',
        placeholder: 'Search eligible classes...',
        searchFields: 'id,title,code,status',
        onSelect: function (item) {
          const classId = String(item?.id || '').trim();
          if (!classId) return;
          classIdInput.value = classId;
          classTitleInput.value = String(item?.title || item?.name || classId);
          previewStudentCount.dataset.enrollmentCount = String(Number(item?.enrollmentCount || 0) || 0);
          sessionIdInput.value = '';
          sessionLabelInput.value = '';
          selectedSessionMeta = null;
          updatePreview();
        }
      }));
    });

    btnClearClass?.addEventListener('click', function () {
      classIdInput.value = '';
      classTitleInput.value = '';
      previewStudentCount.dataset.enrollmentCount = '0';
      sessionIdInput.value = '';
      sessionLabelInput.value = '';
      selectedSessionMeta = null;
      updatePreview();
    });

    btnPickSession?.addEventListener('click', async function () {
      const classId = String(classIdInput?.value || '').trim();
      if (!classId) {
        await showWarning('Please select class first.');
        return;
      }
      if (!window.GenericPicker) return;
      GenericPicker.open(GenericPickerPresets.normalizeConfig({
        title: 'Select Scheduled Session',
        icon: 'bi-calendar3',
        apiEndpoint: `/school/exams/api/class-scheduled-sessions?classId=${encodeURIComponent(classId)}`,
        placeholder: 'Search scheduled sessions...',
        searchFields: 'sessionId,className,date,startTime,endTime,status',
        onSelect: function (item) {
          const sessionId = String(item?.sessionId || item?.id || '').trim();
          if (!sessionId) return;
          const date = String(item?.date || '').trim();
          const start = String(item?.startTime || '').trim();
          const end = String(item?.endTime || '').trim();
          sessionIdInput.value = sessionId;
          sessionLabelInput.value = `${date || '-'} | ${start || '--:--'}-${end || '--:--'} | ${sessionId}`;
          selectedSessionMeta = { date, startTime: start, endTime: end };
          applyWindowFromSessionMeta(selectedSessionMeta);
        }
      }));
    });

    btnClearSession?.addEventListener('click', function () {
      sessionIdInput.value = '';
      sessionLabelInput.value = '';
      selectedSessionMeta = null;
    });

    forceSessionWindowInput?.addEventListener('change', function () {
      if (forceSessionWindowInput.checked) {
        applyWindowFromSessionMeta(selectedSessionMeta);
      }
    });

    formEl?.addEventListener('submit', async function (event) {
      if (!String(templateIdInput?.value || '').trim()) {
        event.preventDefault();
        await showWarning('Please select a published exam template.');
        return;
      }
      if (!String(classIdInput?.value || '').trim()) {
        event.preventDefault();
        await showWarning('Please select a class before saving allocation.');
        return;
      }
      if (!isEditMode && !String(sessionIdInput?.value || '').trim()) {
        event.preventDefault();
        await showWarning('Please select a scheduled session.');
        return;
      }
      if (saveBtn) {
        saveBtn.disabled = true;
        if (!saveBtn.dataset.originalHtml) saveBtn.dataset.originalHtml = saveBtn.innerHTML;
        saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
      }
      if (typeof showLoading === 'function') showLoading();
    });

    updatePreview();
  })();
</script>
