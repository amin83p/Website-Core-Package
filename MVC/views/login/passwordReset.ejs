<%
  const initialEmail = String(prefEmail || '').trim().toLowerCase();
%>

<div class="d-flex align-items-center justify-content-center">
  <div class="bg-light rounded-4 p-4 p-md-5" style="width: 100%; max-width: 1040px;">
    <div class="card border-0 shadow-lg overflow-hidden" style="border-radius: 16px; animation: slideUp .5s ease-out;">
      <div class="row g-0">
        <div class="col-md-6 d-none d-md-flex flex-column align-items-center justify-content-center p-4 text-white text-center"
             style="background: linear-gradient(135deg, var(--color-primary) 0%, #0d47a1 100%);">
          <div class="mb-4 rounded-circle bg-white bg-opacity-25 d-flex align-items-center justify-content-center"
               style="width: 80px; height: 80px; backdrop-filter: blur(5px);">
            <i class="bi bi-shield-check fs-2 text-white"></i>
          </div>
          <h3 class="fw-bold mb-2">Password Recovery</h3>
          <p class="text-white text-opacity-75 small mx-3">
            Request a code, verify it, then set a new password.
          </p>
        </div>

        <div class="col-md-6 bg-white p-4">
          <div class="d-flex align-items-center mb-3">
            <div class="d-md-none me-3 text-primary">
              <i class="bi bi-shield-check fs-2"></i>
            </div>
            <div>
              <h4 class="fw-bold text-dark mb-0">Reset Password</h4>
              <p class="text-muted small mb-0">Follow the secure reset flow</p>
            </div>
          </div>

          <div class="d-flex align-items-center flex-wrap gap-2 mb-4 small">
            <span id="resetStepPill1" class="badge rounded-pill bg-primary">1. Request</span>
            <span id="resetStepPill2" class="badge rounded-pill bg-light text-muted border">2. SMS Target</span>
            <span id="resetStepPill3" class="badge rounded-pill bg-light text-muted border">3. Verify</span>
            <span id="resetStepPill4" class="badge rounded-pill bg-light text-muted border">4. New Password</span>
          </div>

          <div id="resetStepRequest">
            <form id="passwordResetRequestForm">
              <div class="mb-3">
                <label class="form-label x-small fw-bold text-secondary text-uppercase">Email Address</label>
                <div class="input-group">
                  <span class="input-group-text bg-light border-end-0 ps-3 text-muted">
                    <i class="bi bi-envelope"></i>
                  </span>
                  <input
                    type="email"
                    id="resetEmailInput"
                    class="form-control size-md bg-light border-start-0"
                    placeholder="you@example.com"
                    value="<%= initialEmail %>"
                    required
                    autocomplete="email"
                    style="height: 45px;"
                  >
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label x-small fw-bold text-secondary text-uppercase">Delivery Method</label>
                <div class="d-flex flex-column gap-2">
                  <label class="border rounded-3 px-3 py-2 d-flex align-items-center gap-2">
                    <input type="radio" class="form-check-input mt-0" name="resetDeliveryMethod" value="email" checked>
                    <span class="small fw-semibold">Email</span>
                  </label>
                  <label class="border rounded-3 px-3 py-2 d-flex align-items-center gap-2">
                    <input type="radio" class="form-check-input mt-0" name="resetDeliveryMethod" value="sms">
                    <span class="small fw-semibold">SMS</span>
                  </label>
                </div>
              </div>
              <div class="d-grid mb-3">
                <button type="submit" id="requestCodeBtn" class="btn btn-primary btn-filled py-2 shadow-sm fw-bold">
                  Continue
                </button>
              </div>
            </form>
          </div>

          <div id="resetStepSmsTarget" class="d-none">
            <form id="passwordResetSmsTargetForm">
              <div class="small text-muted mb-2">
                Choose a mobile number and confirm the last 4 digits before sending the SMS code.
              </div>
              <div class="mb-3">
                <label class="form-label x-small fw-bold text-secondary text-uppercase">Available Mobile Numbers</label>
                <div id="smsSavedOptions" class="d-flex flex-column gap-2"></div>
              </div>
              <div class="mb-3">
                <label class="form-label x-small fw-bold text-secondary text-uppercase">Manual Mobile Number</label>
                <input
                  type="text"
                  id="smsManualPhoneInput"
                  class="form-control size-md bg-light"
                  placeholder="+1XXXXXXXXXX"
                  autocomplete="tel"
                  style="height: 45px;"
                >
                <div class="form-text">Use this only when you choose “Use another mobile number”.</div>
              </div>
              <div class="mb-3">
                <label class="form-label x-small fw-bold text-secondary text-uppercase">Last 4 Digits</label>
                <input
                  type="text"
                  id="smsLast4Input"
                  maxlength="4"
                  class="form-control size-md bg-light letter-spacing-2 text-center fw-bold"
                  placeholder="1234"
                  inputmode="numeric"
                  autocomplete="one-time-code"
                  style="height: 45px;"
                  required
                >
              </div>
              <div class="d-grid mb-2">
                <button type="submit" id="sendSmsCodeBtn" class="btn btn-primary btn-filled py-2 shadow-sm fw-bold">
                  Send SMS Code
                </button>
              </div>
              <div class="text-center">
                <button type="button" id="backToRequestBtn" class="btn btn-link p-0 small text-decoration-none">Back</button>
              </div>
            </form>
          </div>

          <div id="resetStepVerify" class="d-none">
            <form id="passwordResetVerifyForm">
              <div class="small text-muted mb-2">
                We sent a code via <span class="fw-semibold text-capitalize" id="verifyMethodLabel">email</span>.
                <span id="verifyDestinationWrap">Target: <span class="fw-semibold" id="verifyDestinationLabel">-</span></span>
              </div>
              <div class="mb-3">
                <label class="form-label x-small fw-bold text-secondary text-uppercase">Verification Code</label>
                <div class="input-group">
                  <span class="input-group-text bg-light border-end-0 ps-3 text-muted">
                    <i class="bi bi-shield-lock"></i>
                  </span>
                  <input
                    type="text"
                    id="resetCodeInput"
                    class="form-control size-md bg-light border-start-0 letter-spacing-2 text-center fw-bold"
                    placeholder="123456"
                    maxlength="8"
                    required
                    autocomplete="one-time-code"
                    style="height: 45px;"
                  >
                </div>
              </div>
              <div class="d-grid mb-2">
                <button type="submit" id="verifyCodeBtn" class="btn btn-primary btn-filled py-2 shadow-sm fw-bold">
                  Verify Code
                </button>
              </div>
              <div class="text-center">
                <button type="button" id="resendCodeBtn" class="btn btn-link p-0 small text-decoration-none">
                  Resend code
                </button>
              </div>
            </form>
          </div>

          <div id="resetStepComplete" class="d-none">
            <form id="passwordResetCompleteForm">
              <div class="small text-muted mb-2">
                Email: <span class="fw-semibold" id="completeEmailLabel">-</span>
              </div>
              <div class="mb-3">
                <label class="form-label x-small fw-bold text-secondary text-uppercase">New Password</label>
                <div class="input-group">
                  <span class="input-group-text bg-light border-end-0 ps-3 text-muted">
                    <i class="bi bi-key"></i>
                  </span>
                  <input
                    type="password"
                    id="newPasswordInput"
                    class="form-control size-md bg-light border-start-0"
                    placeholder="Minimum 8 characters"
                    minlength="8"
                    required
                    autocomplete="new-password"
                    style="height: 45px;"
                  >
                </div>
              </div>
              <div class="mb-3">
                <label class="form-label x-small fw-bold text-secondary text-uppercase">Confirm Password</label>
                <div class="input-group">
                  <span class="input-group-text bg-light border-end-0 ps-3 text-muted">
                    <i class="bi bi-key-fill"></i>
                  </span>
                  <input
                    type="password"
                    id="confirmPasswordInput"
                    class="form-control size-md bg-light border-start-0"
                    placeholder="Re-enter new password"
                    minlength="8"
                    required
                    autocomplete="new-password"
                    style="height: 45px;"
                  >
                </div>
              </div>
              <div class="d-grid mb-3">
                <button type="submit" id="completeResetBtn" class="btn btn-success btn-filled py-2 shadow-sm fw-bold">
                  Update Password
                </button>
              </div>
            </form>
          </div>

          <div class="text-center border-top pt-3 mt-3">
            <a href="/login" class="text-decoration-none fw-semibold text-primary small">
              <i class="bi bi-arrow-left me-1"></i> Back to Login
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const state = {
      email: <%- JSON.stringify(initialEmail) %>,
      verificationToken: '',
      deliveryMethod: 'email',
      smsTargetOptions: []
    };

    const stepPanels = {
      request: document.getElementById('resetStepRequest'),
      smsTarget: document.getElementById('resetStepSmsTarget'),
      verify: document.getElementById('resetStepVerify'),
      complete: document.getElementById('resetStepComplete')
    };
    const stepPills = {
      request: document.getElementById('resetStepPill1'),
      smsTarget: document.getElementById('resetStepPill2'),
      verify: document.getElementById('resetStepPill3'),
      complete: document.getElementById('resetStepPill4')
    };
    const stepOrder = ['request', 'smsTarget', 'verify', 'complete'];

    const emailInput = document.getElementById('resetEmailInput');
    const verifyDestinationLabel = document.getElementById('verifyDestinationLabel');
    const completeEmailLabel = document.getElementById('completeEmailLabel');
    const codeInput = document.getElementById('resetCodeInput');
    const newPasswordInput = document.getElementById('newPasswordInput');
    const confirmPasswordInput = document.getElementById('confirmPasswordInput');
    const verifyMethodLabel = document.getElementById('verifyMethodLabel');
    const smsOptionsNode = document.getElementById('smsSavedOptions');
    const smsManualPhoneInput = document.getElementById('smsManualPhoneInput');
    const smsLast4Input = document.getElementById('smsLast4Input');

    const requestForm = document.getElementById('passwordResetRequestForm');
    const smsTargetForm = document.getElementById('passwordResetSmsTargetForm');
    const verifyForm = document.getElementById('passwordResetVerifyForm');
    const completeForm = document.getElementById('passwordResetCompleteForm');

    const requestBtn = document.getElementById('requestCodeBtn');
    const sendSmsCodeBtn = document.getElementById('sendSmsCodeBtn');
    const verifyBtn = document.getElementById('verifyCodeBtn');
    const completeBtn = document.getElementById('completeResetBtn');
    const resendBtn = document.getElementById('resendCodeBtn');
    const backToRequestBtn = document.getElementById('backToRequestBtn');

    const deliveryMethodInputs = Array.from(document.querySelectorAll('input[name="resetDeliveryMethod"]'));

    function setBusy(button, label) {
      if (!button) return;
      if (!button.dataset.defaultHtml) button.dataset.defaultHtml = button.innerHTML;
      button.disabled = true;
      button.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>' + label;
    }

    function clearBusy(button) {
      if (!button) return;
      button.disabled = false;
      if (button.dataset.defaultHtml) button.innerHTML = button.dataset.defaultHtml;
    }

    function normalizeEmail(value) {
      return String(value || '').trim().toLowerCase();
    }

    function normalizeDigits(value) {
      return String(value || '').replace(/\D/g, '');
    }

    function getSelectedDeliveryMethod() {
      const selected = deliveryMethodInputs.find((node) => node && node.checked);
      if (!selected) return 'email';
      return String(selected.value || '').trim().toLowerCase() === 'sms' ? 'sms' : 'email';
    }

    function setPillState(node, isActive, isDone) {
      if (!node) return;
      node.classList.remove('bg-primary', 'text-white', 'bg-success', 'bg-light', 'text-muted', 'border');
      if (isActive) {
        node.classList.add('bg-primary', 'text-white');
        return;
      }
      if (isDone) {
        node.classList.add('bg-success', 'text-white');
        return;
      }
      node.classList.add('bg-light', 'text-muted', 'border');
    }

    function setStep(stepKey) {
      const currentIndex = stepOrder.indexOf(stepKey);
      stepOrder.forEach((key, idx) => {
        if (stepPanels[key]) stepPanels[key].classList.toggle('d-none', key !== stepKey);
        setPillState(stepPills[key], idx === currentIndex, idx < currentIndex);
      });
    }

    function refreshLabels() {
      const email = state.email || '-';
      completeEmailLabel.textContent = email;
      if (verifyMethodLabel) verifyMethodLabel.textContent = state.deliveryMethod === 'sms' ? 'sms' : 'email';
      if (verifyDestinationLabel) {
        verifyDestinationLabel.textContent = state.deliveryMethod === 'sms'
          ? 'your selected mobile number'
          : email;
      }
    }

    function renderSmsOptions() {
      if (!smsOptionsNode) return;
      smsOptionsNode.innerHTML = '';

      const options = Array.isArray(state.smsTargetOptions) ? state.smsTargetOptions : [];
      options.forEach((opt, idx) => {
        const token = String(opt?.token || '').trim();
        const label = String(opt?.label || '').trim() || 'Saved mobile';
        const row = document.createElement('label');
        row.className = 'border rounded-3 px-3 py-2 d-flex align-items-center gap-2';
        row.innerHTML = `
          <input type="radio" class="form-check-input mt-0" name="smsTargetChoice" value="saved:${token}" ${idx === 0 ? 'checked' : ''}>
          <span class="small fw-semibold">${label}</span>
        `;
        smsOptionsNode.appendChild(row);
      });

      const manualRow = document.createElement('label');
      manualRow.className = 'border rounded-3 px-3 py-2 d-flex align-items-center gap-2';
      manualRow.innerHTML = `
        <input type="radio" class="form-check-input mt-0" name="smsTargetChoice" value="manual" ${options.length ? '' : 'checked'}>
        <span class="small fw-semibold">Use another mobile number</span>
      `;
      smsOptionsNode.appendChild(manualRow);

      updateManualPhoneEnabled();
    }

    function getSmsTargetChoiceValue() {
      const node = document.querySelector('input[name="smsTargetChoice"]:checked');
      return String(node?.value || '').trim();
    }

    function updateManualPhoneEnabled() {
      const choice = getSmsTargetChoiceValue();
      const isManual = choice === 'manual';
      smsManualPhoneInput.disabled = !isManual;
      if (!isManual) smsManualPhoneInput.value = '';
    }

    async function showDialog({ title, message, icon = 'info' }) {
      if (typeof showMessageModal === 'function') {
        await showMessageModal({
          title,
          icon,
          message,
          buttons: [{ text: 'OK', class: 'btn-primary' }]
        });
      } else {
        alert(message);
      }
    }

    async function postJson(url, payload) {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload || {})
      });

      let result = {};
      try {
        result = await response.json();
      } catch (_) {
        result = { status: 'error', message: 'Unexpected server response.' };
      }

      if (!response.ok || result.status !== 'success') {
        throw new Error(result.message || 'Request failed.');
      }
      return result;
    }

    async function requestCode(targetEmail) {
      const email = normalizeEmail(targetEmail);
      if (!email) throw new Error('Please enter your email address.');

      const deliveryMethod = getSelectedDeliveryMethod();
      const result = await postJson('/password-reset/request', { email, deliveryMethod });
      state.email = email;
      state.deliveryMethod = deliveryMethod;
      state.smsTargetOptions = Array.isArray(result?.smsTarget?.savedPhoneOptions) ? result.smsTarget.savedPhoneOptions : [];
      refreshLabels();
      return result;
    }

    async function sendSmsCodeFromSelection() {
      const choice = getSmsTargetChoiceValue();
      const selectionMode = choice.startsWith('saved:') ? 'saved' : 'manual';
      const selectedToken = selectionMode === 'saved' ? choice.slice(6) : '';
      const manualPhone = selectionMode === 'manual' ? String(smsManualPhoneInput.value || '').trim() : '';
      const last4 = normalizeDigits(smsLast4Input.value || '').slice(-4);
      if (!last4 || last4.length !== 4) {
        throw new Error('Please enter the last four digits.');
      }

      return postJson('/password-reset/sms/start', {
        email: state.email || emailInput.value,
        selectionMode,
        selectedToken,
        manualPhone,
        last4
      });
    }

    requestForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      setBusy(requestBtn, 'Processing...');
      try {
        await requestCode(emailInput.value);
        if (state.deliveryMethod === 'sms') {
          renderSmsOptions();
          await showDialog({
            title: 'Continue SMS Verification',
            icon: 'success',
            message: 'If the account exists, select a mobile number and confirm the last four digits to send the SMS code.'
          });
          setStep('smsTarget');
          smsLast4Input.focus();
        } else {
          await showDialog({
            title: 'Code Sent',
            icon: 'success',
            message: 'If the account exists, a reset code has been sent to the registered email.'
          });
          setStep('verify');
          codeInput.focus();
        }
      } catch (error) {
        await showDialog({
          title: 'Request Failed',
          icon: 'error',
          message: error?.message || 'Unable to process password reset request.'
        });
      } finally {
        clearBusy(requestBtn);
      }
    });

    smsTargetForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      setBusy(sendSmsCodeBtn, 'Sending...');
      try {
        await sendSmsCodeFromSelection();
        await showDialog({
          title: 'Code Sent',
          icon: 'success',
          message: 'If the account exists, a verification code has been sent by SMS.'
        });
        setStep('verify');
        codeInput.focus();
      } catch (error) {
        await showDialog({
          title: 'SMS Send Failed',
          icon: 'error',
          message: error?.message || 'Unable to send SMS verification code.'
        });
      } finally {
        clearBusy(sendSmsCodeBtn);
      }
    });

    verifyForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      setBusy(verifyBtn, 'Verifying...');
      try {
        const code = String(codeInput.value || '').trim();
        if (!code) throw new Error('Please enter the verification code.');
        const result = await postJson('/password-reset/verify', {
          email: state.email || emailInput.value,
          code,
          deliveryMethod: state.deliveryMethod || getSelectedDeliveryMethod()
        });
        state.verificationToken = String(result.verificationToken || '').trim();
        if (!state.verificationToken) throw new Error('Verification token is missing.');
        await showDialog({
          title: 'Code Verified',
          icon: 'success',
          message: 'Now set your new password.'
        });
        setStep('complete');
        newPasswordInput.focus();
      } catch (error) {
        await showDialog({
          title: 'Verification Failed',
          icon: 'error',
          message: error?.message || 'Unable to verify code.'
        });
      } finally {
        clearBusy(verifyBtn);
      }
    });

    completeForm.addEventListener('submit', async (event) => {
      event.preventDefault();
      setBusy(completeBtn, 'Updating...');
      try {
        const newPassword = String(newPasswordInput.value || '');
        const confirmPassword = String(confirmPasswordInput.value || '');
        if (newPassword.length < 8) throw new Error('New password must be at least 8 characters.');
        if (newPassword !== confirmPassword) throw new Error('Password confirmation does not match.');
        if (!state.verificationToken) throw new Error('Your verification session expired. Please verify the code again.');

        await postJson('/password-reset/complete', {
          email: state.email || emailInput.value,
          verificationToken: state.verificationToken,
          newPassword
        });

        await showDialog({
          title: 'Password Updated',
          icon: 'success',
          message: 'Your password has been reset successfully.'
        });
        window.location.href = '/login?warning=' + encodeURIComponent('Password reset completed. Please sign in.');
      } catch (error) {
        await showDialog({
          title: 'Reset Failed',
          icon: 'error',
          message: error?.message || 'Unable to reset password.'
        });
      } finally {
        clearBusy(completeBtn);
      }
    });

    resendBtn.addEventListener('click', async () => {
      if (state.deliveryMethod === 'sms') {
        setStep('smsTarget');
        smsLast4Input.focus();
        return;
      }
      setBusy(resendBtn, 'Sending...');
      try {
        await postJson('/password-reset/request', {
          email: state.email || emailInput.value,
          deliveryMethod: 'email'
        });
        await showDialog({
          title: 'Code Resent',
          icon: 'success',
          message: 'If the account exists, a new reset code has been sent.'
        });
      } catch (error) {
        await showDialog({
          title: 'Resend Failed',
          icon: 'error',
          message: error?.message || 'Unable to resend reset code.'
        });
      } finally {
        clearBusy(resendBtn);
      }
    });

    backToRequestBtn.addEventListener('click', () => {
      setStep('request');
      emailInput.focus();
    });

    document.addEventListener('change', (event) => {
      if (event.target && event.target.name === 'smsTargetChoice') {
        updateManualPhoneEnabled();
      }
    });

    if (state.email) {
      emailInput.value = state.email;
      refreshLabels();
    }

    setStep('request');
  })();
</script>

<style>
  @keyframes slideUp { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: translateY(0); } }
  .letter-spacing-2 { letter-spacing: 3px; }
  .x-small { font-size: .75rem; }
</style>
