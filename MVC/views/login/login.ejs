<div class="d-flex align-items-center justify-content-center ">

  <div class="bg-light rounded-4 p-4 p-md-5" style="width: 100%; max-width: 950px;">
    
    <div class="card border-0 shadow-lg overflow-hidden" 
         style="border-radius: 16px; animation: slideUp 0.5s ease-out;">
      
      <div class="row g-0">
        
        <div class="col-md-6 d-none d-md-flex flex-column align-items-center justify-content-center p-4 text-white text-center"
             style="background: linear-gradient(135deg, var(--color-primary) 0%, #0d47a1 100%);">
          
          <div class="mb-4 rounded-circle bg-white bg-opacity-25 d-flex align-items-center justify-content-center" 
               style="width: 80px; height: 80px; backdrop-filter: blur(5px);">
             <i class="bi bi-shield-lock-fill fs-2 text-white"></i>
          </div>
          
          <h3 class="fw-bold mb-2">Secure Access</h3>
          <p class="text-white text-opacity-75 small mx-3">
            Welcome to your workspace.<br>Please verify your identity.
          </p>
        </div>

        <div class="col-md-6 bg-white p-4">
          
          <div class="d-flex align-items-center mb-4">
              <div class="d-md-none me-3 text-primary">
                  <i class="bi bi-shield-lock-fill fs-2"></i>
              </div>
              <div>
                  <h4 class="fw-bold text-dark mb-0">Login</h4>
                  <p class="text-muted small mb-0">Enter your credentials</p>
              </div>
          </div>

          <form id="loginForm">
            
            <div class="mb-3">
              <label class="form-label x-small fw-bold text-secondary text-uppercase">Username</label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0 ps-3 text-muted">
                  <i class="bi bi-person"></i>
                </span>
                <input type="text" name="username" class="form-control size-md bg-light border-start-0" 
                       placeholder="Username" required autofocus autocomplete="username" style="height: 45px;">
              </div>
            </div>

            <div class="mb-4">
              <div class="d-flex justify-content-between">
                  <label class="form-label x-small fw-bold text-secondary text-uppercase">Password</label>
                  <a href="/password-reset" class="small text-decoration-none fw-semibold text-primary">Forgot password?</a>
              </div>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0 ps-3 text-muted">
                  <i class="bi bi-key"></i>
                </span>
                <input type="password" name="password" class="form-control size-md bg-light border-start-0" 
                       placeholder="••••••••" required autocomplete="current-password" style="height: 45px;">
              </div>
            </div>

            <div id="captchaContainer" class="mb-4 d-none" style="animation: fadeIn 0.3s ease;">
               <label class="form-label x-small fw-bold text-danger text-uppercase">Security Check</label>
               <div class="card bg-light border-0 p-3">
                  <div class="d-flex align-items-center justify-content-between mb-2">
                      <div class="border rounded bg-white overflow-hidden" style="height: 50px;">
                          <img id="captchaImage" src="" alt="CAPTCHA" style="height: 100%; width: auto;">
                      </div>
                      <button type="button" class="btn btn-sm btn-outline-secondary" onclick="refreshCaptcha()" title="Refresh Image">
                          <i class="bi bi-arrow-clockwise"></i>
                      </button>
                  </div>
                  <input type="text" name="captcha" id="captchaInput" class="form-control text-center fw-bold letter-spacing-2" 
                         placeholder="Enter Code" maxlength="6" autocomplete="off">
               </div>
            </div>

            <div class="d-grid mb-4">
              <button type="submit" class="btn btn-primary btn-filled py-2 shadow-sm fw-bold">
                Sign In
              </button>
            </div>

            <% if (typeof microsoftAuthEnabled !== 'undefined' && microsoftAuthEnabled) { %>
              <div class="d-flex align-items-center gap-2 mb-3">
                <div class="border-top flex-grow-1"></div>
                <span class="text-muted small">or</span>
                <div class="border-top flex-grow-1"></div>
              </div>
              <div class="d-grid mb-4">
                <a href="/auth/microsoft" class="btn btn-outline-secondary py-2 fw-semibold">
                  <i class="bi bi-microsoft me-2"></i>Continue with Microsoft
                </a>
              </div>
            <% } %>

            <div class="text-center border-top pt-3">
               <a href="/" class="text-decoration-none text-muted small me-3">Cancel</a>
               <span class="text-muted small">|</span>
               <a href="persons/join" class="text-decoration-none fw-bold text-primary small ms-3">Create Account</a>
            </div>

          </form>
        </div>

      </div>
    </div>
  
  </div> </div>

<script id="microsoftSessionLimitJson" type="application/json"><%- JSON.stringify((typeof microsoftSessionLimit !== 'undefined' && microsoftSessionLimit) ? microsoftSessionLimit : null).replace(/</g, '\\u003c') %></script>

<script>
// 1. CAPTCHA LOGIC
function refreshCaptcha() {
    const img = document.getElementById('captchaImage');
    img.src = '/captcha?' + Date.now();
    document.getElementById('captchaInput').value = '';
}

function showCaptcha() {
    const container = document.getElementById('captchaContainer');
    const input = document.getElementById('captchaInput');
    
    if (container.classList.contains('d-none')) {
        container.classList.remove('d-none');
        refreshCaptcha();
        input.setAttribute('required', 'true');
    }
    container.classList.add('shake-element');
    setTimeout(() => container.classList.remove('shake-element'), 500);
}

function parseJsonScript(id, fallback) {
    try {
        const node = document.getElementById(id);
        return JSON.parse((node && node.textContent) || '');
    } catch (_) {
        return fallback;
    }
}

function escapeHtml(value) {
    return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}

function escapeJsString(value) {
    return String(value || '')
        .replace(/\\/g, '\\\\')
        .replace(/'/g, "\\'")
        .replace(/\r?\n/g, ' ');
}

function getSessionButtonId(sessionId) {
    return `btn-kill-${String(sessionId || '').replace(/[^A-Za-z0-9_-]/g, '_')}`;
}

function showSessionLimitModal(result) {
    if (!result || !Array.isArray(result.activeSessions)) return;
    const provider = String(result.provider || 'password').toLowerCase();
    const isMicrosoft = provider === 'microsoft';

    let listHtml = '<div class="list-group text-start mt-3 border rounded" style="max-height:300px; overflow-y:auto; background:#fff;">';
    result.activeSessions.forEach(s => {
        const ua = s.deviceFingerprint?.browser || 'Unknown Device';
        const ip = s.deviceFingerprint?.ip || 'Unknown IP';
        let timeStr = 'Just now';
        try { timeStr = new Date(s.lastActivityAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}); } catch(e) {}
        const org = s.currentOrgId === 'SYSTEM' ? 'System' : `Org #${s.currentOrgId}`;
        const rawSessionId = String(s.id || '');
        const safeSessionId = escapeJsString(rawSessionId);
        const buttonId = getSessionButtonId(rawSessionId);
        const uaHtml = escapeHtml(ua);
        const ipHtml = escapeHtml(ip);
        const orgHtml = escapeHtml(org);
        const timeHtml = escapeHtml(timeStr);

        listHtml += `
            <div class="list-group-item d-flex justify-content-between align-items-center p-3">
                <div style="font-size:0.9rem; line-height:1.3; overflow:hidden;">
                    <div class="fw-bold text-dark text-truncate" style="max-width:200px;" title="${uaHtml}">
                        <i class="bi bi-laptop me-1 text-secondary"></i> ${uaHtml}
                    </div>
                    <div class="text-muted small mt-1">${ipHtml} - ${orgHtml} - ${timeHtml}</div>
                </div>
                <button type="button" id="${buttonId}" class="btn btn-sm btn-outline-danger shadow-sm" style="min-width:90px;" onclick="window.killSessionAndLogin('${safeSessionId}', '${provider}')">
                    Disconnect
                </button>
            </div>
        `;
    });
    listHtml += '</div>';

    const msgContent = `
        <div class="text-start">
            <div class="alert alert-warning border-0 bg-warning-subtle text-dark small mb-3">
                <i class="bi bi-exclamation-triangle-fill me-1"></i>
                Limit Reached: You have <b>${result.activeSessions.length}</b> active session(s).
            </div>
            <p class="small text-muted mb-0">
                ${isMicrosoft
                    ? 'Select a session below to disconnect it and continue Microsoft sign-in here:'
                    : 'Select a session below to disconnect it and log in here:'}
            </p>
            ${listHtml}
        </div>
    `;

    showMessageModal({
        title: 'Session Limit Reached',
        icon: 'warning',
        message: msgContent,
        size: 'md',
        buttons: [{ text: "Cancel", class: "btn-secondary" }]
    });
}

// 2. GLOBAL HANDLERS
document.addEventListener('DOMContentLoaded', () => {
    const params = new URLSearchParams(window.location.search);
    if (params.get('warning') && typeof showMessageModal === 'function') {
        showMessageModal({ title: 'Notice', message: params.get('warning'), icon: 'warning', buttons: [{ text: 'OK', class: 'btn-warning' }] });
        window.history.replaceState({}, document.title, "/login");
    }
    const microsoftSessionLimit = parseJsonScript('microsoftSessionLimitJson', null);
    if (microsoftSessionLimit && Array.isArray(microsoftSessionLimit.activeSessions) && typeof showMessageModal === 'function') {
        showSessionLimitModal(microsoftSessionLimit);
        window.history.replaceState({}, document.title, "/login");
    }
});

// 3. LOGIN SUBMISSION
document.addEventListener('DOMContentLoaded', () => {
  const form = document.getElementById('loginForm');

  form.addEventListener('submit', async e => {
    e.preventDefault();
    const btn = form.querySelector('button[type="submit"]');
    const originalText = btn.innerHTML;
    
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status"></span> Checking...';

    // Gather Data
    const payload = {
        username: form.querySelector('input[name="username"]').value,
        password: form.querySelector('input[name="password"]').value
    };
    
    const captchaVal = document.getElementById('captchaInput').value;
    if (!document.getElementById('captchaContainer').classList.contains('d-none')) {
        payload.captcha = captchaVal;
    }

    try {
      const response = await fetch('/login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      const result = await response.json();

      if (response.ok) {
        window.location.href = result.redirectUrl || '/dashboard';
      } else {
        
        // A. CAPTCHA REQUIRED
        if (result.status === 'captcha_required') {
            showCaptcha();
            showMessageModal({
              title: 'Security Check',
              icon: 'warning',
              message: result.message || 'Please solve the CAPTCHA to prove you are human.',
              size: 'sm',
              buttons: [{ text: "OK", class: "btn-secondary" }]
            });
        }
        // B. SESSION LIMIT
        else if (result.status === 'session_limit_exceeded' && result.activeSessions) {
             showSessionLimitModal(result);
        } 
        // C. STANDARD ERROR
        else {
            showMessageModal({
              title: 'Login Failed',
              icon: 'error',
              message: result.message || 'Invalid credentials.',
              size: 'md',
              buttons: [{ text: "Try Again", class: "btn-danger" }]
            });
            if (!document.getElementById('captchaContainer').classList.contains('d-none')) {
                refreshCaptcha();
            }
        }
      }
    } catch (error) {
      console.error(error);
      alert('System Error');
    } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
    }
  });
});

window.killSessionAndLogin = async function(sessionId, authProvider = 'password') {
    const form = document.getElementById('loginForm');
    const username = form.querySelector('input[name="username"]').value;
    const password = form.querySelector('input[name="password"]').value;
    const btn = document.getElementById(getSessionButtonId(sessionId));
    if(btn) { btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>'; btn.disabled = true; }

    try {
        const res = await fetch('/force-login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ username, password, sessionIdToKill: sessionId, authProvider })
        });
        const json = await res.json();
        if (json.status === 'success') {
             window.location.href = json.redirectUrl || '/dashboard';
        } else {
             alert(json.message || 'Failed to terminate session.');
             window.location.reload();
        }
    } catch (err) {
        console.error(err);
        alert('Network error.');
    }
};
</script>

<style>
@keyframes fadeIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
.shake-element { animation: shake 0.5s; }
@keyframes shake {
  0% { transform: translateX(0); }
  25% { transform: translateX(-5px); }
  50% { transform: translateX(5px); }
  75% { transform: translateX(-5px); }
  100% { transform: translateX(0); }
}
.letter-spacing-2 { letter-spacing: 3px; }
.x-small { font-size: 0.75rem; }
</style>
