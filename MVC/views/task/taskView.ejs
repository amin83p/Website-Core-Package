<div class="modal fade" id="uploadDeliverableModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content resizable-modal-content"><form id="uploadForm"><input type="hidden" name="actionStateId" value="<%= stateId %>"><input type="hidden" name="taskId" value="<%= task.id %>"><input type="hidden" name="checkpointId" id="uploadCpId"><div class="modal-header"><h5 class="modal-title">Upload File</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label class="form-label">File</label><input type="file" name="file" class="form-control" required></div><div class="mb-3"><label class="form-label">Note</label><input type="text" name="description" class="form-control" placeholder="Description"></div></div><div class="modal-footer"><button type="button" class="btn btn-light" data-bs-dismiss="modal">Cancel</button><button type="submit" id="btnUploadSubmit" class="btn btn-primary">Upload</button></div></form><div class="modal-resize-grip"><svg viewBox="0 0 10 10" width="100%" height="100%" fill="#adb5bd"><path d="M10 10 L10 2 L2 10 Z" /></svg></div></div></div></div>
<div class="modal fade" id="updateCheckpointModal" tabindex="-1"><div class="modal-dialog"><div class="modal-content resizable-modal-content"><form action="/tasks/checkpoint/update" method="POST"><input type="hidden" name="actionStateId" value="<%= stateId %>"><input type="hidden" name="taskId" value="<%= task.id %>"><input type="hidden" name="checkpointId" id="modalCpId"><div class="modal-header"><h5 class="modal-title">Update Checkpoint</h5><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body"><div class="mb-3"><label>Title</label><input type="text" class="form-control" id="modalCpTitle" readonly></div><div class="row g-2 mb-3"><div class="col-6"><label>New Date</label><input type="date" name="newDate" id="modalCpDate" class="form-control"></div><div class="col-6"><label>Weight (%)</label><input type="number" name="newWeight" id="modalCpWeight" class="form-control"></div></div><div class="mb-3"><label>Criteria</label><textarea name="newCriteria" id="modalCpCriteria" class="form-control" rows="3"></textarea></div><div class="mb-3"><label class="text-danger">Reason *</label><textarea name="note" class="form-control" rows="2" required></textarea></div></div><div class="modal-footer"><button type="submit" class="btn btn-primary">Save Changes</button></div></form><div class="modal-resize-grip"><svg viewBox="0 0 10 10" width="100%" height="100%" fill="#adb5bd"><path d="M10 10 L10 2 L2 10 Z" /></svg></div></div></div></div>

<script>
    const serverComments = <%- JSON.stringify(rawComments) %>;
    const currentUserId = '<%= user.id %>';
</script>
<script>
    let currentFontSize = 1.1;
    function openReader(title, content) { document.getElementById('textReaderTitle').textContent = title; document.getElementById('textReaderContent').innerHTML = content; new bootstrap.Modal(document.getElementById('textReaderModal')).show(); }
    function adjustFont(delta) { currentFontSize += (delta * 0.1); if(currentFontSize < 0.8) currentFontSize = 0.8; if(currentFontSize > 2.0) currentFontSize = 2.0; document.getElementById('textReaderContent').style.fontSize = currentFontSize + 'rem'; }
    function setTheme(theme) { document.getElementById('textReaderContent').className = `reader-theme-${theme}`; }
    
    document.addEventListener('DOMContentLoaded', () => { 
        document.querySelectorAll('.modal-header').forEach(header => { 
            const dialog = header.closest('.modal-dialog'); 
            if(!dialog) return; 
            let isDragging = false, startX, startY, startLeft, startTop; 
            header.addEventListener('mousedown', (e) => { 
                if(e.target.closest('button') || e.target.closest('.btn-group')) return; 
                isDragging = true; startX = e.clientX; startY = e.clientY; header.style.cursor = 'grabbing'; 
                const rect = dialog.getBoundingClientRect(); 
                dialog.style.margin = '0'; dialog.style.position = 'absolute'; 
                dialog.style.left = rect.left + 'px'; dialog.style.top = rect.top + 'px'; 
                startLeft = rect.left; startTop = rect.top; 
            }); 
            window.addEventListener('mousemove', (e) => { 
                if (!isDragging) return; 
                e.preventDefault(); 
                const dx = e.clientX - startX; const dy = e.clientY - startY; 
                dialog.style.left = `${startLeft + dx}px`; dialog.style.top = `${startTop + dy}px`; 
            }); 
            window.addEventListener('mouseup', () => { if(isDragging) { isDragging = false; header.style.cursor = 'move'; } }); 
        }); 
    });
    
    function openUpdateModal(id, title, date, weight, criteria) { document.getElementById('modalCpId').value = id; document.getElementById('modalCpTitle').value = title; document.getElementById('modalCpDate').value = date === 'TBD' ? '' : date; document.getElementById('modalCpWeight').value = weight; document.getElementById('modalCpCriteria').value = criteria; new bootstrap.Modal(document.getElementById('updateCheckpointModal')).show(); }
    function openUploadModal(id) { document.getElementById('uploadCpId').value = id; new bootstrap.Modal(document.getElementById('uploadDeliverableModal')).show(); }
    function openCommentModal(id, title) { document.getElementById('commentCpId').value = id; document.getElementById('commentCpTitleDisplay').textContent = title; new bootstrap.Modal(document.getElementById('commentModal')).show(); }
    
    async function showMsg(t, m, i='info') { 
        if(typeof showMessageModal === 'function') 
            await showMessageModal({
                title:t, message:m, 
                icon:i, 
                buttons:[{text:'OK', class:'btn-primary'}]}); 
        else alert(m); 
    }
    async function confirmMsg(t, m) { if(typeof showMessageModal === 'function') { const res = await showMessageModal({title:t, message:m, icon:'warning', buttons:[{text:'Cancel', class:'btn-secondary'}, {text:'Confirm', class:'btn-primary'}]}); return res === 'Confirm'; } return confirm(m); }
    
function createFileRowHTML(f, isSidebar) {
        let deleteBtn = '';
        if(f.isGlobal || !isSidebar) { 
            deleteBtn = `<i class="bi bi-trash text-danger cursor-pointer small" onclick="deleteFile('${f.url}', '${f.checkpointId || ''}')"></i>`; 
        } 
        else { 
            deleteBtn = `<i class="bi bi-trash text-muted cursor-pointer small opacity-50" onclick="showMsg('File Attached to Step', 'This file belongs to step: <br><b>${f.stepName || 'Step'}</b>.<br><br>Please go to the timeline card for this step to delete it.', 'warning')"></i>`; 
        }
        
        const desc = f.description === '[Definition]' 
            ? '<span class="badge bg-warning text-dark border x-small ms-1">Definition</span>' 
            : `<div class="x-small text-muted">${f.description || 'No description'}</div>`;
        
        const iconClass = isSidebar 
            ? 'bi-file-earmark-text text-primary' 
            : 'bi-file-earmark-text text-primary fs-5';
        
        let containerClass = isSidebar 
            ? "list-group-item px-3 py-2 border-0 d-flex justify-content-between align-items-center file-row" 
            : "list-group-item p-2 border-0 d-flex justify-content-between align-items-center bg-light rounded mb-1 file-row";
        
        // ✅ UPDATED: Link now calls ImageViewer.open()
        return `<div class="${containerClass}" data-url="${f.url}"><div class="${isSidebar ? '' : 'd-flex align-items-center gap-2 overflow-hidden'}">${!isSidebar ? `<i class="${iconClass}"></i>` : ''}<a href="javascript:void(0)" onclick="ImageViewer.open('${f.url}', '${f.filename}', '${f.mimetype || ''}')" class="text-decoration-none text-dark d-flex align-items-center gap-2 overflow-hidden">${isSidebar ? `<i class="${iconClass}"></i>` : ''}<span class="text-truncate small fw-bold">${f.filename}</span></a>${!isSidebar ? desc : ''}</div>${isSidebar ? '' : `<div class="d-flex gap-2"><a href="${f.url}" download class="btn btn-sm btn-light border"><i class="bi bi-download"></i></a> ${deleteBtn}</div>`}${isSidebar ? deleteBtn : ''}</div>`;
    }

    async function updateStatus(cpId, status) { 
        if(!await confirmMsg("Update Status?", "Change status to " + status + "?")) return;
        try { 
            const res = await fetch('/tasks/checkpoint/status', { method: 'POST', headers: {'Content-Type':'application/json', 'X-AJAX-Request':'true'}, body: JSON.stringify({ taskId: '<%= task.id %>', checkpointId: cpId, status: status, actionStateId: '<%= stateId %>' }) });
            const data = await res.json();
            if(res.ok && data.status === 'success') {
                const card = document.getElementById('cp-' + cpId);
                const badgeContainer = document.getElementById('status-badge-' + cpId);
                const oldStatus = card.dataset.status;
                card.classList.remove(oldStatus); card.classList.add(status); card.dataset.status = status;
                
                let badgeHtml = '';
                if(status === 'completed') badgeHtml = '<span class="badge bg-success shadow-sm">Completed</span>';
                else if(status === 'submitted') badgeHtml = '<span class="badge bg-warning text-dark shadow-sm">Submitted</span>';
                else if(status === 'deleted') badgeHtml = '<span class="badge bg-secondary">Deleted</span>';
                else if(status === 'merged') badgeHtml = '<span class="badge bg-info text-dark">Merged</span>';
                else badgeHtml = '<span class="badge bg-primary">Active</span>';
                badgeContainer.innerHTML = badgeHtml;

                // 3. REFRESH LOCKS
                refreshLocks();
                
                // 4. REFRESH PROGRESS
                refreshProgress();

                await showMsg('Success', 'Status updated successfully.', 'success');
            } else { await showMsg('Error', data.message || 'Failed to update status', 'error'); }
        } catch(e) { await showMsg('Error', 'Network failed', 'error'); } 
    }

    function refreshLocks() {
        const allCards = document.querySelectorAll('.checkpoint-card');
        const stepStatusMap = {};
        
        allCards.forEach(card => {
            const idx = card.dataset.stepIndex;
            const status = card.dataset.status;
            stepStatusMap[idx] = status;
        });

        allCards.forEach(card => {
            const cpId = card.id.replace('cp-', '');
            const lockStep = card.dataset.lockStep;
            const lockStatus = card.dataset.lockStatus || 'completed';
            const currentStatus = card.dataset.status;
            
            let isLocked = false;
            let depMsg = '';
            
            if (lockStep && stepStatusMap[lockStep]) {
                const depStatus = stepStatusMap[lockStep];
                if (depStatus !== lockStatus) {
                    isLocked = true;
                    depMsg = `Locked until Step ${lockStep} is ${lockStatus}`;
                }
            }
            
            const isFinished = ['completed', 'submitted', 'deleted', 'merged'].includes(currentStatus);
            const isDisabled = isLocked || isFinished;

            const actionsDiv = document.getElementById(`actions-cp-${cpId}`);
            const lockMsgDiv = document.getElementById(`lock-msg-cp-${cpId}`);
            const statusMsgDiv = document.getElementById(`status-warning-cp-${cpId}`);
            const statusMsgText = document.getElementById(`locked-status-text-${cpId}`);
            const lockBadge = document.getElementById(`lock-badge-${cpId}`);
            const dropdown = document.getElementById(`dropdown-wrapper-${cpId}`);
            const fileActions = document.getElementById(`file-actions-cp-${cpId}`);

            if (isLocked) card.classList.add('locked-overlay');
            else card.classList.remove('locked-overlay');

            if (lockBadge) {
                if (isLocked) {
                    lockBadge.innerHTML = `<i class="bi bi-lock-fill me-1"></i> ${depMsg}`;
                    lockBadge.classList.remove('d-none');
                } else {
                    lockBadge.classList.add('d-none');
                }
            }

            if (dropdown) {
                if (isLocked) dropdown.classList.add('d-none');
                else dropdown.classList.remove('d-none');
            }

            if (actionsDiv) {
                if (isDisabled) actionsDiv.classList.add('d-none');
                else actionsDiv.classList.remove('d-none');
            }
            
            if (fileActions) {
                if (isDisabled) fileActions.classList.add('d-none');
                else fileActions.classList.remove('d-none');
            }

            if (lockMsgDiv) {
                if (isLocked) {
                    lockMsgDiv.innerHTML = `<i class="bi bi-lock-fill me-1"></i> ${depMsg}`;
                    lockMsgDiv.classList.remove('d-none');
                    if(statusMsgDiv) statusMsgDiv.classList.add('d-none'); 
                } else {
                    lockMsgDiv.classList.add('d-none');
                    if(statusMsgDiv) {
                        if (isFinished) {
                            statusMsgDiv.classList.remove('d-none');
                            if(statusMsgText) statusMsgText.innerText = currentStatus;
                        } else {
                            statusMsgDiv.classList.add('d-none');
                        }
                    }
                }
            }
        });
    }

    function refreshProgress() {
        const allCards = document.querySelectorAll('.checkpoint-card');
        let totalW = 0;
        let completedW = 0;

        allCards.forEach(card => {
            const w = parseInt(card.dataset.weight) || 0;
            const status = card.dataset.status;
            
            if (status !== 'deleted' && status !== 'merged') {
                totalW += w;
                if (status === 'completed') completedW += w;
            }
        });

        let pct = 0;
        if (totalW > 0) {
            pct = Math.round((completedW / totalW) * 100);
        } else {
            const activeCount = Array.from(allCards).filter(c => c.dataset.status !== 'deleted' && c.dataset.status !== 'merged').length;
            const completedCount = Array.from(allCards).filter(c => c.dataset.status === 'completed').length;
            if(activeCount > 0) pct = Math.round((completedCount / activeCount) * 100);
        }
        if (pct > 100) pct = 100;

        const bar = document.getElementById('task-progress-bar');
        const text = document.getElementById('task-progress-text');
        
        if(bar) {
            bar.style.width = pct + '%';
            bar.setAttribute('aria-valuenow', pct);
            if(pct >= 100) { bar.classList.remove('bg-primary'); bar.classList.add('bg-success'); }
            else { bar.classList.remove('bg-success'); bar.classList.add('bg-primary'); }
        }
        if(text) text.innerText = pct + '%';
    }

    async function deleteFile(url, cpId) { 
        if(!await confirmMsg("Delete File?", "Are you sure you want to permanently delete this file?")) return;
        try { 
            const res = await fetch('/tasks/deliverable/delete', { method: 'POST', headers: {'Content-Type':'application/json', 'X-AJAX-Request':'true'}, body: JSON.stringify({ taskId: '<%= task.id %>', fileUrl: url, checkpointId: cpId, actionStateId: '<%= stateId %>' }) });
            const data = await res.json(); 
            if(data.status === 'success') {
                document.querySelectorAll(`.file-row[data-url="${url}"]`).forEach(row => row.remove());
                const sbBadge = document.getElementById('sidebar-file-count');
                if(sbBadge) sbBadge.innerText = Math.max(0, parseInt(sbBadge.innerText) - 1);
                if(cpId) {
                    const cpBadge = document.getElementById('cp-file-count-' + cpId);
                    if(cpBadge) cpBadge.innerText = Math.max(0, parseInt(cpBadge.innerText) - 1);
                    const list = document.getElementById('cp-files-list-' + cpId);
                    if(list && list.children.length === 0) list.innerHTML = '<div class="text-center p-4 text-muted small bg-light rounded border-dashed no-files-msg"><i class="bi bi-paperclip fs-4 d-block mb-2 opacity-50"></i> No files attached.</div>';
                }
                const sbList = document.getElementById('sidebar-files-list');
                if(sbList && sbList.children.length === 0) sbList.innerHTML = '<div class="text-center p-3 text-muted small fst-italic no-files-msg">No files found.</div>';
                await showMsg('Deleted', 'File removed.', 'success');
            } else await showMsg('Error', data.message, 'error');
        } catch(e) { await showMsg('Error', 'Network failed', 'error'); } 
    }
    
    document.getElementById('uploadForm').addEventListener('submit', async function(e) { 
        e.preventDefault(); 
        const fd = new FormData(this); 
        const actionId = '<%= stateId %>'; 
        const submitBtn = this.querySelector('button[type="submit"]'); 
        const originalText = submitBtn.innerHTML; submitBtn.innerHTML = 'Uploading...'; 
        submitBtn.disabled = true;
        
        try { 
            const url = `/tasks/deliverable/upload?actionStateId=${encodeURIComponent(actionId)}`;            
            const res = await fetch(url, { method:'POST', headers:{'X-AJAX-Request':'true'}, body:fd }); 
            const data = await res.json(); 
            if(data.status === 'success') { 
                const f = data.file; 
                const modalEl = document.getElementById('uploadDeliverableModal');
                const modal = bootstrap.Modal.getInstance(modalEl); 
                const sidebarList = document.getElementById('sidebar-files-list'); 
                if(sidebarList) { 
                    const emptyMsg = sidebarList.querySelector('.no-files-msg');
                    if(emptyMsg) emptyMsg.remove(); 
                    f.isGlobal = !f.checkpointId; 
                    if(f.checkpointId) { 
                        const stepTitleEl = document.querySelector(`#cp-${f.checkpointId} .card-title`);
                        f.stepName = stepTitleEl ? stepTitleEl.innerText.trim() : 'Step'; 
                    } 
                    sidebarList.insertAdjacentHTML('afterbegin', createFileRowHTML(f, true));
                    const sbBadge = document.getElementById('sidebar-file-count'); 
                    if(sbBadge) sbBadge.innerText = parseInt(sbBadge.innerText) + 1;
                } 
                if(f.checkpointId) { 
                    const cpList = document.getElementById(`cp-files-list-${f.checkpointId}`);
                    if(cpList) { 
                        const emptyMsg = cpList.querySelector('.no-files-msg');
                        if(emptyMsg) emptyMsg.remove(); 
                        cpList.insertAdjacentHTML('afterbegin', createFileRowHTML(f, false)); 
                        const cpBadge = document.getElementById('cp-file-count-' + f.checkpointId); 
                        if(cpBadge) cpBadge.innerText = parseInt(cpBadge.innerText) + 1;
                    }
                } 
                modal.hide();
                await showMsg('Success', 'File attached successfully.', 'success'); 
                this.reset(); 
            } else { 
                await showMsg('Error', data.message, 'error');
            } 
        } catch(e) { 
            await showMsg('Error', 'Failed', 'error');
        } 
        finally { 
            submitBtn.innerHTML = originalText;
            submitBtn.disabled = false; 
        }
    });

    document.getElementById('commentForm').addEventListener('submit', async function(e) { 
        e.preventDefault(); 
        const fd = new FormData(this); 
        const actionId = '<%= stateId %>';
        try { 
            const url = `/tasks/comment/add?actionStateId=${encodeURIComponent(actionId)}`;            
            const res = await fetch(url, { method:'POST', headers:{'X-AJAX-Request':'true'}, body:fd });
            const d = await res.json(); 
            if(d.status === 'success') { 
                const modal = bootstrap.Modal.getInstance(document.getElementById('commentModal')); 
                modal.hide(); 
                this.reset(); 
                const cpId = fd.get('checkpointId');
                const historyContainer = document.getElementById(`history-container-${cpId}`); 
                if(historyContainer) { 
                    const emptyMsg = historyContainer.querySelector('.no-history-msg');
                    if(emptyMsg) emptyMsg.remove(); 
                    const item = d.entry; 
                    const newHtml = `<div class="d-flex gap-2"><div class="avatar-sm rounded-circle bg-secondary text-white flex-shrink-0">${(item.userName||'U').charAt(0)}</div><div><div class="comment-bubble"><strong>${item.userName}:</strong> ${item.details}${item.file ? `<div class="mt-1 border-top pt-1"><a href="${item.file.url}" target="_blank"><i class="bi bi-paperclip"></i> ${item.file.filename}</a></div>` : ''}</div><div class="x-small text-muted ms-1">${new Date().toLocaleString()}</div></div></div>`;
                    const wrapper = historyContainer.querySelector('.d-flex.flex-column'); 
                    if(wrapper) wrapper.insertAdjacentHTML('afterbegin', newHtml); 
                    else historyContainer.insertAdjacentHTML('afterbegin', `<div class="d-flex flex-column gap-3">${newHtml}</div>`);
                } 
                await showMsg('Success', 'Comment added.', 'success');
            } else await showMsg('Error', d.message, 'error'); 
        } catch(e) { 
            await showMsg('Error', 'Failed', 'error');
        } 
    });
</script>