<div class="modal fade" id="textReaderModal" tabindex="-1"><div class="modal-dialog modal-lg modal-dialog-scrollable"><div class="modal-content resizable-modal-content"><div class="modal-header bg-light border-bottom-0 pb-2"><h5 class="modal-title fw-bold" id="textReaderTitle">Reading View</h5><div class="ms-auto d-flex align-items-center gap-2 me-3"><div class="btn-group btn-group-sm"><button class="btn btn-outline-secondary" onclick="adjustFont(-1)"><i class="bi bi-dash-lg"></i></button><button class="btn btn-outline-secondary" onclick="adjustFont(1)"><i class="bi bi-plus-lg"></i></button></div><div class="btn-group btn-group-sm"><button class="btn btn-outline-secondary" onclick="setTheme('light')"><i class="bi bi-brightness-high"></i></button><button class="btn btn-outline-secondary" onclick="setTheme('sepia')"><i class="bi bi-journal-text"></i></button><button class="btn btn-outline-secondary" onclick="setTheme('dark')"><i class="bi bi-moon"></i></button></div></div><button type="button" class="btn-close" data-bs-dismiss="modal"></button></div><div class="modal-body pt-0"><div id="textReaderContent" class="reader-theme-light"></div></div><div class="modal-resize-grip"><svg viewBox="0 0 10 10" width="100%" height="100%" fill="#adb5bd"><path d="M10 10 L10 2 L2 10 Z" /></svg></div></div></div></div>
