<%
  const isEdit = !!(task && task.id);
  const initAssignments = (task && task.assignments) ? task.assignments : [];
  
  const initSteps = (task && task.checkpoints) ? task.checkpoints.map(cp => {
      let d = '';
      if(cp.dates && cp.dates.current) d = cp.dates.current;
      else if(cp.date) d = cp.date; 
      
      return {
          id: cp.id,
          title: cp.title,
          date: d,
          weight: cp.weight || 0,
          criteria: cp.criteria || ''
      };
  }) : [];

  // Calculate files for tab
  let allFiles = [];
  if (isEdit && task) {
      if (task.deliverables) allFiles = [...task.deliverables.map(f => ({...f, isGlobal: true}))];
      if (task.checkpoints) {
          task.checkpoints.forEach(cp => {
              if (cp.deliverables) {
                  allFiles.push(...cp.deliverables.map(f => ({...f, stepName: cp.title, checkpointId: cp.id, isGlobal: false})));
              }
          });
      }
      allFiles.sort((a, b) => new Date(b.uploadedAt || 0) - new Date(a.uploadedAt || 0));
  }
%>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">

<div class="tasks-page">
  
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h1 class="page-heading size-md m-0"><%= isEdit ? 'Edit Task Structure' : 'Create New Task' %></h1>
        <% if (isEdit) { %>
            <div class="text-muted small mt-1">ID: <%= task.id %></div>
        <% } %>
    </div>
    
    <% if (isEdit) { %>
        <div class="d-flex gap-2">
            <a href="/tasks/<%= task.id %>" class="btn btn-sm btn-outline-secondary">
                <i class="bi bi-eye me-1"></i> View Task Management
            </a>
        </div>
    <% } %>
  </div>

  <div class="row">
      <div class="col-12">
          <div class="form-container" style="width: 100%; max-width: 100%;">
            <form id="taskForm" action="<%= isEdit ? '/tasks/edit/' + task.id : '/tasks/new' %>" method="POST" novalidate>
              <input type="hidden" name="actionStateId" value="<%= typeof actionStateId !== 'undefined' ? actionStateId : '' %>">
              <input type="hidden" name="assignments" id="assignmentsInput">
              <input type="hidden" name="steps" id="stepsInput">
              
              <input type="hidden" name="description" id="hiddenDescription">
              
              <script type="application/json" id="initAssignmentsData"><%- JSON.stringify(initAssignments) %></script>
              <script type="application/json" id="initStepsData"><%- JSON.stringify(initSteps) %></script>

              <ul class="nav nav-tabs mb-4" id="taskTabs" role="tablist">
                <li class="nav-item"><button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button">General Details</button></li>
                <li class="nav-item"><button class="nav-link" id="team-tab" data-bs-toggle="tab" data-bs-target="#team" type="button">Team & Roles</button></li>
                <li class="nav-item"><button class="nav-link" id="timeline-tab" data-bs-toggle="tab" data-bs-target="#timeline" type="button">Timeline & Steps</button></li>
                <% if(isEdit) { %>
                <li class="nav-item"><button class="nav-link" id="files-tab" data-bs-toggle="tab" data-bs-target="#files" type="button">Attached Files <span class="badge bg-secondary ms-1 rounded-pill"><%= allFiles.length %></span></button></li>
                <% } %>
              </ul>

              <div class="tab-content">
                <div class="tab-pane fade show active" id="general">
                    <div class="row">
                        <div class="col-md-8">
                            <div class="mb-3">
                                <label class="form-label">Task Title <span class="text-danger">*</span></label>
                                <input type="text" name="title" id="inpTitle" class="form-control size-md" value="<%= task ? task.title : '' %>" required>
                                <div class="invalid-feedback">Task title is required.</div>
                            </div>
                            <div class="row">
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Project / Context</label>
                                    <input type="text" name="projectName" list="projectList" class="form-control size-md" value="<%= task ? task.projectName : '' %>">
                                    <datalist id="projectList"><option value="General"><option value="Audit"><option value="Development"></datalist>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <label class="form-label">Phase</label>
                                    <input type="text" name="phaseName" class="form-control size-md" value="<%= task ? task.phaseName : '' %>" placeholder="e.g. Planning">
                                </div>
                            </div>
                            
                            <div class="mb-3">
                                <label class="form-label">Description</label>
                                <div class="resizable-editor-container">
                                    <div id="desc-editor" class="quill-docked">
                                        <%- task ? task.description : '' %>
                                    </div>
                                </div>
                                <div class="form-text small text-muted text-end">Drag bottom right corner to resize</div>
                            </div>
                        </div>
                        
                        <div class="col-md-4">
                            <div class="card bg-light border-0 mb-3">
                                <div class="card-body">
                                    <h6 class="fw-bold text-primary mb-3">Status & Priority</h6>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">Priority</label>
                                        <select name="priority" class="form-select size-sm">
                                            <% ['low', 'medium', 'high', 'critical'].forEach(p => { %>
                                                <option value="<%= p %>" <%= (task && task.priority === p) ? 'selected' : '' %>><%= p.charAt(0).toUpperCase() + p.slice(1) %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <% if (isEdit) { %>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold">Status</label>
                                        <select name="status" class="form-select size-sm">
                                            <% ['todo', 'in_progress', 'review', 'done'].forEach(s => { %>
                                                <option value="<%= s %>" <%= (task && task.status === s) ? 'selected' : '' %>><%= s.replace('_', ' ').toUpperCase() %></option>
                                            <% }) %>
                                        </select>
                                    </div>
                                    <% } %>
                                    <hr>
                                    <div class="mb-2">
                                        <label class="form-label small fw-bold">Start Date</label>
                                        <input type="date" name="startDate" class="form-control size-sm" value="<%= task && task.dates ? task.dates.start : '' %>">
                                    </div>
                                    <div class="mb-2">
                                        <label class="form-label small fw-bold text-danger">Due Date</label>
                                        <input type="date" name="dueDate" class="form-control size-sm" value="<%= task && task.dates ? task.dates.due : '' %>">
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="team">
                    <div class="row">
                        <div class="col-md-5 border-end">
                            <h6 class="fw-bold text-secondary mb-3">Add Member</h6>
                            <div class="mb-3">
                                <label class="form-label small text-muted">Select User</label>
                                <div class="input-group">
                                     <input type="hidden" id="selectedUserId">
                                     <input type="text" id="selectedUserName" class="form-control size-sm bg-white" placeholder="No user selected" readonly>
                                     <button type="button" class="btn btn-outline-primary btn-sm" id="btnPickUser"><i class="bi bi-search"></i></button>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label small text-muted">Role</label>
                                <select class="form-select size-sm mb-2" id="roleSelect">
                                    <option value="viewer">Viewer</option>
                                    <option value="editor" selected>Editor</option>
                                    <option value="owner">Owner</option>
                                    <option value="coordinator">Coordinator</option>
                                    <option value="approver">Approver</option>
                                    <option value="executor">Executor</option>
                                </select>
                            </div>
                            <button type="button" class="btn btn-primary btn-sm w-100" id="btnAddUser">
                                <i class="bi bi-person-plus-fill me-1"></i> Add to Team
                            </button>
                        </div>
                        <div class="col-md-7">
                            <h6 class="fw-bold text-primary mb-3">Assignments</h6>
                            <div class="list-group list-group-flush border rounded bg-white" id="assignmentsList" style="min-height: 150px;"></div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="timeline">
                    <div class="row">
                        <div class="col-md-5 border-end">
                             <h6 class="fw-bold text-secondary mb-3">Add Checkpoint</h6>
                             <div class="mb-2">
                                <label class="small text-muted">Title *</label>
                                <input type="text" id="stepTitle" class="form-control size-sm" placeholder="e.g. Draft Review">
                             </div>
                             <div class="row g-2 mb-2">
                                 <div class="col-6">
                                    <label class="small text-muted">Date</label>
                                    <input type="date" id="stepDate" class="form-control size-sm">
                                 </div>
                                 <div class="col-6">
                                    <label class="small text-muted">Weight (%)</label>
                                    <input type="number" id="stepWeight" class="form-control size-sm" placeholder="0">
                                 </div>
                             </div>
                             
                             <div class="mb-2">
                                <label class="small text-muted">Criteria / Note</label>
                                <div class="resizable-editor-container">
                                    <div id="criteria-editor" class="quill-docked"></div>
                                </div>
                                <div class="form-text small text-muted text-end">Drag bottom right corner to resize</div>
                             </div>
                             
                             <button type="button" class="btn btn-secondary btn-sm w-100 mt-2" id="btnAddStep">
                                <i class="bi bi-plus-lg me-1"></i> Add Checkpoint
                             </button>
                        </div>
                        <div class="col-md-7">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="fw-bold text-primary m-0">Timeline</h6>
                                <span class="badge bg-light text-dark border">Total Weight: <span id="totalWeightDisplay">0</span>%</span>
                            </div>
                            <div class="list-group list-group-flush border rounded bg-white" id="stepsList" style="min-height: 150px;"></div>
                        </div>
                    </div>
                </div>

                <% if(isEdit) { %>
                <div class="tab-pane fade" id="files">
                    <div class="row">
                        <div class="col-12">
                            <h6 class="fw-bold text-primary mb-3">Attached Files</h6>
                            
                            <% if(allFiles.length > 0) { %>
                                <div class="table-responsive border rounded bg-white">
                                    <table class="table table-hover mb-0 align-middle">
                                        <thead class="bg-light">
                                            <tr>
                                                <th class="ps-3">Filename</th>
                                                <th>Context</th>
                                                <th>Uploaded</th>
                                                <th class="text-end pe-3">Action</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% allFiles.forEach(f => { %>
                                                <tr>
                                                    <td class="ps-3">
                                                        <a href="<%= f.url %>" target="_blank" class="text-decoration-none fw-bold text-dark">
                                                            <i class="bi bi-file-earmark-text text-primary me-2"></i><%= f.filename %>
                                                        </a>
                                                        <% if(f.description) { %><div class="small text-muted ms-4"><%= f.description %></div><% } %>
                                                    </td>
                                                    <td>
                                                        <% if(f.isGlobal) { %>
                                                            <span class="badge bg-secondary">Global</span>
                                                        <% } else { %>
                                                            <span class="badge bg-info text-dark" title="Step ID: <%= f.checkpointId %>">Step: <%= f.stepName %></span>
                                                        <% } %>
                                                    </td>
                                                    <td class="small text-muted"><%= typeof formatOrgDateTime === 'function' ? formatOrgDateTime(f.uploadedAt, { month: 'short', day: 'numeric', year: 'numeric' }) : new Date(f.uploadedAt).toLocaleDateString() %></td>
                                                    <td class="text-end pe-3">
                                                        <a href="<%= f.url %>" download class="btn btn-sm btn-light border"><i class="bi bi-download"></i></a>
                                                    </td>
                                                </tr>
                                            <% }) %>
                                        </tbody>
                                    </table>
                                </div>
                            <% } else { %>
                                <div class="text-center p-5 text-muted bg-light rounded border-dashed">
                                    <i class="bi bi-folder2-open fs-1 opacity-25"></i>
                                    <p class="mt-2">No files attached to this task yet.</p>
                                </div>
                            <% } %>
                        </div>
                    </div>
                </div>
                <% } %>

              </div>

              <div class="button-row mt-4 pt-3 border-top">
                <button type="submit" id="btnSaveTask" class="btn btn-filled btn-primary btn-md">Save Task</button>
                <a href="/tasks" class="btn btn-filled btn-secondary btn-md">Cancel</a>
              </div>
            </form>
          </div>
      </div>
  </div>
</div>

<%- include('../partials/modal_GenericPicker') %>

<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // --- 1. RICH TEXT EDITORS ---
    var toolbarOptions = [
        ['bold', 'italic', 'underline', 'strike'],
        [{ 'list': 'ordered'}, { 'list': 'bullet' }],
        [{ 'color': [] }, { 'background': [] }],
        ['clean']
    ];

    // Description Editor
    var descQuill = new Quill('#desc-editor', {
        theme: 'snow',
        placeholder: 'Task background, goals, and details...',
        modules: { toolbar: toolbarOptions }
    });

    // Criteria Editor
    var criteriaQuill = new Quill('#criteria-editor', {
        theme: 'snow',
        placeholder: 'Definition of done...',
        modules: { toolbar: toolbarOptions }
    });

    // --- 2. STATE & DOM ---
    let assignments = [];
    let steps = [];
    const assignmentsList = document.getElementById('assignmentsList');
    const stepsList = document.getElementById('stepsList');
    const form = document.getElementById('taskForm');
    const saveBtn = document.getElementById('btnSaveTask');
    const totalWeightDisplay = document.getElementById('totalWeightDisplay');

    // --- 3. INIT ---
    try {
        const initA = JSON.parse(document.getElementById('initAssignmentsData').textContent);
        const initS = JSON.parse(document.getElementById('initStepsData').textContent);
        initA.forEach(a => assignments.push(a));
        initS.forEach(s => steps.push(s));
        renderAssignments();
        renderSteps();
    } catch(e) { console.error("Init Error", e); }

    // --- 4. ASSIGNMENT LOGIC ---
    if(document.getElementById('btnPickUser')) {
        document.getElementById('btnPickUser').addEventListener('click', () => {
            GenericPicker.open(GenericPickerPresets.user({
                title: 'Select User',
                context: GenericPickerContexts.scope('Users'),
                onSelect: (item) => {
                    document.getElementById('selectedUserId').value = item.id;
                    document.getElementById('selectedUserName').value = `${item.name || item.username}`;
                }
            }));
        });
    }

    document.getElementById('btnAddUser').addEventListener('click', async () => {
        const id = document.getElementById('selectedUserId').value;
        if(!id){
            if(typeof showMessageModal === 'function') {
                await showMessageModal({
                    title: 'Users/Team', 
                    message: msg, 
                    icon: 'warning', 
                    buttons: [{text:'Ok', class:'btn-warning'}]
                });
            }else{
                return alert("Select user first.");
            }
        }
        //
        const existing = assignments.find(a => a.userId === id);
        if(existing) {
            const msg = `User is already assigned with Role: ${existing.role} and Status: ${existing.status}.<br>
                         Do you want to take the place the new role to their current role?`;
            if(typeof showMessageModal === 'function') {
                const res = await showMessageModal({
                    title: 'Users/Team', 
                    message: msg, 
                    icon: 'warning', 
                    buttons: [{text:'Cancel', class:'btn-secondary'}, {text:'Replace', class:'btn-warning'}]
                });
                confirmed = (res === 'Replace');
                if(!confirmed) return;
            }else{
                const msg1 = `User is already assigned with Role: ${existing.role} and Status: ${existing.status}.<br>
                              The new role will take the place of their current role.`;
               alert(msg1);
            }
            existing.status = 'active';
            existing.role = document.getElementById('roleSelect').value;
        }else{
            assignments.push({
                userId: id,
                name: document.getElementById('selectedUserName').value,
                role: document.getElementById('roleSelect').value,
                status: 'active'
            });
        }
        document.getElementById('selectedUserId').value = '';
        document.getElementById('selectedUserName').value = '';
        renderAssignments();
    });

    function toggleUserStatus(userId) {
        const u = assignments.find(a => a.userId === userId);
        if(u) {
            u.status = (u.status === 'active' ? 'disabled' : 'active');
            renderAssignments();
        }
    }

    function renderAssignments() {
        assignmentsList.innerHTML = '';
        if(assignments.length === 0) assignmentsList.innerHTML = '<div class="p-3 text-center text-muted small">No assignments</div>';
        
        assignments.forEach(a => {
            const isDisabled = a.status === 'disabled';
            const el = document.createElement('div');
            el.className = `list-group-item d-flex justify-content-between align-items-center ${isDisabled ? 'bg-light text-muted' : ''}`;
            el.innerHTML = `
                <div>
                    <span class="fw-bold">${a.name}</span>
                    <span class="badge ${isDisabled ? 'bg-secondary' : 'bg-light text-dark border'} ms-2">${a.role}</span>
                    ${isDisabled ? '<span class="badge bg-danger ms-1">Disabled</span>' : ''}
                </div>
                <button type="button" class="btn btn-sm text-secondary toggle-status" title="${isDisabled ? 'Enable' : 'Disable'}">
                    <i class="bi ${isDisabled ? 'bi-eye-slash-fill' : 'bi-eye-fill'}"></i>
                </button>
            `;
            el.querySelector('.toggle-status').addEventListener('click', () => toggleUserStatus(a.userId));
            assignmentsList.appendChild(el);
        });
    }

    // --- 5. CHECKPOINT LOGIC ---
    document.getElementById('btnAddStep').addEventListener('click', () => {
        const title = document.getElementById('stepTitle').value;
        if(!title) return document.getElementById('stepTitle').focus();
        
        // Get HTML from Quill
        const criteriaHTML = criteriaQuill.root.innerHTML === '<p><br></p>' ? '' : criteriaQuill.root.innerHTML;

        steps.push({
            id: null,
            title: title,
            date: document.getElementById('stepDate').value || '',
            weight: parseInt(document.getElementById('stepWeight').value) || 0,
            criteria: criteriaHTML
        });
        
        // Clear Inputs
        document.getElementById('stepTitle').value = '';
        document.getElementById('stepWeight').value = '';
        document.getElementById('stepDate').value = '';
        criteriaQuill.setContents([]); // Clear Editor
        
        renderSteps();
    });

    async function removeStep(idx) {
        let confirmed = false;
        
        const msg = "Are you sure you want to remove this checkpoint? This action will remove it from the timeline logic upon save.";
        
        if(typeof showMessageModal === 'function') {
            const res = await showMessageModal({
                title: 'Remove Checkpoint?', 
                message: msg, 
                icon: 'warning', 
                buttons: [{text:'Cancel', class:'btn-secondary'}, {text:'Remove', class:'btn-danger'}]
            });
            confirmed = (res === 'Remove');
        } else {
            confirmed = confirm(msg);
        }

        if(confirmed) {
            steps.splice(idx, 1);
            renderSteps();
        }
    }

    function renderSteps() {
        stepsList.innerHTML = '';
        let totalW = 0;
        steps.sort((a,b) => {
            if(!a.date) return 1;
            if(!b.date) return -1;
            return new Date(a.date) - new Date(b.date);
        });

        steps.forEach((s, idx) => {
            totalW += (parseInt(s.weight) || 0);
            const el = document.createElement('div');
            el.className = 'list-group-item d-flex justify-content-between align-items-center';
            el.innerHTML = `
                <div class="d-flex align-items-center gap-2 overflow-hidden">
                    <span class="badge bg-light text-secondary border rounded-circle flex-shrink-0">${idx+1}</span>
                    <div class="overflow-hidden">
                        <div class="fw-bold small text-truncate">${s.title} <span class="text-primary x-small ms-1">(${s.weight}%)</span></div>
                        <div class="x-small text-muted">${s.date ? s.date : 'No Date'} ${s.criteria ? '• Has Criteria' : ''}</div>
                    </div>
                </div>
                <button type="button" class="btn btn-sm text-danger remove-step flex-shrink-0"><i class="bi bi-x-lg"></i></button>
            `;
            el.querySelector('.remove-step').onclick = () => removeStep(idx);
            stepsList.appendChild(el);
        });
        totalWeightDisplay.textContent = totalW;
        totalWeightDisplay.className = totalW > 100 ? 'text-danger fw-bold' : (totalW === 100 ? 'text-success fw-bold' : '');
    }

    // --- 6. SUBMIT LOGIC ---
    saveBtn.addEventListener('click', (e) => {
        if (!form.checkValidity()) {
            const invalidEl = form.querySelector(':invalid');
            if (invalidEl) {
                const tabPane = invalidEl.closest('.tab-pane');
                if (tabPane) {
                    const tabButton = document.querySelector(`button[data-bs-target="#${tabPane.id}"]`);
                    if(tabButton) new bootstrap.Tab(tabButton).show();
                }
                setTimeout(() => invalidEl.focus(), 150);
            }
        }
    });

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const titleIn = document.getElementById('inpTitle');
        if(!titleIn.value.trim()) {
            titleIn.classList.add('is-invalid');
            new bootstrap.Tab(document.querySelector('#general-tab')).show();
            titleIn.focus();
            return;
        } else {
            titleIn.classList.remove('is-invalid');
        }

        document.getElementById('assignmentsInput').value = JSON.stringify(assignments);
        document.getElementById('stepsInput').value = JSON.stringify(steps);
        document.getElementById('hiddenDescription').value = descQuill.root.innerHTML;
        
        const formData = new FormData(form);
        const originalText = saveBtn.innerHTML;
        saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Saving...';
        saveBtn.disabled = true;

        try {
            const res = await fetch(form.action, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-AJAX-Request': 'true' },
                body: new URLSearchParams(formData).toString()
            });
            const data = await res.json();
            
            if(data.status === 'success') {
                if(typeof showMessageModal === 'function') {
                    await showMessageModal({ title: 'Success', icon: 'success', message: data.message, buttons: [{text:'OK', class:'btn-success'}]});
                }
                window.location.href = '/tasks';
            } else {
                if(typeof showMessageModal === 'function') {
                    await showMessageModal({ title: 'Error', icon: 'error', message: data.message, buttons: [{text:'OK', class:'btn-danger'}]});
                } else { alert(data.message); }
            }
        } catch(err) {
            if(typeof showMessageModal === 'function') {
                await showMessageModal({ title: 'Error', icon: 'error', message: err.message, buttons: [{text:'OK', class:'btn-danger'}]});
            }else{
                console.error(err);
                alert("Unexpected error.");
            }
        } finally {
            saveBtn.innerHTML = originalText;
            saveBtn.disabled = false;
        }
    });
});
</script>
<style>
    .form-control.is-invalid { border-color: #dc3545; background-image: none; }
    .x-small { font-size: 0.75rem; }
    
    /* Fix Quill toolbar borders */
    .ql-toolbar.ql-snow { border-top-left-radius: 4px; border-top-right-radius: 4px; }
    .ql-container.ql-snow { border-bottom-left-radius: 4px; border-bottom-right-radius: 4px; }
    
    /* ✅ Resizable & Docked Container Logic */
    .resizable-editor-container {
        resize: vertical;
        overflow: hidden;
        min-height: 150px;
        border: 1px solid #ccc;
        border-radius: 4px;
        display: flex;
        flex-direction: column;
    }
    
    /* Force Quill to fill the resizable parent */
    .quill-docked {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        height: 100%;
    }
    .quill-docked .ql-editor {
        flex-grow: 1;
        overflow-y: auto;
    }
</style>
