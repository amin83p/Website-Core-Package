<%
  const p = person || {};
  const personProfileType = p.personProfileType === 'organization' ? 'organization' : 'individual';
  const organizationProfile = p.organizationProfile || {};
  const name = p.name || {};
  const dem = p.demographics || {};
  const contact = p.contact || {};
  const addressesLegacy = p.address || {};
  const addressesInit = p.addresses || (Object.keys(addressesLegacy).length ? [addressesLegacy] : []);
  const orgsInit = p.organizations || [];
  const manualTagPresets = Array.isArray(locals.manualTagPresets) ? locals.manualTagPresets : [];
  const systemTagKeys = Array.isArray(locals.systemTagKeys) ? locals.systemTagKeys : [
    'school_student',
    'school_funder',
    'school_teacher',
    'school_staff',
    'pte_student',
    'pte_teacher',
    'pte_instructor',
    'pte_trainer',
    'credit_customer'
  ];
  const systemTagSet = new Set(systemTagKeys.map((x) => String(x || '').toLowerCase()));
  const personSystemTags = Array.isArray(p.systemTags) ? p.systemTags : (Array.isArray(p.tags) ? p.tags.filter((t) => systemTagSet.has(String(t || '').toLowerCase())) : []);
  const personManualTags = Array.isArray(p.manualTags)
    ? p.manualTags
    : (Array.isArray(p.tags) ? p.tags.filter((t) => !systemTagSet.has(String(t || '').toLowerCase())) : []);
  const organizationRolePresets = Array.from(new Set(
    ['member', 'admin', ...manualTagPresets]
      .map((x) => String(x || '').trim().toLowerCase())
      .filter(Boolean)
  ));
  
  const isLoggedIn = true;
  const accessLevel = Number(user?.accessLevel || 0);

  // Admin Features
  const canEditOrgs = (typeof canEditOrganizations === 'boolean')
    ? canEditOrganizations
    : (accessLevel > 7);
%>

<div class="sections-page">
    <%- include('../partials/formPage_PageTitle', {
      isEditMode: p.id,
      name: 'Person',
      id: p?.id || 0
    }) %>

  <div class="form-container wide" style="width: 100%; max-width: 1400px;">
    <form id="personForm"
          action="<%= p.id ? '/persons/edit/' + p.id : '/persons/new' %>"
          method="POST">

      <input type="hidden" name="actionStateId" value="<%= typeof actionStateId !== 'undefined' ? actionStateId : '' %>">
      
      <input type="hidden" id="emailsHidden" name="emails">
      <input type="hidden" id="phonesHidden" name="phones">
      <input type="hidden" id="addressesHidden" name="addresses">
      <input type="hidden" id="organizationsHidden" name="organizations">
      <input type="hidden" id="manualTagsHidden" name="manualTags" value="<%= personManualTags.join(', ') %>">

      <script type="application/json" id="initEmails"><%- JSON.stringify(contact.emails || (contact.email ? [{type:"primary",email:contact.email,isPrimary:true}] : [])) %></script>
      <script type="application/json" id="initPhones"><%- JSON.stringify(contact.phones || []) %></script>
      <script type="application/json" id="initAddresses"><%- JSON.stringify(addressesInit || []) %></script>
      <script type="application/json" id="initOrganizations"><%- JSON.stringify(orgsInit || []) %></script>
      <script type="application/json" id="manualTagPresetsJson"><%- JSON.stringify(manualTagPresets || []) %></script>
      <script type="application/json" id="systemTagKeysJson"><%- JSON.stringify(systemTagKeys || []) %></script>
      <script type="application/json" id="organizationRolePresetsJson"><%- JSON.stringify(organizationRolePresets || []) %></script>
      <script type="application/json" id="initManualTags"><%- JSON.stringify(personManualTags || []) %></script>

      <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item">
            <button class="nav-link active fw-bold" data-bs-toggle="tab" data-bs-target="#tab-profile" type="button">
                <i class="bi bi-person-vcard me-2"></i>Profile & Identity
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-contact" type="button">
                <i class="bi bi-envelope-paper me-2"></i>Contact & Addresses
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-orgs" type="button">
                <i class="bi bi-building me-2"></i>Organizations
            </button>
        </li>
        <li class="nav-item">
            <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-system" type="button">
                <i class="bi bi-gear me-2"></i>System & Notes
            </button>
        </li>
      </ul>

      <div class="tab-content">

        <div class="tab-pane fade show active" id="tab-profile">
            <div class="card border-0 bg-light shadow-sm mb-4">
                <div class="card-body">
                    <div class="fw-bold text-primary mb-1"><i class="bi bi-diagram-3 me-2"></i>Role Composition</div>
                    <div class="small text-muted mb-3">Current roles are derived from the organization memberships attached to this person.</div>
                    <div id="personRoleSummary"></div>
                </div>
            </div>
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <h6 class="fw-bold text-uppercase text-muted mb-3"><i class="bi bi-person-bounding-box me-2"></i>Profile Type</h6>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label d-block">Profile Type</label>
                            <% if (p.id) { %>
                              <input type="hidden" name="personProfileType" id="personProfileType" value="<%= personProfileType %>">
                              <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                                <span class="badge text-bg-<%= personProfileType === 'organization' ? 'primary' : 'secondary' %> px-3 py-2">
                                  <% if (personProfileType === 'organization') { %>
                                    <i class="bi bi-building me-1"></i>Organization / Company
                                  <% } else { %>
                                    <i class="bi bi-person me-1"></i>Individual
                                  <% } %>
                                </span>
                              </div>
                              <div class="alert alert-warning py-2 px-3 mb-0 small" role="status">
                                <i class="bi bi-lock-fill me-1"></i>
                                Profile type cannot be changed after the person is created. Create a new person record if the wrong type was selected.
                              </div>
                            <% } else { %>
                              <div class="btn-group w-100" role="group" aria-label="Profile type">
                                <input type="radio" class="btn-check" name="personProfileType" id="personProfileTypeIndividual" value="individual" autocomplete="off" <%= personProfileType === 'individual' ? 'checked' : '' %>>
                                <label class="btn btn-outline-secondary" for="personProfileTypeIndividual">
                                  <i class="bi bi-person me-1"></i>Individual
                                </label>
                                <input type="radio" class="btn-check" name="personProfileType" id="personProfileTypeOrganization" value="organization" autocomplete="off" <%= personProfileType === 'organization' ? 'checked' : '' %>>
                                <label class="btn btn-outline-secondary" for="personProfileTypeOrganization">
                                  <i class="bi bi-building me-1"></i>Organization / Company
                                </label>
                              </div>
                              <div class="form-text mt-2">Choose carefully — profile type cannot be changed later on the edit page.</div>
                            <% } %>
                        </div>
                        <div class="col-md-6 organization-profile-field">
                            <label class="form-label">Organization Legal Name <span class="text-danger">*</span></label>
                            <input type="text" name="organizationLegalName" id="organizationLegalName" class="form-control size-md" value="<%= organizationProfile.legalName || '' %>">
                        </div>
                    </div>
                    <div class="individual-profile-fields">
                    <h6 class="fw-bold text-uppercase text-muted mb-3"><i class="bi bi-person-bounding-box me-2"></i>Personal Information</h6>
                    
                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label class="form-label">First Name <span class="text-danger">*</span></label>
                            <input type="text" name="firstName" class="form-control size-md" value="<%= name.first || '' %>" required>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Middle Name</label>
                            <input type="text" name="middleName" class="form-control size-md" value="<%= name.middle || '' %>">
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">Last Name <span class="text-danger">*</span></label>
                            <input type="text" name="lastName" class="form-control size-md" value="<%= name.last || '' %>" required>
                        </div>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label">Preferred Name</label>
                            <input type="text" name="preferredName" class="form-control size-md" value="<%= name.preferred || '' %>">
                        </div>
                         <div class="col-md-6">
                            <div class="form-check form-switch mt-4 pt-1">
                                <input class="form-check-input" type="checkbox" id="activeCheck" name="active" <%= p.active ? 'checked' : '' %>>
                                <label class="form-check-label" for="activeCheck">Active Person Profile</label>
                            </div>
                        </div>
                    </div>

                    <h6 class="fw-bold text-uppercase text-muted mb-3 pt-3 border-top"><i class="bi bi-sliders me-2"></i>Demographics</h6>
                    
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Gender <span class="text-danger">*</span></label>
                            <select name="gender" class="form-select size-md">
                                <% const g = dem.gender || ''; %>
                                <option value="" <%= g==''?'selected':'' %>>Select...</option>
                                <option value="male" <%= g=='male'?'selected':'' %>>Male</option>
                                <option value="female" <%= g=='female'?'selected':'' %>>Female</option>
                                <option value="nonbinary" <%= g=='nonbinary'?'selected':'' %>>Non-binary</option>
                                <option value="other" <%= g=='other'?'selected':'' %>>Other</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Date of Birth <span class="text-danger">*</span></label>
                            <input type="date" name="dateOfBirth" class="form-control size-md" value="<%= dem.dateOfBirth || '' %>">
                        </div>
                    </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-contact">
            <div class="row g-4">
                
                <div class="col-lg-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-light fw-bold text-uppercase small text-muted">
                            <i class="bi bi-envelope me-2"></i>Communication
                        </div>
                        <div class="card-body">
                            
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label mb-0 fw-bold">Email Addresses</label>
                                <button type="button" class="btn btn-sm btn-outline-primary" id="addEmailBtn"><i class="bi bi-plus-lg"></i> Add</button>
                            </div>
                            <div id="emailsList" class="mb-4"></div>

                            <hr class="text-muted opacity-25">

                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <label class="form-label mb-0 fw-bold">Phone Numbers</label>
                                <button type="button" class="btn btn-sm btn-outline-primary" id="addPhoneBtn"><i class="bi bi-plus-lg"></i> Add</button>
                            </div>
                            <div id="phonesList"></div>
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-header bg-light fw-bold text-uppercase small text-muted">
                            <i class="bi bi-geo-alt me-2"></i>Addresses
                        </div>
                        <div class="card-body bg-light-subtle">
                            
                            <div class="mb-3 position-relative">
                                <label class="form-label small fw-bold text-primary">
                                    <i class="bi bi-search me-1"></i>Find Address (Canada)
                                </label>
                                <div class="input-group">
                                    <input type="text" id="addressSearchInput" class="form-control size-md" placeholder="Type street name..." autocomplete="off">
                                    <button class="btn btn-outline-secondary" type="button" id="addAddressManualBtn">Manual</button>
                                </div>
                                <div id="addressSuggestions" class="list-group position-absolute w-100 shadow-lg" style="z-index: 1000; top: 100%; display: none;"></div>
                            </div>

                            <div id="addressesList"></div>

                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="tab-pane fade" id="tab-orgs">
          <div class="card shadow-sm border-0">
            <div class="card-body">
              <% if (canEditOrgs) { %>
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold m-0 text-primary">Organization Memberships</h5>
                    <button type="button" class="btn btn-primary btn-filled" id="openOrgPickerBtn">
                        <i class="bi bi-search me-1"></i> Find & Add Organization
                    </button>
                </div>
                
                <ul class="list-group list-group-flush" id="organizationsList">
                    </ul>
              <% } else { %>
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>You have read-only access to organizations.
                </div>
                <ul class="list-group">
                    <% (orgsInit || []).forEach(o => { %>
                      <% const orgRoles = (Array.isArray(o.roles) && o.roles.length ? o.roles : [o.role || 'member']).filter(Boolean); %>
                     <li class="list-group-item d-flex justify-content-between align-items-center">
                        <span class="fw-bold"><%= o.name || ('Org ' + o.orgId) %></span>
                        <span class="badge bg-light text-dark border"><%= orgRoles.join(', ') %></span>
                      </li>
                    <% }) %>
                </ul>
              <% } %>
            </div>
          </div>
        </div>

        <div class="tab-pane fade" id="tab-system">
           <div class="row g-4">
               
               <div class="col-md-6">
                   <div class="card shadow-sm border-0 h-100">
                       <div class="card-header bg-light fw-bold">User Account Link</div>
                       <div class="card-body">
                          <% if (p.id) { %>
                              <% if (typeof linkedUser !== 'undefined' && linkedUser) { %>
                                 <div class="alert alert-success d-flex align-items-center mb-3">
                                     <i class="bi bi-check-circle-fill fs-4 me-3"></i>
                                     <div>
                                         <div class="fw-bold">Account Linked</div>
                                         <div class="small"><%= linkedUser.email %></div>
                                     </div>
                                 </div>
                                 <a href="/users/edit/<%= linkedUser.id %>" class="btn btn-outline-primary btn-sm w-100" target="_blank">
                                     Manage User Credentials <i class="bi bi-box-arrow-up-right ms-1"></i>
                                 </a>
                              <% } else { %>
                                <div class="alert alert-warning mb-3">
                                    <i class="bi bi-exclamation-triangle me-2"></i> No login account linked.
                                </div>
                                <a href="/users/new?personId=<%= p.id %>" class="btn btn-primary btn-sm w-100">
                                    <i class="bi bi-person-plus-fill me-1"></i> Create User Account
                                </a>
                              <% } %>
                          <% } else { %>
                              <div class="text-muted small text-center py-4">
                                  Save this person first to create a user account.
                              </div>
                          <% } %>
                       </div>
                   </div>
               </div>

               <div class="col-md-6">
                   <div class="card shadow-sm border-0 h-100">
                       <div class="card-header bg-light fw-bold">Metadata</div>
                       <div class="card-body">
                           <div class="mb-3">
                               <label class="form-label">Avatar URL</label>
                               <input type="text" name="avatarUrl" class="form-control size-md" value="<%= p.avatarUrl || '' %>" placeholder="https://...">
                           </div>
                           <div class="mb-3">
                               <label class="form-label">System Tags (Auto)</label>
                               <div class="border rounded p-2 bg-light-subtle">
                                 <% if (personSystemTags.length > 0) { %>
                                   <% personSystemTags.forEach((tag) => { %>
                                     <span class="badge bg-secondary me-1 mb-1"><%= tag %></span>
                                   <% }) %>
                                 <% } else { %>
                                   <span class="text-muted small">No system tags yet. Tags like student/teacher/staff are assigned automatically by workflow data.</span>
                                 <% } %>
                               </div>
                            </div>
                            <div class="mb-3">
                               <label class="form-label">Manual Tags</label>
                               <div class="border rounded p-2 bg-light-subtle text-muted small">
                                 Manual tags are managed from <b>Organizations</b> tab roles.
                               </div>
                            </div>
                           <div class="mb-3">
                               <label class="form-label">Internal Notes</label>
                               <textarea name="notes" class="form-control size-md" rows="3"><%= p.notes || '' %></textarea>
                           </div>
                       </div>
                   </div>
               </div>

           </div>
        </div>

      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md px-4">Save Changes</button>
        <a href="/persons" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction">Cancel</a>
      </div>

    </form>
  </div>
</div>

<%- include('../partials/modal_GenericPicker') %>

<script>
document.addEventListener('DOMContentLoaded', () => {

  // --- 1. DATA SYNCING ---
  function readJson(id, fallback) {
    const el = document.getElementById(id);
    if (!el) return fallback;
    try { return JSON.parse(el.textContent || ''); } catch { return fallback; }
  }

  const emailsHidden = document.getElementById('emailsHidden');
  const phonesHidden = document.getElementById('phonesHidden');
  const addressesHidden = document.getElementById('addressesHidden');
  const organizationsHidden = document.getElementById('organizationsHidden');
  const manualTagsHidden = document.getElementById('manualTagsHidden');

  let emails = readJson('initEmails', []);
  let phones = readJson('initPhones', []);
  let addresses = readJson('initAddresses', []);
  let organizations = readJson('initOrganizations', []);
  const manualTagPresets = readJson('manualTagPresetsJson', []);
  const systemTagKeys = readJson('systemTagKeysJson', []);
  const organizationRolePresets = readJson('organizationRolePresetsJson', []);
  const allowedManualTagSet = new Set(manualTagPresets.map((t) => String(t || '').trim().toLowerCase()));
  const systemRoleSet = new Set(systemTagKeys.map((t) => String(t || '').trim().toLowerCase()));
  const organizationRoleOptions = organizationRolePresets
    .map((t) => String(t || '').trim().toLowerCase())
    .filter((t, idx, arr) => t && arr.indexOf(t) === idx);
  let manualTags = readJson('initManualTags', [])
    .map((t) => String(t || '').trim().toLowerCase())
    .filter((t, idx, arr) => t && arr.indexOf(t) === idx)
    .filter((t) => allowedManualTagSet.has(t));

  function rebuildManualTagsFromOrganizations() {
    const tagSet = new Set();
    (Array.isArray(organizations) ? organizations : []).forEach((org) => {
      normalizeOrgRolesClient(org).forEach((role) => {
        if (allowedManualTagSet.has(role)) {
          tagSet.add(role);
        }
      });
    });
    manualTags = Array.from(tagSet);
  }

  function syncHidden() {
    if (emailsHidden) emailsHidden.value = JSON.stringify(emails);
    if (phonesHidden) phonesHidden.value = JSON.stringify(phones);
    if (addressesHidden) addressesHidden.value = JSON.stringify(addresses);
    if (organizationsHidden) organizationsHidden.value = JSON.stringify(organizations);
    rebuildManualTagsFromOrganizations();
    if (manualTagsHidden) manualTagsHidden.value = manualTags.join(', ');
  }

  async function showInfoModal(title, message, icon = 'info') {
    if (typeof window.showMessageModal === 'function') {
      await window.showMessageModal({
        title: title || 'Message',
        message: message || '',
        icon,
        buttons: [{ text: 'OK', class: 'btn-primary' }]
      });
      return;
    }
    alert((title ? `${title}: ` : '') + (message || ''));
  }

  // --- 2. EMAILS RENDERER ---
  const emailsList = document.getElementById('emailsList');
  const addEmailBtn = document.getElementById('addEmailBtn');

  function renderEmails() {
    if (!emailsList) return;
    emailsList.innerHTML = '';

    emails.forEach((e, i) => {
      const row = document.createElement('div');
      row.className = 'input-group mb-2';
      
      const typeSel = document.createElement('select'); 
      typeSel.className = 'form-select size-md bg-light border-end-0'; 
      typeSel.style.maxWidth = '120px';
      ['primary','work','personal'].forEach(t => {
        const opt = document.createElement('option'); opt.value = t; opt.textContent = t.charAt(0).toUpperCase() + t.slice(1);
        if (e.type === t) opt.selected = true; typeSel.appendChild(opt);
      });

      const emailInput = document.createElement('input'); 
      emailInput.type = 'email'; 
      emailInput.className = 'form-control size-md'; 
      emailInput.placeholder = 'email@example.com'; 
      emailInput.value = e.email || '';

      const removeBtn = document.createElement('button'); 
      removeBtn.type = 'button'; 
      removeBtn.className = 'btn btn-outline-danger'; 
      removeBtn.innerHTML = '<i class="bi bi-x-lg"></i>';

      typeSel.addEventListener('change', () => { emails[i].type = typeSel.value; syncHidden(); });
      emailInput.addEventListener('input', () => { emails[i].email = emailInput.value; syncHidden(); });
      removeBtn.addEventListener('click', () => { emails.splice(i, 1); renderEmails(); syncHidden(); });

      if(e.isPrimary) {
          typeSel.classList.add('fw-bold', 'text-primary');
          emailInput.classList.add('border-primary');
      }

      row.append(typeSel, emailInput, removeBtn);
      emailsList.appendChild(row);
    });
    syncHidden();
  }
  
  if(addEmailBtn) addEmailBtn.addEventListener('click', () => { emails.push({ type:'work', email:'', isPrimary:false }); renderEmails(); });

  // --- 3. PHONES RENDERER ---
  const phonesList = document.getElementById('phonesList');
  const addPhoneBtn = document.getElementById('addPhoneBtn');

  function renderPhones() {
    if (!phonesList) return;
    phonesList.innerHTML = '';
    phones.forEach((p, i) => {
        const row = document.createElement('div');
        row.className = 'input-group mb-2';
        
        const typeSel = document.createElement('select'); 
        typeSel.className = 'form-select size-md bg-light border-end-0'; 
        typeSel.style.maxWidth = '120px';
        ['mobile','work','home'].forEach(t => {
            const opt = document.createElement('option'); opt.value = t; opt.textContent = t.charAt(0).toUpperCase() + t.slice(1);
            if (p.type === t) opt.selected = true; typeSel.appendChild(opt);
        });

        const numInput = document.createElement('input'); 
        numInput.className = 'form-control size-md'; 
        numInput.placeholder = '(555) 123-4567';
        numInput.value = p.number || '';
        
        const removeBtn = document.createElement('button'); 
        removeBtn.type = 'button'; 
        removeBtn.className = 'btn btn-outline-danger'; 
        removeBtn.innerHTML = '<i class="bi bi-x-lg"></i>';

        typeSel.addEventListener('change', () => { phones[i].type = typeSel.value; syncHidden(); });
        numInput.addEventListener('input', () => { phones[i].number = numInput.value; syncHidden(); });
        removeBtn.addEventListener('click', () => { phones.splice(i,1); renderPhones(); syncHidden(); });
        
        row.append(typeSel, numInput, removeBtn);
        phonesList.appendChild(row);
    });
    syncHidden();
  }
  if(addPhoneBtn) addPhoneBtn.addEventListener('click', () => { phones.push({ type:'mobile', number:'' }); renderPhones(); });

  // --- 4. ADDRESSES (With Autocomplete) ---
  const addressesList = document.getElementById('addressesList');
  const addAddressManualBtn = document.getElementById('addAddressManualBtn');
  const addressSearchInput = document.getElementById('addressSearchInput');
  const addressSuggestions = document.getElementById('addressSuggestions');
  let debounceTimer;

  function renderAddresses() {
      if (!addressesList) return;
      addressesList.innerHTML = '';
      addresses.forEach((a, i) => {
          const card = document.createElement('div'); 
          card.className = 'card mb-3 border shadow-sm';
          
          card.innerHTML = `
            <div class="card-body p-3 bg-white rounded">
                <div class="d-flex justify-content-between mb-2">
                    <select class="form-select form-select-sm border-0 bg-light fw-bold text-uppercase px-2 addr-type" style="width:auto;">
                        <option value="home">HOME</option>
                        <option value="work">WORK</option>
                        <option value="other">OTHER</option>
                    </select>
                    <button class="btn btn-sm text-danger addr-remove" type="button"><i class="bi bi-trash"></i></button>
                </div>
                
                <input class="form-control size-md mb-2 addr-line1" value="${a.line1 || ''}" placeholder="Street Address">
                
                <div class="row g-2">
                    <div class="col-6"><input class="form-control size-md addr-city" value="${a.city || ''}" placeholder="City"></div>
                    <div class="col-3"><input class="form-control size-md addr-prov" value="${a.province || ''}" placeholder="Prov"></div>
                    <div class="col-3"><input class="form-control size-md addr-post" value="${a.postalCode || ''}" placeholder="Postal"></div>
                </div>
            </div>
          `;

          const typeSel = card.querySelector('.addr-type');
          if(a.type) typeSel.value = a.type;

          typeSel.addEventListener('change', e => { addresses[i].type = e.target.value; syncHidden(); });
          
          const bindInput = (cls, key) => {
              card.querySelector(cls).addEventListener('input', e => { addresses[i][key] = e.target.value; syncHidden(); });
          };
          bindInput('.addr-line1', 'line1');
          bindInput('.addr-city', 'city');
          bindInput('.addr-prov', 'province');
          bindInput('.addr-post', 'postalCode');

          card.querySelector('.addr-remove').addEventListener('click', () => { addresses.splice(i, 1); renderAddresses(); syncHidden(); });
          
          addressesList.appendChild(card);
      });
      syncHidden();
  }

  if(addAddressManualBtn) {
      addAddressManualBtn.addEventListener('click', () => { 
          addresses.push({ type:'home', line1:'', city:'', province:'', postalCode:'' }); 
          renderAddresses(); 
      });
  }

  // AUTOCOMPLETE LOGIC (OpenStreetMap)
  if (addressSearchInput) {
      addressSearchInput.addEventListener('input', (e) => {
          const query = e.target.value.trim();
          clearTimeout(debounceTimer);
          
          if (query.length < 3) {
              addressSuggestions.style.display = 'none';
              return;
          }

          debounceTimer = setTimeout(async () => {
              try {
                  addressSuggestions.innerHTML = '<div class="list-group-item text-muted"><span class="spinner-border spinner-border-sm me-2"></span>Searching...</div>';
                  addressSuggestions.style.display = 'block';

                  const url = `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(query)}&countrycodes=ca&addressdetails=1&limit=5`;
                  const res = await fetch(url);
                  const data = await res.json();

                  addressSuggestions.innerHTML = '';
                  if (data.length === 0) {
                      addressSuggestions.innerHTML = '<div class="list-group-item text-muted">No results found.</div>';
                      return;
                  }

                  data.forEach(item => {
                      const addr = item.address;
                      const display = item.display_name;
                      
                      const btn = document.createElement('button');
                      btn.type = 'button';
                      btn.className = 'list-group-item list-group-item-action text-start small';
                      btn.innerHTML = `<i class="bi bi-geo-alt me-2 text-primary"></i>${display}`;
                      
                      btn.addEventListener('click', () => {
                          const newAddr = {
                              type: 'home',
                              line1: `${addr.house_number || ''} ${addr.road || ''}`.trim() || display.split(',')[0],
                              city: addr.city || addr.town || addr.village || '',
                              province: addr.state || '',
                              postalCode: addr.postcode || ''
                          };
                          
                          addresses.push(newAddr);
                          renderAddresses();
                          
                          addressSearchInput.value = '';
                          addressSuggestions.style.display = 'none';
                      });
                      addressSuggestions.appendChild(btn);
                  });

              } catch (err) {
                  console.error('API Error:', err);
                  addressSuggestions.style.display = 'none';
              }
          }, 500);
      });

      document.addEventListener('click', (e) => {
          if (!addressSearchInput.contains(e.target) && !addressSuggestions.contains(e.target)) {
              addressSuggestions.style.display = 'none';
          }
      });
  }

  // --- 5. ORGS RENDERER ---
  const organizationsList = document.getElementById('organizationsList');
  const openOrgPickerBtn = document.getElementById('openOrgPickerBtn');
  const personRoleSummary = document.getElementById('personRoleSummary');

  function normalizeOrgRolesClient(org) {
      const raw = Array.isArray(org?.roles) ? org.roles : (org?.role ? [org.role] : []);
      const normalized = raw
        .map((role) => String(role || '').trim().toLowerCase())
        .filter(Boolean)
        .filter((role, idx, arr) => arr.indexOf(role) === idx);
      return normalized.length ? normalized : ['member'];
  }

  function splitOrgRolesClient(rolesArr) {
      const normalized = (Array.isArray(rolesArr) ? rolesArr : [])
        .map((role) => String(role || '').trim().toLowerCase())
        .filter(Boolean)
        .filter((role, idx, arr) => arr.indexOf(role) === idx);
      const system = [];
      const manual = [];
      normalized.forEach((role) => {
          if (systemRoleSet.has(role)) system.push(role);
          else manual.push(role);
      });
      return { system, manual };
  }

  function renderPersonRoleSummary() {
      if (!personRoleSummary) return;
      const orgList = Array.isArray(organizations) ? organizations : [];
      if (!orgList.length) {
          personRoleSummary.innerHTML = '<div class="text-muted small">No organization memberships are assigned yet. This person currently has no composed school roles.</div>';
          return;
      }

      const roleSet = new Set();
      const rows = orgList.map((org) => {
          const roles = normalizeOrgRolesClient(org);
          roles.forEach((role) => roleSet.add(role));
          const badges = roles.map((role) => `<span class="badge bg-light text-dark border me-1 mb-1">${role}</span>`).join('');
          const orgName = org?.name || ('Org ' + org?.orgId);
          return `
            <div class="border rounded p-2 bg-white">
              <div class="fw-bold text-dark">${orgName}</div>
              <div class="small text-muted mb-1">Organization ID: ${org?.orgId || '-'}</div>
              <div>${badges}</div>
            </div>
          `;
      }).join('');

      const aggregateBadges = Array.from(roleSet).map((role) => `<span class="badge bg-primary-subtle text-primary border border-primary-subtle me-1 mb-1">${role}</span>`).join('');
      personRoleSummary.innerHTML = `
        <div class="mb-3">
          <div class="small text-muted mb-1">All current roles</div>
          <div>${aggregateBadges}</div>
        </div>
        <div class="d-grid gap-2">${rows}</div>
      `;
  }

  function renderOrgs() {
      if(!organizationsList) return;
      organizationsList.innerHTML = '';
      organizations.forEach((o, i) => {
          const roles = Array.isArray(o.roles) && o.roles.length
            ? o.roles
            : (o.role ? [o.role] : ['member']);
          o.roles = roles
            .map(r => String(r || '').trim().toLowerCase())
            .filter(Boolean)
            .filter((r, idx, arr) => arr.indexOf(r) === idx);
          if (!o.roles.length) o.roles = ['member'];
          o.role = o.roles[0];

          const li = document.createElement('li');
          li.className = 'list-group-item p-3 border rounded mb-2';
          const joinedDate = o.joinedAt ? new Date(o.joinedAt).toISOString().slice(0, 10) : new Date().toISOString().slice(0, 10);
          
          li.innerHTML = `
              <div class="d-flex justify-content-between align-items-center mb-2">
                  <span class="fw-bold text-dark">${o.name || ('Org ' + o.orgId)} <span class="text-muted small ms-1">#${o.orgId}</span></span>
                  <button type="button" class="btn btn-sm btn-outline-danger remove-org"><i class="bi bi-trash"></i></button>
              </div>
              <div class="row g-2">
                  <div class="col-md-4">
                      <label class="form-label x-small text-muted mb-0">Roles</label>
                      <div class="input-group">
                        <select class="form-select size-md org-role-select">
                          <option value="">Select role...</option>
                        </select>
                        <button type="button" class="btn btn-outline-primary org-role-add">Add</button>
                      </div>
                      <div class="small text-muted mt-1">Only manual tags can be edited here. System and domain-managed roles are locked.</div>
                      <div class="mt-2 d-flex flex-wrap gap-2 org-roles-preview"></div>
                  </div>
                  <div class="col-md-4">
                      <label class="form-label x-small text-muted mb-0">Status</label>
                      <select class="form-select size-md org-status">
                          <option value="active" ${o.memberStatus==='active'?'selected':''}>Active</option>
                          <option value="pending" ${o.memberStatus==='pending'?'selected':''}>Pending</option>
                      </select>
                  </div>
                  <div class="col-md-4">
                      <label class="form-label x-small text-muted mb-0">Joined</label>
                      <input type="date" class="form-control size-md org-joined" value="${joinedDate}">
                  </div>
              </div>
          `;

          const rolesPreview = li.querySelector('.org-roles-preview');
          const roleSelect = li.querySelector('.org-role-select');
          const addRoleBtn = li.querySelector('.org-role-add');

          const getRoleOptionsForOrg = (rolesArr) => {
              const currentManual = splitOrgRolesClient(rolesArr).manual;
              return Array.from(new Set([...organizationRoleOptions, ...currentManual]))
                .map((roleVal) => String(roleVal || '').trim().toLowerCase())
                .filter((roleVal) => !systemRoleSet.has(roleVal))
                .filter((roleVal) => roleVal);
          };

          const paintRoleOptions = (rolesArr) => {
              if (!roleSelect) return;
              const selected = String(roleSelect.value || '').trim().toLowerCase();
              const opts = getRoleOptionsForOrg(rolesArr);
              roleSelect.innerHTML = '<option value="">Select role...</option>';
              opts.forEach((roleVal) => {
                  const opt = document.createElement('option');
                  opt.value = roleVal;
                  opt.textContent = roleVal;
                  if (selected && selected === roleVal) opt.selected = true;
                  roleSelect.appendChild(opt);
              });
              if (addRoleBtn) addRoleBtn.disabled = !roleSelect.value;
          };

          const paintRoleBadges = (rolesArr) => {
              if (!rolesPreview) return;
              rolesPreview.innerHTML = '';
              const normalizedRoles = Array.isArray(rolesArr) && rolesArr.length ? rolesArr : ['member'];
              const splitRoles = splitOrgRolesClient(normalizedRoles);
              paintRoleOptions(normalizedRoles);
              splitRoles.manual.forEach((roleVal) => {
                  const roleText = String(roleVal || '').trim() || 'member';
                  const chip = document.createElement('button');
                  chip.type = 'button';
                  chip.className = 'btn btn-sm btn-outline-secondary org-role-chip';
                  chip.dataset.role = roleText;
                  chip.dataset.locked = '0';
                  chip.innerHTML = `${roleText} <i class="bi bi-x-lg ms-1"></i>`;
                  rolesPreview.appendChild(chip);
              });
              splitRoles.system.forEach((roleVal) => {
                  const roleText = String(roleVal || '').trim();
                  const chip = document.createElement('span');
                  chip.className = 'badge bg-secondary-subtle text-secondary border';
                  chip.title = 'Managed by system workflow';
                  chip.textContent = `${roleText} (system)`;
                  rolesPreview.appendChild(chip);
              });
          };
          paintRoleBadges(o.roles);

          if (roleSelect && addRoleBtn) {
              roleSelect.addEventListener('change', () => {
                  addRoleBtn.disabled = !roleSelect.value;
              });
              addRoleBtn.addEventListener('click', () => {
                  const nextRole = String(roleSelect.value || '').trim().toLowerCase();
                  if (!nextRole) return;
                  if (systemRoleSet.has(nextRole)) return;
                  const splitRoles = splitOrgRolesClient(normalizeOrgRolesClient(organizations[i]));
                  if (!splitRoles.manual.includes(nextRole)) {
                      splitRoles.manual.push(nextRole);
                  }
                  organizations[i].roles = Array.from(new Set([...splitRoles.manual, ...splitRoles.system]));
                  if (!organizations[i].roles.length) organizations[i].roles = ['member'];
                  organizations[i].role = organizations[i].roles[0];
                  roleSelect.value = '';
                  addRoleBtn.disabled = true;
                  paintRoleBadges(organizations[i].roles);
                  syncHidden();
                  renderPersonRoleSummary();
              });
          }

          rolesPreview.addEventListener('click', (event) => {
              const chip = event.target.closest('.org-role-chip');
              if (!chip) return;
              if (chip.dataset.locked === '1') return;
              const targetRole = String(chip.dataset.role || '').trim().toLowerCase();
              if (!targetRole) return;
              if (systemRoleSet.has(targetRole)) return;

              const splitRoles = splitOrgRolesClient(normalizeOrgRolesClient(organizations[i]));
              splitRoles.manual = splitRoles.manual.filter((r) => r !== targetRole);
              const nextRoles = Array.from(new Set([...splitRoles.manual, ...splitRoles.system]));
              organizations[i].roles = nextRoles.length ? nextRoles : ['member'];
              organizations[i].role = organizations[i].roles[0];
              paintRoleBadges(organizations[i].roles);
              syncHidden();
              renderPersonRoleSummary();
          });
          li.querySelector('.org-status').addEventListener('change', e => { organizations[i].memberStatus = e.target.value; syncHidden(); });
          li.querySelector('.org-joined').addEventListener('change', e => { organizations[i].joinedAt = e.target.value; syncHidden(); });
          li.querySelector('.remove-org').addEventListener('click', async () => {
              const splitRoles = splitOrgRolesClient(normalizeOrgRolesClient(organizations[i]));
              if (splitRoles.system.length) {
                  await showInfoModal(
                    'System Roles Locked',
                    `Cannot remove this organization membership because it has system role(s): ${splitRoles.system.join(', ')}.`
                  );
                  return;
              }
              organizations.splice(i, 1);
              renderOrgs();
              syncHidden();
          });

          organizationsList.appendChild(li);
      });
      syncHidden();
      renderPersonRoleSummary();
  }

  if(openOrgPickerBtn) {
      openOrgPickerBtn.addEventListener('click', () => {
         const notify = async ({ title, message, icon='info', buttons } = {}) => {
            if (typeof window.showMessageModal === 'function') {
               const btns = buttons && buttons.length ? buttons : [{ text: 'OK', class: 'btn-primary' }];
               return await window.showMessageModal({ title: title || 'Message', message: message || '', icon, buttons: btns });
            }
            // Fallback only if modal helper is unavailable
            alert((title ? title + ': ' : '') + (message || ''));
            return 'OK';
         };

         if (typeof GenericPicker === 'undefined') { notify({ title: 'Error', icon: 'error', message: 'Picker library not loaded.' }); return; }
         GenericPicker.open(GenericPickerPresets.organization({
            title: 'Add Organization',
            placeholder: 'Search...',
            onSelect: async (item) => {
                const id = Number(item.id);
                if (organizations.some(o => Number(o.orgId) === id)) { await notify({ title: 'Already Added', icon: 'info', message: 'This organization is already added.' }); return; }
                organizations.push({
                    orgId: id, name: item.name, roles: ['member'], role: 'member', memberStatus: 'active', joinedAt: new Date().toISOString()
                });
                renderOrgs();
            }
         }));
      });
  }

  // --- INITIAL RENDER ---
  const organizationLegalName = document.getElementById('organizationLegalName');
  const individualProfileFields = document.querySelectorAll('.individual-profile-fields');
  const organizationProfileFields = document.querySelectorAll('.organization-profile-field');
  const getSelectedPersonProfileType = () => {
    const checked = document.querySelector('input[name="personProfileType"]:checked');
    if (checked) return checked.value;
    const hidden = document.getElementById('personProfileType');
    return hidden ? hidden.value : 'individual';
  };
  const syncPersonProfileType = () => {
    const isOrganization = getSelectedPersonProfileType() === 'organization';
    individualProfileFields.forEach((node) => { node.style.display = isOrganization ? 'none' : ''; });
    organizationProfileFields.forEach((node) => { node.style.display = isOrganization ? '' : 'none'; });
    if (organizationLegalName) organizationLegalName.required = Boolean(isOrganization);
    document.querySelectorAll('.individual-profile-fields input[name="firstName"], .individual-profile-fields input[name="lastName"]').forEach((input) => {
      input.required = !isOrganization;
    });
  };
  document.querySelectorAll('input[name="personProfileType"]').forEach((input) => {
    input.addEventListener('change', syncPersonProfileType);
  });
  syncPersonProfileType();
  renderEmails(); renderPhones(); renderAddresses(); renderOrgs(); syncHidden(); renderPersonRoleSummary();

  // --- FORM SUBMIT ---
  const form = document.getElementById('personForm');
  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      syncHidden();

      const notify = async ({ title, message, icon='info', buttons } = {}) => {
        if (typeof window.showMessageModal === 'function') {
          const btns = buttons && buttons.length ? buttons : [{ text: 'OK', class: 'btn-primary' }];
          return await window.showMessageModal({ title: title || 'Message', message: message || '', icon, buttons: btns });
        }
        // Fallback only if modal helper is unavailable
        alert((title ? title + ': ' : '') + (message || ''));
        return 'OK';
      };
      
      const fd = new FormData(form);
      const activeCheck = document.getElementById('activeCheck');
      if (activeCheck) fd.set('active', activeCheck.checked ? 'true' : 'false');

      const submitBtn = form.querySelector('button[type="submit"]');
      if(submitBtn) { submitBtn.disabled = true; submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Saving...'; }

      try {
        const resp = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-AJAX-Request': 'true' },
          body: new URLSearchParams(fd).toString()
        });
        const result = await resp.json();
        if (result.status === 'success') {
             const pieces = [];
             pieces.push(result.message || 'Person saved successfully.');
             if (result.autoUserCreated && result.userEditUrl) {
               pieces.push('<hr class="my-2"/>');
               pieces.push('<div><b>User account</b> was created for this person.</div>');
               if (result.tempPassword) {
                 const safePass = String(result.tempPassword).replace(/</g,'&lt;').replace(/>/g,'&gt;');
                 pieces.push(`<div class="mt-1"><b>Temporary password:</b> <code>${safePass}</code></div>`);
                 pieces.push('<div class="small text-muted mt-1">Ask the user to change this password after first login.</div>');
               }
             }

             const choice = await notify({
               title: 'Success',
               icon: 'success',
               message: pieces.join(''),
               buttons: [
                 ...(result.userEditUrl ? [{ text: 'Go to User', class: 'btn-primary' }] : []),
                 { text: 'Stay Here', class: 'btn-primary' },
                 { text: 'Return to List', class: 'btn-secondary' }
               ]
             });

             if (choice === 'Go to User' && result.userEditUrl) {
               window.location.href = result.userEditUrl;
               return;
             }

             if (choice === 'Return to List') {
               window.location.href = '/persons';
               return;
             }

             if(submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = 'Save Changes'; }
        } else {
             await notify({ title: 'Error', icon: 'error', message: result.message || 'Error saving person.' });
             if(submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = 'Save Changes'; }
        }
      } catch (error) {
        console.error(error);
        await notify({ title: 'Error', icon: 'error', message: 'Network error.' });
        if(submitBtn) { submitBtn.disabled = false; submitBtn.innerHTML = 'Save Changes'; }
      }
    });
  }
});
</script>
