  position: relative;
  display: flex;
  align-items: center;
  gap: 0.8rem;
  min-width: 310px;
  max-width: min(42vw, 430px);
  min-height: 74px;
  padding: 0.7rem 0.9rem;
  border-radius: 16px;
  border: 1px solid rgba(13, 110, 253, 0.2);
  background:
    radial-gradient(circle at 100% 0%, rgba(13, 110, 253, 0.1), rgba(13, 110, 253, 0) 58%),
    linear-gradient(165deg, rgba(255, 255, 255, 0.95), rgba(247, 251, 255, 0.9));
  backdrop-filter: blur(8px);
  box-shadow:
    0 10px 24px rgba(15, 23, 42, 0.08),
