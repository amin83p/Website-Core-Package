    height: 88px;
    right: -3px;
    bottom: -5px;
    opacity: 0.2;
  }

  .dashboard-compact-card .dashboard-compact-watermark i {
    font-size: 4.4rem;
  }

  .dashboard-compact-icon {
    width: 60px;
    height: 60px;
    padding: 7px;
  }

  .dashboard-compact-icon i {
    font-size: 1.6rem;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  // ---------- Data ----------
  function parseModuleDataset(elementId) {
    try {
      const payload = JSON.parse(document.getElementById(elementId).textContent);
      return Array.isArray(payload) ? payload : [];
    } catch (e) {
      console.error(`Failed to parse ${elementId}`, e);
      return [];
    }
  }
  const dashboardModules = parseModuleDataset('modulesData');
  let allModules = dashboardModules.slice();

  // ---------- Preferences / State ----------
  const MODE_KEY = 'dashMode';              // 'categories' | 'modules'
  const CAT_KEY  = 'dashCategory';          // 'ALL' | category key
  const VIEW_KEY = 'dashView';              // 'card' | 'compact' | 'list'
  const SORT_KEY = 'dashSort';              // name/access sorts
  const SEARCH_KEY = 'dashSearch';          // query string
  const SOURCE_KEY = 'dashSourceMode';      // 'main' | 'all'

  const MODE_CATEGORIES = 'categories';
  const MODE_MODULES = 'modules';
  const CAT_ALL = 'ALL';
  const SOURCE_MAIN = 'main';
  const SOURCE_ALL = 'all';
  const SEARCH_DEBOUNCE_MS = 320;

  let currentMode = localStorage.getItem(MODE_KEY) || MODE_CATEGORIES;
  let currentCategory = String(localStorage.getItem(CAT_KEY) || CAT_ALL).toUpperCase();
  let currentView = localStorage.getItem(VIEW_KEY) || 'compact';
  let currentSort = localStorage.getItem(SORT_KEY) || 'name_asc';
  let searchQuery = localStorage.getItem(SEARCH_KEY) || '';
  let currentSourceMode = String(localStorage.getItem(SOURCE_KEY) || SOURCE_MAIN).toLowerCase() === SOURCE_ALL
    ? SOURCE_ALL
    : SOURCE_MAIN;
  let searchDebounceHandle = null;
  let allSectionsRequestSeq = 0;

  // ---------- Elements ----------
  const container = document.getElementById('modulesContainer');
  const sortSelect = document.getElementById('sortSelect');
  const viewBtns = document.querySelectorAll('.view-btn');
  const searchInput = document.getElementById('dashSearch');
  const toggleAllSectionsBtn = document.getElementById('toggleAllSectionsBtn');
  const moduleCountBadgeEl = document.getElementById('dashboardModuleCountBadge');

  if (sortSelect) sortSelect.value = currentSort;
  if (searchInput) searchInput.value = searchQuery;

  function normalizeSortToken(sortToken) {
    const token = String(sortToken || '').trim().toLowerCase();
    return ['name_asc', 'name_desc', 'access_asc', 'access_desc'].includes(token)
      ? token
      : 'name_asc';
  }

  async function fetchAllAccessibleSectionsFromServer(options = {}) {
    const params = new URLSearchParams();
    const sort = normalizeSortToken(options.sort || currentSort);
    params.set('sort', sort);
    const q = String(options.q || '').trim();
    if (q) params.set('q', q);

    const response = await fetch(`/dashboard/all-sections?${params.toString()}`, {
      method: 'GET',
      credentials: 'same-origin',
      headers: { Accept: 'application/json' }
    });
    if (!response.ok) {
      throw new Error(`All sections request failed with status ${response.status}.`);
    }
    const payload = await response.json();
    if (!payload || payload.status !== 'success' || !Array.isArray(payload.sections)) {
      throw new Error('Invalid all sections payload.');
    }
    return payload.sections;
  }

  function renderLoadingState(message = 'Loading modules...') {
    if (!container) return;
    container.innerHTML = ''
      + '<div class="text-center py-5 text-muted">'
      + '  <div class="spinner-border text-primary mb-2" role="status"></div>'
      + `  <div>${String(message || 'Loading modules...')}</div>`
      + '</div>';
  }

  async function reloadAllSectionsData(options = {}) {
    const requestedQ = Object.prototype.hasOwnProperty.call(options, 'q')
      ? String(options.q || '')
      : String(searchQuery || '');
    const requestedSort = normalizeSortToken(options.sort || currentSort);
    const requestSeq = ++allSectionsRequestSeq;

    if (options.showLoading !== false) {
      renderLoadingState('Loading all accessible sections...');
    }

    try {
      const sections = await fetchAllAccessibleSectionsFromServer({
        q: requestedQ,
        sort: requestedSort
      });
      if (requestSeq !== allSectionsRequestSeq) return;
      allModules = sections.slice();
      updateModuleCountBadge();
      if (options.render !== false) render();
    } catch (error) {
      if (requestSeq !== allSectionsRequestSeq) return;
      console.error('Dashboard all-sections load error:', error);
      allModules = [];
      updateModuleCountBadge();
      container.innerHTML = '<div class="alert alert-warning border text-center p-4">Unable to load all sections right now. Please try again.</div>';
    }
  }

  function updateModuleCountBadge() {
    if (!moduleCountBadgeEl) return;
    const count = Array.isArray(allModules) ? allModules.length : 0;
    moduleCountBadgeEl.textContent = String(count);
    moduleCountBadgeEl.title = currentSourceMode === SOURCE_ALL
      ? 'Showing all accessible sections (navigation sections excluded)'
      : 'Showing dashboard sections';
  }

  function updateSourceToggleButton() {
    if (!toggleAllSectionsBtn) return;
    const showingAll = currentSourceMode === SOURCE_ALL;
    toggleAllSectionsBtn.setAttribute('aria-pressed', showingAll ? 'true' : 'false');
    toggleAllSectionsBtn.classList.toggle('active', showingAll);
    toggleAllSectionsBtn.classList.toggle('bg-secondary', showingAll);
    toggleAllSectionsBtn.classList.toggle('text-white', showingAll);
    toggleAllSectionsBtn.classList.toggle('btn-outline-secondary', !showingAll);
    toggleAllSectionsBtn.innerHTML = showingAll
      ? '<i class="bi bi-layout-text-window-reverse me-1"></i>Show Modules'
      : '<i class="bi bi-diagram-3 me-1"></i>All Section';
  }

  async function setSectionSource(mode, options = {}) {
    const nextMode = mode === SOURCE_ALL ? SOURCE_ALL : SOURCE_MAIN;
    currentSourceMode = nextMode;
    currentMode = MODE_MODULES;
    currentCategory = CAT_ALL;
    localStorage.setItem(MODE_KEY, currentMode);
    localStorage.setItem(CAT_KEY, currentCategory);
    if (options.persist !== false) {
      localStorage.setItem(SOURCE_KEY, currentSourceMode);
    }
    updateSourceToggleButton();
    if (nextMode === SOURCE_ALL) {
      await reloadAllSectionsData({
        q: searchQuery,
        sort: currentSort,
        showLoading: options.showLoading !== false
      });
      return;
    }
    allModules = dashboardModules.slice();
    updateModuleCountBadge();
    render();
  }

  allModules = dashboardModules.slice();
  updateSourceToggleButton();
  updateModuleCountBadge();
  updateViewBtnState();

  // ---------- Helpers ----------
  function normalizeCategory(cat) {
    const c = (cat || '').toString().trim();
    return c ? c.toUpperCase() : 'OTHER';
  }

  const DISPLAY_ACRONYMS = new Set([
    'PTE',
    'IELTS',
    'CLB',
    'AI',
    'API',
    'UI',
    'UX',
    'URL',
    'IP',
    'ID',
    'SQL',
    'JSON',
    'CSV',
    'PDF',
    'XML'
  ]);
  const ICON_VARIANT_CLASSES = ['bg-primary-subtle text-primary', 'bg-secondary-subtle text-secondary', 'bg-success-subtle text-success', 'bg-info-subtle text-info', 'bg-warning-subtle text-warning', 'bg-danger-subtle text-danger'];

  function formatName(name) {
    const raw = String(name || '').trim();
    if (!raw) return 'Unknown';
    return raw
      .replace(/[_-]+/g, ' ')
      .split(/\s+/)
      .map((token) => {
        const part = String(token || '').trim();
        if (!part) return '';
        if (/[a-z]/.test(part) && /[A-Z]/.test(part) && !/^[A-Z0-9]+$/.test(part)) return part;
        const upper = part.toUpperCase();
        if (DISPLAY_ACRONYMS.has(upper)) return upper;
        if (/^[A-Z0-9]+$/.test(part) && /[0-9]/.test(part)) return upper;
        return upper.charAt(0) + upper.slice(1).toLowerCase();
      })
      .filter(Boolean)
      .join(' ');
  }

  function getModuleSearchText(m) {
    return [
      m?.name, m?.description, m?.message, m?.category
    ].filter(Boolean).join(' ').toLowerCase();
  }

  function applySearchToModules(list) {
    const q = String(searchQuery || '').trim().toLowerCase();
    if (!q) return list;
    return list.filter(m => getModuleSearchText(m).includes(q));
  }

  function computeCategoriesFromModules(mods) {
    // derived ONLY from modules array -> no zero-count categories
    const counts = new Map();
    for (const m of mods) {
      const key = normalizeCategory(m.category);
      counts.set(key, (counts.get(key) || 0) + 1);
    }
    const keys = Array.from(counts.keys()).sort((a,b) => a.localeCompare(b));
    return keys.map(key => ({
      key,
      name: formatName(key),
      count: counts.get(key) || 0
    }));
  }

  function applySearchToCategories(cats) {
    const q = String(searchQuery || '').trim().toLowerCase();
    if (!q) return cats;
    return cats.filter(c => (c.name || '').toLowerCase().includes(q) || (c.key || '').toLowerCase().includes(q));
  }

  // ---------- Icon renderer (reuses section icon defs) ----------
  function renderIconHtml(m, defaultClass = 'bi-grid-fill') {
    if (!m || !m.customIcon) return `<i class="bi ${defaultClass}"></i>`;
    const type = m.customIcon.type;
    const val = m.customIcon.value;

    if (type === 'class') return `<i class="${val}"></i>`;
    if (type === 'image') return `<img src="${val}" alt="icon" style="width: 100%; height: 100%; object-fit: contain;">`;
    if (type === 'raw') return `<div class="raw-icon-container" style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;">${val}</div>`;
    return `<i class="bi ${defaultClass}"></i>`;
  }

  function hasRegisteredSymbolIcon(m) {
    const icon = m && m.customIcon ? m.customIcon : null;
    if (!icon) return false;
    const type = String(icon.type || '').trim().toLowerCase();
    const value = String(icon.value || '').trim();
    return ['class', 'image', 'raw'].includes(type) && value.length > 0;
  }

  function getModuleIconVariant(m, index = 0) {
    const classToken = String(m?.subtleClass || '').trim();
    const styleToken = String(m?.iconStyle || '').trim();
    if (classToken || styleToken) {
      return { className: classToken, style: styleToken };
    }
    const fallbackClass = ICON_VARIANT_CLASSES[Math.abs(Number(index) || 0) % ICON_VARIANT_CLASSES.length];
    return { className: fallbackClass, style: '' };
  }

  // homeURL → open link; no homeURL but has subsections → sub-dashboard; else /sections
  function getSectionUrl(m) {
    const home = String(m.homeURL || '').trim();
    if (home) return home;
    const subs = m.subsections || [];
    if (Array.isArray(subs) && subs.length > 0) {
      return `/dashboard/section-nav/${encodeURIComponent(m.name || m.id)}`;
    }
    return '/sections';
  }

  // ---------- Mode switching ----------
  function setMode(mode, category = null) {
    currentMode = mode;
    localStorage.setItem(MODE_KEY, currentMode);

    if (category !== null) {
      currentCategory = String(category || CAT_ALL).toUpperCase();
      localStorage.setItem(CAT_KEY, currentCategory);
    }
    render();
  }

  // ---------- Rendering ----------
  function render() {
    container.innerHTML = '';

    if (!allModules.length) {
      container.innerHTML = '<div class="alert alert-light border text-center p-4">No dashboard modules enabled.</div>';
      return;
    }

    if (currentMode === MODE_CATEGORIES) {
      renderCategoriesView();
      return;
    }

    renderModulesView();
  }


  function buildCategoryModels() {
    const computed = computeCategoriesFromModules(allModules);
    const cats = applySearchToCategories(computed);

    // Always include "All Sections" entry (searchable by name)
    const allEntry = {
      key: CAT_ALL,
      name: 'All Sections',
      count: allModules.length,
      isAll: true
    };

    // If user is searching and "All Sections" doesn't match, still keep it (acts as escape hatch)
    const entries = [allEntry, ...cats.map(c => ({...c, isAll: false}))];

    // Attach representative icon HTML (reuse section icons)
    return entries.map(c => {
      let iconHtml = `<i class="bi ${c.isAll ? 'bi-grid-fill' : 'bi-folder-fill'}"></i>`;
      const rep = c.isAll
        ? (allModules.find(m => m && m.customIcon) || null)
        : (allModules.find(m => normalizeCategory(m.category) === c.key && m && m.customIcon) || null);

      if (rep) iconHtml = renderIconHtml(rep, c.isAll ? 'bi-grid-fill' : 'bi-folder-fill');
      const hasWatermark = !!rep && hasRegisteredSymbolIcon(rep);

      return { ...c, iconHtml, hasWatermark };
    });
  }

  function renderCategoriesView() {
    const entries = buildCategoryModels();
    if (!entries.length) {
      container.innerHTML = '<div class="alert alert-light border text-center p-4">No categories available.</div>';
      return;
    }

    // Render categories using the SAME 3 view styles (card/compact/list)
    if (currentView === 'list') renderCategoriesList(entries);
    else if (currentView === 'compact') renderCategoriesCompact(entries);
    else renderCategoriesCard(entries);
  }

  function openCategory(entry) {
    if (entry.isAll || entry.key === CAT_ALL) setMode(MODE_MODULES, CAT_ALL);
    else setMode(MODE_MODULES, entry.key);
  }

  function renderCategoriesCard(entries) {
    const row = document.createElement('div');
    row.className = 'row g-4';

    entries.forEach(entry => {
      const col = document.createElement('div');
      col.className = 'col-lg-4 col-md-6';

      const title = entry.name || formatName(entry.key);
      const subtitle = `${entry.count} item${entry.count === 1 ? '' : 's'}`;
      const watermarkHtml = entry.hasWatermark ? entry.iconHtml : '';

      // Uses same module-card + module-icon classes for consistent sizing.
      col.innerHTML = `
        <div class="module-card category-card dashboard-module-card" role="button" tabindex="0" style="cursor:pointer;">
          <div class="module-accent"></div>
          ${watermarkHtml ? `<div class="dashboard-card-watermark" aria-hidden="true">${watermarkHtml}</div>` : ''}
          <div class="dashboard-card-content">
            <div class="d-flex align-items-start justify-content-between mb-3">
              <div class="module-icon d-flex align-items-center justify-content-center">
                ${entry.iconHtml}
              </div>
              <span class="badge bg-light text-secondary border">${subtitle}</span>
            </div>
            <h4 class="fw-bold mb-1" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;" title="${title}">
              ${title}
            </h4>
            <div class="text-muted small mb-3">
              ${entry.isAll ? 'Browse all modules' : 'Open folder'}
            </div>
            <div class="mt-auto">
              <button type="button" class="btn btn-primary btn-filled w-100">
                ${entry.isAll ? 'Show All Sections' : 'Open Category'}
              </button>
            </div>
          </div>
        </div>
      `;

      const card = col.querySelector('.category-card');
      card.addEventListener('click', () => openCategory(entry));
      card.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          openCategory(entry);
        }
      });

      row.appendChild(col);
    });

    container.appendChild(row);
  }

  function renderCategoriesCompact(entries) {
    const row = document.createElement('div');
    row.className = 'row g-3';

    entries.forEach(entry => {
      const col = document.createElement('div');
      col.className = 'col-6 col-md-4 col-lg-2';

      const label = entry.name || formatName(entry.key);
      const watermarkHtml = entry.hasWatermark ? entry.iconHtml : '';

      // module-compact keeps the familiar compact style; icon sizing is controlled by your existing CSS.
      col.innerHTML = `
        <button type="button"
                class="w-100 text-start text-decoration-none border bg-white rounded-3 shadow-sm p-3 module-compact dashboard-compact-card"
                style="cursor:pointer;">
          ${watermarkHtml ? `<div class="dashboard-compact-watermark" aria-hidden="true">${watermarkHtml}</div>` : ''}
          <div class="dashboard-compact-content d-flex align-items-center gap-3">
            <div class="module-icon dashboard-compact-icon d-flex align-items-center justify-content-center flex-shrink-0">
              ${entry.iconHtml}
            </div>
            <div class="flex-grow-1 overflow-hidden">
              <div class="fw-bold" style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;" title="${label}">
                ${label}
              </div>
              <div class="small text-muted">${entry.count} item${entry.count === 1 ? '' : 's'}</div>
            </div>
            <div class="text-muted"><i class="bi bi-chevron-right"></i></div>
          </div>
        </button>
      `;

      col.querySelector('button').addEventListener('click', () => openCategory(entry));
      row.appendChild(col);
    });

    container.appendChild(row);
  }

  function renderCategoriesList(entries) {
    const list = document.createElement('div');
    list.className = 'list-group';

    entries.forEach(entry => {
      const label = entry.name || formatName(entry.key);
      const subtitle = `${entry.count} item${entry.count === 1 ? '' : 's'}`;

      const item = document.createElement('button');
      item.type = 'button';
      item.className = 'list-group-item list-group-item-action d-flex align-items-center gap-3 py-3';
      item.innerHTML = `
        <div class="module-icon d-flex align-items-center justify-content-center flex-shrink-0"
             style="width:40px;height:40px;overflow:hidden;border-radius:999px;background:var(--bs-light);">
          ${entry.iconHtml}
        </div>
        <div class="flex-grow-1 overflow-hidden">
          <div class="fw-bold" style="display:-webkit-box;-webkit-line-clamp:1;-webkit-box-orient:vertical;overflow:hidden;" title="${label}">
            ${label}
          </div>
          <div class="small text-muted">${subtitle}</div>
        </div>
        <div class="text-muted"><i class="bi bi-chevron-right"></i></div>
      `;
      item.addEventListener('click', () => openCategory(entry));
      list.appendChild(item);
    });

    container.appendChild(list);
  }

  function renderModulesView() {
    let header = null;
    const showCategoryHeader = currentCategory !== CAT_ALL;
    if (showCategoryHeader) {
      header = document.createElement('div');
      header.className = 'd-flex align-items-center justify-content-between mb-3';
      const title = formatName(currentCategory);
      header.innerHTML = `
        <div class="d-flex align-items-center gap-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" id="backToCatsBtn" title="Back to Categories">
            <i class="bi bi-folder-fill"></i>
          </button>
          <div class="fw-bold text-secondary">${title}</div>
        </div>
        <div class="small text-muted" id="resultsCount"></div>
      `;
      container.appendChild(header);
      header.querySelector('#backToCatsBtn').addEventListener('click', () => setMode(MODE_CATEGORIES));
    }

    let mods = allModules.slice();
    if (currentCategory !== CAT_ALL) {
      mods = mods.filter(m => normalizeCategory(m.category) === currentCategory);
    }
    mods = applySearchToModules(mods);

    mods.sort((a, b) => {
      const nameA = (a.name || '').toLowerCase();
      const nameB = (b.name || '').toLowerCase();
      const accA = a.minimumAccessRequirement || 0;
      const accB = b.minimumAccessRequirement || 0;

      switch (currentSort) {
        case 'name_asc': return nameA.localeCompare(nameB);
        case 'name_desc': return nameB.localeCompare(nameA);
        case 'access_asc': return accA - accB;
        case 'access_desc': return accB - accA;
        default: return 0;
      }
    });

    if (header) {
      const resultsEl = header.querySelector('#resultsCount');
      if (resultsEl) resultsEl.textContent = `${mods.length} shown`;
    }

    if (!mods.length) {
      const empty = document.createElement('div');
      empty.className = 'alert alert-light border text-center p-4';
      empty.textContent = 'No items match your filter.';
      container.appendChild(empty);
      return;
    }

    if (currentView === 'list') renderListView(mods);
    else if (currentView === 'compact') renderCompactView(mods);
    else renderCardView(mods);
  }

  // ---------- View Templates ----------
  function renderCardView(mods) {
    const row = document.createElement('div');
    row.className = 'row g-4';

    mods.forEach((m, idx) => {
      const col = document.createElement('div');
      col.className = 'col-lg-4 col-md-6 d-flex';

      const displayName = formatName(m.name);
      const url = getSectionUrl(m);
      const opsCount = (m.operations || []).length;
      const iconHtml = renderIconHtml(m, 'bi-compass');
      const watermarkHtml = hasRegisteredSymbolIcon(m) ? iconHtml : '';
      const safeAria = String(displayName).replace(/&/g, '&amp;').replace(/"/g, '&quot;');
      const iconVariant = getModuleIconVariant(m, idx);
      const iconClass = iconVariant.className ? ` ${iconVariant.className}` : '';
      const iconStyleAttr = iconVariant.style ? ` style="${iconVariant.style.replace(/"/g, '&quot;')}"` : '';

      col.innerHTML = `
        <a href="${url}" class="dashboard-module-card-link d-flex flex-column flex-grow-1 w-100 text-decoration-none" aria-label="Open ${safeAria}">
          <div class="module-card dashboard-module-card flex-grow-1 w-100">
            <div class="module-accent"></div>
            ${watermarkHtml ? `<div class="dashboard-card-watermark" aria-hidden="true">${watermarkHtml}</div>` : ''}
            <div class="dashboard-card-content d-flex flex-column flex-grow-1">
              <div class="d-flex align-items-start justify-content-between mb-3">
                <div class="module-icon d-flex align-items-center justify-content-center flex-shrink-0${iconClass}"${iconStyleAttr}>
                  ${iconHtml}
                </div>
                <div class="d-flex gap-1 flex-wrap justify-content-end">
                  <span class="badge bg-light text-dark border">Access ${m.minimumAccessRequirement || 0}</span>
                  ${opsCount ? `<span class="badge bg-light text-secondary border">${opsCount} Ops</span>` : ''}
                </div>
              </div>
              <h4 class="fw-bold mb-1 text-truncate text-dark" title="${displayName}">${displayName}</h4>
              <div class="text-muted small mb-3 text-truncate flex-grow-1" style="min-height: 2.75rem;" title="${m.description || ''}">${m.description || 'No description'}</div>
              ${m.message ? `<div class="module-message small text-body"><i class="bi bi-info-circle me-1"></i> ${m.message}</div>` : ''}
            </div>
          </div>
        </a>
      `;
      row.appendChild(col);
    });

    container.appendChild(row);
  }

  function renderCompactView(mods) {
    const row = document.createElement('div');
    row.className = 'row g-3';

    mods.forEach((m, idx) => {
      const col = document.createElement('div');
      col.className = 'col-6 col-md-4 col-lg-2';

      const displayName = formatName(m.name);
      const url = getSectionUrl(m);
      const iconHtml = renderIconHtml(m, 'bi-grid-fill');
      const watermarkHtml = hasRegisteredSymbolIcon(m) ? iconHtml : '';
      const iconVariant = getModuleIconVariant(m, idx);
      const iconClass = iconVariant.className ? ` ${iconVariant.className}` : '';
      const iconStyleAttr = iconVariant.style ? ` style="${iconVariant.style.replace(/"/g, '&quot;')}"` : '';

      col.innerHTML = `
        <a href="${url}" class="text-decoration-none text-dark h-100 d-block">
          <div class="module-compact shadow-sm bg-white border rounded-3 p-3 text-center h-100 position-relative overflow-hidden dashboard-compact-card">
            ${watermarkHtml ? `<div class="dashboard-compact-watermark" aria-hidden="true">${watermarkHtml}</div>` : ''}
            <div class="dashboard-compact-content">
              <div class="mb-2 d-inline-flex align-items-center justify-content-center dashboard-compact-icon${iconClass}"${iconStyleAttr}>
                ${iconHtml}
              </div>
              <div class="fw-bold small text-truncate w-100 text-dark" title="${displayName}">${displayName}</div>
              <div class="x-small text-muted mt-1">Lvl ${m.minimumAccessRequirement || 0}</div>
            </div>
          </div>
        </a>
      `;
      row.appendChild(col);
    });

    container.appendChild(row);
  }

  function renderListView(mods) {
    const tableResp = document.createElement('div');
    tableResp.className = 'table-responsive border rounded bg-white shadow-sm';

    let html = `
      <table class="table table-hover align-middle mb-0">
        <thead class="bg-light text-secondary small text-uppercase">
          <tr>
            <th class="ps-4" style="width: 60px;"></th>
            <th>Module Name</th>
            <th>Description</th>
            <th class="text-center">Access</th>
            <th class="text-end pe-4">Action</th>
          </tr>
        </thead>
        <tbody>
    `;

    mods.forEach((m, idx) => {
      const displayName = formatName(m.name);
      const url = getSectionUrl(m);
      const iconHtml = renderIconHtml(m, 'bi-compass');
      const iconVariant = getModuleIconVariant(m, idx);
      const iconClass = iconVariant.className ? ` ${iconVariant.className}` : '';
      const iconStyleAttr = iconVariant.style ? ` ${iconVariant.style}` : '';

      html += `
        <tr class="module-list-row cursor-pointer" onclick="window.location='${url}'">
          <td class="ps-4">
            <div class="rounded d-flex align-items-center justify-content-center${iconClass}"
                 style="width:32px; height:32px; font-size: 1rem; overflow: hidden;${iconStyleAttr}">
              ${iconHtml}
            </div>
          </td>
          <td class="fw-bold text-primary">${displayName}</td>
          <td class="text-muted small text-truncate" style="max-width: 300px;">${m.description || '-'}</td>
          <td class="text-center"><span class="badge bg-light text-dark border">${m.minimumAccessRequirement || 0}</span></td>
          <td class="text-end pe-4">
            <a href="${url}" class="btn btn-sm btn-outline-primary py-0">Open <i class="bi bi-arrow-right"></i></a>
          </td>
        </tr>
      `;
    });

    html += `</tbody></table>`;
    tableResp.innerHTML = html;
    container.appendChild(tableResp);
  }

  function updateViewBtnState() {
    viewBtns.forEach(btn => {
      if (btn.dataset.view === currentView) {
        btn.classList.add('active', 'bg-secondary', 'text-white');
        btn.classList.remove('btn-outline-secondary');
      } else {
        btn.classList.remove('active', 'bg-secondary', 'text-white');
        btn.classList.add('btn-outline-secondary');
      }
    });
  }

  // ---------- Events ----------
  if (sortSelect) {
    sortSelect.addEventListener('change', async (e) => {
      currentSort = e.target.value;
      localStorage.setItem(SORT_KEY, currentSort);
      if (currentSourceMode === SOURCE_ALL) {
        await reloadAllSectionsData({
          q: searchQuery,
          sort: currentSort,
          showLoading: false
        });
        return;
      }
      render();
    });
  }

  viewBtns.forEach(btn => {
    btn.addEventListener('click', (e) => {
      currentView = e.currentTarget.dataset.view;
      localStorage.setItem(VIEW_KEY, currentView);
      updateViewBtnState();
      render();
    });
  });

  if (searchInput) {
    searchInput.addEventListener('input', () => {
      searchQuery = searchInput.value || '';
      localStorage.setItem(SEARCH_KEY, searchQuery);
      if (searchDebounceHandle) clearTimeout(searchDebounceHandle);
      searchDebounceHandle = setTimeout(async () => {
        if (currentSourceMode === SOURCE_ALL) {
          await reloadAllSectionsData({
            q: searchQuery,
            sort: currentSort,
            showLoading: false
          });
          return;
        }
        render();
      }, SEARCH_DEBOUNCE_MS);
    });
  }

  if (toggleAllSectionsBtn) {
    toggleAllSectionsBtn.addEventListener('click', () => {
      const nextMode = currentSourceMode === SOURCE_ALL ? SOURCE_MAIN : SOURCE_ALL;
      setSectionSource(nextMode).catch((error) => {
        console.error('Dashboard source toggle error:', error);
      });
    });
  }

  if (currentMode === MODE_MODULES && currentCategory !== CAT_ALL) {
    const exists = allModules.some(m => normalizeCategory(m.category) === currentCategory);
    if (!exists) currentCategory = CAT_ALL;
  }

  if (currentSourceMode === SOURCE_ALL) {
    setSectionSource(SOURCE_ALL, { persist: false, showLoading: true }).catch((error) => {
      console.error('Dashboard initial all-sections load error:', error);
      allModules = dashboardModules.slice();
      currentSourceMode = SOURCE_MAIN;
      localStorage.setItem(SOURCE_KEY, SOURCE_MAIN);
      updateSourceToggleButton();
      updateModuleCountBadge();
      render();
    });
    return;
  }

  updateSourceToggleButton();
  updateModuleCountBadge();
  render();
});
</script>

