<% if (websitePolicy && websitePolicy.maintenance && websitePolicy.maintenance.enabled) { %>
  <div class="alert alert-warning border-2 border-warning shadow-sm d-flex align-items-center mb-4" role="alert">
    <div class="fs-1 me-3">
        <i class="bi bi-cone-striped"></i>
    </div>
    <div>
      <h4 class="alert-heading fw-bold mb-1">System is in Maintenance Mode</h4>
      <p class="mb-0">
        Public access is currently <strong>blocked</strong>. You are seeing this page because your role or IP has bypass permissions.
        <br>
        <span class="small opacity-75">Public Message: "<%= websitePolicy.maintenance.message %>"</span>
      </p>
    </div>
    <div class="ms-auto ps-3 border-start border-warning border-opacity-25">
       <a href="/websitePolicy" class="btn btn-warning btn-sm text-dark fw-bold">Manage Policy</a>
    </div>
  </div>
<% } %>

<%
  function cleanNamePart(value) {
    return String(value || '').trim();
  }
  function firstToken(value) {
    const token = cleanNamePart(value);
    if (!token) return '';
    return token.split(/\s+/).filter(Boolean)[0] || '';
  }

  const preferredName = cleanNamePart(user?.name?.preferred || user?.preferredName || '');
  const firstName = cleanNamePart(user?.name?.first || user?.firstName || '');
  const stringNameFirst = firstToken(typeof user?.name === 'string' ? user.name : '');
  const displayNameFirst = firstToken(user?.displayName || user?.identity?.displayName || '');
  const usernameFirst = firstToken(user?.username || '');
  const activeDisplayName = preferredName || firstName || stringNameFirst || displayNameFirst || usernameFirst || 'there';
  const nowHour = new Date().getHours();
  let dayPeriodGreeting = 'good evening';
  if (nowHour >= 5 && nowHour < 12) dayPeriodGreeting = 'good morning';
  else if (nowHour >= 12 && nowHour < 17) dayPeriodGreeting = 'good afternoon';
  else if (nowHour >= 17 && nowHour < 21) dayPeriodGreeting = 'good evening';
  else dayPeriodGreeting = 'good night';
  const adminCtx = typeof adminContext !== 'undefined' && adminContext ? adminContext : {};
  const isSuperAdminViewer = !!adminCtx.isSuperAdmin;
%>
<div class="dash-hero dashboard-greeting-hero mb-4">
  <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
    
    <div>
      <h1 class="page-heading size-lg text-start mb-1">
        Hey <%= activeDisplayName %>, <%= dayPeriodGreeting %>
      </h1>
      <div class="text-muted d-none d-sm-block" style="font-size:1.05rem;">
        Welcome to your workspace.
        <% if (isSuperAdminViewer) { %>
          <a href='/debug/thisuser' class="text-decoration-none small ms-2 badge bg-light text-secondary border">Session Debug</a>
        <% } %>
      </div>
      <div class="text-muted small d-sm-none">
        Welcome.
        <% if (isSuperAdminViewer) { %>
          <a href='/debug/thisuser' class="text-decoration-none small ms-2 badge bg-light text-secondary border">Session Debug</a>
        <% } %>
      </div>
    </div>

        <div class="d-flex align-items-center justify-content-md-end gap-3">
        
        <% 
           // Logic to derive Active Org Name
           let activeOrgName = 'System / Global';
           let activeOrgRole = 'System Admin';
           const activeId = user?.activeOrgId;
           const isSystemContext = !activeId || String(activeId).toUpperCase() === 'SYSTEM';
           
           if (activeId && activeId !== 'SYSTEM') {
               const orgs = user.allowedOrgs || [];
               const current = orgs.find(o => String(o.orgId) === String(activeId));
               if (current) {
                   activeOrgName = current.name || `Organization #${activeId}`;
                   activeOrgRole = (Array.isArray(current.roles) && current.roles.length ? current.roles.join(', ') : (current.role || 'Member'));
               } else {
                   activeOrgName = `Organization #${activeId}`;
               }
           }

           const activeContextChip = isSystemContext
             ? 'SYSTEM'
             : `ORG ${String(activeId).trim()}`;
        %>

        <div
          id="dashboardActiveContextCard"
          class="dash-org-switch-card <%= isSystemContext ? 'is-system-context' : 'is-org-context' %>"
          title="Current active organization context">
            <div class="dash-org-switch-icon d-flex align-items-center justify-content-center flex-shrink-0">
                <i id="dashboardActiveOrgIcon" class="bi <%= isSystemContext ? 'bi-globe2' : 'bi-building-fill' %>"></i>
            </div>

            <div class="dash-org-switch-main overflow-hidden">
                <div class="dash-org-switch-label-row">
                    <span class="dash-org-switch-label text-uppercase">Active Context</span>
                    <span id="dashboardActiveOrgChip" class="dash-org-switch-chip"><%= activeContextChip %></span>
                </div>

                <div
                  class="dash-org-switch-name fw-bold text-dark text-truncate"
                  id="dashboardActiveOrgName"
                  title="<%= activeOrgName %>">
                    <%= activeOrgName %>
                </div>

                <div
                  class="dash-org-switch-role text-truncate"
                  id="dashboardActiveOrgRole"
                  title="<%= activeOrgRole %>">
                    <%= activeOrgRole %>
                </div>
            </div>
        </div>

        <% if (user.canSwitchProfile) { %>
            <% const isSystemMode = (user.currentProfileMode === 'SYSTEM'); %>
            <button type="button" id="profileModeSwitchBtn" 
                    class="btn border rounded-4 bg-white bg-opacity-50 shadow-sm d-flex align-items-center gap-2 px-3"
                    style="height: 68px; backdrop-filter: blur(5px); transition: transform 0.2s ease;"
                    title="Switch View: <%= isSystemMode ? 'System Admin' : 'Local Member' %>"
                    onclick="event.stopPropagation(); toggleProfileMode('<%= isSystemMode ? 'LOCAL' : 'SYSTEM' %>')"
                    onmouseover="this.style.transform='translateY(-2px)'"
                    onmouseout="this.style.transform='translateY(0)'">
                
                <div class="rounded-circle d-flex align-items-center justify-content-center flex-shrink-0 <%= isSystemMode ? 'bg-danger-subtle text-danger' : 'bg-info-subtle text-info-emphasis' %>" 
                     style="width: 42px; height: 42px;">
                    <i class="bi <%= isSystemMode ? 'bi-shield-lock-fill' : 'bi-person-badge-fill' %> fs-5"></i>
                </div>

                <div class="text-start d-none d-lg-block">
                    <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.65rem; letter-spacing: 0.5px;">
                        View Mode
                    </div>
                    <span class="fw-bold text-dark text-truncate d-block" style="font-size: 0.85rem; max-width: 150px;">
                        <%= isSystemMode ? 'System Admin' : 'Local Member' %> 
                    </span>
                </div>

                <i class="bi bi-arrow-repeat text-muted ms-1"></i>
            </button>
        <% } %>
        
        <!-- Org switch modal/logic is provided by the header partial; do not duplicate it here. -->
    </div>    
  </div>
</div>

<% if (showDashboardSummary) { %>
  <% 
    const hasLogCard = !!(access && access.showLogCard);
    const hasActionStateCard = !!(access && access.showActionStateCard);
    const logHealth = (stats && stats.logHealth) ? stats.logHealth : 'secondary';
    const actionStateHealth = (stats && stats.actionStateHealth) ? stats.actionStateHealth : 'secondary';
    const sectionsHealth = Number(stats && stats.sections ? stats.sections : 0) > 0 ? 'primary' : 'danger';
    const dashboardHealth = Number(stats && stats.dashboardSections ? stats.dashboardSections : 0) > 0 ? 'success' : 'danger';
    const sectionCoverageHealth = (sectionsHealth === 'danger' || dashboardHealth === 'danger') ? 'danger' : 'info';
    const sectionCoverageValue = `${Number(stats?.dashboardSections || 0)} / ${Number(stats?.sections || 0)}`;
    const hasAttentionItem =
      (hasLogCard && logHealth === 'danger') ||
      (hasActionStateCard && actionStateHealth === 'danger') ||
      sectionsHealth === 'danger' ||
      dashboardHealth === 'danger';
    const statsHeaderClass = hasAttentionItem ? 'bg-danger-subtle border-danger-subtle text-danger-emphasis' : 'bg-light border-light text-secondary';
    const statsToggleClass = hasAttentionItem ? 'btn-outline-danger' : 'btn-outline-secondary';
    const statsHeaderLabel = hasAttentionItem ? 'Attention Needed' : 'Dashboard Summary';
  %>
  <div class="mb-3">
    <div class="d-flex align-items-center justify-content-between border rounded-3 px-3 py-2 <%= statsHeaderClass %>">
      <div class="small fw-bold">
        <% if (hasAttentionItem) { %>
          <i class="bi bi-exclamation-triangle-fill me-1"></i>
        <% } else { %>
          <i class="bi bi-bar-chart-line-fill me-1"></i>
        <% } %>
        <%= statsHeaderLabel %>
      </div>
      <button class="btn btn-sm <%= statsToggleClass %>" type="button" data-bs-toggle="collapse" data-bs-target="#dashboardAttentionCards" aria-expanded="false" aria-controls="dashboardAttentionCards">
        Show/Hide
      </button>
    </div>

    <div class="collapse mt-2" id="dashboardAttentionCards">
      <div class="dashboard-stats-row">
        <% if (hasLogCard) { %>
          <div class="dashboard-stat-col">
            <a href="/logs" class="dashboard-stat-link text-decoration-none text-reset d-block h-100">
              <div class="dash-stat dashboard-top-stat d-flex align-items-center justify-content-between border-start border-4 border-<%= logHealth %> shadow-sm h-100 bg-white p-3 rounded-3">
                <div>
                  <div class="text-muted small fw-bold text-uppercase ls-1">System Logs</div>

                  <div class="d-flex align-items-baseline gap-2 mt-1">
                      <div class="fw-bold text-<%= logHealth %> dashboard-top-stat-value"><%= stats.logCount %></div>
                      <span class="text-muted small">entries</span>
                  </div>

                  <div class="d-flex align-items-center gap-2 mt-2">
                      <span class="badge bg-light text-secondary border font-monospace">
                          <i class="bi bi-hdd me-1"></i><%= stats.logSize %>
                      </span>
                      <% if (logHealth !== 'success') { %>
                          <span class="badge bg-<%= logHealth %>-subtle text-<%= logHealth %> border border-<%= logHealth %>-subtle">
                              <%= stats.logMessage %>
                          </span>
                      <% } %>
                  </div>
                </div>

                <div class="text-end opacity-25 dashboard-top-stat-icon">
                   <% if (logHealth === 'danger') { %>
                      <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                   <% } else if (logHealth === 'warning') { %>
                      <i class="bi bi-exclamation-circle-fill text-warning"></i>
                   <% } else { %>
                      <i class="bi bi-database-check text-success"></i>
                   <% } %>
                </div>
              </div>
            </a>
          </div>
        <% } %>

        <% if (hasActionStateCard) { %>
          <div class="dashboard-stat-col">
            <a href="/actionStates" class="dashboard-stat-link text-decoration-none text-reset d-block h-100">
              <div class="dash-stat dashboard-top-stat d-flex align-items-center justify-content-between border-start border-4 border-<%= actionStateHealth %> shadow-sm h-100 bg-white p-3 rounded-3">
                <div>
                  <div class="text-muted small fw-bold text-uppercase ls-1">Action States</div>
                  <div class="d-flex align-items-baseline gap-2 mt-1">
                    <div class="fw-bold text-<%= actionStateHealth %> dashboard-top-stat-value"><%= stats.actionStateCount %></div>
                    <span class="text-muted small">entries</span>
                  </div>
                  <div class="d-flex align-items-center gap-2 mt-2">
                    <% if (actionStateHealth !== 'success') { %>
                      <span class="badge bg-<%= actionStateHealth %>-subtle text-<%= actionStateHealth %> border border-<%= actionStateHealth %>-subtle">
                        <%= stats.actionStateMessage %>
                      </span>
                    <% } else { %>
                      <span class="badge bg-success-subtle text-success border border-success-subtle">
                        Healthy
                      </span>
                    <% } %>
                  </div>
                </div>

                <div class="text-end opacity-25 dashboard-top-stat-icon">
                  <% if (actionStateHealth === 'danger') { %>
                    <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                  <% } else if (actionStateHealth === 'warning') { %>
                    <i class="bi bi-exclamation-circle-fill text-warning"></i>
                  <% } else { %>
                    <i class="bi bi-activity text-success"></i>
                  <% } %>
                </div>
              </div>
            </a>
          </div>
        <% } %>

        <div class="dashboard-stat-col">
          <a href="/sections" class="dashboard-stat-link text-decoration-none text-reset d-block h-100">
            <div class="dash-stat dashboard-top-stat d-flex align-items-center justify-content-between border-start border-4 border-<%= sectionCoverageHealth %> shadow-sm h-100 bg-white p-3 rounded-3">
              <div>
                <div class="text-muted small fw-bold text-uppercase ls-1">Sections / Dashboard</div>
                <div class="d-flex align-items-baseline gap-2 mt-1">
                    <div class="fw-bold text-<%= sectionCoverageHealth %> dashboard-top-stat-value"><%= sectionCoverageValue %></div>
                    <span class="text-muted small">visible / total</span>
                </div>
                <div class="d-flex align-items-center gap-2 mt-2">
                    <% if (sectionsHealth === 'danger') { %>
                      <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                        No Sections Found
                      </span>
                    <% } else if (dashboardHealth === 'danger') { %>
                      <span class="badge bg-danger-subtle text-danger border border-danger-subtle">
                        No Visible Dashboard Items
                      </span>
                    <% } else { %>
                      <span class="badge bg-info-subtle text-info border border-info-subtle">
                        Coverage
                      </span>
                    <% } %>
                    <span class="badge bg-light text-secondary border font-monospace">
                      <%= stats.dashboardSections %> / <%= stats.sections %>
                    </span>
                </div>
              </div>
              <div class="text-end opacity-25 dashboard-top-stat-icon">
                 <% if (sectionCoverageHealth === 'danger') { %>
                  <i class="bi bi-exclamation-triangle-fill text-danger"></i>
                 <% } else { %>
                  <i class="bi bi-grid-1x2-fill text-info"></i>
                 <% } %>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
<% } %>

<div class="mb-4 dashboard-modules-toolbar-block">
  <h3 class="fw-bold text-secondary m-0">
    Dashboard Modules 
    <span id="dashboardModuleCountBadge" class="badge bg-light text-muted border ms-2" style="font-size: 0.5em; vertical-align: middle;"><%= dashboardSections.length %></span>
  </h3>
  <div class="d-flex flex-column flex-md-row justify-content-start justify-content-md-between align-items-stretch align-items-md-center gap-2 mt-2 dashboard-toolbar-row">
    <div class="d-flex gap-2 flex-wrap align-items-center dashboard-toolbar-left">
      <div class="input-group input-group-sm flex-nowrap dashboard-search-group" style="min-width: 220px; max-width: 340px;">
        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search"></i></span>
        <input id="dashSearch" type="text" class="form-control form-control-sm border-start-0 ps-0" placeholder="Search..." autocomplete="off">
      </div>
    </div>

    <div class="d-flex gap-2 align-items-center justify-content-md-end dashboard-toolbar-right">
      <div class="input-group input-group-sm flex-nowrap dashboard-sort-group">
        <span class="input-group-text bg-white border-end-0"><i class="bi bi-sort-down"></i></span>
        <select id="sortSelect" class="form-select form-select-sm border-start-0 ps-0 dash-sort-select">
          <option value="name_asc">Name (A-Z)</option>
          <option value="name_desc">Name (Z-A)</option>
          <option value="access_asc">Access (Low-High)</option>
          <option value="access_desc">Access (High-Low)</option>
        </select>
      </div>

      <div class="btn-group" role="group" aria-label="View Style">
        <button type="button" class="btn btn-outline-secondary btn-sm view-btn" data-view="card" title="Card View">
          <i class="bi bi-grid-fill"></i>
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm view-btn active" data-view="compact" title="Compact View">
          <i class="bi bi-grid-3x3-gap-fill"></i>
        </button>
        <button type="button" class="btn btn-outline-secondary btn-sm view-btn" data-view="list" title="List View">
          <i class="bi bi-list-ul"></i>
        </button>
      </div>
      <button
        type="button"
        id="toggleAllSectionsBtn"
        class="btn btn-outline-secondary btn-sm ms-2"
        aria-pressed="false"
        title="Show all accessible sections except navigation sections">
        <i class="bi bi-diagram-3 me-1"></i>All Section
      </button>
    </div>
  </div>
</div>

<div id="modulesContainer">
    <div class="text-center py-5 text-muted">
        <div class="spinner-border text-primary mb-2" role="status"></div>
        <div>Loading modules...</div>
    </div>
</div>

<div class="dashboard-help-footer-attach p-4 bg-light rounded-3 border border-light">
  <div class="row align-items-center">
    <div class="col-md-8">
      <h5 class="fw-bold mb-1">Need Help?</h5>
      <p class="mb-0 text-muted text-small">
        Check the documentation for guidance on import formats and admin codes.
      </p>
    </div>
    <div class="col-md-4 text-md-end mt-3 mt-md-0">
      <a href="/docs" class="btn btn-outline-secondary btn-sm">View Documentation</a>
    </div>
  </div>
</div>
<span id="urlRef" data-id="<%= newUrl %>" hidden></span>

<script type="application/json" id="modulesData">
    <%- JSON.stringify(dashboardSections || []) %>
</script>

<style>
