<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
      <h1 class="page-heading size-md m-0"><%= title %></h1>
      <span class="badge bg-primary border font-monospace">ID: <%= group.id %></span>
  </div>

  <div class="form-container wide" style="max-width: 1400px;">
      
      <div class="d-flex flex-wrap align-items-center justify-content-between mb-4 pb-3 border-bottom">
          <div>
              <span class="text-muted small text-uppercase fw-bold ls-1">Group Status</span>
              <div class="d-flex align-items-center mt-1">
                  <% if (group.active) { %>
                      <i class="bi bi-check-circle-fill text-success me-2"></i>
                      <span class="fw-bold text-dark">Active</span>
                  <% } else { %>
                      <i class="bi bi-dash-circle-fill text-danger me-2"></i>
                      <span class="fw-bold text-dark">Inactive</span>
                  <% } %>
                  <span class="text-muted mx-3">|</span>
                  <span class="text-muted"><%= group.description || 'No description provided.' %></span>
              </div>
          </div>
          
          <button id="btnAddMember" type="button" class="btn btn-filled btn-primary btn-md shadow-sm">
             <i class="bi bi-person-plus-fill me-2"></i>Add Member
          </button>
      </div>

      <div class="mb-3">
        <%- include('../partials/tablePages-search', {
            placeholder: 'Search members in this group...',
            fields: []
        }) %>
      </div>

      <div class="table-scroll-wrapper border rounded-3 overflow-hidden mb-3">
        <table class="table-responsive size-md mb-0" id="members-table">
          <thead class="bg-light border-bottom">
            <tr>
              <th class="ps-3">Email / ID</th>
              <th>Status</th>
              <th class="text-center">Active</th>
              <th>Subscribed At</th>
              <th class="text-end pe-3">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (members.length === 0) { %>
                <tr>
                    <td colspan="5" class="text-center py-5">
                        <div class="text-muted opacity-50 mb-2">
                            <i class="bi bi-people fs-1"></i>
                        </div>
                        <h6 class="text-muted fw-bold">No members found</h6>
                        <p class="text-muted small mb-0">Use the "Add Member" button to populate this group.</p>
                    </td>
                </tr>
            <% } %>

            <% members.forEach(sub => { %>
              <tr class="align-middle">
                <td class="ps-3">
                   <div class="fw-bold text-dark"><%= sub.email %></div>
                   <div class="small text-muted font-monospace"><%= sub.id %></div>
                </td>

                <td>
                   <% if(sub.status === 'subscribed') { %>
                      <span class="badge bg-success-subtle text-success border border-success-subtle shadow-sm">Subscribed</span>
                   <% } else { %>
                      <span class="badge bg-secondary-subtle text-secondary border border-secondary-subtle shadow-sm"><%= sub.status %></span>
                   <% } %>
                </td>

                <td class="text-center">
                   <% if (sub.active) { %>
                      <i class="bi bi-check-circle-fill text-success fs-5" title="Active"></i>
                   <% } else { %>
                      <i class="bi bi-dash-circle text-muted fs-5" title="Inactive"></i>
                   <% } %>
                </td>

                <td>
                   <% if (sub.subscribedAt) { %>
                      <%= new Date(sub.subscribedAt).toLocaleDateString() %> 
                      <small class="text-muted"><%= new Date(sub.subscribedAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %></small>
                   <% } else { %>
                      <span class="text-muted">—</span>
                   <% } %>
                </td>

                <td class="text-end pe-3">
                   <button class="btn btn-sm btn-outline-danger btn-remove-member btn-filled" 
                           data-id="<%= sub.id %>" 
                           data-email="<%= sub.email %>">
                      <i class="bi bi-person-dash-fill me-1"></i> Remove
                   </button>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <%- include('../partials/pagination', { 
          pagination: pagination, 
          filters: filters, 
          baseUrlPath: `subscription-groups/${group.id}/members`
      }) %>

      <div class="button-row mt-4 pt-3 border-top">
          <a href="/subscription-groups" class="btn btn-filled btn-secondary btn-md px-4">
              <i class="bi bi-arrow-left me-2"></i>Return to Groups
          </a>
      </div>
  </div>
</div>

<%- include('../partials/modal_GenericPicker') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
    
    // Helper for Modal Feedback
    const showFeedback = async (type, title, message) => {
        if (typeof showMessageModal === 'function') {
            await showMessageModal({
                title: title,
                icon: type,
                message: message,
                buttons: [{ text: 'OK', class: type === 'success' ? 'btn-primary' : 'btn-danger' }]
            });
        } else {
            alert(message);
        }
    };

    // --- ADD MEMBER (PICKER) ---
    const btnAdd = document.getElementById('btnAddMember');
    if (btnAdd) {
        btnAdd.addEventListener('click', () => {
             if (typeof GenericPicker === 'undefined') return console.error('GenericPicker missing');

             GenericPicker.open(GenericPickerPresets.user({
                title: 'Add Subscriber to Group',
                apiEndpoint: '/newsletter/admin',
                placeholder: 'Search by email...',
                renderer: (item) => {
                    // Custom Renderer for Subscriber in Picker
                    return `
                        <div class="d-flex justify-content-between align-items-center w-100">
                            <div class="d-flex align-items-center gap-3">
                                <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center text-primary" style="width: 40px; height: 40px;">
                                    <i class="bi bi-person fs-5"></i>
                                </div>
                                <div>
                                    <div class="fw-bold text-dark">${item.email}</div>
                                    <div class="text-muted small">Current Group: <span class="fw-bold text-dark">${item.groupId || 'None'}</span></div>
                                </div>
                            </div>
                            <div class="badge bg-light text-secondary border font-monospace">${item.id}</div>
                        </div>
                    `;
                },
                onSelect: async (item) => {
                    // Perform Add Action via AJAX
                    try {
                        const res = await fetch(`/subscription-groups/<%= group.id %>/members/add`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
                            body: JSON.stringify({ subscriptionId: item.id })
                        });
                        const result = await res.json();
                        
                        if (result.status === 'success') {
                            await showFeedback('success', 'Member Added', 'Subscriber successfully added to group.');
                            window.location.reload();
                        } else {
                            await showFeedback('error', 'Add Failed', result.message || 'Failed to add member.');
                        }
                    } catch (e) {
                        await showFeedback('error', 'Network Error', 'Could not connect to server.');
                    }
                }
             }));
        });
    }

    // --- REMOVE MEMBER ---
    document.querySelectorAll('.btn-remove-member').forEach(btn => {
        btn.addEventListener('click', async () => {
            const subId = btn.dataset.id;
            const email = btn.dataset.email;
            
            // Confirm Dialog
            if (!confirm(`Are you sure you want to remove ${email} from this group?`)) return;
            
            // Visual Feedback (Loading state)
            const originalContent = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

            try {
                const res = await fetch(`/subscription-groups/<%= group.id %>/members/remove`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
                    body: JSON.stringify({ subscriptionId: subId })
                });
                const result = await res.json();
                
                if (result.status === 'success') {
                    // No modal needed for quick actions usually, but consistent feedback requested
                    await showFeedback('success', 'Member Removed', 'Subscriber removed from group.');
                    window.location.reload();
                } else {
                    await showFeedback('error', 'Remove Failed', result.message || 'Failed to remove member.');
                    btn.disabled = false;
                    btn.innerHTML = originalContent;
                }
            } catch (e) {
                await showFeedback('error', 'Network Error', 'Could not connect to server.');
                btn.disabled = false;
                btn.innerHTML = originalContent;
            }
        });
    });

});
</script>
