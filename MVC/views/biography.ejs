<%
  const bioContact = (typeof appContact !== 'undefined' && appContact && typeof appContact === 'object') ? appContact : {};
  const cleanBioRows = (rows, valueKey, legacyRows = []) => {
    const source = Array.isArray(rows) ? rows : legacyRows;
    return source
      .map((row) => {
        const item = row && typeof row === 'object' ? row : {};
        const title = String(item.title || item.label || '').trim();
        const value = String(item[valueKey] || item.value || '').trim();
        return value ? { title, value } : null;
      })
      .filter(Boolean);
  };
  const bioEmails = cleanBioRows(bioContact.emails, 'email', bioContact.email ? [{ title: 'Email', email: bioContact.email }] : []);
  const bioPhones = cleanBioRows(bioContact.phones, 'number', bioContact.phone ? [{ title: 'Phone', number: bioContact.phone }] : []);
  const bioFaxes = cleanBioRows(bioContact.faxes, 'number', bioContact.fax ? [{ title: 'Fax', number: bioContact.fax }] : []);
  const bioAddresses = cleanBioRows(bioContact.addresses, 'address', bioContact.address ? [{ title: 'Address', address: bioContact.address }] : []);
  const bioEmail = bioEmails[0]?.value || '';
  const bioAddress = bioAddresses[0]?.value || '';
  const bioEmailHref = bioEmail ? `mailto:${encodeURIComponent(bioEmail)}` : '#';
  const bioContactRows = [
    ...bioEmails.map((row) => ({ label: row.title || 'Email', value: row.value })),
    ...bioPhones.map((row) => ({ label: row.title || 'Phone', value: row.value })),
    ...bioFaxes.map((row) => ({ label: row.title || 'Fax', value: row.value })),
    ...bioAddresses.map((row) => ({ label: row.title || 'Address', value: row.value }))
  ];
%>
