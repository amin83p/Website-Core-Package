<section class="pte-public-page home-pro home-pte-page">
  <% 
    const homePageContent = (typeof homeContent !== 'undefined' && homeContent && typeof homeContent === 'object') ? homeContent : {};
    const homeHero = homePageContent.hero || {};
    const homeHighlights = Array.isArray(homePageContent.highlights) ? homePageContent.highlights : [];
    const homeFeatureSection = homePageContent.featureSection || {};
    const homeFeatures = Array.isArray(homePageContent.features) ? homePageContent.features : [];
    const homeSolutions = homePageContent.solutions || {};
    const homeSolutionItems = Array.isArray(homeSolutions.items) ? homeSolutions.items : [];
    const homeServiceScope = homePageContent.serviceScope || {};
    const homeServiceTags = Array.isArray(homeServiceScope.tags) ? homeServiceScope.tags : [];
    const homeSupportCards = Array.isArray(homePageContent.supportCards) ? homePageContent.supportCards : [];
    const homeFinalCta = homePageContent.finalCta || {};
    const homeSlides = (typeof homeShowcaseItems !== 'undefined' && Array.isArray(homeShowcaseItems)) ? homeShowcaseItems : [];
  %>
  <section class="pte-hero-intro home-hero reveal" aria-labelledby="homeLandingTitle">
    <div class="pte-hero-orbit" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>

    <div class="pte-hero-copy">
      <div class="pte-eyebrow home-kicker"><%= homeHero.eyebrow || 'Integrated Systems + AI Automation' %></div>
      <h1 id="homeLandingTitle" class="home-title"><%= homeHero.title || 'We build integrated software systems that automate workflows and speed up execution.' %></h1>
      <p class="home-subtitle">
        <%= homeHero.subtitle || 'We provide engineering and software services for companies and individuals, with practical platforms that connect people, process, and data across education and industrial operations.' %>
      </p>

      <div class="pte-hero-actions">
        <a href="<%= homeHero.primaryHref || '/whatIOffer' %>" class="btn pte-btn-primary home-btn-main">
          <i class="bi bi-stars me-2"></i>
          <%= homeHero.primaryLabel || 'Explore Projects' %>
        </a>
        <a href="<%= homeHero.secondaryHref || '/about' %>" class="btn pte-btn-secondary home-btn-ghost">
          <i class="bi bi-person-workspace me-2"></i>
          <%= homeHero.secondaryLabel || 'How It Works' %>
        </a>
      </div>
    </div>

    <div class="pte-highlight-row home-stat-row" aria-label="Home page highlights">
      <%
        const homeHighlightIcons = ['bi-diagram-3-fill', 'bi-rocket-takeoff-fill', 'bi-shield-check', 'bi-lightning-charge-fill'];
        const homeHighlightTones = ['sky', 'emerald', 'amber', 'indigo'];
      %>
      <% homeHighlights.forEach((item, index) => { 
        const chipTone = homeHighlightTones[index % homeHighlightTones.length];
        const chipIcon = item.icon || homeHighlightIcons[index % homeHighlightIcons.length];
      %>
        <div class="pte-highlight-chip home-stat-chip tone-<%= chipTone %>">
          <div class="home-stat-icon" aria-hidden="true"><i class="bi <%= chipIcon %>"></i></div>
          <div class="home-stat-copy">
            <strong class="home-stat-value"><%= item.value %></strong>
            <span class="home-stat-label"><%= item.label %></span>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="pte-showcase-block home-showcase-block reveal delay-1" aria-label="Integrated systems image showcase">
    <div id="homeHeroSlide" class="carousel slide pte-showcase-carousel home-slide-carousel" data-bs-ride="carousel" data-bs-interval="4500">
      <div class="carousel-inner pte-showcase-inner">
        <% homeSlides.forEach((slide, i) => { %>
          <div class="carousel-item pte-showcase-item <%= i === 0 ? 'active' : '' %>">
            <img src="<%= slide.src %>" class="pte-showcase-image home-slide-image" alt="<%= slide.alt || ('Integrated systems slide ' + (i + 1)) %>">
            <% if (slide.title || slide.caption) { %>
              <div class="pte-image-caption home-slide-caption">
                <% if (slide.title) { %><span class="home-slide-caption-title"><%= slide.title %></span><% } %>
                <% if (slide.caption) { %><small><%= slide.caption %></small><% } %>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>

      <% if (homeSlides.length > 1) { %>
        <div class="pte-showcase-controls">
          <button type="button" class="pte-showcase-control-btn" data-bs-target="#homeHeroSlide" data-bs-slide="prev" aria-label="Previous slide">
            <i class="bi bi-chevron-left"></i>
            <span class="visually-hidden">Previous</span>
          </button>
          <button type="button" class="pte-showcase-control-btn" data-bs-target="#homeHeroSlide" data-bs-slide="next" aria-label="Next slide">
            <i class="bi bi-chevron-right"></i>
            <span class="visually-hidden">Next</span>
          </button>
        </div>
      <% } %>
    </div>
  </section>

  <section class="pte-section pte-feature-section home-feature-section reveal delay-1" aria-labelledby="homeFeaturesTitle">
    <div class="pte-section-heading">
      <span><%= homeFeatureSection.eyebrow || 'What Changes' %></span>
      <h2 id="homeFeaturesTitle"><%= homeFeatureSection.title || 'Everything is focused on practical systems, reliable automation, and execution speed.' %></h2>
      <p><%= homeFeatureSection.body || 'We start from real workflows, then build connected tools that teams can actually use every day.' %></p>
    </div>

    <div class="pte-feature-grid home-feature-grid">
      <% homeFeatures.forEach((feature) => { %>
        <article class="pte-feature-card home-card">
          <div class="pte-feature-icon home-icon <%= feature.tone || 'primary' %>"><i class="bi <%= feature.icon || 'bi-check2-circle' %>"></i></div>
          <h3><%= feature.title %></h3>
          <p><%= feature.body %></p>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="pte-section pte-info-section home-solutions-section reveal delay-2" aria-labelledby="homeSolutionsTitle">
    <div class="pte-info-main home-panel">
      <div class="pte-section-heading pte-section-heading-left">
        <span><%= homeSolutions.eyebrow || 'Core Solutions' %></span>
        <h2 id="homeSolutionsTitle" class="home-section-title"><%= homeSolutions.title || 'Systems we build and improve.' %></h2>
      </div>

      <div class="home-step-list pte-path-list">
        <% homeSolutionItems.forEach((item, index) => { %>
          <article class="home-step-item pte-path-item">
            <div class="home-step-no pte-path-step"><%= item.step || String(index + 1).padStart(2, '0') %></div>
            <div>
              <h3><%= item.title %></h3>
              <p><%= item.body %></p>
            </div>
          </article>
        <% }) %>
      </div>
    </div>

    <aside class="pte-info-side home-card" aria-label="Service scope">
      <div class="pte-section-heading pte-section-heading-left">
        <span><%= homeServiceScope.eyebrow || 'Service Scope' %></span>
        <h2 class="home-section-title"><%= homeServiceScope.title || 'Where this work fits.' %></h2>
      </div>
      <div class="home-tag-grid mb-3">
        <% homeServiceTags.forEach((tag) => { %>
          <span><%= tag %></span>
        <% }) %>
      </div>
      <div class="home-note-card pte-type-card">
        <div class="home-note-title"><%= homeServiceScope.noteTitle || 'Current Focus' %></div>
        <p class="mb-0">
          <%= homeServiceScope.noteBody || 'We are not currently developing a Review Manager product. Our focus is integrated academic and industrial automation systems.' %>
        </p>
      </div>
    </aside>
  </section>

  <section class="pte-section home-support-section reveal delay-2" aria-label="Support and contact options">
  <div class="row g-4 mb-4">
    <% homeSupportCards.forEach((card, index) => { %>
      <div class="col-lg-6 home-support-col">
        <div class="home-support-card home-support-card-<%= card.variant || 'service' %> h-100 reveal <%= index % 2 ? 'delay-3' : 'delay-2' %>">
          <div class="home-support-icon" aria-hidden="true">
            <i class="bi <%= card.icon || 'bi-gear-wide-connected' %>"></i>
          </div>
          <div class="home-support-body">
            <div class="home-support-kicker"><%= card.kicker || '' %></div>
            <h3 class="home-support-title"><%= card.title %></h3>
            <p class="home-support-text mb-0"><%= card.body %></p>
          </div>
          <div class="home-support-actions">
            <% if (card.variant === 'coffee') { %>
              <% if (typeof buyMeACoffeeQr !== 'undefined' && buyMeACoffeeQr && card.primaryLabel) { %>
                <button type="button"
                        class="btn btn-light fw-semibold home-support-btn"
                        data-bs-toggle="modal"
                        data-bs-target="#homeCoffeeQrModal"
                        aria-label="Show Buy Me a Coffee QR code">
                  <%= card.primaryLabel %>
                  <i class="bi bi-qr-code-scan ms-1"></i>
                </button>
              <% } %>
              <% if (card.secondaryHref && card.secondaryLabel) { %>
                <a class="home-support-btn-ghost"
                   href="<%= card.secondaryHref %>"
                   target="_blank"
                   rel="noopener noreferrer">
                  <%= card.secondaryLabel %>
                </a>
              <% } %>
            <% } else if (card.primaryHref && card.primaryLabel) { %>
              <a class="btn btn-light fw-semibold home-support-btn"
                 href="<%= card.primaryHref %>">
                <%= card.primaryLabel %>
                <i class="bi bi-arrow-up-right ms-1"></i>
              </a>
            <% } %>
            <% if (card.subtext) { %><div class="home-support-subtext"><%= card.subtext %></div><% } %>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
  </section>

  <% if (typeof buyMeACoffeeQr !== 'undefined' && buyMeACoffeeQr) { %>
    <div class="modal fade" id="homeCoffeeQrModal" tabindex="-1" aria-labelledby="homeCoffeeQrModalLabel" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content home-coffee-modal">
          <div class="modal-header">
            <h5 class="modal-title" id="homeCoffeeQrModalLabel">Buy Me a Coffee</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body text-center">
            <img src="<%= buyMeACoffeeQr %>" alt="Buy Me a Coffee QR code" class="home-coffee-qr-image">
          </div>
          <div class="modal-footer">
            <a class="btn btn-primary"
               href="https://www.buymeacoffee.com/paknejad"
               target="_blank"
               rel="noopener noreferrer">
              Open Page
            </a>
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
          </div>
        </div>
      </div>
    </div>
  <% } %>

  <section class="pte-final-cta home-cta reveal delay-3" aria-labelledby="homeFinalCtaTitle">
    <div>
      <span><%= homeFinalCta.eyebrow || 'Start The Next Build' %></span>
      <h2 id="homeFinalCtaTitle"><%= homeFinalCta.title || 'Ready to automate and scale your operations?' %></h2>
      <p><%= homeFinalCta.body || 'Adopt integrated systems for education, assessment, and industry.' %></p>
    </div>
    <div class="pte-final-actions">
      <% if (typeof user !== 'undefined' && user) { %>
        <a href="<%= homeFinalCta.signedInPrimaryHref || '/dashboard' %>" class="btn pte-btn-light">
          <i class="bi bi-speedometer2 me-2"></i><%= homeFinalCta.signedInPrimaryLabel || 'Open Dashboard' %>
        </a>
      <% } else { %>
        <a href="<%= homeFinalCta.guestPrimaryHref || '/login' %>" class="btn pte-btn-light">
          <i class="bi bi-box-arrow-in-right me-2"></i><%= homeFinalCta.guestPrimaryLabel || 'Sign In' %>
        </a>
        <a href="<%= homeFinalCta.guestSecondaryHref || '/persons/join' %>" class="btn pte-btn-outline-light"><%= homeFinalCta.guestSecondaryLabel || 'Create Account' %></a>
      <% } %>
      <a href="<%= homeFinalCta.contactHref || '/contact' %>" class="btn pte-btn-outline-light">
        <i class="bi bi-chat-dots me-2"></i><%= homeFinalCta.contactLabel || 'Talk to Our Team' %>
      </a>
    </div>
  </section>
</section>

<style>
@import url('https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap');

html.home-public-root,
html.home-public-root body.home-public-body {
  background:
    radial-gradient(circle at 7% 7%, rgba(10, 102, 194, 0.15), transparent 28%),
    radial-gradient(circle at 93% 4%, rgba(37, 136, 114, 0.14), transparent 26%),
    radial-gradient(circle at 8% 48%, rgba(180, 91, 43, 0.08), transparent 25%),
    radial-gradient(circle at 91% 76%, rgba(10, 102, 194, 0.1), transparent 28%),
    linear-gradient(135deg, #f8fbff 0%, #eef7f4 50%, #ffffff 100%);
  min-height: 100%;
}

body.home-public-body {
  background-attachment: fixed;
}

main.home-public-main {
  margin-bottom: 0 !important;
  margin-top: 0 !important;
  padding-bottom: clamp(2.2rem, 5vw, 4.5rem);
  padding-top: 0;
  position: relative;
}

.home-pro {
  --home-primary: #0a66c2;
  --home-primary-dark: #094d92;
  --home-ink: #17223b;
  --home-muted: #5c687d;
  --home-border: #dbe3ee;
  --home-surface: #ffffff;
  --home-soft: #f4f8fc;

  font-family: 'Manrope', 'Segoe UI', sans-serif;
  isolation: isolate;
  padding-top: clamp(1.25rem, 3vw, 2.4rem);
  position: relative;
}

.home-pro::before {
  background:
    radial-gradient(circle at 7% 7%, rgba(10, 102, 194, 0.15), transparent 28%),
    radial-gradient(circle at 93% 4%, rgba(37, 136, 114, 0.14), transparent 26%),
    radial-gradient(circle at 8% 48%, rgba(180, 91, 43, 0.08), transparent 25%),
    radial-gradient(circle at 91% 76%, rgba(10, 102, 194, 0.1), transparent 28%),
    linear-gradient(135deg, #f8fbff 0%, #eef7f4 50%, #ffffff 100%);
  bottom: calc(-1 * clamp(2.2rem, 5vw, 4.5rem));
  content: "";
  left: 50%;
  pointer-events: none;
  position: absolute;
  top: 0;
  transform: translateX(-50%);
  width: 100vw;
  z-index: -1;
}

.home-pro .reveal {
  opacity: 0;
  transform: translateY(14px);
  animation: homeFadeUp 0.55s ease forwards;
}

.home-pro .delay-1 { animation-delay: 0.1s; }
.home-pro .delay-2 { animation-delay: 0.2s; }
.home-pro .delay-3 { animation-delay: 0.3s; }

.home-pro .home-hero {
  background:
    radial-gradient(circle at 76% 3%, rgba(10, 102, 194, 0.12), transparent 36%),
    radial-gradient(circle at 12% 88%, rgba(37, 136, 114, 0.1), transparent 34%);
  border: 0;
  border-radius: 0;
  box-shadow: none;
  margin-bottom: clamp(1.5rem, 3vw, 2.2rem);
  padding: clamp(1.5rem, 3.5vw, 3rem) 0 clamp(1.3rem, 3vw, 2.4rem);
  position: relative;
}

.home-pro .home-kicker {
  display: inline-flex;
  align-items: center;
  gap: 0.45rem;
  font-size: 0.78rem;
  font-weight: 700;
  letter-spacing: 0;
  text-transform: uppercase;
  color: var(--home-primary-dark);
  background: rgba(10, 102, 194, 0.08);
  border: 1px solid rgba(10, 102, 194, 0.2);
  border-radius: 999px;
  padding: 0.42rem 0.82rem;
  margin-bottom: 1rem;
}

.home-pro .home-title {
  font-size: clamp(1.95rem, 4vw, 3.1rem);
  line-height: 1.1;
  font-weight: 800;
  color: var(--home-ink);
  max-width: 780px;
  margin-bottom: 1rem;
}

.home-pro .home-subtitle {
  font-size: 1.08rem;
  color: var(--home-muted);
  line-height: 1.65;
  max-width: 760px;
  margin-bottom: 1.25rem;
}

.home-pro .home-btn-main,
.home-pro .home-btn-ghost {
  border-radius: 12px;
  padding: 0.56rem 1rem;
  font-weight: 600;
}

.home-pro .home-stat-row {
  display: flex;
  flex-wrap: wrap;
  gap: 0.55rem;
}

.home-pro .home-stat-chip {
  background: var(--home-surface);
  border: 1px solid var(--home-border);
  border-radius: 12px;
  padding: 0.65rem 0.8rem;
  min-width: 130px;
}

.home-pro .home-stat-value {
  display: block;
  font-size: 0.9rem;
  font-weight: 700;
  color: var(--home-ink);
}

.home-pro .home-stat-label {
  display: block;
  font-size: 0.74rem;
  color: var(--home-muted);
}

.home-pro .home-panel,
.home-pro .home-card {
  background: var(--home-surface);
  border: 1px solid var(--home-border);
  border-radius: 18px;
  box-shadow: 0 10px 28px rgba(18, 44, 74, 0.07);
  padding: 1.15rem 1.2rem;
}

.home-pro .home-panel-title,
.home-pro .home-section-title {
  color: var(--home-ink);
  font-weight: 750;
  margin-bottom: 0.95rem;
}

.home-pro .home-panel-title {
  font-size: 0.98rem;
  text-transform: uppercase;
  letter-spacing: 0;
  color: #32567f;
}

.home-pro .home-score-item {
  margin-bottom: 0.75rem;
}

.home-pro .home-score-item span {
  display: block;
  color: var(--home-ink);
  font-size: 0.88rem;
  font-weight: 600;
  margin-bottom: 0.3rem;
}

.home-pro .home-progress {
  height: 0.52rem;
  border-radius: 20px;
  background: #e6edf7;
}

.home-pro .home-progress .progress-bar {
  border-radius: 20px;
  background: linear-gradient(90deg, #1c77d8, #4fa6ff);
}

.home-pro .home-panel-note {
  color: var(--home-muted);
  font-size: 0.87rem;
}

.home-pro .home-slide-card {
  position: relative;
  border: 1px solid var(--home-border);
  border-radius: 18px;
  overflow: hidden;
  background: #0f243d;
  box-shadow: 0 12px 30px rgba(18, 44, 74, 0.18);
}

.home-pro .home-slide-carousel {
  border-radius: 18px 18px 0 0;
  overflow: hidden;
}

.home-pro .home-slide-image {
  height: 345px;
  object-fit: cover;
  filter: brightness(0.78);
}

.home-pro .home-slide-card .carousel-indicators {
  margin-bottom: 0.55rem;
}

.home-pro .home-slide-card .carousel-indicators [data-bs-target] {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  border: 0;
}

.home-pro .home-slide-card .carousel-control-prev,
.home-pro .home-slide-card .carousel-control-next {
  width: 36px;
  height: 36px;
  top: 50%;
  transform: translateY(-50%);
  border-radius: 50%;
  background: rgba(9, 22, 38, 0.45);
  margin: 0 0.55rem;
}

.home-pro .home-slide-card .carousel-control-prev-icon,
.home-pro .home-slide-card .carousel-control-next-icon {
  width: 1rem;
  height: 1rem;
}

.home-pro .home-slide-caption {
  padding: 0.75rem 0.9rem 0.95rem 0.9rem;
  color: #e8f0fc;
  background: linear-gradient(180deg, rgba(15, 36, 61, 0.95), rgba(10, 31, 52, 1));
}

.home-pro .home-slide-caption-title {
  font-size: 0.9rem;
  font-weight: 700;
  margin-bottom: 0.2rem;
}

.home-pro .home-slide-caption p {
  font-size: 0.79rem;
  line-height: 1.4;
  color: #b7c7de;
}

.home-pro .home-card h3 {
  font-size: 1.1rem;
  color: var(--home-ink);
  font-weight: 750;
  margin-bottom: 0.45rem;
}

.home-pro .home-card p {
  color: var(--home-muted);
  margin-bottom: 0;
  line-height: 1.6;
}

.home-pro .home-icon {
  width: 44px;
  height: 44px;
  border-radius: 12px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 0.85rem;
  font-size: 1.15rem;
}

.home-pro .home-icon.primary { background: rgba(10, 102, 194, 0.12); color: #0a66c2; }
.home-pro .home-icon.success { background: rgba(41, 147, 75, 0.12); color: #1f7f3f; }
.home-pro .home-icon.danger { background: rgba(213, 68, 58, 0.13); color: #bf3f34; }

.home-pro .home-step-list {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.home-pro .home-step-item {
  display: flex;
  gap: 0.8rem;
  border: 1px solid #e2e9f3;
  border-radius: 14px;
  padding: 0.85rem 0.9rem;
  background: linear-gradient(180deg, #ffffff, #f9fcff);
}

.home-pro .home-step-no {
  width: 38px;
  height: 38px;
  border-radius: 10px;
  background: rgba(10, 102, 194, 0.13);
  color: var(--home-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-weight: 750;
  font-size: 0.82rem;
  flex: 0 0 auto;
}

.home-pro .home-step-item h4 {
  font-size: 0.97rem;
  margin: 0 0 0.2rem 0;
  color: var(--home-ink);
  font-weight: 700;
}

.home-pro .home-step-item p {
  margin: 0;
  font-size: 0.88rem;
  color: var(--home-muted);
}

.home-pro .home-tag-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 0.45rem;
}

.home-pro .home-tag-grid span {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #d7e0ec;
  border-radius: 10px;
  background: var(--home-soft);
  color: #2e4668;
  font-size: 0.8rem;
  font-weight: 650;
  padding: 0.38rem 0.55rem;
}

.home-pro .home-note-card {
  background: linear-gradient(140deg, #f8fbff, #eef5fc);
  border: 1px solid #dbe7f4;
  border-radius: 12px;
  padding: 0.75rem 0.82rem;
}

.home-pro .home-note-title {
  color: var(--home-primary-dark);
  font-size: 0.8rem;
  text-transform: uppercase;
  font-weight: 700;
  letter-spacing: 0;
  margin-bottom: 0.35rem;
}

.home-pro .home-support-col {
  display: flex;
}

.home-pro .home-support-col .home-support-card {
  width: 100%;
}

.home-pro .home-support-card {
  position: relative;
  border-radius: 20px;
  padding: 1.25rem 1.2rem;
  border: 1px solid rgba(10, 102, 194, 0.25);
  background:
    radial-gradient(circle at 12% 18%, rgba(255, 193, 7, 0.22), transparent 42%),
    radial-gradient(circle at 88% 20%, rgba(10, 102, 194, 0.16), transparent 50%),
    linear-gradient(135deg, #0f3052, #0a66c2);
  color: #ffffff;
  box-shadow: 0 16px 38px rgba(10, 49, 88, 0.22);
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 1rem;
  align-items: center;
  margin-bottom: 0;
  transition: box-shadow 0.22s ease, border-color 0.22s ease;
}

.home-pro .home-support-card:hover,
.home-pro .home-support-card:focus-within {
