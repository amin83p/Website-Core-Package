<%
  const row = session && typeof session === 'object' ? session : {};
  const itemRows = Array.isArray(items) ? items : [];
  const mockExam = row?.metadata?.mockExam && typeof row.metadata.mockExam === 'object' ? row.metadata.mockExam : {};
  const scoredCount = itemRows.filter((item) => ['scored', 'feedback_provided'].includes(String(item?.status || '').toLowerCase())).length;
  const submittedCount = itemRows.filter((item) => ['submitted', 'auto_submitted', 'scored', 'feedback_provided'].includes(String(item?.status || '').toLowerCase())).length;
%>

<div class="sections-page">
  <div class="card border-0 shadow-sm">
    <div class="card-body p-4">
      <div class="d-flex align-items-start justify-content-between flex-wrap gap-3">
        <div>
          <h1 class="page-heading size-md m-0"><i class="bi bi-check2-circle me-2 text-success"></i>PTE Mock Exam Complete</h1>
          <div class="text-muted mt-2">
            <%= mockExam.testTitle || 'PTE Mock Exam' %>
            <% if (mockExam.testCode) { %>
              | <span class="font-monospace"><%= mockExam.testCode %></span>
            <% } %>
          </div>
        </div>
        <span class="badge bg-success-subtle text-success-emphasis border">Finished</span>
      </div>

      <hr>

      <div class="row g-3 mb-3">
        <div class="col-12 col-md-4">
          <div class="border rounded p-3 bg-light-subtle">
            <div class="small text-muted">Session</div>
            <div class="fw-bold font-monospace"><%= row.id || '-' %></div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="border rounded p-3 bg-light-subtle">
            <div class="small text-muted">Submitted Items</div>
            <div class="fw-bold"><%= submittedCount %> / <%= itemRows.length %></div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="border rounded p-3 bg-light-subtle">
            <div class="small text-muted">Scoring Progress</div>
            <div class="fw-bold"><%= scoredCount %> / <%= itemRows.length %></div>
          </div>
        </div>
      </div>

      <div class="alert alert-info">
        Your exam has been submitted. Scoring runs in the background, so provider issues will not block the final submission.
      </div>

      <div class="d-flex align-items-center justify-content-end flex-wrap gap-2">
        <a href="/pte/practice/mock-exams" class="btn btn-outline-secondary">
          <i class="bi bi-list me-1"></i> Mock Exams
        </a>
        <a href="/pte/practice/attempts/<%= encodeURIComponent(row.id || '') %>/details" class="btn btn-filled btn-primary">
          View Attempt Details <i class="bi bi-arrow-right ms-1"></i>
        </a>
      </div>
    </div>
  </div>
</div>
