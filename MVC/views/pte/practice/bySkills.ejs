<%
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const data = (overview && typeof overview === 'object') ? overview : {};
  const skillRows = Array.isArray(data.skills) ? data.skills : [];
  const analytics = (data.analytics && typeof data.analytics === 'object') ? data.analytics : null;
  const recentSessions = Array.isArray(data.recentSessions) ? data.recentSessions : [];
  const formatQuestionTypeLabel = (value) => String(value || '')
    .trim()
    .toLowerCase()
    .split('_')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
  const formatSkillLabel = (value) => {
    const token = String(value || '').trim().toLowerCase();
    if (!token) return '-';
    return token.charAt(0).toUpperCase() + token.slice(1);
  };
%>

<div class="sections-page">
  <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3 pte-practice-page-head">
    <div class="pte-practice-page-title-wrap">
      <h1 class="page-heading size-md m-0 pte-practice-page-title"><i class="bi bi-bullseye me-2"></i>PTE Practice By Skills</h1>
      <div class="text-muted mt-2">Choose a skill, set question counts by type, and run flexible practice without forced answers.</div>
    </div>
    <div class="d-flex flex-column align-items-end gap-2">
      <a href="<%= dashboardHref %>" class="btn btn-filled btn-secondary btn-md">
        <i class="bi bi-speedometer2 me-1"></i> PTE Dashboard
      </a>
      <a href="/pte/practice/attempts" class="btn btn-outline-secondary btn-md">
        <i class="bi bi-grid-3x3-gap me-1"></i> Practice Attempts
      </a>
    </div>
  </div>

  <script id="ptePracticeOverviewJson" type="application/json"><%- JSON.stringify(data || {}).replace(/</g, '\\u003c') %></script>
  <input type="hidden" id="ptePracticeActionStateId" value="<%= actionStateId || '' %>">

  <style>
    .pte-practice-page-head {
      width: 100%;
      margin-left: 0 !important;
      padding-left: 0 !important;
      text-align: left !important;
    }
    .pte-practice-page-title-wrap {
      flex: 1 1 auto;
      min-width: 280px;
      margin-left: 0 !important;
      padding-left: 0 !important;
      text-align: left !important;
    }
    .pte-practice-page-title {
      text-align: left !important;
      margin-left: 0 !important;
      padding-left: 0 !important;
    }
    .pte-practice-simple-skill-btn {
      border: 1px solid #d9e1eb;
      border-radius: 0.7rem;
      background: #fff;
      padding: 0.65rem 0.75rem;
      text-align: left;
      transition: border-color .15s ease, background-color .15s ease, box-shadow .15s ease;
    }
    .pte-practice-simple-skill-btn:hover {
      border-color: #bfd0e5;
      box-shadow: 0 0.25rem 0.8rem rgba(10, 38, 69, 0.08);
    }
    .pte-practice-simple-skill-btn.is-selected {
      border-color: #0d6efd;
      background: #edf4ff;
      box-shadow: 0 0.35rem 1rem rgba(13, 110, 253, 0.15);
    }
    .pte-practice-plan-skill + .pte-practice-plan-skill {
      border-top: 1px solid #e9edf3;
      margin-top: 0.9rem;
      padding-top: 0.9rem;
    }
    .pte-practice-type-row {
      border-bottom: 1px solid #f0f3f7;
      padding: 0.45rem 0;
    }
    .pte-practice-type-row:last-child {
      border-bottom: 0;
    }
    .pte-practice-plan-box {
      min-height: 280px;
      border: 1px solid #dfe5ee;
      border-radius: 0.75rem;
      background: #fff;
      padding: 0.85rem;
    }
    .pte-practice-empty {
      color: #6c757d;
      font-size: 0.95rem;
      border: 1px dashed #d5dde8;
      border-radius: 0.6rem;
      padding: 1rem;
      background: #fbfcfe;
    }
    .pte-collapsible-trigger {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 700;
      color: inherit;
      text-decoration: none;
      border: 0;
      background: transparent;
      padding: 0;
    }
    .pte-collapsible-trigger .pte-chevron {
      transition: transform .18s ease;
    }
    .pte-collapsible-trigger[aria-expanded="false"] .pte-chevron {
      transform: rotate(-90deg);
    }
    .pte-practice-wizard-steps {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 0.95rem;
    }
    .pte-practice-wizard-step {
      border: 1px solid #d9e1eb;
      border-radius: 999px;
      background: #f8fafc;
      color: #475569;
      padding: 0.26rem 0.62rem;
      font-size: 0.82rem;
      font-weight: 700;
    }
    .pte-practice-wizard-step.is-active {
      border-color: #0d6efd;
      background: #e9f1ff;
      color: #0b4cb8;
    }
    .pte-practice-wizard-pane.is-hidden {
      display: none;
    }
    .pte-practice-summary-box {
      min-height: 220px;
      border: 1px solid #dfe5ee;
      border-radius: 0.75rem;
      background: #fff;
      padding: 0.85rem;
    }
    .pte-practice-summary-skill + .pte-practice-summary-skill {
      border-top: 1px solid #eef2f7;
      margin-top: 0.75rem;
      padding-top: 0.75rem;
    }
  </style>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
      <div class="pte-practice-wizard-steps">
        <span class="pte-practice-wizard-step is-active" data-wizard-step-indicator="1">Step 1: Skills</span>
        <span class="pte-practice-wizard-step" data-wizard-step-indicator="2">Step 2: Question Counts</span>
        <span class="pte-practice-wizard-step" data-wizard-step-indicator="3">Step 3: Summary</span>
        <span class="pte-practice-wizard-step" data-wizard-step-indicator="4">Step 4: Name & Start</span>
      </div>

      <div id="ptePracticeWizardStep1" class="pte-practice-wizard-pane">
        <div class="fw-bold mb-2">Step 1: Select One or More Skills</div>
        <% if (!skillRows.length) { %>
          <div class="alert alert-warning mb-0">No published practice-enabled questions are available for your current organization scope.</div>
        <% } else { %>
          <div id="ptePracticeSkillButtons" class="d-grid gap-2">
            <% skillRows.forEach((row) => { %>
              <% const rowTypeRows = Array.isArray(row.questionTypes) ? row.questionTypes : []; %>
              <% const fallbackQuestionCount = rowTypeRows.reduce((sum, typeRow) => sum + (Number(typeRow?.count || 0) || 0), 0); %>
              <% const displayQuestionCount = Number(row.availableQuestionCount || fallbackQuestionCount || 0) || 0; %>
              <% const displayTypeCount = Number(row.availableQuestionTypes || rowTypeRows.length || 0) || 0; %>
              <button
                type="button"
                class="pte-practice-simple-skill-btn"
                data-skill="<%= row.skill %>"
                data-no-wait="true">
                <div class="d-flex align-items-center justify-content-between gap-2">
                  <div class="fw-bold text-capitalize"><%= formatSkillLabel(row.skill) %></div>
                  <span class="badge bg-primary-subtle text-primary border border-primary-subtle"><%= displayQuestionCount %> Questions</span>
                </div>
                <div class="small text-muted mt-1"><%= displayTypeCount %> question types available</div>
              </button>
            <% }) %>
          </div>
        <% } %>
        <div class="d-flex justify-content-end mt-3">
          <button type="button" class="btn btn-filled btn-primary btn-md" id="ptePracticeStep1NextBtn">
            Next <i class="bi bi-arrow-right ms-1"></i>
          </button>
        </div>
      </div>

      <div id="ptePracticeWizardStep2" class="pte-practice-wizard-pane is-hidden">
        <div class="fw-bold mb-2">Step 2: Set Question Counts Per Type</div>
        <div id="ptePracticePlanBox" class="pte-practice-plan-box">
          <div class="pte-practice-empty">Select at least one skill to configure your practice plan.</div>
        </div>
        <div id="ptePracticePlanTotals" class="small text-muted mt-2">No skills selected yet.</div>
        <div class="small text-muted mt-1">Maximum allowed per practice: <strong>15 questions</strong>.</div>
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-3">
          <button type="button" class="btn btn-outline-secondary btn-md" id="ptePracticeStep2PrevBtn">
            <i class="bi bi-arrow-left me-1"></i> Previous
          </button>
          <button type="button" class="btn btn-filled btn-primary btn-md" id="ptePracticeStep2NextBtn">
            Next <i class="bi bi-arrow-right ms-1"></i>
          </button>
        </div>
      </div>

      <div id="ptePracticeWizardStep3" class="pte-practice-wizard-pane is-hidden">
        <div class="fw-bold mb-2">Step 3: Review Plan</div>
        <div id="ptePracticeSummaryBox" class="pte-practice-summary-box">
          <div class="pte-practice-empty">Your selected question plan will appear here.</div>
        </div>
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-3">
          <button type="button" class="btn btn-outline-secondary btn-md" id="ptePracticeStep3PrevBtn">
            <i class="bi bi-arrow-left me-1"></i> Previous
          </button>
          <button type="button" class="btn btn-filled btn-primary btn-md" id="ptePracticeStep3NextBtn">
            Next <i class="bi bi-arrow-right ms-1"></i>
          </button>
        </div>
      </div>

      <div id="ptePracticeWizardStep4" class="pte-practice-wizard-pane is-hidden">
        <div class="fw-bold mb-2">Step 4: Name and Start</div>
        <div class="mb-3">
          <label for="ptePracticeNameInput" class="form-label fw-bold mb-1">Practice Name *</label>
          <input
            type="text"
            id="ptePracticeNameInput"
            class="form-control size-md"
            maxlength="120"
            placeholder="e.g. Speaking Drill - May 2026"
            autocomplete="off">
          <div class="form-text">Give this practice a clear name so you can find it quickly later.</div>
        </div>
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-3">
          <button type="button" class="btn btn-outline-secondary btn-md" id="ptePracticeStep4PrevBtn">
            <i class="bi bi-arrow-left me-1"></i> Previous
          </button>
          <button type="button" class="btn btn-filled btn-primary btn-md" id="ptePracticeStartBtn">
            <i class="bi bi-play-circle me-1"></i> Start Practice
          </button>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
            <button
              type="button"
              class="pte-collapsible-trigger collapsed"
              data-bs-toggle="collapse"
              data-bs-target="#ptePerformanceSnapshotCollapse"
              aria-expanded="false"
              aria-controls="ptePerformanceSnapshotCollapse">
              <i class="bi bi-chevron-down pte-chevron"></i>
              <span><i class="bi bi-graph-up-arrow me-2"></i>Performance Snapshot</span>
            </button>
          </div>
          <div id="ptePerformanceSnapshotCollapse" class="collapse">
            <% if (!analytics) { %>
              <div class="text-muted">No analytics data available yet for the active learner scope.</div>
            <% } else { %>
              <div class="row g-2 mb-3">
                <div class="col-sm-6 col-lg-3">
                  <div class="border rounded p-2 bg-light">
                    <div class="small text-muted">Average Score</div>
                    <div class="fw-bold"><%= Number(analytics.summary?.averagePercentage || 0).toFixed(2) %>%</div>
                  </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                  <div class="border rounded p-2 bg-light">
                    <div class="small text-muted">Average Time</div>
                    <div class="fw-bold"><%= Number(analytics.summary?.averageTimeSeconds || 0).toFixed(2) %> sec</div>
                  </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                  <div class="border rounded p-2 bg-light">
                    <div class="small text-muted">Accuracy</div>
                    <div class="fw-bold"><%= Number(analytics.summary?.accuracyPercentage || 0).toFixed(2) %>%</div>
                  </div>
                </div>
                <div class="col-sm-6 col-lg-3">
                  <div class="border rounded p-2 bg-light">
                    <div class="small text-muted">Submitted Items</div>
                    <div class="fw-bold"><%= Number(analytics.summary?.submittedCount || 0) %> / <%= Number(analytics.summary?.totalItems || 0) %></div>
                  </div>
                </div>
              </div>
              <div class="mb-2 fw-bold">Skill Distribution</div>
              <% (Array.isArray(analytics.bySkill) ? analytics.bySkill : []).forEach((row) => { %>
                <% const pct = Math.max(0, Math.min(100, Number(row.averagePercentage || 0))); %>
                <div class="mb-2">
                  <div class="d-flex align-items-center justify-content-between small">
                    <span class="text-capitalize"><%= row.skill %></span>
                    <span><%= Number(row.averagePercentage || 0).toFixed(2) %>%</span>
                  </div>
                  <div class="progress" style="height: 8px;">
                    <div class="progress-bar" role="progressbar" style="width: <%= pct %>%;" aria-valuenow="<%= pct %>" aria-valuemin="0" aria-valuemax="100"></div>
                  </div>
                </div>
              <% }) %>
            <% } %>
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
            <button
              type="button"
              class="pte-collapsible-trigger collapsed"
              data-bs-toggle="collapse"
              data-bs-target="#pteRecentSessionsCollapse"
              aria-expanded="false"
              aria-controls="pteRecentSessionsCollapse">
              <i class="bi bi-chevron-down pte-chevron"></i>
              <span><i class="bi bi-clock-history me-2"></i>Recent Skill Practice Sessions</span>
            </button>
          </div>
          <div id="pteRecentSessionsCollapse" class="collapse">
            <div class="table-responsive">
              <table class="table table-sm align-middle">
                <thead>
                  <tr>
                    <th>Session</th>
                    <th>Status</th>
                    <th>Questions</th>
                    <th>Score</th>
                    <th>Started</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!recentSessions.length) { %>
                    <tr><td colspan="5" class="text-center text-muted py-3">No skill-practice sessions yet.</td></tr>
                  <% } %>
                  <% recentSessions.forEach((row) => { %>
                    <tr>
                      <td>
                        <% if (row.practiceName) { %>
                          <div class="small fw-bold text-dark">
                            <a href="/pte/practice/session/<%= encodeURIComponent(row.id) %>"><%= row.practiceName %></a>
                          </div>
                        <% } %>
                        <div class="x-small text-muted font-monospace mt-1"><%= row.id || '-' %></div>
                      </td>
                      <td class="text-capitalize"><%= row.status || '-' %></td>
                      <td><%= Number(row.submittedQuestions || 0) %> / <%= Number(row.totalQuestions || 0) %></td>
                      <td><%= Number(row.percentage || 0).toFixed(2) %>%</td>
                      <td><%= row.startedAt ? new Date(row.startedAt).toLocaleString() : '-' %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(() => {
  const overview = (() => {
    try {
      const node = document.getElementById('ptePracticeOverviewJson');
      return JSON.parse((node && node.textContent) || '{}');
    } catch (_) {
      return {};
    }
  })();

  const skillRows = Array.isArray(overview.skills) ? overview.skills : [];
  const skillMap = new Map(skillRows.map((row) => [String(row.skill || '').trim().toLowerCase(), row]));
  const skillButtons = Array.from(document.querySelectorAll('[data-skill]'));
  const stepIndicators = Array.from(document.querySelectorAll('[data-wizard-step-indicator]'));
  const step1Pane = document.getElementById('ptePracticeWizardStep1');
  const step2Pane = document.getElementById('ptePracticeWizardStep2');
  const step3Pane = document.getElementById('ptePracticeWizardStep3');
  const step4Pane = document.getElementById('ptePracticeWizardStep4');
  const step1NextBtn = document.getElementById('ptePracticeStep1NextBtn');
  const step2PrevBtn = document.getElementById('ptePracticeStep2PrevBtn');
  const step2NextBtn = document.getElementById('ptePracticeStep2NextBtn');
  const step3PrevBtn = document.getElementById('ptePracticeStep3PrevBtn');
  const step3NextBtn = document.getElementById('ptePracticeStep3NextBtn');
  const step4PrevBtn = document.getElementById('ptePracticeStep4PrevBtn');
  const planBox = document.getElementById('ptePracticePlanBox');
  const planTotals = document.getElementById('ptePracticePlanTotals');
  const summaryBox = document.getElementById('ptePracticeSummaryBox');
  const startBtn = document.getElementById('ptePracticeStartBtn');
  const practiceNameInput = document.getElementById('ptePracticeNameInput');
  const MAX_PRACTICE_QUESTIONS = 15;
  const MAX_PRACTICE_NAME_LENGTH = 120;

  const state = {
    selectedSkills: new Map(),
    currentStep: 1,
    limitWarningVisible: false
  };
  const normalizeNumber = (value, fallback = 0) => {
    const out = Number(value);
    return Number.isFinite(out) ? out : Number(fallback || 0);
  };

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function showMessage(title, message, icon = 'info') {
    if (typeof window.showMessageModal === 'function') {
      return window.showMessageModal({
        title,
        message,
        icon,
        buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : 'btn-primary' }]
      });
    }
    return Promise.resolve();
  }

  async function requestRuntimeStartActionStateId() {
    const response = await fetch('/pte/practice/api/runtime/start/token', {
      method: 'POST',
      headers: {
        'X-AJAX-Request': 'true',
        Accept: 'application/json'
      },
      credentials: 'include'
    });
    const result = await response.json().catch(() => null);
    const runtimeActionStateId = String(result?.results?.actionStateId || '').trim();
    if (!response.ok || !result || result.status !== 'success' || !runtimeActionStateId) {
      throw new Error((result && result.message) || ('Failed to prepare secure start session (status ' + response.status + ').'));
    }
    return runtimeActionStateId;
  }

  function formatSkillLabel(value) {
    const token = String(value || '').trim().toLowerCase();
    if (!token) return '-';
    return token.charAt(0).toUpperCase() + token.slice(1);
  }

  function formatQuestionTypeLabel(value) {
    return String(value || '')
      .trim()
      .toLowerCase()
      .split('_')
      .filter(Boolean)
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(' ');
  }

  function sanitizePracticeName(value, { trimEdges = true } = {}) {
    const token = String(value || '').replace(/\0/g, '');
    const clipped = token.length > MAX_PRACTICE_NAME_LENGTH
      ? token.slice(0, MAX_PRACTICE_NAME_LENGTH)
      : token;
    if (!trimEdges) return clipped;
    return clipped.trim();
  }

  function getDayPeriod(hour) {
    const safeHour = Number.isFinite(hour) ? hour : 12;
    if (safeHour < 12) return 'morning';
    if (safeHour < 17) return 'afternoon';
    if (safeHour < 21) return 'evening';
    return 'night';
  }

  function buildSuggestedPracticeName(now = new Date()) {
    const weekday = now.toLocaleDateString(undefined, { weekday: 'long' });
    const hour = String(now.getHours()).padStart(2, '0');
    return sanitizePracticeName(weekday + ' ' + getDayPeriod(now.getHours()) + ' at ' + hour);
  }

  function ensureSuggestedPracticeName() {
    if (!(practiceNameInput instanceof HTMLInputElement)) return;
    const current = sanitizePracticeName(practiceNameInput.value);
    if (current) return;
    practiceNameInput.value = buildSuggestedPracticeName(new Date());
  }

  function normalizeCount(value, maxValue) {
    const parsed = Number.parseInt(String(value || '').trim(), 10);
    const max = Math.max(1, Number(maxValue || 1));
    if (!Number.isFinite(parsed) || parsed < 1) return 1;
    return Math.max(1, Math.min(max, parsed));
  }

  function setBusy(button, busy, label = 'Working...') {
    if (!button) return;
    if (busy) {
      button.dataset.originalHtml = button.innerHTML;
      button.disabled = true;
      button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + label;
      return;
    }
    button.disabled = false;
    if (button.dataset.originalHtml) button.innerHTML = button.dataset.originalHtml;
  }

  function setWizardStep(stepNumber = 1) {
    const nextStep = Math.max(1, Math.min(4, Number(stepNumber) || 1));
    state.currentStep = nextStep;
    if (step1Pane) step1Pane.classList.toggle('is-hidden', nextStep !== 1);
    if (step2Pane) step2Pane.classList.toggle('is-hidden', nextStep !== 2);
    if (step3Pane) step3Pane.classList.toggle('is-hidden', nextStep !== 3);
    if (step4Pane) step4Pane.classList.toggle('is-hidden', nextStep !== 4);
    stepIndicators.forEach((node) => {
      const indicatorStep = Number.parseInt(String(node.getAttribute('data-wizard-step-indicator') || ''), 10);
      node.classList.toggle('is-active', indicatorStep === nextStep);
    });
  }

  function maybeWarnQuestionLimit(totalQuestions) {
    if (state.currentStep <= 1) {
      state.limitWarningVisible = false;
      return;
    }
    const exceedsCap = Number(totalQuestions || 0) > MAX_PRACTICE_QUESTIONS;
    if (!exceedsCap) {
      state.limitWarningVisible = false;
      return;
    }
    if (state.limitWarningVisible) return;
    state.limitWarningVisible = true;
    showMessage(
      'Question Limit Reached',
      'A practice can include at most ' + MAX_PRACTICE_QUESTIONS + ' questions. Please reduce your plan.',
      'warning'
    ).catch(() => null);
  }

  function createSkillPlan(skillToken) {
    const skill = String(skillToken || '').trim().toLowerCase();
    const skillRow = skillMap.get(skill);
    if (!skillRow) return null;

    const typeRows = Array.isArray(skillRow.questionTypes) ? skillRow.questionTypes : [];
    const typePlans = new Map();

    typeRows.forEach((typeRow) => {
      const questionType = String(typeRow.questionType || '').trim().toLowerCase();
      if (!questionType) return;
      const availableCount = Math.max(0, Number(typeRow.count || 0) || 0);
      if (availableCount <= 0) return;
      typePlans.set(questionType, {
        questionType,
        availableCount,
        selected: true,
        questionCount: 1
      });
    });

    return {
      skill,
      availableQuestionCount: Math.max(
        0,
        normalizeNumber(
          skillRow.availableQuestionCount,
          typeRows.reduce((sum, row) => sum + Math.max(0, normalizeNumber(row?.count, 0)), 0)
        )
      ),
      typePlans
    };
  }

  function toggleSkill(skillToken) {
    const skill = String(skillToken || '').trim().toLowerCase();
    if (!skill) return;
    if (state.selectedSkills.has(skill)) {
      state.selectedSkills.delete(skill);
    } else {
      const plan = createSkillPlan(skill);
      if (plan) {
        state.selectedSkills.set(skill, plan);
      }
    }
    renderSkillButtons();
    renderPlan();
  }

  function renderSkillButtons() {
    skillButtons.forEach((button) => {
      const skill = String(button.getAttribute('data-skill') || '').trim().toLowerCase();
      const selected = state.selectedSkills.has(skill);
      button.classList.toggle('is-selected', selected);
      button.setAttribute('aria-pressed', selected ? 'true' : 'false');
    });
    refreshWizardButtons();
  }

  function renderPlan() {
    const plans = Array.from(state.selectedSkills.values());
    if (!plans.length) {
      planBox.innerHTML = '<div class="pte-practice-empty">Select at least one skill to configure your practice plan.</div>';
      if (planTotals) {
        planTotals.textContent = 'No skills selected yet.';
        planTotals.classList.remove('text-danger');
        planTotals.classList.remove('fw-bold');
      }
      renderSummary();
      refreshWizardButtons();
      return;
    }

    let totalSkills = 0;
    let totalTypes = 0;
    let totalQuestions = 0;

    const html = plans.map((plan) => {
      totalSkills += 1;
      const typeRows = Array.from(plan.typePlans.values());
      if (!typeRows.length) {
        return ''
          + '<section class="pte-practice-plan-skill">'
          + '  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">'
          + '    <div class="fw-bold text-capitalize">' + escapeHtml(formatSkillLabel(plan.skill)) + '</div>'
          + '    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Available ' + escapeHtml(plan.availableQuestionCount) + '</span>'
          + '  </div>'
          + '  <div class="small text-muted">No practice-enabled question types are available for this skill with your current scope.</div>'
          + '</section>';
      }
      const typeRowsHtml = typeRows.map((typePlan, index) => {
        const isChecked = typePlan.selected === true;
        const requestedCount = normalizeCount(typePlan.questionCount, typePlan.availableCount);
        if (isChecked) {
          totalTypes += 1;
          totalQuestions += requestedCount;
        }
        const inputId = 'pte_plan_' + escapeHtml(plan.skill) + '_' + index;
        return ''
          + '<div class="row g-2 align-items-center pte-practice-type-row">'
          + '  <div class="col-md-7">'
          + '    <div class="form-check">'
          + '      <input class="form-check-input pte-practice-type-check" type="checkbox" id="' + inputId + '" data-skill="' + escapeHtml(plan.skill) + '" data-question-type="' + escapeHtml(typePlan.questionType) + '" ' + (isChecked ? 'checked' : '') + '>'
          + '      <label class="form-check-label" for="' + inputId + '">' + escapeHtml(formatQuestionTypeLabel(typePlan.questionType)) + '</label>'
          + '    </div>'
          + '  </div>'
          + '  <div class="col-md-2">'
          + '    <span class="badge bg-light text-dark border">Pool ' + escapeHtml(typePlan.availableCount) + '</span>'
          + '  </div>'
          + '  <div class="col-md-3">'
          + '    <input class="form-control form-control-sm pte-practice-type-count" type="number" min="1" max="' + escapeHtml(typePlan.availableCount) + '" value="' + escapeHtml(requestedCount) + '" data-skill="' + escapeHtml(plan.skill) + '" data-question-type="' + escapeHtml(typePlan.questionType) + '" ' + (isChecked ? '' : 'disabled') + '>'
          + '  </div>'
          + '</div>';
      }).join('');

      return ''
        + '<section class="pte-practice-plan-skill">'
        + '  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">'
        + '    <div class="fw-bold text-capitalize">' + escapeHtml(formatSkillLabel(plan.skill)) + '</div>'
        + '    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Available ' + escapeHtml(plan.availableQuestionCount) + '</span>'
        + '  </div>'
        + typeRowsHtml
        + '</section>';
    }).join('');

    planBox.innerHTML = html;
    if (planTotals) {
      const exceedsCap = totalQuestions > MAX_PRACTICE_QUESTIONS;
      planTotals.classList.toggle('text-danger', exceedsCap);
      planTotals.classList.toggle('fw-bold', exceedsCap);
      if (exceedsCap) {
        planTotals.textContent = totalSkills + ' skill(s), ' + totalTypes + ' type(s), ' + totalQuestions
          + ' planned question(s). Maximum allowed is ' + MAX_PRACTICE_QUESTIONS + '.';
      } else {
        planTotals.textContent = totalSkills + ' skill(s), ' + totalTypes + ' type(s), ' + totalQuestions + ' planned question(s).';
      }
    }
    maybeWarnQuestionLimit(totalQuestions);
    renderSummary();
    refreshWizardButtons();
  }

  function readRuntimePlan() {
    const plans = [];
    state.selectedSkills.forEach((plan) => {
      const typePlans = Array.from(plan.typePlans.values())
        .filter((typePlan) => typePlan.selected === true)
        .map((typePlan) => ({
          questionType: typePlan.questionType,
          questionCount: normalizeCount(typePlan.questionCount, typePlan.availableCount)
        }))
        .filter((row) => row.questionType && row.questionCount > 0);

      if (!typePlans.length) return;
      plans.push({
        skill: plan.skill,
        typePlans
      });
    });
    return plans;
  }

  function getPlannedQuestionCount(skillPlans = null) {
    const sourcePlans = Array.isArray(skillPlans) ? skillPlans : readRuntimePlan();
    return sourcePlans.reduce((sum, row) => {
      const count = Array.isArray(row.typePlans)
        ? row.typePlans.reduce((typeSum, typeRow) => (
          typeSum + Math.max(1, Number(typeRow?.questionCount || 0) || 0)
        ), 0)
        : 0;
      return sum + count;
    }, 0);
  }

  function getRuntimePlanMeta(skillPlans = null) {
    const plans = Array.isArray(skillPlans) ? skillPlans : readRuntimePlan();
    const totalQuestions = plans.reduce((sum, row) => {
      const count = Array.isArray(row.typePlans)
        ? row.typePlans.reduce((typeSum, typeRow) => (
          typeSum + Math.max(1, Number(typeRow?.questionCount || 0) || 0)
        ), 0)
        : 0;
      return sum + count;
    }, 0);
    return {
      plans,
      totalQuestions,
      withinCap: totalQuestions > 0 && totalQuestions <= MAX_PRACTICE_QUESTIONS
    };
  }

  function renderSummary() {
    if (!summaryBox) return;
    const skillPlans = readRuntimePlan();
    if (!skillPlans.length) {
      summaryBox.innerHTML = '<div class="pte-practice-empty">No valid question plan found. Please go back and select at least one type.</div>';
      return;
    }

    let totalQuestions = 0;
    let totalTypes = 0;
    const html = skillPlans.map((plan) => {
      const typeRows = Array.isArray(plan.typePlans) ? plan.typePlans : [];
      const typeHtml = typeRows.map((typeRow) => {
        const count = Math.max(1, Number(typeRow?.questionCount || 1) || 1);
        totalQuestions += count;
        totalTypes += 1;
        return ''
          + '<li class="d-flex align-items-center justify-content-between gap-2 mb-1">'
          + '  <span>' + escapeHtml(formatQuestionTypeLabel(typeRow.questionType)) + '</span>'
          + '  <span class="badge bg-light text-dark border">' + escapeHtml(count) + '</span>'
          + '</li>';
      }).join('');

      return ''
        + '<section class="pte-practice-summary-skill">'
        + '  <div class="fw-bold text-capitalize mb-2">' + escapeHtml(formatSkillLabel(plan.skill)) + '</div>'
        + '  <ul class="list-unstyled mb-0">' + typeHtml + '</ul>'
        + '</section>';
    }).join('');

    summaryBox.innerHTML = ''
      + html
      + '<hr class="my-3">'
      + '<div class="d-flex flex-wrap gap-2">'
      + '  <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Skills: ' + escapeHtml(skillPlans.length) + '</span>'
      + '  <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Types: ' + escapeHtml(totalTypes) + '</span>'
      + '  <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Questions: ' + escapeHtml(totalQuestions) + '</span>'
      + '  <span class="badge bg-light text-dark border">Max Allowed: ' + escapeHtml(MAX_PRACTICE_QUESTIONS) + '</span>'
      + '</div>';
  }

  function refreshWizardButtons() {
    const hasSkillSelection = state.selectedSkills.size > 0;
    const runtimeMeta = getRuntimePlanMeta();
    const hasRuntimePlan = runtimeMeta.plans.length > 0;
    const withinCap = runtimeMeta.withinCap;
    const practiceName = sanitizePracticeName(practiceNameInput?.value || '');
    if (step1NextBtn) step1NextBtn.disabled = !hasSkillSelection;
    if (step2NextBtn) step2NextBtn.disabled = !hasRuntimePlan;
    if (step3NextBtn) step3NextBtn.disabled = !hasRuntimePlan;
    if (startBtn) startBtn.disabled = !hasRuntimePlan || !withinCap || !practiceName;
  }

  planBox?.addEventListener('change', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;

    if (target.classList.contains('pte-practice-type-check')) {
      const skill = String(target.getAttribute('data-skill') || '').trim().toLowerCase();
      const questionType = String(target.getAttribute('data-question-type') || '').trim().toLowerCase();
      const skillPlan = state.selectedSkills.get(skill);
      const typePlan = skillPlan?.typePlans?.get(questionType);
      if (!typePlan) return;

      typePlan.selected = !!target.checked;
      const countInput = Array.from(planBox.querySelectorAll('.pte-practice-type-count')).find((node) =>
        String(node.getAttribute('data-skill') || '').trim().toLowerCase() === skill
        && String(node.getAttribute('data-question-type') || '').trim().toLowerCase() === questionType
      );
      if (countInput instanceof HTMLInputElement) countInput.disabled = !typePlan.selected;
      renderPlan();
    }
  });

  planBox?.addEventListener('input', (event) => {
    const target = event.target;
    if (!(target instanceof HTMLElement)) return;
    if (!target.classList.contains('pte-practice-type-count')) return;

    const skill = String(target.getAttribute('data-skill') || '').trim().toLowerCase();
    const questionType = String(target.getAttribute('data-question-type') || '').trim().toLowerCase();
    const skillPlan = state.selectedSkills.get(skill);
    const typePlan = skillPlan?.typePlans?.get(questionType);
    if (!typePlan) return;

    typePlan.questionCount = normalizeCount(target.value, typePlan.availableCount);
    renderPlan();
  });

  skillButtons.forEach((button) => {
    button.addEventListener('click', (event) => {
      if (event && typeof event.preventDefault === 'function') event.preventDefault();
      toggleSkill(String(button.getAttribute('data-skill') || '').trim().toLowerCase());
    });
  });

  step1NextBtn?.addEventListener('click', async () => {
    if (!state.selectedSkills.size) {
      await showMessage('Skill Required', 'Please select at least one skill before going to the next step.', 'warning');
      return;
    }
    setWizardStep(2);
  });

  step2PrevBtn?.addEventListener('click', () => {
    setWizardStep(1);
  });

  step2NextBtn?.addEventListener('click', async () => {
    const skillPlans = readRuntimePlan();
    if (!skillPlans.length) {
      await showMessage('Question Plan Required', 'Please select at least one question type and count before continuing.', 'warning');
      return;
    }
    renderSummary();
    setWizardStep(3);
  });

  step3PrevBtn?.addEventListener('click', () => {
    setWizardStep(2);
  });

  step3NextBtn?.addEventListener('click', async () => {
    const runtimeMeta = getRuntimePlanMeta();
    if (!runtimeMeta.plans.length) {
      await showMessage('Practice Plan Required', 'Select at least one skill and one question type to continue.', 'warning');
      return;
    }
    if (!runtimeMeta.withinCap) {
      await showMessage(
        'Question Limit Reached',
        'A practice can include at most ' + MAX_PRACTICE_QUESTIONS + ' questions. Please reduce your plan.',
        'warning'
      );
      return;
    }
    ensureSuggestedPracticeName();
    setWizardStep(4);
    practiceNameInput?.focus();
  });

  step4PrevBtn?.addEventListener('click', () => {
    setWizardStep(3);
  });

  startBtn?.addEventListener('click', async () => {
    const runtimeMeta = getRuntimePlanMeta();
    const skillPlans = runtimeMeta.plans;
    if (!skillPlans.length) {
      await showMessage('Practice Plan Required', 'Select at least one skill and one question type to start practice.', 'warning');
      return;
    }
    if (!runtimeMeta.withinCap) {
      await showMessage(
        'Question Limit Reached',
        'A practice can include at most ' + MAX_PRACTICE_QUESTIONS + ' questions. Please reduce your plan.',
        'warning'
      );
      return;
    }
    const practiceName = sanitizePracticeName(practiceNameInput?.value || '');
    if (!practiceName) {
      await showMessage('Practice Name Required', 'Please enter a name for this practice before starting.', 'warning');
      practiceNameInput?.focus();
      return;
    }

    const allSkills = skillPlans.map((row) => row.skill).filter(Boolean);
    const allTypes = Array.from(new Set(skillPlans.flatMap((row) =>
      Array.isArray(row.typePlans) ? row.typePlans.map((typeRow) => String(typeRow.questionType || '').trim().toLowerCase()).filter(Boolean) : []
    )));
    const totalCount = Math.max(1, skillPlans.reduce((sum, row) => {
      const count = Array.isArray(row.typePlans)
        ? row.typePlans.reduce((typeSum, typeRow) => typeSum + Math.max(1, Number(typeRow.questionCount || 0) || 0), 0)
        : 0;
      return sum + count;
    }, 0));

    const runtimePlan = {
      skillPlans,
      skill: allSkills.length === 1 ? allSkills[0] : 'multi',
      questionTypes: allTypes,
      questionCount: totalCount,
      practiceName,
      source: {
        module: 'pte_practice_ui',
        eventType: 'attempt_started',
        eventId: 'PTE-PRACTICE-START-' + Date.now()
      }
    };

    setBusy(startBtn, true, 'Starting...');
    try {
      const runtimeActionStateId = await requestRuntimeStartActionStateId();
      const body = new URLSearchParams();
      body.set('runtimePlan', JSON.stringify(runtimePlan));
      body.set('actionStateId', runtimeActionStateId);

      const endpoint = '/pte/practice/api/runtime/start?actionStateId=' + encodeURIComponent(runtimeActionStateId);
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'X-AJAX-Request': 'true',
          'Accept': 'application/json'
        },
        credentials: 'include',
        body: body.toString()
      });

      const result = await response.json().catch(() => null);
      if (!response.ok || !result || result.status !== 'success') {
        throw new Error((result && result.message) || ('Start failed with status ' + response.status + '.'));
      }

      const sessionId = String(result?.results?.session?.id || '').trim();
      if (!sessionId) throw new Error('Session id was not returned by runtime start.');
      window.location.href = '/pte/practice/session/' + encodeURIComponent(sessionId);
    } catch (error) {
      await showMessage('Practice Start Failed', error.message || 'Unexpected start error.', 'error');
      setBusy(startBtn, false);
    }
  });

  practiceNameInput?.addEventListener('input', () => {
    const next = sanitizePracticeName(practiceNameInput.value, { trimEdges: false });
    if (practiceNameInput.value !== next) practiceNameInput.value = next;
    refreshWizardButtons();
  });

  const firstSkill = skillRows.length ? String(skillRows[0].skill || '').trim().toLowerCase() : '';
  if (firstSkill) {
    const firstPlan = createSkillPlan(firstSkill);
    if (firstPlan) {
      state.selectedSkills.set(firstSkill, firstPlan);
    }
  }

  renderSkillButtons();
  renderPlan();
  setWizardStep(1);
  ensureSuggestedPracticeName();
  refreshWizardButtons();
})();
</script>
