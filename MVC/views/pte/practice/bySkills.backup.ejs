<%
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const data = (overview && typeof overview === 'object') ? overview : {};
  const skillRows = Array.isArray(data.skills) ? data.skills : [];
  const analytics = (data.analytics && typeof data.analytics === 'object') ? data.analytics : null;
  const recentSessions = Array.isArray(data.recentSessions) ? data.recentSessions : [];
  const initialSkill = (skillRows[0] && skillRows[0].skill) ? String(skillRows[0].skill) : '';
  const formatQuestionTypeLabel = (value) => String(value || '')
    .trim()
    .toLowerCase()
    .split('_')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');
%>

<div class="sections-page">
  <div class="pte-practice-header mb-4">
    <div class="pte-practice-hero-wrap">
      <h1 class="page-heading size-md m-0 pte-practice-hero-title"><i class="bi bi-bullseye me-2"></i>PTE Practice By Skills</h1>
      <div class="pte-practice-hero-subtitle mt-3 mb-2">Choose a skill, select question types, and run flexible practice without forced answers.</div>
    </div>
    <div class="d-flex align-items-center justify-content-end gap-2 flex-wrap pte-practice-header-actions">
      <a href="<%= dashboardHref %>" class="btn btn-filled btn-secondary btn-md">
        <i class="bi bi-speedometer2 me-1"></i> PTE Dashboard
      </a>
      <a href="/pte/practice/attempts" class="btn btn-filled btn-secondary btn-md">
        <i class="bi bi-grid-3x3-gap me-1"></i> Practice Dashboard
      </a>
    </div>
  </div>

  <script id="ptePracticeOverviewJson" type="application/json"><%- JSON.stringify(data || {}).replace(/</g, '\\u003c') %></script>
  <input type="hidden" id="ptePracticeActionStateId" value="<%= actionStateId || '' %>">

  <style>
    .pte-practice-header {
      position: relative;
      width: 100%;
      margin-left: 0 !important;
      padding-left: 0 !important;
      padding-right: 300px;
      min-height: 66px;
    }
    .pte-practice-skill-card {
      position: relative;
      overflow: hidden;
      border: 1px solid #e7ecf2;
      border-radius: 0.95rem;
      background: #ffffff;
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background-color 0.18s ease;
    }
    .pte-practice-skill-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 0.6rem 1.4rem rgba(31, 41, 55, 0.12);
      border-color: #ced8e6;
    }
    .pte-practice-skill-card.is-selected {
      border-color: #0d6efd;
      background: linear-gradient(135deg, #e9f2ff 0%, #dceeff 40%, #ffffff 100%);
      box-shadow: 0 0.95rem 1.8rem rgba(13, 110, 253, 0.22);
      transform: translateY(-3px);
    }
    .pte-practice-skill-card.is-selected .text-muted {
      color: #355070 !important;
    }
    .pte-practice-skill-card.is-selected .badge.bg-primary {
      background: #0b5ed7 !important;
    }
    .pte-practice-control-shell {
      width: 100%;
      border: 1px solid #e7ecf2;
      border-radius: 0.9rem;
      background: #f8fafc;
      padding: 0.85rem 0.9rem 0.65rem;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
    }
    .pte-practice-control-shell .form-control {
      min-height: 48px;
    }
    .pte-practice-control-note {
      min-height: 1.35rem;
      margin-top: 0.35rem;
      font-size: 0.8rem;
      color: #6c757d;
      line-height: 1.2rem;
    }
    .pte-practice-control-note.is-placeholder {
      visibility: hidden;
    }
    .pte-practice-action-shell {
      width: 100%;
      border: 1px solid #e7ecf2;
      border-radius: 0.9rem;
      background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
      padding: 0.85rem 0.9rem 0.65rem;
      display: flex;
      align-items: stretch;
      height: 100%;
    }
    .pte-practice-action-shell #ptePracticeStartBtn {
      width: 100%;
      height: 100%;
      min-height: 96px;
      border-radius: 0.72rem;
    }
    .pte-practice-hero-wrap {
      flex: 1 1 auto;
      text-align: left !important;
      padding-right: 0.25rem;
      margin-left: 0;
      padding-left: 0 !important;
    }
    .pte-practice-hero-title {
      font-size: clamp(1.7rem, 2.2vw, 2.15rem);
      font-weight: 800;
      letter-spacing: 0.01em;
      text-align: left !important;
      margin-left: 0 !important;
    }
    .pte-practice-hero-subtitle {
      display: block;
      min-height: 52px;
      font-size: clamp(1.03rem, 1.32vw, 1.2rem);
      font-weight: 700;
      color: #0b4f9e;
      background: linear-gradient(90deg, #eaf3ff 0%, #f4f9ff 100%);
      border: 1px solid #cfe2ff;
      border-left: 5px solid #0d6efd;
      border-radius: 0.65rem;
      padding: 0.55rem 0.85rem;
      text-align: left !important;
      margin-left: 0 !important;
    }
    .pte-practice-header-actions {
      position: absolute;
      top: 0;
      right: 0;
      min-height: 56px;
    }
    @media (max-width: 1199.98px) {
      .pte-practice-header {
        padding-right: 0;
        min-height: 0;
      }
      .pte-practice-header-actions {
        position: static;
        margin-top: 0.75rem;
        justify-content: flex-start !important;
      }
    }
  </style>

  <div class="row g-3 mb-3">
    <% if (!skillRows.length) { %>
      <div class="col-12">
        <div class="alert alert-warning border shadow-sm mb-0">
          No published practice-enabled questions are available for your current organization scope.
        </div>
      </div>
    <% } %>
    <% skillRows.forEach((row) => { %>
      <div class="col-md-6 col-xl-3">
        <button
          type="button"
          class="card border-0 shadow-sm h-100 text-start w-100 pte-practice-skill-card"
          data-no-wait="true"
          data-skill="<%= row.skill %>">
          <div class="card-body">
            <div class="d-flex align-items-center justify-content-between mb-2">
              <div class="text-uppercase small fw-bold text-muted"><%= row.skill %></div>
              <span class="badge bg-primary"><%= Number(row.availableQuestionCount || 0) %> Q</span>
            </div>
            <div class="fw-bold mb-1">Available Question Types: <%= Number(row.availableQuestionTypes || 0) %></div>
            <div class="small text-muted">
              <% const topTypes = Array.isArray(row.questionTypes) ? row.questionTypes.slice(0, 3) : []; %>
              <% if (!topTypes.length) { %>
                No question types available yet.
              <% } else { %>
                <% topTypes.forEach((t, index) => { %>
                  <span><%= formatQuestionTypeLabel(t.questionType) || '-' %></span> (<%= Number(t.count || 0) %>)<%= index < topTypes.length - 1 ? ', ' : '' %>
                <% }) %>
              <% } %>
            </div>
          </div>
        </button>
      </div>
    <% }) %>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body">
      <div class="row g-3 align-items-stretch">
        <div class="col-lg-4 d-flex">
          <div class="pte-practice-control-shell">
            <label class="form-label fw-bold" for="ptePracticeSelectedSkill">Selected Skill</label>
            <input type="text" id="ptePracticeSelectedSkill" class="form-control form-control-lg text-capitalize" value="<%= initialSkill %>" readonly>
            <div class="pte-practice-control-note is-placeholder">placeholder</div>
          </div>
        </div>
        <div class="col-lg-4 d-flex">
          <div class="pte-practice-control-shell">
            <label class="form-label fw-bold" for="ptePracticeQuestionCount">Question Count</label>
            <input type="number" id="ptePracticeQuestionCount" class="form-control form-control-lg" value="20" min="1" max="120">
            <div class="pte-practice-control-note">Questions are randomized from the matching published pool.</div>
          </div>
        </div>
        <div class="col-lg-4 d-flex">
          <div class="pte-practice-action-shell">
            <button type="button" class="btn btn-filled btn-primary btn-lg w-100 h-100 fw-bold" id="ptePracticeStartBtn">
              <i class="bi bi-play-circle me-1"></i> Start Practice
            </button>
          </div>
        </div>
      </div>

      <div class="mt-3">
        <label class="form-label fw-bold mb-2">Question Types (Multi-select)</label>
        <div id="ptePracticeTypeBox" class="border rounded p-3 bg-light-subtle">
          <div class="text-muted small">Select a skill card to load question types.</div>
        </div>
        <div class="small text-muted mt-2">
          During practice, skipped questions are logged with seen time. Answered questions log submission performance and optional self difficulty rating.
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-xl-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h5 class="fw-bold mb-3"><i class="bi bi-graph-up-arrow me-2"></i>Performance Snapshot</h5>
          <% if (!analytics) { %>
            <div class="text-muted">No analytics data available yet for the active learner scope.</div>
          <% } else { %>
            <div class="row g-2 mb-3">
              <div class="col-sm-6">
                <div class="border rounded p-2 bg-light">
                  <div class="small text-muted">Average Score</div>
                  <div class="fw-bold"><%= Number(analytics.summary?.averagePercentage || 0).toFixed(2) %>%</div>
                </div>
              </div>
              <div class="col-sm-6">
                <div class="border rounded p-2 bg-light">
                  <div class="small text-muted">Average Time</div>
                  <div class="fw-bold"><%= Number(analytics.summary?.averageTimeSeconds || 0).toFixed(2) %> sec</div>
                </div>
              </div>
              <div class="col-sm-6">
                <div class="border rounded p-2 bg-light">
                  <div class="small text-muted">Accuracy</div>
                  <div class="fw-bold"><%= Number(analytics.summary?.accuracyPercentage || 0).toFixed(2) %>%</div>
                </div>
              </div>
              <div class="col-sm-6">
                <div class="border rounded p-2 bg-light">
                  <div class="small text-muted">Submitted Items</div>
                  <div class="fw-bold"><%= Number(analytics.summary?.submittedCount || 0) %> / <%= Number(analytics.summary?.totalItems || 0) %></div>
                </div>
              </div>
            </div>
            <div class="mb-2 fw-bold">Skill Distribution</div>
            <% (Array.isArray(analytics.bySkill) ? analytics.bySkill : []).forEach((row) => { %>
              <% const pct = Math.max(0, Math.min(100, Number(row.averagePercentage || 0))); %>
              <div class="mb-2">
                <div class="d-flex align-items-center justify-content-between small">
                  <span class="text-capitalize"><%= row.skill %></span>
                  <span><%= Number(row.averagePercentage || 0).toFixed(2) %>%</span>
                </div>
                <div class="progress" style="height: 8px;">
                  <div class="progress-bar" role="progressbar" style="width: <%= pct %>%;" aria-valuenow="<%= pct %>" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
              </div>
            <% }) %>
            <div class="mt-3">
              <div class="fw-bold mb-1">Roadmap Hints</div>
              <ul class="small mb-0">
                <% (Array.isArray(analytics.roadmap) ? analytics.roadmap : []).forEach((hint) => { %>
                  <li><%= hint %></li>
                <% }) %>
                <% if (!Array.isArray(analytics.roadmap) || analytics.roadmap.length === 0) { %>
                  <li>No roadmap hints yet. Complete more attempts to generate guidance.</li>
                <% } %>
              </ul>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <div class="col-xl-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
            <h5 class="fw-bold m-0"><i class="bi bi-clock-history me-2"></i>Recent Skill Practice Sessions</h5>
            <a href="/pte/practice/attempts" class="btn btn-outline-primary btn-sm">
              <i class="bi bi-list-check me-1"></i> View All Attempts
            </a>
          </div>
          <div class="table-responsive">
            <table class="table table-sm align-middle">
              <thead>
                <tr>
                  <th>Session</th>
                  <th>Status</th>
                  <th>Questions</th>
                  <th>Score</th>
                  <th>Started</th>
                </tr>
              </thead>
              <tbody>
                <% if (!recentSessions.length) { %>
                  <tr><td colspan="5" class="text-center text-muted py-3">No skill-practice sessions yet.</td></tr>
                <% } %>
                <% recentSessions.forEach((row) => { %>
                  <tr>
                    <td class="font-monospace"><a href="/pte/practice/session/<%= encodeURIComponent(row.id) %>"><%= row.id %></a></td>
                    <td class="text-capitalize"><%= row.status || '-' %></td>
                    <td><%= Number(row.submittedQuestions || 0) %> / <%= Number(row.totalQuestions || 0) %></td>
                    <td><%= Number(row.percentage || 0).toFixed(2) %>%</td>
                    <td><%= row.startedAt ? new Date(row.startedAt).toLocaleString() : '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(() => {
  const overview = (() => {
    try {
      const node = document.getElementById('ptePracticeOverviewJson');
      return JSON.parse((node && node.textContent) || '{}');
    } catch (_) {
      return {};
    }
  })();
  const actionStateId = String(document.getElementById('ptePracticeActionStateId')?.value || '').trim();
  const skillRows = Array.isArray(overview.skills) ? overview.skills : [];
  const skillMap = new Map(skillRows.map((row) => [String(row.skill || '').toLowerCase(), row]));

  const selectedSkillInput = document.getElementById('ptePracticeSelectedSkill');
  const questionCountInput = document.getElementById('ptePracticeQuestionCount');
  const typeBox = document.getElementById('ptePracticeTypeBox');
  const startBtn = document.getElementById('ptePracticeStartBtn');
  const skillCards = Array.from(document.querySelectorAll('.pte-practice-skill-card'));

  function showMessage(title, message, icon = 'info') {
    if (typeof window.showMessageModal === 'function') {
      return window.showMessageModal({
        title,
        message,
        icon,
        buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : 'btn-primary' }]
      });
    }
    return Promise.resolve();
  }

  function formatQuestionTypeLabel(value) {
    return String(value || '')
      .trim()
      .toLowerCase()
      .split('_')
      .filter(Boolean)
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(' ');
  }

  function setSkill(skillToken) {
    const token = String(skillToken || '').trim().toLowerCase();
    const row = skillMap.get(token) || null;
    if (!row) return;
    if (selectedSkillInput) selectedSkillInput.value = token;

    skillCards.forEach((card) => {
      const cardToken = String(card.getAttribute('data-skill') || '').trim().toLowerCase();
      const isSelected = cardToken === token;
      card.classList.toggle('is-selected', isSelected);
      card.setAttribute('aria-pressed', isSelected ? 'true' : 'false');
    });

    const typeRows = Array.isArray(row.questionTypes) ? row.questionTypes : [];
    if (!typeRows.length) {
      typeBox.innerHTML = '<div class="text-muted small">No question types available for this skill.</div>';
      return;
    }

    typeBox.innerHTML = typeRows.map((typeRow, index) => {
      const qt = String(typeRow.questionType || '').trim();
      const label = formatQuestionTypeLabel(qt) || qt || '-';
      return ''
        + '<div class="form-check mb-2">'
        + '  <input class="form-check-input pte-practice-type-check" type="checkbox" id="ptePracticeType_' + index + '" value="' + qt + '" checked>'
        + '  <label class="form-check-label d-flex align-items-center justify-content-between gap-2" for="ptePracticeType_' + index + '">'
        + '    <span>' + label + '</span>'
        + '    <span class="badge bg-light text-dark border">' + Number(typeRow.count || 0) + '</span>'
        + '  </label>'
        + '</div>';
    }).join('');
  }

  function getSelectedTypes() {
    return Array.from(document.querySelectorAll('.pte-practice-type-check:checked'))
      .map((node) => String(node.value || '').trim())
      .filter(Boolean);
  }

  function setBusy(button, busy, label = 'Working...') {
    if (!button) return;
    if (busy) {
      button.dataset.originalHtml = button.innerHTML;
      button.disabled = true;
      button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + label;
      return;
    }
    button.disabled = false;
    if (button.dataset.originalHtml) button.innerHTML = button.dataset.originalHtml;
  }

  skillCards.forEach((card) => {
    card.addEventListener('click', (event) => {
      if (event && typeof event.preventDefault === 'function') event.preventDefault();
      const skillToken = String(card.getAttribute('data-skill') || '').trim().toLowerCase();
      setSkill(skillToken);
    });
  });

  startBtn?.addEventListener('click', async () => {
    const skill = String(selectedSkillInput?.value || '').trim().toLowerCase();
    if (!skill) {
      await showMessage('Skill Required', 'Please select a skill to start practice.', 'warning');
      return;
    }
    const questionTypes = getSelectedTypes();
    if (!questionTypes.length) {
      await showMessage('Question Types Required', 'Select at least one question type.', 'warning');
      return;
    }
    const questionCount = Math.max(1, Math.min(120, Number.parseInt(String(questionCountInput?.value || '20'), 10) || 20));

    setBusy(startBtn, true, 'Starting...');
    try {
      const runtimePlan = {
        skill,
        questionTypes,
        questionCount,
        source: {
          module: 'pte_practice_ui',
          eventType: 'attempt_started',
          eventId: 'PTE-PRACTICE-START-' + Date.now()
        }
      };
      const body = new URLSearchParams();
      body.set('runtimePlan', JSON.stringify(runtimePlan));
      body.set('actionStateId', actionStateId);
      const endpoint = '/pte/practice/api/runtime/start' + (actionStateId ? ('?actionStateId=' + encodeURIComponent(actionStateId)) : '');
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'X-AJAX-Request': 'true',
          'Accept': 'application/json'
        },
        credentials: 'include',
        body: body.toString()
      });
      const result = await response.json().catch(() => null);
      if (!response.ok || !result || result.status !== 'success') {
        throw new Error((result && result.message) || ('Start failed with status ' + response.status + '.'));
      }
      const sessionId = String(result?.results?.session?.id || '').trim();
      if (!sessionId) throw new Error('Session id was not returned by runtime start.');
      window.location.href = '/pte/practice/session/' + encodeURIComponent(sessionId);
    } catch (error) {
      await showMessage('Practice Start Failed', error.message || 'Unexpected start error.', 'error');
      setBusy(startBtn, false);
    }
  });

  setSkill(String(selectedSkillInput?.value || '').trim().toLowerCase());
})();
</script>
