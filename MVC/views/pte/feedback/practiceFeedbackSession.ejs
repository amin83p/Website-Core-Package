<%
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const session = detail?.session || {};
  const rows = Array.isArray(detail?.items) ? detail.items : [];
  const sessionId = String(session?.id || '').trim();
  const attemptStatus = String(session?.status || '').trim().toLowerCase();
  const attemptSkill = String(session?.metadata?.practice?.skill || '').trim().toLowerCase();
  const userLabel = String(detail?.userLabel || session?.userId || '-').trim();
  const savedDetailedFeedback = (session?.metadata && typeof session.metadata === 'object' && session.metadata.practiceDetailedFeedback && typeof session.metadata.practiceDetailedFeedback === 'object')
    ? session.metadata.practiceDetailedFeedback
    : null;

  const escapeHtml = (value) => String(value == null ? '' : value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
  const toText = (value) => String(value == null ? '' : value).replace(/\0/g, '').trim();
  const toParagraph = (value) => escapeHtml(toText(value)).replace(/\r?\n/g, '<br>');
  const toArray = (value) => (Array.isArray(value) ? value : []);
  const isObject = (value) => value && typeof value === 'object' && !Array.isArray(value);

  const formatQuestionTypeLabel = (value) => String(value || '')
    .trim()
    .toLowerCase()
    .split('_')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');

  const formatStatusLabel = (value) => toText(value || '-').replace(/_/g, ' ') || '-';
  const formatStatusClass = (value) => {
    const token = toText(value).toLowerCase();
    if (!token) return 'bg-secondary';
    if (token === 'submitted' || token === 'auto_submitted' || token === 'scored' || token === 'feedback_provided') return 'bg-success';
    if (token === 'saved') return 'bg-primary';
    if (token === 'in_progress') return 'bg-info text-dark';
    if (token === 'abandoned') return 'bg-warning text-dark';
    return 'bg-secondary';
  };

  const normalizeQuestionType = (value) => toText(value).toLowerCase();
  const isListeningQuestionType = (value) => normalizeQuestionType(value).startsWith('listening_');

  const LISTENING_PROMPT_TYPES = new Set([
    'listening_summarize_spoken_text',
    'listening_mcq_single',
    'listening_mcq_multiple',
    'listening_fill_in_blank',
    'listening_select_missing_word',
    'listening_highlight_incorrect_words',
    'listening_dictation',
    'listening_matching'
  ]);

  function parseJsonObject(value) {
    const raw = toText(value);
    if (!raw) return null;
    try {
      const parsed = JSON.parse(raw);
      return isObject(parsed) ? parsed : null;
    } catch (_) {
      return null;
    }
  }

  function parseJsonArray(value) {
    const raw = toText(value);
    if (!raw) return [];
    try {
      const parsed = JSON.parse(raw);
      return Array.isArray(parsed) ? parsed : [];
    } catch (_) {
      return [];
    }
  }

  function resolveQuestionMediaUrl(question = {}, mediaRef = '') {
    const tokenRaw = toText(mediaRef);
    const token = tokenRaw.toLowerCase();
    if (!token) return '';
    if (/^https?:\/\//i.test(tokenRaw)) return tokenRaw;
    if (/^data:(audio|image|video)\//i.test(tokenRaw)) return tokenRaw;
    if (/^\/uploads\//i.test(tokenRaw)) return tokenRaw;
    if (/^uploads\//i.test(tokenRaw)) return `/${tokenRaw.replace(/^\/+/, '')}`;

    const mediaRows = Array.isArray(question?.mediaAssets) ? question.mediaAssets : [];
    const matched = mediaRows.find((row) => {
      const candidates = [
        row?.id,
        row?.name,
        row?.originalName,
        row?.filename,
        row?.path,
        row?.url
      ].map((value) => toText(value).toLowerCase()).filter(Boolean);
      return candidates.includes(token);
    }) || null;
    if (!matched) return '';
    const directUrl = toText(matched?.url);
    if (directUrl) return directUrl;
    const pathText = toText(matched?.path).replace(/\\/g, '/');
    if (!pathText) return '';
    const match = pathText.match(/\/uploads\/(.+)$/i);
    if (match && match[1]) return `/uploads/${String(match[1]).replace(/^\/+/, '')}`;
    return pathText;
  }

  function resolveQuestionMediaItems(question = {}, refs = []) {
    const rows = [];
    const seen = new Set();
    const sourceRefs = Array.isArray(refs) ? refs : [];
    sourceRefs.forEach((ref) => {
      const token = toText(ref);
      if (!token) return;
      const url = resolveQuestionMediaUrl(question, token);
      const dedupe = `${token}|${url}`;
      if (seen.has(dedupe)) return;
      seen.add(dedupe);
      rows.push({
        ref: token,
        url: toText(url),
        mimeType: '',
        name: token
      });
    });

    const mediaRows = Array.isArray(question?.mediaAssets) ? question.mediaAssets : [];
    mediaRows.forEach((row) => {
      const ref = toText(row?.id || row?.name || row?.filename || row?.path || row?.url);
      const url = toText(row?.url || resolveQuestionMediaUrl(question, ref));
      const dedupe = `${ref}|${url}`;
      if (seen.has(dedupe)) return;
      seen.add(dedupe);
      rows.push({
        ref,
        url,
        mimeType: toText(row?.mimeType),
        name: toText(row?.name || row?.originalName || row?.filename || row?.id || 'Media')
      });
    });
    return rows;
  }

  function normalizeQuestionOptions(options = []) {
    return (Array.isArray(options) ? options : [])
      .map((row, index) => {
        if (isObject(row)) {
          const key = toText(row.key || row.id || row.value || String(index + 1));
          const text = toText(row.text || row.label || row.content || row.value || key);
          return { key, text };
        }
        const text = toText(row);
        return { key: String(index + 1), text };
      })
      .filter((row) => row.key && row.text);
  }

  function findOptionLabel(options = [], key = '') {
    const token = toText(key).toLowerCase();
    if (!token) return '';
    const row = (Array.isArray(options) ? options : []).find((opt) => toText(opt?.key).toLowerCase() === token);
    return toText(row?.text);
  }

  function buildListeningAnswerView(questionPayload = {}, responsePayload = {}, questionType = '') {
    const type = normalizeQuestionType(questionType);
    const options = normalizeQuestionOptions(questionPayload?.options);
    const out = {
      lines: [],
      optionRows: options,
      missing: false
    };

    const textValue = toText(responsePayload?.text);
    const singleValue = toText(responsePayload?.selectedSingle);
    const multiValues = toArray(responsePayload?.selectedMultiple).map((value) => toText(value)).filter(Boolean);
    const mapText = toText(responsePayload?.mapText);

    if (type === 'listening_summarize_spoken_text' || type === 'listening_dictation') {
      if (textValue) out.lines.push({ label: 'Typed response', value: textValue });
      if (!textValue) out.missing = true;
      return out;
    }

    if (type === 'listening_mcq_single' || type === 'listening_select_missing_word') {
      if (singleValue) {
        const optionLabel = findOptionLabel(options, singleValue);
        out.lines.push({
          label: 'Selected option',
          value: optionLabel ? `${singleValue}: ${optionLabel}` : singleValue
        });
      } else {
        out.missing = true;
      }
      return out;
    }

    if (type === 'listening_mcq_multiple') {
      if (multiValues.length) {
        const resolved = multiValues.map((value) => {
          const optionLabel = findOptionLabel(options, value);
          return optionLabel ? `${value}: ${optionLabel}` : value;
        });
        out.lines.push({ label: 'Selected options', value: resolved.join('\n') });
      } else {
        out.missing = true;
      }
      return out;
    }

    if (type === 'listening_fill_in_blank') {
      const map = parseJsonObject(mapText) || {};
      const entries = Object.entries(map).map(([key, value]) => ({
        key: toText(key),
        value: toText(value)
      })).filter((row) => row.key);
      if (entries.length) {
        out.lines.push({
          label: 'Filled blanks',
          value: entries.map((row) => `${row.key}: ${row.value || '-'}`).join('\n')
        });
      } else {
        out.missing = true;
      }
      return out;
    }

    if (type === 'listening_highlight_incorrect_words') {
      const map = parseJsonObject(mapText) || {};
      const words = toArray(map.selectedWords).map((value) => toText(value)).filter(Boolean);
      if (words.length) {
        out.lines.push({ label: 'Highlighted words', value: words.join('\n') });
      } else if (textValue) {
        out.lines.push({ label: 'Highlighted words', value: textValue });
      } else {
        out.missing = true;
      }
      return out;
    }

    if (type === 'listening_matching') {
      const entries = parseJsonArray(mapText);
      if (entries.length) {
        const pairs = entries.map((row, index) => {
          if (isObject(row)) {
            const left = toText(row.left || row.leftItem || row.prompt || row.source || row.a || '');
            const right = toText(row.right || row.rightItem || row.target || row.match || row.b || '');
            if (left || right) return `${left || `Left ${index + 1}`} -> ${right || '-'}`;
          }
          const text = toText(row);
          return text || `Pair ${index + 1}`;
        }).filter(Boolean);
        if (pairs.length) out.lines.push({ label: 'Matched pairs', value: pairs.join('\n') });
      } else {
        out.missing = true;
      }
      return out;
    }

    if (textValue) out.lines.push({ label: 'Response text', value: textValue });
    if (mapText) out.lines.push({ label: 'Response map', value: mapText });
    if (!out.lines.length) out.missing = true;
    return out;
  }

  function buildScoringTraitRows(item = {}, scoring = {}) {
    const traitScores = isObject(item?.traitScores) ? item.traitScores : {};
    const traitMax = isObject(scoring?.traitMax) ? scoring.traitMax : {};
    return Object.keys(traitScores)
      .filter((key) => toText(key))
      .map((key) => ({
        key,
        label: formatQuestionTypeLabel(key),
        score: Number(traitScores[key] || 0),
        max: Number(traitMax[key] || 0)
      }));
  }

  function getListeningTranscriptForPrompt(payload = {}, questionType = '') {
    const source = isObject(payload) ? payload : {};
    const token = normalizeQuestionType(questionType);
    const candidates = [];
    if (token === 'listening_highlight_incorrect_words') {
      candidates.push(source.transcriptText, source.transcript, source.promptText);
    } else if (token === 'listening_fill_in_blank') {
      candidates.push(source.transcriptWithBlanks, source.transcriptWithGap, source.transcriptText, source.transcript, source.promptText);
    } else if (token === 'listening_select_missing_word') {
      candidates.push(source.transcriptWithGap, source.transcriptText, source.transcript, source.promptText);
    } else {
      candidates.push(source.transcriptText, source.transcript, source.transcriptWithGap, source.transcriptWithBlanks, source.promptText);
    }
    for (const row of candidates) {
      const text = toText(row);
      if (text) return text;
    }
    return '';
  }

  function buildListeningPromptModel(question = {}, payload = {}, questionType = '') {
    const type = normalizeQuestionType(questionType);
    const promptAudioRef = toText(payload?.promptAudioAssetId || payload?.promptTextOrAudio);
    const transcriptText = getListeningTranscriptForPrompt(payload, type);
    return {
      type,
      audioRef: promptAudioRef,
      audioUrl: resolveQuestionMediaUrl(question, promptAudioRef),
      transcriptText,
      stem: toText(payload?.stem),
      promptText: toText(payload?.promptText),
      transcriptWithGap: toText(payload?.transcriptWithGap),
      transcriptWithBlanks: toText(payload?.transcriptWithBlanks),
      transcriptTextDisplay: toText(payload?.transcriptText),
      expectedTranscript: toText(payload?.expectedTranscript)
    };
  }

  function toCleanStringMap(source = {}) {
    const input = isObject(source) ? source : {};
    return Object.entries(input).reduce((acc, [key, value]) => {
      const cleanKey = toText(key);
      if (!cleanKey) return acc;
      acc[cleanKey] = toText(value);
      return acc;
    }, {});
  }

  function renderFillBlankAnswerPreview(sourceText = '', responseMap = {}) {
    const source = toText(sourceText);
    if (!source) return '';
    const map = toCleanStringMap(responseMap);
    const keys = Object.keys(map);
    const blankPattern = /(\{\{[^}]+\}\}|\[\s*blank\s*\]|_{3,}|\.{3,})/ig;
    const parts = source.split(blankPattern);
    let index = 0;
    const out = [];
    parts.forEach((part) => {
      const segment = String(part || '');
      const isBlank = /^\{\{[^}]+\}\}$/i.test(segment) || /^\[\s*blank\s*\]$/i.test(segment) || /^_{3,}$/.test(segment) || /^\.{3,}$/.test(segment);
      if (!isBlank) {
        out.push(segment);
        return;
      }
      const explicit = toText(segment.replace(/^\{\{|\}\}$/g, ''));
      const key = explicit && Object.prototype.hasOwnProperty.call(map, explicit)
        ? explicit
        : (keys[index] || explicit || `blank_${index + 1}`);
      const value = toText(map[key]);
      out.push(`[${value || '-'}]`);
      index += 1;
    });
    return out.join('');
  }

  function buildListeningResponseRunnerModel(questionPayload = {}, responsePayload = {}, questionType = '') {
    const type = normalizeQuestionType(questionType);
    const options = normalizeQuestionOptions(questionPayload?.options);
    const map = parseJsonObject(responsePayload?.mapText) || {};
    const selectedWords = toArray(map.selectedWords).map((value) => toText(value)).filter(Boolean);
    const matchingPairs = parseJsonArray(responsePayload?.mapText)
      .map((row, index) => {
        if (isObject(row)) {
          const left = toText(row.left || row.leftItem || row.prompt || row.source || row.a || '');
          const right = toText(row.right || row.rightItem || row.target || row.match || row.b || '');
          if (left || right) return { left: left || `Left ${index + 1}`, right: right || '-' };
        }
        const text = toText(row);
        if (!text) return null;
        return { left: `Pair ${index + 1}`, right: text };
      })
      .filter(Boolean);

    const selectedSingle = toText(responsePayload?.selectedSingle);
    const selectedMultiple = toArray(responsePayload?.selectedMultiple).map((value) => toText(value)).filter(Boolean);
    const selectedSet = new Set(selectedMultiple.map((value) => value.toLowerCase()));
    const optionRows = options.map((row) => ({
      ...row,
      selected: selectedSingle && toText(row.key).toLowerCase() === selectedSingle.toLowerCase(),
      checked: selectedSet.has(toText(row.key).toLowerCase())
    }));

    const responseMap = toCleanStringMap(map);
    const responseText = toText(responsePayload?.text || responsePayload?.transcript);
    const fillSourceText = toText(questionPayload?.transcriptWithBlanks || questionPayload?.transcriptWithGap || questionPayload?.promptText || questionPayload?.stem);

    return {
      type,
      optionRows,
      responseText,
      selectedSingle,
      selectedMultiple,
      fillEntries: Object.entries(responseMap).map(([key, value]) => ({ key, value })),
      fillPreview: renderFillBlankAnswerPreview(fillSourceText, responseMap),
      hiwTranscript: toText(questionPayload?.transcriptText || questionPayload?.promptText || questionPayload?.stem || questionPayload?.transcript),
      hiwSelectedWords: selectedWords.length ? selectedWords : responseText.split(/\r?\n+/g).map((value) => toText(value)).filter(Boolean),
      matchingPairs,
      missing: !responseText && !selectedSingle && !selectedMultiple.length && !Object.keys(responseMap).length && !matchingPairs.length
    };
  }

  const normalizePromptToken = (value) => toText(value).toLowerCase().replace(/\s+/g, ' ').trim();

  function buildPromptContext(item) {
    const question = isObject(item?.question) ? item.question : {};
    const metadata = isObject(item?.metadata) ? item.metadata : {};
    const questionSnapshot = isObject(metadata?.questionSnapshot) ? metadata.questionSnapshot : {};
    const payload = isObject(question?.payload)
      ? question.payload
      : (
        isObject(questionSnapshot?.payload)
          ? questionSnapshot.payload
          : (
            isObject(metadata?.questionPayload)
              ? metadata.questionPayload
              : (isObject(metadata?.payload) ? metadata.payload : {})
          )
      );
    const seenTokens = new Set();
    const context = {
      instruction: '',
      situations: [],
      bodies: [],
      mediaRefs: []
    };

    const remember = (value) => {
      const token = normalizePromptToken(value);
      if (!token) return false;
      if (seenTokens.has(token)) return false;
      seenTokens.add(token);
      return true;
    };

    const instruction = toText(
      payload.instructions
      || question.instructions
      || question.instructionText
      || questionSnapshot.instructions
      || questionSnapshot.instructionText
      || metadata.questionInstructions
      || ''
    );
    if (instruction) {
      context.instruction = instruction;
      remember(instruction);
    }

    const addSituation = (value) => {
      const raw = toText(value);
      if (!raw) return;
      const body = toText(raw.replace(/^situation\s*:\s*/i, '')) || raw;
      if (!remember(body)) return;
      context.situations.push(body);
    };

    addSituation(payload.situationText);
    addSituation(payload.scenarioText);

    const promptText = toText(payload.promptText);
    if (/^situation\s*:/i.test(promptText)) {
      addSituation(promptText);
    }

    const addBody = (value) => {
      const text = toText(value);
      if (!text) return;
      if (!remember(text)) return;
      context.bodies.push(text);
    };

    const bodyCandidates = [
      payload.sourceText,
      payload.stem,
      payload.taskText,
      payload.taskBody,
      payload.questionText,
      payload.promptTextOrAudio,
      /^situation\s*:/i.test(promptText) ? '' : promptText,
      payload.transcriptWithBlanks,
      payload.passageWithBlanks,
      payload.passageHtml,
      payload.passage,
      payload.itemPrompt,
      payload.scenario,
      payload.situation,
      payload.description,
      payload.expectedTranscript,
      questionSnapshot.promptText,
      questionSnapshot.questionText,
      metadata.promptText,
      metadata.questionText,
      metadata.sourceText
    ];
    bodyCandidates.forEach(addBody);

    if (!context.bodies.length && Array.isArray(payload.paragraphItems) && payload.paragraphItems.length) {
      addBody(payload.paragraphItems.map((row, index) => `${index + 1}. ${toText(row)}`).join('\n'));
    }
    if (!context.bodies.length && Array.isArray(payload.leftItems) && payload.leftItems.length) {
      addBody(payload.leftItems.map((row) => {
        if (isObject(row)) return toText(row.text || row.label || row.value || row.id || '');
        return toText(row);
      }).filter(Boolean).join('\n'));
    }

    const mediaCandidates = [
      payload.imageAssetId,
      payload.promptAudioAssetId,
      payload.sampleAudioAssetId
    ];
    mediaCandidates.forEach((value) => {
      const text = toText(value);
      if (!text) return;
      context.mediaRefs.push(text);
    });

    return context;
  }
%>

