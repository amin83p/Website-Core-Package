      font-size: 0.84rem;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .pte-feedback-kv-table {
      border: 1px solid #e2e8f0;
      border-radius: 0.55rem;
      overflow: hidden;
    }

    .pte-feedback-kv-row {
      display: grid;
      grid-template-columns: 140px minmax(0, 1fr);
      border-top: 1px solid #eef2f7;
    }

    .pte-feedback-kv-row:first-child {
      border-top: none;
    }

    .pte-feedback-kv-key {
      background: #f8fafc;
      padding: 0.45rem 0.55rem;
      font-size: 0.75rem;
      color: #475569;
      font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    }

    .pte-feedback-kv-value {
      padding: 0.45rem 0.55rem;
      font-size: 0.83rem;
      color: #0f172a;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    .pte-feedback-item-panel .card-body,
    .pte-feedback-item-panel .card-header,
    .pte-feedback-runner-card,
    .pte-feedback-audio-card {
      min-width: 0;
    }

    .pte-feedback-question-nav {
      width: 100%;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 0.65rem;
      margin-top: 0.5rem;
    }

    .pte-feedback-question-nav .btn {
      width: 100%;
      min-height: 42px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    @media (max-width: 575.98px) {
      .pte-feedback-question-nav {
        grid-template-columns: 1fr;
      }
    }

    .pte-feedback-chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
    }

    @media (max-width: 991.98px) {
      .pte-feedback-layout {
        grid-template-columns: 1fr;
      }

      .pte-feedback-sidebar {
        position: static;
        max-height: none;
      }

      .pte-feedback-layout.is-sidebar-collapsed .pte-feedback-sidebar {
        display: none;
      }
    }
  </style>

  <input type="hidden" id="pteFeedbackActionStateId" value="<%= actionStateId || '' %>">

  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
      <h1 class="page-heading size-md m-0"><%= title %></h1>
      <div class="small text-muted mt-1">
        <% if (attemptSkill) { %>
          Skill: <span class="text-capitalize"><%= attemptSkill %></span> |
        <% } %>
        Status: <span class="text-capitalize"><%= attemptStatus || '-' %></span>
      </div>
      <div class="small text-muted">Student: <strong><%= userLabel %></strong></div>
    </div>
    <div class="d-flex align-items-center">
      <a href="<%= dashboardHref %>" class="btn btn-filled btn-secondary btn-md">
        <i class="bi bi-speedometer2 me-1"></i> PTE Dashboard
      </a>
    </div>
  </div>

  <div class="d-flex align-items-center justify-content-end mb-3 flex-wrap">
    <div class="d-flex align-items-center flex-wrap">
      <a href="/pte/feedback/practice" class="btn btn-outline-secondary btn-md me-2 mb-2">
        <i class="bi bi-arrow-left me-1"></i> Back to List
      </a>
      <% if (!canEdit && canCreateFeedback) { %>
        <a href="/pte/feedback/practice/<%= encodeURIComponent(sessionId) %>/edit" class="btn btn-filled btn-success btn-md me-2 mb-2">
          <i class="bi bi-chat-left-text me-1"></i> Provide Feedback
        </a>
      <% } %>
      <% if (canEdit) { %>
        <a href="/pte/feedback/practice/<%= encodeURIComponent(sessionId) %>" class="btn btn-outline-primary btn-md me-2 mb-2">
          <i class="bi bi-eye me-1"></i> Read View
        </a>
        <button type="button" class="btn btn-filled btn-primary btn-md me-2 mb-2" id="pteFeedbackGenerateDetailedBtn" data-no-wait="true">
          <i class="bi bi-stars me-1"></i> Generate Detailed Feedback
        </button>
        <button
          type="button"
          class="btn btn-outline-primary btn-md me-2 mb-2"
          id="pteFeedbackOpenSavedDetailedBtn"
          data-no-wait="true"
          <%= savedDetailedFeedback && toText(savedDetailedFeedback.text) ? '' : 'disabled' %>>
          <i class="bi bi-journal-text me-1"></i> Open Saved Detailed Feedback
        </button>
      <% } %>
    </div>
  </div>

  <div class="alert alert-light border mb-3">
    <div class="row g-2 small">
      <div class="col-md-3"><strong>Total Questions:</strong> <%= Number(session?.totalQuestions || 0) %></div>
      <div class="col-md-3"><strong>Submitted:</strong> <%= Number(session?.submittedQuestions || 0) %></div>
      <div class="col-md-3"><strong>Feedback Count:</strong> <%= Number(session?.feedbackCount || 0) %></div>
      <div class="col-md-3"><strong>Started At:</strong> <%= session?.startedAt ? new Date(session.startedAt).toLocaleString() : '-' %></div>
    </div>
  </div>

  <% if (!rows.length) { %>
    <div class="alert alert-warning border">No question items were found for this practice session.</div>
  <% } %>

  <% if (rows.length) { %>
    <div class="pte-feedback-layout" id="pteFeedbackLayout">
      <aside class="pte-feedback-sidebar" id="pteFeedbackSidebar">
        <div class="pte-feedback-sidebar-head">Questions</div>
        <div class="pte-feedback-sidebar-list" id="pteFeedbackSidebarList">
          <% rows.forEach((item, index) => { %>
            <% const question = item?.question || {}; %>
            <% const itemId = String(item?.id || '').trim(); %>
            <% const questionTitle = toText(question?.title || item?.metadata?.questionTitle || `Question ${index + 1}`); %>
            <% const questionType = toText(question?.questionType || item?.questionType || ''); %>
            <% const statusLabel = formatStatusLabel(item?.status); %>
            <% const statusClass = formatStatusClass(item?.status); %>
            <% const hasFeedback = Boolean(toText(item?.latestFeedback || item?.feedbackProvidedAt)); %>
            <button
              type="button"
              class="pte-feedback-nav-btn<%= index === 0 ? ' is-active' : '' %>"
              data-feedback-nav-index="<%= index %>"
              data-item-id="<%= itemId %>"
              data-no-wait="true">
              <div class="pte-feedback-nav-row">
                <span class="pte-feedback-nav-title">Q<%= index + 1 %></span>
                <span class="badge <%= statusClass %> text-capitalize"><%= statusLabel %></span>
              </div>
              <div class="pte-feedback-nav-sub"><%= questionTitle || '-' %></div>
              <div class="pte-feedback-nav-sub"><%= formatQuestionTypeLabel(questionType) || '-' %></div>
              <div
                class="pte-feedback-nav-feedback<%= hasFeedback ? '' : ' d-none' %>"
                data-nav-feedback-flag="<%= itemId %>">
                <i class="bi bi-chat-left-text"></i> Feedback saved
              </div>
            </button>
          <% }) %>
        </div>
      </aside>

      <section class="pte-feedback-main">
        <div class="pte-feedback-controls d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
          <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm" id="pteFeedbackSidebarToggle" data-no-wait="true">
              <i class="bi bi-layout-sidebar me-1"></i> Toggle Question List
            </button>
            <div class="small text-muted" id="pteFeedbackActiveIndicator"></div>
          </div>
        </div>

        <div id="pteFeedbackQuestionPanels">
          <% rows.forEach((item, index) => { %>
            <% const question = item?.question || {}; %>
            <% const itemId = String(item?.id || '').trim(); %>
            <% const questionTitle = toText(question?.title || item?.metadata?.questionTitle || `Question ${index + 1}`); %>
            <% const questionType = toText(question?.questionType || item?.questionType || ''); %>
            <% const questionSkill = toText(question?.skill || item?.skill || ''); %>
            <% const statusLabel = formatStatusLabel(item?.status); %>
            <% const statusClass = formatStatusClass(item?.status); %>
            <% const metadata = isObject(item?.metadata) ? item.metadata : {}; %>
            <% const questionSnapshot = isObject(metadata?.questionSnapshot) ? metadata.questionSnapshot : {}; %>
            <% const questionPayload = isObject(question?.payload) ? question.payload : (isObject(questionSnapshot?.payload) ? questionSnapshot.payload : {}); %>
            <% const responsePayload = isObject(metadata?.responsePayload) ? metadata.responsePayload : {}; %>
            <% const normalizedQuestionType = normalizeQuestionType(questionType); %>
            <% const isListeningQuestion = isListeningQuestionType(normalizedQuestionType); %>
            <% const promptContext = buildPromptContext(item); %>
            <% const promptBodyText = toText(promptContext.bodies.join('\n\n')); %>
            <% const summary = (item?.responseSummary && typeof item.responseSummary === 'object') ? item.responseSummary : {}; %>
            <% const listeningAnswerView = isListeningQuestion ? buildListeningAnswerView(questionPayload, responsePayload, normalizedQuestionType) : null; %>
            <% const listeningPromptModel = isListeningQuestion ? buildListeningPromptModel(question, questionPayload, normalizedQuestionType) : null; %>
            <% const listeningRunnerResponse = isListeningQuestion ? buildListeningResponseRunnerModel(questionPayload, responsePayload, normalizedQuestionType) : null; %>
            <% const questionMediaRows = resolveQuestionMediaItems(question, promptContext.mediaRefs); %>
            <% const incorporatedMediaRefs = new Set((promptContext.mediaRefs || []).map((row) => toText(row).toLowerCase()).filter(Boolean)); %>
            <% const incorporatedMediaUrls = new Set((promptContext.mediaRefs || []).map((row) => toText(resolveQuestionMediaUrl(question, row)).toLowerCase()).filter(Boolean)); %>
            <% if (listeningPromptModel?.audioRef) { incorporatedMediaRefs.add(toText(listeningPromptModel.audioRef).toLowerCase()); } %>
            <% if (listeningPromptModel?.audioUrl) { incorporatedMediaUrls.add(toText(listeningPromptModel.audioUrl).toLowerCase()); } %>
            <%
              const questionMediaRowsForDisplay = questionMediaRows.filter((media) => {
                const mediaRefToken = toText(media?.ref).toLowerCase();
                const mediaUrlToken = toText(media?.url).toLowerCase();
                if (mediaRefToken && incorporatedMediaRefs.has(mediaRefToken)) return false;
                if (mediaUrlToken && incorporatedMediaUrls.has(mediaUrlToken)) return false;
                return true;
              });
            %>
            <% const artifactRows = Array.isArray(item?.artifacts) ? item.artifacts : []; %>
            <% const feedbackHtml = String(item?.latestFeedback || ''); %>
            <% const feedbackStamp = toText(item?.feedbackProvidedAt); %>
            <% const scoring = item?.metadata && typeof item.metadata === 'object' && item.metadata.scoring && typeof item.metadata.scoring === 'object' ? item.metadata.scoring : null; %>
            <% const scoringDraft = scoring?.feedbackDraft && typeof scoring.feedbackDraft === 'object' ? scoring.feedbackDraft : null; %>
            <% const scoringTraitRows = scoring ? buildScoringTraitRows(item, scoring) : []; %>

            <div
              class="card border-0 shadow-sm mb-3 pte-feedback-item-panel<%= index === 0 ? '' : ' d-none' %>"
              data-feedback-panel-index="<%= index %>"
              data-item-id="<%= itemId %>">
              <div class="card-header bg-light d-flex align-items-start justify-content-between flex-wrap gap-2">
                <div>
                  <div class="fw-bold"><%= index + 1 %>. <%= questionTitle || '-' %></div>
                  <div class="small text-muted">
                    <span class="text-capitalize"><%= questionSkill || '-' %></span>
                    | <%= formatQuestionTypeLabel(questionType) || '-' %>
                    | Item <span class="font-monospace"><%= itemId || '-' %></span>
                  </div>
                </div>
                <div class="text-end small">
                  <div class="text-capitalize">Status: <strong><span class="badge <%= statusClass %> text-capitalize"><%= statusLabel %></span></strong></div>
                  <div class="mt-1">Feedback At: <%= feedbackStamp || '-' %></div>
                </div>
              </div>
              <div class="card-body">
                <div class="row g-3">
                  <div class="col-lg-6">
                    <h6 class="fw-bold mb-2">Prompt Context</h6>
                    <div class="pte-feedback-prompt-box mb-2">
                      <div class="small text-muted fw-bold mb-1">Instruction</div>
                      <div class="small"><%- promptContext.instruction ? toParagraph(promptContext.instruction) : '<span class="text-muted">No instruction text.</span>' %></div>
                    </div>

                    <% if (promptContext.situations.length) { %>
                      <% promptContext.situations.forEach((row) => { %>
                        <div class="pte-feedback-situation-box mb-2">
                          <div class="small text-muted fw-bold mb-1">Situation</div>
                          <div class="small"><%- toParagraph(row) %></div>
                        </div>
                      <% }) %>
                    <% } %>

                    <div class="pte-feedback-prompt-box">
                      <div class="small text-muted fw-bold mb-1">Question / Task</div>
                      <div class="small"><%- promptBodyText ? toParagraph(promptBodyText) : '<span class="text-muted">No prompt text captured.</span>' %></div>
                    </div>

                    <% if (isListeningQuestion && listeningPromptModel) { %>
                      <div class="pte-feedback-runner-card">
                        <div class="small text-muted fw-bold mb-2">Practice Runner Listening View</div>
                        <div class="pte-feedback-audio-card">
                          <div class="small fw-bold mb-1">Listening Audio</div>
                          <% if (listeningPromptModel.audioUrl) { %>
                            <audio controls preload="metadata" class="w-100 mb-2">
                              <source src="<%= listeningPromptModel.audioUrl %>" type="audio/mpeg">
                            </audio>
                          <% } else { %>
                            <div class="small text-warning">Listening audio is not attached yet.</div>
                          <% } %>
                          <% if (listeningPromptModel.transcriptText) { %>
                            <details>
                              <summary class="small">Transcript</summary>
                              <div class="pte-feedback-response-box mt-1"><%- toParagraph(listeningPromptModel.transcriptText) %></div>
                            </details>
                          <% } %>
                        </div>
                        <% if (listeningPromptModel.stem) { %>
                          <div class="pte-feedback-response-box mb-2"><%- toParagraph(listeningPromptModel.stem) %></div>
                        <% } %>
                        <% if (normalizedQuestionType === 'listening_fill_in_blank' && listeningPromptModel.transcriptWithBlanks) { %>
                          <div class="small text-muted fw-bold mb-1">Transcript With Blanks</div>
                          <div class="pte-feedback-response-box"><%- toParagraph(listeningPromptModel.transcriptWithBlanks) %></div>
                        <% } %>
                        <% if (normalizedQuestionType === 'listening_select_missing_word' && listeningPromptModel.transcriptWithGap) { %>
                          <div class="small text-muted fw-bold mb-1">Transcript With Gap</div>
                          <div class="pte-feedback-response-box"><%- toParagraph(listeningPromptModel.transcriptWithGap) %></div>
                        <% } %>
                        <% if (normalizedQuestionType === 'listening_dictation' && listeningPromptModel.expectedTranscript) { %>
                          <div class="small text-muted fw-bold mb-1">Expected Transcript</div>
                          <div class="pte-feedback-response-box"><%- toParagraph(listeningPromptModel.expectedTranscript) %></div>
                        <% } %>
                      </div>
                    <% } %>

                    <% if (questionMediaRowsForDisplay.length) { %>
                      <div class="mt-2">
                        <div class="small text-muted fw-bold mb-1">Question Artifacts</div>
                        <% questionMediaRowsForDisplay.forEach((media) => { %>
                          <% const mediaUrl = toText(media?.url); %>
                          <% const mediaMime = toText(media?.mimeType).toLowerCase(); %>
                          <% const mediaName = toText(media?.name || media?.ref || 'Media'); %>
                          <div class="border rounded p-2 bg-white mb-2">
                            <div class="small fw-bold"><%= mediaName %></div>
                            <div class="x-small text-muted mb-1 font-monospace"><%= toText(media?.ref) || '-' %></div>
                            <% if (mediaUrl && (mediaMime.startsWith('audio/') || /\.(mp3|wav|m4a|ogg|webm)(\?|$)/i.test(mediaUrl))) { %>
                              <audio controls preload="metadata" class="w-100 mb-2">
                                <source src="<%= mediaUrl %>" type="<%= mediaMime || 'audio/mpeg' %>">
                              </audio>
                            <% } %>
                            <% if (mediaUrl && (mediaMime.startsWith('image/') || /\.(jpg|jpeg|png|webp|gif|bmp|svg)(\?|$)/i.test(mediaUrl))) { %>
                              <img src="<%= mediaUrl %>" alt="Question media" class="img-fluid rounded border mb-2">
                            <% } %>
                            <% if (mediaUrl) { %>
                              <a class="btn btn-outline-secondary btn-sm" href="<%= mediaUrl %>" target="_blank" rel="noopener">
                                <i class="bi bi-box-arrow-up-right me-1"></i> Open Question Artifact
                              </a>
                            <% } %>
                          </div>
                        <% }) %>
                      </div>
                    <% } else if (promptContext.mediaRefs.length && !isListeningQuestion) { %>
                      <div class="small text-muted mt-2">
                        Media references:
                        <% promptContext.mediaRefs.forEach((ref, refIndex) => { %>
                          <span class="font-monospace"><%= ref %></span><%= refIndex < (promptContext.mediaRefs.length - 1) ? ', ' : '' %>
                        <% }) %>
                      </div>
                    <% } %>
                  </div>

                  <div class="col-lg-6">
                    <h6 class="fw-bold mb-2">Response Summary</h6>
                    <div class="border rounded p-2 bg-light-subtle">
                      <div class="row g-2 small">
                        <div class="col-6"><strong>Kind:</strong> <%= toText(summary?.kind) || '-' %></div>
                        <div class="col-6"><strong>Words:</strong> <%= Number(summary?.wordCount || 0) %></div>
                        <div class="col-6"><strong>Text Length:</strong> <%= Number(summary?.textLength || 0) %></div>
                        <div class="col-6"><strong>Options:</strong> <%= Number(summary?.optionCount || 0) %></div>
                        <div class="col-6"><strong>Audio Sec:</strong> <%= Number(summary?.audioDurationSeconds || 0) %></div>
                        <div class="col-6"><strong>Artifacts:</strong> <%= Number(summary?.artifactCount || 0) %></div>
                        <div class="col-6"><strong>Seen Time:</strong> <%= Number(item?.totalSeenSeconds || item?.timeSpentSeconds || 0) %> sec</div>
                        <div class="col-6"><strong>Self Difficulty:</strong> <%= toText(item?.selfDifficultyRating) || '-' %></div>
                      </div>
                    </div>

                    <% if (isListeningQuestion) { %>
                      <div class="mt-2 border rounded p-2 bg-white">
                        <div class="small text-muted fw-bold mb-2">Listening Response (Runner Style)</div>
                        <% if (listeningRunnerResponse && (
                          normalizedQuestionType === 'listening_mcq_single'
                          || normalizedQuestionType === 'listening_mcq_multiple'
                          || normalizedQuestionType === 'listening_select_missing_word'
                        )) { %>
                          <div class="pte-feedback-choice-list mb-2">
                            <% listeningRunnerResponse.optionRows.forEach((row) => { %>
                              <% const isSelected = normalizedQuestionType === 'listening_mcq_single' || normalizedQuestionType === 'listening_select_missing_word' ? row.selected : row.checked; %>
                              <div class="pte-feedback-choice-item<%= isSelected ? ' is-selected' : '' %>">
                                <div class="pte-feedback-choice-key"><%= row.key %></div>
                                <div class="flex-grow-1">
                                  <div><%= row.text %></div>
                                  <% if (isSelected) { %>
                                    <div class="x-small text-success mt-1"><i class="bi bi-check-circle me-1"></i>Selected by student</div>
                                  <% } %>
                                </div>
                              </div>
                            <% }) %>
                          </div>
                        <% } %>

                        <% if (listeningRunnerResponse && (normalizedQuestionType === 'listening_summarize_spoken_text' || normalizedQuestionType === 'listening_dictation')) { %>
                          <div class="small fw-bold mb-1">Typed Response</div>
                          <div class="pte-feedback-response-box mb-2"><%- toParagraph(listeningRunnerResponse.responseText || '-') %></div>
                        <% } %>

                        <% if (listeningRunnerResponse && normalizedQuestionType === 'listening_fill_in_blank') { %>
                          <div class="small fw-bold mb-1">Filled Transcript Preview</div>
                          <div class="pte-feedback-response-box mb-2"><%- toParagraph(listeningRunnerResponse.fillPreview || '-') %></div>
                          <% if (listeningRunnerResponse.fillEntries.length) { %>
                            <div class="pte-feedback-kv-table mb-2">
                              <% listeningRunnerResponse.fillEntries.forEach((row) => { %>
                                <div class="pte-feedback-kv-row">
                                  <div class="pte-feedback-kv-key"><%= row.key %></div>
                                  <div class="pte-feedback-kv-value"><%= row.value || '-' %></div>
                                </div>
                              <% }) %>
                            </div>
                          <% } %>
                        <% } %>

                        <% if (listeningRunnerResponse && normalizedQuestionType === 'listening_highlight_incorrect_words') { %>
                          <div class="small fw-bold mb-1">Displayed Transcript</div>
                          <div class="pte-feedback-response-box mb-2"><%- toParagraph(listeningRunnerResponse.hiwTranscript || '-') %></div>
                          <div class="small fw-bold mb-1">Highlighted Words By Student</div>
                          <% if (listeningRunnerResponse.hiwSelectedWords.length) { %>
                            <div class="pte-feedback-chip-row mb-2">
                              <% listeningRunnerResponse.hiwSelectedWords.forEach((word) => { %>
                                <span class="badge bg-light text-dark border"><%= word %></span>
                              <% }) %>
                            </div>
                          <% } else { %>
                            <div class="small text-muted mb-2">No highlighted words captured.</div>
                          <% } %>
                        <% } %>

                        <% if (listeningRunnerResponse && normalizedQuestionType === 'listening_matching') { %>
                          <div class="small fw-bold mb-1">Matched Pairs</div>
                          <% if (listeningRunnerResponse.matchingPairs.length) { %>
                            <div class="pte-feedback-kv-table mb-2">
                              <% listeningRunnerResponse.matchingPairs.forEach((pair) => { %>
                                <div class="pte-feedback-kv-row">
                                  <div class="pte-feedback-kv-key"><%= pair.left %></div>
                                  <div class="pte-feedback-kv-value"><%= pair.right %></div>
                                </div>
                              <% }) %>
                            </div>
                          <% } else { %>
                            <div class="small text-muted mb-2">No matching pairs captured.</div>
                          <% } %>
                        <% } %>

                        <% if ((!listeningRunnerResponse || listeningRunnerResponse.missing) && (!listeningAnswerView || listeningAnswerView.missing)) { %>
                          <div class="small text-warning">No clear listening answer is captured for this item yet.</div>
                        <% } %>
                      </div>
                    <% } %>

                    <% if (scoring) { %>
                      <div class="mt-2 border rounded p-2 bg-white">
                        <div class="d-flex align-items-center justify-content-between gap-2 mb-1">
                          <div class="small text-muted fw-bold">Automatic Scoring Evidence</div>
                          <span class="badge <%= scoring.status === 'scored' ? 'bg-success' : (scoring.status === 'needs_evidence' ? 'bg-warning text-dark' : 'bg-danger') %> text-capitalize"><%= String(scoring.status || '-').replace(/_/g, ' ') %></span>
                        </div>
                        <div class="row g-2 small mb-2">
                          <div class="col-6"><strong>Score:</strong> <%= Number(item?.scoreFinal || 0).toFixed(2) %> / <%= Number(item?.maxScore || 0).toFixed(2) %></div>
                          <div class="col-6"><strong>Raw:</strong> <%= Number(item?.scoreRaw || 0).toFixed(2) %></div>
                          <div class="col-6"><strong>Percentage:</strong> <%= Number(item?.percentage || 0).toFixed(2) %>%</div>
                          <% if (Number(scoring?.alignment?.errorCount || 0) > 0) { %>
                            <div class="col-6"><strong>Errors:</strong> <%= Number(scoring?.alignment?.errorCount || 0) %></div>
                          <% } %>
                          <% if (Number(scoring?.speechMetrics?.estimatedWpm || 0) > 0) { %>
                            <div class="col-6"><strong>WPM:</strong> <%= Number(scoring?.speechMetrics?.estimatedWpm || 0).toFixed(2) %></div>
                          <% } %>
                        </div>
                        <% if (scoringTraitRows.length) { %>
                          <div class="small fw-bold mb-1">Trait Scores</div>
                          <div class="row g-2 small mb-2">
                            <% scoringTraitRows.forEach((trait) => { %>
                              <div class="col-6">
                                <strong><%= trait.label || trait.key %>:</strong>
                                <%= Number(trait.score || 0).toFixed(2) %>
                                <% if (trait.max > 0) { %>/ <%= Number(trait.max || 0).toFixed(2) %><% } %>
                              </div>
                            <% }) %>
                          </div>
                        <% } %>
                        <% if (scoringDraft) { %>
                          <div class="small fw-bold mb-1">Draft Feedback</div>
                          <div class="small"><%- scoringDraft.summary ? toParagraph(scoringDraft.summary) : '' %></div>
                          <% if (Array.isArray(scoringDraft.improvements) && scoringDraft.improvements.length) { %>
                            <ul class="small mb-1 ps-3">
                              <% scoringDraft.improvements.slice(0, 3).forEach((row) => { %>
                                <li><%= row %></li>
                              <% }) %>
                            </ul>
                          <% } %>
                          <% if (scoringDraft.nextPracticeAction) { %>
                            <div class="small"><strong>Next:</strong> <%- toParagraph(scoringDraft.nextPracticeAction) %></div>
                          <% } %>
                        <% } %>
                      </div>
                    <% } %>

                    <div class="mt-2">
                      <div class="small text-muted fw-bold mb-1">Response Artifacts</div>
                      <% if (!artifactRows.length) { %>
                        <div class="small text-muted">No linked artifacts.</div>
                      <% } %>
                      <% artifactRows.forEach((artifact) => { %>
                        <div class="border rounded p-2 bg-white mb-2">
                          <div class="small fw-bold"><%= toText(artifact?.name) || 'Artifact' %></div>
                          <div class="x-small text-muted mb-1"><%= toText(artifact?.artifactType) || '-' %> | <%= toText(artifact?.mimeType) || '-' %></div>
                          <% if (String(artifact?.artifactType || '').toLowerCase() === 'audio' && artifact?.url) { %>
                            <audio controls preload="metadata" class="w-100 mb-2">
                              <source src="<%= artifact.url %>" type="<%= artifact.mimeType || 'audio/webm' %>">
                            </audio>
                          <% } %>
                          <% if (artifact?.url) { %>
                            <a class="btn btn-outline-secondary btn-sm" href="<%= artifact.url %>" target="_blank" rel="noopener">
                              <i class="bi bi-box-arrow-up-right me-1"></i> Open Artifact
                            </a>
                          <% } %>
                        </div>
                      <% }) %>
                    </div>
                  </div>
                </div>

                <hr>
                <h6 class="fw-bold mb-2">Teacher / Facilitator Feedback</h6>
                <script type="application/json" id="feedback_payload_<%= itemId %>"><%- JSON.stringify(feedbackHtml || '').replace(/</g, '\\u003c') %></script>
                <% if (!canEdit) { %>
                  <div class="border rounded p-3 bg-white pte-feedback-sanitized" data-feedback-key="<%= itemId %>"></div>
                <% } else { %>
                  <div class="border rounded p-2 bg-white">
                    <div class="pte-feedback-editor" id="editor_<%= itemId %>" data-feedback-key="<%= itemId %>"></div>
                  </div>
                  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mt-2">
                    <div class="small text-muted" id="feedback_meta_<%= itemId %>">
                      <% if (feedbackStamp) { %>
                        Last saved at <%= new Date(feedbackStamp).toLocaleString() %>.
                      <% } else { %>
                        Not saved yet.
                      <% } %>
                    </div>
                    <button
                      type="button"
                      class="btn btn-filled btn-success btn-sm pte-feedback-save-btn"
                      data-item-id="<%= itemId %>"
                      data-no-wait="true">
                      <i class="bi bi-check2-square me-1"></i> Save Feedback
                    </button>
                  </div>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>

        <div class="pte-feedback-question-nav">
          <button type="button" class="btn btn-outline-secondary btn-md" id="pteFeedbackPrevBtn" data-no-wait="true">
            <i class="bi bi-arrow-left me-1"></i> Previous Question
          </button>
          <button type="button" class="btn btn-outline-secondary btn-md" id="pteFeedbackNextBtn" data-no-wait="true">
            Next Question <i class="bi bi-arrow-right ms-1"></i>
          </button>
        </div>
      </section>
    </div>
  <% } %>
</div>

<div class="modal fade" id="pteFeedbackDetailedModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content border-0 shadow">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-stars me-2"></i>Detailed Student Feedback</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="small text-muted mb-2" id="pteFeedbackDetailedMeta">Generate feedback to view details.</div>
        <textarea
          class="form-control size-md font-monospace"
          id="pteFeedbackDetailedOutput"
          rows="20"
          readonly
          placeholder="Generated detailed feedback will appear here..."></textarea>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
        <% if (canEdit) { %>
          <button type="button" class="btn btn-filled btn-success" id="pteFeedbackDetailedSaveBtn" data-no-wait="true">
            <i class="bi bi-save me-1"></i> Save Detailed Feedback
          </button>
        <% } %>
        <button type="button" class="btn btn-filled btn-primary" id="pteFeedbackDetailedCopyBtn" data-no-wait="true">
          <i class="bi bi-clipboard me-1"></i> Copy
        </button>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.6/dist/purify.min.js"></script>
<% if (canEdit) { %>
  <script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<% } %>

<script>
(() => {
  const canEdit = <%- canEdit ? 'true' : 'false' %>;
  const sessionId = <%- JSON.stringify(sessionId || '').replace(/</g, '\\u003c') %>;
  const initialSavedDetailedFeedback = <%- JSON.stringify(savedDetailedFeedback || null).replace(/</g, '\\u003c') %>;
  const actionStateId = String(document.getElementById('pteFeedbackActionStateId')?.value || '').trim();

  const layoutNode = document.getElementById('pteFeedbackLayout');
  const panelNodes = Array.from(document.querySelectorAll('[data-feedback-panel-index]'));
  const navNodes = Array.from(document.querySelectorAll('[data-feedback-nav-index]'));
  const indicatorNode = document.getElementById('pteFeedbackActiveIndicator');
  const prevBtn = document.getElementById('pteFeedbackPrevBtn');
  const nextBtn = document.getElementById('pteFeedbackNextBtn');
  const sidebarToggleBtn = document.getElementById('pteFeedbackSidebarToggle');
  const generateDetailedBtn = document.getElementById('pteFeedbackGenerateDetailedBtn');
  const openSavedDetailedBtn = document.getElementById('pteFeedbackOpenSavedDetailedBtn');
  const detailedModalEl = document.getElementById('pteFeedbackDetailedModal');
  const detailedOutputEl = document.getElementById('pteFeedbackDetailedOutput');
  const detailedMetaEl = document.getElementById('pteFeedbackDetailedMeta');
  const detailedSaveBtn = document.getElementById('pteFeedbackDetailedSaveBtn');
  const detailedCopyBtn = document.getElementById('pteFeedbackDetailedCopyBtn');
  let activeIndex = 0;
  let detailedModal = null;
  let latestDetailedPayload = null;
  let savedDetailedPayload = (initialSavedDetailedFeedback && typeof initialSavedDetailedFeedback === 'object')
    ? initialSavedDetailedFeedback
    : null;

  function sanitizeHtml(html) {
    if (window.DOMPurify && typeof window.DOMPurify.sanitize === 'function') {
      return window.DOMPurify.sanitize(String(html || ''));
    }
    return String(html || '');
  }

  function readFeedbackPayloadByKey(key) {
    const node = document.getElementById('feedback_payload_' + key);
    if (!node) return '';
    try {
      return String(JSON.parse(node.textContent || '""') || '');
    } catch (_) {
      return '';
    }
  }

  function setIndicatorText() {
    if (!indicatorNode) return;
    if (!panelNodes.length) {
      indicatorNode.textContent = '';
      return;
    }
    indicatorNode.textContent = `Question ${activeIndex + 1} of ${panelNodes.length}`;
  }

  function setNavButtonsState() {
    if (prevBtn) prevBtn.disabled = activeIndex <= 0;
    if (nextBtn) nextBtn.disabled = activeIndex >= (panelNodes.length - 1);
  }

  function setActiveIndex(nextIndex) {
    if (!panelNodes.length) return;
    const safeIndex = Math.max(0, Math.min(panelNodes.length - 1, Number(nextIndex || 0)));
    activeIndex = safeIndex;

    panelNodes.forEach((panel) => {
      const index = Number(panel.getAttribute('data-feedback-panel-index'));
      const isActive = index === safeIndex;
      panel.classList.toggle('d-none', !isActive);
      panel.setAttribute('data-active', isActive ? '1' : '0');
    });

    navNodes.forEach((node) => {
      const index = Number(node.getAttribute('data-feedback-nav-index'));
      node.classList.toggle('is-active', index === safeIndex);
    });

    setIndicatorText();
    setNavButtonsState();
  }

  function setSidebarCollapsed(collapsed) {
    if (!layoutNode) return;
    layoutNode.classList.toggle('is-sidebar-collapsed', collapsed);
  }

  function getDetailedModal() {
    if (!detailedModalEl || !window.bootstrap || typeof window.bootstrap.Modal !== 'function') return null;
    if (!detailedModal) {
      detailedModal = new window.bootstrap.Modal(detailedModalEl);
    }
    return detailedModal;
  }

  function setDetailedOutputText(text = '', meta = '') {
    if (detailedOutputEl) detailedOutputEl.value = String(text || '').trim();
    if (detailedMetaEl) detailedMetaEl.textContent = String(meta || '').trim() || 'Generated detailed feedback.';
  }

  function hasSavedDetailedFeedback() {
    return Boolean(savedDetailedPayload && String(savedDetailedPayload.text || '').trim());
  }

  function updateDetailedButtonsState() {
    if (openSavedDetailedBtn) {
      openSavedDetailedBtn.disabled = !hasSavedDetailedFeedback();
    }
    if (detailedSaveBtn) {
      const hasGenerated = Boolean(latestDetailedPayload && String(latestDetailedPayload.feedback || '').trim());
      detailedSaveBtn.disabled = !hasGenerated;
    }
  }

  function buildDetailedMetaText(payload = {}, { saved = false } = {}) {
    const source = (payload && typeof payload === 'object') ? payload : {};
    const provider = (source.provider && typeof source.provider === 'object') ? source.provider : {};
    const warningRows = Array.isArray(source.warnings)
      ? source.warnings.map((row) => String(row || '').trim()).filter(Boolean)
      : [];
    const providerLabel = [
      String(provider.providerId || '').trim(),
      String(provider.modelUsed || '').trim()
    ].filter(Boolean).join(' / ');
    const rows = [];
    if (source.generatedAt) rows.push(`Generated at: ${new Date(source.generatedAt).toLocaleString()}`);
    if (saved && source.savedAt) rows.push(`Saved at: ${new Date(source.savedAt).toLocaleString()}`);
    rows.push(providerLabel ? `Provider: ${providerLabel}` : 'Provider: Deterministic fallback');
    if (warningRows.length) rows.push(`Warnings: ${warningRows.join(' | ')}`);
    return rows.join(' | ');
  }

  function showDetailedPayload(payload = {}, options = {}) {
    const source = (payload && typeof payload === 'object') ? payload : {};
    const text = String(source.feedback || source.text || '').trim();
    const meta = buildDetailedMetaText(source, options);
    setDetailedOutputText(text || 'No detailed feedback was returned.', meta);
  }

  document.querySelectorAll('.pte-feedback-sanitized').forEach((node) => {
    const key = String(node.getAttribute('data-feedback-key') || '').trim();
    const raw = readFeedbackPayloadByKey(key);
    const clean = sanitizeHtml(raw);
    node.innerHTML = clean || '<div class="text-muted">No feedback has been provided yet.</div>';
  });

  if (navNodes.length) {
    navNodes.forEach((node) => {
      node.addEventListener('click', () => {
        const index = Number(node.getAttribute('data-feedback-nav-index'));
        setActiveIndex(index);
      });
    });
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      if (activeIndex <= 0) return;
      setActiveIndex(activeIndex - 1);
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      if (activeIndex >= panelNodes.length - 1) return;
      setActiveIndex(activeIndex + 1);
    });
  }

  if (sidebarToggleBtn) {
    sidebarToggleBtn.addEventListener('click', () => {
      if (!layoutNode) return;
      const next = !layoutNode.classList.contains('is-sidebar-collapsed');
      setSidebarCollapsed(next);
    });
  }

  if (hasSavedDetailedFeedback()) {
    const savedText = String(savedDetailedPayload.text || '').trim();
    latestDetailedPayload = {
      feedback: savedText,
      generatedAt: String(savedDetailedPayload.generatedAt || '').trim(),
      provider: (savedDetailedPayload.provider && typeof savedDetailedPayload.provider === 'object') ? savedDetailedPayload.provider : null,
      warnings: Array.isArray(savedDetailedPayload.warnings) ? savedDetailedPayload.warnings : [],
      evidenceSummary: (savedDetailedPayload.evidenceSummary && typeof savedDetailedPayload.evidenceSummary === 'object')
        ? savedDetailedPayload.evidenceSummary
        : null,
      savedAt: String(savedDetailedPayload.savedAt || '').trim(),
      revisionNo: Number(savedDetailedPayload.revisionNo || 0)
    };
    showDetailedPayload({
      text: savedText,
      generatedAt: savedDetailedPayload.generatedAt,
      provider: savedDetailedPayload.provider,
      warnings: savedDetailedPayload.warnings,
      savedAt: savedDetailedPayload.savedAt
    }, { saved: true });
  }

  if (openSavedDetailedBtn) {
    openSavedDetailedBtn.addEventListener('click', () => {
      if (!hasSavedDetailedFeedback()) return;
      showDetailedPayload({
        text: savedDetailedPayload.text,
        generatedAt: savedDetailedPayload.generatedAt,
        provider: savedDetailedPayload.provider,
        warnings: savedDetailedPayload.warnings,
        savedAt: savedDetailedPayload.savedAt
      }, { saved: true });
      const modal = getDetailedModal();
      if (modal) modal.show();
    });
  }

  if (detailedCopyBtn) {
    detailedCopyBtn.addEventListener('click', async () => {
      const text = String(detailedOutputEl?.value || '').trim();
      if (!text) return;
      try {
        if (navigator?.clipboard?.writeText) {
          await navigator.clipboard.writeText(text);
        }
        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: 'Copied',
            message: 'Detailed feedback was copied to clipboard.',
            icon: 'success',
            buttons: [{ text: 'OK', class: 'btn-success' }]
          });
        }
      } catch (_) {
        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: 'Copy Failed',
            message: 'Unable to copy automatically. Please copy from the textarea.',
            icon: 'warning',
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
        }
      }
    });
  }

  if (generateDetailedBtn) {
    generateDetailedBtn.addEventListener('click', async () => {
      if (!sessionId) return;
      const original = generateDetailedBtn.innerHTML;
      generateDetailedBtn.disabled = true;
      generateDetailedBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generating...';
      try {
        const response = await fetch(
          `/pte/feedback/practice/${encodeURIComponent(sessionId)}/generate-detailed-feedback?actionStateId=${encodeURIComponent(actionStateId)}`,
          {
            method: 'POST',
            credentials: 'include',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json',
              'X-AJAX-Request': 'true'
            },
            body: JSON.stringify({
              actionStateId,
              source: {
                module: 'pte_feedback_practice_ui',
                eventType: 'generate_detailed_feedback_clicked',
                eventId: `PTE-FEEDBACK-DETAILED-${Date.now()}`
              }
            })
          }
        );
        const result = await response.json().catch(() => null);
        if (!response.ok || !result || result.status !== 'success') {
          throw new Error((result && result.message) || `Generation failed with status ${response.status}.`);
        }

        const payload = (result.results && typeof result.results === 'object') ? result.results : {};
        const feedbackText = String(payload.feedback || '').trim();
        const warningRows = Array.isArray(payload.warnings)
          ? payload.warnings.map((row) => String(row || '').trim()).filter(Boolean)
          : [];
        latestDetailedPayload = {
          feedback: feedbackText,
          generatedAt: String(payload.generatedAt || '').trim(),
          provider: payload.provider && typeof payload.provider === 'object' ? payload.provider : null,
          warnings: warningRows,
          evidenceSummary: payload.evidenceSummary && typeof payload.evidenceSummary === 'object' ? payload.evidenceSummary : null
        };
        showDetailedPayload(latestDetailedPayload, { saved: false });
        updateDetailedButtonsState();
        const modal = getDetailedModal();
        if (modal) modal.show();
      } catch (error) {
        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: 'Generation Failed',
            message: error.message || 'Unable to generate detailed feedback.',
            icon: 'error',
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        } else {
          alert(error.message || 'Unable to generate detailed feedback.');
        }
      } finally {
        generateDetailedBtn.disabled = false;
        generateDetailedBtn.innerHTML = original;
      }
    });
  }

  if (detailedSaveBtn) {
    detailedSaveBtn.addEventListener('click', async () => {
      const feedbackText = String(detailedOutputEl?.value || '').trim();
      if (!feedbackText) {
        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: 'Nothing To Save',
            message: 'Generate detailed feedback first, then save it.',
            icon: 'warning',
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
        }
        return;
      }
      const sourcePayload = (latestDetailedPayload && typeof latestDetailedPayload === 'object')
        ? latestDetailedPayload
        : { feedback: feedbackText };
      const original = detailedSaveBtn.innerHTML;
      detailedSaveBtn.disabled = true;
      detailedSaveBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
      try {
        const response = await fetch(
          `/pte/feedback/practice/${encodeURIComponent(sessionId)}/save-detailed-feedback?actionStateId=${encodeURIComponent(actionStateId)}`,
          {
            method: 'POST',
            credentials: 'include',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json',
              'X-AJAX-Request': 'true'
            },
            body: JSON.stringify({
              actionStateId,
              feedback: feedbackText,
              generatedAt: sourcePayload.generatedAt || '',
              provider: sourcePayload.provider || null,
              warnings: Array.isArray(sourcePayload.warnings) ? sourcePayload.warnings : [],
              evidenceSummary: sourcePayload.evidenceSummary || null,
              source: {
                module: 'pte_feedback_practice_ui',
                eventType: 'save_detailed_feedback_clicked',
                eventId: `PTE-FEEDBACK-DETAILED-SAVE-${Date.now()}`
              }
            })
          }
        );
        const result = await response.json().catch(() => null);
        if (!response.ok || !result || result.status !== 'success') {
          throw new Error((result && result.message) || `Save failed with status ${response.status}.`);
        }
        const saved = (result?.results?.savedDetailedFeedback && typeof result.results.savedDetailedFeedback === 'object')
          ? result.results.savedDetailedFeedback
          : null;
        if (saved) {
          savedDetailedPayload = saved;
          latestDetailedPayload = {
            feedback: String(saved.text || feedbackText).trim(),
            generatedAt: String(saved.generatedAt || sourcePayload.generatedAt || '').trim(),
            provider: saved.provider || sourcePayload.provider || null,
            warnings: Array.isArray(saved.warnings) ? saved.warnings : (Array.isArray(sourcePayload.warnings) ? sourcePayload.warnings : []),
            evidenceSummary: saved.evidenceSummary || sourcePayload.evidenceSummary || null,
            savedAt: String(saved.savedAt || '').trim(),
            revisionNo: Number(saved.revisionNo || 0)
          };
          showDetailedPayload({
            text: saved.text || feedbackText,
            generatedAt: saved.generatedAt || sourcePayload.generatedAt || '',
            provider: saved.provider || sourcePayload.provider || null,
            warnings: saved.warnings || sourcePayload.warnings || [],
            savedAt: saved.savedAt || ''
          }, { saved: true });
        }
        updateDetailedButtonsState();
        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: 'Saved',
            message: 'Detailed feedback was saved to this practice session.',
            icon: 'success',
            buttons: [{ text: 'OK', class: 'btn-success' }]
          });
        }
      } catch (error) {
        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: 'Save Failed',
            message: error.message || 'Unable to save detailed feedback.',
            icon: 'error',
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        } else {
          alert(error.message || 'Unable to save detailed feedback.');
        }
      } finally {
        detailedSaveBtn.disabled = false;
        detailedSaveBtn.innerHTML = original;
      }
    });
  }

  updateDetailedButtonsState();

  setActiveIndex(0);

  if (!canEdit) return;
  if (typeof window.Quill !== 'function') return;

  const editors = new Map();
  const toolbar = [
    ['bold', 'italic', 'underline', 'strike'],
    [{ list: 'ordered' }, { list: 'bullet' }],
    [{ header: [1, 2, 3, false] }],
    [{ color: [] }, { background: [] }],
    ['blockquote', 'code-block'],
    ['clean']
  ];

  document.querySelectorAll('.pte-feedback-editor').forEach((node) => {
    const id = String(node.id || '').replace(/^editor_/, '');
    const key = String(node.getAttribute('data-feedback-key') || '').trim();
    const raw = readFeedbackPayloadByKey(key || id);
    const editor = new Quill(node, {
      theme: 'snow',
      modules: { toolbar }
    });
    editor.root.innerHTML = sanitizeHtml(raw);
    editors.set(id, editor);
  });

  function showSavedFlag(itemId) {
    document.querySelectorAll('[data-nav-feedback-flag]').forEach((node) => {
      if (String(node.getAttribute('data-nav-feedback-flag') || '') !== String(itemId || '')) return;
      node.classList.remove('d-none');
    });
  }

  async function saveFeedback(itemId, button) {
    const editor = editors.get(itemId);
    if (!editor) return;
    const feedback = String(editor.root.innerHTML || '').trim();
    const payload = {
      actionStateId,
      feedback,
      source: {
        module: 'pte_feedback_practice_ui',
        eventType: 'feedback_saved',
        eventId: `PTE-FEEDBACK-PRACTICE-${itemId}-${Date.now()}`
      }
    };

    const original = button.innerHTML;
    button.disabled = true;
    button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

    try {
      const response = await fetch(
        `/pte/feedback/practice/${encodeURIComponent(sessionId)}/items/${encodeURIComponent(itemId)}/feedback?actionStateId=${encodeURIComponent(actionStateId)}`,
        {
          method: 'POST',
          credentials: 'include',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'X-AJAX-Request': 'true'
          },
          body: JSON.stringify(payload)
        }
      );
      const result = await response.json().catch(() => null);
      if (!response.ok || !result || result.status !== 'success') {
        throw new Error((result && result.message) || ('Save failed with status ' + response.status + '.'));
      }
      const item = result?.results?.item || {};
      const metaNode = document.getElementById('feedback_meta_' + itemId);
      if (metaNode) {
        const stamp = String(item.feedbackProvidedAt || '').trim();
        metaNode.textContent = stamp
          ? ('Last saved at ' + new Date(stamp).toLocaleString() + '.')
          : 'Feedback saved.';
      }
      showSavedFlag(itemId);
      if (typeof window.showMessageModal === 'function') {
        await window.showMessageModal({
          title: 'Saved',
          message: 'Feedback was saved successfully.',
          icon: 'success',
          buttons: [{ text: 'OK', class: 'btn-primary' }]
        });
      }
    } catch (error) {
      if (typeof window.showMessageModal === 'function') {
        await window.showMessageModal({
          title: 'Save Failed',
          message: error.message || 'Unable to save feedback.',
          icon: 'error',
          buttons: [{ text: 'OK', class: 'btn-danger' }]
        });
      } else {
        alert(error.message || 'Unable to save feedback.');
      }
    } finally {
      button.disabled = false;
      button.innerHTML = original;
    }
  }

  document.querySelectorAll('.pte-feedback-save-btn').forEach((button) => {
    button.addEventListener('click', () => {
      const itemId = String(button.getAttribute('data-item-id') || '').trim();
      if (!itemId) return;
      saveFeedback(itemId, button);
    });
  });
})();
</script>
