<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'PTE Test Preview' %></title>
  <style>
    :root {
      --bg-page: #f2f6fb;
      --panel: #ffffff;
      --border: #d6dfec;
      --text: #10253f;
      --muted: #60748d;
      --primary: #1f4f96;
      --primary-soft: #e9f1ff;
      --success: #198754;
      --warning-bg: #fff3cd;
      --warning-border: #ffe69c;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: Calibri, "Segoe UI", Arial, sans-serif;
      background: var(--bg-page);
      color: var(--text);
    }

    .shell {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .topbar {
      background: linear-gradient(110deg, #0d326f 0%, #1f4f96 100%);
      color: #fff;
      padding: 14px 18px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .topbar .title {
      font-size: 22px;
      font-weight: 700;
      line-height: 1.1;
    }

    .topbar .meta {
      font-size: 12px;
      opacity: .9;
      margin-top: 4px;
    }

    .btn {
      border: 1px solid rgba(255, 255, 255, .65);
      border-radius: 8px;
      background: transparent;
      color: #fff;
      padding: 8px 12px;
      font-size: 13px;
      font-weight: 700;
      text-decoration: none;
      display: inline-block;
    }

    .content {
      width: min(1400px, 96%);
      margin: 16px auto;
      display: grid;
      gap: 12px;
    }

    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(8, 35, 73, .05);
      overflow: hidden;
    }

    .panel-head {
      padding: 12px 14px;
      border-bottom: 1px solid var(--border);
      background: var(--primary-soft);
    }

    .panel-title {
      font-size: 20px;
      font-weight: 700;
      margin: 0;
    }

    .panel-subtitle {
      margin-top: 4px;
      font-size: 13px;
      color: var(--muted);
    }

    .panel-body {
      padding: 12px 14px;
    }

    .skill-panel {
      border: 1px solid var(--border);
      border-radius: 10px;
      margin-bottom: 12px;
      overflow: hidden;
    }

    .skill-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      padding: 10px 12px;
      background: #f8fbff;
      border-bottom: 1px solid var(--border);
      font-size: 16px;
      font-weight: 700;
      text-transform: capitalize;
    }

    .skill-count {
      font-size: 12px;
      color: var(--muted);
      font-weight: 700;
      text-transform: none;
    }

    .question-list {
      list-style: decimal;
      margin: 0;
      padding: 12px 16px 12px 34px;
    }

    .question-item {
      margin-bottom: 10px;
      padding-bottom: 10px;
      border-bottom: 1px dashed #d8e1ef;
    }

    .question-item:last-child {
      margin-bottom: 0;
      padding-bottom: 0;
      border-bottom: none;
    }

    .question-title {
      font-weight: 700;
      font-size: 15px;
      margin-bottom: 3px;
    }

    .question-meta {
      font-size: 12px;
      color: var(--muted);
      line-height: 1.4;
    }

    .badge {
      display: inline-block;
      border-radius: 999px;
      padding: 2px 8px;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .02em;
      margin-left: 6px;
    }

    .badge-published {
      background: #e7f6ee;
      border: 1px solid #c0ead3;
      color: var(--success);
    }

    .badge-retired {
      background: var(--warning-bg);
      border: 1px solid var(--warning-border);
      color: #8a6d1f;
    }

    .alert-retired {
      background: var(--warning-bg);
      border: 1px solid var(--warning-border);
      border-radius: 8px;
      padding: 8px 10px;
      margin-top: 6px;
      font-size: 12px;
      color: #8a6d1f;
    }

    .empty {
      font-size: 13px;
      color: var(--muted);
      padding: 12px;
    }
  </style>
</head>
<body>
  <%
    const testRow = (test && typeof test === 'object') ? test : {};
    const allocations = (testRow.allocations && typeof testRow.allocations === 'object') ? testRow.allocations : {};
    const skillOrder = ['speaking', 'writing', 'reading', 'listening'];
    const formatQuestionTypeLabel = (value) => String(value || '')
      .trim()
      .toLowerCase()
      .split('_')
      .filter(Boolean)
      .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
      .join(' ');
  %>
  <div class="shell">
    <header class="topbar">
      <div>
        <div class="title">PTE Test Preview</div>
        <div class="meta">Candidate Exam Flow Snapshot</div>
      </div>
      <a href="/pte/tests" class="btn">Back to Tests</a>
    </header>

    <main class="content">
      <section class="panel">
        <div class="panel-head">
          <h1 class="panel-title"><%= testRow.title || 'Untitled Test' %></h1>
          <div class="panel-subtitle">
            Code: <span class="font-monospace"><%= testRow.code || '-' %></span>
            <% if (testRow.description) { %>
              | <%= testRow.description %>
            <% } %>
          </div>
        </div>
        <div class="panel-body">
          <% if (testRow.instructions) { %>
            <div class="panel-subtitle" style="font-size:14px;color:#274568;"><%= testRow.instructions %></div>
          <% } else { %>
            <div class="panel-subtitle">No additional instructions.</div>
          <% } %>
        </div>
      </section>

      <section class="panel">
        <div class="panel-head">
          <h2 class="panel-title" style="font-size:18px;">Skill Allocation</h2>
          <div class="panel-subtitle">Published questions can be allocated; retired linked questions are highlighted.</div>
        </div>
        <div class="panel-body">
          <% skillOrder.forEach((skill) => { %>
            <% const rows = Array.isArray(allocations[skill]) ? allocations[skill] : []; %>
            <div class="skill-panel">
              <div class="skill-head">
                <span><%= skill %></span>
                <span class="skill-count"><%= rows.length %> question(s)</span>
              </div>
              <% if (!rows.length) { %>
                <div class="empty">No questions in this skill.</div>
              <% } else { %>
                <ol class="question-list">
                  <% rows.forEach((row) => { %>
                    <% const status = String(row.currentStatus || row.statusAtSelection || '').toLowerCase(); %>
                    <li class="question-item">
                      <div class="question-title">
                        <%= row.questionTitle || '-' %>
                        <% if (status === 'retired') { %>
                          <span class="badge badge-retired">Retired</span>
                        <% } else { %>
                          <span class="badge badge-published">Published</span>
                        <% } %>
                      </div>
                      <div class="question-meta">
                        Type: <%= formatQuestionTypeLabel(row.questionType) || '-' %>
                        | Code: <%= row.questionCode || '-' %>
                        | ID: <span class="font-monospace"><%= row.questionVersionId || '-' %></span>
                      </div>
                      <% if (status === 'retired') { %>
                        <div class="alert-retired">
                          This question is now retired and is kept in this test by design.
                        </div>
                      <% } %>
                    </li>
                  <% }) %>
                </ol>
              <% } %>
            </div>
          <% }) %>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
