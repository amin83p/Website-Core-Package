              : '<div class="prompt-box small muted">Audio asset is not attached yet.</div>';
            if (toInt(payload.recommendedTimeMinutes, 0) > 0) {
              questionHtml += '<div class="timer-chip">Time ' + toInt(payload.recommendedTimeMinutes, 0) + ' min</div>';
            }
            questionHtml += '<div class="small muted mb-12">Word limit: ' + toInt(payload.minWords, 0) + (toInt(payload.maxWords, 0) > 0 ? (' - ' + toInt(payload.maxWords, 0)) : '+') + '</div>';
