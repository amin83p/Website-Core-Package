              questionHtml += '<div class="mb-10 fw-700 small">Expected Key Points</div><ul class="small">';
              payload.expectedKeyPoints.forEach((row) => { questionHtml += '<li>' + esc(row) + '</li>'; });
              questionHtml += '</ul>';
            }
            questionHtml += '<div class="small muted mb-12">Replay: ' + (payload.allowReplay === true ? 'Allowed' : 'Single pass') + '</div>';
            responseHtml = buildResponseChrome('<textarea id="examWritingInput" placeholder="Write your spoken-text summary..."></textarea><div id="examWordCount" class="small muted mb-12">Word count: 0</div>');
            break;
          }
          case 'listening_mcq_multiple': {
            const audioUrl = resolveMediaUrl(questionRow, payload.promptAudioAssetId);
            questionHtml += audioUrl
              ? '<div class="mb-12"><audio controls><source src="' + esc(audioUrl) + '"></audio></div>'
              : '<div class="prompt-box small muted">Audio asset is not attached yet.</div>';
            questionHtml += '<div class="fw-700 mb-10">' + esc(payload.stem || '') + '</div>';
            responseHtml = buildResponseChrome(renderOptionRows(payload.options, 'checkbox', 'preview_listening_multiple'));
            break;
          }
          case 'listening_fill_in_blank': {
            const audioUrl = resolveMediaUrl(questionRow, payload.promptAudioAssetId);
            questionHtml += audioUrl
              ? '<div class="mb-12"><audio controls><source src="' + esc(audioUrl) + '"></audio></div>'
              : '<div class="prompt-box small muted">Audio asset is not attached yet.</div>';
            questionHtml += '<div class="prompt-box">' + renderTextWithBlankSlots(payload.transcriptWithBlanks) + '</div>';
            responseHtml = buildResponseChrome('<div class="small muted">Fill blanks while listening in production flow.</div>');
            break;
          }
          case 'listening_select_missing_word': {
            const audioUrl = resolveMediaUrl(questionRow, payload.promptAudioAssetId);
            questionHtml += audioUrl
              ? '<div class="mb-12"><audio controls><source src="' + esc(audioUrl) + '"></audio></div>'
              : '<div class="prompt-box small muted">Audio asset is not attached yet.</div>';
            questionHtml += '<div class="prompt-box mb-10">' + renderMissingWordGapPrompt(payload.transcriptWithGap) + '</div>';
            questionHtml += '<div class="small muted mb-12">Replay: ' + (payload.allowReplay === true ? 'Allowed' : 'Single pass') + '</div>';
            responseHtml = buildResponseChrome(renderOptionRows(payload.options, 'radio', 'preview_listening_missing_word'));
            break;
          }
          case 'listening_highlight_incorrect_words': {
            const audioUrl = resolveMediaUrl(questionRow, payload.promptAudioAssetId);
            questionHtml += audioUrl
              ? '<div class="mb-12"><audio controls><source src="' + esc(audioUrl) + '"></audio></div>'
              : '<div class="prompt-box small muted">Audio asset is not attached yet.</div>';
            questionHtml += '<div class="prompt-box">' + nl2br(payload.transcriptText) + '</div>';
            questionHtml += '<div class="small muted mb-12">Replay: ' + (payload.allowReplay === true ? 'Allowed' : 'Single pass') + '</div>';
            responseHtml = buildResponseChrome('<textarea id="examWritingInput" placeholder="Type words you would highlight as incorrect..."></textarea>');
            break;
          }
          case 'listening_dictation': {
            const audioUrl = resolveMediaUrl(questionRow, payload.promptAudioAssetId);
            questionHtml += audioUrl
              ? '<div class="mb-12"><audio controls><source src="' + esc(audioUrl) + '"></audio></div>'
              : '<div class="prompt-box small muted">Audio asset is not attached yet.</div>';
            responseHtml = buildResponseChrome('<textarea id="examWritingInput" placeholder="Type dictation answer..."></textarea><div id="examWordCount" class="small muted mb-12">Word count: 0</div>');
            break;
          }
          case 'listening_matching': {
            const audioUrl = resolveMediaUrl(questionRow, payload.promptAudioAssetId);
            questionHtml += audioUrl
              ? '<div class="mb-12"><audio controls><source src="' + esc(audioUrl) + '"></audio></div>'
              : '<div class="prompt-box small muted">Audio asset is not attached yet.</div>';
            responseHtml = buildResponseChrome(renderMatchingTable(payload.leftItems, payload.rightItems));
            break;
          }
          default:
            questionHtml += '<div class="prompt-box muted">Preview template for this question type is not defined yet.</div>';
            responseHtml = buildResponseChrome('<div class="muted small">No response mock available.</div>');
            break;
        }

        questionBody.innerHTML = questionHtml || '<div class="muted">No question content.</div>';
        responseBody.innerHTML = responseHtml || '<div class="muted">No response panel.</div>';
        wireQuestionImageModal();
        requestAnimationFrame(fitPreviewImagesToPanel);

        return {
          questionType,
          payload,
          isSpeaking: SPEAKING_TYPES.has(questionType),
          isWriting: WRITING_TYPES.has(questionType),
          timing,
          needsAudioInput: SPEAKING_TYPES.has(questionType),
          needsCamera: normalizeBoolean(payload.requireCamera, false),
          testTypeLabel
        };
      }

      const runtimeState = {
        context: null,
        timerHandle: null,
        submitted: false,
        mediaStream: null,
        mediaRecorder: null,
        recordedChunks: [],
        recordedBlob: null,
        recordedAudioUrl: '',
        permissionReady: false
      };

      function clearRuntimeTimer() {
        if (runtimeState.timerHandle) {
          clearInterval(runtimeState.timerHandle);
          runtimeState.timerHandle = null;
        }
      }

      function setMetaPhase(phaseText) {
        const phaseNode = document.getElementById('examMetaPhase');
        const chipTextNode = document.getElementById('examPhaseText');
        if (phaseNode) phaseNode.textContent = phaseText;
        if (chipTextNode) chipTextNode.textContent = phaseText;
      }

      function setMetaRemaining(seconds) {
        const remainingNode = document.getElementById('examMetaRemaining');
        const responseTimerNode = document.getElementById('examResponseTimer');
        if (seconds === null || seconds === undefined) {
          if (remainingNode) remainingNode.textContent = '--';
          if (responseTimerNode) responseTimerNode.style.display = 'none';
          return;
        }
        const text = formatCountdown(seconds);
        if (remainingNode) remainingNode.textContent = text;
        if (responseTimerNode) {
          responseTimerNode.style.display = 'inline-block';
          responseTimerNode.textContent = text;
        }
      }

      function setStatus(message, tone) {
        const banner = document.getElementById('examStatusBanner');
        if (!banner) return;
        banner.className = 'status-banner';
        if (tone === 'error') banner.classList.add('error');
        if (tone === 'success') banner.classList.add('success');
        banner.textContent = clean(message) || '...';
      }

      function setRecordingIndicator(isRecording) {
        const dot = document.getElementById('examPhaseDot');
        if (!dot) return;
        dot.style.display = isRecording ? 'inline-block' : 'none';
      }

      function countWords(text) {
        return clean(text)
          .split(/\s+/)
          .map((token) => clean(token))
          .filter(Boolean)
          .length;
      }

      function setResponseInputsEnabled(enabled) {
        const responseBody = document.getElementById('examResponseBody');
        if (!responseBody) return;
        responseBody.querySelectorAll('input, textarea, select, button').forEach((node) => {
          if (!node || node.id === 'btnEnterFullscreen') return;
          node.disabled = !enabled;
        });
      }

      function disableResponseInputs() {
        setResponseInputsEnabled(false);
      }

      function stopMediaTracks() {
        if (runtimeState.mediaStream && typeof runtimeState.mediaStream.getTracks === 'function') {
          runtimeState.mediaStream.getTracks().forEach((track) => {
            try { track.stop(); } catch (_) {}
          });
        }
        runtimeState.mediaStream = null;
      }

      function getPreferredAudioMimeType() {
        const candidates = ['audio/webm;codecs=opus', 'audio/webm', 'audio/ogg;codecs=opus', 'audio/mp4'];
        if (typeof MediaRecorder === 'undefined' || typeof MediaRecorder.isTypeSupported !== 'function') return '';
        return candidates.find((mime) => MediaRecorder.isTypeSupported(mime)) || '';
      }

      function renderRecordedPlayback(blob) {
        const host = document.getElementById('examRecordedPlayback');
        if (!host || !blob) return;
        if (runtimeState.recordedAudioUrl) {
          try { URL.revokeObjectURL(runtimeState.recordedAudioUrl); } catch (_) {}
        }
        runtimeState.recordedAudioUrl = URL.createObjectURL(blob);
        host.innerHTML = '<div class="small fw-700 mb-10">Recorded Response (Local Preview)</div>'
          + '<audio controls preload="metadata"><source src="' + esc(runtimeState.recordedAudioUrl) + '"></audio>';
      }

      function stopLocalRecording() {
        if (runtimeState.mediaRecorder && runtimeState.mediaRecorder.state !== 'inactive') {
          try { runtimeState.mediaRecorder.stop(); } catch (_) {}
        }
      }

      function startLocalRecording() {
        if (!runtimeState.mediaStream) {
          setStatus('Microphone stream is unavailable. Recording cannot start in this preview.', 'error');
          return false;
        }
        if (typeof MediaRecorder === 'undefined') {
          setStatus('MediaRecorder API is not supported in this browser.', 'error');
          return false;
        }

        const mimeType = getPreferredAudioMimeType();
        const options = mimeType ? { mimeType } : undefined;
        runtimeState.recordedChunks = [];
        runtimeState.recordedBlob = null;
        runtimeState.mediaRecorder = new MediaRecorder(runtimeState.mediaStream, options);
        runtimeState.mediaRecorder.ondataavailable = (event) => {
          if (event && event.data && event.data.size > 0) {
            runtimeState.recordedChunks.push(event.data);
          }
        };
        runtimeState.mediaRecorder.onstop = () => {
          if (runtimeState.recordedChunks.length) {
            runtimeState.recordedBlob = new Blob(runtimeState.recordedChunks, {
              type: runtimeState.mediaRecorder && runtimeState.mediaRecorder.mimeType
                ? runtimeState.mediaRecorder.mimeType
                : 'audio/webm'
            });
            renderRecordedPlayback(runtimeState.recordedBlob);
          }
          stopMediaTracks();
          runtimeState.mediaRecorder = null;
        };
        try {
          runtimeState.mediaRecorder.start(250);
          return true;
        } catch (_) {
          setStatus('Unable to start audio recording in this browser.', 'error');
          return false;
        }
      }

      async function requestRequiredPermissions(context) {
        if (!context.needsAudioInput && !context.needsCamera) {
          runtimeState.permissionReady = true;
          setStatus('No media permissions required for this question type.', 'info');
          return;
        }
        if (!navigator.mediaDevices || typeof navigator.mediaDevices.getUserMedia !== 'function') {
          runtimeState.permissionReady = false;
          setStatus('This browser does not support media permission APIs.', 'error');
          return;
        }

        setStatus('Requesting required permissions (microphone/camera) for exam-like preview...', 'info');
        try {
          runtimeState.mediaStream = await navigator.mediaDevices.getUserMedia({
            audio: context.needsAudioInput === true,
            video: context.needsCamera === true
          });
          runtimeState.permissionReady = true;
          setStatus('Permissions granted. Preview runtime is ready.', 'success');
        } catch (error) {
          runtimeState.permissionReady = false;
          const errName = clean(error && error.name) || 'PermissionError';
          setStatus('Permission request failed (' + errName + '). Timed flow will continue without local recording.', 'error');
        }
      }

      function runCountdown(seconds, onTick, onDone) {
        clearRuntimeTimer();
        let remaining = Math.max(0, Number(seconds || 0));
        onTick(remaining);
        if (remaining <= 0) {
          onDone();
          return;
        }
        runtimeState.timerHandle = setInterval(() => {
          remaining -= 1;
          onTick(Math.max(0, remaining));
          if (remaining <= 0) {
            clearRuntimeTimer();
            onDone();
          }
        }, 1000);
      }

      function markSubmitted(reasonText) {
        if (runtimeState.submitted) return;
        runtimeState.submitted = true;
        clearRuntimeTimer();
        stopLocalRecording();
        if (!runtimeState.mediaRecorder || runtimeState.mediaRecorder.state === 'inactive') {
          stopMediaTracks();
        }
        setRecordingIndicator(false);
        setMetaPhase('Submitted');
        setMetaRemaining(0);
        disableResponseInputs();
        const noticeNode = document.getElementById('examAutoSubmitNotice');
        if (noticeNode) {
          noticeNode.textContent = 'Auto-submit completed: ' + (clean(reasonText) || 'Response finalized.');
        }
        setStatus('Response submitted locally in preview mode. No data was sent to server.', 'success');
      }

      function wireWordCount() {
        const writingInput = document.getElementById('examWritingInput');
        const countNode = document.getElementById('examWordCount');
        if (!writingInput || !countNode) return;
        const refresh = () => {
          countNode.textContent = 'Word count: ' + countWords(writingInput.value);
        };
        writingInput.addEventListener('input', refresh);
        refresh();
      }

      function startTimedFlow(context) {
        if (!context) return;
        const submitBtn = document.getElementById('btnSubmitNow');
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.addEventListener('click', () => markSubmitted('Submitted manually.'));
        }

        if (context.isWriting) {
          wireWordCount();
        }

        const beginResponsePhase = () => {
          if (runtimeState.submitted) return;
          setResponseInputsEnabled(true);
          setMetaPhase(context.isSpeaking ? 'Recording' : 'Response');
          setRecordingIndicator(context.isSpeaking);
          if (submitBtn) submitBtn.disabled = false;
          if (context.isSpeaking) {
            const started = startLocalRecording();
            if (started) {
              setStatus('Recording in progress (local only). Auto-submit will run when timer reaches zero.', 'info');
            } else {
              setRecordingIndicator(false);
            }
          } else {
            setStatus('Response timer is active. Input will auto-submit when time ends.', 'info');
          }

          if (context.timing.responseSeconds > 0) {
            runCountdown(context.timing.responseSeconds, (remaining) => {
              setMetaRemaining(remaining);
            }, () => {
              markSubmitted('Response timer completed.');
            });
          } else {
            setMetaRemaining(null);
            setStatus('No response timer configured for this question. Submit manually when ready.', 'info');
          }
        };

        if (context.timing.prepSeconds > 0) {
          setResponseInputsEnabled(false);
          setMetaPhase('Preparation');
          setRecordingIndicator(false);
          setStatus('Preparation time started. Recording will begin automatically after prep ends.', 'info');
          runCountdown(context.timing.prepSeconds, (remaining) => {
            setMetaRemaining(remaining);
          }, () => {
            beginResponsePhase();
          });
          return;
        }

        beginResponsePhase();
      }

      const question = parseJsonScript('questionJson', {});
      const typeRegistry = parseJsonScript('typeRegistryJson', []);
      const typeMap = new Map((Array.isArray(typeRegistry) ? typeRegistry : []).map((row) => [String(row && row.key || '').trim().toLowerCase(), row]));
      const examContext = renderExam(question || {}, typeMap);

      async function initializeExamRuntime() {
        if (!examContext) return;
        await requestRequiredPermissions(examContext);
        startTimedFlow(examContext);
      }

      initializeExamRuntime().catch(() => {
        setStatus('Unable to initialize preview runtime.', 'error');
      });

      const btnEnterFullscreen = document.getElementById('btnEnterFullscreen');
      if (btnEnterFullscreen) {
        btnEnterFullscreen.addEventListener('click', async () => {
          try {
            if (!document.fullscreenElement) {
              await document.documentElement.requestFullscreen();
              btnEnterFullscreen.textContent = 'Exit Fullscreen';
            } else {
              await document.exitFullscreen();
              btnEnterFullscreen.textContent = 'Enter Fullscreen';
            }
          } catch (_) {
            // no-op
          }
        });
      }

      window.addEventListener('beforeunload', () => {
        clearRuntimeTimer();
        stopLocalRecording();
        stopMediaTracks();
        closeImageModal();
      });

      window.addEventListener('resize', () => {
        fitPreviewImagesToPanel();
      });
    })();
  </script>
</body>
</html>
