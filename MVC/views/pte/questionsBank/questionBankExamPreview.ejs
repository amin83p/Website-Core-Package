          : {};
        const questionType = clean(questionRow.questionType).toLowerCase();
        const skill = clean(questionRow.skill).toLowerCase();
        const title = clean(questionRow.title) || 'Untitled Question';
        const instructions = clean(questionRow.instructions);
        const typeDef = typeMap.get(questionType) || null;
        const questionTypeLabel = (typeDef && typeDef.label) || formatQuestionTypeLabel(questionType) || 'Question';
        const testTypeLabel = getTestTypeLabel(questionRow && questionRow.testType);
        const timing = getTimingConfig(questionType, payload);

        const questionBody = document.getElementById('examQuestionBody');
        const responseBody = document.getElementById('examResponseBody');
        if (!questionBody || !responseBody) return null;

