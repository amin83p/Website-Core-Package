<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title || 'PTE Exam Preview' %></title>
  <style>
    :root {
      --brand-900: #0b2f6b;
      --brand-800: #144692;
      --brand-100: #edf4ff;
      --accent: #00a7e1;
      --surface-page: #e9eef6;
      --surface-panel: #ffffff;
      --surface-soft: #f6f8fc;
      --text-main: #101f34;
      --text-muted: #5d6d82;
      --border-soft: #d3dcea;
      --shadow-panel: 0 4px 16px rgba(8, 32, 74, .08);
      --radius-md: 12px;
      --radius-sm: 8px;
      --topbar-h: 72px;
      --footer-h: 78px;
    }

    * { box-sizing: border-box; }
    html, body { height: 100%; }

    body {
      margin: 0;
      font-family: Calibri, "Segoe UI", "Helvetica Neue", Arial, sans-serif;
      font-size: 16px;
      line-height: 1.5;
      background: var(--surface-page);
      color: var(--text-main);
    }

    .exam-shell {
      min-height: 100vh;
      display: grid;
      grid-template-rows: var(--topbar-h) 1fr var(--footer-h);
    }

    .exam-topbar {
      min-height: var(--topbar-h);
      display: grid;
      grid-template-columns: max-content 1fr max-content;
      align-items: center;
      gap: 16px;
      padding: 10px 20px;
      background: linear-gradient(105deg, var(--brand-900) 0%, var(--brand-800) 100%);
      color: #fff;
      border-bottom: 4px solid var(--accent);
    }

    .exam-brand {
      min-width: 170px;
    }

    .exam-brand-title {
      font-size: 22px;
      line-height: 1.05;
      font-weight: 700;
      letter-spacing: .1px;
    }

    .exam-brand-subtitle {
      margin-top: 3px;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: .04em;
      text-transform: uppercase;
      opacity: .9;
    }

    .exam-meta {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 14px;
      min-width: 0;
    }

    .exam-meta-item {
      min-width: 120px;
      padding: 6px 10px;
      border: 1px solid rgba(255, 255, 255, .24);
      border-radius: 10px;
      background: rgba(255, 255, 255, .08);
      backdrop-filter: blur(2px);
    }

    .exam-meta-label {
      display: block;
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: .08em;
      opacity: .82;
      margin-bottom: 2px;
      white-space: nowrap;
    }

    .exam-meta-value {
      display: block;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.2;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .exam-actions {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .btn {
      border: 1px solid #c6d3e5;
      border-radius: var(--radius-sm);
      min-height: 38px;
      padding: 7px 14px;
      font-size: 14px;
      font-weight: 700;
      line-height: 1.2;
      cursor: pointer;
      background: #fff;
      color: #173a71;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 1px 2px rgba(8, 32, 74, .08);
    }

    .btn.btn-outline {
      background: transparent;
      color: #fff;
      border-color: rgba(255, 255, 255, .58);
      box-shadow: none;
    }

    .btn.btn-light {
      background: #fff;
      color: #173a71;
    }

    .btn.btn-primary {
      background: #1a4f98;
      border-color: #1a4f98;
      color: #fff;
    }

    .btn:disabled {
      opacity: .72;
      cursor: not-allowed;
    }

    .exam-main {
      min-height: 0;
      display: grid;
      grid-template-columns: minmax(0, 1.7fr) minmax(340px, 1fr);
      gap: 16px;
      padding: 16px 18px;
    }

    .panel {
      min-height: 0;
      background: var(--surface-panel);
      border: 1px solid var(--border-soft);
      border-radius: var(--radius-md);
      box-shadow: var(--shadow-panel);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .panel-head {
      min-height: 62px;
      padding: 12px 16px;
      border-bottom: 1px solid var(--border-soft);
      background: var(--surface-soft);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
    }

    .panel-title {
      margin: 0;
      font-size: 20px;
      line-height: 1.15;
      font-weight: 700;
      letter-spacing: .1px;
    }

    .panel-subtitle {
      margin-top: 3px;
      font-size: 13px;
      font-weight: 600;
      color: var(--text-muted);
      letter-spacing: .01em;
    }

    .panel-body {
      flex: 1;
      min-height: 0;
      overflow: auto;
      padding: 18px;
      font-size: 16px;
      line-height: 1.58;
    }

    .badge {
      border: 1px solid #c6d7ec;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 800;
      letter-spacing: .05em;
      text-transform: uppercase;
      padding: 5px 12px;
      color: #214a7a;
      background: #f3f8ff;
      white-space: nowrap;
    }

    .badge-soft {
      border-color: #d8e3f2;
      color: #5f7593;
      background: #f8fbff;
    }

    .instruction-box {
      border: 1px solid #c4d8f0;
      background: var(--brand-100);
      color: #1a4168;
      border-radius: 10px;
      padding: 10px 13px;
      margin-bottom: 12px;
      font-size: 14px;
      line-height: 1.5;
    }

    .prompt-box {
      border: 1px solid var(--border-soft);
      border-radius: 10px;
      padding: 12px 14px;
      margin-bottom: 12px;
      background: #fff;
      line-height: 1.58;
      font-size: 16px;
    }

    .muted { color: var(--text-muted); }
    .small { font-size: 13px; }
    .mb-10 { margin-bottom: 10px; }
    .mb-12 { margin-bottom: 12px; }
    .mb-14 { margin-bottom: 14px; }
    .mb-16 { margin-bottom: 16px; }
    .fw-700 { font-weight: 700; }

    .option-row {
      display: flex;
      align-items: flex-start;
      gap: 10px;
      margin-bottom: 10px;
      font-size: 15px;
      line-height: 1.45;
    }

    .option-row input {
      margin-top: 2px;
    }

    .option-key {
      min-width: 30px;
      padding: 2px 7px;
      border-radius: 6px;
      border: 1px solid #cbd8ea;
      background: #f8fbff;
      text-align: center;
      font-family: Consolas, "Courier New", monospace;
      font-size: 11px;
      font-weight: 700;
      color: #31527d;
    }

    .word-bank {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .word-bank span {
      border: 1px solid #cfdaea;
      border-radius: 999px;
      padding: 4px 10px;
      font-size: 13px;
      font-weight: 600;
      background: #fbfdff;
      color: #314b6c;
    }

    .blank-slot {
      display: inline-block;
      min-width: 64px;
      border-bottom: 2px solid #8cb1de;
      margin: 0 5px;
      transform: translateY(-1px);
    }

    .response-box textarea,
    .response-box select,
    .response-box input[type="text"] {
      width: 100%;
      border: 1px solid #c8d5e7;
      border-radius: 8px;
      padding: 10px 11px;
      font-size: 15px;
      line-height: 1.45;
      background: #fff;
      color: #203857;
    }

    .response-box textarea { min-height: 168px; resize: vertical; }

    .matching-table {
      width: 100%;
      border-collapse: collapse;
      font-size: 14px;
    }

    .matching-table th,
    .matching-table td {
      border: 1px solid var(--border-soft);
      padding: 8px 9px;
      text-align: left;
      vertical-align: top;
    }

    .timer-chip {
      display: inline-block;
      padding: 6px 11px;
      border-radius: 8px;
      background: #e8f6ff;
      border: 1px solid #b7dcf3;
      color: #134568;
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 10px;
    }

    .phase-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 7px 11px;
      border-radius: 8px;
      background: #edf4ff;
      border: 1px solid #c7d8f0;
      color: #153f68;
      font-size: 12px;
      font-weight: 800;
      margin-bottom: 10px;
      text-transform: uppercase;
      letter-spacing: .04em;
    }

    .record-dot {
      width: 10px;
      height: 10px;
      border-radius: 999px;
      background: #d62f2f;
      box-shadow: 0 0 0 rgba(214, 47, 47, .55);
      animation: pulse-rec 1.4s infinite;
    }

    @keyframes pulse-rec {
      0% { box-shadow: 0 0 0 0 rgba(214, 47, 47, .55); }
      70% { box-shadow: 0 0 0 9px rgba(214, 47, 47, 0); }
      100% { box-shadow: 0 0 0 0 rgba(214, 47, 47, 0); }
    }

    .status-banner {
      border: 1px solid #c7d8f0;
      background: #f3f8ff;
      color: #193f63;
      border-radius: 10px;
      padding: 10px 12px;
      margin-bottom: 12px;
      font-size: 13px;
      line-height: 1.45;
    }

    .status-banner.error {
      border-color: #f1c4c4;
      background: #fff5f5;
      color: #7a1f1f;
    }

    .status-banner.success {
      border-color: #bfe6c8;
      background: #effcf2;
      color: #1f6630;
    }

    audio { width: 100%; }

    .preview-image-frame {
      width: 100%;
      min-height: 230px;
      height: min(52vh, 520px);
      border: 1px solid var(--border-soft);
      border-radius: 10px;
      background: #f7fafe;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      padding: 10px;
    }

    img.preview-image {
      max-width: 100%;
      max-height: 100%;
      width: auto;
      height: auto;
      object-fit: contain;
      border-radius: 8px;
      border: 1px solid var(--border-soft);
      display: block;
    }

    img.preview-image.is-clickable {
      cursor: zoom-in;
      transition: transform .12s ease, box-shadow .12s ease;
    }

    img.preview-image.is-clickable:hover {
      transform: scale(1.01);
      box-shadow: 0 2px 10px rgba(8, 32, 74, .14);
    }

    .preview-image-hint {
      margin-top: -2px;
    }

    .image-modal {
      position: fixed;
      inset: 0;
      z-index: 1200;
      background: rgba(4, 15, 31, .76);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    .image-modal.is-open {
      display: flex;
    }

    .image-modal-inner {
      width: min(96vw, 1400px);
      height: min(94vh, 940px);
      border-radius: 12px;
      border: 1px solid #2d4465;
      background: #0d1f37;
      box-shadow: 0 14px 36px rgba(5, 14, 29, .46);
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }

    .image-modal-toolbar {
      padding: 10px 12px;
      border-bottom: 1px solid #2f4769;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      background: #142845;
    }

    .image-modal-title {
      color: #d9e8ff;
      font-size: 13px;
      font-weight: 700;
      letter-spacing: .02em;
      text-transform: uppercase;
    }

    .image-modal-toolbar .btn {
      min-height: 34px;
      padding: 6px 11px;
      font-size: 13px;
    }

    .image-modal-canvas {
      flex: 1;
      overflow: auto;
      padding: 14px;
      background: #091528;
    }

    .image-modal-canvas img {
      display: block;
      width: auto;
      height: auto;
      max-width: none;
      max-height: none;
      margin: 0 auto;
      border-radius: 6px;
      border: 1px solid #2e4463;
      background: #fff;
    }

    .exam-footer {
      min-height: var(--footer-h);
      border-top: 1px solid var(--border-soft);
      background: var(--surface-panel);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 18px;
      box-shadow: 0 -2px 8px rgba(8, 32, 74, .04);
    }

    .exam-footer .left,
    .exam-footer .right {
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .exam-footer .btn {
      min-width: 118px;
      justify-content: space-between;
    }

    .btn-hotkey {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 22px;
      height: 20px;
      border: 1px solid #c7d3e3;
      border-radius: 5px;
      background: #f7fafe;
      color: #476188;
      font-size: 11px;
      font-weight: 800;
      line-height: 1;
      margin-left: 2px;
    }

    .btn:disabled .btn-hotkey {
      opacity: .95;
    }

    @media (max-width: 1200px) {
      .exam-main {
        grid-template-columns: 1fr;
      }

      .response-box .panel-body {
        max-height: 44vh;
      }
    }

    @media (max-width: 900px) {
      .exam-shell {
        grid-template-rows: auto 1fr auto;
      }

      .exam-topbar {
        grid-template-columns: 1fr;
        justify-items: stretch;
        gap: 10px;
        padding: 10px 12px;
      }

      .exam-meta {
        justify-content: flex-start;
        flex-wrap: wrap;
      }

      .exam-meta-item {
        min-width: 132px;
      }

      .exam-actions {
        justify-content: flex-start;
        flex-wrap: wrap;
      }

      .exam-main {
        padding: 12px;
        gap: 12px;
      }

      .panel-head {
        padding: 11px 12px;
      }

      .panel-body {
        padding: 13px;
      }

      .preview-image-frame {
        min-height: 170px;
        height: min(42vh, 340px);
      }

      .image-modal-inner {
        width: 98vw;
        height: 95vh;
      }

      .exam-footer {
        flex-wrap: wrap;
        justify-content: center;
      }
    }
  </style>
</head>
<body>
  <script id="questionJson" type="application/json"><%- JSON.stringify(question || {}).replace(/</g, '\\u003c') %></script>
  <script id="typeRegistryJson" type="application/json"><%- JSON.stringify(typeRegistry || []).replace(/</g, '\\u003c') %></script>

  <div class="exam-shell">
    <header class="exam-topbar">
      <div class="exam-brand">
        <div class="exam-brand-title" id="examBrandTitle">PTE Exam</div>
        <div class="exam-brand-subtitle">Candidate Exam Screen</div>
      </div>
      <div class="exam-meta">
        <div class="exam-meta-item">
          <span class="exam-meta-label">Test Type</span>
          <span class="exam-meta-value" id="examMetaTestType">-</span>
        </div>
        <div class="exam-meta-item">
          <span class="exam-meta-label">Question Type</span>
          <span class="exam-meta-value" id="examMetaType">Question</span>
        </div>
        <div class="exam-meta-item">
          <span class="exam-meta-label">Skill</span>
          <span class="exam-meta-value" id="examMetaSkill">-</span>
        </div>
        <div class="exam-meta-item">
          <span class="exam-meta-label">Timing</span>
          <span class="exam-meta-value" id="examMetaTimer">--</span>
        </div>
        <div class="exam-meta-item">
          <span class="exam-meta-label">Phase</span>
          <span class="exam-meta-value" id="examMetaPhase">Ready</span>
        </div>
        <div class="exam-meta-item">
          <span class="exam-meta-label">Remaining</span>
          <span class="exam-meta-value" id="examMetaRemaining">--</span>
        </div>
      </div>
      <div class="exam-actions">
        <button type="button" id="btnEnterFullscreen" class="btn btn-outline">Enter Fullscreen</button>
        <a href="/pte/questions-bank" class="btn btn-light">Back to Questions</a>
      </div>
    </header>

    <main class="exam-main">
      <section class="panel">
        <div class="panel-head">
          <div>
            <h1 class="panel-title" id="examQuestionTitle">Question</h1>
            <div class="panel-subtitle" id="examQuestionSubtitle">Question Prompt</div>
          </div>
          <span class="badge" id="examQuestionBadge">TYPE</span>
        </div>
        <div class="panel-body" id="examQuestionBody"></div>
      </section>

      <aside class="panel response-box">
        <div class="panel-head">
          <div>
            <h2 class="panel-title">Response</h2>
            <div class="panel-subtitle">Candidate input and response controls</div>
          </div>
          <span class="badge badge-soft">Preview Mode</span>
        </div>
        <div class="panel-body" id="examResponseBody"></div>
      </aside>
    </main>

    <footer class="exam-footer">
      <div class="left">
        <button class="btn" disabled>Previous <span class="btn-hotkey">P</span></button>
        <button class="btn" disabled>Flag <span class="btn-hotkey">F</span></button>
      </div>
      <div class="right">
        <button class="btn" disabled>Skip <span class="btn-hotkey">S</span></button>
        <button class="btn btn-primary" disabled>Next <span class="btn-hotkey">N</span></button>
      </div>
    </footer>
  </div>

  <div id="imagePreviewModal" class="image-modal" hidden aria-hidden="true">
    <div class="image-modal-inner" role="dialog" aria-modal="true" aria-label="Image preview at actual size">
      <div class="image-modal-toolbar">
        <div class="image-modal-title">Actual Size Image Preview</div>
        <button type="button" class="btn" id="imagePreviewModalClose">Close</button>
      </div>
      <div class="image-modal-canvas">
        <img id="imagePreviewModalImg" alt="Full size question image">
      </div>
    </div>
  </div>

  <script>
    (function initExamPreview() {
      function parseJsonScript(id, fallback) {
        try {
          const node = document.getElementById(id);
          return JSON.parse((node && node.textContent) || '');
        } catch (_) {
          return fallback;
        }
      }

      function esc(value) {
        return String(value == null ? '' : value)
          .replace(/&/g, '&amp;')
          .replace(/</g, '&lt;')
          .replace(/>/g, '&gt;')
          .replace(/"/g, '&quot;')
          .replace(/'/g, '&#39;');
      }

      function clean(value) {
        return String(value || '').replace(/\0/g, '').trim();
      }

      function nl2br(value) {
        return esc(String(value || '')).replace(/\r?\n/g, '<br>');
      }

      function toArray(value) {
        return Array.isArray(value) ? value : [];
      }

      function toMediaArray(value) {
        if (Array.isArray(value)) return value;
        if (value && typeof value === 'object') {
          return Object.values(value).filter((row) => row && typeof row === 'object');
        }
        return [];
      }

      function toInt(value, fallback) {
        const numeric = Number.parseInt(String(value || ''), 10);
        if (!Number.isFinite(numeric) || Number.isNaN(numeric)) return fallback;
        return numeric;
      }

      function normalizeOptionRows(options) {
        return toArray(options).map((item, index) => {
          if (item && typeof item === 'object' && !Array.isArray(item)) {
            return {
              key: clean(item.key || item.id || String.fromCharCode(65 + index)) || String(index + 1),
              text: clean(item.text || item.label || item.value || '')
            };
          }
          return {
            key: String.fromCharCode(65 + index),
            text: clean(item)
          };
        }).filter((row) => row.text);
      }

      function normalizeBoolean(value, fallback) {
        if (value === undefined || value === null || value === '') return fallback;
        if (typeof value === 'boolean') return value;
        const token = clean(value).toLowerCase();
        if (['1', 'true', 'yes', 'y', 'on'].includes(token)) return true;
        if (['0', 'false', 'no', 'n', 'off'].includes(token)) return false;
        return fallback;
      }

      function formatCountdown(seconds) {
        const s = Math.max(0, Number(seconds || 0));
        const mm = String(Math.floor(s / 60)).padStart(2, '0');
        const ss = String(s % 60).padStart(2, '0');
        return mm + ':' + ss;
      }

      function parseMinutesToSeconds(value) {
        const minutes = toInt(value, 0);
        return minutes > 0 ? minutes * 60 : 0;
      }

      function renderOptionRows(options, inputType, groupName) {
        const rows = normalizeOptionRows(options);
        if (!rows.length) return '<div class="muted small">No options configured.</div>';
        const sharedGroup = clean(groupName) || ('preview_choice_' + Date.now());
        return rows.map((row) => ''
          + '<label class="option-row">'
          + '  <input type="' + esc(inputType) + '" name="' + esc(sharedGroup) + '">'
          + '  <span class="option-key">' + esc(row.key) + '</span>'
          + '  <span>' + esc(row.text) + '</span>'
          + '</label>').join('');
      }

      function renderTextWithBlankSlots(value) {
        return String(value || '')
          .split(/(\{\{[^}]+\}\})/g)
          .map((part) => /^\{\{[^}]+\}\}$/.test(part) ? '<span class="blank-slot"></span>' : esc(part))
          .join('')
          .replace(/\r?\n/g, '<br>');
      }

      function renderMissingWordGapPrompt(value) {
        return String(value || '')
          .split(/(\{\{[^}]+\}\}|\[\s*blank\s*\]|_{3,}|\.{3,})/ig)
          .map((part) => /^(\{\{[^}]+\}\}|\[\s*blank\s*\]|_{3,}|\.{3,})$/i.test(part) ? '<span class="blank-slot"></span>' : esc(part))
          .join('')
          .replace(/\r?\n/g, '<br>');
      }

      function renderMatchingTable(leftItems, rightItems) {
        const left = toArray(leftItems).map((v) => clean(v)).filter(Boolean);
        const right = toArray(rightItems).map((v) => clean(v)).filter(Boolean);
        if (!left.length || !right.length) return '<div class="muted small">Matching rows are incomplete.</div>';
        const options = right.map((item) => '<option>' + esc(item) + '</option>').join('');
        return ''
          + '<table class="matching-table">'
          + '<thead><tr><th>Left Item</th><th>Match</th></tr></thead><tbody>'
          + left.map((row) => '<tr><td>' + esc(row) + '</td><td><select><option>-- Select --</option>' + options + '</select></td></tr>').join('')
          + '</tbody></table>';
      }

      function resolveMediaUrl(questionRow, assetRef) {
        const tokenRaw = clean(assetRef);
        const token = tokenRaw.toLowerCase();
        if (!token) return '';
        if (/^https?:\/\//i.test(tokenRaw)) return tokenRaw;
        if (/^\/pte\/questions-bank\//i.test(tokenRaw)) return tokenRaw;
        if (/^pte\/questions-bank\//i.test(tokenRaw)) return '/' + tokenRaw;
        if (/^\/uploads\//i.test(tokenRaw)) return tokenRaw;
        if (/^uploads\//i.test(tokenRaw)) return '/' + tokenRaw;

        let decodedToken = tokenRaw;
        try {
          decodedToken = decodeURIComponent(tokenRaw);
        } catch (_) {
          decodedToken = tokenRaw;
        }
        const decodedTokenLower = clean(decodedToken).toLowerCase();

        const normalizedToken = decodedTokenLower.replace(/\\/g, '/');
        const tokenBasename = normalizedToken.split('/').pop();

        const mediaRows = toMediaArray(questionRow && questionRow.mediaAssets);
        const media = mediaRows.find((row) => {
          const keys = [row && row.id, row && row.name, row && row.originalName, row && row.filename, row && row.path, row && row.url]
            .map((v) => clean(v))
            .filter(Boolean);
          const normalizedKeys = [];
          keys.forEach((rawKey) => {
            const lowered = rawKey.toLowerCase();
            normalizedKeys.push(lowered);
            normalizedKeys.push(lowered.replace(/\\/g, '/'));
            try {
              normalizedKeys.push(decodeURIComponent(rawKey).toLowerCase().replace(/\\/g, '/'));
            } catch (_) {}
          });
          if (normalizedKeys.includes(token)) return true;
          if (normalizedKeys.includes(decodedTokenLower)) return true;
          if (normalizedKeys.includes(normalizedToken)) return true;
          if (tokenBasename && normalizedKeys.some((key) => key.split('/').pop() === tokenBasename)) return true;
          return false;
        }) || null;
        if (!media) return '';
        if (clean(media.url)) return clean(media.url);
        if (clean(media.path)) {
          const normalized = clean(media.path).replace(/\\/g, '/');
          const match = normalized.match(/\/uploads\/(.+)$/i);
          if (match && match[1]) return '/uploads/' + String(match[1]).replace(/^\/+/, '');
        }
        const questionId = clean(questionRow && questionRow.id);
        const mediaId = clean(media.id);
        if (!questionId || !mediaId) return '';
        return '/pte/questions-bank/' + encodeURIComponent(questionId) + '/media/' + encodeURIComponent(mediaId) + '/download';
      }

      function buildResponseChrome(innerHtml) {
        return ''
          + '<div id="examStatusBanner" class="status-banner">Initializing timed preview...</div>'
          + '<div id="examPhaseChip" class="phase-chip"><span id="examPhaseDot" class="record-dot" style="display:none;"></span><span id="examPhaseText">Ready</span></div>'
          + '<div id="examResponseTimer" class="timer-chip" style="display:none;">--</div>'
          + innerHtml
          + '<div class="mb-12"><button type="button" class="btn btn-primary" id="btnSubmitNow">Submit Now</button></div>'
          + '<div id="examAutoSubmitNotice" class="small muted"></div>';
      }

      const imageModalState = {
        bound: false,
        previousBodyOverflow: ''
      };

      function openImageModal(src, altText) {
        const modal = document.getElementById('imagePreviewModal');
        const modalImage = document.getElementById('imagePreviewModalImg');
        if (!modal || !modalImage) return;
        const source = clean(src);
        if (!source) return;
        modalImage.src = source;
        modalImage.alt = clean(altText) || 'Full size question image';
        imageModalState.previousBodyOverflow = document.body.style.overflow || '';
        document.body.style.overflow = 'hidden';
        modal.hidden = false;
        modal.classList.add('is-open');
        modal.setAttribute('aria-hidden', 'false');
      }

      function closeImageModal() {
        const modal = document.getElementById('imagePreviewModal');
        const modalImage = document.getElementById('imagePreviewModalImg');
        if (!modal) return;
        modal.classList.remove('is-open');
        modal.setAttribute('aria-hidden', 'true');
        modal.hidden = true;
        document.body.style.overflow = imageModalState.previousBodyOverflow || '';
        if (modalImage) modalImage.removeAttribute('src');
      }

      function setupImageModalBindings() {
        if (imageModalState.bound) return;
        const modal = document.getElementById('imagePreviewModal');
        const closeBtn = document.getElementById('imagePreviewModalClose');
        if (!modal || !closeBtn) return;

        closeBtn.addEventListener('click', closeImageModal);
        modal.addEventListener('click', (event) => {
          if (event.target === modal) closeImageModal();
        });
        document.addEventListener('keydown', (event) => {
          if (event.key === 'Escape' && !modal.hidden) {
            closeImageModal();
          }
        });
        imageModalState.bound = true;
      }

      function wireQuestionImageModal() {
        setupImageModalBindings();
        const images = document.querySelectorAll('#examQuestionBody img.preview-image');
        images.forEach((imgNode) => {
          if (!imgNode || imgNode.dataset.modalBound === '1') return;
          imgNode.dataset.modalBound = '1';
          imgNode.classList.add('is-clickable');
          imgNode.addEventListener('click', () => {
            const src = clean(imgNode.getAttribute('data-modal-src') || imgNode.currentSrc || imgNode.src);
            openImageModal(src, clean(imgNode.alt));
          });
        });
      }

      function fitPreviewImagesToPanel() {
        const questionBody = document.getElementById('examQuestionBody');
        if (!questionBody) return;
        const frames = Array.from(questionBody.querySelectorAll('.preview-image-frame'));
        if (!frames.length) return;

        let nonFrameHeight = 0;
        Array.from(questionBody.children).forEach((node) => {
          if (!node || !node.classList || node.classList.contains('preview-image-frame')) return;
          nonFrameHeight += Number(node.offsetHeight || 0);
        });

        let available = Number(questionBody.clientHeight || 0) - nonFrameHeight - 24;
        if (!Number.isFinite(available) || available <= 0) {
          available = Math.floor(window.innerHeight * 0.45);
        }

        const maxAllowed = Math.floor(window.innerHeight * 0.62);
        const targetHeight = Math.max(180, Math.min(available, maxAllowed));
        frames.forEach((frame) => {
          frame.style.height = String(targetHeight) + 'px';
        });
      }

      function getTimingConfig(questionType, payload) {
        const prepSeconds = Math.max(0, toInt(payload.prepTimeSeconds, 0), parseMinutesToSeconds(payload.planningTimeMinutes));
        const responseSeconds = Math.max(0, toInt(payload.responseTimeSeconds, 0), parseMinutesToSeconds(payload.recommendedTimeMinutes), toInt(payload.timeLimitSeconds, 0));
        const hasTiming = prepSeconds > 0 || responseSeconds > 0;
        const label = hasTiming
          ? ('Prep ' + prepSeconds + 's / Response ' + responseSeconds + 's')
          : '--';
        return { prepSeconds, responseSeconds, hasTiming, label };
      }

      function getTestTypeLabel(testType) {
        const token = clean(testType).toLowerCase();
        if (token === 'core') return 'PTE Core';
        if (token === 'academic') return 'PTE Academic';
        return 'PTE Exam';
      }

      function formatQuestionTypeLabel(questionType) {
        return clean(questionType)
          .toLowerCase()
          .split('_')
          .filter(Boolean)
          .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
          .join(' ');
      }

      const SPEAKING_TYPES = new Set([
        'speaking_read_aloud',
        'speaking_repeat_sentence',
        'speaking_describe_image',
        'speaking_respond_to_situation',
        'speaking_answer_short_question'
      ]);
      const WRITING_TYPES = new Set([
        'writing_summarize_written_text',
        'writing_write_email',
        'writing_short_answer',
        'writing_essay'
      ]);

      function renderExam(questionRow, typeMap) {
        const payload = (questionRow && typeof questionRow.payload === 'object' && !Array.isArray(questionRow.payload))
