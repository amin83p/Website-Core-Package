            responseHtml = buildResponseChrome('<div class="small muted mb-12">Recording starts automatically when prep ends. Audio is kept local in this browser preview.</div><textarea id="examTranscriptInput" placeholder="Optional transcript notes (local only)"></textarea><div id="examRecordedPlayback" class="mb-12"></div>');
