              ? '<div class="mb-12"><audio controls><source src="' + esc(audioUrl) + '"></audio></div>'
              : '<div class="prompt-box small muted">Audio asset is not attached yet.</div>';
            responseHtml = buildResponseChrome('<div class="small muted mb-12">Recording starts automatically. Repeat the sentence clearly.</div><textarea id="examTranscriptInput" placeholder="Optional transcript notes (local only)"></textarea><div id="examRecordedPlayback" class="mb-12"></div>');
            break;
          }
          case 'speaking_describe_image': {
            const imageUrl = resolveMediaUrl(questionRow, payload.imageAssetId);
            questionHtml += '<div class="timer-chip">Prep ' + toInt(payload.prepTimeSeconds, 0) + 's / Response ' + toInt(payload.responseTimeSeconds, 0) + 's</div>';
            questionHtml += imageUrl
              ? '<div class="preview-image-frame mb-10"><img class="preview-image" data-modal-src="' + esc(imageUrl) + '" src="' + esc(imageUrl) + '" alt="Question image"></div><div class="preview-image-hint small muted mb-12">Click the image to open actual size.</div>'
              : '<div class="prompt-box small muted">Image asset is not attached yet.</div>';
            if (clean(payload.imageCaption)) questionHtml += '<div class="small muted mb-12">' + esc(payload.imageCaption) + '</div>';
            responseHtml = buildResponseChrome('<div class="small muted mb-12">Recording starts automatically after prep.</div><textarea id="examTranscriptInput" placeholder="Optional transcript notes (local only)"></textarea><div id="examRecordedPlayback" class="mb-12"></div>');
            break;
          }
          case 'speaking_respond_to_situation':
            questionHtml += '<div class="timer-chip">Prep ' + toInt(payload.prepTimeSeconds, 0) + 's / Response ' + toInt(payload.responseTimeSeconds, 0) + 's</div>';
            questionHtml += '<div class="prompt-box">' + nl2br(payload.situationText) + '</div>';
            questionHtml += '<div class="small muted mb-12">Role: ' + esc(payload.role) + ' | Audience: ' + esc(payload.audience) + ' | Function: ' + esc(payload.targetFunction) + ' | Register: ' + esc(payload.targetRegister) + '</div>';
            responseHtml = buildResponseChrome('<div class="small muted mb-12">Respond in the requested role/register. Recording stays local.</div><textarea id="examTranscriptInput" placeholder="Optional transcript notes (local only)"></textarea><div id="examRecordedPlayback" class="mb-12"></div>');
            break;
          case 'speaking_answer_short_question':
            questionHtml += '<div class="timer-chip">Response ' + toInt(payload.responseTimeSeconds, 0) + 's</div>';
            questionHtml += '<div class="prompt-box">' + nl2br(payload.promptTextOrAudio) + '</div>';
            responseHtml = buildResponseChrome('<div class="small muted mb-12">Short recorded response. Local-only recording.</div><input id="examTranscriptInput" type="text" placeholder="Optional recognized answer notes"><div id="examRecordedPlayback" class="mb-12"></div>');
            break;
          case 'writing_summarize_written_text':
            questionHtml += '<div class="prompt-box">' + nl2br(payload.sourceText) + '</div>';
            questionHtml += '<div class="small muted mb-12">Word limit: ' + toInt(payload.minWords, 0) + ' - ' + toInt(payload.maxWords, 0) + '</div>';
            responseHtml = buildResponseChrome('<textarea id="examWritingInput" placeholder="Write your summary..."></textarea><div id="examWordCount" class="small muted mb-12">Word count: 0</div>');
            break;
          case 'writing_write_email':
            questionHtml += '<div class="prompt-box">' + nl2br(payload.scenarioText) + '</div>';
            questionHtml += '<div class="small muted mb-10">Recipient: ' + esc(payload.recipientRole || '-') + ' | Purpose: ' + esc(payload.purpose || '-') + '</div>';
            if (toArray(payload.requiredPoints).length) {
              questionHtml += '<div class="mb-10 fw-700 small">Required Points</div><ul class="small">';
              toArray(payload.requiredPoints).forEach((row) => { questionHtml += '<li>' + esc(row) + '</li>'; });
              questionHtml += '</ul>';
            }
            responseHtml = buildResponseChrome('<textarea id="examWritingInput" placeholder="Write your email..."></textarea><div id="examWordCount" class="small muted mb-12">Word count: 0</div>');
            break;
          case 'writing_short_answer':
            questionHtml += '<div class="prompt-box">' + nl2br(payload.promptText) + '</div>';
            responseHtml = buildResponseChrome('<textarea id="examWritingInput" placeholder="Write a short response..."></textarea><div id="examWordCount" class="small muted mb-12">Word count: 0</div>');
            break;
          case 'writing_essay':
            questionHtml += '<div class="prompt-box">' + nl2br(payload.promptText) + '</div>';
            questionHtml += '<div class="small muted mb-12">Essay type: ' + esc(payload.essayType || '-') + ' | Minimum words: ' + toInt(payload.minWords, 0) + '</div>';
            responseHtml = buildResponseChrome('<textarea id="examWritingInput" placeholder="Write your essay..."></textarea><div id="examWordCount" class="small muted mb-12">Word count: 0</div>');
            break;
          case 'reading_mcq_single':
            if (clean(payload.passageHtml)) questionHtml += '<div class="prompt-box">' + nl2br(payload.passageHtml) + '</div>';
            questionHtml += '<div class="fw-700 mb-10">' + esc(payload.stem || '') + '</div>';
            responseHtml = buildResponseChrome(renderOptionRows(payload.options, 'radio', 'preview_mcq_single'));
            break;
          case 'reading_mcq_multiple':
            if (clean(payload.passageHtml)) questionHtml += '<div class="prompt-box">' + nl2br(payload.passageHtml) + '</div>';
            questionHtml += '<div class="fw-700 mb-10">' + esc(payload.stem || '') + '</div>';
            responseHtml = buildResponseChrome(renderOptionRows(payload.options, 'checkbox', 'preview_mcq_multiple'));
            break;
          case 'reading_true_false':
            if (clean(payload.passageHtml)) questionHtml += '<div class="prompt-box">' + nl2br(payload.passageHtml) + '</div>';
            questionHtml += '<div class="fw-700 mb-10">' + esc(payload.stem || '') + '</div>';
            responseHtml = buildResponseChrome('<select id="examTrueFalseSelect"><option>True</option><option>False</option><option>Not Given</option></select>');
            break;
          case 'reading_fill_in_blank':
            questionHtml += '<div class="prompt-box">' + renderTextWithBlankSlots(payload.passageWithBlanks) + '</div>';
            if (toArray(payload.bankOptions).length) {
              questionHtml += '<div class="mb-10 fw-700 small">Word Bank</div><div class="word-bank">';
              toArray(payload.bankOptions).forEach((row) => { questionHtml += '<span>' + esc(row) + '</span>'; });
              questionHtml += '</div>';
            }
            responseHtml = buildResponseChrome('<div class="small muted">Complete blanks directly in the passage area in production flow.</div>');
            break;
          case 'reading_writing_fill_in_blank': {
            const answerMap = (payload.blankAnswerMap && typeof payload.blankAnswerMap === 'object' && !Array.isArray(payload.blankAnswerMap))
              ? payload.blankAnswerMap
              : {};
            const optionsMap = (payload.blankOptionsMap && typeof payload.blankOptionsMap === 'object' && !Array.isArray(payload.blankOptionsMap))
              ? payload.blankOptionsMap
              : {};
            questionHtml += '<div class="prompt-box">' + renderTextWithBlankSlots(payload.passageWithBlanks) + '</div>';
            const optionRows = Object.keys(answerMap)
              .map((blankKey) => {
                const optionList = Array.isArray(optionsMap[blankKey]) ? optionsMap[blankKey] : [];
                return '<li><span class="fw-700">' + esc(blankKey) + ':</span> ' + esc(optionList.join(' | ')) + '</li>';
              })
              .join('');
            questionHtml += optionRows
              ? '<div class="mb-10 fw-700 small">Per-Blank Dropdown Options</div><ul class="small mb-0">' + optionRows + '</ul>'
              : '<div class="small muted">No per-blank options set.</div>';
            responseHtml = buildResponseChrome('<div class="small muted">Select one option per blank from each drop-down in production flow.</div>');
            break;
          }
          case 'reading_reorder_paragraphs':
            if (clean(payload.passageTitle)) questionHtml += '<div class="fw-700 mb-10">' + esc(payload.passageTitle) + '</div>';
            questionHtml += '<div class="fw-700 mb-10">Reorder the paragraphs into the correct sequence.</div>';
            questionHtml += '<ol>';
            toArray(payload.paragraphItems).forEach((row) => { questionHtml += '<li class="mb-10">' + esc(row) + '</li>'; });
            questionHtml += '</ol>';
            responseHtml = buildResponseChrome('<div class="small muted">Drag/drop ordering interaction is represented in this preview.</div>');
            break;
          case 'reading_matching':
            questionHtml += '<div class="fw-700 mb-10">Match each left item to the correct right item.</div>';
            responseHtml = buildResponseChrome(renderMatchingTable(payload.leftItems, payload.rightItems));
            break;
          case 'listening_mcq_single': {
            const audioUrl = resolveMediaUrl(questionRow, payload.promptAudioAssetId);
            questionHtml += audioUrl
              ? '<div class="mb-12"><audio controls><source src="' + esc(audioUrl) + '"></audio></div>'
              : '<div class="prompt-box small muted">Audio asset is not attached yet.</div>';
            questionHtml += '<div class="fw-700 mb-10">' + esc(payload.stem || '') + '</div>';
            responseHtml = buildResponseChrome(renderOptionRows(payload.options, 'radio', 'preview_listening_single'));
