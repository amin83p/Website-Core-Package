    font-size: 0.78rem;
    font-weight: 820;
    gap: 0.4rem;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .pte-back-link {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.24);
    border-radius: 8px;
    color: #ffffff;
    margin-bottom: 1rem;
    padding: 0.48rem 0.68rem;
    text-decoration: none;
  }

  .pte-back-link:hover,
  .pte-back-link:focus {
    background: rgba(255, 255, 255, 0.2);
    color: #ffffff;
  }

  .pte-package-eyebrow {
    color: #f0c86e;
    margin-bottom: 0.75rem;
  }

  .pte-packages-hero-copy h1 {
    font-size: clamp(2.2rem, 5vw, 4.7rem);
    font-weight: 900;
    line-height: 1.03;
    margin: 0 0 1rem;
    max-width: 820px;
  }

  .pte-packages-hero-copy p {
    color: #dbeef3;
    font-size: 1.09rem;
    line-height: 1.7;
    margin: 0;
    max-width: 670px;
  }

  .pte-packages-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
    margin-top: 1.35rem;
  }

  .pte-package-btn-primary,
  .pte-package-btn-secondary,
  .pte-package-select-btn,
  .pte-package-added-btn,
  .pte-package-banner-btn {
    align-items: center;
    border-radius: 8px;
    display: inline-flex;
    font-weight: 820;
    justify-content: center;
    min-height: 44px;
    padding: 0.72rem 1rem;
  }

  .pte-package-btn-primary,
  .pte-package-select-btn {
    background: #087f8c;
    border: 1px solid #087f8c;
    color: #ffffff;
  }

  .pte-package-btn-primary:hover,
  .pte-package-btn-primary:focus,
  .pte-package-select-btn:hover,
  .pte-package-select-btn:focus {
    background: #065d67;
    border-color: #065d67;
    color: #ffffff;
  }

  .pte-package-btn-secondary {
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.5);
    color: #ffffff;
  }

  .pte-package-btn-secondary:hover,
  .pte-package-btn-secondary:focus {
    background: rgba(255, 255, 255, 0.22);
    color: #ffffff;
  }

  .pte-package-intro {
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin: -2.1rem auto 0;
    max-width: 1120px;
    padding: 0 1rem;
    position: relative;
    z-index: 2;
  }

  .pte-package-intro > div {
    background: #ffffff;
    border: 1px solid var(--pte-package-line);
    border-radius: 8px;
    box-shadow: 0 18px 36px rgba(16, 47, 63, 0.12);
    padding: 1rem;
  }

  .pte-package-intro span {
    color: var(--pte-package-muted);
    display: block;
    font-size: 0.78rem;
    font-weight: 820;
    margin-bottom: 0.25rem;
    text-transform: uppercase;
  }

  .pte-package-intro strong {
    color: var(--pte-package-ink);
    font-size: 1rem;
  }

  .pte-package-notice,
  .pte-package-join-banner,
  .pte-package-list-section {
    margin: 1rem auto 0;
    max-width: 1120px;
    padding-left: 1rem;
    padding-right: 1rem;
  }

  .pte-package-notice {
    align-items: flex-start;
    border-radius: 8px;
    display: flex;
    gap: 0.75rem;
    padding-bottom: 0.95rem;
    padding-top: 0.95rem;
  }

  .pte-package-notice i {
    font-size: 1.2rem;
    margin-top: 0.1rem;
  }

  .pte-package-notice strong,
  .pte-package-notice span {
    display: block;
  }

  .pte-package-notice span {
    color: #385160;
    margin-top: 0.15rem;
  }

  .pte-package-notice-success {
    background: #e8f6ef;
    border: 1px solid #b8e0ca;
    color: #17673e;
  }

  .pte-package-notice-info {
    background: #eaf3fb;
    border: 1px solid #c5dcf1;
    color: #2457c5;
  }

  .pte-package-notice-warning {
    background: #fff7e2;
    border: 1px solid #ecd58f;
    color: #8b5d04;
  }

  .pte-package-notice-danger {
    background: #fdeeed;
    border: 1px solid #efc5c0;
    color: #a43d32;
  }

  .pte-package-join-banner {
    align-items: center;
    background: #fff7e2;
    border: 1px solid #ecd58f;
    border-radius: 8px;
    display: flex;
    gap: 1rem;
    justify-content: space-between;
    padding-bottom: 1rem;
    padding-top: 1rem;
  }

  .pte-package-join-banner span,
  .pte-package-join-banner strong {
    display: block;
  }

  .pte-package-join-banner span {
    color: #8b5d04;
    font-weight: 820;
  }

  .pte-package-join-banner strong {
    color: #4c3a11;
    font-size: 0.93rem;
    font-weight: 650;
    margin-top: 0.18rem;
  }

  .pte-package-banner-btn {
    background: #f0b84e;
    border: 1px solid #f0b84e;
    color: #102f3f;
    flex: 0 0 auto;
  }

  .pte-package-banner-btn:hover,
  .pte-package-banner-btn:focus {
    background: #d99d26;
    border-color: #d99d26;
    color: #102f3f;
  }

  .pte-package-list-section {
    padding-bottom: 4rem;
    padding-top: 2.2rem;
  }

  .pte-package-section-heading {
    margin-bottom: 1.1rem;
    max-width: 680px;
  }

  .pte-package-section-heading span {
    color: #087f8c;
    display: block;
    font-size: 0.78rem;
    font-weight: 820;
    margin-bottom: 0.38rem;
    text-transform: uppercase;
  }

  .pte-package-section-heading h2 {
    color: var(--pte-package-ink);
    font-size: clamp(1.6rem, 3vw, 2.35rem);
    font-weight: 900;
    line-height: 1.12;
    margin: 0 0 0.45rem;
  }

  .pte-package-section-heading p {
    color: var(--pte-package-muted);
    line-height: 1.65;
    margin: 0;
  }

  .pte-package-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .pte-package-card {
    --package-accent: #087f8c;
    --package-accent-2: #13b0a5;
    --package-line: #b8e6e2;
    --package-wash: rgba(8, 127, 140, 0.1);
    background:
      linear-gradient(135deg, var(--package-wash), #ffffff 50%, rgba(240, 184, 78, 0.13));
    border: 1px solid var(--package-line);
    border-radius: 8px;
    box-shadow: 0 14px 34px rgba(16, 47, 63, 0.08);
    display: flex;
    flex-direction: column;
    min-height: 520px;
    overflow: hidden;
    padding: 1rem;
    position: relative;
    transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }

  .pte-package-card:nth-child(2n) {
    --package-accent: #2457c5;
    --package-accent-2: #6f55d8;
    --package-line: #c8d6fb;
    --package-wash: rgba(36, 87, 197, 0.1);
  }

  .pte-package-card:nth-child(3n) {
    --package-accent: #287a54;
    --package-accent-2: #8bb43f;
    --package-line: #c8e4cf;
    --package-wash: rgba(40, 122, 84, 0.1);
  }

  .pte-package-card:nth-child(4n) {
    --package-accent: #b56b00;
    --package-accent-2: #de8d2e;
    --package-line: #ecd2a5;
    --package-wash: rgba(181, 107, 0, 0.1);
  }

  .pte-package-card:nth-child(5n) {
    --package-accent: #8d3f95;
    --package-accent-2: #d24b7c;
    --package-line: #e5c3e8;
    --package-wash: rgba(141, 63, 149, 0.1);
  }

  .pte-package-card::before {
    background: linear-gradient(90deg, var(--package-accent), var(--package-accent-2));
    content: "";
    height: 6px;
    inset: 0 0 auto;
    position: absolute;
  }

  .pte-package-card:hover,
  .pte-package-card:focus-within {
    border-color: var(--package-accent);
    box-shadow: 0 20px 42px rgba(16, 47, 63, 0.16);
    transform: translateY(-4px);
  }

  .pte-package-card-top {
    align-items: center;
    display: flex;
    justify-content: space-between;
    margin-bottom: 1rem;
    padding-top: 0.35rem;
  }

  .pte-package-card-icon {
    align-items: center;
    background: #ffffff;
    border: 1px solid var(--package-line);
    border-radius: 8px;
    color: var(--package-accent);
    display: inline-flex;
    font-size: 1.2rem;
    height: 44px;
    justify-content: center;
    width: 44px;
  }

  .pte-package-card-price {
    background: #102f3f;
    border-radius: 8px;
    color: #ffffff;
    font-size: 0.92rem;
    font-weight: 900;
    padding: 0.45rem 0.62rem;
  }

  .pte-package-category {
    color: var(--package-accent);
    display: block;
    font-size: 0.78rem;
    font-weight: 820;
    margin-bottom: 0.35rem;
    text-transform: uppercase;
  }

  .pte-package-card-main h3 {
    color: var(--pte-package-ink);
    font-size: 1.25rem;
    font-weight: 900;
    line-height: 1.24;
    margin: 0 0 0.55rem;
  }

  .pte-package-card-main p {
    color: var(--pte-package-muted);
    font-size: 0.94rem;
    line-height: 1.58;
    margin: 0;
  }

  .pte-package-meta {
    display: grid;
    gap: 0.55rem;
    margin-top: 1rem;
  }

  .pte-package-meta div {
    align-items: flex-start;
    color: #2e4858;
    display: flex;
    font-size: 0.88rem;
    gap: 0.5rem;
    line-height: 1.45;
  }

  .pte-package-meta i {
    color: var(--package-accent);
    margin-top: 0.12rem;
  }

  .pte-package-chips,
  .pte-package-role-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
    margin-top: 1rem;
  }

  .pte-package-chips span,
  .pte-package-role-row span {
    align-items: center;
    border-radius: 8px;
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 760;
    gap: 0.25rem;
    line-height: 1.25;
    padding: 0.36rem 0.5rem;
  }

  .pte-package-chips span {
    background: #ffffff;
    border: 1px solid var(--package-line);
    color: #304c5d;
  }

  .pte-package-role-row span {
    background: rgba(8, 127, 140, 0.09);
    border: 1px solid var(--package-line);
    color: var(--package-accent);
  }

  .pte-package-card-action {
    margin-top: auto;
    padding-top: 1.15rem;
  }

  .pte-package-card-action form,
  .pte-package-card-action .btn {
    width: 100%;
  }

  .pte-package-added-btn {
    background: #e8f6ef;
    border: 1px solid #b8e0ca;
    color: #17673e;
    cursor: default;
  }

  .pte-package-empty {
    background: var(--pte-package-soft);
    border: 1px solid var(--pte-package-line);
    border-radius: 8px;
    padding: 2.2rem;
    text-align: center;
  }

  .pte-package-empty i {
    color: #087f8c;
    font-size: 2.4rem;
  }

  .pte-package-empty h3 {
    color: var(--pte-package-ink);
    font-size: 1.35rem;
    font-weight: 900;
    margin: 0.8rem 0 0.45rem;
  }

  .pte-package-empty p {
    color: var(--pte-package-muted);
    margin: 0 auto;
    max-width: 540px;
  }

  @media (max-width: 1099.98px) {
    .pte-package-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 767.98px) {
    .pte-packages-hero {
      min-height: 560px;
      padding: 2rem 1rem;
    }

    .pte-packages-hero-overlay {
      background: linear-gradient(180deg, rgba(10, 28, 39, 0.94) 0%, rgba(10, 28, 39, 0.75) 68%, rgba(10, 28, 39, 0.38) 100%);
    }

    .pte-packages-actions .btn,
    .pte-package-banner-btn {
      width: 100%;
    }

    .pte-package-intro,
    .pte-package-grid {
      grid-template-columns: 1fr;
    }

    .pte-package-join-banner {
      align-items: stretch;
      flex-direction: column;
    }

    .pte-package-card {
      min-height: 0;
    }
  }
</style>
