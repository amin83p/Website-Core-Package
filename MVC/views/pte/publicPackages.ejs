  }

  .pte-packages-hero-image {
    height: 100%;
    inset: 0;
    object-fit: cover;
    position: absolute;
    width: 100%;
  }

  .pte-packages-hero-overlay {
    background:
      linear-gradient(90deg, rgba(10, 28, 39, 0.92) 0%, rgba(10, 28, 39, 0.76) 48%, rgba(10, 28, 39, 0.26) 100%),
      linear-gradient(180deg, rgba(240, 184, 78, 0.24), rgba(8, 127, 140, 0.12));
    inset: 0;
    position: absolute;
  }

  .pte-packages-hero-copy {
    color: #ffffff;
    max-width: 760px;
    position: relative;
