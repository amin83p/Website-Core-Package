<%
  const pageData = page || {};
  const packages = Array.isArray(pageData.packages) ? pageData.packages : [];
  const assignedPackageIds = Array.isArray(pageData.assignedPackageIds) ? pageData.assignedPackageIds.map((id) => String(id || '')) : [];
  const roleState = pageData.roleState || {};
  const isSignedIn = Boolean(user);
  const hasPublicAccess = roleState.joined === true;
  const publicRoleToken = pageData.publicRoleToken || 'pte_student_public';
  const pageNotice = notice || null;
  const packageHeroImage = '/uploads/ORG_900000/PTE/Question_Bank/chart__2__1777010014581.webp';
  const isAssigned = (id) => assignedPackageIds.some((item) => String(item) === String(id || ''));
  const plural = (count, word) => Number(count || 0) === 1 ? word : word + 's';
  const firstItems = (values, limit) => (Array.isArray(values) ? values : []).slice(0, limit).filter(Boolean);
%>

<section class="pte-packages-page">
  <section class="pte-packages-hero" aria-labelledby="ptePackagesTitle">
    <img src="<%= packageHeroImage %>" alt="PTE practice chart prompt" class="pte-packages-hero-image">
    <div class="pte-packages-hero-overlay"></div>

    <div class="pte-packages-hero-copy">
      <a class="pte-back-link" href="/pte">
        <i class="bi bi-arrow-left"></i>
        <span>PTE Public Page</span>
      </a>
      <div class="pte-package-eyebrow">Public PTE Packages</div>
      <h1 id="ptePackagesTitle">Choose the package that fits your practice plan.</h1>
      <p>
        These packages are prepared for public PTE students. Browse the options, activate Public PTE with your account, and add the package you want to your profile.
      </p>

      <div class="pte-packages-actions">
        <% if (!isSignedIn) { %>
          <a class="btn pte-package-btn-primary" href="/pte/join">
            <i class="bi bi-person-plus-fill me-2"></i>Join Public PTE
          </a>
          <a class="btn pte-package-btn-secondary" href="/login">
            <i class="bi bi-box-arrow-in-right me-2"></i>Sign In
          </a>
        <% } else if (!hasPublicAccess) { %>
          <a class="btn pte-package-btn-primary" href="/pte/join">
            <i class="bi bi-stars me-2"></i>Activate Public PTE
          </a>
        <% } else { %>
          <a class="btn pte-package-btn-primary" href="#ptePackageList">
            <i class="bi bi-bag-check-fill me-2"></i>View Packages
          </a>
        <% } %>
      </div>
    </div>
  </section>

  <section class="pte-package-intro" aria-label="Package status">
    <div>
      <span>Role Required</span>
      <strong><%= publicRoleToken %></strong>
    </div>
    <div>
      <span>Same Login</span>
      <strong><%= isSignedIn ? 'Signed in account' : 'Join or sign in' %></strong>
    </div>
    <div>
      <span>Profile Action</span>
      <strong>Add package to profile</strong>
    </div>
  </section>

  <% if (pageNotice) { %>
    <div class="pte-package-notice pte-package-notice-<%= pageNotice.type || 'info' %>" role="status">
      <i class="bi <%= pageNotice.type === 'success' ? 'bi-check-circle-fill' : (pageNotice.type === 'warning' ? 'bi-exclamation-triangle-fill' : (pageNotice.type === 'danger' ? 'bi-x-circle-fill' : 'bi-info-circle-fill')) %>"></i>
      <div>
        <strong><%= pageNotice.title || 'Notice' %></strong>
        <span><%= pageNotice.message || '' %></span>
      </div>
    </div>
  <% } %>

  <% if (isSignedIn && !hasPublicAccess) { %>
    <div class="pte-package-join-banner">
      <div>
        <span>Public PTE is not active on this account yet.</span>
        <strong>Activate it first so package role checks can add the selected package correctly.</strong>
      </div>
      <a href="/pte/join" class="btn pte-package-banner-btn">Activate Public PTE</a>
    </div>
  <% } %>

  <section class="pte-package-list-section" id="ptePackageList" aria-labelledby="ptePackageListTitle">
    <div class="pte-package-section-heading">
      <span>Available Packages</span>
      <h2 id="ptePackageListTitle">Public packages for PTE applicants.</h2>
      <p>Only packages configured for the public PTE student role are shown here.</p>
    </div>

    <% if (!packages.length) { %>
      <div class="pte-package-empty">
        <i class="bi bi-box-seam"></i>
        <h3>No public PTE packages are available yet.</h3>
        <p>When a package is marked public and assigned to <%= publicRoleToken %>, it will appear on this page.</p>
      </div>
    <% } else { %>
      <div class="pte-package-grid">
        <% packages.forEach((pkg, index) => { %>
          <% const assigned = isAssigned(pkg.id); %>
          <% const sectionCount = Number(pkg.summary?.sectionCount || 0); %>
          <% const operationCount = Number(pkg.summary?.operationCount || 0); %>
          <% const profileCount = Number(pkg.summary?.accessProfileCount || 0); %>
          <article class="pte-package-card" style="--package-index: <%= index %>;">
            <div class="pte-package-card-top">
              <div class="pte-package-card-icon">
                <i class="bi bi-bag-heart-fill"></i>
              </div>
              <div class="pte-package-card-price"><%= pkg.priceLabel || 'Free' %></div>
            </div>

            <div class="pte-package-card-main">
              <span class="pte-package-category"><%= pkg.category || 'PTE Practice' %></span>
              <h3><%= pkg.name || 'PTE Public Package' %></h3>
              <p><%= pkg.description || '' %></p>
            </div>

            <div class="pte-package-meta">
              <div>
                <i class="bi bi-calendar2-check"></i>
                <span><%= pkg.validityLabel || 'Starts when added' %></span>
              </div>
              <div>
                <i class="bi bi-layers"></i>
                <span><%= sectionCount %> <%= plural(sectionCount, 'section') %>, <%= operationCount %> <%= plural(operationCount, 'operation') %></span>
              </div>
              <div>
                <i class="bi bi-person-vcard"></i>
                <span><%= profileCount %> access <%= plural(profileCount, 'profile') %></span>
              </div>
            </div>

            <% const sectionsPreview = firstItems(pkg.sectionLabels, 3); %>
            <% const operationsPreview = firstItems(pkg.operationLabels, 5); %>
            <div class="pte-package-chips" aria-label="Package contents">
              <% if (sectionsPreview.length) { %>
                <% sectionsPreview.forEach((label) => { %>
                  <span><%= label %></span>
                <% }) %>
              <% } %>
              <% if (operationsPreview.length) { %>
                <% operationsPreview.forEach((label) => { %>
                  <span><%= label %></span>
                <% }) %>
              <% } %>
              <% if (!sectionsPreview.length && !operationsPreview.length) { %>
                <span>Practice access</span>
              <% } %>
            </div>

            <div class="pte-package-role-row">
              <% (pkg.roleLabels || []).forEach((role) => { %>
                <span><i class="bi bi-check2-circle"></i><%= role %></span>
              <% }) %>
            </div>

            <div class="pte-package-card-action">
              <% if (assigned) { %>
                <button type="button" class="btn pte-package-added-btn" disabled>
                  <i class="bi bi-check-circle-fill me-2"></i>Added To Profile
                </button>
              <% } else if (!isSignedIn) { %>
                <a class="btn pte-package-select-btn" href="/pte/join">
                  <i class="bi bi-person-plus-fill me-2"></i>Join To Select
                </a>
              <% } else if (!hasPublicAccess) { %>
                <a class="btn pte-package-select-btn" href="/pte/join">
                  <i class="bi bi-stars me-2"></i>Activate To Select
                </a>
              <% } else { %>
                <form method="POST" action="/pte/packages/<%= encodeURIComponent(pkg.id) %>/select">
                  <button type="submit" class="btn pte-package-select-btn">
                    <i class="bi bi-plus-circle-fill me-2"></i>Add To My Profile
                  </button>
                </form>
              <% } %>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
</section>

<style>
