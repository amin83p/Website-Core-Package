// ✅ COMPLETE RENDER FUNCTION (Restores all cards)
function renderExtractionResults(data, keys, meta) {
  // 1. Update Raw JSON Tab
  const rawEl = document.getElementById("aiRawJson");
  if (rawEl) rawEl.textContent = JSON.stringify(data, null, 2);

  // 2. Prepare visual container
  const container = document.getElementById("visual-pane");
  if (!container) return;
  
  // Clear previous content
  container.innerHTML = ""; 

  // --- A. MODEL BADGE ---
  const modelName = meta?.modelUsed || 'Unknown Model';
  const badgeHtml = `<div class="mb-2 text-end"><span class="badge bg-light text-dark border"><i class="bi bi-cpu me-1"></i> ${modelName}</span></div>`;

  // --- B. PROMPT COVERAGE CARD ---
  const answers = data?.answersBySubquestion || {};
  const displayKeys = Array.isArray(keys) && keys.length ? keys : Object.keys(answers);
  
  let subQList = "";
  displayKeys.forEach(k => {
    const indices = Array.isArray(answers[k]) ? answers[k] : [];
    const count = indices.length;
    const badge = count > 0 
        ? `<span class="badge bg-success rounded-pill">${count} refs</span>` 
        : `<span class="badge bg-danger rounded-pill">Missing</span>`;
    
    // Clean up key name for display
    const readableKey = String(k).replace(/^q\d+_/, "").replace(/_/g, " ");
    const idxText = count > 0 
        ? `<span class="text-muted font-monospace me-2">S${indices.join(", S")}</span>` 
        : `<span class="text-muted font-monospace me-2">—</span>`;

    subQList += `
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <span class="text-capitalize text-truncate" style="max-width: 350px;" title="${readableKey}">${readableKey}</span>
        <div>${idxText}${badge}</div>
      </li>`;
  });

  const coverageCardHtml = `
    <div class="card shadow-sm border-0 mb-3" id="aiSubQCard">
      <div class="card-header bg-white fw-bold small">Prompt Coverage</div>
      <ul class="list-group list-group-flush small">
        ${subQList}
      </ul>
    </div>`;

  // --- C. POSITION & STANCE CARD ---
  const stance = data?.position?.stance ?? "unknown";
  const stanceIdx = data?.position?.stanceSentenceIndex ?? "-";
  const contradictions = data?.position?.contradictionSentenceIndices || [];
  
  let contraHtml = (Array.isArray(contradictions) && contradictions.length > 0) 
      ? `<div class="small text-danger mt-1"><i class="bi bi-exclamation-triangle-fill me-1"></i> Contradictions at Sentences ${contradictions.join(", ")}</div>`
      : `<div class="small text-success mt-1"><i class="bi bi-check-circle me-1"></i> No contradictions detected.</div>`;

  const stanceCardHtml = `
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-header bg-white fw-bold text-dark small">Position & Stance</div>
        <div class="card-body">
            <div class="d-flex gap-3 align-items-center">
                <span class="badge bg-primary text-uppercase fs-6" id="aiStance">${stance}</span>
                <span class="small text-muted">Stance found at Sentence #<span id="aiStanceIdx" class="fw-bold text-dark">${stanceIdx}</span></span>
            </div>
            <div id="aiContradictions">${contraHtml}</div>
        </div>
    </div>`;

  // --- D. PARAGRAPH EVIDENCE MAP CARD ---
  const topicMap = data?.topicSentenceByParagraph || [];
  const paraRows = (data?.bodySupport || []).map(para => {
      const pIdx = para.paragraphIndex;
      const topicEntry = topicMap.find(t => t.paragraphIndex === pIdx);
      const topicIdx = topicEntry ? (topicEntry.topicSentenceIndex ?? "-") : "-";
      const evidence = Array.isArray(para.evidenceSentenceIndices) && para.evidenceSentenceIndices.length
        ? para.evidenceSentenceIndices.join(", ") : "-";
      
      const flags = [];
      if (para.hasExplanation) flags.push(`<span class="badge bg-success bg-opacity-10 text-success border">Exp</span>`);
      if (para.hasExample) flags.push(`<span class="badge bg-info bg-opacity-10 text-info border">Ex</span>`);
      
      return `
        <tr>
          <td class="fw-bold text-center">${pIdx}</td>
          <td class="text-center font-monospace text-primary">${topicIdx}</td>
          <td class="text-center font-monospace">${evidence}</td>
          <td>${flags.join(" ")}</td>
        </tr>`;
  }).join("");

  const evidenceCardHtml = `
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-header bg-white fw-bold text-dark small">Paragraph Evidence Map</div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-sm mb-0 small align-middle">
                    <thead class="table-light">
                        <tr><th>Para</th><th>Topic Sent #</th><th>Evidence #</th><th>Flags</th></tr>
                    </thead>
                    <tbody id="aiParaTable">${paraRows || '<tr><td colspan="4" class="text-center text-muted">No body paragraphs detected.</td></tr>'}</tbody>
                </table>
            </div>
        </div>
    </div>`;

  // --- E. INJECT EVERYTHING ---
  container.insertAdjacentHTML('beforeend', badgeHtml);
  container.insertAdjacentHTML('beforeend', coverageCardHtml);
  container.insertAdjacentHTML('beforeend', stanceCardHtml);
  container.insertAdjacentHTML('beforeend', evidenceCardHtml);
}
