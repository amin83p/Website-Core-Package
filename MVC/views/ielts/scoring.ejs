<!-- Grading Settings Modal (no Bootstrap dependency) -->
<div id="gradingSettingsOverlay" class="gs-overlay d-none" role="dialog" aria-modal="true" aria-labelledby="gradingSettingsTitle">
  <div class="gs-modal">
    <div class="gs-header">
      <div>
        <div id="gradingSettingsTitle" class="fw-bold">Grading Settings</div>
        <div class="text-muted small">Controls how Step 4 batches questions and how many AI requests run in parallel.</div>
      </div>
      <button type="button" class="btn btn-sm btn-outline-secondary" onclick="closeGradingSettings()" aria-label="Close">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <div class="gs-body">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label fw-bold">Batch size (questions per prompt)</label>
          <input id="gradingBatchSizeInput" type="number" class="form-control" min="1" max="20" step="1" />
          <div class="form-text">Recommended: 4–8. Max: 20.</div>
        </div>

        <div class="col-md-6">
          <label class="form-label fw-bold">Concurrency (parallel batches)</label>
          <input id="gradingConcurrencyInput" type="number" class="form-control" min="1" max="10" step="1" />
          <div class="form-text">Recommended: 1–4. Max: 10.</div>
        </div>
      </div>

      <div id="gradingSettingsWarning" class="alert alert-warning mt-3 d-none" role="alert"></div>
    </div>

    <div class="gs-footer">
      <button type="button" class="btn btn-outline-secondary" onclick="resetGradingSettings()">Reset</button>
      <div class="ms-auto d-flex gap-2">
        <button type="button" class="btn btn-outline-secondary" onclick="closeGradingSettings()">Cancel</button>
        <button type="button" class="btn btn-success" onclick="applyGradingSettings()">Apply</button>
      </div>
    </div>
  </div>
</div>

<script>
/* =========================================================
   Global Stores (same intent as your original)
   ========================================================= */
let GLOBALESSAYOBJECT = null;
let GLOBALSAMPLEID = null;

let GLOBALEXTRACTION = null;
let GLOBALPARAGRAPHROLES = null;
let GLOBALANALYSIS = null;
let GLOBALGRADING = null;
let GLOBALFEEDBACK = null;

// ------------------------------
// Grading (Step 4) runtime settings
// ------------------------------
const GRADING_LIMITS = {
  batchSize: { min: 1, max: 20, criticalMax: 12 },      // criticalMax: warning threshold
  concurrency: { min: 1, max: 10, criticalMax: 6 }      // criticalMax: warning threshold
};

let GRADING_SETTINGS = {
  batchSize: 5,
  concurrency: 2
};

function clampInt(v, min, max, fallback) {
  const n = Number.parseInt(v, 10);
  if (Number.isNaN(n)) return fallback;
  return Math.max(min, Math.min(max, n));
}

function loadGradingSettings() {
  try {
    const raw = localStorage.getItem("ielts_grading_settings");
    if (raw) {
      const parsed = JSON.parse(raw);
      GRADING_SETTINGS.batchSize = clampInt(parsed.batchSize, GRADING_LIMITS.batchSize.min, GRADING_LIMITS.batchSize.max, GRADING_SETTINGS.batchSize);
      GRADING_SETTINGS.concurrency = clampInt(parsed.concurrency, GRADING_LIMITS.concurrency.min, GRADING_LIMITS.concurrency.max, GRADING_SETTINGS.concurrency);
    }
  } catch (_) {}
  updateGradingSettingsLabels();
}

function saveGradingSettings() {
  localStorage.setItem("ielts_grading_settings", JSON.stringify(GRADING_SETTINGS));
  updateGradingSettingsLabels();
}

function updateGradingSettingsLabels() {
  const b = document.getElementById("gradingBatchSizeLabel");
  const c = document.getElementById("gradingConcurrencyLabel");
  if (b) b.textContent = String(GRADING_SETTINGS.batchSize);
  if (c) c.textContent = String(GRADING_SETTINGS.concurrency);
}


function computeGradingSettingsWarnings(batchSize, concurrency) {
  const warnings = [];
  if (batchSize > GRADING_LIMITS.batchSize.criticalMax) {
    warnings.push(`Batch size ${batchSize} is high. Large prompts may reduce reliability and can trigger truncation.`);
  }
  if (concurrency > GRADING_LIMITS.concurrency.criticalMax) {
    warnings.push(`Concurrency ${concurrency} is high. This can trigger rate limits, increase cost, and make runs less stable.`);
  }
  if (batchSize * concurrency > 60) {
    warnings.push(`BatchSize × Concurrency = ${batchSize * concurrency} (very high). Consider lowering one of them.`);
  }
  return warnings;
}

function openGradingSettings() {
  loadGradingSettings();
  const overlay = document.getElementById("gradingSettingsOverlay");
  const b = document.getElementById("gradingBatchSizeInput");
  const c = document.getElementById("gradingConcurrencyInput");
  if (!overlay || !b || !c) return;

  b.value = GRADING_SETTINGS.batchSize;
  c.value = GRADING_SETTINGS.concurrency;

  overlay.classList.remove("d-none");
  document.body.classList.add("gs-no-scroll");

  setTimeout(() => b.focus(), 0);

  // Close on outside click
  overlay.addEventListener("click", gradingOverlayClickClose);
  // Close on Esc
  window.addEventListener("keydown", gradingEscClose);
  updateGradingSettingsModalWarning();
}

function closeGradingSettings() {
  const overlay = document.getElementById("gradingSettingsOverlay");
  if (!overlay) return;
  overlay.classList.add("d-none");
  document.body.classList.remove("gs-no-scroll");

  overlay.removeEventListener("click", gradingOverlayClickClose);
  window.removeEventListener("keydown", gradingEscClose);
}

function gradingOverlayClickClose(e) {
  if (e.target && e.target.id === "gradingSettingsOverlay") {
    closeGradingSettings();
  }
}
function gradingEscClose(e) {
  if (e.key === "Escape") closeGradingSettings();
}

function updateGradingSettingsModalWarning() {
  const warnEl = document.getElementById("gradingSettingsWarning");
  const b = document.getElementById("gradingBatchSizeInput");
  const c = document.getElementById("gradingConcurrencyInput");
  if (!warnEl || !b || !c) return;

  const bs = clampInt(b.value, GRADING_LIMITS.batchSize.min, GRADING_LIMITS.batchSize.max, GRADING_SETTINGS.batchSize);
  const cc = clampInt(c.value, GRADING_LIMITS.concurrency.min, GRADING_LIMITS.concurrency.max, GRADING_SETTINGS.concurrency);

  const warnings = computeGradingSettingsWarnings(bs, cc);
  if (warnings.length === 0) {
    warnEl.classList.add("d-none");
    warnEl.innerHTML = "";
  } else {
    warnEl.classList.remove("d-none");
    warnEl.innerHTML = `<div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle me-1"></i>Warning</div><ul class="mb-0">${warnings.map(w => `<li>${escapeHtml(w)}</li>`).join("")}</ul>`;
  }
}

function applyGradingSettings() {
  const b = document.getElementById("gradingBatchSizeInput");
  const c = document.getElementById("gradingConcurrencyInput");
  if (!b || !c) return;

  const newBatch = clampInt(b.value, GRADING_LIMITS.batchSize.min, GRADING_LIMITS.batchSize.max, GRADING_SETTINGS.batchSize);
  const newConc = clampInt(c.value, GRADING_LIMITS.concurrency.min, GRADING_LIMITS.concurrency.max, GRADING_SETTINGS.concurrency);

  GRADING_SETTINGS.batchSize = newBatch;
  GRADING_SETTINGS.concurrency = newConc;

  saveGradingSettings();
  closeGradingSettings();
}

function resetGradingSettings() {
  GRADING_SETTINGS = { batchSize: 5, concurrency: 2 };
  saveGradingSettings();
  const b = document.getElementById("gradingBatchSizeInput");
  const c = document.getElementById("gradingConcurrencyInput");
  if (b) b.value = GRADING_SETTINGS.batchSize;
  if (c) c.value = GRADING_SETTINGS.concurrency;
  updateGradingSettingsModalWarning();
}

// Live warning update while user types
document.addEventListener("input", (e) => {
  if (e.target && (e.target.id === "gradingBatchSizeInput" || e.target.id === "gradingConcurrencyInput")) {
    updateGradingSettingsModalWarning();
  }
});



/* =========================================================
   RAW SESSION BUNDLE (no HTML)
   ========================================================= */
const SESSION_BUNDLE = {
  schema: "ielts-scoring-session",
  version: 1,
  savedAt: null,
  metadata: {},
  uiState: {},
  steps: {}, // stepKey -> { request, response, timing }
  dirty: false //if we have data on page

};

function downloadJson(filename, obj) {
  const blob = new Blob([JSON.stringify(obj, null, 2)], { type: "application/json" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = filename;
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
}

async function safeShowMessage(options) {
  if (typeof showMessageModal === "function") return await showMessageModal(options);
  alert(`${options.title}\n\n${options.message}`);
}


// ----- TIMING UI -----
const TIMED_STEPS = [
  { key: "step1freeze", label: "Step 1 Freeze", el: "timerStep1" },
  { key: "step2analyze", label: "Step 2 Analysis", el: "timerStep2" },
  { key: "step3extract", label: "Step 3 Extraction", el: "timerStep3" },
  { key: "step4grade", label: "Step 4 Grading", el: "timerStep4" },
  { key: "step5feedback", label: "Step 5 Feedback", el: "timerStep5" }
];

let RUNNING_TIMER = { intervalId: null, startedAtMs: null, stepKey: null };

function formatMs(ms) {
  if (ms == null || Number.isNaN(ms)) return "—";
  return `${(ms / 1000).toFixed(2)}s`;
}

function getStepDurationMs(stepKey) {
  const step = SESSION_BUNDLE?.steps?.[stepKey]; // if your constant is SESSIONBUNDLE, rename here
  const t = step?.timing;
  if (!t?.startedAt || !t?.endedAt) return null;
  return Math.max(0, t.endedAt - t.startedAt);
}

function computeTotalMs() {
  return TIMED_STEPS.reduce((sum, s) => {
    const d = getStepDurationMs(s.key);
    return sum + (d ?? 0);
  }, 0);
}

function refreshTimingUI() {
  const totalEl = document.getElementById("timerTotal");
  if (totalEl) totalEl.textContent = formatMs(computeTotalMs());

  TIMED_STEPS.forEach(s => {
    const el = document.getElementById(s.el);
    if (!el) return;
    el.textContent = formatMs(getStepDurationMs(s.key));
  });
}

function startRunningTimer(stepKey, label) {
  const badge = document.getElementById("timerRunningBadge");
  const labelEl = document.getElementById("timerRunningLabel");
  const valEl = document.getElementById("timerRunningValue");

  RUNNING_TIMER.stepKey = stepKey;
  RUNNING_TIMER.startedAtMs = Date.now();

  if (labelEl) labelEl.textContent = label || stepKey;
  if (badge) badge.classList.remove("d-none");

  if (RUNNING_TIMER.intervalId) clearInterval(RUNNING_TIMER.intervalId);
  RUNNING_TIMER.intervalId = setInterval(() => {
    if (!valEl) return;
    valEl.textContent = formatMs(Date.now() - RUNNING_TIMER.startedAtMs);
  }, 100);
}

function stopRunningTimer() {
  const badge = document.getElementById("timerRunningBadge");
  if (RUNNING_TIMER.intervalId) clearInterval(RUNNING_TIMER.intervalId);
  RUNNING_TIMER.intervalId = null;
  RUNNING_TIMER.startedAtMs = null;
  RUNNING_TIMER.stepKey = null;
  if (badge) badge.classList.add("d-none");
}


function getCurrentStepNumber() {
  const active = document.querySelector(".step-item.active");
  return active ? String(active.dataset.step) : "1";
}

function captureUiState() {
  return {
    currentStep: getCurrentStepNumber(),
    subQKeys: document.getElementById("subQKeys")?.value ?? "",
    reviewPromptText: document.getElementById("reviewPromptText")?.value ?? "",
    // Persist Step 4 runtime parameters with the session so saved/reopened sessions
    // are reproducible and comparisons are meaningful.
    gradingSettings: {
      batchSize: GRADING_SETTINGS?.batchSize ?? 5,
      concurrency: GRADING_SETTINGS?.concurrency ?? 2
    }
  };
}

async function postJsonAndRecord(stepKey, url, payload) {
    const stepMeta = TIMED_STEPS.find(s => s.key === stepKey);
    startRunningTimer(stepKey, stepMeta?.label || stepKey);
  
    const startedAt = Date.now();
  try {

        const res = await fetch(url, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(payload)
        });

        const contentType = res.headers.get("content-type") || "";
        let json = null;
        let text = null;

        try {
            if (contentType.includes("application/json")) json = await res.json();
            else text = await res.text();
        } catch (e) {
            text = `<<failed to parse response>> ${String(e?.message || e)}`;
        }

        SESSION_BUNDLE.steps[stepKey] = {
            request: { url, payload },
            response: { contentType, json, text },
            timing: { startedAt, endedAt: Date.now() }
        };
        SESSION_BUNDLE.dirty = true;
        
        if (!json) throw new Error(`Non-JSON response for ${stepKey} (content-type: ${contentType || "unknown"})`);
        return json;
    } finally {
    stopRunningTimer();
    refreshTimingUI();
  }
}

/* =========================================================
   Navigation (same behavior)
   ========================================================= */
function activateStep(n) {
  // OLD (problem): document.querySelectorAll('.tab-pane')...
  document.querySelectorAll('.tab-pane').forEach(p => {
    if (/^step[1-6]$/.test(p.id)) p.classList.remove('show', 'active');
  });

  document.getElementById(`step${n}`)?.classList.add('show', 'active');

  document.querySelectorAll("#pipelineStepsContent > .tab-pane").forEach(p => p.classList.remove("show", "active"));
  document.getElementById(`step${n}`)?.classList.add("show", "active");

  document.querySelectorAll(".step-item").forEach(el => {
    el.classList.remove("active", "border-primary", "bg-light");
    el.classList.add("text-muted");
    const fw = el.querySelector(".fw-bold");
    if (fw) { fw.classList.remove("text-primary"); fw.classList.add("text-muted"); }
  });

  document.querySelectorAll(".step-item").forEach(el => {
    if (parseInt(el.dataset.step) === n) {
      el.classList.add("active", "border-primary", "bg-light");
      el.classList.remove("text-muted");
      const fw = el.querySelector(".fw-bold");
      if (fw) { fw.classList.add("text-primary"); fw.classList.remove("text-muted"); }
    }
  });

  window.scrollTo({ top: 0, behavior: "smooth" });
}

function ensureInnerTabVisible(tabsId) {
  const btn = document.querySelector(`#${tabsId} .nav-link.active`);
  if (!btn) return;

  // Bootstrap tab API will apply active/show to the correct pane
  if (window.bootstrap?.Tab) bootstrap.Tab.getOrCreateInstance(btn).show();
}


function ensureActiveInnerTab(tabsUlId) {
  const btn = document.querySelector(`#${tabsUlId} .nav-link.active`);
  if (btn && window.bootstrap?.Tab) bootstrap.Tab.getOrCreateInstance(btn).show();
}

function goToReport() {
  // Require feedback because report depends on it
  if (!GLOBALFEEDBACK) {
    return safeShowMessage({
      title: "Report not ready",
      icon: "warning",
      message: "Complete Step 5 (Feedback) first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }
  activateStep(6);
  renderReport();
}

function hasActiveSessionData() {
  const hasGlobals =
    !!GLOBALESSAYOBJECT ||
    !!GLOBALANALYSIS ||
    !!GLOBALEXTRACTION ||
    !!GLOBALGRADING ||
    !!GLOBALFEEDBACK;

  const hasSteps = SESSION_BUNDLE?.steps && Object.keys(SESSION_BUNDLE.steps).length > 0;

  const sampleVal = document.getElementById("sampleSelect")?.value;
  const hasSampleSelected = !!sampleVal && sampleVal !== "-- Select Essay --";

  return hasGlobals || hasSteps || hasSampleSelected;
}

function doHardReset() {
  // simplest: reload the page and clear in-memory session
  window.location='scoring';
}

function startNewReport() {
  const active = hasActiveSessionData();
  const dirty = !!SESSION_BUNDLE?.dirty;

  if (!active) return doHardReset();

  const message = dirty
    ? "You have an active session with unsaved changes. Starting a new report will clear everything on this page."
    : "You have an active session. Starting a new report will clear everything on this page.";

    const p = safeShowMessage({
    title: "Start a new report?",
    icon: "warning",
    message,
    buttons: [
      { text: "Cancel", class: "btn-secondary" },
      { text: "Start New", class: "btn-warning" }
    ]
  });

  // safeShowMessage() returns a Promise when showMessageModal exists [file:8]
  if (p && typeof p.then === "function") {
    p.then((choice) => {
      if (choice === "Start New") doHardReset();
    });
  }
}

document.querySelectorAll(".step-item").forEach(el => {
  el.addEventListener("click", () => {
    const s = parseInt(el.dataset.step);
    // lock progression rules (same idea as your original)
    if (s > 1 && !GLOBALESSAYOBJECT) {
      return safeShowMessage({
        title: "Locked",
        icon: "lock",
        message: "Please complete Step 1 first.",
        buttons: [{ text: "OK", class: "btn-secondary" }]
      });
    }
    activateStep(s);
  });
});

function navigateToStep(stepNumberString) {
  const el = document.querySelector(`[data-step="${stepNumberString}"]`);
  if (el) el.click();
}

/* =========================================================
   Render helpers (data -> DOM)
   ========================================================= */
function renderFreezeFromData(data) {
  document.getElementById("resWordCount").textContent = data.stats.wordCount;
  document.getElementById("resSentCount").textContent = data.stats.sentenceCount;
  document.getElementById("resParaCount").textContent = data.stats.paragraphCount;
  document.getElementById("resCharCount").textContent = data.stats.charCount;

  document.getElementById("resNormalizedText").textContent = data.normalizedText;
  document.getElementById("resJsonStruct").textContent = JSON.stringify(data, null, 2);

  document.getElementById("step1Placeholder")?.classList.add("d-none");
  document.getElementById("step1Result")?.classList.remove("d-none");
}

function renderAnalysisFromData(d) {
  document.getElementById("resJsonFeatures").textContent = JSON.stringify(d, null, 2);

  // 1) Structure visuals
  const structHTML = (d.structure.paragraphRoles || []).map((role, idx) => {
    const sentCount = d.structure.paragraphSentenceCounts?.[idx] ?? 0;
    const color = role === "intro" ? "primary" : role === "conclusion" ? "success" : "secondary";
    return `
      <div class="col border-end">
        <div class="fw-bold text-${color} text-uppercase small mb-1">${role}</div>
        <div class="p-2 bg-light rounded border position-relative" style="height:60px;">
          <span class="position-absolute top-50 start-50 translate-middle fw-bold text-muted">
            ${sentCount} sent.
          </span>
        </div>
        <div class="x-small text-muted mt-1">Para ${idx + 1}</div>
      </div>
    `;
  }).join("");

  document.getElementById("structureViz").innerHTML = structHTML;

  document.getElementById("flagIntro").innerHTML = d.structure.hasIntro
    ? `<i class="bi bi-check text-success"></i> Intro`
    : `<i class="bi bi-x text-danger"></i> No Intro`;

  document.getElementById("flagConclusion").innerHTML = d.structure.hasConclusion
    ? `<i class="bi bi-check text-success"></i> Concl.`
    : `<i class="bi bi-x text-danger"></i> No Concl.`;

  // 2) Cohesion / Lexical
  document.getElementById("connDensity").textContent = d.cohesion.densityPer100;
  document.getElementById("connVariety").textContent = d.cohesion.distinctConnectors;

  const tags = Object.entries(d.cohesion.usageMap || {})
    .sort((a, b) => (b[1] || 0) - (a[1] || 0))
    .slice(0, 6)
    .map(([w, c]) => `<span class="badge bg-light text-dark border">${w} (${c})</span>`)
    .join("") || "None";

  document.getElementById("connTags").innerHTML = tags;

  document.getElementById("refDensity").textContent = d.lexical.referencingDensity;

  const repHTML = (d.lexical.topRepeatedWords || [])
    .map(r => `<li>${r.word} <span class="fw-bold">${r.count}</span></li>`)
    .join("") || `<li class="text-muted small">None</li>`;

  document.getElementById("repWordsList").innerHTML = repHTML;

  document.getElementById("step2Placeholder")?.classList.add("d-none");
  document.getElementById("step2Result")?.classList.remove("d-none");

  //Amin added
  document.getElementById('step2Placeholder')?.classList.add('d-none');
  document.getElementById('step2Result')?.classList.remove('d-none');
  ensureInnerTabVisible('step2Tabs');
}

function copyJson(elementId) {
  const text = document.getElementById(elementId)?.textContent || "";
  navigator.clipboard.writeText(text).then(() => safeShowMessage({
    title: "Copied",
    icon: "check",
    message: "JSON copied to clipboard!",
    buttons: [{ text: "OK", class: "btn-success" }]
  }));
}

function escapeHtml(s) {
  return String(s ?? "")
    .replace(/&/g, "&amp;").replace(/</g, "&lt;")
    .replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
}

function formatMs(ms) {
  if (ms == null || Number.isNaN(ms)) return "—";
  return `${(ms / 1000).toFixed(2)}s`;
}

function stepMs(stepKey) {
  const t = SESSION_BUNDLE?.steps?.[stepKey]?.timing;
  if (!t?.startedAt || !t?.endedAt) return null;
  return Math.max(0, t.endedAt - t.startedAt);
}

function totalMs() {
  const keys = ["step1freeze", "step2analyze", "step3extract", "step4grade", "step5feedback"];
  return keys.reduce((sum, k) => sum + (stepMs(k) ?? 0), 0);
}

function renderReport() {
  const c = document.getElementById("reportContainer");
  if (!c) return;

  if (!GLOBALESSAYOBJECT || !GLOBALGRADING || !GLOBALFEEDBACK) {
    c.innerHTML = `
      <div class="alert alert-warning">
        Report is not ready yet. Complete Steps 1–5 first.
      </div>
    `;
    return;
  }

  const sampleName = SESSION_BUNDLE?.metadata?.sampleName || "";
  const sampleId = SESSION_BUNDLE?.metadata?.sampleId || GLOBALSAMPLEID || "";
  const savedAt = SESSION_BUNDLE?.savedAt || "";

  const metaLine = document.getElementById("reportMetaLine");
  if (metaLine) {
    metaLine.textContent = `${sampleName ? sampleName + " • " : ""}${sampleId ? "ID: " + sampleId + " • " : ""}${savedAt ? "Saved: " + savedAt + " • " : ""}Total time: ${formatMs(totalMs())}`;
  }

  // Timings table
  const timingRows = [
    ["Step 1 (Freeze)", "step1freeze"],
    ["Step 2 (Analysis)", "step2analyze"],
    ["Step 3 (Extraction)", "step3extract"],
    ["Step 4 (Grading)", "step4grade"],
    ["Step 5 (Feedback)", "step5feedback"]
  ].map(([label, key]) => `
    <tr>
      <td>${escapeHtml(label)}</td>
      <td class="text-end font-monospace">${escapeHtml(formatMs(stepMs(key)))}</td>
    </tr>
  `).join("");

  // Evidence snapshot
  const stance = GLOBALEXTRACTION?.position?.stance ?? "—";
  const stanceIdx = GLOBALEXTRACTION?.position?.stanceSentenceIndex ?? "—";

  const evidenceRows = (GLOBALEXTRACTION?.bodySupport || []).map(p => {
    const pIdx = p.paragraphIndex;
    const topic = (GLOBALEXTRACTION?.topicSentenceByParagraph || []).find(t => t.paragraphIndex === pIdx)?.topicSentenceIndex;
    const evidence = Array.isArray(p.evidenceSentenceIndices) ? p.evidenceSentenceIndices.join(", ") : "—";
    const flags = [
      p.hasExplanation ? "Exp" : null,
