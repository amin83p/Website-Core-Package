<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
        <h2 class="page-heading size-md m-0">Scoring Pipeline</h2>
        <div class="text-muted small mt-1">Deterministic & AI-Assisted Evaluation.</div>
    </div>
    <div class="d-flex gap-2">
        <button id="btnSaveServer" onclick="saveToServer()" class="btn btn-primary btn-filled btn-sm">
            <i class="bi bi-cloud-upload me-1"></i> Save to Cloud
        </button>

        <button onclick="saveProgress()" class="btn btn-filled btn-primary btn-sm">
            <i class="bi bi-download me-1"></i> Save to File
        </button>

        <button onclick="document.getElementById('loadProgressInput').click()" class="btn btn-filled btn-success btn-sm">
            <i class="bi bi-upload me-1"></i> Load from File
        </button>
        <input type="file" id="loadProgressInput" accept=".json" style="display:none;" onchange="loadProgress(event)">

        <button onclick="startNewReport()" class="btn btn-filled btn-warning btn-sm">
            <i class="bi bi-plus-circle me-1"></i> New / Start
        </button>

        <a href="<%= ieltsSectionDashboardHref %>" class="ielts-navigator-dashboard btn btn-filled btn-secondary btn-sm">
            <i class="bi bi-speedometer2 me-1"></i> IELTS Dashboard
        </a>
        <a href="/ielts/scoring/dashboard" class="btn btn-filled btn-outline-secondary btn-sm">
            <i class="bi bi-graph-up-arrow me-1"></i> Scoring Dashboard
        </a>
    </div>
  </div>
      </div>
        <!-- Timing Bar -->
        <div id="timingBar" class="d-flex flex-wrap gap-2 align-items-center mt-2 mb-2">
            <span class="badge bg-dark">
                Total: <span id="timerTotal">—</span>
            </span>

            <span class="badge bg-light text-dark border">S1: <span id="timerStep1">—</span></span>
            <span class="badge bg-light text-dark border">S2: <span id="timerStep2">—</span></span>
            <span class="badge bg-light text-dark border">S3: <span id="timerStep3">—</span></span>
            <span class="badge bg-light text-dark border">S4: <span id="timerStep4">—</span></span>
            <span class="badge bg-light text-dark border">S5: <span id="timerStep5">—</span></span>

            <span id="timerRunningBadge" class="badge bg-warning text-dark d-none">
                Running: <span id="timerRunningLabel">—</span> (<span id="timerRunningValue">0.00s</span>)
            </span>
        </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-0">
            <div class="d-flex justify-content-between text-center" id="stepperContainer">
                
                <div class="step-item flex-fill p-3 border-bottom border-primary border-3 bg-light active" data-step="1">
                    <div class="fw-bold text-primary">Step 1</div>
                    <div class="small text-muted">Freeze Inputs</div>
                </div>

                <div class="step-item flex-fill p-3 border-bottom text-muted" data-step="2">
                    <div class="fw-bold">Step 2</div>
                    <div class="small opacity-75">Analysis</div>
                </div>

                <div class="step-item flex-fill p-3 border-bottom text-muted" data-step="3">
                    <div class="fw-bold">Step 3</div>
                    <div class="small opacity-75">AI Extraction</div>
                </div>

                <div class="step-item flex-fill p-3 border-bottom text-muted" data-step="4">
                    <div class="fw-bold">Step 4</div>
                    <div class="small opacity-75">Grading</div>
                </div>

                <div class="step-item flex-fill p-3 border-bottom text-muted" data-step="5">
                    <div class="fw-bold">Step 5</div>
                    <div class="small opacity-75">Feedback</div>
                </div>
                
                <div class="step-item flex-fill p-3 border-bottom text-muted" data-step="6">
                    <div class="fw-bold">Step 6</div>
                    <div class="small opacity-75">Report</div>
                </div>

            </div>
        </div>
    </div>

    <div class="tab-content" id="pipelineStepsContent">
        
        <div class="tab-pane fade show active" id="step1">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-dark mb-3"><i class="bi bi-snow2 me-2"></i>Select Sample</h6>
                            <p class="small text-muted">Select an essay to create a canonical "frozen" object for grading.</p>
                            
                            <select id="sampleSelect" class="form-select mb-3">
                                <option value="">-- Select Essay --</option>
                                <% if(samples && samples.length > 0) { %>
                                    <% samples.forEach(s => { %>
                                        <option value="<%= s.id %>"><%= s.refName %> (<%= s.type %>)</option>
                                    <% }) %>
                                <% } %>
                            </select>

                            <button id="btnFreeze" class="btn btn-primary w-100 fw-bold" onclick="runFreezeStep()">
                                <i class="bi bi-snow2 me-1"></i> Freeze Inputs
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                     <div id="step1Placeholder" class="text-center py-5 text-muted border rounded bg-light">
                        <i class="bi bi-box-seam fs-1 d-block mb-2 opacity-50"></i>
                        Select an essay and click Freeze to generate the object.
                    </div>

                     <div id="step1Result" class="d-none">
                        
                        <ul class="nav nav-tabs mb-3" id="step1Tabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active small fw-bold" id="s1-visual-tab" data-bs-toggle="tab" data-bs-target="#s1-visual-pane" type="button">Visual Summary</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link small fw-bold text-muted" id="s1-json-tab" data-bs-toggle="tab" data-bs-target="#s1-json-pane" type="button">Raw Object (JSON)</button>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="s1-visual-pane">
                                <div class="row g-3 mb-3">
                                    <div class="col-3">
                                        <div class="p-3 border rounded bg-white text-center shadow-sm">
                                            <div class="display-6 fw-bold text-primary" id="resWordCount">-</div>
                                            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Words</div>
                                        </div>
                                    </div>
                                    <div class="col-3">
                                        <div class="p-3 border rounded bg-white text-center shadow-sm">
                                            <div class="display-6 fw-bold text-success" id="resSentCount">-</div>
                                            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Sentences</div>
                                        </div>
                                    </div>
                                    <div class="col-3">
                                        <div class="p-3 border rounded bg-white text-center shadow-sm">
                                            <div class="display-6 fw-bold text-info" id="resParaCount">-</div>
                                            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Paragraphs</div>
                                        </div>
                                    </div>
                                    <div class="col-3">
                                        <div class="p-3 border rounded bg-white text-center shadow-sm">
                                            <div class="display-6 fw-bold text-dark" id="resCharCount">-</div>
                                            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Chars</div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card shadow-sm border-0 mb-3">
                                    <div class="card-header bg-white fw-bold small text-muted">Canonical Text</div>
                                    <div class="card-body bg-light p-2">
                                        <div id="resNormalizedText" class="p-2 bg-white border rounded small font-monospace" style="max-height:350px; overflow:auto; white-space: pre-wrap;"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="s1-json-pane">
                                <div class="card shadow-sm border-0">
                                    <div class="card-body bg-dark rounded p-0">
                                        <div class="d-flex justify-content-between align-items-center bg-secondary px-3 py-1 rounded-top">
                                            <span class="text-white small font-monospace">essayObject.json</span>
                                            <button class="btn btn-sm btn-link text-white text-decoration-none" onclick="copyJson('resJsonStruct')">
                                                <i class="bi bi-clipboard"></i> Copy
                                            </button>
                                        </div>
                                        <pre id="resJsonStruct" class="text-success m-0 p-3 small font-monospace" style="max-height: 400px; overflow-y: auto;"></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-end mt-3 d-flex justify-content-between align-items-center">
                            <button class="btn btn-outline-secondary" onclick="activateStep(1)" style="visibility: hidden;">
                                <i class="bi bi-arrow-left"></i> Previous
                            </button>
                            <button id="btnNextToStep2" class="btn btn-primary" onclick="activateStep(2)">
                                Next: Analysis <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                     </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="step2">
            <div class="row g-4">
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-dark mb-3">Feature Extraction</h6>
                            <ul class="small text-muted ps-3 mb-4">
                                <li>Structure Analysis</li>
                                <li>Cohesion Density</li>
                                <li>Lexical Repetition</li>
                            </ul>
                            <button id="btnAnalyze" class="btn btn-secondary w-100 fw-bold" onclick="runAnalysisStep()">
                                <i class="bi bi-bar-chart-fill me-1"></i> Run Analysis
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-md-9">
                     <div id="step2Placeholder" class="text-center py-5 text-muted border rounded bg-light">
                        <i class="bi bi-search fs-1 d-block mb-2 opacity-50"></i>
                        Waiting for analysis...
                    </div>

                     <div id="step2Result" class="d-none">
                        
                        <ul class="nav nav-tabs mb-3" id="step2Tabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active small fw-bold" id="s2-visual-tab" data-bs-toggle="tab" data-bs-target="#s2-visual-pane" type="button">Visual Report</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link small fw-bold text-muted" id="s2-json-tab" data-bs-toggle="tab" data-bs-target="#s2-json-pane" type="button">Raw Features (JSON)</button>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="s2-visual-pane">
                                <div class="card shadow-sm border-0 mb-3">
                                    <div class="card-header bg-white fw-bold text-primary"><i class="bi bi-layout-text-window-reverse me-2"></i>Structure</div>
                                    <div class="card-body">
                                        <div class="row text-center" id="structureViz"></div>
                                        <div class="mt-2 text-muted small d-flex justify-content-center gap-3">
                                            <span id="flagIntro"></span>
                                            <span id="flagConclusion"></span>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="card shadow-sm border-0 h-100">
                                            <div class="card-header bg-white fw-bold text-info small">Cohesion</div>
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between mb-1 small"><span>Density:</span><span class="fw-bold" id="connDensity">-</span></div>
                                                <div class="d-flex justify-content-between mb-2 small"><span>Variety:</span><span class="fw-bold" id="connVariety">-</span></div>
                                                <div id="connTags" class="d-flex flex-wrap gap-1"></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="card shadow-sm border-0 h-100">
                                            <div class="card-header bg-white fw-bold text-warning small">Lexical</div>
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between mb-2 small"><span>Ref. Density:</span><span class="fw-bold" id="refDensity">-</span></div>
                                                <ul class="list-unstyled small m-0" id="repWordsList"></ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="s2-json-pane">
                                <div class="card shadow-sm border-0">
                                    <div class="card-body bg-dark rounded p-0">
                                        <div class="d-flex justify-content-between align-items-center bg-secondary px-3 py-1 rounded-top">
                                            <span class="text-white small font-monospace">analysisFeatures.json</span>
                                            <button class="btn btn-sm btn-link text-white text-decoration-none" onclick="copyJson('resJsonFeatures')">
                                                <i class="bi bi-clipboard"></i> Copy
                                            </button>
                                        </div>
                                        <pre id="resJsonFeatures" class="text-success m-0 p-3 small font-monospace" style="max-height: 450px; overflow-y: auto;"></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-end mt-3">
                            <button class="btn btn-primary" onclick="activateStep(3)">Next: AI Extraction <i class="bi bi-arrow-right"></i></button>
                        </div>
                     </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="step3">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-purple mb-3" style="color: #6f42c1;"><i class="bi bi-robot me-2"></i>Evidence Locator</h6>
                            <p class="small text-muted">Locate sentence indices for stance, topic sentences, and evidence.</p>
                            
                            <div class="d-none">
                                <input type="text" id="subQKeys">
                            </div>

                            <button id="btnPrepareExtract" class="btn text-white w-100 fw-bold" style="background-color: #6f42c1;" onclick="prepareExtraction()">
                                <i class="bi bi-eye me-1"></i> Review & Extract
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                    <div id="step3Placeholder" class="text-center py-5 text-muted border rounded bg-light">
                        <i class="bi bi-bullseye fs-1 d-block mb-2 opacity-50"></i>
                        Waiting to locate evidence...
                    </div>

                    <div id="step3Result" class="d-none">
                        
                        <ul class="nav nav-tabs mb-3" id="step3Tabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active small fw-bold" id="visual-tab" data-bs-toggle="tab" data-bs-target="#visual-pane" type="button">Visual Report</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link small fw-bold text-muted" id="json-tab" data-bs-toggle="tab" data-bs-target="#json-pane" type="button">Raw JSON</button>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="visual-pane">
                                
                                <div id="aiSubQCard"></div>

                                <div class="card shadow-sm border-0 mb-3">
                                    <div class="card-header bg-white fw-bold text-dark small">Position & Stance</div>
                                    <div class="card-body">
                                        <div class="d-flex gap-3 align-items-center mb-2">
                                            <span class="badge bg-primary text-uppercase" id="aiStance">-</span>
                                            <span class="small text-muted">Stance at Sentence #<span id="aiStanceIdx" class="fw-bold">-</span></span>
                                        </div>
                                        <div id="aiContradictions" class="small text-danger"></div>
                                    </div>
                                </div>

                                <div class="card shadow-sm border-0 mb-3">
                                    <div class="card-header bg-white fw-bold text-dark small">Paragraph Evidence Map</div>
                                    <div class="card-body p-0">
                                        <div class="table-responsive">
                                            <table class="table table-sm mb-0 small align-middle">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Para</th>
                                                        <th>Topic Sent #</th>
                                                        <th>Evidence #</th>
                                                        <th>Flags</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="aiParaTable"></tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="json-pane">
                                <div class="card shadow-sm border-0">
                                    <div class="card-body bg-dark rounded p-0">
                                        <div class="d-flex justify-content-between align-items-center bg-secondary px-3 py-1 rounded-top">
                                            <span class="text-white small font-monospace">response.json</span>
                                            <button class="btn btn-sm btn-link text-white text-decoration-none" onclick="copyJson('aiRawJson')">
                                                <i class="bi bi-clipboard"></i> Copy
                                            </button>
                                        </div>
                                        <pre id="aiRawJson" class="text-success m-0 p-3 small font-monospace" style="max-height: 500px; overflow-y: auto;"></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-end mt-4">
                            <button class="btn btn-secondary" onclick="activateStep(4)">Next: Grading <i class="bi bi-arrow-right"></i></button>
                        </div>

                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="step4">
            <div class="row g-4">
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-success mb-3"><i class="bi bi-calculator me-2"></i>Grading Engine</h6>
                            <p class="small text-muted">Apply rubric logic to calculated features and AI evidence.</p>
                            
                            <button id="btnGrade" class="btn btn-success w-100 fw-bold mb-3" onclick="runGradingStep()">
                                <i class="bi bi-play-circle-fill me-1"></i> Calculate Score
                            </button>

                            
                            <button type="button" id="btnGradingSettings" class="btn btn-outline-success w-100 mb-2" onclick="openGradingSettings()">
                                <i class="bi bi-sliders me-1"></i> Grading Settings
                            </button>
                            <div class="small text-muted">
                                <span class="fw-bold">Batch size:</span> <span id="gradingBatchSizeLabel">—</span>
                                <span class="mx-2">|</span>
                                <span class="fw-bold">Concurrency:</span> <span id="gradingConcurrencyLabel">—</span>
                            </div>
<div id="scoreSummary" class="d-none">
                                <hr>
                                <div class="text-center">
                                    <div class="small text-uppercase text-muted fw-bold">Overall Band</div>
                                    <div class="display-1 fw-bold text-primary" id="resOverallBand">-</div>
                                </div>
                                <div class="row g-2 mt-3 text-center">
                                    <div class="col-6">
                                        <div class="p-2 bg-light rounded border">
                                            <div class="small text-muted fw-bold">TR</div>
                                            <div class="h4 m-0" id="resBandTR">-</div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="p-2 bg-light rounded border">
                                            <div class="small text-muted fw-bold">CC</div>
                                            <div class="h4 m-0" id="resBandCC">-</div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="p-2 bg-light rounded border">
                                            <div class="small text-muted fw-bold">LR</div>
                                            <div class="h4 m-0" id="resBandLR">-</div>
                                        </div>
                                    </div>
                                    <div class="col-6">
                                        <div class="p-2 bg-light rounded border">
                                            <div class="small text-muted fw-bold">GRA</div>
                                            <div class="h4 m-0" id="resBandGRA">-</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-9">
                    <div id="step4Placeholder" class="text-center py-5 text-muted border rounded bg-light">
                        <i class="bi bi-clipboard-data fs-1 d-block mb-2 opacity-50"></i>
                        Waiting for calculation...
                    </div>

                    <div id="step4Result" class="d-none">
                        <div class="card shadow-sm border-0">
                            <div class="card-header bg-white fw-bold small">
                                Criterion Breakdown
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive" style="max-height: 500px;">
                                    <table class="table table-sm table-hover mb-0 align-middle small">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th>ID</th>
                                                <th>Criterion</th>
                                                <th>Band</th>
                                                <th>Question</th>
                                                <th class="text-center">Result</th>
                                                <th class="text-end">Source</th>
                                            </tr>
                                        </thead>
                                        <tbody id="gradingTableBody">
                                            </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                        <div id="gradingPrompts" class="mt-3"></div>                        
                        <div class="text-end mt-3">
                            <button class="btn btn-primary" onclick="activateStep(5)">Next: Feedback <i class="bi bi-arrow-right"></i></button>
                            <button class="btn btn-outline-primary" onclick="goToReport()">
                                View Report <i class="bi bi-file-earmark-text ms-1"></i>
                            </button>                            
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="tab-pane fade" id="step5">
            <div class="row g-4">
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-info mb-3"><i class="bi bi-lightbulb-fill me-2"></i>Feedback</h6>
                            <p class="small text-muted">Generate specific improvements based on failed criteria.</p>
                            <button id="btnFeedback" class="btn btn-info text-white w-100 fw-bold mb-3" onclick="runFeedbackStep()">
                                <i class="bi bi-magic me-1"></i> Generate
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-9">
                    <div id="step5Placeholder" class="text-center py-5 text-muted border rounded bg-light">
                        <i class="bi bi-chat-square-text fs-1 d-block mb-2 opacity-50"></i> Waiting for feedback generation...
                    </div>
                    <div id="step5Result" class="d-none">
                    </div>
                    <div class="text-end mt-3">
                        <button class="btn btn-primary" onclick="goToReport()">
                            Next Report <i class="bi bi-arrow-right ms-1"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="step6">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <div>
            <h5 class="mb-0 fw-bold">Session Report</h5>
            <div class="text-muted small" id="reportMetaLine">—</div>
            </div>
            <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm" onclick="printReport()">
                <i class="bi bi-printer me-1"></i> Print
            </button>
            <button class="btn btn-outline-primary btn-sm" onclick="downloadReportHtml()">
                <i class="bi bi-file-earmark-code me-1"></i> Download HTML
            </button>
            <button class="btn btn-primary btn-sm" onclick="saveProgress()">
                <i class="bi bi-download me-1"></i> Save Session JSON
            </button>
            </div>
        </div>

        <div id="reportContainer"></div>
        </div>


    </div>
</div>

<div class="modal fade" id="promptReviewModal" tabindex="-1">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
