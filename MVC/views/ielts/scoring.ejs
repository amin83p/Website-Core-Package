   function renderGradingFromData(d) {
  // 1. Scores
  document.getElementById("resOverallBand").textContent = d.overallBand;
  document.getElementById("resBandTR").textContent = d.scores.TR;
  document.getElementById("resBandCC").textContent = d.scores.CC;
  document.getElementById("resBandLR").textContent = d.scores.LR;
  document.getElementById("resBandGRA").textContent = d.scores.GRA;

  document.getElementById("scoreSummary")?.classList.remove("d-none");

  // ✅ ADDED: Model Name Badge
  const modelName = d.meta?.modelUsed || 'Unknown Model';
  // Remove old badge if exists to prevent stacking
  const existingBadge = document.getElementById("scoreSummary").querySelector('.badge-model');
  if(existingBadge) existingBadge.remove();
  
  document.getElementById("scoreSummary").insertAdjacentHTML('afterbegin', 
    `<div class="text-center mb-2 badge-model"><span class="badge bg-purple-subtle text-purple border border-purple" style="color: #6f42c1; background-color: #e0cffc;"><i class="bi bi-cpu-fill me-1"></i> Graded by: ${modelName}</span></div>`
  );

  // 2. Table
  const tbody = document.getElementById("gradingTableBody");
  tbody.innerHTML = "";
  
  const sortedDetails = (d.results || []).slice().sort((a, b) => {
    if (a.criterion !== b.criterion) return a.criterion.localeCompare(b.criterion);
    return (a.band || 0) - (b.band || 0);
  });

  sortedDetails.forEach(item => {
    const val = String(item.value || "NA");
    const positives = ["Yes", "clear", "positive", "adequate", "well-managed", "logical"];
    const negatives = ["No", "unclear", "limited", "weak"];

    const isPositive = positives.some(x => val.toLowerCase().includes(x.toLowerCase()));
    const isNegative = negatives.some(x => val.toLowerCase().includes(x.toLowerCase()));

    let badgeClass = "bg-light text-muted border";
    let icon = "";
    if (isPositive) { badgeClass = "bg-success text-white"; icon = `<i class="bi bi-check-lg"></i>`; }
    else if (isNegative) { badgeClass = "bg-danger bg-opacity-10 text-danger"; icon = `<i class="bi bi-x"></i>`; }

    const sourceIcon = item.source === "deterministic"
      ? `<i class="bi bi-lightning-charge-fill text-warning" title="Code"></i>`
      : `<i class="bi bi-stars" style="color:#6f42c1" title="AI"></i>`;

    const tr = `
      <tr>
        <td class="font-monospace text-muted">${item.question_key || ""}</td>
        <td><span class="badge bg-light text-dark border">${item.criterion || ""}</span></td>
        <td class="fw-bold">${item.band ?? ""}</td>
        <td><div class="text-truncate" style="max-width:350px;" title="${item.atomic_question || ""}">${item.atomic_question || ""}</div></td>
        <td class="text-center"><span class="badge ${badgeClass} rounded-pill px-3">${icon} ${val}</span></td>
        <td class="text-end text-muted x-small">${sourceIcon}</td>
      </tr>
    `;
    tbody.insertAdjacentHTML("beforeend", tr);
  });

  // 3. AI Prompts (Collapsible)
  const promptContainer = document.getElementById("gradingPrompts");
  if (promptContainer) {
    promptContainer.innerHTML = ""; 
    
    // Check 'aiPrompts' or 'allAiPrompts' depending on service naming (Service uses 'aiPrompts')
    const prompts = d.meta?.aiPrompts || d.meta?.allAiPrompts;

    if (prompts && Array.isArray(prompts) && prompts.length > 0) {
      const promptsHtml = prompts.map((p, idx) => `
        <div class="border-bottom border-secondary p-3">
          <div class="text-white-50 small mb-2 text-uppercase fw-bold">Batch ${idx + 1}</div>
          <pre class="text-success small font-monospace m-0" style="white-space: pre-wrap;">${escapeHtml(p)}</pre>
        </div>
      `).join("");
      
      promptContainer.innerHTML = `
        <details class="card border-0 shadow-sm">
          <summary class="card-header bg-white fw-bold small text-muted" style="cursor:pointer;">
            <i class="bi bi-code-square me-2"></i>View Grading Engine Prompts (${prompts.length} Batches)
          </summary>
          <div class="card-body bg-dark p-0">
            ${promptsHtml}
          </div>
        </details>
      `;
    }
  }

  document.getElementById("step4Placeholder")?.classList.add("d-none");
  document.getElementById("step4Result")?.classList.remove("d-none");
}

