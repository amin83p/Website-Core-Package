function printReport() {
  const printable = document.getElementById("reportPrintable");
  if (!printable) return;
  const w = window.open("", "_blank");
  w.document.write(`
    <html><head>
      <title>IELTS Report</title>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    </head>
    <body class="p-3">
      ${printable.innerHTML}
    </body></html>
  `);
  w.document.close();
  w.focus();
  w.print();
}

function downloadReportHtml() {
  const printable = document.getElementById("reportPrintable");
  if (!printable) return;

  const html = `
<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>IELTS Session Report</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="p-3">
${printable.innerHTML}
</body>
</html>
  `.trim();

  const stamp = new Date().toISOString().slice(0,19).replace(/[:T]/g,"-");
  const blob = new Blob([html], { type: "text/html" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = `scoring-report-${stamp}.html`;
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
}

