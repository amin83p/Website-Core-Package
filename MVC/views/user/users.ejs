<%- include('../partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  print,
  btn_export: true
}) %>

  <%- include('../partials/tablePages-search', {
    placeholder: 'Search users...',
    fields: []
  }) %>

  <div class="table-scroll-wrapper" data-floating-row-actions="true">
    <table class="table-responsive size-md" id="first-table">
      <thead>
      <tr>
        <th class="draggable" data-column="email">Email <span class="sort-icon"></span></th>
        <th class="draggable" data-column="personId">Person <span class="sort-icon"></span></th>
        <th class="draggable" data-column="accessLevel">Access Level <span class="sort-icon"></span></th>
        <th class="draggable" data-column="primaryOrgId">Active Org <span class="sort-icon"></span></th>
        <th class="draggable" data-column="organizations">Organizations <span class="sort-icon"></span></th>
        <th class="draggable" data-column="status">Status <span class="sort-icon"></span></th>
        <th class="draggable" data-column="active">Active <span class="sort-icon"></span></th>
        <th class="draggable" data-column="isEmailVerified">Email Verified <span class="sort-icon"></span></th>
        <th class="draggable" data-column="lastLoginAt">Last Login <span class="sort-icon"></span></th>
        <th class="draggable" data-column="createDateTime">Created <span class="sort-icon"></span></th>
        <th class="draggable" data-column="lastUpdateDateTime">Last Updated <span class="sort-icon"></span></th>
        <th class="text-end pe-4">Action</th>
      </tr>
    </thead>

    <tbody>
      <% if (users && users.length) { %>
        <% users.forEach(u => { %>
          <%
            // 1. Find Linked Person
            const person = (persons || []).find(p => String(p.id) === String(u.personId));
            
            // 2. Derive Organizations from Person (Source of Truth)
            const personOrgs = person ? (person.organizations || []) : [];
            
            // 3. Format Organization Names for display
            const orgNamesStr = personOrgs
              .map(o => o.displayLabel || (o.orgId ? (o.name ? `${o.name} (${o.orgId})` : `Org #${o.orgId}`) : o.name))
              .filter(Boolean)
              .join(', ');

            // 4. Resolve Active Org Name
            let activeOrgName = '—';
            if (u.primaryOrgId) {
                const active = personOrgs.find(o => String(o.orgId) === String(u.primaryOrgId));
                activeOrgName = active ? (active.displayLabel || (active.name ? `${active.name} (${active.orgId})` : active.orgId)) : u.primaryOrgId;
            }

            // 5. Audit Info

            const audit = u.audit || {};
            const createDateTime = audit.createDateTime || u.createDateTime;
            const lastUpdateDateTime = audit.lastUpdateDateTime || u.lastUpdateDateTime;
            const createUser = audit.createUser || u.createUser;
            const lastUpdateUser = audit.lastUpdateUser || u.lastUpdateUser;
          %>

          <tr>
            <td>
                <%= u.email || '—' %>
                <% if (u.username) { %>
                    <div class="text-muted small"><%= u.username %></div>
                <% } %>
            </td>

            <td>
              <% if (person) { %>
                <%= [person.name?.first, person.name?.last].filter(Boolean).join(' ') %>
                <div class="text-muted small">#<%= u.personId %></div>
              <% } else { %>
                <span class="text-danger">Unlinked (#<%= u.personId %>)</span>
              <% } %>
            </td>

            <td><%= u.accessLevel ?? '—' %></td>

            <td>
                <%= activeOrgName %>
                <% if (u.primaryOrgId) { %>
                    <small class="text-muted d-block">#<%= u.primaryOrgId %></small>
                <% } %>
            </td>

            <td>
                <% if (orgNamesStr) { %>
                    <%= orgNamesStr %>
                <% } else { %>
                    <span class="text-muted small">None</span>
                <% } %>
            </td>

            <td>
                <% if (u.status === 'active') { %>
                    <span class="badge bg-success">Active</span>
                <% } else if (u.status === 'pending') { %>
                    <span class="badge bg-warning text-dark">Pending</span>
                <% } else if (u.status === 'suspended') { %>
                    <span class="badge bg-danger">suspended</span>
                <% } else { %>
                    <span class="badge bg-secondary"><%= u.status %></span>
                <% } %>
            </td>

            <td><%= u.active ? 'Yes' : 'No' %></td>

            <td><%= u.isEmailVerified ? 'Yes' : 'No' %></td>

            <td>
              <% if (u.lastLoginAt) { %>
                <%= new Date(u.lastLoginAt).toLocaleString() %>
              <% } else { %>
                <span class="text-muted">—</span>
              <% } %>
            </td>


            <td>
              <% if (createDateTime) { %>
                <%= new Date(createDateTime).toLocaleString() %>
                <% if (createUser) { %>
                  <br><span class="text-muted small">by <%= createUser %></span>
                <% } %>
              <% } else { %>
                —
              <% } %>
            </td>
            <td>
              <% if (lastUpdateDateTime) { %>
                <%= new Date(lastUpdateDateTime).toLocaleString() %>
                <% if (lastUpdateUser) { %>
                  <br><span class="text-muted small">by <%= lastUpdateUser %></span>
                <% } %>
              <% } else { %>
                —
              <% } %>
            </td>
  
            <td class="table-actions text-end pe-4">
              <div class="row-actions-wrap">
                <button
                  type="button"
                  class="btn btn-secondary btn-sm btn-row-actions-toggle"
                  data-row-actions-id="<%= u.id %>"
                  title="Row actions">
                  <i class="bi bi-three-dots-vertical"></i>
                </button>
                <div class="row-actions-menu d-none" data-row-actions-id="<%= u.id %>">
                  <a href="/users/edit/<%= u.id %>" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-pencil-square me-2"></i>Edit
                  </a>
                  <button class="btn btn-outline-danger btn-sm delete-btn" data-id="<%= u.id %>">
                    <i class="bi bi-trash me-2"></i>Delete
                  </button>
                </div>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="12" class="text-center text-muted py-3">No users found.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

<%- include('../partials/pagination', { 
    pagination: pagination, 
    filters: null, 
    baseUrlPath: newUrl
}) %>

<%- include('../partials/tablePages-end') %>

