<%- include('./partials/modal_ImageViewer') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const items = Array.from(document.querySelectorAll('.js-open-image'));
  if (!items.length) return;

  function buildExperienceGallery(clickedButton) {
    const galleryRoot = clickedButton.closest('.about-media-grid');
    if (!galleryRoot) return { gallery: [], index: 0 };

    const galleryButtons = Array.from(galleryRoot.querySelectorAll('.js-open-image'));
    const gallery = galleryButtons
      .map((button) => ({
        url: String(button.dataset.imageUrl || '').trim(),
        name: String(button.dataset.imageName || 'Portfolio Image').trim() || 'Portfolio Image',
        mimeType: 'image/*'
      }))
      .filter((item) => item.url);

    if (!gallery.length) return { gallery: [], index: 0 };

    const rawIndex = galleryButtons.indexOf(clickedButton);
    const index = Number.isInteger(rawIndex) && rawIndex >= 0 && rawIndex < gallery.length ? rawIndex : 0;
    return { gallery, index };
  }

  items.forEach((btn) => {
    btn.addEventListener('click', () => {
      const imageUrl = btn.dataset.imageUrl || '';
      const imageName = btn.dataset.imageName || 'Portfolio Image';
      if (!imageUrl) return;
      if (window.ImageViewer && typeof window.ImageViewer.open === 'function') {
        const { gallery, index } = buildExperienceGallery(btn);
        if (gallery.length) {
          window.ImageViewer.open(imageUrl, imageName, 'image/*', { gallery, index });
        } else {
          window.ImageViewer.open(imageUrl, imageName, 'image/*');
        }
      } else {
        window.open(imageUrl, '_blank');
      }
    });
  });
});
</script>

