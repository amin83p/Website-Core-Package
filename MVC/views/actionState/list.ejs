<%
  const stateFilters = filters || {};
  const hasActionStateFiltersApplied = Boolean(
    String(stateFilters.id || '').trim()
    || String(stateFilters.userId || '').trim()
    || String(stateFilters.sectionId || '').trim()
    || String(stateFilters.targetKey || '').trim()
    || String(stateFilters.operationId || '').trim()
    || String(stateFilters.status || '').trim()
    || String(stateFilters.startDate || '').trim()
    || String(stateFilters.endDate || '').trim()
  );
%>

<%- include('../partials/tablePages-start', {
  title,
  newUrl: null,
  newLabel: null,
  user,
  tableName,
  print,
  btn_export: true,
  optionalBtns: [`
    <button type="button" id="run-retention-cleanup-btn" class="btn btn-filled btn-warning text-dark me-2">
      <i class="bi bi-broom-fill me-1"></i> Run Retention Cleanup
    </button>
    <button type="button" id="delete-all-logs-btn" class="btn btn-filled btn-danger text-white me-2">
      <i class="bi bi-trash-fill me-1"></i> Delete All Data
    </button>
  `]
}) %>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 h-100 border-start border-4 border-primary">
            <div class="text-muted small text-uppercase fw-bold">Total Activities</div>
            <div class="fs-4 fw-bold text-dark"><%= summary?.totalActivities || 0 %></div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 h-100 border-start border-4 border-success">
            <div class="text-muted small text-uppercase fw-bold">Total Volume</div>
            <div class="fs-4 fw-bold text-dark">
                <% 
                   const totalVol = Number(summary?.totalVolumeKB || 0);
                   let volDisplay = totalVol.toFixed(2) + ' KB';
                   if (totalVol > 1024) volDisplay = (totalVol / 1024).toFixed(2) + ' MB';
                %>
                <%= volDisplay %>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 h-100 border-start border-4 border-warning">
            <div class="text-muted small text-uppercase fw-bold">Active Sessions</div>
            <div class="fs-4 fw-bold text-dark">
                <%= summary?.activeSessions || 0 %>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm p-3 h-100 border-start border-4 border-danger">
            <div class="text-muted small text-uppercase fw-bold">Failures</div>
            <div class="fs-4 fw-bold text-dark">
                <%= summary?.failures || 0 %>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
        <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter Activity States</div>
        <button
            id="actionStateFilterToggleBtn"
            type="button"
            class="btn btn-outline-secondary btn-sm px-2"
            data-bs-toggle="collapse"
            data-bs-target="#actionStateFilterCollapse"
            aria-expanded="<%= hasActionStateFiltersApplied ? 'true' : 'false' %>"
            aria-controls="actionStateFilterCollapse"
            aria-label="<%= hasActionStateFiltersApplied ? 'Close filters' : 'Open filters' %>">
            <i id="actionStateFilterToggleIcon" class="bi <%= hasActionStateFiltersApplied ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
        </button>
    </div>
    <div class="collapse<%= hasActionStateFiltersApplied ? ' show' : '' %>" id="actionStateFilterCollapse">
        <div class="card-body p-4">
            <form method="GET" action="">
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Action ID</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-hash"></i></span>
                        <input type="text" name="id" class="form-control border-start-0 ps-0" placeholder="e.g. ASI..." value="<%= filters.id || '' %>">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">User ID</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-person"></i></span>
                        <input type="text" name="userId" class="form-control border-start-0 ps-0" placeholder="e.g. 1001" value="<%= filters.userId || '' %>">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Section</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-collection"></i></span>
                        <input type="text" name="sectionId" class="form-control border-start-0 ps-0" placeholder="e.g. USERS" value="<%= filters.sectionId || '' %>">
                    </div>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Target Object</label>
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-light border-end-0"><i class="bi bi-bullseye"></i></span>
                        <input type="text" name="targetKey" class="form-control border-start-0 ps-0" placeholder="e.g. user_555" value="<%= filters.targetKey || '' %>">
                    </div>
                </div>
            </div>
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Operation</label>
                    <input type="text" name="operationId" class="form-control form-control-sm" placeholder="e.g. EDIT" value="<%= filters.operationId || '' %>">
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted text-uppercase">Status</label>
                    <select name="status" class="form-select form-select-sm">
                        <option value="">All Statuses</option>
                        <option value="active" <%= filters.status === 'active' ? 'selected' : '' %>>Active</option>
                        <option value="attempted" <%= filters.status === 'attempted' ? 'selected' : '' %>>Attempted</option>
                        <option value="in_progress" <%= filters.status === 'in_progress' ? 'selected' : '' %>>In Progress</option>
                        <option value="retryable_error" <%= filters.status === 'retryable_error' ? 'selected' : '' %>>Retryable Error</option>
                        <option value="completed" <%= filters.status === 'completed' ? 'selected' : '' %>>Completed</option>
                        <option value="cancelled" <%= filters.status === 'cancelled' ? 'selected' : '' %>>Cancelled</option>
                        <option value="failed" <%= filters.status === 'failed' ? 'selected' : '' %>>Failed</option>
                        <option value="terminated" <%= filters.status === 'terminated' ? 'selected' : '' %>>Terminated</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted text-uppercase">Date Range</label>
                    <div class="input-group input-group-sm">
                        <input type="date" name="startDate" class="form-control" title="Start Date" value="<%= filters.startDate || '' %>">
                        <span class="input-group-text bg-light border-start-0 border-end-0 text-muted">to</span>
                        <input type="date" name="endDate" class="form-control" title="End Date" value="<%= filters.endDate || '' %>">
                    </div>
                </div>
                <div class="col-md-2">
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm w-100 btn-filled">
                            <i class="bi bi-funnel-fill me-1"></i> Filter
                        </button>
                        <a href="/actionStates" class="btn btn-outline-secondary btn-sm" title="Reset">
                            <i class="bi bi-arrow-counterclockwise"></i>
                        </a>
                    </div>
                </div>
            </div>
            </form>
        </div>
    </div>
</div>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="draggable" data-column="id">Track ID <span class="sort-icon"></span></th>
        <th class="draggable" data-column="userId">User <span class="sort-icon"></span></th>
        <th class="draggable" data-column="sectionId">Context <span class="sort-icon"></span></th>
        <th>Origin <span class="sort-icon"></span></th> <th class="draggable" data-column="targetKey">Target <span class="sort-icon"></span></th>
        <th class="draggable text-center" data-column="status">Status <span class="sort-icon"></span></th>
        <th class="draggable text-center" data-column="attemptCount">Count <span class="sort-icon"></span></th>
        <th class="draggable text-end" data-column="volumeUsageKB">Data <span class="sort-icon"></span></th>
        <th class="draggable" data-column="startedAt">Started <span class="sort-icon"></span></th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (data && data.length > 0) { %>
        <% data.forEach(item => { 
            // Extract Initial IP if available
            const initIP = item.initialContext ? item.initialContext.ip : '-';
            const method = item.initialContext ? item.initialContext.method : '';
            const requestId = item.initialContext ? (item.initialContext.requestId || '') : '';
            const actorDisplayName = item.initialContext ? (item.initialContext.displayName || item.initialContext.username || '') : '';
            const sectionName = item.sectionDisplayName || item.sectionId || '-';
            const operationName = item.operationDisplayName || item.operationId || '-';
            const showSectionId = item.sectionId && sectionName !== item.sectionId;
            const showOperationId = item.operationId && operationName !== item.operationId;
        %>
          <tr class="cursor-pointer view-details-row" data-id="<%= item.id %>">
            <td><span class="font-monospace text-primary small fw-bold"><%= item.id %></span></td>
            <td>
                <div class="d-flex align-items-center">
                    <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-2 border" style="width: 24px; height: 24px;">
                        <i class="bi bi-person text-secondary" style="font-size: 0.75rem;"></i>
                    </div>
                    <div>
                        <span class="small fw-semibold"><%= actorDisplayName || item.userId %></span>
                        <% if (actorDisplayName) { %><div class="x-small text-muted"><%= item.userId %></div><% } %>
                    </div>
                </div>
            </td>
            <td>
                <div class="d-flex align-items-center gap-1">
                    <span class="badge bg-light text-dark border"><%= sectionName %></span>
                    <i class="bi bi-chevron-right x-small text-muted"></i>
                    <span class="text-muted small fw-bold"><%= operationName %></span>
                </div>
                <% if (showSectionId || showOperationId) { %>
                  <div class="x-small text-muted mt-1">
                    <% if (showSectionId) { %>Section ID: <span class="font-monospace"><%= item.sectionId %></span><% } %>
                    <% if (showSectionId && showOperationId) { %> | <% } %>
                    <% if (showOperationId) { %>Operation ID: <span class="font-monospace"><%= item.operationId %></span><% } %>
                  </div>
                <% } %>
            </td>
            <td> <div class="small font-monospace text-muted">
                    <% if(method) { %><span class="badge bg-secondary-subtle text-dark border me-1" style="font-size: 0.65rem;"><%= method %></span><% } %>
                    <%= initIP %>
                    <% if (requestId) { %><div class="x-small text-muted mt-1">Req: <span class="font-monospace"><%= requestId %></span></div><% } %>
                </div>
            </td>
            <td>
                <div class="text-truncate" style="max-width: 120px;">
                    <span class="font-monospace small text-muted"><%= item.targetKey || '-' %></span>
                </div>
            </td>
            <td class="text-center">
                <% if (item.status === 'completed') { %>
                    <span class="badge bg-success">Success</span>
                <% } else if (item.status === 'active' || item.status === 'attempted' || item.status === 'in_progress' || item.status === 'retryable_error') { %>
                    <span class="badge bg-primary">Active</span>
                <% } else if (item.status === 'failed') { %>
                    <span class="badge bg-danger">Failed</span>
                <% } else { %>
                    <span class="badge bg-secondary"><%= item.status %></span>
                <% } %>
            </td>
            <td class="text-center">
                <span class="badge rounded-pill bg-light text-dark border"><%= item.attemptCount %></span>
            </td>
            <td class="text-end font-monospace small"><%= (item.volumeUsageKB || 0).toFixed(2) %> KB</td>
            <td><div class="small"><%= typeof formatOrgDateTime === 'function' ? formatOrgDateTime(item.startedAt || item.createdAt) : new Date(item.startedAt || item.createdAt).toLocaleString() %></div></td>
            <td class="table-actions text-end pe-4">
              <div class="row-actions-wrap">
                <button
                  type="button"
                  class="btn btn-secondary btn-sm btn-row-actions-toggle"
                  data-row-actions-id="<%= item.id %>"
                  title="Row actions">
                  <i class="bi bi-three-dots-vertical"></i>
                </button>
                <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                  <button class="btn btn-outline-primary btn-sm view-details-btn" data-id="<%= item.id %>">
                    <i class="bi bi-eye me-2"></i>View Details
                  </button>
                </div>
              </div>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr>
          <td colspan="10" class="text-center text-muted py-5">No activity records found.</td>
        </tr>
      <% } %>
    </tbody>
  </table>
</div>

