            <div class="text-muted x-small text-uppercase fw-bold ls-1">Activity Log</div>
            <h5 class="modal-title fw-bold" id="detailIdDisplay"></h5>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
