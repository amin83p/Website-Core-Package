<script>
document.addEventListener('DOMContentLoaded', () => {
    function initCollapseToggleIcon(options = {}) {
        const collapseEl = document.getElementById(String(options.collapseId || ''));
        const buttonEl = document.getElementById(String(options.buttonId || ''));
        const iconEl = document.getElementById(String(options.iconId || ''));
        if (!collapseEl || !buttonEl || !iconEl) return;

        const openIcon = String(options.openIcon || 'bi-chevron-down');
        const closeIcon = String(options.closeIcon || 'bi-chevron-up');
        const setState = (expanded) => {
            iconEl.classList.remove(openIcon, closeIcon);
            iconEl.classList.add(expanded ? closeIcon : openIcon);
            buttonEl.setAttribute('aria-expanded', expanded ? 'true' : 'false');
            buttonEl.setAttribute('aria-label', expanded ? 'Close filters' : 'Open filters');
        };

        setState(collapseEl.classList.contains('show'));
        collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
        collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
    }

    initCollapseToggleIcon({
        collapseId: 'actionStateFilterCollapse',
        buttonId: 'actionStateFilterToggleBtn',
        iconId: 'actionStateFilterToggleIcon',
        openIcon: 'bi-chevron-down',
        closeIcon: 'bi-chevron-up'
    });

    const modalEl = document.getElementById('actionStateModal');
    const bsModal = new bootstrap.Modal(modalEl);
    const detailsCache = {
        payload: null,
        changeEvents: [],
        entityTimeline: []
    };
    
    // UI Elements
    const els = {
        id: document.getElementById('detailIdDisplay'),
        userCon: document.getElementById('detailUserContainer'), 
        secCon: document.getElementById('detailSectionContainer'),
        
        // Header Context
        headOp: document.getElementById('headOp'),
        headTarget: document.getElementById('headTarget'),
        headIP: document.getElementById('headIP'),
        headUA: document.getElementById('headUA'),
        
        // Summary Stats
        sumDur: document.getElementById('summaryDuration'),
        sumAtt: document.getElementById('summaryAttempts'),
        sumVol: document.getElementById('summaryVolume'),
        
        // History
        timeline: document.getElementById('historyTimeline'),

        // Payload + Diff
        viewChanges: document.getElementById('viewChanges'),
        viewJson: document.getElementById('viewJson'),
        viewForm: document.getElementById('viewForm'),
        conChange: document.getElementById('changeViewContainer'),
        conJson: document.getElementById('jsonViewContainer'),
        conForm: document.getElementById('formViewContainer'),
        changeSet: document.getElementById('changeSetBuilder'),
        entityTimeline: document.getElementById('entityTimeline'),
        payloadCode: document.getElementById('detailPayload'),
        payloadForm: document.getElementById('payloadFormBuilder')
    };

    function toFiniteNumber(value) {
        const num = Number(value);
        return Number.isFinite(num) ? num : 0;
    }

    function resolveVolumeKB(record) {
        if (!record || typeof record !== 'object') return 0;
        const direct = toFiniteNumber(record.volumeUsageKB);
        if (direct > 0) return direct;

        const nested = [
            record?.progress?.volumeKB,
            record?.result?.volumeKB,
            record?.failure?.volumeKB,
            record?.retryableError?.volumeKB
        ].reduce((sum, value) => sum + toFiniteNumber(value), 0);
        if (nested > 0) return nested;

        if (Array.isArray(record?.history)) {
            return record.history.reduce((sum, row) => sum + toFiniteNumber(row?.volumeKB), 0);
        }
        return 0;
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function togglePayloadView(mode = 'changes') {
        const isChanges = mode === 'changes';
        const isJson = mode === 'json';
        const isForm = mode === 'form';

        els.conChange.classList.toggle('d-none', !isChanges);
        els.conJson.classList.toggle('d-none', !isJson);
        els.conForm.classList.toggle('d-none', !isForm);
    }

    function renderChangeSet(changeEvents = []) {
        if (!Array.isArray(changeEvents) || !changeEvents.length) {
            els.changeSet.innerHTML = '<div class="text-muted small">No structured change events recorded for this action.</div>';
            return;
        }

        const html = changeEvents.map((event, index) => {
            const summary = event?.summary || {};
            const actor = event?.actor || {};
            const changes = Array.isArray(event?.changes) ? event.changes : [];
            const eventAt = event?.at ? ((window.AppOrgDateTime && AppOrgDateTime.formatInstant) ? AppOrgDateTime.formatInstant(event.at) : new Date(event.at).toLocaleString()) : '-';
            const actorName = actor.displayName || actor.username || actor.userId || '-';

            let changesHtml = '<div class="text-muted small fst-italic">No field-level changes captured.</div>';
            if ((String(event?.mode || '').toLowerCase() === 'create') && changes.length === 0) {
                changesHtml = '<div class="text-muted small fst-italic">Create snapshot saved. Open JSON/Form tabs to view object details.</div>';
            }
            if (changes.length) {
                const rows = changes.map((row) => `
                    <tr>
                        <td class="font-monospace x-small">${escapeHtml(row.path)}</td>
                        <td class="x-small text-uppercase">${escapeHtml(row.type)}</td>
                        <td class="font-monospace x-small text-break">${escapeHtml(JSON.stringify(row.from))}</td>
                        <td class="font-monospace x-small text-break">${escapeHtml(JSON.stringify(row.to))}</td>
                    </tr>
                `).join('');
                changesHtml = `
                    <div class="table-scroll-wrapper border rounded">
                      <table class="table table-sm mb-0">
                        <thead class="table-light">
                          <tr>
                            <th>Path</th>
                            <th>Type</th>
                            <th>From</th>
                            <th>To</th>
                          </tr>
                        </thead>
                        <tbody>${rows}</tbody>
                      </table>
                    </div>
                `;
            }

            return `
              <div class="border rounded p-2 mb-3 bg-light">
                <div class="d-flex align-items-center justify-content-between mb-2">
                  <div>
                    <span class="badge bg-primary me-1">${escapeHtml(event.mode || 'update')}</span>
                    <span class="badge bg-dark">${escapeHtml(event.entityType || '-')}</span>
                    <span class="font-monospace small ms-1">${escapeHtml(event.entityId || '-')}</span>
                  </div>
                  <span class="text-muted x-small">${escapeHtml(eventAt)}</span>
                </div>
                <div class="x-small text-muted mb-2">
                  By: <strong>${escapeHtml(actorName)}</strong> |
                  Added: ${Number(summary.addedCount || 0)} |
                  Changed: ${Number(summary.changedCount || 0)} |
                  Hidden Audit: ${Number(summary.hiddenAuditCount || 0)}
                </div>
                ${changesHtml}
              </div>
            `;
        }).join('');

        els.changeSet.innerHTML = html;
    }

    function renderEntityTimeline(rows = []) {
        if (!Array.isArray(rows) || !rows.length) {
            els.entityTimeline.innerHTML = '<div class="text-muted">No cross-action timeline found for this entity.</div>';
            return;
        }

        const html = rows.map((row) => {
            const event = row?.event || {};
            const actor = event?.actor || {};
            const summary = event?.summary || {};
            const actorName = actor.displayName || actor.username || actor.userId || row?.userId || '-';
            const atDisplay = row?.at ? ((window.AppOrgDateTime && AppOrgDateTime.formatInstant) ? AppOrgDateTime.formatInstant(row.at) : new Date(row.at).toLocaleString()) : '-';
            return `
              <div class="border-start ps-2 mb-2">
                <div class="fw-semibold x-small">${escapeHtml(atDisplay)} - ${escapeHtml(actorName)}</div>
                <div class="x-small text-muted">
                  ${escapeHtml(event.mode || 'update')} | ${escapeHtml(event.entityType || '-')} |
                  +${Number(summary.addedCount || 0)} / ~${Number(summary.changedCount || 0)}
                </div>
                <div class="x-small text-muted">Action State: <span class="font-monospace">${escapeHtml(row.actionStateId || '-')}</span></div>
              </div>
            `;
        }).join('');

        els.entityTimeline.innerHTML = html;
    }

    // Toggle Payload Views
    els.viewChanges.addEventListener('change', () => {
        togglePayloadView('changes');
    });
    els.viewJson.addEventListener('change', () => {
        togglePayloadView('json');
    });
    els.viewForm.addEventListener('change', () => {
        togglePayloadView('form');
    });
    
    togglePayloadView('changes');

    document.querySelectorAll('.view-details-btn, .view-details-row').forEach(el => {
        el.addEventListener('click', async (e) => {
            if(el.classList.contains('view-details-row') && e.target.closest('.view-details-btn')) return;
            if (el.classList.contains('view-details-row') && e.target.closest('.row-actions-wrap, .row-actions-menu, .btn-row-actions-toggle')) return;
            const id = el.getAttribute('data-id');
            loadDetails(id);
        });
    });

    async function loadDetails(id) {
        document.getElementById('modalLoading').classList.remove('d-none');
        document.getElementById('modalContent').classList.add('d-none');
        
        els.viewChanges.checked = true;
        togglePayloadView('changes');
        
        bsModal.show();

        try {
            const res = await fetch(`/actionStates/details/${id}`, { headers: { 'X-AJAX-Request': 'true' } });
            if (!res.ok) throw new Error("Failed to load details");
            
            const json = await res.json();
            const rec = json.record;
            const meta = json.meta || {};
            const payload = json.decryptedPayload;
            const changeEvents = Array.isArray(json.changeEvents) ? json.changeEvents : [];
            const entityTimeline = Array.isArray(json.entityTimeline) ? json.entityTimeline : [];
            const ctx = rec.initialContext || {}; // ✅ Get Context

            detailsCache.payload = payload || null;
            detailsCache.changeEvents = changeEvents;
            detailsCache.entityTimeline = entityTimeline;

            els.id.textContent = rec.id;
            
            // Header Context
            els.headOp.textContent = meta.opName || rec.operationId;
            els.headTarget.textContent = rec.targetKey || 'Global';
            els.headIP.textContent = ctx.ip || 'Unknown IP';
            els.headUA.textContent = ctx.userAgent || '-';
            els.headUA.title = ctx.userAgent || '';

            // User Link
            els.userCon.innerHTML = `
                <a href="/users/edit/${rec.userId}" class="fw-bold text-dark text-decoration-none hover-primary" target="_blank">
                    ${meta.userName} <i class="bi bi-box-arrow-up-right x-small text-muted ms-1"></i>
                </a>
                <div class="x-small text-muted">ID: ${rec.userId}</div>
                ${meta.username ? `<div class="x-small text-muted">Username: <span class="font-monospace">${meta.username}</span></div>` : ''}
                ${meta.requestId ? `<div class="x-small text-muted">Request: <span class="font-monospace">${meta.requestId}</span></div>` : ''}
            `;
            
            // Section Link
            els.secCon.innerHTML = `
                <a href="/sections/edit/${rec.sectionId}" class="badge bg-secondary text-decoration-none fs-6" target="_blank">
                    <i class="bi bi-collection me-1"></i> ${meta.sectionName}
                </a>
            `;

            // Metrics
            const start = new Date(rec.startedAt || rec.createdAt).getTime();
            const last = new Date(rec.lastActiveAt || rec.updatedAt || rec.startedAt || rec.createdAt).getTime();
            const diffMs = last - start;
            els.sumDur.textContent = (diffMs / 1000).toFixed(2) + 's';
            els.sumAtt.textContent = rec.attemptCount || 0;
            els.sumVol.textContent = resolveVolumeKB(rec).toFixed(2) + ' KB';

            // History Timeline with Context
            let tlHtml = '';
            if (rec.history && rec.history.length) {
                rec.history.forEach((h, idx) => {
                    let dotClass = '';
                    // Status Coloring
                    if (h.status.includes('success') || h.status.includes('completed')) dotClass = 'success';
                    else if (h.status.includes('fail') || h.status.includes('error')) dotClass = 'fail';
                    else if (h.status.includes('start')) dotClass = 'start';

                    const date = new Date(h.ts);
                    
                    // ✅ Show Context (Method/URL)
                    let ctxHtml = '';
                    if (h.context && h.context.method) {
                        ctxHtml = `
                            <div class="mt-1 p-1 bg-light border rounded font-monospace" style="font-size: 0.7rem;">
                                <span class="fw-bold text-dark">${h.context.method}</span> 
                                <span class="text-muted text-break">${h.context.url}</span>
                            </div>`;
                    }

                    tlHtml += `
                        <div class="timeline-item pb-3 border-start ps-3 position-relative" style="margin-left: 10px;">
                            <div class="timeline-dot ${dotClass}" style="left: -5px;"></div>
                            <div class="d-flex justify-content-between">
                                <div class="fw-bold text-dark small">${h.status}</div>
                                <div class="text-muted x-small">${date.toLocaleTimeString()}</div>
                            </div>
                            <div class="text-muted x-small fst-italic">${h.details || ''}</div>
                            ${ctxHtml}
                        </div>
                    `;
                });
            } else { 
                tlHtml = '<div class="text-muted small p-3">No history recorded.</div>';
            }
            els.timeline.innerHTML = tlHtml;

            // Change Set + Timeline
            renderChangeSet(changeEvents);
            renderEntityTimeline(entityTimeline);

            // Legacy Payload fallback
            if (payload) els.payloadCode.textContent = JSON.stringify(payload, null, 4);
            else els.payloadCode.textContent = "// No data payload saved.";

            // Form Builder
            els.payloadForm.innerHTML = '';
            if (payload && typeof payload === 'object') {
                Object.keys(payload).forEach(key => {
                    const val = payload[key];
                    let inputHtml = '';
                    if (typeof val === 'object' && val !== null) {
                        inputHtml = `<textarea class="form-control font-monospace size-sm bg-light" rows="3" readonly>${JSON.stringify(val, null, 2)}</textarea>`;
                    } else {
                        inputHtml = `<input type="text" class="form-control font-monospace size-sm bg-light" value="${val}" readonly>`;
                    }
                    const col = document.createElement('div');
                    col.className = 'col-12';
                    col.innerHTML = `<label class="form-label x-small text-uppercase fw-bold text-muted mb-1">${key}</label>${inputHtml}`;
                    els.payloadForm.appendChild(col);
                });
            } else {
                els.payloadForm.innerHTML = `<div class="text-center text-muted py-5"><i>No structured data.</i></div>`;
            }

            document.getElementById('modalLoading').classList.add('d-none');
            document.getElementById('modalContent').classList.remove('d-none');
        } catch (err) {
            console.error(err);
            document.getElementById('modalLoading').innerHTML = `<div class="alert alert-danger m-3">Error: ${err.message}</div>`;
        }
    }

    // Copy Button
    document.getElementById('copyPayloadBtn').addEventListener('click', () => {
        let text = '';
        if (els.viewChanges.checked) {
            text = JSON.stringify({
                changeEvents: detailsCache.changeEvents || [],
                entityTimeline: detailsCache.entityTimeline || []
            }, null, 2);
        } else if (els.viewJson.checked) {
            text = els.payloadCode.textContent;
        } else {
            text = JSON.stringify(detailsCache.payload || {}, null, 2);
        }
        navigator.clipboard.writeText(text).then(() => {
            const btn = document.getElementById('copyPayloadBtn');
            const orig = btn.innerHTML;
            btn.innerHTML = '<i class="bi bi-check2"></i>';
            setTimeout(() => btn.innerHTML = orig, 1500);
        });
    });
});
</script>

<script>
  (function () {
    const btn = document.getElementById('run-retention-cleanup-btn');
    if (!btn) return;

    btn.addEventListener('click', () => {
      showMessageModal({
        title: 'Run Cleanup',
        icon: 'warning',
        message: 'This will run Action State retention cleanup now. Continue?',
        buttons: [
          { text: 'Cancel', class: 'btn-secondary btn-md' },
          { text: 'Run Cleanup', class: 'btn-warning btn-md' }
        ]
      }).then(async (result) => {
        if (result !== 'Run Cleanup') return;

        if (typeof window.requestProtectedAction === 'function') {
          await window.requestProtectedAction();
        } else {
          await showMessageModal({
            title: 'Verification Code',
            icon: 'error',
            message: 'Admin Verification System not loaded.',
            buttons: [{ text: 'Close', class: 'btn-secondary btn-md' }]
          });
          return;
        }

        btn.disabled = true;
        try {
          const resp = await fetch('/actionStates/retention-cleanup', {
            method: 'POST',
            headers: {
              'x-ajax-request': '1',
              'Accept': 'application/json'
            },
            credentials: 'same-origin'
          });

          const data = await resp.json().catch(() => ({}));
          if (!resp.ok || data.status !== 'success') {
            throw new Error(data?.message || 'Cleanup failed.');
          }

          await showMessageModal({
            title: 'Cleanup Completed',
            icon: 'success',
            message: data.message || 'Retention cleanup completed.',
            buttons: [{ text: 'OK', class: 'btn-primary btn-md' }]
          });
          window.location.href = '/actionStates';
        } catch (err) {
          await showMessageModal({
            title: 'Cleanup Failed',
            icon: 'error',
            message: err.message || 'Cleanup request failed.',
            buttons: [{ text: 'Close', class: 'btn-secondary btn-md' }]
          });
        } finally {
          btn.disabled = false;
        }
      });
    });
  })();
</script>

<script>
  (function () {
    const FETCH_URL = '/actionStates/delete-all';
    const btn = document.getElementById('delete-all-logs-btn');

    if (!btn) return;

    btn.addEventListener('click', () => {
      showMessageModal({
        title: 'Confirm Delete',
        icon: 'warning',
        message: 'This action will permanently delete ALL stored data. This cannot be undone.',
        buttons: [
          { text: 'Cancel', class: 'btn-secondary btn-md' },
          { text: 'Delete', class: 'btn-danger btn-md' }
        ]
      }).then(async (result) => {
        if (result !== 'Delete') return;  
        if (typeof window.requestProtectedAction === 'function') {
            await window.requestProtectedAction();
        } else {
          showMessageModal({
              title: 'Verification Code',
              icon: 'error',
              message: 'Admin Verification System not loaded. Proceeding...',
              buttons: [ { text: 'Ok', class: 'btn-danger btn-md' } ]
            });
            return;
        }
        
        btn.disabled = true;
        try {
          const resp = await fetch(FETCH_URL, {
            method: 'GET', 
            headers: {
              'x-ajax-request': '1',       
              'Accept': 'application/json' 
            },
            credentials: 'same-origin'
          });
          if (!resp.ok) {
            let data;
            try { data = await resp.json(); } catch (e) { data = null; }
            const serverMessage = data?.message || 'Delete failed due to a server error.';
            await showMessageModal({
              title: 'Delete Failed',
              icon: 'error',
              message: serverMessage,
              buttons: [{ text: 'Close', class: 'btn-secondary btn-md' }]
            });
            return;
          }

          await showMessageModal({
            title: 'All data Deleted',
            icon: 'success',
            message: 'All stored data was deleted successfully.',
            buttons: [{ text: 'OK', class: 'btn-primary btn-md' }]
          });
          window.location.href = '/actionStates';
        } catch (err) {
          await showMessageModal({
            title: 'Network Error',
            icon: 'error',
            message: `Request failed: ${err.message}`,
            buttons: [{ text: 'Close', class: 'btn-secondary btn-md' }]
          });
        } finally {
          btn.disabled = false;
        }
      });
    });
  })();
</script>
