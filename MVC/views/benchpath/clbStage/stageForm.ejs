<%
  const isEdit = !!(stageData && stageData.id);
  const formAction = isEdit ? `/benchpath/clb-stages/edit/${stageData.id}` : '/benchpath/clb-stages/new';
  const benchmarkRange = stageData?.benchmarkRange || { minimum: '', maximum: '' };
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <h1 class="page-heading size-md m-0"><%= isEdit ? 'Edit CLB Stage' : 'Create CLB Stage' %></h1>
    <div class="d-flex align-items-center gap-2">
      <% if (isEdit) { %><span class="badge bg-primary border">ID: <%= stageData.id %></span><% } else { %><span class="badge bg-success border">New Item</span><% } %>
    </div>
  </div>

  <div class="form-container" style="width: 100%; max-width: 1400px;">
    <form id="stageForm" method="POST" action="<%= formAction %>">
      <input type="hidden" name="actionStateId" value="<%= typeof actionStateId !== 'undefined' ? actionStateId : '' %>">

      <div class="border rounded p-3 bg-white shadow-sm">
        <div class="row g-2">
          <div class="col-md-6 mb-3"><label class="form-label fw-bold">ID *</label><input class="form-control" name="id" value="<%= stageData?.id || '' %>" <%= isEdit ? 'readonly' : '' %> required></div>
          <div class="col-md-6 mb-3"><label class="form-label fw-bold">Slug *</label><input class="form-control" name="slug" value="<%= stageData?.slug || '' %>" required></div>
        </div>

        <div class="row g-2">
          <div class="col-md-3 mb-3"><label class="form-label fw-bold">Code *</label><input class="form-control" name="code" value="<%= stageData?.code || '' %>" required></div>
          <div class="col-md-5 mb-3"><label class="form-label fw-bold">Label *</label><input class="form-control" name="label" value="<%= stageData?.label || '' %>" required></div>
          <div class="col-md-4 mb-3"><label class="form-label">Short Label</label><input class="form-control" name="shortLabel" value="<%= stageData?.shortLabel || '' %>"></div>
        </div>

        <div class="row g-2">
          <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Framework *</label>
            <select class="form-select" name="frameworkId" required>
              <option value="">Select framework...</option>
              <% (frameworks || []).forEach((fw) => { %>
                <option value="<%= fw.id %>" <%= stageData?.frameworkId === fw.id ? 'selected' : '' %>><%= fw.title %> (<%= fw.id %>)</option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-6 mb-3"><label class="form-label fw-bold">Descriptor *</label><select class="form-select" name="descriptor" required><option value="">Select...</option><% descriptorOptions.forEach((opt)=>{ %><option value="<%= opt %>" <%= stageData?.descriptor===opt?'selected':'' %>><%= opt %></option><% }) %></select></div>
        </div>

        <div class="row g-2">
          <div class="col-md-4 mb-3"><label class="form-label fw-bold">Benchmark Min *</label><input type="number" min="1" class="form-control" name="benchmarkMin" value="<%= benchmarkRange.minimum ?? '' %>" required></div>
          <div class="col-md-4 mb-3"><label class="form-label fw-bold">Benchmark Max *</label><input type="number" min="1" class="form-control" name="benchmarkMax" value="<%= benchmarkRange.maximum ?? '' %>" required></div>
          <div class="col-md-4 mb-3"><label class="form-label fw-bold">Display Order *</label><input type="number" min="1" class="form-control" name="displayOrder" value="<%= stageData?.displayOrder || '' %>" required></div>
        </div>

        <div class="row g-2">
          <div class="col-md-6 mb-3"><label class="form-label fw-bold">Status *</label><select class="form-select" name="status" required><option value="">Select...</option><% statusOptions.forEach((opt)=>{ %><option value="<%= opt %>" <%= stageData?.status===opt?'selected':'' %>><%= opt %></option><% }) %></select></div>
          <div class="col-md-6 mb-3"><label class="form-label fw-bold">Review Status *</label><select class="form-select" name="reviewStatus" required><option value="">Select...</option><% reviewStatusOptions.forEach((opt)=>{ %><option value="<%= opt %>" <%= stageData?.reviewStatus===opt?'selected':'' %>><%= opt %></option><% }) %></select></div>
        </div>

        <div class="mb-3"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="2"><%= stageData?.description || '' %></textarea></div>
        <div class="mb-3"><label class="form-label">Tags (comma separated)</label><input class="form-control" name="tags" value="<%= Array.isArray(stageData?.tags) ? stageData.tags.join(', ') : '' %>"></div>

        <div class="d-flex gap-4 flex-wrap">
          <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="isActive" name="isActive" value="true" <%= stageData ? (stageData.isActive?'checked':'') : 'checked' %>><label class="form-check-label fw-bold" for="isActive">isActive</label></div>
          <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="isSystem" name="isSystem" value="true" <%= stageData?.isSystem?'checked':'' %>><label class="form-check-label fw-bold" for="isSystem">isSystem</label></div>
          <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="isLocked" name="isLocked" value="true" <%= stageData?.isLocked?'checked':'' %>><label class="form-check-label fw-bold" for="isLocked">isLocked</label></div>
        </div>
      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md"><i class="bi bi-save me-1"></i> Save</button>
        <a href="/benchpath/clb-stages" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction" data-return-url="/benchpath/clb-stages">Cancel</a>
      </div>
    </form>
  </div>
</div>

<script>
  (function () {
    const form = document.getElementById('stageForm');
    if (!form) return;
    let isSubmitting = false;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (isSubmitting) return;

      isSubmitting = true;
      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;

      try {
        const payload = new URLSearchParams(new FormData(form));
        const response = await fetch(form.action, {
          method: (form.method || 'POST').toUpperCase(),
          headers: {
            'x-ajax-request': '1',
            Accept: 'application/json',
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
          },
          body: payload
        });
        const result = await response.json().catch(() => ({ status: 'error', message: `Server returned HTTP ${response.status}.` }));
        const isSuccess = response.ok && result?.status === 'success';

        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: isSuccess ? 'Saved' : 'Save Failed',
            icon: isSuccess ? 'success' : 'error',
            message: result?.message || (isSuccess ? 'Saved successfully.' : 'Unable to save.'),
            buttons: [{ text: 'OK', class: isSuccess ? 'btn-success' : 'btn-danger' }]
          });
        }
        if (isSuccess) window.location.href = '/benchpath/clb-stages';
      } catch (error) {
        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: 'Save Failed',
            icon: 'error',
            message: error?.message || 'Unexpected network error.',
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        }
      } finally {
        isSubmitting = false;
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  })();
</script>
