<div class="mb-3">
  <label class="form-label fw-bold">Descriptor Summary</label>
  <textarea class="form-control" name="descriptorSummary" rows="3"><%= itemData?.descriptorSummary || '' %></textarea>
</div>
<div class="mb-3">
  <label class="form-label fw-bold">Descriptor Dimensions</label>
  <div class="d-flex gap-2 mb-2">
    <input type="text" class="form-control" id="descriptorDimensionsChipText" placeholder="Type dimension and press Enter">
    <button type="button" class="btn btn-outline-primary" id="descriptorDimensionsAddChip">Add</button>
  </div>
  <div id="descriptorDimensionsChipContainer" class="d-flex flex-wrap gap-2"></div>
</div>
<div class="mb-3">
  <label class="form-label fw-bold">Features Of Communication</label>
  <div class="border rounded p-2" style="max-height: 220px; overflow:auto;">
    <% (options.featuresOfCommunication || []).forEach((row) => { %>
      <div class="form-check dep-cb-features" data-framework-id="<%= row.frameworkId || '' %>" data-skill-id="<%= row.skillId || '' %>" data-benchmark-id="<%= row.benchmarkId || '' %>" data-competency-id="<%= row.competencyId || '' %>">
        <input class="form-check-input" type="checkbox" name="featureIds" value="<%= row.id %>" id="po_feat_<%= String(row.id).replace(/[^A-Za-z0-9_-]/g, '_') %>" <%= inSet(selectedFeatureIds, row.id) ? 'checked' : '' %>>
        <label class="form-check-label small" for="po_feat_<%= String(row.id).replace(/[^A-Za-z0-9_-]/g, '_') %>"><%= row.title || row.id %></label>
      </div>
    <% }) %>
  </div>
</div>
