<div class="mb-3">
  <label class="form-label fw-bold">Competency Statement</label>
  <textarea class="form-control" name="competencyStatement" rows="3"><%= itemData?.competencyStatement || '' %></textarea>
</div>
<div class="mb-3">
  <label class="form-label fw-bold">Communicative Purpose</label>
  <input class="form-control" name="communicativePurpose" value="<%= itemData?.communicativePurpose || '' %>">
</div>
<div class="row g-3">
  <div class="col-lg-4">
    <label class="form-label fw-bold">Indicators</label>
    <div class="border rounded p-2" style="max-height: 220px; overflow:auto;">
      <% (options.indicators || []).forEach((row) => { %>
        <div class="form-check dep-cb-indicators" data-framework-id="<%= row.frameworkId || '' %>" data-skill-id="<%= row.skillId || '' %>" data-benchmark-id="<%= row.benchmarkId || '' %>" data-competency-id="<%= row.competencyId || '' %>">
          <input class="form-check-input" type="checkbox" name="indicatorIds" value="<%= row.id %>" id="co_ind_<%= String(row.id).replace(/[^A-Za-z0-9_-]/g, '_') %>" <%= inSet(selectedIndicatorIds, row.id) ? 'checked' : '' %>>
          <label class="form-check-label small" for="co_ind_<%= String(row.id).replace(/[^A-Za-z0-9_-]/g, '_') %>"><%= row.title || row.id %></label>
        </div>
      <% }) %>
    </div>
  </div>
  <div class="col-lg-4">
    <label class="form-label fw-bold">Features Of Communication</label>
    <div class="border rounded p-2" style="max-height: 220px; overflow:auto;">
      <% (options.featuresOfCommunication || []).forEach((row) => { %>
        <div class="form-check dep-cb-features" data-framework-id="<%= row.frameworkId || '' %>" data-skill-id="<%= row.skillId || '' %>" data-benchmark-id="<%= row.benchmarkId || '' %>" data-competency-id="<%= row.competencyId || '' %>">
          <input class="form-check-input" type="checkbox" name="featureIds" value="<%= row.id %>" id="co_feat_<%= String(row.id).replace(/[^A-Za-z0-9_-]/g, '_') %>" <%= inSet(selectedFeatureIds, row.id) ? 'checked' : '' %>>
          <label class="form-check-label small" for="co_feat_<%= String(row.id).replace(/[^A-Za-z0-9_-]/g, '_') %>"><%= row.title || row.id %></label>
        </div>
      <% }) %>
    </div>
  </div>
  <div class="col-lg-4">
    <label class="form-label fw-bold">Sample Task Labels</label>
    <div class="border rounded p-2" style="max-height: 220px; overflow:auto;">
      <% (options.sampleTaskLabels || []).forEach((row) => { %>
        <div class="form-check dep-cb-sample-task-labels" data-framework-id="<%= row.frameworkId || '' %>" data-skill-id="<%= row.skillId || '' %>" data-benchmark-id="<%= row.benchmarkId || '' %>" data-competency-id="<%= row.competencyId || '' %>">
          <input class="form-check-input" type="checkbox" name="sampleTaskLabelIds" value="<%= row.id %>" id="co_task_<%= String(row.id).replace(/[^A-Za-z0-9_-]/g, '_') %>" <%= inSet(selectedSampleTaskLabelIds, row.id) ? 'checked' : '' %>>
          <label class="form-check-label small" for="co_task_<%= String(row.id).replace(/[^A-Za-z0-9_-]/g, '_') %>"><%= row.title || row.id %></label>
        </div>
      <% }) %>
    </div>
  </div>
</div>
