<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
      <h1 class="page-heading size-md m-0">BenchPath Migration Tools</h1>
      <div class="text-muted small mt-1">Run normalization dry-run reports and controlled apply runs for the BenchPath reference layer.</div>
    </div>
    <a href="/benchpath" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-speedometer2 me-1"></i>Dashboard
    </a>
  </div>

  <div class="form-container wide" style="max-width: 1400px;">
    <input type="hidden" id="hid_actionStateId" value="<%= actionStateId || '' %>">

    <div class="card border-0 shadow-sm mb-4">
      <div class="card-body p-4">
        <div class="row g-3">
          <div class="col-lg-8">
            <h5 class="fw-bold mb-2"><i class="bi bi-shield-check me-2"></i>Migration Workflow</h5>
            <div class="small text-muted">
              1. Run a dry-run report first to detect coercions and integrity issues.<br>
              2. Review report details before applying normalization migration.<br>
              3. Apply mode writes only valid changed records and keeps backups.
            </div>
          </div>
          <div class="col-lg-4 d-flex align-items-center justify-content-lg-end">
            <div class="d-flex flex-wrap gap-2">
              <button type="button" class="btn btn-primary btn-md" id="btnDryRun">
                <i class="bi bi-search me-1"></i>Run Dry-Run
              </button>
              <button type="button" class="btn btn-danger btn-md" id="btnApply">
                <i class="bi bi-lightning-charge me-1"></i>Apply Migration
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm mb-4" id="resultCard" style="display:none;">
      <div class="card-header bg-white py-3">
        <h5 class="m-0 fw-bold"><i class="bi bi-clipboard-data me-2"></i>Last Run Summary</h5>
      </div>
      <div class="card-body p-4">
        <div id="summaryMetrics" class="row g-3 mb-4"></div>
        <div id="runMeta" class="small text-muted mb-3"></div>
        <div class="table-responsive">
          <table class="table table-sm align-middle">
            <thead>
              <tr>
                <th>Entity</th>
                <th class="text-end">Records</th>
                <th class="text-end">Changed</th>
                <th class="text-end">Coerced Fields</th>
                <th class="text-end">Integrity Issues</th>
                <th class="text-end">Skipped</th>
              </tr>
            </thead>
            <tbody id="entitySummaryRows"></tbody>
          </table>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white py-3 d-flex align-items-center justify-content-between">
        <h5 class="m-0 fw-bold"><i class="bi bi-file-earmark-text me-2"></i>Recent Reports</h5>
        <span class="badge text-bg-secondary"><%= Array.isArray(reports) ? reports.length : 0 %> files</span>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>File</th>
                <th>Modified</th>
                <th class="text-end">Size (KB)</th>
                <th class="text-end">Action</th>
              </tr>
            </thead>
            <tbody id="reportsRows">
              <% if (Array.isArray(reports) && reports.length) { %>
                <% reports.forEach((report) => { %>
                  <tr>
                    <td class="font-monospace"><%= report.fileName %></td>
                    <td><%= report.modifiedAt %></td>
                    <td class="text-end"><%= (Number(report.sizeBytes || 0) / 1024).toFixed(1) %></td>
                    <td class="text-end">
                      <a class="btn btn-sm btn-outline-primary" href="/benchpath/tools/reports/<%= encodeURIComponent(report.fileName) %>">
                        <i class="bi bi-download me-1"></i>Download
                      </a>
                    </td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr>
                  <td colspan="4" class="text-center py-4 text-muted">No migration reports found yet.</td>
                </tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const btnDryRun = document.getElementById('btnDryRun');
    const btnApply = document.getElementById('btnApply');
    const actionStateIdInput = document.getElementById('hid_actionStateId');
    const resultCard = document.getElementById('resultCard');
    const summaryMetrics = document.getElementById('summaryMetrics');
    const runMeta = document.getElementById('runMeta');
    const entitySummaryRows = document.getElementById('entitySummaryRows');
    const reportsRows = document.getElementById('reportsRows');

    function escapeHtml(value) {
      return String(value == null ? '' : value)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function renderReports(reports) {
      if (!reportsRows) return;
      const list = Array.isArray(reports) ? reports : [];
      if (!list.length) {
        reportsRows.innerHTML = '<tr><td colspan="4" class="text-center py-4 text-muted">No migration reports found yet.</td></tr>';
        return;
      }

      reportsRows.innerHTML = list.map((report) => `
        <tr>
          <td class="font-monospace">${escapeHtml(report.fileName || '')}</td>
          <td>${escapeHtml(report.modifiedAt || '')}</td>
          <td class="text-end">${(Number(report.sizeBytes || 0) / 1024).toFixed(1)}</td>
          <td class="text-end">
            <a class="btn btn-sm btn-outline-primary" href="/benchpath/tools/reports/${encodeURIComponent(report.fileName || '')}">
              <i class="bi bi-download me-1"></i>Download
            </a>
          </td>
        </tr>
      `).join('');
    }

    function renderSummary(payload) {
      const summary = payload?.summary || {};
      const meta = payload?.meta || {};
      const entities = Array.isArray(payload?.entities) ? payload.entities : [];

      if (!resultCard || !summaryMetrics || !runMeta || !entitySummaryRows) return;
      resultCard.style.display = '';

      const metricCards = [
        { label: 'Records Scanned', value: Number(summary.recordsScanned || 0), tone: 'primary' },
        { label: 'Records Changed', value: Number(summary.recordsChanged || 0), tone: 'info' },
        { label: 'Fields Coerced', value: Number(summary.fieldsCoerced || 0), tone: 'warning' },
        { label: 'Integrity Issues', value: Number(summary.invalidRelationsFound || 0), tone: 'danger' },
        { label: 'Records Skipped', value: Number(summary.recordsSkipped || 0), tone: 'secondary' },
        { label: 'Indexes Rebuilt', value: Number(summary.indexesRebuilt || 0), tone: 'success' }
      ];

      summaryMetrics.innerHTML = metricCards.map((item) => `
        <div class="col-xl-2 col-lg-4 col-md-6">
          <div class="border rounded-3 p-3 h-100">
            <div class="small text-muted">${escapeHtml(item.label)}</div>
            <div class="fs-4 fw-bold text-${escapeHtml(item.tone)}">${escapeHtml(item.value)}</div>
          </div>
        </div>
      `).join('');

      runMeta.innerHTML = `
        Mode: <b>${escapeHtml(meta.mode || 'n/a')}</b> |
        Generated At: <b>${escapeHtml(meta.generatedAt || 'n/a')}</b> |
        Reference Dir: <span class="font-monospace">${escapeHtml(meta.referenceDir || '')}</span>
      `;

      entitySummaryRows.innerHTML = entities.map((entity) => `
        <tr>
          <td>${escapeHtml(entity.entityType || '')}</td>
          <td class="text-end">${Number(entity.recordCount || 0)}</td>
          <td class="text-end">${Number(entity.recordsChanged || 0)}</td>
          <td class="text-end">${Number(entity.fieldsCoerced || 0)}</td>
          <td class="text-end">${Number(entity.invalidRelationsFound || 0)}</td>
          <td class="text-end">${Number(entity.recordsSkipped || 0)}</td>
        </tr>
      `).join('');
    }

    async function showModal(options) {
      if (typeof window.showMessageModal === 'function') {
        return window.showMessageModal(options);
      }
      return null;
    }

    async function runAction(button, path, successTitle, successMessage, withConfirm) {
      const originalHtml = button.innerHTML;
      try {
        if (withConfirm) {
          const decision = await showModal({
            title: 'Apply Normalization Migration?',
            icon: 'warning',
            message: 'This operation writes normalized data into BenchPath reference files and creates backup copies. Continue?',
            buttons: [
              { text: 'Cancel', class: 'btn-secondary' },
              { text: 'Apply', class: 'btn-danger' }
            ]
          });
          if (decision !== 'Apply') return;
        }

        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Running...';

        const body = new URLSearchParams();
        body.set('actionStateId', String(actionStateIdInput?.value || '').trim());

        const response = await fetch(path, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
            'X-AJAX-Request': 'true',
            Accept: 'application/json'
          },
          body: body.toString()
        });

        const payload = await response.json().catch(() => ({
          status: 'error',
          message: `Server returned HTTP ${response.status}.`
        }));

        if (!response.ok || payload?.status !== 'success') {
          throw new Error(payload?.message || 'Operation failed.');
        }

        renderSummary(payload);
        renderReports(payload.recentReports);

        await showModal({
          title: successTitle,
          icon: 'success',
          message: `${successMessage}${payload.reportFile ? `<br><br><b>Report:</b> <span class="font-monospace">${escapeHtml(payload.reportFile)}</span>` : ''}`,
          buttons: [{ text: 'OK', class: 'btn-success' }]
        });
      } catch (error) {
        await showModal({
          title: 'Operation Failed',
          icon: 'error',
          message: String(error?.message || 'Unexpected error occurred.'),
          buttons: [{ text: 'Close', class: 'btn-danger' }]
        });
      } finally {
        button.disabled = false;
        button.innerHTML = originalHtml;
      }
    }

    if (btnDryRun) {
      btnDryRun.addEventListener('click', function () {
        runAction(this, '/benchpath/tools/dry-run', 'Dry-Run Completed', 'Dry-run report generated successfully.', false);
      });
    }

    if (btnApply) {
      btnApply.addEventListener('click', function () {
        runAction(this, '/benchpath/tools/apply', 'Migration Applied', 'Normalization migration was applied successfully.', true);
      });
    }
  })();
</script>
