<%
  const stateFilters = (filters && typeof filters === 'object') ? filters : {};
  const summaryData = (summary && typeof summary === 'object') ? summary : {};
  const timelineMaxRangeDays = Number(maxRangeDays || 7);
  const allowUserPicker = Boolean(canPickUsers);

  function toList(raw) {
    if (Array.isArray(raw)) {
      return Array.from(new Set(raw
        .map((item) => String(item || '').trim())
        .filter(Boolean)));
    }
    const token = String(raw || '').trim();
    if (!token) return [];
    return Array.from(new Set(token
      .split(',')
      .map((item) => String(item || '').trim())
      .filter(Boolean)));
  }

  const defaultUserId = String(allowUserPicker ? (stateFilters.userId || '') : (stateFilters.userId || user?.id || '')).trim();
  const selectedSummary = String(selectedUserSummary || '').trim();
  const showAllUsersMode = allowUserPicker && !defaultUserId;
  const defaultUserLabel = String(
    (showAllUsersMode ? 'All users' : '')
      || selectedSummary
      || user?.displayName
      || user?.name
      || user?.username
      || defaultUserId
      || '-'
  ).trim();

  function orgLabel(org) {
    if (!org || typeof org !== 'object') return '';
    const name = String(org?.identity?.displayName || org?.name || '').trim();
    const id = String(org?.id || '').trim();
    if (name && id && name !== id) return `${name} (${id})`;
    return name || id;
  }

  const sectionRows = Array.isArray(sections) ? sections : [];
  const operationRows = Array.isArray(operations) ? operations : [];
  const organizationRows = Array.isArray(organizations) ? organizations : [];

  const sectionLookupRows = sectionRows.map((row) => ({
    id: String(row?.id || '').trim(),
    name: String(row?.name || row?.id || '').trim()
  })).filter((row) => row.id);
  sectionLookupRows.push({ id: '000000', name: 'SYSTEM' });
  sectionLookupRows.push({ id: '0000000', name: 'SYSTEM' });

  const operationLookupRows = operationRows.map((row) => ({
    id: String(row?.id || '').trim(),
    name: String(row?.name || row?.id || '').trim()
  })).filter((row) => row.id);

  const orgLookupRows = organizationRows.map((row) => ({
    id: String(row?.id || '').trim(),
    name: orgLabel(row)
  })).filter((row) => row.id && row.name);

  const sectionLookupMap = {};
  sectionLookupRows.forEach((row) => { sectionLookupMap[row.id] = row.name; });
  const operationLookupMap = {};
  operationLookupRows.forEach((row) => { operationLookupMap[row.id] = row.name; });
  const orgLookupMap = {};
  orgLookupRows.forEach((row) => { orgLookupMap[row.id] = row.name; });

  const selectedSectionIds = toList(stateFilters.sectionIds || stateFilters.sectionId);
  const selectedOperationIds = toList(stateFilters.operationIds || stateFilters.operationId);
  const selectedOrgIds = toList(stateFilters.orgIds || stateFilters.orgId);
  const selectedSectionRows = selectedSectionIds.map((id) => ({ id, name: sectionLookupMap[id] || id }));
  const selectedOperationRows = selectedOperationIds.map((id) => ({ id, name: operationLookupMap[id] || id }));
  const selectedOrgRows = selectedOrgIds.map((id) => ({ id, name: orgLookupMap[id] || id }));

  const hasAdvancedFilters = Boolean(
    String(stateFilters.status || '').trim()
    || String(stateFilters.source || '').trim()
    || String(stateFilters.q || '').trim()
    || selectedSectionIds.length
    || selectedOperationIds.length
    || selectedOrgIds.length
  );
%>

