<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white py-2 px-3 d-flex align-items-center justify-content-between">
    <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Timeline Filters</div>
    <div class="small text-muted">Hourly timeline - max range: <%= timelineMaxRangeDays %> days</div>
  </div>
  <div class="card-body p-3">
    <form id="trackActivityFilterForm" method="GET" action="/security/track-activity">
      <input type="hidden" name="maxRows" value="<%= Number(stateFilters.maxRows || 2500) %>">
      <input type="hidden" name="limit" value="<%= Number(stateFilters.limit || 2500) %>">
      <input type="hidden" id="trackActivityUserIdInput" name="userId" value="<%= defaultUserId %>">

      <div class="row g-3 align-items-end">
        <div class="col-lg-4">
          <label class="form-label small fw-bold text-muted text-uppercase">User</label>
          <div class="input-group">
            <input
              id="trackActivityUserSummary"
              type="text"
              class="form-control size-md"
              value="<%= defaultUserLabel %>"
              readonly>
            <% if (allowUserPicker) { %>
              <button id="trackActivityPickUserBtn" type="button" class="btn btn-outline-primary">
                <i class="bi bi-person-plus"></i>
              </button>
              <button id="trackActivityResetUserBtn" type="button" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-counterclockwise"></i>
              </button>
            <% } %>
          </div>
          <% if (!allowUserPicker) { %>
            <div class="form-text">Your scope is fixed to your own activity.</div>
          <% } %>
        </div>
        <div class="col-lg-3 col-md-6">
          <label class="form-label small fw-bold text-muted text-uppercase">Start (Date & Time)</label>
          <input
            id="trackActivityStartAt"
            type="datetime-local"
            name="startAt"
            class="form-control size-md"
            value="<%= stateFilters.startAt || '' %>">
        </div>
        <div class="col-lg-3 col-md-6">
          <label class="form-label small fw-bold text-muted text-uppercase">End (Date & Time)</label>
          <input
            id="trackActivityEndAt"
            type="datetime-local"
            name="endAt"
            class="form-control size-md"
            value="<%= stateFilters.endAt || '' %>">
        </div>
        <div class="col-lg-2 d-flex gap-2">
          <button type="submit" class="btn btn-primary btn-filled btn-md w-100">
            <i class="bi bi-play-fill"></i> Run
          </button>
        </div>
        <div class="col-12">
          <label class="form-label small fw-bold text-muted text-uppercase mb-1">Quick Range</label>
          <div id="trackActivityRangeShortcuts" class="ta-range-shortcuts d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-range-shortcut="today">Today</button>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-range-shortcut="yesterday">Yesterday</button>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-range-shortcut="last2">2 Days</button>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-range-shortcut="last3">3 Days</button>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-range-shortcut="last4">4 Days</button>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-range-shortcut="last5">5 Days</button>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-range-shortcut="last6">6 Days</button>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-range-shortcut="weekly">Weekly</button>
          </div>
          <div class="form-text">Shortcuts set Start and End quickly. Click Run to fetch timeline.</div>
        </div>
      </div>

      <div class="mt-3 border rounded-3 overflow-hidden">
        <div class="bg-light d-flex align-items-center justify-content-between py-2 px-3">
          <div class="small fw-bold text-muted text-uppercase">Advanced Filters</div>
          <button
            id="trackActivityAdvancedToggleBtn"
            type="button"
            class="btn btn-outline-secondary btn-sm px-2"
            data-bs-toggle="collapse"
            data-bs-target="#trackActivityAdvancedCollapse"
            aria-expanded="<%= hasAdvancedFilters ? 'true' : 'false' %>"
            aria-controls="trackActivityAdvancedCollapse"
            aria-label="Open advanced filters">
            <i id="trackActivityAdvancedToggleIcon" class="bi <%= hasAdvancedFilters ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
          </button>
        </div>
        <div class="collapse <%= hasAdvancedFilters ? 'show' : '' %>" id="trackActivityAdvancedCollapse">
          <div class="p-3">
            <div class="row g-3">
              <div class="col-lg-3 col-md-4">
                <label class="form-label small fw-bold text-muted text-uppercase">Status</label>
                <input type="text" name="status" class="form-control size-md" placeholder="e.g. success" value="<%= stateFilters.status || '' %>">
              </div>
              <div class="col-lg-9 col-md-8">
                <label class="form-label small fw-bold text-muted text-uppercase">Search</label>
                <input type="text" name="q" class="form-control size-md" placeholder="summary / context / request" value="<%= stateFilters.q || '' %>">
              </div>
              <div class="col-lg-4 col-md-6">
                <label class="form-label small fw-bold text-muted text-uppercase">Section</label>
                <input type="hidden" name="sectionId" id="trackActivitySectionIdsInput" value="<%= selectedSectionIds.join(',') %>">
                <div class="input-group">
                  <input
                    id="trackActivitySectionSummary"
                    type="text"
                    class="form-control size-md"
                    value="<%= selectedSectionRows.length ? (selectedSectionRows.length + ' selected') : '' %>"
                    placeholder="All Sections"
                    readonly>
                  <button id="trackActivityPickSectionBtn" type="button" class="btn btn-outline-primary" title="Pick sections">
                    <i class="bi bi-collection"></i>
                  </button>
                  <button id="trackActivityClearSectionBtn" type="button" class="btn btn-outline-secondary" title="Clear sections">
                    <i class="bi bi-x-lg"></i>
                  </button>
                </div>
                <div id="trackActivitySectionSelectedList" class="ta-filter-list mt-2">
                  <% if (!selectedSectionRows.length) { %>
                    <div class="ta-filter-empty">All Sections</div>
                  <% } else { %>
                    <% selectedSectionRows.forEach((row) => { %>
                      <div class="ta-filter-item d-flex align-items-start justify-content-between gap-2 mb-1">
                        <div class="overflow-hidden">
                          <div class="ta-filter-item-title text-truncate"><%= row.name %></div>
                          <div class="ta-filter-item-id text-truncate"><%= row.id %></div>
                        </div>
                      </div>
                    <% }) %>
                  <% } %>
                </div>
              </div>
              <div class="col-lg-4 col-md-6">
                <label class="form-label small fw-bold text-muted text-uppercase">Operation</label>
                <input type="hidden" name="operationId" id="trackActivityOperationIdsInput" value="<%= selectedOperationIds.join(',') %>">
                <div class="input-group">
                  <input
                    id="trackActivityOperationSummary"
                    type="text"
                    class="form-control size-md"
                    value="<%= selectedOperationRows.length ? (selectedOperationRows.length + ' selected') : '' %>"
                    placeholder="All Operations"
                    readonly>
                  <button id="trackActivityPickOperationBtn" type="button" class="btn btn-outline-primary" title="Pick operations">
                    <i class="bi bi-gear"></i>
                  </button>
                  <button id="trackActivityClearOperationBtn" type="button" class="btn btn-outline-secondary" title="Clear operations">
                    <i class="bi bi-x-lg"></i>
                  </button>
                </div>
                <div id="trackActivityOperationSelectedList" class="ta-filter-list mt-2">
                  <% if (!selectedOperationRows.length) { %>
                    <div class="ta-filter-empty">All Operations</div>
                  <% } else { %>
                    <% selectedOperationRows.forEach((row) => { %>
                      <div class="ta-filter-item d-flex align-items-start justify-content-between gap-2 mb-1">
                        <div class="overflow-hidden">
                          <div class="ta-filter-item-title text-truncate"><%= row.name %></div>
                          <div class="ta-filter-item-id text-truncate"><%= row.id %></div>
                        </div>
                      </div>
                    <% }) %>
                  <% } %>
                </div>
              </div>
              <div class="col-lg-4 col-md-6">
                <label class="form-label small fw-bold text-muted text-uppercase">Organization</label>
                <input type="hidden" name="orgId" id="trackActivityOrgIdsInput" value="<%= selectedOrgIds.join(',') %>">
                <div class="input-group">
                  <input
                    id="trackActivityOrgSummary"
                    type="text"
                    class="form-control size-md"
                    value="<%= selectedOrgRows.length ? (selectedOrgRows.length + ' selected') : '' %>"
                    placeholder="All Organizations"
                    readonly>
                  <button id="trackActivityPickOrgBtn" type="button" class="btn btn-outline-primary" title="Pick organizations">
                    <i class="bi bi-building"></i>
                  </button>
                  <button id="trackActivityClearOrgBtn" type="button" class="btn btn-outline-secondary" title="Clear organizations">
                    <i class="bi bi-x-lg"></i>
                  </button>
                </div>
                <div id="trackActivityOrgSelectedList" class="ta-filter-list mt-2">
                  <% if (!selectedOrgRows.length) { %>
                    <div class="ta-filter-empty">All Organizations</div>
                  <% } else { %>
                    <% selectedOrgRows.forEach((row) => { %>
                      <div class="ta-filter-item d-flex align-items-start justify-content-between gap-2 mb-1">
                        <div class="overflow-hidden">
                          <div class="ta-filter-item-title text-truncate"><%= row.name %></div>
                          <div class="ta-filter-item-id text-truncate"><%= row.id %></div>
                        </div>
                      </div>
                    <% }) %>
                  <% } %>
                </div>
              </div>
            </div>
            <div class="d-flex justify-content-end gap-2 mt-3">
              <a href="/security/track-activity" class="btn btn-outline-secondary btn-md">
                <i class="bi bi-arrow-counterclockwise me-1"></i>Reset
              </a>
              <button type="submit" class="btn btn-primary btn-filled btn-md">
                <i class="bi bi-funnel-fill me-1"></i>Apply
              </button>
            </div>
          </div>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="row g-3 mb-3">
  <div class="col-lg-4 col-md-6">
    <div class="card border-0 shadow-sm p-3 h-100 border-start border-4 border-primary">
      <div class="text-muted small text-uppercase fw-bold">Total Requests</div>
      <div id="taCardRequests" class="fs-4 fw-bold text-dark"><%= Number(summaryData.totalEvents || 0).toLocaleString() %></div>
    </div>
  </div>
  <div class="col-lg-4 col-md-6">
    <div class="card border-0 shadow-sm p-3 h-100 border-start border-4 border-success">
      <div class="text-muted small text-uppercase fw-bold">Attempt-like Requests</div>
      <div id="taCardAttempts" class="fs-4 fw-bold text-dark">0</div>
    </div>
  </div>
  <div class="col-lg-4 col-md-6">
    <div class="card border-0 shadow-sm p-3 h-100 border-start border-4 border-info">
      <div class="text-muted small text-uppercase fw-bold">Busiest Chunk</div>
      <div id="taCardBusiest" class="fs-6 fw-bold text-dark">-</div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm">
  <div class="card-header bg-white d-flex align-items-center justify-content-between">
    <div class="fw-bold text-dark"><i class="bi bi-clock-history me-2"></i>Activity Timeline</div>
    <div id="trackActivityTimelineMeta" class="small text-muted">No timeline data loaded yet.</div>
  </div>
  <div class="card-body">
    <div id="trackActivityTimelineAlert" class="mb-2"></div>
    <div id="trackActivityTimelineLayout" class="ta-timeline-layout">
      <div class="ta-timeline-toolbar">
        <div id="trackActivityTimelineMode" class="ta-timeline-mode">Set filters and click Run to load timeline.</div>
        <div class="ta-timeline-actions">
          <div class="btn-group btn-group-sm ta-view-toggle" role="group" aria-label="Activity timeline view">
            <button id="trackActivityShadeViewBtn" type="button" class="btn btn-primary btn-sm" data-track-activity-view="shade">
              <i class="bi bi-grid-3x3-gap me-1"></i>Shading
            </button>
            <button id="trackActivityLineViewBtn" type="button" class="btn btn-outline-primary btn-sm" data-track-activity-view="line">
              <i class="bi bi-graph-up-arrow me-1"></i>Line Graph
            </button>
          </div>
          <button id="trackActivityTimelineBackBtn" type="button" class="btn btn-outline-secondary btn-sm d-none">
            <i class="bi bi-arrow-left me-1"></i>Back
          </button>
          <button id="trackActivityTimelineResetZoomBtn" type="button" class="btn btn-outline-primary btn-sm d-none">
            <i class="bi bi-diagram-3 me-1"></i>All Days
          </button>
        </div>
      </div>
      <div id="trackActivityTimelineFocusHost" class="d-none"></div>
      <div id="trackActivityTimelineDaysHost"></div>
      <div id="trackActivityLineGraphHost" class="ta-line-graph-host d-none"></div>
      <div id="trackActivityTimelineSummary" class="ta-hour-summary"></div>
    </div>
  </div>
</div>

<div class="modal fade" id="trackActivityChunkModal" tabindex="-1" aria-labelledby="trackActivityChunkModalTitle" aria-hidden="true">
