<%
  const currentStep = wizard.currentStep;
  const isEdit = wizard.isEdit;
  const taskId = task?.id || '';
  const selectedCompetencyAreaIds = Array.isArray(task?.competencyAreaIds) ? task.competencyAreaIds : [];
  const selectedCompetencyIds = Array.isArray(task?.competencyIds) ? task.competencyIds : [];
  const selectedProfileRefs = Array.isArray(task?.profileOfAbilityRefs) ? task.profileOfAbilityRefs : [];
  const selectedIndicatorIds = Array.isArray(task?.indicatorIds) ? task.indicatorIds : [];
  const selectedFeatureIds = Array.isArray(task?.featureOfCommunicationIds) ? task.featureOfCommunicationIds : [];
  const selectedSampleTaskIds = Array.isArray(task?.sampleTaskLabelIds) ? task.sampleTaskLabelIds : [];
  const evidencePlan = task?.evidencePlan || {};
  const criteriaRows = Array.isArray(task?.criteriaForSuccess) ? task.criteriaForSuccess : [];
  const taskConditions = task?.taskConditions || {};
  const step1Draft = task?.extensions?.wizardDraftData?.step1 || {};
  const staleWarningList = Array.isArray(staleWarnings) ? staleWarnings : [];
  const taskTypeLabelMap = {
    assessment: 'Assessment (PBLA Evidence)',
    enabling: 'Enabling (Practice/Preparation)'
  };
  const contextDomainLabelMap = {
    community: 'Community',
    work: 'Work',
    study: 'Study',
    school: 'School',
    daily_life: 'Daily Life'
  };
  const supportLevelLabelMap = {
    independent: 'Independent',
    limited_support: 'Limited Support',
    guided_support: 'Guided Support',
    high_support: 'High Support'
  };
  const collectionMethodLabelMap = {
    teacher_observation_notes: 'Teacher Observation Notes',
    artifact_capture: 'Artifact Capture',
    audio_capture: 'Audio Capture',
    video_capture: 'Video Capture',
    peer_observation: 'Peer Observation',
    self_reflection: 'Self-Reflection'
  };
  const toLabel = (value, mapObj) => mapObj[String(value || '').trim()] || String(value || '').trim();
  const skillLabel = (value) => {
    const raw = String(value || '').trim().replace(/^skill:/, '');
    if (!raw) return '';
    return raw.charAt(0).toUpperCase() + raw.slice(1);
  };
  const shortText = (value, max = 170) => {
    const normalized = String(value || '').trim();
    if (!normalized) return '';
    if (normalized.length <= max) return normalized;
    return `${normalized.slice(0, max - 3)}...`;
  };
  const joinParts = (...parts) => parts.map((entry) => String(entry || '').trim()).filter(Boolean).join(' | ');
  const selectedMethods = Array.isArray(evidencePlan.collectionMethods) ? evidencePlan.collectionMethods : [];
  const additionalMethodRows = selectedMethods.filter((value) => !collectionMethodOptions.includes(value));
  const aiStep1Notes = (currentStep === 1 && Array.isArray(task?.wizardTrace?.step1AutoGeneration?.teacherFacingNotes))
    ? task.wizardTrace.step1AutoGeneration.teacherFacingNotes.map((entry) => String(entry || '').trim()).filter(Boolean)
    : [];
  const aiStep1Compatibility = (currentStep === 1 && task?.wizardTrace?.step1AutoGeneration?.learnerGoalCompatibility && typeof task.wizardTrace.step1AutoGeneration.learnerGoalCompatibility === 'object')
    ? task.wizardTrace.step1AutoGeneration.learnerGoalCompatibility
    : null;
  const aiStep1FieldAssessments = (currentStep === 1 && task?.wizardTrace?.step1AutoGeneration?.fieldAssessments && typeof task.wizardTrace.step1AutoGeneration.fieldAssessments === 'object')
    ? task.wizardTrace.step1AutoGeneration.fieldAssessments
    : {};
  const step1FieldReviewRows = currentStep === 1 ? [
    { key: 'skill', fieldName: 'skill', label: 'Skill', currentValue: task?.skill || step1Draft.skill || '' },
    { key: 'approximateLevel', fieldName: 'approximateLevel', label: 'Approx CLB', currentValue: task?.learnerContext?.approximateLevel || step1Draft.approximateLevel || '' },
    { key: 'clbRange', fieldName: 'clbRange', label: 'CLB Range', currentValue: task?.learnerContext?.clbRange || step1Draft.clbRange || '' },
    { key: 'classContext', fieldName: 'classContext', label: 'Class Context', currentValue: task?.classContext?.summary || step1Draft.classContext || '' },
    { key: 'learnerGoal', fieldName: 'learnerGoal', label: 'Learner Goal', currentValue: task?.learnerContext?.goal || step1Draft.learnerGoal || '' },
    { key: 'realWorldNeed', fieldName: 'realWorldNeed', label: 'Real-World Need', currentValue: task?.learnerContext?.realWorldNeed || step1Draft.realWorldNeed || '' },
    { key: 'taskType', fieldName: 'taskType', label: 'Task Type', currentValue: toLabel(task?.taskType || step1Draft.taskType || '', taskTypeLabelMap) || '' }
  ] : [];
  const aiStep2Trace = ((currentStep === 1 || currentStep === 2) && task?.wizardTrace?.step2AutoGeneration && typeof task.wizardTrace.step2AutoGeneration === 'object')
    ? task.wizardTrace.step2AutoGeneration
    : {};
  const aiStep2IntentReview = ((currentStep === 1 || currentStep === 2) && aiStep2Trace?.intentReview && typeof aiStep2Trace.intentReview === 'object')
    ? aiStep2Trace.intentReview
    : null;
  const aiStep2FieldAssessments = ((currentStep === 1 || currentStep === 2) && aiStep2Trace?.fieldAssessments && typeof aiStep2Trace.fieldAssessments === 'object')
    ? aiStep2Trace.fieldAssessments
    : {};
  const aiStep2Notes = ((currentStep === 1 || currentStep === 2) && Array.isArray(aiStep2Trace?.teacherFacingNotes))
    ? aiStep2Trace.teacherFacingNotes.map((entry) => String(entry || '').trim()).filter(Boolean)
    : [];
  const aiStep2SuggestionRows = (currentStep === 1 || currentStep === 2)
    ? []
        .concat(aiStep2IntentReview?.intentClassification ? [`Intent Classification: ${aiStep2IntentReview.intentClassification}`] : [])
        .concat(aiStep2IntentReview?.confidence ? [`Confidence: ${aiStep2IntentReview.confidence}`] : [])
        .concat(aiStep2IntentReview?.why ? [`Why Suggested: ${aiStep2IntentReview.why}`] : [])
        .concat(Array.isArray(aiStep2IntentReview?.authenticityChecklist)
          ? aiStep2IntentReview.authenticityChecklist.map((entry) => `Authenticity Check: ${entry}`)
          : [])
        .concat(Array.isArray(aiStep2IntentReview?.cautionFlags)
          ? aiStep2IntentReview.cautionFlags.map((entry) => `Caution: ${entry}`)
          : [])
        .concat(aiStep2Notes)
    : [];
  const step2FieldReviewRows = (currentStep === 1 || currentStep === 2) ? [
    { key: 'desiredModality', fieldName: 'desiredModality', label: 'Desired Modality/Output', currentValue: task?.classContext?.desiredModality || task?.taskConditions?.modality || '' },
    { key: 'contextDomain', fieldName: 'contextDomain', label: 'Context Domain', currentValue: task?.classContext?.contextDomain || '' },
    { key: 'authenticityGuidance', fieldName: 'authenticityGuidance', label: 'Authenticity Guidance', currentValue: task?.taskConditions?.authenticityGuidance || '' }
  ] : [];
  const hasStep1ClbMismatch = currentStep === 1 && aiStep1Compatibility?.compatible === false;
  const hasApproxLevelMismatch = currentStep === 1 && (aiStep1FieldAssessments?.approximateLevel?.compatible === false || hasStep1ClbMismatch);
  const hasClbRangeMismatch = currentStep === 1 && (aiStep1FieldAssessments?.clbRange?.compatible === false || hasStep1ClbMismatch);
  const hasLearnerGoalMismatch = currentStep === 1 && (aiStep1FieldAssessments?.learnerGoal?.compatible === false || hasStep1ClbMismatch);
  const stepHelpSpec = {
    1: {
      title: 'Step Purpose',
      summary: 'Define learner context and teacher-selected task type: who this is for, what they need to do in real life, and the target CLB range.',
      tips: [
        'Start from learner need, not benchmark tables.',
        'Keep CLB estimate narrow (for example 1-2 or 2-3).',
        'Describe class context in one concrete sentence.'
      ],
      examples: [
        'Learner Goal: Write a short note to my child’s school.',
        'Real-World Need: Complete a school absence form and note.',
        'Class Context: Morning LINC class focused on school communication.'
      ]
    },
    2: {
      title: 'Step Purpose',
      summary: 'Review intent details from Step 1 and finalize output, domain, and authenticity guidance.',
      tips: [
        'Use teacher-selected task type from Step 1 as the anchor.',
        'Use a real domain (community, work, school, daily life, study).'
      ],
      examples: [
        'Task Type: Assessment',
        'Desired Output: Short written note + simple form',
        'Authenticity: Teacher clarifies procedure only, learner writes independently.'
      ]
    },
    3: {
      title: 'Step Purpose',
      summary: 'Review CLB suggestions and keep scope narrow. One benchmark and only the most relevant competencies.',
      tips: [
        'Usually pick 1 benchmark and 1-2 competencies.',
        'Pick indicators that are directly observable in learner output.',
        'Use sample task labels as models, not exact copies.'
      ],
      examples: [
        'Benchmark: Writing CLB 2',
        'Competencies: Short message + simple form completion',
        'Indicators: Includes key details, purpose is understandable'
      ]
    },
    4: {
      title: 'Step Purpose',
      summary: 'Build the classroom task from the selected CLB mapping.',
      tips: [
        'Write learner instructions in plain classroom language.',
        'Teacher instructions should separate allowed vs disallowed support.',
        'Set realistic time and conditions.'
      ],
      examples: [
        'Scenario: Parent sends absence note to school office.',
        'Support Level: Limited support for assessment tasks.',
        'Materials: Form template, vocabulary support sheet.'
      ]
    },
    5: {
      title: 'Step Purpose',
      summary: 'Define observable evidence, artifacts, and success criteria for assessment.',
      tips: [
        'Evidence must be directly observable or collectible.',
        'Use concise, behavior-based criteria.',
        'Collection methods should match the task modality.'
      ],
      examples: [
        'Observable: Includes key details and clear purpose.',
        'Artifact: Completed form + written note.',
        'Criterion: Message is understandable without teacher rewriting.'
      ]
    },
    6: {
      title: 'Step Purpose',
      summary: 'Final quality check before publish.',
      tips: [
        'Confirm benchmark fit, evidence quality, and criteria clarity.',
        'Resolve validation errors before publishing.',
        'Treat warnings as improvement opportunities before final release.'
      ],
      examples: [
        'One benchmark, focused competencies, observable evidence.',
        'Criteria align with competency + indicators.',
        'Task clearly supports PBLA collection.'
      ]
    }
  };
  const stepHelp = stepHelpSpec[currentStep] || null;
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <h1 class="page-heading size-md m-0">BenchPath Task Wizard (CLB 1-4)</h1>
    <div class="d-flex align-items-center gap-2">
      <% if (taskId) { %><span class="badge bg-light border text-dark">ID: <%= taskId %></span><% } %>
      <span class="badge <%= isEdit ? 'bg-primary' : 'bg-success' %> border"><%= isEdit ? 'Edit / Resume' : 'New Draft' %></span>
    </div>
  </div>

  <div class="form-container" style="width: 100%; max-width: 1400px;">
    <div class="card border-0 shadow-sm mb-3" id="benchpathTaskWizardGuide">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
          <div>
            <div class="fw-bold text-primary">Task Authoring Wizard</div>
            <div class="text-muted">Guided CLB/PBLA-aligned task design with save/resume at every step.</div>
          </div>
          <div class="d-flex align-items-center gap-2">
            <span class="badge bg-light text-dark border">Step <%= currentStep %> of <%= wizard.steps.length %></span>
            <span class="badge bg-primary-subtle text-primary border border-primary-subtle"><%= Math.round((currentStep / wizard.steps.length) * 100) %>%</span>
          </div>
        </div>
        <div class="wizard-progress mb-3"><div class="wizard-progress-bar" style="width: <%= ((currentStep / wizard.steps.length) * 100).toFixed(2) %>%;"></div></div>
        <div class="wizard-step-rail" id="wizardStepRail">
          <% wizard.steps.forEach((step) => { %>
            <% const cls = step.number === currentStep ? 'active' : (step.number < currentStep ? 'completed' : ''); %>
            <% if (wizard.canNavigateWithId) { %>
              <a class="wizard-step-pill <%= cls %>" href="<%= wizard.stepLinks[String(step.number)] %>"><%= step.number %>. <%= step.title %></a>
            <% } else { %>
              <span class="wizard-step-pill <%= cls %> <%= step.number > 1 ? 'disabled' : '' %>"><%= step.number %>. <%= step.title %></span>
            <% } %>
          <% }) %>
        </div>
      </div>
    </div>

    <% if (noticeMessage) { %>
      <div class="alert alert-<%= noticeType === 'error' ? 'danger' : noticeType === 'warning' ? 'warning' : 'success' %> border-0 shadow-sm"><%= noticeMessage %></div>
    <% } %>

    <% if ((staleWarningList || []).length) { %>
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-light fw-bold">Upstream Change Notice</div>
        <div class="card-body small">
          <div class="alert alert-warning mb-0">
            <ul class="mb-0 ps-3">
              <% staleWarningList.forEach((item) => { %><li><%= item %></li><% }) %>
            </ul>
          </div>
        </div>
      </div>
    <% } %>

    <% if ((stepValidation.errors || []).length || (stepValidation.warnings || []).length) { %>
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-light fw-bold">Step Validation</div>
        <div class="card-body small">
          <% if ((stepValidation.errors || []).length) { %>
            <div class="alert alert-danger mb-2"><ul class="mb-0 ps-3"><% stepValidation.errors.forEach((item) => { %><li><%= item %></li><% }) %></ul></div>
          <% } %>
          <% if ((stepValidation.warnings || []).length) { %>
            <div class="alert alert-warning mb-0">
              <details>
                <summary class="fw-semibold">Show Warnings (<%= stepValidation.warnings.length %>)</summary>
                <ul class="mb-0 ps-3 mt-2">
                  <% stepValidation.warnings.forEach((item) => { %><li><%= item %></li><% }) %>
                </ul>
              </details>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>

    <% if (currentStep === 1) { %>
      <div class="card border-0 shadow-sm mb-3" id="aiStep1SuggestionsCard" style="<%= aiStep1Notes.length ? '' : 'display:none;' %>">
        <div class="card-header bg-light fw-bold">AI Suggestions</div>
        <div class="card-body small">
          <details id="aiStep1SuggestionsDetails">
            <summary class="fw-semibold" id="aiStep1SuggestionsSummary">Show AI Suggestions (<%= aiStep1Notes.length %>)</summary>
            <ul class="mb-0 ps-3 mt-2" id="aiStep1SuggestionsList">
              <% aiStep1Notes.forEach((item) => { %><li><%= item %></li><% }) %>
            </ul>
          </details>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-3" id="aiStep1FieldReviewCard" style="<%= Object.keys(aiStep1FieldAssessments || {}).length ? '' : 'display:none;' %>">
        <div class="card-header bg-light fw-bold">AI Field Review</div>
        <div class="card-body small">
          <details id="aiStep1FieldReviewDetails">
            <summary class="fw-semibold" id="aiStep1FieldReviewSummary">Show Field Results (<%= step1FieldReviewRows.length %>)</summary>
            <div class="table-responsive mt-2">
              <table class="table table-sm align-middle mb-0">
                <thead>
                  <tr>
                    <th style="min-width: 130px;">Field</th>
                    <th style="min-width: 160px;">Current Value</th>
                    <th style="min-width: 110px;">Compatibility</th>
                    <th style="min-width: 160px;">Suggested Value</th>
                    <th>Rationale</th>
                    <th style="min-width: 90px;">Apply</th>
                  </tr>
                </thead>
                <tbody id="aiStep1FieldReviewBody">
                  <% step1FieldReviewRows.forEach((row) => { %>
                    <% const baseReview = aiStep1FieldAssessments[row.key] || {}; %>
                    <% const review = (row.key === 'learnerGoal' && (baseReview.compatible === null || baseReview.compatible === undefined) && aiStep1Compatibility)
                      ? { ...baseReview, compatible: aiStep1Compatibility.compatible, rationale: baseReview.rationale || aiStep1Compatibility.rationale, suggestedValue: baseReview.suggestedValue || aiStep1Compatibility.recommendedLearnerGoal }
                      : baseReview; %>
                    <% const compat = (review.compatible === true) ? 'Compatible' : (review.compatible === false ? 'Review' : 'Unknown'); %>
                    <% const compatClass = (review.compatible === true) ? 'bg-success-subtle text-success border border-success-subtle' : (review.compatible === false ? 'bg-danger-subtle text-danger border border-danger-subtle' : 'bg-secondary-subtle text-secondary border border-secondary-subtle'); %>
                    <tr>
                      <td class="fw-semibold"><%= row.label %></td>
                      <td><%= row.currentValue || '-' %></td>
                      <td><span class="badge <%= compatClass %>"><%= compat %></span></td>
                      <td>
                        <% if (review.suggestedValue) { %>
                          <span class="badge bg-info-subtle text-info border border-info-subtle mb-1">Preview</span>
                          <div><%= review.suggestedValue %></div>
                        <% } else { %>
                          <span class="text-muted">-</span>
                        <% } %>
                      </td>
                      <td><%= review.rationale || '-' %></td>
                      <td>
                        <% if (review.suggestedValue) { %>
                          <button type="button" class="btn btn-outline-primary btn-sm apply-ai-field-btn" data-target-field="<%= row.fieldName %>" data-suggested-value="<%= encodeURIComponent(String(review.suggestedValue || '')) %>">Apply</button>
                        <% } else { %>
                          <span class="text-muted">-</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </details>
        </div>
      </div>
    <% } %>

    <% if (currentStep === 1 || currentStep === 2) { %>
      <div class="card border-0 shadow-sm mb-3" id="aiStep2SuggestionsCard" style="<%= aiStep2SuggestionRows.length ? '' : 'display:none;' %>">
        <div class="card-header bg-light fw-bold">AI Suggestions</div>
        <div class="card-body small">
          <details id="aiStep2SuggestionsDetails">
            <summary class="fw-semibold" id="aiStep2SuggestionsSummary">Show AI Suggestions (<%= aiStep2SuggestionRows.length %>)</summary>
            <ul class="mb-0 ps-3 mt-2" id="aiStep2SuggestionsList">
              <% aiStep2SuggestionRows.forEach((item) => { %><li><%= item %></li><% }) %>
            </ul>
          </details>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-3" id="aiStep2FieldReviewCard" style="<%= Object.keys(aiStep2FieldAssessments || {}).length ? '' : 'display:none;' %>">
        <div class="card-header bg-light fw-bold">AI Field Review</div>
        <div class="card-body small">
          <details id="aiStep2FieldReviewDetails">
            <summary class="fw-semibold" id="aiStep2FieldReviewSummary">Show Field Results (<%= step2FieldReviewRows.length %>)</summary>
            <div class="table-responsive mt-2">
              <table class="table table-sm align-middle mb-0">
                <thead>
                  <tr>
                    <th style="min-width: 130px;">Field</th>
                    <th style="min-width: 160px;">Current Value</th>
                    <th style="min-width: 110px;">Compatibility</th>
                    <th style="min-width: 160px;">Suggested Value</th>
                    <th>Rationale</th>
                    <th style="min-width: 90px;">Apply</th>
                  </tr>
                </thead>
                <tbody id="aiStep2FieldReviewBody">
                  <% step2FieldReviewRows.forEach((row) => { %>
                    <% const review = aiStep2FieldAssessments[row.key] || {}; %>
                    <% const compat = (review.compatible === true) ? 'Compatible' : (review.compatible === false ? 'Review' : 'Unknown'); %>
                    <% const compatClass = (review.compatible === true) ? 'bg-success-subtle text-success border border-success-subtle' : (review.compatible === false ? 'bg-danger-subtle text-danger border border-danger-subtle' : 'bg-secondary-subtle text-secondary border border-secondary-subtle'); %>
                    <tr>
                      <td class="fw-semibold"><%= row.label %></td>
                      <td><%= row.currentValue || '-' %></td>
                      <td><span class="badge <%= compatClass %>"><%= compat %></span></td>
                      <td>
                        <% if (review.suggestedValue) { %>
                          <span class="badge bg-info-subtle text-info border border-info-subtle mb-1">Preview</span>
                          <div><%= review.suggestedValue %></div>
                        <% } else { %>
                          <span class="text-muted">-</span>
                        <% } %>
                      </td>
                      <td><%= review.rationale || '-' %></td>
                      <td>
                        <% if (review.suggestedValue) { %>
                          <button type="button" class="btn btn-outline-primary btn-sm apply-ai-field-btn" data-target-field="<%= row.fieldName %>" data-suggested-value="<%= encodeURIComponent(String(review.suggestedValue || '')) %>">Apply</button>
                        <% } else { %>
                          <span class="text-muted">-</span>
                        <% } %>
                      </td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </details>
        </div>
      </div>
    <% } %>

    <% if (stepHelp) { %>
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-light fw-bold"><%= stepHelp.title %></div>
        <div class="card-body">
          <div class="row g-3">
            <div class="col-lg-8">
              <p class="mb-2"><%= stepHelp.summary %></p>
              <ul class="mb-0 ps-3 small">
                <% stepHelp.tips.forEach((tip) => { %>
                  <li><%= tip %></li>
                <% }) %>
              </ul>
            </div>
            <div class="col-lg-4">
              <div class="small text-uppercase fw-bold text-secondary mb-2">Example Values</div>
              <div class="border rounded p-2 bg-light">
                <ul class="mb-0 ps-3 small">
                  <% stepHelp.examples.forEach((example) => { %>
                    <li><%= example %></li>
                  <% }) %>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% } %>

    <form method="POST" action="<%= wizard.postUrl %>" id="benchpathTaskWizardForm">
      <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
      <input type="hidden" name="taskId" value="<%= taskId %>">

      <div class="card border-0 shadow-sm">
        <div class="card-header bg-light fw-bold">Step <%= currentStep %>: <%= wizard.currentMeta.title %></div>
        <div class="card-body">
          <% if (currentStep === 1) { %>
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label fw-bold">Skill *</label>
                <select id="step1_skill" class="form-select <%= fieldErrors.skill ? 'is-invalid' : '' %>" name="skill" required>
                  <option value="">Select skill...</option>
                  <% (skills || []).forEach((skill) => { %>
                    <option value="<%= skill.id %>" <%= (task.skill || step1Draft.skill) === skill.id ? 'selected' : '' %>><%= skill.title %></option>
                  <% }) %>
                </select>
                <div class="form-text">Choose the one primary skill this task is designed to assess or practice.</div>
              </div>
              <div class="col-md-2">
                <label id="step1_label_approximateLevel" class="form-label fw-bold <%= hasApproxLevelMismatch ? 'text-danger' : '' %>">Approx CLB</label>
                <input id="step1_approximateLevel" type="number" min="1" max="4" class="form-control <%= (fieldErrors.approximateLevel || hasApproxLevelMismatch) ? 'is-invalid' : '' %>" name="approximateLevel" value="<%= task?.learnerContext?.approximateLevel || step1Draft.approximateLevel || '' %>" placeholder="1-4">
                <div class="form-text">Best estimate of current skill level.</div>
              </div>
              <div class="col-md-2">
                <label id="step1_label_clbRange" class="form-label fw-bold <%= hasClbRangeMismatch ? 'text-danger' : '' %>">CLB Range</label>
                <input id="step1_clbRange" class="form-control <%= (fieldErrors.clbRange || hasClbRangeMismatch) ? 'is-invalid' : '' %>" name="clbRange" value="<%= task?.learnerContext?.clbRange || step1Draft.clbRange || '' %>" placeholder="e.g. 1-2">
                <div class="form-text">Use a narrow range when level is uncertain.</div>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Class Context *</label>
                <input id="step1_classContext" class="form-control <%= fieldErrors.classContext ? 'is-invalid' : '' %>" name="classContext" value="<%= task?.classContext?.summary || step1Draft.classContext || '' %>" placeholder="Class type, learner profile, current topic" required>
                <div class="form-text">Describe teaching context in one concrete sentence.</div>
              </div>
            </div>
            <div class="row g-3 mt-1">
              <div class="col-md-4">
                <label class="form-label fw-bold">Task Type *</label>
                <select class="form-select <%= fieldErrors.taskType ? 'is-invalid' : '' %>" name="taskType" required>
                  <option value="">Select...</option>
                  <% taskTypeOptions.forEach((opt) => { %>
                    <option value="<%= opt %>" <%= (task.taskType || step1Draft.taskType || '') === opt ? 'selected' : '' %>><%= toLabel(opt, taskTypeLabelMap) %></option>
                  <% }) %>
                </select>
                <div class="form-text">Teacher-selected task type. AI can use this input but does not overwrite it.</div>
              </div>
              <div class="col-md-8">
                <label id="step1_label_learnerGoal" class="form-label fw-bold <%= hasLearnerGoalMismatch ? 'text-danger' : '' %>">Learner Goal *</label>
                <textarea id="step1_learnerGoal" class="form-control <%= (fieldErrors.learnerGoal || hasLearnerGoalMismatch) ? 'is-invalid' : '' %>" name="learnerGoal" rows="3" placeholder="What learner wants to be able to do" required><%= task?.learnerContext?.goal || step1Draft.learnerGoal || '' %></textarea>
                <div class="form-text">Write from learner perspective, for example: "Write a short note to my child’s school."</div>
              </div>
            </div>
            <div class="row g-3 mt-1">
              <div class="col-md-12">
                <div class="d-flex align-items-center justify-content-between mb-1">
                  <label class="form-label fw-bold mb-0">Real-World Need *</label>
                  <button type="submit" name="intent" value="auto_generate_step1_and_2" formnovalidate class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-stars me-1"></i>Auto-Generate Context + Intent
                  </button>
                </div>
                <textarea id="step1_realWorldNeed" class="form-control <%= fieldErrors.realWorldNeed ? 'is-invalid' : '' %>" name="realWorldNeed" rows="3" placeholder="Concrete real-life task and situation" required><%= task?.learnerContext?.realWorldNeed || step1Draft.realWorldNeed || '' %></textarea>
                <div class="form-text">After you fill Step 1 fields, use Auto-Generate to prefill Real-World Need plus Step 2 intent fields.</div>
              </div>
            </div>
          <% } %>

          <% if (currentStep === 2) { %>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-bold">Desired Modality/Output *</label>
                <input class="form-control <%= fieldErrors.desiredModality ? 'is-invalid' : '' %>" name="desiredModality" value="<%= task?.classContext?.desiredModality || '' %>" placeholder="e.g. short written note + simple form" required>
                <div class="form-text">Describe what learner will produce, not just topic.</div>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Context Domain *</label>
                <select class="form-select <%= fieldErrors.contextDomain ? 'is-invalid' : '' %>" name="contextDomain" required>
                  <option value="">Select...</option>
                  <% contextDomainOptions.forEach((opt) => { %>
                    <option value="<%= opt %>" <%= (task?.classContext?.contextDomain || '') === opt ? 'selected' : '' %>><%= toLabel(opt, contextDomainLabelMap) %></option>
                  <% }) %>
                </select>
                <div class="form-text">Choose where this task happens in real life.</div>
              </div>
            </div>
            <div class="mt-3">
              <label class="form-label fw-bold">Authenticity Guidance *</label>
              <textarea class="form-control <%= fieldErrors.authenticityGuidance ? 'is-invalid' : '' %>" name="authenticityGuidance" rows="3" placeholder="Describe realism and allowed support for this task" required><%= task?.taskConditions?.authenticityGuidance || '' %></textarea>
              <div class="form-text">Explain what support is allowed and what is not allowed during performance.</div>
            </div>
          <% } %>
          <% if (currentStep === 3) { %>
            <% const rec = stepThreeData?.recommendationGroups || stepThreeData?.recommendations || null; %>
            <% const recBenchmark = rec?.recommendedBenchmark || rec?.benchmark || null; %>
            <% const recPrimaryArea = rec?.recommendedPrimaryCompetencyArea || null; %>
            <% const recCompetencies = rec?.recommendedCompetencies || rec?.competencies || []; %>
            <% const recIndicators = rec?.recommendedIndicators || rec?.indicators || []; %>
            <% const recFeatures = rec?.recommendedFeatures || rec?.featuresOfCommunication || []; %>
            <% const recSampleTaskLabels = rec?.recommendedSampleTaskLabels || rec?.sampleTaskLabels || []; %>
            <% if (stepThreeData?.recommendationError) { %><div class="alert alert-warning"><%= stepThreeData.recommendationError %></div><% } %>
            <% if (recBenchmark) { %>
              <div class="alert alert-info">
                <div class="fw-bold">Suggested Benchmark: <%= recBenchmark.displayTitle || recBenchmark.title || recBenchmark.id %></div>
                <div class="small text-muted"><%= recBenchmark.id %></div>
                <div class="small text-muted"><%= recBenchmark.whySuggested || '' %></div>
                <% if (recBenchmark?.confidence?.label) { %><div class="small text-muted">Confidence: <%= recBenchmark.confidence.label %> (<%= recBenchmark.confidence.value %>)</div><% } %>
              </div>
            <% } %>

            <% if (rec) { %>
              <div class="card border-0 bg-light mb-3">
                <div class="card-body py-2">
                  <div class="small fw-bold text-uppercase text-secondary mb-1">Narrow Recommendation Pattern</div>
                  <div class="small">
                    <strong>Primary Area:</strong> <%= recPrimaryArea?.displayTitle || recPrimaryArea?.title || recPrimaryArea?.id || '-' %><br>
                    <strong>Competencies:</strong> <%= recCompetencies.map((row) => row.displayTitle || row.title || row.id).join(' | ') || '-' %><br>
                    <strong>Indicators:</strong> <%= recIndicators.map((row) => row.displayTitle || row.title || row.id).join(' | ') || '-' %><br>
                    <strong>Features:</strong> <%= recFeatures.map((row) => row.displayTitle || row.title || row.id).join(' | ') || '-' %><br>
                    <strong>Sample Task Labels:</strong> <%= recSampleTaskLabels.map((row) => row.displayTitle || row.title || row.id).join(' | ') || '-' %>
                  </div>
                </div>
              </div>
            <% } %>

            <% if ((rec?.alternateOptions?.competencies || []).length || (rec?.alternateOptions?.sampleTaskLabels || []).length) { %>
              <div class="card border-0 bg-light mb-3">
                <div class="card-body py-2">
                  <div class="small fw-bold text-uppercase text-secondary mb-1">Alternates (Optional)</div>
                  <% if ((rec?.alternateOptions?.competencies || []).length) { %>
                    <div class="small"><strong>Competency Alternates:</strong> <%= (rec.alternateOptions.competencies || []).map((row) => `${row.displayTitle || row.title || row.id} (${row.whyNotSelected || 'alternate'})`).join(' | ') %></div>
                  <% } %>
                  <% if ((rec?.alternateOptions?.sampleTaskLabels || []).length) { %>
                    <div class="small"><strong>Sample Label Alternates:</strong> <%= (rec.alternateOptions.sampleTaskLabels || []).map((row) => `${row.displayTitle || row.title || row.id} (${row.whyNotSelected || 'alternate'})`).join(' | ') %></div>
                  <% } %>
                </div>
              </div>
            <% } %>

            <% if ((rec?.qualitySafeguards?.warnings || []).length) { %>
              <div class="alert alert-warning">
                <div class="fw-bold mb-1">Recommendation Quality Safeguards</div>
                <ul class="mb-0 ps-3">
                  <% (rec.qualitySafeguards.warnings || []).forEach((w) => { %>
                    <li><%= w %></li>
                  <% }) %>
                </ul>
              </div>
            <% } %>
            <div class="d-flex justify-content-end mb-3"><button type="submit" name="intent" value="regenerate" class="btn btn-outline-primary btn-sm"><i class="bi bi-arrow-repeat me-1"></i>Regenerate Suggestions</button></div>

            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-bold">Selected Benchmark *</label>
                <select class="form-select <%= fieldErrors.selectedBenchmarkId ? 'is-invalid' : '' %>" name="selectedBenchmarkId" required>
                  <option value="">Select benchmark...</option>
                  <% (stepThreeData?.benchmarkOptions || []).forEach((row) => { %>
                    <option value="<%= row.id %>" <%= row.id === task.selectedBenchmarkId ? 'selected' : '' %>><%= row.title || row.id %></option>
                  <% }) %>
                </select>
                <div class="form-text">Choose one benchmark. Keep scope narrow for better assessment quality.</div>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Profile Of Ability</label>
                <div class="border rounded p-2 picker-list">
                  <% (stepThreeData?.profileOptions || []).forEach((row) => { %>
                    <label class="d-flex align-items-start gap-2 mb-2">
                      <input type="checkbox" class="form-check-input mt-1" name="profileOfAbilityRefs" value="<%= row.id %>" <%= selectedProfileRefs.includes(row.id) ? 'checked' : '' %>>
                      <span class="small">
                        <strong><%= row.title || row.id %></strong>
                        <br><span class="text-muted"><%= shortText(row.descriptorSummary || row.description || row.id) %></span>
                        <br><span class="text-muted"><%= row.id %></span>
                      </span>
                    </label>
                  <% }) %>
                </div>
                <div class="form-text">Usually one profile record linked to the selected benchmark.</div>
              </div>
            </div>

            <div class="row g-3 mt-1">
              <div class="col-md-6">
                <label class="form-label fw-bold">Competency Areas</label>
                <div class="border rounded p-2 picker-list">
                  <% (stepThreeData?.competencyAreaOptions || []).forEach((row) => { %>
                    <label class="d-flex align-items-start gap-2 mb-2">
                      <input type="checkbox" class="form-check-input mt-1" name="competencyAreaIds" value="<%= row.id %>" <%= selectedCompetencyAreaIds.includes(row.id) ? 'checked' : '' %>>
                      <span class="small">
                        <strong><%= row.title || row.id %></strong>
                        <br><span class="text-muted"><%= shortText(row.description || row.progressionNotes || row.areaFamilyCode) %></span>
                        <br><span class="text-muted"><%= row.id %></span>
                      </span>
                    </label>
                  <% }) %>
                </div>
                <div class="form-text">Select the areas that directly support this task intent.</div>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Competencies *</label>
                <div class="border rounded p-2 picker-list">
                  <% (stepThreeData?.competencyOptions || []).forEach((row) => { %>
                    <% const recItem = recCompetencies.find((r) => r.id === row.id); %>
                    <% const why = recItem?.whySuggested || ''; %>
                    <label class="d-flex align-items-start gap-2 mb-2">
                      <input type="checkbox" class="form-check-input mt-1" name="competencyIds" value="<%= row.id %>" <%= selectedCompetencyIds.includes(row.id) ? 'checked' : '' %>>
                      <span class="small">
                        <strong><%= row.title || row.id %></strong>
                        <br><span class="text-muted"><%= shortText(row.competencyStatement || row.description) %></span>
                        <br><span class="text-muted"><%= row.id %></span>
                        <% if (why) { %><br><span class="text-primary-emphasis"><%= why %></span><% } %>
                        <% if (recItem?.confidence?.label) { %><br><span class="text-muted">Confidence: <%= recItem.confidence.label %> (<%= recItem.confidence.value %>)</span><% } %>
                      </span>
                    </label>
                  <% }) %>
                </div>
                <div class="form-text">Recommended: pick 1-2 core competencies for a focused task.</div>
              </div>
            </div>

            <div class="row g-3 mt-1">
              <div class="col-md-4">
                <label class="form-label fw-bold">Indicators</label>
                <div class="border rounded p-2 picker-list">
                  <% (stepThreeData?.indicatorOptions || []).forEach((row) => { %>
                    <% const recItem = recIndicators.find((r) => r.id === row.id); %>
                    <% const why = recItem?.whySuggested || ''; %>
                    <label class="d-flex align-items-start gap-2 mb-2">
                      <input type="checkbox" class="form-check-input mt-1" name="indicatorIds" value="<%= row.id %>" <%= selectedIndicatorIds.includes(row.id) ? 'checked' : '' %>>
                      <span class="small">
                        <strong><%= row.title || row.id %></strong>
                        <br><span class="text-muted"><%= shortText(row.indicatorText || row.description) %></span>
                        <br><span class="text-muted"><%= row.id %></span>
                        <% if (why) { %><br><span class="text-primary-emphasis"><%= why %></span><% } %>
                        <% if (recItem?.confidence?.label) { %><br><span class="text-muted">Confidence: <%= recItem.confidence.label %> (<%= recItem.confidence.value %>)</span><% } %>
                      </span>
                    </label>
                  <% }) %>
                </div>
                <div class="form-text">Recommended: select 2-4 observable indicators.</div>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Features Of Communication</label>
                <div class="border rounded p-2 picker-list">
                  <% (stepThreeData?.featureOptions || []).forEach((row) => { %>
                    <% const recItem = recFeatures.find((r) => r.id === row.id); %>
                    <% const why = recItem?.whySuggested || ''; %>
                    <label class="d-flex align-items-start gap-2 mb-2">
                      <input type="checkbox" class="form-check-input mt-1" name="featureOfCommunicationIds" value="<%= row.id %>" <%= selectedFeatureIds.includes(row.id) ? 'checked' : '' %>>
                      <span class="small">
                        <strong><%= row.title || row.id %></strong>
                        <br><span class="text-muted"><%= shortText(joinParts(row.featureDimension, row.featureValue, row.description)) %></span>
                        <br><span class="text-muted"><%= row.id %></span>
                        <% if (why) { %><br><span class="text-primary-emphasis"><%= why %></span><% } %>
                        <% if (recItem?.confidence?.label) { %><br><span class="text-muted">Confidence: <%= recItem.confidence.label %> (<%= recItem.confidence.value %>)</span><% } %>
                      </span>
                    </label>
                  <% }) %>
                </div>
                <div class="form-text">Use only features that matter for this specific task output.</div>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Sample Task Labels</label>
                <div class="border rounded p-2 picker-list">
                  <% (stepThreeData?.sampleTaskOptions || []).forEach((row) => { %>
                    <% const recItem = recSampleTaskLabels.find((r) => r.id === row.id); %>
                    <% const why = recItem?.whySuggested || ''; %>
                    <label class="d-flex align-items-start gap-2 mb-2">
                      <input type="checkbox" class="form-check-input mt-1" name="sampleTaskLabelIds" value="<%= row.id %>" <%= selectedSampleTaskIds.includes(row.id) ? 'checked' : '' %>>
                      <span class="small">
                        <strong><%= row.title || row.id %></strong>
                        <br><span class="text-muted"><%= shortText(row.taskLabelText || row.description || row.contextDomain) %></span>
                        <br><span class="text-muted"><%= row.id %></span>
                        <% if (why) { %><br><span class="text-primary-emphasis"><%= why %></span><% } %>
                        <% if (recItem?.confidence?.label) { %><br><span class="text-muted">Confidence: <%= recItem.confidence.label %> (<%= recItem.confidence.value %>)</span><% } %>
                      </span>
                    </label>
                  <% }) %>
                </div>
                <div class="form-text">Use as model patterns, not copy-paste tasks.</div>
              </div>
            </div>
          <% } %>
          <% if (currentStep === 4) { %>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-bold">Real-World Scenario *</label>
                <textarea class="form-control <%= fieldErrors.realWorldScenario ? 'is-invalid' : '' %>" name="realWorldScenario" rows="3" placeholder="Describe realistic situation, audience, and purpose" required><%= task.realWorldScenario || '' %></textarea>
                <div class="form-text">Example: Parent writes an absence note and completes school form.</div>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Materials / Resources</label>
                <textarea class="form-control" name="materialsResources" rows="3" placeholder="One item per line"><%= (taskConditions.materialsResources || []).join('\n') %></textarea>
                <div class="form-text">List teacher/learner resources used during the task.</div>
              </div>
            </div>
            <div class="row g-3 mt-1">
              <div class="col-md-6">
                <label class="form-label fw-bold">Learner Instructions *</label>
                <textarea class="form-control <%= fieldErrors.learnerInstructions ? 'is-invalid' : '' %>" name="learnerInstructions" rows="4" placeholder="Student-facing directions in plain language" required><%= task.learnerInstructions || '' %></textarea>
                <div class="form-text">Use classroom-friendly wording and clear completion targets.</div>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Teacher Instructions *</label>
                <textarea class="form-control <%= fieldErrors.teacherInstructions ? 'is-invalid' : '' %>" name="teacherInstructions" rows="4" placeholder="Administration + evidence collection instructions" required><%= task.teacherInstructions || '' %></textarea>
                <div class="form-text">Specify what support is allowed and what is not allowed.</div>
              </div>
            </div>
            <div class="row g-3 mt-1">
              <div class="col-md-4">
                <label class="form-label fw-bold">Support Level</label>
                <select class="form-select" name="supportLevel">
                  <% supportLevelOptions.forEach((opt) => { %>
                    <option value="<%= opt %>" <%= (taskConditions.supportLevel || '') === opt ? 'selected' : '' %>><%= toLabel(opt, supportLevelLabelMap) %></option>
                  <% }) %>
                </select>
                <div class="form-text">Assessment tasks usually use limited support.</div>
              </div>
              <div class="col-md-2">
                <label class="form-label fw-bold">Est. Time (min)</label>
                <input type="number" min="1" class="form-control" name="estimatedTimeMinutes" value="<%= taskConditions.estimatedTimeMinutes || 25 %>">
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Task Conditions Notes</label>
                <textarea class="form-control" name="conditionsNotes" rows="2" placeholder="Fairness, constraints, and administration conditions"><%= taskConditions.conditionsNotes || '' %></textarea>
              </div>
            </div>
          <% } %>

          <% if (currentStep === 5) { %>
            <div class="row g-3">
              <div class="col-md-6">
                <label class="form-label fw-bold">Observable Evidence *</label>
                <textarea class="form-control <%= fieldErrors.observableEvidence ? 'is-invalid' : '' %>" name="observableEvidence" rows="4" placeholder="One item per line"><%= (evidencePlan.observableEvidence || []).join('\n') %></textarea>
                <div class="form-text">Write directly observable behaviors or outcomes.</div>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Artifacts</label>
                <textarea class="form-control" name="artifacts" rows="4" placeholder="One item per line"><%= (evidencePlan.artifacts || []).join('\n') %></textarea>
                <div class="form-text">Examples: completed form, short note, checklist, audio clip.</div>
              </div>
            </div>
            <div class="row g-3 mt-1">
              <div class="col-md-6">
                <label class="form-label fw-bold">Collection Methods</label>
                <div class="border rounded p-2">
                  <% collectionMethodOptions.forEach((opt) => { %>
                    <div class="form-check">
                      <input class="form-check-input" type="checkbox" name="collectionMethods" value="<%= opt %>" id="cm_<%= opt %>" <%= selectedMethods.includes(opt) ? 'checked' : '' %>>
                      <label class="form-check-label small" for="cm_<%= opt %>"><%= toLabel(opt, collectionMethodLabelMap) %></label>
                    </div>
                  <% }) %>
                </div>
                <div class="form-text">Select the methods used to capture evidence for this task.</div>
              </div>
              <div class="col-md-6">
                <label class="form-label fw-bold">Additional Methods (optional)</label>
                <textarea class="form-control" name="collectionMethodsText" rows="4" placeholder="One per line"><%= additionalMethodRows.join('\n') %></textarea>
                <div class="form-text">Use this for methods not listed above.</div>
              </div>
            </div>
            <div class="mt-3">
              <label class="form-label fw-bold">Criteria For Success *</label>
              <textarea class="form-control <%= fieldErrors.criteriaForSuccess ? 'is-invalid' : '' %>" name="criteriaForSuccess" rows="5" placeholder="One criterion per line"><%= criteriaRows.map((row) => row?.text || '').filter(Boolean).join('\n') %></textarea>
              <div class="form-text">Keep criteria concise, observable, and aligned to competency/indicator evidence.</div>
            </div>
          <% } %>

          <% if (currentStep === 6) { %>
            <div class="row g-3">
              <div class="col-md-6"><div class="border rounded p-3 h-100 bg-light"><div class="fw-bold mb-2">Task Summary</div><div class="small"><strong>Title:</strong> <%= task.title || '-' %></div><div class="small"><strong>Skill:</strong> <%= skillLabel(task.skill) || '-' %></div><div class="small"><strong>Benchmark:</strong> <%= task.selectedBenchmarkId || '-' %></div><div class="small"><strong>Task Type:</strong> <%= toLabel(task.taskType, taskTypeLabelMap) || '-' %></div><div class="small"><strong>Domain:</strong> <%= toLabel(task?.classContext?.contextDomain, contextDomainLabelMap) || '-' %></div><div class="small"><strong>Support:</strong> <%= toLabel(task?.taskConditions?.supportLevel, supportLevelLabelMap) || '-' %></div><div class="small"><strong>Competencies:</strong> <%= (task.competencyIds || []).length %></div><div class="small"><strong>Indicators:</strong> <%= (task.indicatorIds || []).length %></div><div class="small"><strong>Criteria:</strong> <%= (task.criteriaForSuccess || []).length %></div></div></div>
              <div class="col-md-6"><div class="border rounded p-3 h-100 bg-light"><div class="fw-bold mb-2">Final Validation</div><% if (finalValidation) { %><div class="mb-2"><span class="badge <%= finalValidation.isValid ? 'bg-success' : 'bg-danger' %>"><%= finalValidation.isValid ? 'PASS' : 'HAS ERRORS' %></span></div><% if ((finalValidation.errors || []).length) { %><div class="text-danger small mb-2"><ul class="mb-0 ps-3"><% finalValidation.errors.forEach((item) => { %><li><%= item %></li><% }) %></ul></div><% } %><% if ((finalValidation.warnings || []).length) { %><div class="text-warning-emphasis small"><ul class="mb-0 ps-3"><% finalValidation.warnings.forEach((item) => { %><li><%= item %></li><% }) %></ul></div><% } %><% } else { %><div class="small text-muted">Validation summary will be generated when this step is loaded.</div><% } %></div></div>
            </div>
          <% } %>
        </div>
      </div>

      <div class="wizard-controls d-flex justify-content-between align-items-center flex-wrap gap-2 mt-3">
        <div class="wizard-step-label"><strong>Current:</strong> Step <%= currentStep %> - <%= wizard.currentMeta.title %></div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <% if (currentStep > 1) { %><button type="submit" name="intent" value="previous" formnovalidate class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Save & Previous</button><% } %>
          <button type="submit" name="intent" value="save" class="btn btn-outline-primary btn-sm"><i class="bi bi-save me-1"></i>Save Draft</button>
          <% if (currentStep < wizard.steps.length) { %>
            <button type="submit" name="intent" value="next" class="btn btn-primary btn-sm">Save & Next<i class="bi bi-arrow-right ms-1"></i></button>
          <% } else { %>
            <button type="submit" name="intent" value="publish" class="btn btn-success btn-sm"><i class="bi bi-check2-circle me-1"></i>Publish Task</button>
          <% } %>
        </div>
      </div>
    </form>

    <hr>
    <div class="button-row d-flex justify-content-end">
      <a href="/benchpath/tasks" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction" data-return-url="/benchpath/tasks">Cancel</a>
    </div>
  </div>
</div>
<div id="wizardBusyOverlay" class="wizard-busy-overlay" aria-hidden="true">
  <div class="wizard-busy-modal card border-0 shadow">
    <div class="card-body d-flex align-items-center gap-3">
      <div class="spinner-border text-primary" role="status" aria-label="Loading"></div>
      <div>
        <div class="fw-semibold">Please wait</div>
        <div class="text-muted small">Auto-Generation is running. Do not close this page.</div>
      </div>
    </div>
  </div>
</div>
<style>
  .wizard-step-rail { display: flex; gap: 0.5rem; flex-wrap: nowrap; overflow-x: auto; padding-bottom: 0.25rem; scrollbar-width: none; }
  .wizard-step-rail::-webkit-scrollbar { display: none; }
  .wizard-step-pill { flex: 0 0 auto; white-space: nowrap; border: 1px solid #c8d1dc; background: #f8fafc; color: #17324d; font-weight: 600; font-size: 1rem; border-radius: 999px; padding: 0.35rem 0.8rem; text-decoration: none; }
  .wizard-step-pill.active { background: #17324d; color: #fff; border-color: #17324d; }
  .wizard-step-pill.completed { background: #e8f5ee; border-color: #95d5b2; color: #1b6f4a; }
  .wizard-step-pill.disabled { opacity: 0.65; }
  .wizard-progress { height: 0.35rem; background: #e8edf3; border-radius: 999px; overflow: hidden; }
  .wizard-progress-bar { height: 100%; background: linear-gradient(90deg, #17324d 0%, #2f5d8a 100%); transition: width 0.25s ease; }
  .wizard-controls { background: #f8fafc; border: 1px solid #d5dee8; border-radius: 0.75rem; font-size: 1rem; padding: 0.75rem 1rem; }
  .picker-list { max-height: 220px; overflow: auto; }
  .wizard-busy-overlay {
    position: fixed;
    inset: 0;
    background: rgba(8, 18, 35, 0.42);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 1080;
    padding: 1rem;
  }
  .wizard-busy-overlay.active { display: flex; }
  .wizard-busy-modal { width: min(92vw, 460px); border-radius: 0.9rem; }
</style>

<script src="/scripts/wizardStepRail.js"></script>
<script>
  document.addEventListener('DOMContentLoaded', function () {
    const rail = document.getElementById('wizardStepRail');
    if (window.WizardStepRail && rail) window.WizardStepRail.sync(rail);
    const form = document.getElementById('benchpathTaskWizardForm');
    const busyOverlay = document.getElementById('wizardBusyOverlay');
    let lastIntent = '';
    const step1FieldRows = [
      { key: 'skill', fieldName: 'skill', label: 'Skill' },
      { key: 'approximateLevel', fieldName: 'approximateLevel', label: 'Approx CLB' },
      { key: 'clbRange', fieldName: 'clbRange', label: 'CLB Range' },
      { key: 'classContext', fieldName: 'classContext', label: 'Class Context' },
      { key: 'learnerGoal', fieldName: 'learnerGoal', label: 'Learner Goal' },
      { key: 'realWorldNeed', fieldName: 'realWorldNeed', label: 'Real-World Need' },
      { key: 'taskType', fieldName: 'taskType', label: 'Task Type' }
    ];
    const step2FieldRows = [
      { key: 'desiredModality', fieldName: 'desiredModality', label: 'Desired Modality/Output' },
      { key: 'contextDomain', fieldName: 'contextDomain', label: 'Context Domain' },
      { key: 'authenticityGuidance', fieldName: 'authenticityGuidance', label: 'Authenticity Guidance' }
    ];

    function escapeHtml(text) {
      return String(text || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function showWizardMessage(message, type) {
      if (!message) return;
      if (typeof window.showMessageModal === 'function') {
        const icon = type === 'error' ? 'error' : (type === 'warning' ? 'warning' : 'success');
        window.showMessageModal({
          title: 'BenchPath Wizard',
          message,
          icon,
          buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : icon === 'warning' ? 'btn-warning' : 'btn-success' }]
        });
      }
    }

    function applySuggestedValueToField(fieldName, suggestedValue) {
      if (!form) return;
      const target = form.querySelector(`[name="${fieldName}"]`);
      if (!target) return;

      if (target.tagName === 'SELECT') {
        const normalized = String(suggestedValue || '').trim().toLowerCase();
        const direct = Array.from(target.options).find((opt) => String(opt.value || '').trim().toLowerCase() === normalized);
        const skillPrefix = Array.from(target.options).find((opt) => String(opt.value || '').trim().toLowerCase() === `skill:${normalized}`.toLowerCase());
        const byLabel = Array.from(target.options).find((opt) => String(opt.text || '').trim().toLowerCase() === normalized);
        const matched = direct || skillPrefix || byLabel;
        if (matched) target.value = matched.value;
      } else {
        target.value = suggestedValue;
      }

      target.dispatchEvent(new Event('input', { bubbles: true }));
      target.dispatchEvent(new Event('change', { bubbles: true }));
      target.focus();
    }

    function updateStep1MismatchStyles(fieldAssessments, compatibility) {
      const assess = fieldAssessments && typeof fieldAssessments === 'object' ? fieldAssessments : {};
      const hasGlobalMismatch = compatibility && compatibility.compatible === false;
      const approxMismatch = (assess.approximateLevel && assess.approximateLevel.compatible === false) || hasGlobalMismatch;
      const rangeMismatch = (assess.clbRange && assess.clbRange.compatible === false) || hasGlobalMismatch;
      const goalMismatch = (assess.learnerGoal && assess.learnerGoal.compatible === false) || hasGlobalMismatch;

      const approxInput = document.getElementById('step1_approximateLevel');
      const rangeInput = document.getElementById('step1_clbRange');
      const goalInput = document.getElementById('step1_learnerGoal');
      const approxLabel = document.getElementById('step1_label_approximateLevel');
      const rangeLabel = document.getElementById('step1_label_clbRange');
      const goalLabel = document.getElementById('step1_label_learnerGoal');

      if (approxInput) approxInput.classList.toggle('is-invalid', Boolean(approxMismatch));
      if (rangeInput) rangeInput.classList.toggle('is-invalid', Boolean(rangeMismatch));
      if (goalInput) goalInput.classList.toggle('is-invalid', Boolean(goalMismatch));
      if (approxLabel) approxLabel.classList.toggle('text-danger', Boolean(approxMismatch));
      if (rangeLabel) rangeLabel.classList.toggle('text-danger', Boolean(rangeMismatch));
      if (goalLabel) goalLabel.classList.toggle('text-danger', Boolean(goalMismatch));
    }

    function renderStep1Suggestions(notes) {
      const card = document.getElementById('aiStep1SuggestionsCard');
      const summary = document.getElementById('aiStep1SuggestionsSummary');
      const list = document.getElementById('aiStep1SuggestionsList');
      const rows = Array.isArray(notes) ? notes.filter((item) => String(item || '').trim()) : [];

      if (!card || !summary || !list) return;
      if (!rows.length) {
        card.style.display = 'none';
        list.innerHTML = '';
        summary.textContent = 'Show AI Suggestions (0)';
        return;
      }

      card.style.display = '';
      summary.textContent = `Show AI Suggestions (${rows.length})`;
      list.innerHTML = rows.map((item) => `<li>${escapeHtml(item)}</li>`).join('');
    }

    function buildStep2SuggestionRows(intentReview, notes) {
      const review = intentReview && typeof intentReview === 'object' ? intentReview : {};
      const list = []
        .concat(review.intentClassification ? [`Intent Classification: ${review.intentClassification}`] : [])
        .concat(review.confidence ? [`Confidence: ${review.confidence}`] : [])
        .concat(review.why ? [`Why Suggested: ${review.why}`] : [])
        .concat(Array.isArray(review.authenticityChecklist)
          ? review.authenticityChecklist
            .map((entry) => String(entry || '').trim())
            .filter(Boolean)
            .map((entry) => `Authenticity Check: ${entry}`)
          : [])
        .concat(Array.isArray(review.cautionFlags)
          ? review.cautionFlags
            .map((entry) => String(entry || '').trim())
            .filter(Boolean)
            .map((entry) => `Caution: ${entry}`)
          : [])
        .concat(Array.isArray(notes) ? notes.map((entry) => String(entry || '').trim()).filter(Boolean) : []);
      return list.filter(Boolean);
    }

    function renderStep2Suggestions(intentReview, notes) {
      const card = document.getElementById('aiStep2SuggestionsCard');
      const summary = document.getElementById('aiStep2SuggestionsSummary');
      const list = document.getElementById('aiStep2SuggestionsList');
      const rows = buildStep2SuggestionRows(intentReview, notes);
      if (!card || !summary || !list) return;

      if (!rows.length) {
        card.style.display = 'none';
        list.innerHTML = '';
        summary.textContent = 'Show AI Suggestions (0)';
        return;
      }

      card.style.display = '';
      summary.textContent = `Show AI Suggestions (${rows.length})`;
      list.innerHTML = rows.map((item) => `<li>${escapeHtml(item)}</li>`).join('');
    }

    function renderStep1FieldReview(fieldAssessments, compatibility) {
      const card = document.getElementById('aiStep1FieldReviewCard');
      const summary = document.getElementById('aiStep1FieldReviewSummary');
      const body = document.getElementById('aiStep1FieldReviewBody');
      if (!card || !summary || !body) return;

      const assess = fieldAssessments && typeof fieldAssessments === 'object' ? fieldAssessments : {};
      const hasAny = Object.keys(assess).length > 0 || (compatibility && compatibility.compatible !== undefined && compatibility.compatible !== null);
      if (!hasAny) {
        card.style.display = 'none';
        body.innerHTML = '';
        summary.textContent = 'Show Field Results (0)';
        return;
      }

      const compatClass = (compatible) => {
        if (compatible === true) return 'bg-success-subtle text-success border border-success-subtle';
        if (compatible === false) return 'bg-danger-subtle text-danger border border-danger-subtle';
        return 'bg-secondary-subtle text-secondary border border-secondary-subtle';
      };
      const compatLabel = (compatible) => {
        if (compatible === true) return 'Compatible';
        if (compatible === false) return 'Review';
        return 'Unknown';
      };

      const rowHtml = step1FieldRows.map((row) => {
        const baseReview = assess[row.key] || {};
        const review = (row.key === 'learnerGoal' && (baseReview.compatible === null || baseReview.compatible === undefined) && compatibility)
          ? { ...baseReview, compatible: compatibility.compatible, rationale: baseReview.rationale || compatibility.rationale, suggestedValue: baseReview.suggestedValue || compatibility.recommendedLearnerGoal }
          : baseReview;
        const currentField = form ? form.querySelector(`[name="${row.fieldName}"]`) : null;
        const currentValue = currentField ? String(currentField.value || '').trim() : '';
        const suggested = String(review.suggestedValue || '').trim();
        const rationale = String(review.rationale || '').trim();
        const applyCell = suggested
          ? `<button type="button" class="btn btn-outline-primary btn-sm apply-ai-field-btn" data-target-field="${escapeHtml(row.fieldName)}" data-suggested-value="${encodeURIComponent(suggested)}">Apply</button>`
          : '<span class="text-muted">-</span>';
        const suggestedCell = suggested
          ? `<span class="badge bg-info-subtle text-info border border-info-subtle mb-1">Preview</span><div>${escapeHtml(suggested)}</div>`
          : '<span class="text-muted">-</span>';

        return `<tr>
          <td class="fw-semibold">${escapeHtml(row.label)}</td>
          <td>${escapeHtml(currentValue || '-')}</td>
          <td><span class="badge ${compatClass(review.compatible)}">${compatLabel(review.compatible)}</span></td>
          <td>${suggestedCell}</td>
          <td>${escapeHtml(rationale || '-')}</td>
          <td>${applyCell}</td>
        </tr>`;
      }).join('');

      card.style.display = '';
      summary.textContent = `Show Field Results (${step1FieldRows.length})`;
      body.innerHTML = rowHtml;
    }

    function renderStep2FieldReview(fieldAssessments) {
      const card = document.getElementById('aiStep2FieldReviewCard');
      const summary = document.getElementById('aiStep2FieldReviewSummary');
      const body = document.getElementById('aiStep2FieldReviewBody');
      if (!card || !summary || !body) return;

      const assess = fieldAssessments && typeof fieldAssessments === 'object' ? fieldAssessments : {};
      const hasAny = Object.keys(assess).length > 0;
      if (!hasAny) {
        card.style.display = 'none';
        body.innerHTML = '';
        summary.textContent = 'Show Field Results (0)';
        return;
      }

      const compatClass = (compatible) => {
        if (compatible === true) return 'bg-success-subtle text-success border border-success-subtle';
        if (compatible === false) return 'bg-danger-subtle text-danger border border-danger-subtle';
        return 'bg-secondary-subtle text-secondary border border-secondary-subtle';
      };
      const compatLabel = (compatible) => {
        if (compatible === true) return 'Compatible';
        if (compatible === false) return 'Review';
        return 'Unknown';
      };

      const rowHtml = step2FieldRows.map((row) => {
        const review = assess[row.key] || {};
        const currentField = form ? form.querySelector(`[name="${row.fieldName}"]`) : null;
        const currentValue = currentField ? String(currentField.value || '').trim() : '';
        const suggested = String(review.suggestedValue || '').trim();
        const rationale = String(review.rationale || '').trim();
        const allowApply = row.fieldName !== 'taskType';
        const applyCell = (suggested && allowApply)
          ? `<button type="button" class="btn btn-outline-primary btn-sm apply-ai-field-btn" data-target-field="${escapeHtml(row.fieldName)}" data-suggested-value="${encodeURIComponent(suggested)}">Apply</button>`
          : '<span class="text-muted">-</span>';
        const suggestedCell = suggested
          ? `<span class="badge bg-info-subtle text-info border border-info-subtle mb-1">Preview</span><div>${escapeHtml(suggested)}</div>`
          : '<span class="text-muted">-</span>';

        return `<tr>
          <td class="fw-semibold">${escapeHtml(row.label)}</td>
          <td>${escapeHtml(currentValue || '-')}</td>
          <td><span class="badge ${compatClass(review.compatible)}">${compatLabel(review.compatible)}</span></td>
          <td>${suggestedCell}</td>
          <td>${escapeHtml(rationale || '-')}</td>
          <td>${applyCell}</td>
        </tr>`;
      }).join('');

      card.style.display = '';
      summary.textContent = `Show Field Results (${step2FieldRows.length})`;
      body.innerHTML = rowHtml;
    }

    if (form) {
      form.querySelectorAll('button[name="intent"]').forEach((btn) => {
        btn.addEventListener('click', function () {
          lastIntent = String(this.value || '').toLowerCase();
        });
      });

      document.addEventListener('click', function (event) {
        const btn = event.target.closest('.apply-ai-field-btn');
        if (!btn) return;
        const fieldName = String(btn.dataset.targetField || '').trim();
        const rawSuggested = String(btn.dataset.suggestedValue || '').trim();
        let suggestedValue = rawSuggested;
        if (rawSuggested) {
          try {
            suggestedValue = decodeURIComponent(rawSuggested);
          } catch (_) {
            suggestedValue = rawSuggested;
          }
        }
        if (!suggestedValue) {
          const row = btn.closest('tr');
          const suggestedCell = row ? row.children[3] : null;
          const fallbackText = suggestedCell
            ? String(suggestedCell.textContent || '').replace(/\bPreview\b/i, '').trim()
            : '';
          suggestedValue = fallbackText;
        }
        if (!fieldName || !suggestedValue) return;
        applySuggestedValueToField(fieldName, suggestedValue);
      });

      form.addEventListener('submit', function (event) {
        const submitter = event.submitter;
        const submitIntent = (submitter && submitter.name === 'intent'
          ? String(submitter.value || '').toLowerCase()
          : lastIntent);

        if (submitIntent === 'auto_generate_step1_and_2' || submitIntent === 'auto_generate' || submitIntent === 'auto_generate_step2') {
          event.preventDefault();
          if (busyOverlay) busyOverlay.classList.add('active');
          const formData = new FormData(form);
          formData.set('intent', submitIntent);
          const encodedBody = new URLSearchParams();
          formData.forEach((value, key) => {
            encodedBody.append(key, value == null ? '' : String(value));
          });

          fetch(form.action, {
            method: 'POST',
            headers: {
              'X-AJAX-Request': 'true',
              'X-Requested-With': 'XMLHttpRequest',
              Accept: 'application/json',
              'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
            },
            body: encodedBody.toString()
          })
            .then(async (response) => {
              let payload;
              try {
                payload = await response.json();
              } catch (_) {
                payload = { status: 'error', message: `Auto-Generation failed with status ${response.status}.` };
              }
              if (!response.ok || payload.status !== 'success') {
                const error = new Error(payload.message || 'Auto-Generation failed.');
                error.payload = payload;
                throw error;
              }
              return payload;
            })
            .then((result) => {
              const payload = result.payload || {};
              if (payload.fields) {
                if (submitIntent === 'auto_generate_step1_and_2' || submitIntent === 'auto_generate') {
                  if (payload.fields.skill) applySuggestedValueToField('skill', payload.fields.skill);
                  if (payload.fields.approximateLevel) applySuggestedValueToField('approximateLevel', payload.fields.approximateLevel);
                  if (payload.fields.clbRange) applySuggestedValueToField('clbRange', payload.fields.clbRange);
                  if (payload.fields.classContext) applySuggestedValueToField('classContext', payload.fields.classContext);
                  if (payload.fields.learnerGoal) applySuggestedValueToField('learnerGoal', payload.fields.learnerGoal);
                  if (payload.fields.realWorldNeed) applySuggestedValueToField('realWorldNeed', payload.fields.realWorldNeed);
                  if (payload.fields.desiredModality) applySuggestedValueToField('desiredModality', payload.fields.desiredModality);
                  if (payload.fields.contextDomain) applySuggestedValueToField('contextDomain', payload.fields.contextDomain);
                  if (payload.fields.authenticityGuidance) applySuggestedValueToField('authenticityGuidance', payload.fields.authenticityGuidance);
                } else if (submitIntent === 'auto_generate_step2') {
                  if (payload.fields.desiredModality) applySuggestedValueToField('desiredModality', payload.fields.desiredModality);
                  if (payload.fields.contextDomain) applySuggestedValueToField('contextDomain', payload.fields.contextDomain);
                  if (payload.fields.authenticityGuidance) applySuggestedValueToField('authenticityGuidance', payload.fields.authenticityGuidance);
                }
              }
              const taskIdInput = form.querySelector('input[name="taskId"]');
              if (taskIdInput && payload.draftId) taskIdInput.value = payload.draftId;

              if (submitIntent === 'auto_generate_step1_and_2' || submitIntent === 'auto_generate') {
                renderStep1Suggestions(payload.teacherFacingNotes || []);
                renderStep1FieldReview(payload.fieldAssessments || {}, payload.compatibility || null);
                updateStep1MismatchStyles(payload.fieldAssessments || {}, payload.compatibility || null);
                renderStep2Suggestions(payload.intentReview || null, payload.teacherFacingNotes || []);
                renderStep2FieldReview(payload.step2FieldAssessments || {});
              } else if (submitIntent === 'auto_generate_step2') {
                renderStep2Suggestions(payload.intentReview || null, payload.teacherFacingNotes || []);
                renderStep2FieldReview(payload.fieldAssessments || {});
              }
              showWizardMessage(result.message || 'Auto-Generation completed.', 'success');
            })
            .catch((error) => {
              const message = error?.payload?.message || error.message || 'Auto-Generation failed.';
              showWizardMessage(message, 'error');
            })
            .finally(() => {
              if (busyOverlay) busyOverlay.classList.remove('active');
            });
        }
      });
    }

    const noticeMessage = '<%- (noticeMessage || "").replace(/'/g, "\\'") %>';
    const noticeType = '<%- (noticeType || "success").replace(/'/g, "\\'") %>';
    if (noticeMessage && typeof window.showMessageModal === 'function') {
      const icon = noticeType === 'error' ? 'error' : (noticeType === 'warning' ? 'warning' : 'success');
      window.showMessageModal({
        title: 'BenchPath Wizard',
        message: noticeMessage,
        icon,
        buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : icon === 'warning' ? 'btn-warning' : 'btn-success' }]
      });
    }
  });
</script>
