<%
  const isEdit = !!(skillData && skillData.id);
  const formAction = isEdit ? `/benchpath/clb-skills/edit/${skillData.id}` : '/benchpath/clb-skills/new';
  const selectedEvidenceModes = Array.isArray(skillData?.assessmentCharacteristics?.primaryEvidenceModes) ? skillData.assessmentCharacteristics.primaryEvidenceModes : [];
  const selectedStageIds = Array.isArray(skillData?.stageIds) ? skillData.stageIds : [];
  const selectedFrameworkId = skillData?.frameworkId || (frameworks && frameworks[0] ? frameworks[0].id : 'framework:clb');
  const benchmarkRange = skillData?.supportedBenchmarkRange || { minimum: 1, maximum: 12, totalCount: 12 };
  const benchmarkIds = Array.isArray(skillData?.benchmarkIds) ? skillData.benchmarkIds.filter((v) => String(v || '').trim()) : [];
  const competencyAreaIds = Array.isArray(skillData?.competencyAreaIds) ? skillData.competencyAreaIds.filter((v) => String(v || '').trim()) : [];
  const sourceRefs = Array.isArray(skillData?.sourceRefs) ? skillData.sourceRefs : [];
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <h1 class="page-heading size-md m-0"><%= isEdit ? 'Edit CLB Skill' : 'Create CLB Skill' %></h1>
    <div class="d-flex align-items-center gap-2">
      <% if (isEdit) { %><span class="badge bg-primary border">ID: <%= skillData.id %></span><% } else { %><span class="badge bg-success border">New Item</span><% } %>
    </div>
  </div>

  <div class="form-container" style="width: 100%; max-width: 1400px;">
    <form id="skillForm" method="POST" action="<%= formAction %>">
      <input type="hidden" name="actionStateId" value="<%= typeof actionStateId !== 'undefined' ? actionStateId : '' %>">
      <input type="hidden" name="supportedBenchmarkRange" id="supportedBenchmarkRangeInput">
      <input type="hidden" name="sourceRefs" id="sourceRefsInput">

      <ul class="nav nav-tabs mb-3" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#core-pane" type="button">Core</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#assessment-pane" type="button">Assessment & Teaching</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#structure-pane" type="button">Structure</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#refs-pane" type="button">Source Refs</button></li>
      </ul>

      <div class="tab-content border border-top-0 rounded-bottom p-3 bg-white shadow-sm">
        <div class="tab-pane fade show active" id="core-pane">
          <div class="row g-2">
            <div class="col-md-6 mb-3"><label class="form-label fw-bold">ID *</label><input class="form-control" name="id" value="<%= skillData?.id || '' %>" <%= isEdit ? 'readonly' : '' %> required></div>
            <div class="col-md-3 mb-3"><label class="form-label fw-bold">Slug *</label><input class="form-control" name="slug" value="<%= skillData?.slug || '' %>" required></div>
            <div class="col-md-3 mb-3"><label class="form-label fw-bold">Code *</label><input class="form-control" name="code" value="<%= skillData?.code || '' %>" required></div>
          </div>
          <div class="mb-3"><label class="form-label fw-bold">Title *</label><input class="form-control" name="title" value="<%= skillData?.title || '' %>" required></div>
          <div class="row g-2">
            <div class="col-md-4 mb-3"><label class="form-label">Short Title</label><input class="form-control" name="shortTitle" value="<%= skillData?.shortTitle || '' %>"></div>
            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">Framework *</label>
              <div class="input-group">
                <select class="form-select" name="frameworkId" id="frameworkIdSelect" required>
                  <option value="">Select framework...</option>
                  <% (frameworks || []).forEach((fw) => { %>
                    <option value="<%= fw.id %>" <%= (skillData?.frameworkId || 'framework:clb') === fw.id ? 'selected' : '' %>><%= fw.title %> (<%= fw.id %>)</option>
                  <% }) %>
                </select>
                <button type="button" class="btn btn-outline-primary" id="pickFrameworkBtn" title="Pick framework">
                  <i class="bi bi-search"></i>
                </button>
              </div>
            </div>
            <div class="col-md-4 mb-3"><label class="form-label">Framework Code</label><input class="form-control" name="frameworkCode" value="<%= skillData?.frameworkCode || 'CLB' %>"></div>
          </div>
          <div class="row g-2">
            <div class="col-md-4 mb-3"><label class="form-label fw-bold">Modality *</label><select class="form-select" name="modality" required><option value="">Select...</option><% modalityOptions.forEach((opt)=>{ %><option value="<%= opt %>" <%= skillData?.modality===opt?'selected':'' %>><%= opt %></option><% }) %></select></div>
            <div class="col-md-4 mb-3"><label class="form-label fw-bold">Display Order *</label><input type="number" min="1" class="form-control" name="displayOrder" value="<%= skillData?.displayOrder || '' %>" required></div>
            <div class="col-md-4 mb-3"><label class="form-label fw-bold">Status *</label><select class="form-select" name="status" required><option value="">Select...</option><% statusOptions.forEach((opt)=>{ %><option value="<%= opt %>" <%= skillData?.status===opt?'selected':'' %>><%= opt %></option><% }) %></select></div>
          </div>
          <div class="mb-3"><label class="form-label fw-bold">Review Status *</label><select class="form-select" name="reviewStatus" required><option value="">Select...</option><% reviewStatusOptions.forEach((opt)=>{ %><option value="<%= opt %>" <%= skillData?.reviewStatus===opt?'selected':'' %>><%= opt %></option><% }) %></select></div>
          <div class="mb-3"><label class="form-label">Description</label><textarea class="form-control" name="description" rows="2"><%= skillData?.description || '' %></textarea></div>
        </div>

        <div class="tab-pane fade" id="assessment-pane">
          <div class="mb-3">
            <label class="form-label fw-bold">Primary Evidence Modes *</label>
            <div class="row g-2 border rounded p-2">
              <% evidenceModeOptions.forEach((opt)=>{ %>
                <div class="col-md-4">
                  <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="ev_<%= opt %>" name="primaryEvidenceModes" value="<%= opt %>" <%= selectedEvidenceModes.includes(opt)?'checked':'' %>>
                    <label class="form-check-label small" for="ev_<%= opt %>"><%= opt %></label>
                  </div>
                </div>
              <% }) %>
            </div>
          </div>
          <div class="mb-3"><label class="form-label fw-bold">Default Assessment Approach *</label><select class="form-select" name="defaultAssessmentApproach" required><option value="">Select...</option><% assessmentApproachOptions.forEach((opt)=>{ %><option value="<%= opt %>" <%= skillData?.assessmentCharacteristics?.defaultAssessmentApproach===opt?'selected':'' %>><%= opt %></option><% }) %></select></div>

          <div class="d-flex gap-4 mb-3 flex-wrap">
            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="supportsPortfolioEvidence" name="supportsPortfolioEvidence" value="true" <%= skillData?.assessmentCharacteristics?.supportsPortfolioEvidence ? 'checked' : '' %>><label class="form-check-label fw-bold" for="supportsPortfolioEvidence">supportsPortfolioEvidence</label></div>
            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="supportsDeterministicChecks" name="supportsDeterministicChecks" value="true" <%= skillData?.assessmentCharacteristics?.supportsDeterministicChecks ? 'checked' : '' %>><label class="form-check-label fw-bold" for="supportsDeterministicChecks">supportsDeterministicChecks</label></div>
            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="supportsAiAssistance" name="supportsAiAssistance" value="true" <%= skillData?.assessmentCharacteristics?.supportsAiAssistance ? 'checked' : '' %>><label class="form-check-label fw-bold" for="supportsAiAssistance">supportsAiAssistance</label></div>
          </div>

          <div class="d-flex gap-4 flex-wrap">
            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="taskBased" name="taskBased" value="true" <%= skillData?.teachingCharacteristics?.taskBased ? 'checked' : '' %>><label class="form-check-label fw-bold" for="taskBased">taskBased</label></div>
            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="realWorldOriented" name="realWorldOriented" value="true" <%= skillData?.teachingCharacteristics?.realWorldOriented ? 'checked' : '' %>><label class="form-check-label fw-bold" for="realWorldOriented">realWorldOriented</label></div>
            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="oftenIntegratedWithOtherSkills" name="oftenIntegratedWithOtherSkills" value="true" <%= skillData?.teachingCharacteristics?.oftenIntegratedWithOtherSkills ? 'checked' : '' %>><label class="form-check-label fw-bold" for="oftenIntegratedWithOtherSkills">oftenIntegratedWithOtherSkills</label></div>
            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="canUseVisualSupport" name="canUseVisualSupport" value="true" <%= skillData?.teachingCharacteristics?.canUseVisualSupport ? 'checked' : '' %>><label class="form-check-label fw-bold" for="canUseVisualSupport">canUseVisualSupport</label></div>
          </div>
        </div>

        <div class="tab-pane fade" id="structure-pane">
          <label class="form-label fw-bold">Supported Benchmark Range *</label>
          <div class="row g-2 mb-3">
            <div class="col-md-4"><input type="number" min="1" class="form-control" id="brMin" value="<%= benchmarkRange.minimum %>" placeholder="Minimum" required></div>
            <div class="col-md-4"><input type="number" min="1" class="form-control" id="brMax" value="<%= benchmarkRange.maximum %>" placeholder="Maximum" required></div>
            <div class="col-md-4"><input type="number" min="1" class="form-control" id="brTotal" value="<%= benchmarkRange.totalCount %>" placeholder="Total Count" required></div>
          </div>

          <div class="mb-3">
            <label class="form-label fw-bold">Stage IDs *</label>
            <div id="stageIdsContainer" class="row g-2 border rounded p-2"></div>
          </div>

          <div class="mb-3">
            <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
              <label class="form-label fw-bold m-0">Benchmark IDs *</label>
              <button type="button" class="btn btn-sm btn-outline-primary" id="pickBenchmarkBtn"><i class="bi bi-plus-circle me-1"></i>Pick Benchmark</button>
            </div>
            <div id="benchmarkIdRows" class="vstack gap-2">
              <% benchmarkIds.forEach((id) => { %>
                <div class="input-group benchmark-row">
                  <input class="form-control benchmark-id-input bg-light" name="benchmarkIds" value="<%= id %>" readonly required>
                  <button type="button" class="btn btn-outline-danger remove-benchmark">Remove</button>
                </div>
              <% }) %>
            </div>
          </div>

          <div class="mb-3">
            <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
              <label class="form-label fw-bold m-0">Competency Area IDs *</label>
              <button type="button" class="btn btn-sm btn-outline-primary" id="pickCompetencyAreaBtn"><i class="bi bi-plus-circle me-1"></i>Pick Competency Area</button>
            </div>
            <div id="competencyAreaRows" class="vstack gap-2">
              <% competencyAreaIds.forEach((id) => { %>
                <div class="input-group competency-row">
                  <input class="form-control competency-id-input bg-light" name="competencyAreaIds" value="<%= id %>" readonly required>
                  <button type="button" class="btn btn-outline-danger remove-competency">Remove</button>
                </div>
              <% }) %>
            </div>
          </div>

          <div class="mb-3"><label class="form-label">Tags (comma separated)</label><input class="form-control" name="tags" value="<%= Array.isArray(skillData?.tags)?skillData.tags.join(', '):'' %>"></div>
          <div class="d-flex gap-4 flex-wrap">
            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="isActive" name="isActive" value="true" <%= skillData ? (skillData.isActive?'checked':'') : 'checked' %>><label class="form-check-label fw-bold" for="isActive">isActive</label></div>
            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="isSystem" name="isSystem" value="true" <%= skillData?.isSystem?'checked':'' %>><label class="form-check-label fw-bold" for="isSystem">isSystem</label></div>
            <div class="form-check form-switch"><input class="form-check-input" type="checkbox" id="isLocked" name="isLocked" value="true" <%= skillData?.isLocked?'checked':'' %>><label class="form-check-label fw-bold" for="isLocked">isLocked</label></div>
          </div>
        </div>

        <div class="tab-pane fade" id="refs-pane">
          <label class="form-label fw-bold">Source References</label>
          <div class="table-responsive border rounded">
            <table class="table table-sm align-middle mb-0" id="refsTable">
              <thead class="table-light">
                <tr><th>Source</th><th>Fragment</th><th>Page Start</th><th>Page End</th><th>Note</th><th></th></tr>
              </thead>
              <tbody>
                <% (sourceRefs.length ? sourceRefs : [{}]).forEach((ref) => { %>
                  <tr class="ref-row">
                    <td>
                      <select class="form-select form-select-sm ref-source-id">
                        <option value="">Select source...</option>
                        <% (sources || []).forEach((src) => { %>
                          <option value="<%= src.id %>" <%= ref.sourceId === src.id ? 'selected' : '' %>><%= src.title %> (<%= src.id %>)</option>
                        <% }) %>
                      </select>
                    </td>
                    <td>
                      <select class="form-select form-select-sm ref-fragment-id">
                        <option value="">No fragment</option>
                        <% (fragments || []).forEach((frg) => { %>
                          <option value="<%= frg.id %>" <%= ref.fragmentId === frg.id ? 'selected' : '' %>><%= frg.title || frg.id %> (<%= frg.id %>)</option>
                        <% }) %>
                      </select>
                    </td>
                    <td><input type="number" min="1" class="form-control form-control-sm ref-page-start" value="<%= Array.isArray(ref.pages) ? (ref.pages[0] || '') : '' %>"></td>
                    <td><input type="number" min="1" class="form-control form-control-sm ref-page-end" value="<%= Array.isArray(ref.pages) ? (ref.pages[1] || '') : '' %>"></td>
                    <td><input class="form-control form-control-sm ref-note" value="<%= ref.note || '' %>"></td>
                    <td><button type="button" class="btn btn-sm btn-outline-danger remove-ref">Remove</button></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
          <button type="button" class="btn btn-sm btn-outline-primary mt-2" id="addRefBtn">Add Source Ref</button>
        </div>
      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md"><i class="bi bi-save me-1"></i> Save</button>
        <a href="/benchpath/clb-skills" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction" data-return-url="/benchpath/clb-skills">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/modal_GenericPicker') %>

<script>
  (function () {
    const form = document.getElementById('skillForm');
    const benchmarkRows = document.getElementById('benchmarkIdRows');
    const competencyRows = document.getElementById('competencyAreaRows');
    const refsTable = document.getElementById('refsTable').querySelector('tbody');
    const stageIdsContainer = document.getElementById('stageIdsContainer');
    const frameworkSelect = document.getElementById('frameworkIdSelect');
    const pickFrameworkBtn = document.getElementById('pickFrameworkBtn');
    const pickBenchmarkBtn = document.getElementById('pickBenchmarkBtn');
    const pickCompetencyAreaBtn = document.getElementById('pickCompetencyAreaBtn');
    const initialFrameworkId = <%- JSON.stringify(selectedFrameworkId) %>;
    const initialSelectedStageIds = new Set(<%- JSON.stringify(selectedStageIds) %>);
    const frameworkStageMap = <%- JSON.stringify(stageOptionsByFramework || {}) %>;

    const addValueRow = (container, inputName, rowClass, value, inputClassName) => {
      const normalized = String(value || '').trim();
      if (!normalized) return;
      const exists = Array.from(container.querySelectorAll(`input[name="${inputName}"]`))
        .some((input) => String(input.value || '').trim() === normalized);
      if (exists) return;
      const row = document.createElement('div');
      row.className = `input-group ${rowClass}`;
      row.innerHTML = `<input class="form-control ${inputClassName} bg-light" name="${inputName}" value="" readonly required><button type="button" class="btn btn-outline-danger ${rowClass === 'benchmark-row' ? 'remove-benchmark' : 'remove-competency'}">Remove</button>`;
      const input = row.querySelector('input');
      if (input) input.value = normalized;
      container.appendChild(row);
    };

    const openPicker = (config) => {
      if (!window.GenericPicker || typeof window.GenericPicker.open !== 'function') {
        console.error('Generic picker is not available on this page.');
        return;
      }
      const normalizedConfig = (typeof window.GenericPickerPresets?.normalizeConfig === 'function')
        ? window.GenericPickerPresets.normalizeConfig(config)
        : config;
      window.GenericPicker.open(normalizedConfig);
    };

    const getCheckedStageIds = () => {
      if (!stageIdsContainer) return [];
      return Array.from(stageIdsContainer.querySelectorAll('input[name="stageIds"]:checked'))
        .map((input) => String(input.value || '').trim())
        .filter(Boolean);
    };

    const renderStageOptions = (frameworkId, preferredSelections) => {
      if (!stageIdsContainer) return;
      const ids = Array.isArray(frameworkStageMap[String(frameworkId || '')])
        ? frameworkStageMap[String(frameworkId || '')]
        : [];
      const selectedSet = new Set(Array.isArray(preferredSelections) ? preferredSelections : []);

      stageIdsContainer.innerHTML = '';
      ids.forEach((stageId) => {
        const safeId = String(stageId).replace(/[^a-zA-Z0-9]/g, '_');
        const col = document.createElement('div');
        col.className = 'col-md-4';
        col.innerHTML = `
          <div class="form-check">
            <input class="form-check-input" type="checkbox" id="stage_${safeId}" name="stageIds" value="${stageId}" ${selectedSet.has(stageId) ? 'checked' : ''}>
            <label class="form-check-label" for="stage_${safeId}">${stageId}</label>
          </div>
        `;
        stageIdsContainer.appendChild(col);
      });
    };

    const refreshStageOptionsForFramework = (frameworkId, forceSelectAll = false) => {
      const existingSelections = forceSelectAll ? [] : getCheckedStageIds();
      const availableStages = Array.isArray(frameworkStageMap[String(frameworkId || '')])
        ? frameworkStageMap[String(frameworkId || '')]
        : [];
      const filteredSelections = existingSelections.filter((stageId) => availableStages.includes(stageId));
      const nextSelections = filteredSelections.length
        ? filteredSelections
        : (forceSelectAll ? availableStages : filteredSelections);
      renderStageOptions(frameworkId, nextSelections);
    };

    pickBenchmarkBtn?.addEventListener('click', () => {
      openPicker((typeof window.GenericPickerPresets?.clbBenchmark === 'function')
        ? window.GenericPickerPresets.clbBenchmark({
            onSelect: (item) => addValueRow(benchmarkRows, 'benchmarkIds', 'benchmark-row', item?.id || '', 'benchmark-id-input')
          })
        : {
            title: 'Select Benchmark',
            icon: 'bi-123',
            apiEndpoint: '/benchpath/clb-benchmarks',
            placeholder: 'Search benchmarks...',
            onSelect: (item) => addValueRow(benchmarkRows, 'benchmarkIds', 'benchmark-row', item?.id || '', 'benchmark-id-input')
          });
    });

    pickCompetencyAreaBtn?.addEventListener('click', () => {
      openPicker((typeof window.GenericPickerPresets?.clbCompetencyArea === 'function')
        ? window.GenericPickerPresets.clbCompetencyArea({
            onSelect: (item) => addValueRow(competencyRows, 'competencyAreaIds', 'competency-row', item?.id || '', 'competency-id-input')
          })
        : {
            title: 'Select Competency Area',
            icon: 'bi-diagram-3',
            apiEndpoint: '/benchpath/clb-competency-areas',
            placeholder: 'Search competency areas...',
            onSelect: (item) => addValueRow(competencyRows, 'competencyAreaIds', 'competency-row', item?.id || '', 'competency-id-input')
          });
    });

    pickFrameworkBtn?.addEventListener('click', () => {
      openPicker((typeof window.GenericPickerPresets?.clbFramework === 'function')
        ? window.GenericPickerPresets.clbFramework({
            onSelect: (item) => {
              const id = String(item?.id || '').trim();
              if (!id || !frameworkSelect) return;
              const existing = Array.from(frameworkSelect.options).find((opt) => String(opt.value) === id);
              if (!existing) {
                const option = document.createElement('option');
                option.value = id;
                option.text = `${item?.title || id} (${id})`;
                frameworkSelect.appendChild(option);
              }
              frameworkSelect.value = id;
              frameworkSelect.dispatchEvent(new Event('change', { bubbles: true }));
            }
          })
        : {
            title: 'Select Framework',
            icon: 'bi-diagram-2-fill',
            apiEndpoint: '/benchpath/clb-framework',
            placeholder: 'Search frameworks...',
            onSelect: (item) => {
              const id = String(item?.id || '').trim();
              if (!id || !frameworkSelect) return;
              const existing = Array.from(frameworkSelect.options).find((opt) => String(opt.value) === id);
              if (!existing) {
                const option = document.createElement('option');
                option.value = id;
                option.text = `${item?.title || id} (${id})`;
                frameworkSelect.appendChild(option);
              }
              frameworkSelect.value = id;
              frameworkSelect.dispatchEvent(new Event('change', { bubbles: true }));
            }
          });
    });

    frameworkSelect?.addEventListener('change', (event) => {
      refreshStageOptionsForFramework(String(event?.target?.value || ''), false);
    });

    const hasInitialSelections = initialSelectedStageIds.size > 0;
    renderStageOptions(initialFrameworkId, hasInitialSelections
      ? Array.from(initialSelectedStageIds)
      : (Array.isArray(frameworkStageMap[String(initialFrameworkId || '')]) ? frameworkStageMap[String(initialFrameworkId || '')] : []));

    document.getElementById('addRefBtn').addEventListener('click', () => {
      const tr = document.createElement('tr');
      tr.className = 'ref-row';
      tr.innerHTML = `
        <td>
          <select class="form-select form-select-sm ref-source-id">
            <option value="">Select source...</option>
            <% (sources || []).forEach((src) => { %><option value="<%= src.id %>"><%= src.title %> (<%= src.id %>)</option><% }) %>
          </select>
        </td>
        <td>
          <select class="form-select form-select-sm ref-fragment-id">
            <option value="">No fragment</option>
            <% (fragments || []).forEach((frg) => { %><option value="<%= frg.id %>"><%= frg.title || frg.id %> (<%= frg.id %>)</option><% }) %>
          </select>
        </td>
        <td><input type="number" min="1" class="form-control form-control-sm ref-page-start"></td>
        <td><input type="number" min="1" class="form-control form-control-sm ref-page-end"></td>
        <td><input class="form-control form-control-sm ref-note"></td>
        <td><button type="button" class="btn btn-sm btn-outline-danger remove-ref">Remove</button></td>
      `;
      refsTable.appendChild(tr);
    });

    form.addEventListener('click', (e) => {
      if (e.target.classList.contains('remove-benchmark')) e.target.closest('.benchmark-row').remove();
      if (e.target.classList.contains('remove-competency')) e.target.closest('.competency-row').remove();
      if (e.target.classList.contains('remove-ref')) e.target.closest('.ref-row').remove();
    });

    let isSubmitting = false;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (isSubmitting) return;

      const refs = [];
      refsTable.querySelectorAll('.ref-row').forEach((row) => {
        const sourceId = row.querySelector('.ref-source-id').value.trim();
        if (!sourceId) return;
        const pageStart = parseInt(row.querySelector('.ref-page-start').value || '', 10);
        const pageEnd = parseInt(row.querySelector('.ref-page-end').value || '', 10);
        const pages = Number.isFinite(pageStart) && Number.isFinite(pageEnd) ? [pageStart, pageEnd] : null;
        refs.push({
          sourceId,
          fragmentId: row.querySelector('.ref-fragment-id').value.trim() || null,
          pages,
          note: row.querySelector('.ref-note').value.trim() || null
        });
      });
      document.getElementById('sourceRefsInput').value = JSON.stringify(refs);

      const min = parseInt(document.getElementById('brMin').value || '', 10);
      const max = parseInt(document.getElementById('brMax').value || '', 10);
      const totalCount = parseInt(document.getElementById('brTotal').value || '', 10);
      document.getElementById('supportedBenchmarkRangeInput').value = JSON.stringify({ minimum: min, maximum: max, totalCount });

      isSubmitting = true;
      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;

      try {
        const payload = new URLSearchParams(new FormData(form));
        const response = await fetch(form.action, {
          method: (form.method || 'POST').toUpperCase(),
          headers: {
            'x-ajax-request': '1',
            Accept: 'application/json',
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
          },
          body: payload
        });

        const result = await response.json().catch(() => ({ status: 'error', message: `Server returned HTTP ${response.status}.` }));
        const isSuccess = response.ok && result?.status === 'success';

        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: isSuccess ? 'Saved' : 'Save Failed',
            icon: isSuccess ? 'success' : 'error',
            message: result?.message || (isSuccess ? 'Saved successfully.' : 'Unable to save.'),
            buttons: [{ text: 'OK', class: isSuccess ? 'btn-success' : 'btn-danger' }]
          });
        }

        if (isSuccess) {
          window.location.href = '/benchpath/clb-skills';
        }
      } catch (error) {
        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: 'Save Failed',
            icon: 'error',
            message: error?.message || 'Unexpected network error.',
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        }
      } finally {
        isSubmitting = false;
        if (submitBtn) submitBtn.disabled = false;
      }
    });
  })();
</script>
