<div class="mb-3">
  <label class="form-label fw-bold">Task Label Text</label>
  <textarea class="form-control" name="taskLabelText" rows="3"><%= itemData?.taskLabelText || '' %></textarea>
</div>
<div class="row g-2">
  <div class="col-md-4 mb-3">
    <label class="form-label fw-bold">Context Domain</label>
    <input class="form-control" name="contextDomain" value="<%= itemData?.contextDomain || '' %>">
  </div>
  <div class="col-md-4 mb-3">
    <label class="form-label fw-bold">Task Type</label>
    <input class="form-control" name="taskType" value="<%= itemData?.taskType || '' %>">
  </div>
  <div class="col-md-4 mb-3 d-flex align-items-end">
    <div class="form-check form-switch">
      <input class="form-check-input" type="checkbox" id="officialSample" name="officialSample" value="true" <%= itemData?.officialSample ? 'checked' : '' %>>
      <label class="form-check-label fw-bold" for="officialSample">Official Sample</label>
    </div>
  </div>
</div>
<div class="row g-2">
  <div class="col-md-6 mb-3">
    <label class="form-label fw-bold">Linked Benchmark</label>
    <select class="form-select" name="linkedBenchmarkId" id="linkedBenchmarkId">
      <option value="">Select benchmark...</option>
      <% (options.benchmarks || []).forEach((row) => { %>
        <option value="<%= row.id %>" data-framework-id="<%= row.frameworkId || '' %>" data-skill-id="<%= row.skillId || '' %>" <%= itemData?.linkedBenchmarkId === row.id ? 'selected' : '' %>>
          <%= row.title || row.id %> (<%= row.id %>)
        </option>
      <% }) %>
    </select>
  </div>
  <div class="col-md-6 mb-3">
    <label class="form-label fw-bold">Linked Competency</label>
    <select class="form-select" name="linkedCompetencyId" id="linkedCompetencyId">
      <option value="">Select competency...</option>
      <% (options.competencies || []).forEach((row) => { %>
        <option value="<%= row.id %>" data-framework-id="<%= row.frameworkId || '' %>" data-skill-id="<%= row.skillId || '' %>" data-benchmark-id="<%= row.benchmarkId || '' %>" <%= itemData?.linkedCompetencyId === row.id ? 'selected' : '' %>>
          <%= row.title || row.id %> (<%= row.id %>)
        </option>
      <% }) %>
    </select>
  </div>
</div>
