<%
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const stateFilters = (filters && typeof filters === 'object') ? filters : {};
  const statusRows = Array.isArray(formOptions?.statuses) ? formOptions.statuses : [];
  const activeStatus = String(stateFilters?.status || '').trim().toLowerCase();
  const totalMatchedRows = Number(pagination?.totalItems ?? (Array.isArray(data) ? data.length : 0));

  function toList(input) {
    if (Array.isArray(input)) return input.map((item) => String(item || '').trim()).filter(Boolean);
    const token = String(input || '').trim();
    if (!token) return [];
    return token.split(',').map((item) => String(item || '').trim()).filter(Boolean);
  }

  const pickedTeacherCount = Math.max(
    toList(stateFilters.teacherIds || stateFilters.teacherId).length,
    Array.isArray(selectedTeachers) ? selectedTeachers.length : 0
  );
  const pickedStudentCount = Math.max(
    toList(stateFilters.studentIds || stateFilters.studentId).length,
    Array.isArray(selectedStudents) ? selectedStudents.length : 0
  );
  const hasCourseFiltersApplied = Boolean(
    String(stateFilters.status || '').trim()
    || String(stateFilters.dateFrom || '').trim()
    || String(stateFilters.dateTo || '').trim()
    || pickedTeacherCount
    || pickedStudentCount
  );
%>

<%- include('partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print: true,
  manageBtns: [
    '<a href="' + dashboardHref + '" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> PTE Dashboard</a>'
  ]
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
    <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter Courses</div>
    <button
      id="pteCourseFilterToggleBtn"
      type="button"
      class="btn btn-outline-secondary btn-sm px-2"
      data-bs-toggle="collapse"
      data-bs-target="#pteCourseFilterCollapse"
      aria-expanded="<%= hasCourseFiltersApplied ? 'true' : 'false' %>"
      aria-controls="pteCourseFilterCollapse"
      aria-label="<%= hasCourseFiltersApplied ? 'Close filters' : 'Open filters' %>">
      <i id="pteCourseFilterToggleIcon" class="bi <%= hasCourseFiltersApplied ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
    </button>
  </div>
  <div class="collapse<%= hasCourseFiltersApplied ? ' show' : '' %>" id="pteCourseFilterCollapse">
    <form method="GET" action="/pte/courses" id="pteCourseFilterForm" class="card-body p-3">
      <% if (stateFilters?.q) { %><input type="hidden" name="q" value="<%= stateFilters.q %>"><% } %>
      <% if (stateFilters?.type) { %><input type="hidden" name="type" value="<%= stateFilters.type %>"><% } %>
      <% if (stateFilters?.searchFields) { %><input type="hidden" name="searchFields" value="<%= stateFilters.searchFields %>"><% } %>

      <div class="row g-3 align-items-end">
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Status</label>
          <select class="form-select size-md" name="status">
            <option value="">All Statuses</option>
            <% statusRows.forEach((row) => { %>
              <% const token = String(row.value || '').trim().toLowerCase(); %>
              <option value="<%= row.value %>" <%= token === activeStatus ? 'selected' : '' %>><%= row.label || row.value %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Date From</label>
          <input type="date" class="form-control size-md" name="dateFrom" value="<%= stateFilters?.dateFrom || '' %>">
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Date To</label>
          <input type="date" class="form-control size-md" name="dateTo" value="<%= stateFilters?.dateTo || '' %>">
        </div>
        <div class="col-md-6 col-xl-3 d-flex justify-content-xl-end gap-2 pt-xl-4">
          <a href="/pte/courses" class="btn btn-outline-secondary btn-md">Reset</a>
          <button type="submit" class="btn btn-filled btn-primary btn-md">
            <i class="bi bi-funnel me-1"></i> Apply
          </button>
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-md-6">
          <div class="d-flex align-items-center justify-content-between mb-1">
            <label class="form-label mb-0">Teachers</label>
            <div class="d-flex align-items-center gap-2">
              <button type="button" class="btn btn-outline-primary btn-md" id="btnPickCourseTeachers">
                <i class="bi bi-search me-1"></i> Select
              </button>
              <button type="button" class="btn btn-outline-secondary btn-md" id="btnClearCourseTeachers">Clear</button>
            </div>
          </div>
          <div id="courseSelectedTeachersBox" class="border rounded p-2 bg-light-subtle small"></div>
        </div>
        <div class="col-md-6">
          <div class="d-flex align-items-center justify-content-between mb-1">
            <label class="form-label mb-0">Students</label>
            <div class="d-flex align-items-center gap-2">
              <button type="button" class="btn btn-outline-primary btn-md" id="btnPickCourseStudents">
                <i class="bi bi-search me-1"></i> Select
              </button>
              <button type="button" class="btn btn-outline-secondary btn-md" id="btnClearCourseStudents">Clear</button>
            </div>
          </div>
          <div id="courseSelectedStudentsBox" class="border rounded p-2 bg-light-subtle small"></div>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div class="small text-muted">
      Matched rows: <span class="fw-bold text-dark"><%= totalMatchedRows.toLocaleString() %></span>
    </div>
    <div class="small text-muted">
      Showing page: <span class="fw-bold text-dark"><%= Number(pagination?.currentPage || 1) %> / <%= Number(pagination?.totalPages || 1) %></span>
    </div>
  </div>
</div>

<%- include('partials/tablePages-search', {
  placeholder: 'Search courses by code, name, course type, teacher, student, or status...',
  fields: searchableFields || []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4 draggable" data-column="name">Course<span class="sort-icon"></span></th>
        <th class="draggable" data-column="dateRange">Date Range<span class="sort-icon"></span></th>
        <th class="draggable" data-column="teachers">Teachers<span class="sort-icon"></span></th>
        <th class="draggable" data-column="students">Students<span class="sort-icon"></span></th>
        <th class="draggable" data-column="status">Status<span class="sort-icon"></span></th>
        <th class="draggable" data-column="creator">Creator<span class="sort-icon"></span></th>
        <th class="text-end pe-4">Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || data.length === 0) { %>
        <tr>
          <td colspan="7" class="text-center py-4 text-muted">No courses found.</td>
        </tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <% const teachers = Array.isArray(item.teachers) ? item.teachers : []; %>
        <% const students = Array.isArray(item.students) ? item.students : []; %>
        <% const status = String(item.status || 'draft').toLowerCase(); %>
        <% const statusClass = status === 'active' ? 'bg-success' : (status === 'closed' ? 'bg-secondary' : (status === 'archived' ? 'bg-dark' : 'bg-info text-dark')); %>
        <% const creator = item.creator || {}; %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-dark"><%= item.name || '-' %></div>
            <div class="x-small text-muted">Code: <span class="font-monospace"><%= item.code || '-' %></span></div>
            <div class="x-small text-muted font-monospace"><%= item.id || '-' %></div>
            <div class="x-small text-muted mt-1">
              Course Type: <%= item.courseType || item.level || '-' %> | Max Students: <%= Number(item.maxStudents || 0) %>
            </div>
          </td>
          <td>
            <div class="small text-dark"><%= item.startDate || '-' %> to <%= item.endDate || '-' %></div>
          </td>
          <td>
            <div class="small text-dark"><%= Number(item.summary?.teacherCount || teachers.length || 0) %> teacher(s)</div>
            <div class="x-small text-muted">
              <% if (!teachers.length) { %>
                -
              <% } else { %>
                <%= teachers.slice(0, 2).map((row) => (row.displayName ? (row.displayName + ' (' + row.id + ')') : row.id)).join(', ') %><%= teachers.length > 2 ? ', ...' : '' %>
              <% } %>
            </div>
          </td>
          <td>
            <div class="small text-dark"><%= Number(item.summary?.studentCount || students.length || 0) %> student(s)</div>
            <div class="x-small text-muted">
              <% if (!students.length) { %>
                -
              <% } else { %>
                <%= students.slice(0, 2).map((row) => (row.displayName ? (row.displayName + ' (' + row.id + ')') : row.id)).join(', ') %><%= students.length > 2 ? ', ...' : '' %>
              <% } %>
            </div>
          </td>
          <td>
            <span class="badge <%= statusClass %> text-capitalize"><%= status %></span>
          </td>
          <td>
            <div class="small fw-bold text-dark"><%= creator.displayName || (creator.type === 'system' ? 'System' : '-') %></div>
            <div class="x-small text-muted font-monospace"><%= creator.userId || 'System' %></div>
          </td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= item.id %>"
                title="Row actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                <a href="/pte/courses/edit/<%= item.id %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-pencil-square me-2"></i>Edit
                </a>
                <% if (status !== 'archived') { %>
                  <button class="btn btn-outline-danger btn-sm pte-course-action-btn" data-id="<%= item.id %>" data-action="archive" data-url="/pte/courses/archive/<%= item.id %>">
                    <i class="bi bi-archive me-2"></i>Archive
                  </button>
                <% } else { %>
                  <button class="btn btn-outline-success btn-sm pte-course-action-btn" data-id="<%= item.id %>" data-action="recover" data-url="/pte/courses/recover/<%= item.id %>">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>Recover
                  </button>
                <% } %>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/pagination', {
  pagination: pagination,
  filters: filters,
  baseUrlPath: newUrl
}) %>

<%- include('partials/tablePages-end') %>
<%- include('partials/modal_GenericPicker', { user }) %>

<script>
(() => {
  const filterForm = document.getElementById('pteCourseFilterForm');
  if (!filterForm) return;

  const selectedTeachers = <%- JSON.stringify(selectedTeachers || []).replace(/</g, '\\u003c') %>;
  const selectedStudents = <%- JSON.stringify(selectedStudents || []).replace(/</g, '\\u003c') %>;
  const selectedTeachersBox = document.getElementById('courseSelectedTeachersBox');
  const selectedStudentsBox = document.getElementById('courseSelectedStudentsBox');
  const btnPickTeachers = document.getElementById('btnPickCourseTeachers');
  const btnPickStudents = document.getElementById('btnPickCourseStudents');
  const btnClearTeachers = document.getElementById('btnClearCourseTeachers');
  const btnClearStudents = document.getElementById('btnClearCourseStudents');
  const actionStateRef = document.getElementById('actionStateIdRef');
  const actionStateId = actionStateRef ? String(actionStateRef.getAttribute('data-id') || '').trim() : '';

  function initCollapseToggleIcon(options = {}) {
    const collapseEl = document.getElementById(String(options.collapseId || ''));
    const buttonEl = document.getElementById(String(options.buttonId || ''));
    const iconEl = document.getElementById(String(options.iconId || ''));
    if (!collapseEl || !buttonEl || !iconEl) return;

    const openIcon = String(options.openIcon || 'bi-chevron-down');
    const closeIcon = String(options.closeIcon || 'bi-chevron-up');
    const openLabel = String(options.openLabel || 'Open filters');
    const closeLabel = String(options.closeLabel || 'Close filters');

    const setState = (expanded) => {
      iconEl.classList.remove(openIcon, closeIcon);
      iconEl.classList.add(expanded ? closeIcon : openIcon);
      buttonEl.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      buttonEl.setAttribute('aria-label', expanded ? closeLabel : openLabel);
    };

    setState(collapseEl.classList.contains('show'));
    collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
    collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
  }

  initCollapseToggleIcon({
    collapseId: 'pteCourseFilterCollapse',
    buttonId: 'pteCourseFilterToggleBtn',
    iconId: 'pteCourseFilterToggleIcon',
    openIcon: 'bi-chevron-down',
    closeIcon: 'bi-chevron-up',
    openLabel: 'Open filters',
    closeLabel: 'Close filters'
  });

  function esc(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function normalizeId(value) {
    return String(value || '').trim();
  }

  async function showMessage(title, message, icon) {
    if (typeof window.showMessageModal === 'function') {
      await window.showMessageModal({
        title: title,
        message: message,
        icon: icon || 'info',
        buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : 'btn-primary' }]
      });
      return;
    }
    alert(title + ': ' + message);
  }

  function addUniqueMember(targetList, row) {
    const id = normalizeId(row && row.id);
    if (!id) return;
    if (targetList.some((item) => normalizeId(item && item.id) === id)) return;
    targetList.push({
      id: id,
      name: String((row && (row.displayName || row.name || row.username || row.email)) || id).trim(),
      email: String((row && row.email) || '').trim()
    });
  }

  function renderMemberList(container, list, inputName, removeClassName) {
    if (!container) return;
    if (!list.length) {
      container.innerHTML = '<div class="text-muted">No selection.</div>';
      return;
    }
    container.innerHTML = list.map((row, index) => {
      const id = normalizeId(row && row.id);
      const label = String((row && row.name) || id).trim() || id;
      return ''
        + '<div class="d-flex align-items-center justify-content-between gap-2 border rounded bg-white px-2 py-1 mb-2">'
        + '  <div class="text-break">'
        + '    <div class="fw-bold">' + esc(label) + '</div>'
        + '    <div class="x-small text-muted font-monospace">' + esc(id) + '</div>'
        + '    <input type="hidden" name="' + esc(inputName) + '" value="' + esc(id) + '">'
        + '  </div>'
        + '  <button type="button" class="btn btn-outline-danger btn-sm ' + esc(removeClassName) + '" data-index="' + index + '">'
        + '    <i class="bi bi-x-lg"></i>'
        + '  </button>'
        + '</div>';
    }).join('');
  }

  function renderSelections() {
    renderMemberList(selectedTeachersBox, selectedTeachers, 'teacherIds', 'course-remove-teacher');
    renderMemberList(selectedStudentsBox, selectedStudents, 'studentIds', 'course-remove-student');

    selectedTeachersBox.querySelectorAll('.course-remove-teacher').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = Number.parseInt(String(btn.getAttribute('data-index') || ''), 10);
        if (!Number.isFinite(idx) || idx < 0 || idx >= selectedTeachers.length) return;
        selectedTeachers.splice(idx, 1);
        renderSelections();
      });
    });
    selectedStudentsBox.querySelectorAll('.course-remove-student').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = Number.parseInt(String(btn.getAttribute('data-index') || ''), 10);
        if (!Number.isFinite(idx) || idx < 0 || idx >= selectedStudents.length) return;
        selectedStudents.splice(idx, 1);
        renderSelections();
      });
    });
  }

  btnPickTeachers?.addEventListener('click', () => {
    if (!window.GenericPicker || !window.GenericPickerPresets) return;
    const contexts = window.GenericPickerContexts || {};
    const context = (typeof contexts.activeOrganizationScope === 'function')
      ? contexts.activeOrganizationScope({ label: 'Active Organization Scope' })
      : null;
    window.GenericPicker.open(window.GenericPickerPresets.person({
      title: 'Select Teachers',
      apiEndpoint: '/pte/courses/api/pickers/teachers',
      placeholder: 'Search teachers by name, id, or email...',
      multiselect: true,
      context,
      onSelect: (items) => {
        const rows = Array.isArray(items) ? items : [items];
        rows.forEach((row) => addUniqueMember(selectedTeachers, row));
        renderSelections();
      }
    }));
  });

  btnPickStudents?.addEventListener('click', () => {
    if (!window.GenericPicker || !window.GenericPickerPresets) return;
    const contexts = window.GenericPickerContexts || {};
    const context = (typeof contexts.activeOrganizationScope === 'function')
      ? contexts.activeOrganizationScope({ label: 'Active Organization Scope' })
      : null;
    window.GenericPicker.open(window.GenericPickerPresets.student({
      title: 'Select Students',
      apiEndpoint: '/pte/courses/api/pickers/students',
      placeholder: 'Search students/applicants by name, id, email...',
      multiselect: true,
      context,
      onSelect: (items) => {
        const rows = Array.isArray(items) ? items : [items];
        rows.forEach((row) => addUniqueMember(selectedStudents, row));
        renderSelections();
      }
    }));
  });

  btnClearTeachers?.addEventListener('click', () => {
    selectedTeachers.length = 0;
    renderSelections();
  });
  btnClearStudents?.addEventListener('click', () => {
    selectedStudents.length = 0;
    renderSelections();
  });

  filterForm.addEventListener('submit', () => {
    renderSelections();
  });

  document.querySelectorAll('.pte-course-action-btn').forEach((button) => {
    button.addEventListener('click', async () => {
      const url = String(button.getAttribute('data-url') || '').trim();
      const action = String(button.getAttribute('data-action') || '').trim();
      if (!url) return;

      const verbLabel = action === 'recover' ? 'Recovering...' : 'Archiving...';
      const originalHtml = button.innerHTML;
      button.disabled = true;
      button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + verbLabel;

      try {
        const response = await fetch(url + '?actionStateId=' + encodeURIComponent(actionStateId), {
          method: 'POST',
          headers: {
            'X-AJAX-Request': 'true',
            'Accept': 'application/json'
          },
          credentials: 'include'
        });
        const result = await response.json().catch(() => null);
        if (!response.ok || !result || result.status !== 'success') {
          throw new Error((result && result.message) || ('Request failed with status ' + response.status + '.'));
        }
        await showMessage('Success', result.message || 'Operation completed.', 'success');
        window.location.reload();
      } catch (error) {
        await showMessage('Operation Failed', error.message || 'Unexpected operation error.', 'error');
        button.disabled = false;
        button.innerHTML = originalHtml;
      }
    });
  });

  renderSelections();
})();
</script>
