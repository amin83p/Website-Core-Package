<%
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const stateFilters = (filters && typeof filters === 'object') ? filters : {};
  const attemptTypeRows = Array.isArray(filterOptions?.attemptTypes) ? filterOptions.attemptTypes : [];
  const eventTypeRows = Array.isArray(filterOptions?.eventTypes) ? filterOptions.eventTypes : [];
  const skillRows = Array.isArray(filterOptions?.skills) ? filterOptions.skills : [];
  const itemStatusRows = Array.isArray(filterOptions?.itemStatuses) ? filterOptions.itemStatuses : [];
  const sessionStatusRows = [
    { value: 'in_progress', label: 'in progress' },
    { value: 'submitted', label: 'submitted' },
    { value: 'finished', label: 'finished' },
    { value: 'abandoned', label: 'abandoned' }
  ];
  const questionTypeRows = Array.isArray(questionTypeOptions) ? questionTypeOptions : [];

  function toList(input) {
    if (Array.isArray(input)) return input.map((item) => String(item || '').trim()).filter(Boolean);
    const token = String(input || '').trim();
    if (!token) return [];
    return token.split(',').map((item) => String(item || '').trim()).filter(Boolean);
  }

  const selectedAttemptTypes = new Set(toList(stateFilters.attemptTypes).map((v) => String(v || '').trim().toLowerCase()));
  const selectedEventTypes = new Set(toList(stateFilters.eventTypes).map((v) => String(v || '').trim().toLowerCase()));
  const selectedSkills = new Set(toList(stateFilters.skills).map((v) => String(v || '').trim().toLowerCase()));
  const selectedSessionStatus = String(stateFilters.sessionStatus || '').trim().toLowerCase();
  const selectedItemStatus = String(stateFilters.itemStatus || '').trim().toLowerCase();
  const activeWithFeedback = String(stateFilters.withFeedback || '').trim().toLowerCase();
  const activeQuestionType = String(stateFilters.questionType || '').trim().toLowerCase();
  const totalMatchedRows = Number(pagination?.totalItems ?? (Array.isArray(data) ? data.length : 0));

  const formatQuestionTypeLabel = (value) => String(value || '')
    .trim()
    .toLowerCase()
    .split('_')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');

  const hasAttemptLedgerFiltersApplied = Boolean(
    String(stateFilters.startDate || stateFilters.eventFrom || '').trim()
    || String(stateFilters.endDate || stateFilters.eventTo || '').trim()
    || String(stateFilters.questionType || '').trim()
    || String(stateFilters.withFeedback || '').trim()
    || selectedAttemptTypes.size
    || selectedEventTypes.size
    || selectedSkills.size
    || String(stateFilters.sessionStatus || '').trim()
    || String(stateFilters.itemStatus || '').trim()
    || String(stateFilters.sessionId || '').trim()
    || String(stateFilters.itemId || '').trim()
    || String(stateFilters.testVersionId || '').trim()
    || String(stateFilters.questionVersionId || '').trim()
    || String(stateFilters.minScoreFinal || '').trim()
    || String(stateFilters.maxScoreFinal || '').trim()
    || String(stateFilters.minTimeSpentSeconds || '').trim()
    || String(stateFilters.maxTimeSpentSeconds || '').trim()
    || toList(stateFilters.userIds || stateFilters.userId).length
  );
%>

<%- include('../../../../../../MVC/views/partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print: true,
  manageBtns: [
    '<a href="' + dashboardHref + '" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> PTE Dashboard</a>',
    '<a href="/pte/attempt/details" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-journal-text me-1"></i> Attempt Details</a>',
    '<a href="/pte/attempt/overall-performance" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-graph-up-arrow me-1"></i> Overall Performance</a>'
  ]
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
    <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter Attempt Ledger</div>
    <button
      id="pteRuntimeLedgerFilterToggleBtn"
      type="button"
      class="btn btn-outline-secondary btn-sm px-2"
      data-bs-toggle="collapse"
      data-bs-target="#pteRuntimeLedgerFilterCollapse"
      aria-expanded="<%= hasAttemptLedgerFiltersApplied ? 'true' : 'false' %>"
      aria-controls="pteRuntimeLedgerFilterCollapse"
      aria-label="<%= hasAttemptLedgerFiltersApplied ? 'Close filters' : 'Open filters' %>">
      <i id="pteRuntimeLedgerFilterToggleIcon" class="bi <%= hasAttemptLedgerFiltersApplied ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
    </button>
  </div>
  <div class="collapse<%= hasAttemptLedgerFiltersApplied ? ' show' : '' %>" id="pteRuntimeLedgerFilterCollapse">
    <form method="GET" action="/pte/attempt/ledger" id="pteRuntimeLedgerFilterForm" class="card-body p-3">
      <% if (stateFilters?.q) { %><input type="hidden" name="q" value="<%= stateFilters.q %>"><% } %>
      <% if (stateFilters?.type) { %><input type="hidden" name="type" value="<%= stateFilters.type %>"><% } %>
      <% if (stateFilters?.searchFields) { %><input type="hidden" name="searchFields" value="<%= stateFilters.searchFields %>"><% } %>
      <div class="row g-3 align-items-end">
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Event Date From</label>
          <input type="date" class="form-control size-md" name="eventFrom" value="<%= stateFilters?.startDate || stateFilters?.eventFrom || '' %>">
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Event Date To</label>
          <input type="date" class="form-control size-md" name="eventTo" value="<%= stateFilters?.endDate || stateFilters?.eventTo || '' %>">
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Question Type</label>
          <select class="form-select size-md" name="questionType">
            <option value="">All Question Types</option>
            <% questionTypeRows.forEach((token) => { %>
              <% const value = String(token || '').trim().toLowerCase(); %>
              <option value="<%= value %>" <%= value === activeQuestionType ? 'selected' : '' %>><%= formatQuestionTypeLabel(value) || value %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">With Feedback</label>
          <select class="form-select size-md" name="withFeedback">
            <option value="" <%= !activeWithFeedback ? 'selected' : '' %>>All</option>
            <option value="yes" <%= activeWithFeedback === 'yes' ? 'selected' : '' %>>Yes</option>
            <option value="no" <%= activeWithFeedback === 'no' ? 'selected' : '' %>>No</option>
          </select>
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-md-4">
          <label class="form-label">Attempt Types</label>
          <select class="form-select size-md" name="attemptTypes" multiple size="3">
            <% attemptTypeRows.forEach((row) => { %>
              <% const token = String(row.value || '').trim().toLowerCase(); %>
              <option value="<%= row.value %>" <%= selectedAttemptTypes.has(token) ? 'selected' : '' %>><%= row.label || row.value %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Event Types</label>
          <select class="form-select size-md" name="eventTypes" multiple size="3">
            <% eventTypeRows.forEach((row) => { %>
              <% const token = String(row.value || '').trim().toLowerCase(); %>
              <option value="<%= row.value %>" <%= selectedEventTypes.has(token) ? 'selected' : '' %>><%= row.label || row.value %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-4">
          <label class="form-label">Skills</label>
          <select class="form-select size-md" name="skills" multiple size="3">
            <% skillRows.forEach((row) => { %>
              <% const token = String(row.value || '').trim().toLowerCase(); %>
              <option value="<%= row.value %>" <%= selectedSkills.has(token) ? 'selected' : '' %>><%= row.label || row.value %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-md-6">
          <label class="form-label">Session Status</label>
          <select class="form-select size-md" name="sessionStatus">
            <option value="">All Session Statuses</option>
            <% sessionStatusRows.forEach((row) => { %>
              <% const value = String(row.value || '').trim().toLowerCase(); %>
              <option value="<%= value %>" <%= value === selectedSessionStatus ? 'selected' : '' %>><%= row.label || row.value %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6">
          <label class="form-label">Item Status</label>
          <select class="form-select size-md" name="itemStatus">
            <option value="">All Item Statuses</option>
            <% itemStatusRows.forEach((row) => { %>
              <% const value = String(row.value || '').trim().toLowerCase(); %>
              <option value="<%= value %>" <%= value === selectedItemStatus ? 'selected' : '' %>><%= row.label || row.value %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-md-3">
          <label class="form-label">Session ID</label>
          <input type="text" class="form-control size-md font-monospace" name="sessionId" value="<%= stateFilters?.sessionId || '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">Item ID</label>
          <input type="text" class="form-control size-md font-monospace" name="itemId" value="<%= stateFilters?.itemId || '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">Test Version ID</label>
          <input type="text" class="form-control size-md font-monospace" name="testVersionId" value="<%= stateFilters?.testVersionId || '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">Question Version ID</label>
          <input type="text" class="form-control size-md font-monospace" name="questionVersionId" value="<%= stateFilters?.questionVersionId || '' %>">
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-md-3">
          <label class="form-label">Min Score (Final)</label>
          <input type="number" step="0.01" class="form-control size-md" name="minScoreFinal" value="<%= stateFilters?.minScoreFinal || '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">Max Score (Final)</label>
          <input type="number" step="0.01" class="form-control size-md" name="maxScoreFinal" value="<%= stateFilters?.maxScoreFinal || '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">Min Time (sec)</label>
          <input type="number" step="1" class="form-control size-md" name="minTimeSpentSeconds" value="<%= stateFilters?.minTimeSpentSeconds || '' %>">
        </div>
        <div class="col-md-3">
          <label class="form-label">Max Time (sec)</label>
          <input type="number" step="1" class="form-control size-md" name="maxTimeSpentSeconds" value="<%= stateFilters?.maxTimeSpentSeconds || '' %>">
        </div>
      </div>

      <div class="row g-3 mt-1">
        <div class="col-12">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
            <label class="form-label mb-0">Users</label>
            <div class="d-flex align-items-center gap-2">
              <button type="button" class="btn btn-outline-primary btn-md" id="btnPickRuntimeUsers">
                <i class="bi bi-people me-1"></i> Select Users
              </button>
              <button type="button" class="btn btn-outline-secondary btn-md" id="btnClearRuntimeUsers">Clear Users</button>
            </div>
          </div>
          <div id="runtimeSelectedUsersBox" class="border rounded p-2 bg-light-subtle small"></div>
        </div>
      </div>

      <div class="row g-3 align-items-start mt-1">
        <div class="col-12 d-flex justify-content-xl-end gap-2 pt-xl-2">
          <a href="/pte/attempt/ledger" class="btn btn-outline-secondary btn-md">Reset</a>
          <button type="submit" class="btn btn-filled btn-primary btn-md">
            <i class="bi bi-funnel me-1"></i> Apply
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div class="small text-muted">
      Matched rows: <span class="fw-bold text-dark"><%= totalMatchedRows.toLocaleString() %></span>
    </div>
    <div class="small text-muted">
      Showing page: <span class="fw-bold text-dark"><%= Number(pagination?.currentPage || 1) %> / <%= Number(pagination?.totalPages || 1) %></span>
    </div>
  </div>
</div>

<%- include('../../../../../../MVC/views/partials/tablePages-search', {
  placeholder: 'Search runtime events by ids, types, source ids, question ids, or user ids...',
  fields: searchableFields || []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Event</th>
        <th>User</th>
        <th>Attempt</th>
        <th>Question</th>
        <th>Score / Time</th>
        <th>Feedback / Status</th>
        <th>Source</th>
        <th class="text-end pe-4">Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || data.length === 0) { %>
        <tr>
          <td colspan="8" class="text-center py-4 text-muted">No runtime ledger events found for the selected filters.</td>
        </tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <% const eventType = String(item.eventType || '').toLowerCase(); %>
        <% const eventBadgeClass = eventType.includes('submit') ? 'bg-success' : (eventType.includes('score') ? 'bg-primary' : (eventType.includes('feedback') ? 'bg-info text-dark' : 'bg-secondary')); %>
        <% const sessionStatus = String(item.sessionStatus || '').toLowerCase(); %>
        <% const itemStatus = String(item.itemStatus || '').toLowerCase(); %>
        <tr>
          <td class="ps-4">
            <div class="small fw-bold text-dark"><%= item.eventAtDisplay || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.id || '-' %></div>
            <div class="x-small mt-1">
              <span class="badge <%= eventBadgeClass %> text-capitalize"><%= eventType || '-' %></span>
            </div>
          </td>
          <td>
            <div class="small fw-bold text-dark"><%= item.userLabel || item.userId || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.userId || '-' %></div>
            <div class="x-small text-muted font-monospace">Org: <%= item.orgId || '-' %></div>
          </td>
          <td>
            <% if (item.practiceName) { %>
              <div class="small fw-bold text-dark"><%= item.practiceName %></div>
            <% } %>
            <div class="small text-capitalize"><strong>Type:</strong> <%= item.attemptType || '-' %></div>
            <div class="x-small text-muted font-monospace">Session: <%= item.attemptSessionId || '-' %></div>
            <div class="x-small text-muted font-monospace">Item: <%= item.attemptItemId || '-' %></div>
          </td>
          <td>
            <div class="small text-capitalize"><%= item.skill || '-' %> / <%= formatQuestionTypeLabel(item.questionType) || '-' %></div>
            <div class="x-small text-muted font-monospace">Q: <%= item.questionVersionId || '-' %></div>
            <div class="x-small text-muted">Order: <%= Number(item.questionOrder || 0) %></div>
          </td>
          <td>
            <div class="small"><strong><%= Number(item.scoreFinal || 0).toFixed(2) %></strong> / <%= Number(item.maxScore || 0).toFixed(2) %></div>
            <div class="x-small text-muted">Raw: <%= Number(item.scoreRaw || 0).toFixed(2) %> | <%= Number(item.percentage || 0).toFixed(2) %>%</div>
            <div class="x-small text-muted">Time: <%= Number(item.timeSpentSeconds || 0) %> sec</div>
          </td>
          <td>
            <div class="x-small text-muted">Feedback At:</div>
            <div class="small"><%= item.feedbackProvidedAt || '-' %></div>
            <div class="x-small mt-1">
              <span class="badge <%= sessionStatus === 'finished' ? 'bg-success' : (sessionStatus ? 'bg-secondary' : 'bg-light text-dark border') %>">
                Session: <%= sessionStatus || '-' %>
              </span>
            </div>
            <div class="x-small mt-1">
              <span class="badge <%= itemStatus === 'feedback_provided' ? 'bg-info text-dark' : (itemStatus ? 'bg-light text-dark border' : 'bg-light text-dark border') %>">
                Item: <%= itemStatus || '-' %>
              </span>
            </div>
          </td>
          <td>
            <div class="x-small text-muted text-uppercase">Module</div>
            <div class="small font-monospace"><%= item.source?.module || '-' %></div>
            <div class="x-small text-muted text-uppercase mt-1">Event ID</div>
            <div class="x-small font-monospace"><%= item.source?.eventId || '-' %></div>
          </td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= item.id %>"
                title="Row actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                <% if (item.attemptSessionId) { %>
                  <a
                    href="/pte/attempt/details/<%= encodeURIComponent(item.attemptSessionId) %>"
                    class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-eye me-2"></i>Open Details
                  </a>
                <% } %>
                <% if (item.attemptSessionId) { %>
                  <a
                    href="/pte/attempt/ledger?sessionId=<%= encodeURIComponent(item.attemptSessionId) %>"
                    class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-funnel me-2"></i>Filter This Session
                  </a>
                <% } %>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../../../../../../MVC/views/partials/pagination', {
  pagination: pagination,
  filters: filters,
  baseUrlPath: newUrl
}) %>

<%- include('../../../../../../MVC/views/partials/tablePages-end') %>
<%- include('../../../../../../MVC/views/partials/modal_GenericPicker', { user }) %>

<script>
(() => {
  const form = document.getElementById('pteRuntimeLedgerFilterForm');
  if (!form) return;

  const selectedUsers = <%- JSON.stringify(selectedUsers || []).replace(/</g, '\\u003c') %>;
  const selectedUsersBox = document.getElementById('runtimeSelectedUsersBox');
  const btnPickUsers = document.getElementById('btnPickRuntimeUsers');
  const btnClearUsers = document.getElementById('btnClearRuntimeUsers');

  function initCollapseToggleIcon(options = {}) {
    const collapseEl = document.getElementById(String(options.collapseId || ''));
    const buttonEl = document.getElementById(String(options.buttonId || ''));
    const iconEl = document.getElementById(String(options.iconId || ''));
    if (!collapseEl || !buttonEl || !iconEl) return;

    const openIcon = String(options.openIcon || 'bi-chevron-down');
    const closeIcon = String(options.closeIcon || 'bi-chevron-up');
    const openLabel = String(options.openLabel || 'Open filters');
    const closeLabel = String(options.closeLabel || 'Close filters');

    const setState = (expanded) => {
      iconEl.classList.remove(openIcon, closeIcon);
      iconEl.classList.add(expanded ? closeIcon : openIcon);
      buttonEl.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      buttonEl.setAttribute('aria-label', expanded ? closeLabel : openLabel);
    };

    setState(collapseEl.classList.contains('show'));
    collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
    collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
  }

  initCollapseToggleIcon({
    collapseId: 'pteRuntimeLedgerFilterCollapse',
    buttonId: 'pteRuntimeLedgerFilterToggleBtn',
    iconId: 'pteRuntimeLedgerFilterToggleIcon',
    openIcon: 'bi-chevron-down',
    closeIcon: 'bi-chevron-up',
    openLabel: 'Open filters',
    closeLabel: 'Close filters'
  });

  function esc(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function normalizeId(value) {
    return String(value || '').trim();
  }

  function addUser(row) {
    const id = normalizeId(row?.id);
    if (!id) return;
    if (selectedUsers.some((item) => normalizeId(item?.id) === id)) return;
    const displayName = String(row?.name || row?.username || row?.email || id).trim();
    selectedUsers.push({
      id,
      name: displayName,
      username: String(row?.username || '').trim(),
      email: String(row?.email || '').trim()
    });
    renderSelectedUsers();
  }

  function renderSelectedUsers() {
    if (!selectedUsersBox) return;
    if (!selectedUsers.length) {
      selectedUsersBox.innerHTML = '<div class="text-muted">No users selected.</div>';
      return;
    }

    selectedUsersBox.innerHTML = selectedUsers.map((row, index) => {
      const id = normalizeId(row?.id);
      const label = String(row?.name || row?.username || row?.email || id).trim() || id;
      return ''
        + '<div class="d-flex align-items-center justify-content-between gap-2 border rounded bg-white px-2 py-1 mb-2">'
        + '  <div class="text-break">'
        + '    <div class="fw-bold">' + esc(label) + '</div>'
        + '    <div class="x-small text-muted font-monospace">' + esc(id) + '</div>'
        + '    <input type="hidden" name="userIds" value="' + esc(id) + '">'
        + '  </div>'
        + '  <button type="button" class="btn btn-outline-danger btn-sm runtime-remove-user" data-index="' + index + '">'
        + '    <i class="bi bi-x-lg"></i>'
        + '  </button>'
        + '</div>';
    }).join('');

    selectedUsersBox.querySelectorAll('.runtime-remove-user').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = Number.parseInt(String(btn.getAttribute('data-index') || ''), 10);
        if (!Number.isFinite(idx) || idx < 0 || idx >= selectedUsers.length) return;
        selectedUsers.splice(idx, 1);
        renderSelectedUsers();
      });
    });
  }

  btnPickUsers?.addEventListener('click', () => {
    if (!window.GenericPicker || !window.GenericPickerPresets) return;
    const contexts = window.GenericPickerContexts || {};
    const context = (typeof contexts.activeOrganizationScope === 'function')
      ? contexts.activeOrganizationScope({ label: 'Active Organization' })
      : null;

    window.GenericPicker.open(window.GenericPickerPresets.user({
      title: 'Select Users',
      apiEndpoint: '/pte/attempt/ledger/picker/users',
      placeholder: 'Search users by name, username, email, or id...',
      multiselect: true,
      context,
      onSelect: (items) => {
        const rows = Array.isArray(items) ? items : [items];
        rows.forEach(addUser);
      }
    }));
  });

  btnClearUsers?.addEventListener('click', () => {
    selectedUsers.length = 0;
    renderSelectedUsers();
  });

  form.addEventListener('submit', () => {
    renderSelectedUsers();
  });

  renderSelectedUsers();
})();
</script>
