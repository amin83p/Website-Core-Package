<%
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const rows = Array.isArray(sessions) ? sessions : [];
  const sessionDetail = detail && typeof detail === 'object' ? detail : null;
  const detailSession = sessionDetail && sessionDetail.session ? sessionDetail.session : null;
  const detailItems = sessionDetail && Array.isArray(sessionDetail.items) ? sessionDetail.items : [];
  const detailEvents = sessionDetail && Array.isArray(sessionDetail.events) ? sessionDetail.events : [];
  const detailArtifacts = sessionDetail && Array.isArray(sessionDetail.artifacts) ? sessionDetail.artifacts : [];
  const scoringItems = detailItems.filter((item) => item?.metadata && typeof item.metadata === 'object' && item.metadata.scoring && typeof item.metadata.scoring === 'object');
  const lifecycle = sessionDetail && sessionDetail.lifecycle && typeof sessionDetail.lifecycle === 'object'
    ? sessionDetail.lifecycle
    : null;
  const lifecycleSummary = lifecycle && lifecycle.summary ? lifecycle.summary : {};
  const lifecycleMatrix = lifecycle && Array.isArray(lifecycle.questionMatrix) ? lifecycle.questionMatrix : [];
  const lifecycleIntervals = lifecycle && Array.isArray(lifecycle.intervals) ? lifecycle.intervals : [];
  const lifecycleAnomalies = lifecycle && Array.isArray(lifecycle.anomalies) ? lifecycle.anomalies : [];
  const selectedUsersRows = Array.isArray(selectedUsers) ? selectedUsers : [];
  const filterRows = filters && typeof filters === 'object' ? filters : {};
  const optionRows = optionSets && typeof optionSets === 'object' ? optionSets : {};
  const attemptTypeRows = Array.isArray(optionRows.attemptTypes) ? optionRows.attemptTypes : [];
  const statusRows = Array.isArray(optionRows.sessionStatuses) ? optionRows.sessionStatuses : [];
  const activeSessionId = String(selectedSessionId || detailSession?.id || '').trim();
  const totalSessionRows = rows.length;
  const hasAttemptDetailsFiltersApplied = Boolean(
    String(filterRows.q || '').trim()
    || String(filterRows.attemptType || '').trim()
    || String(filterRows.status || '').trim()
    || String(filterRows.startedFrom || '').trim()
    || String(filterRows.startedTo || '').trim()
    || String(filterRows.userId || '').trim()
    || (Array.isArray(selectedUsersRows) && selectedUsersRows.length)
  );

  function buildQueryParams(extra = {}) {
    const merged = {
      q: filterRows.q || '',
      attemptType: filterRows.attemptType || '',
      status: filterRows.status || '',
      userId: filterRows.userId || '',
      startedFrom: filterRows.startedFrom || '',
      startedTo: filterRows.startedTo || '',
      ...extra
    };
    return Object.entries(merged)
      .filter(([, value]) => String(value || '').trim())
      .map(([key, value]) => `${encodeURIComponent(key)}=${encodeURIComponent(String(value))}`);
  }

  function buildDetailHref(sessionId) {
    const params = buildQueryParams();
    const suffix = params.length ? `?${params.join('&')}` : '';
    return `/pte/attempt/details/${encodeURIComponent(sessionId || '')}${suffix}`;
  }

  function buildExportHref(sessionId, format) {
    const params = buildQueryParams({ format });
    const suffix = params.length ? `?${params.join('&')}` : '';
    return `/pte/attempt/details/${encodeURIComponent(sessionId || '')}/export${suffix}`;
  }

  function formatJson(value) {
    try {
      return JSON.stringify(value == null ? null : value, null, 2);
    } catch (_) {
      return String(value == null ? '' : value);
    }
  }

  function formatBytes(value) {
    const bytes = Number(value || 0);
    if (!Number.isFinite(bytes) || bytes <= 0) return '0 B';
    const units = ['B', 'KB', 'MB', 'GB'];
    let size = bytes;
    let index = 0;
    while (size >= 1024 && index < units.length - 1) {
      size /= 1024;
      index += 1;
    }
    return `${size.toFixed(index === 0 ? 0 : 2)} ${units[index]}`;
  }

  function formatSeconds(value) {
    const total = Number(value || 0);
    if (!Number.isFinite(total) || total <= 0) return '0s';
    const safe = Math.floor(total);
    const hours = Math.floor(safe / 3600);
    const minutes = Math.floor((safe % 3600) / 60);
    const seconds = safe % 60;
    if (hours > 0) return `${hours}h ${minutes}m ${seconds}s`;
    if (minutes > 0) return `${minutes}m ${seconds}s`;
    return `${seconds}s`;
  }

  function eventAtValue(value) {
    if (!value) return 0;
    const ms = Date.parse(value);
    return Number.isFinite(ms) ? ms : 0;
  }
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <h1 class="page-heading size-md m-0"><i class="bi bi-journal-text me-2"></i>PTE Attempt Details</h1>
    <div class="d-flex align-items-center">
      <a href="<%= dashboardHref %>" class="btn btn-filled btn-secondary btn-md">
        <i class="bi bi-speedometer2 me-1"></i> PTE Dashboard
      </a>
    </div>
  </div>

  <div class="d-flex align-items-center justify-content-end mb-3 flex-wrap">
    <div class="d-flex align-items-center flex-wrap">
      <a href="/pte/attempt/ledger" class="btn btn-outline-secondary btn-md me-2 mb-2">
        <i class="bi bi-list-columns-reverse me-1"></i> Attempt Ledger
      </a>
      <a href="/pte/attempt/overall-performance" class="btn btn-outline-secondary btn-md me-2 mb-2">
        <i class="bi bi-graph-up-arrow me-1"></i> Overall Performance
      </a>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
      <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter Attempt Details</div>
      <button
        id="pteAttemptDetailsFilterToggleBtn"
        type="button"
        class="btn btn-outline-secondary btn-sm px-2"
        data-bs-toggle="collapse"
        data-bs-target="#pteAttemptDetailsFilterCollapse"
        aria-expanded="<%= hasAttemptDetailsFiltersApplied ? 'true' : 'false' %>"
        aria-controls="pteAttemptDetailsFilterCollapse"
        aria-label="<%= hasAttemptDetailsFiltersApplied ? 'Close filters' : 'Open filters' %>">
        <i id="pteAttemptDetailsFilterToggleIcon" class="bi <%= hasAttemptDetailsFiltersApplied ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
      </button>
    </div>
    <div class="collapse<%= hasAttemptDetailsFiltersApplied ? ' show' : '' %>" id="pteAttemptDetailsFilterCollapse">
      <form method="GET" action="/pte/attempt/details" id="pteAttemptDetailsFilterForm" class="card-body p-3">
        <div class="row g-3 align-items-end">
          <div class="col-md-4">
            <label class="form-label">Search</label>
            <input type="text" class="form-control size-md" name="q" value="<%= filterRows.q || '' %>" placeholder="Search by id, status, user, type...">
          </div>
          <div class="col-md-2">
            <label class="form-label">Attempt Type</label>
            <select class="form-select size-md" name="attemptType">
              <option value="">All Types</option>
              <% attemptTypeRows.forEach((row) => { %>
                <option value="<%= row.value %>" <%= String(filterRows.attemptType || '').toLowerCase() === String(row.value || '').toLowerCase() ? 'selected' : '' %>>
                  <%= row.label || row.value %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label">Status</label>
            <select class="form-select size-md" name="status">
              <option value="">All Statuses</option>
              <% statusRows.forEach((row) => { %>
                <option value="<%= row.value %>" <%= String(filterRows.status || '').toLowerCase() === String(row.value || '').toLowerCase() ? 'selected' : '' %>>
                  <%= row.label || row.value %>
                </option>
              <% }) %>
            </select>
          </div>
          <div class="col-md-2">
            <label class="form-label">Started From</label>
            <input type="date" class="form-control size-md" name="startedFrom" value="<%= filterRows.startedFrom || '' %>">
          </div>
          <div class="col-md-2">
            <label class="form-label">Started To</label>
            <input type="date" class="form-control size-md" name="startedTo" value="<%= filterRows.startedTo || '' %>">
          </div>
        </div>

        <div class="row g-3 mt-1">
          <div class="col-12">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
              <label class="form-label mb-0">User</label>
              <div class="d-flex align-items-center gap-2">
                <button type="button" class="btn btn-outline-primary btn-md" id="btnPickAttemptDetailUser">
                  <i class="bi bi-person me-1"></i>Select User
                </button>
                <button type="button" class="btn btn-outline-secondary btn-md" id="btnClearAttemptDetailUser">
                  Clear User
                </button>
              </div>
            </div>
            <div id="attemptDetailSelectedUserBox" class="border rounded p-2 bg-light-subtle small"></div>
          </div>
        </div>

        <div class="row g-3 align-items-start mt-1">
          <div class="col-12 d-flex justify-content-xl-end gap-2 pt-xl-2">
            <a href="/pte/attempt/details" class="btn btn-outline-secondary btn-md">Reset</a>
            <button type="submit" class="btn btn-filled btn-primary btn-md">
              <i class="bi bi-funnel me-1"></i>Apply
            </button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
      <div class="small text-muted">
        Matched sessions: <span class="fw-bold text-dark"><%= Number(totalSessionRows || 0).toLocaleString() %></span>
      </div>
      <div class="small text-muted">
        Active session: <span class="fw-bold text-dark font-monospace"><%= activeSessionId || '-' %></span>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white border-0 pb-0">
      <h5 class="fw-bold m-0"><i class="bi bi-list-task me-2"></i>Attempt Sessions</h5>
    </div>
    <div class="card-body pt-3">
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead>
            <tr>
              <th>Session</th>
              <th>User</th>
              <th>Type</th>
              <th>Status</th>
              <th>Started</th>
              <th>Finished</th>
              <th class="text-end">Action</th>
            </tr>
          </thead>
          <tbody>
            <% if (!rows.length) { %>
              <tr><td colspan="7" class="text-center text-muted py-3">No attempt sessions found.</td></tr>
            <% } %>
            <% rows.forEach((row) => { %>
              <% const rowId = String(row?.id || '').trim(); %>
              <% const isActive = rowId && activeSessionId && rowId === activeSessionId; %>
              <tr class="<%= isActive ? 'table-primary' : '' %>">
                <td>
                  <% if (row?.practiceName) { %>
                    <div class="small fw-bold text-dark"><%= row.practiceName %></div>
                  <% } %>
                  <div class="x-small text-muted font-monospace mt-1"><%= rowId || '-' %></div>
                </td>
                <td class="font-monospace small"><%= row?.userId || '-' %></td>
                <td class="small text-capitalize"><%= row?.attemptType || '-' %></td>
                <td><span class="badge <%= String(row?.status || '').toLowerCase() === 'finished' ? 'bg-success' : 'bg-secondary' %>"><%= row?.status || '-' %></span></td>
                <td class="small"><%= row?.startedAt ? new Date(row.startedAt).toLocaleString() : '-' %></td>
                <td class="small"><%= row?.finishedAt ? new Date(row.finishedAt).toLocaleString() : '-' %></td>
                <td class="text-end">
                  <a href="<%= buildDetailHref(rowId) %>" class="btn btn-outline-primary btn-sm">
                    <i class="bi bi-eye me-1"></i>Open
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white border-0 pb-0 d-flex align-items-center justify-content-between gap-2 flex-wrap">
      <h5 class="fw-bold m-0"><i class="bi bi-file-earmark-text me-2"></i>Session Detail</h5>
      <% if (detailSession?.id) { %>
        <div class="d-flex gap-2">
          <a href="<%= buildExportHref(detailSession.id, 'csv') %>" class="btn btn-outline-primary btn-sm">
            <i class="bi bi-download me-1"></i>Export CSV
          </a>
          <a href="<%= buildExportHref(detailSession.id, 'json') %>" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-braces me-1"></i>Export JSON
          </a>
        </div>
      <% } %>
    </div>
    <div class="card-body pt-3">
      <% if (detailError) { %>
        <div class="alert alert-danger"><%= detailError %></div>
      <% } %>
      <% if (!detailSession) { %>
        <div class="text-muted">Open a session from the list above to view full lifecycle analytics.</div>
      <% } else { %>
        <div class="row g-2 mb-3">
          <div class="col-md-6">
            <div class="border rounded p-2 bg-light">
              <div class="x-small text-muted">Session ID</div>
              <div class="fw-bold font-monospace"><%= detailSession.id || '-' %></div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="border rounded p-2 bg-light">
              <div class="x-small text-muted">Type</div>
              <div class="fw-bold text-capitalize"><%= detailSession.attemptType || '-' %></div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="border rounded p-2 bg-light">
              <div class="x-small text-muted">Status</div>
              <div class="fw-bold text-capitalize"><%= detailSession.status || '-' %></div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded p-2 bg-light">
              <div class="x-small text-muted">User</div>
              <div class="fw-bold font-monospace"><%= detailSession.userId || '-' %></div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded p-2 bg-light">
              <div class="x-small text-muted">Started</div>
              <div class="fw-bold"><%= detailSession.startedAt ? new Date(detailSession.startedAt).toLocaleString() : '-' %></div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded p-2 bg-light">
              <div class="x-small text-muted">Finished</div>
              <div class="fw-bold"><%= detailSession.finishedAt ? new Date(detailSession.finishedAt).toLocaleString() : '-' %></div>
            </div>
          </div>
        </div>

        <h6 class="fw-bold mb-2">Lifecycle Summary</h6>
        <div class="row g-2 mb-3">
          <div class="col-6 col-md-3 col-lg-2">
            <div class="border rounded p-2 bg-light h-100">
              <div class="x-small text-muted">Questions</div>
              <div class="fw-bold"><%= Number(lifecycleSummary.itemCount || 0) %></div>
            </div>
          </div>
          <div class="col-6 col-md-3 col-lg-2">
            <div class="border rounded p-2 bg-light h-100">
              <div class="x-small text-muted">Starts</div>
              <div class="fw-bold"><%= Number(lifecycleSummary.startCount || 0) %></div>
            </div>
          </div>
          <div class="col-6 col-md-3 col-lg-2">
            <div class="border rounded p-2 bg-light h-100">
              <div class="x-small text-muted">Saves</div>
              <div class="fw-bold"><%= Number(lifecycleSummary.saveCount || 0) %></div>
            </div>
          </div>
          <div class="col-6 col-md-3 col-lg-2">
            <div class="border rounded p-2 bg-light h-100">
              <div class="x-small text-muted">Submits</div>
              <div class="fw-bold"><%= Number(lifecycleSummary.submitCount || 0) %></div>
            </div>
          </div>
          <div class="col-6 col-md-3 col-lg-2">
            <div class="border rounded p-2 bg-light h-100">
              <div class="x-small text-muted">Skips</div>
              <div class="fw-bold"><%= Number(lifecycleSummary.skipCount || 0) %></div>
            </div>
          </div>
          <div class="col-6 col-md-3 col-lg-2">
            <div class="border rounded p-2 bg-light h-100">
              <div class="x-small text-muted">No-Save Starts</div>
              <div class="fw-bold"><%= Number(lifecycleSummary.noSaveStartCount || 0) %></div>
            </div>
          </div>
          <div class="col-6 col-md-3 col-lg-2">
            <div class="border rounded p-2 bg-light h-100">
              <div class="x-small text-muted">Avg Start Duration</div>
              <div class="fw-bold"><%= formatSeconds(lifecycleSummary.avgStartDurationSeconds || 0) %></div>
            </div>
          </div>
          <div class="col-6 col-md-3 col-lg-2">
            <div class="border rounded p-2 bg-light h-100">
              <div class="x-small text-muted">Total Active Time</div>
              <div class="fw-bold"><%= formatSeconds(lifecycleSummary.totalActiveSeconds || 0) %></div>
            </div>
          </div>
          <div class="col-6 col-md-3 col-lg-2">
            <div class="border rounded p-2 bg-light h-100">
              <div class="x-small text-muted">Anomalies</div>
              <div class="fw-bold <%= Number(lifecycleSummary.anomalyCount || 0) > 0 ? 'text-danger' : '' %>"><%= Number(lifecycleSummary.anomalyCount || 0) %></div>
            </div>
          </div>
        </div>

        <h6 class="fw-bold mb-2">Question Lifecycle Matrix</h6>
        <div class="table-responsive mb-3">
          <table class="table table-sm align-middle">
            <thead>
              <tr>
                <th>#</th>
                <th>Question</th>
                <th>Starts</th>
                <th>Saves</th>
                <th>Submits</th>
                <th>Auto</th>
                <th>Skips</th>
                <th>No-Save Starts</th>
                <th>Avg Duration</th>
                <th>Total Active</th>
                <th>Anomalies</th>
              </tr>
            </thead>
            <tbody>
              <% if (!lifecycleMatrix.length) { %>
                <tr><td colspan="11" class="text-center text-muted py-3">No lifecycle rows available for this session.</td></tr>
              <% } %>
              <% lifecycleMatrix.forEach((row) => { %>
                <% const hasAnomaly = Number(row?.anomalyCount || 0) > 0; %>
                <tr>
                  <td><%= Number(row?.questionOrder || 0) %></td>
                  <td>
                    <div class="small fw-bold"><%= row?.questionTitle || row?.questionVersionId || '-' %></div>
                    <div class="x-small text-muted text-capitalize"><%= row?.skill || '-' %> / <%= String(row?.questionType || '-').replace(/_/g, ' ') %></div>
                    <div class="x-small text-muted font-monospace"><%= row?.itemId || '-' %></div>
                  </td>
                  <td><%= Number(row?.startCount || 0) %></td>
                  <td><%= Number(row?.saveCount || 0) %></td>
                  <td><%= Number(row?.submitCount || 0) %></td>
                  <td><%= Number(row?.autoSubmitCount || 0) %></td>
                  <td><%= Number(row?.skipCount || 0) %></td>
                  <td><%= Number(row?.noSaveStartCount || 0) %></td>
                  <td><%= formatSeconds(row?.avgStartDurationSeconds || 0) %></td>
                  <td><%= formatSeconds(row?.totalActiveSeconds || 0) %></td>
                  <td>
                    <% if (hasAnomaly) { %>
                      <span class="badge bg-danger"><%= Number(row?.anomalyCount || 0) %></span>
                    <% } else { %>
                      <span class="badge bg-success">0</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <h6 class="fw-bold mb-2">Start Intervals</h6>
        <div class="table-responsive mb-3">
          <table class="table table-sm align-middle">
            <thead>
              <tr>
                <th>#</th>
                <th>Question</th>
                <th>Start No</th>
                <th>Started</th>
                <th>Ended</th>
                <th>Reason</th>
                <th>Duration</th>
                <th>Saves In Interval</th>
                <th>Submit</th>
                <th>View ID</th>
              </tr>
            </thead>
            <tbody>
              <% if (!lifecycleIntervals.length) { %>
                <tr><td colspan="10" class="text-center text-muted py-3">No start intervals recorded.</td></tr>
              <% } %>
              <% lifecycleIntervals.slice().sort((a, b) => eventAtValue(a?.startedAt) - eventAtValue(b?.startedAt)).forEach((row) => { %>
                <tr>
                  <td><%= Number(row?.questionOrder || 0) %></td>
                  <td>
                    <div class="small fw-bold"><%= row?.questionTitle || row?.questionVersionId || '-' %></div>
                    <div class="x-small text-muted font-monospace"><%= row?.itemId || '-' %></div>
                  </td>
                  <td><%= Number(row?.startNo || 0) %></td>
                  <td class="small"><%= row?.startedAt ? new Date(row.startedAt).toLocaleString() : '-' %></td>
                  <td class="small"><%= row?.endedAt ? new Date(row.endedAt).toLocaleString() : '-' %></td>
                  <td><span class="badge bg-secondary"><%= row?.endReason || '-' %></span></td>
                  <td><%= formatSeconds(row?.durationSeconds || 0) %></td>
                  <td><%= Number(row?.saveCountInInterval || 0) %></td>
                  <td><%= row?.submitOccurred ? 'Yes' : 'No' %></td>
                  <td class="x-small font-monospace"><%= row?.viewInstanceId || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <h6 class="fw-bold mb-2">Anomalies</h6>
        <div class="table-responsive mb-3">
          <table class="table table-sm align-middle">
            <thead>
              <tr>
                <th>Type</th>
                <th>Question</th>
                <th>Event At</th>
                <th>Event</th>
                <th>Message</th>
              </tr>
            </thead>
            <tbody>
              <% if (!lifecycleAnomalies.length) { %>
                <tr><td colspan="5" class="text-center text-muted py-3">No anomalies detected.</td></tr>
              <% } %>
              <% lifecycleAnomalies.forEach((row) => { %>
                <tr>
                  <td><span class="badge bg-danger"><%= row?.type || '-' %></span></td>
                  <td>
                    <div class="small fw-bold"><%= row?.questionTitle || row?.questionVersionId || row?.itemId || '-' %></div>
                    <div class="x-small text-muted font-monospace"><%= row?.itemId || '-' %></div>
                  </td>
                  <td class="small"><%= row?.eventAt ? new Date(row.eventAt).toLocaleString() : '-' %></td>
                  <td class="x-small font-monospace"><%= row?.eventType || '-' %> / <%= row?.eventId || '-' %></td>
                  <td class="small"><%= row?.message || '-' %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

        <details class="border rounded p-3 bg-light-subtle mb-3">
          <summary class="fw-bold">Diagnostics: Attempt Items (<%= detailItems.length %>)</summary>
          <div class="table-responsive mt-3">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Question</th>
                  <th>Status</th>
                  <th>Score</th>
                  <th>Time</th>
                </tr>
              </thead>
              <tbody>
                <% if (!detailItems.length) { %>
                  <tr><td colspan="5" class="text-center text-muted py-3">No items found for this session.</td></tr>
                <% } %>
                <% detailItems.forEach((item) => { %>
                  <tr>
                    <td><%= Number(item.questionOrder || 0) %></td>
                    <td>
                      <div class="small fw-bold"><%= item.question?.title || item.metadata?.questionTitle || item.questionVersionId || '-' %></div>
                      <div class="x-small text-muted text-capitalize"><%= item.skill || '-' %> / <%= String(item.questionType || '-').replace(/_/g, ' ') %></div>
                      <div class="x-small text-muted font-monospace"><%= item.questionVersionId || '-' %></div>
                    </td>
                    <td><span class="badge <%= String(item.status || '').toLowerCase().includes('submit') || String(item.status || '').toLowerCase() === 'scored' ? 'bg-success' : 'bg-secondary' %>"><%= item.status || '-' %></span></td>
                    <td class="small"><%= Number(item.scoreFinal || 0).toFixed(2) %> / <%= Number(item.maxScore || 0).toFixed(2) %></td>
                    <td class="small"><%= Number(item.timeSpentSeconds || 0) %> sec</td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </details>

        <% if (scoringItems.length) { %>
          <details class="border rounded p-3 bg-light-subtle mb-3" open>
            <summary class="fw-bold">Scoring Evidence (<%= scoringItems.length %>)</summary>
            <div class="row g-3 mt-1">
              <% scoringItems.forEach((item) => { %>
                <% const scoring = item?.metadata?.scoring || {}; %>
                <% const draft = scoring?.feedbackDraft && typeof scoring.feedbackDraft === 'object' ? scoring.feedbackDraft : null; %>
                <div class="col-lg-6">
                  <div class="border rounded p-3 bg-white h-100">
                    <div class="d-flex align-items-start justify-content-between gap-2 mb-2">
                      <div>
                        <div class="small fw-bold"><%= item.question?.title || item.metadata?.questionTitle || item.questionVersionId || '-' %></div>
                        <div class="x-small text-muted text-capitalize"><%= String(item.questionType || '-').replace(/_/g, ' ') %> | <span class="font-monospace"><%= item.id || '-' %></span></div>
                      </div>
                      <span class="badge <%= scoring.status === 'scored' ? 'bg-success' : (scoring.status === 'needs_evidence' ? 'bg-warning text-dark' : 'bg-danger') %> text-capitalize"><%= String(scoring.status || '-').replace(/_/g, ' ') %></span>
                    </div>
                    <div class="row g-2 small mb-2">
                      <div class="col-6"><strong>Score:</strong> <%= Number(item.scoreFinal || 0).toFixed(2) %> / <%= Number(item.maxScore || 0).toFixed(2) %></div>
                      <div class="col-6"><strong>Content:</strong> <%= Number(item.traitScores?.content || 0) %> / <%= Number(scoring?.alignment?.contentMax || scoring?.sourceWordCount || 0) %></div>
                      <div class="col-6"><strong>Pronunciation:</strong> <%= Number(item.traitScores?.pronunciation || 0) %> / 5</div>
                      <div class="col-6"><strong>Fluency:</strong> <%= Number(item.traitScores?.fluency || 0) %> / 5</div>
                      <div class="col-6"><strong>Errors:</strong> <%= Number(scoring?.alignment?.errorCount || 0) %></div>
                      <div class="col-6"><strong>WPM:</strong> <%= Number(scoring?.speechMetrics?.estimatedWpm || 0).toFixed(2) %></div>
                    </div>
                    <% if (draft) { %>
                      <div class="small fw-bold mb-1">Feedback Draft</div>
                      <div class="small mb-1"><%= draft.summary || '-' %></div>
                      <% if (Array.isArray(draft.nextPracticeAction) && draft.nextPracticeAction.length) { %>
                        <div class="small"><%= draft.nextPracticeAction.join(' ') %></div>
                      <% } else if (draft.nextPracticeAction) { %>
                        <div class="small"><%= draft.nextPracticeAction %></div>
                      <% } %>
                    <% } %>
                    <details class="mt-2">
                      <summary class="small fw-bold">Raw Metadata</summary>
                      <pre class="small mb-0 mt-2"><%= formatJson(scoring) %></pre>
                    </details>
                  </div>
                </div>
              <% }) %>
            </div>
          </details>
        <% } %>

        <details class="border rounded p-3 bg-light-subtle mb-3">
          <summary class="fw-bold">Diagnostics: Artifacts (<%= detailArtifacts.length %>)</summary>
          <div class="table-responsive mt-3">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th>Created</th>
                  <th>Item</th>
                  <th>Type</th>
                  <th>Name</th>
                  <th>MIME</th>
                  <th>Size</th>
                  <th>Duration</th>
                  <th>URL</th>
                  <th>Saved Path</th>
                </tr>
              </thead>
              <tbody>
                <% if (!detailArtifacts.length) { %>
                  <tr><td colspan="9" class="text-center text-muted py-3">No artifacts recorded.</td></tr>
                <% } %>
                <% detailArtifacts.forEach((artifact) => { %>
                  <tr>
                    <td class="small"><%= artifact.createdAt ? new Date(artifact.createdAt).toLocaleString() : '-' %></td>
                    <td class="x-small font-monospace"><%= artifact.attemptItemId || '-' %></td>
                    <td><span class="badge bg-secondary text-capitalize"><%= artifact.artifactType || '-' %></span></td>
                    <td>
                      <div class="small fw-bold"><%= artifact.name || '-' %></div>
                      <div class="x-small text-muted font-monospace"><%= artifact.id || '-' %></div>
                    </td>
                    <td class="x-small font-monospace"><%= artifact.mimeType || '-' %></td>
                    <td class="small"><%= formatBytes(artifact.sizeBytes) %></td>
                    <td class="small"><%= Number(artifact.durationSeconds || 0).toFixed(2) %> sec</td>
                    <td class="x-small font-monospace" style="max-width: 260px; word-break: break-all;"><%= artifact.url || '-' %></td>
                    <td class="x-small font-monospace" style="max-width: 320px; word-break: break-all;"><%= artifact.path || '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </details>

        <details class="border rounded p-3 bg-light-subtle mb-3">
          <summary class="fw-bold">Diagnostics: Event Timeline (<%= detailEvents.length %>)</summary>
          <div class="table-responsive mt-3">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th>Event At</th>
                  <th>Type</th>
                  <th>Item</th>
                  <th>Score</th>
                  <th>Source</th>
                </tr>
              </thead>
              <tbody>
                <% if (!detailEvents.length) { %>
                  <tr><td colspan="5" class="text-center text-muted py-3">No events recorded.</td></tr>
                <% } %>
                <% detailEvents.forEach((event) => { %>
                  <tr>
                    <td class="small"><%= event.eventAt ? new Date(event.eventAt).toLocaleString() : '-' %></td>
                    <td><span class="badge bg-secondary text-capitalize"><%= event.eventType || '-' %></span></td>
                    <td class="small font-monospace"><%= event.attemptItemId || '-' %></td>
                    <td class="small"><%= Number(event.scoreFinal || 0).toFixed(2) %></td>
                    <td class="x-small font-monospace"><%= event.source?.eventId || '-' %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </details>

        <details class="border rounded p-3 bg-light-subtle">
          <summary class="fw-bold">Raw Detail Dump</summary>
          <div class="d-flex flex-column gap-2 mt-3">
            <details class="border rounded p-2 bg-white">
              <summary class="fw-bold">Session JSON</summary>
              <pre class="small mb-0 mt-2"><%= formatJson(detailSession) %></pre>
            </details>
            <details class="border rounded p-2 bg-white">
              <summary class="fw-bold">Lifecycle JSON</summary>
              <pre class="small mb-0 mt-2"><%= formatJson(lifecycle) %></pre>
            </details>
            <details class="border rounded p-2 bg-white">
              <summary class="fw-bold">Items JSON (<%= detailItems.length %>)</summary>
              <pre class="small mb-0 mt-2"><%= formatJson(detailItems) %></pre>
            </details>
            <details class="border rounded p-2 bg-white">
              <summary class="fw-bold">Artifacts JSON (<%= detailArtifacts.length %>)</summary>
              <pre class="small mb-0 mt-2"><%= formatJson(detailArtifacts) %></pre>
            </details>
            <details class="border rounded p-2 bg-white">
              <summary class="fw-bold">Events JSON (<%= detailEvents.length %>)</summary>
              <pre class="small mb-0 mt-2"><%= formatJson(detailEvents) %></pre>
            </details>
          </div>
        </details>
      <% } %>
    </div>
  </div>
</div>

<%- include('../../partials/modal_GenericPicker', { user }) %>

<script>
(() => {
  const selectedUsers = <%- JSON.stringify(selectedUsersRows || []).replace(/</g, '\\u003c') %>;
  const filterForm = document.getElementById('pteAttemptDetailsFilterForm');
  if (!filterForm) return;

  const selectedBox = document.getElementById('attemptDetailSelectedUserBox');
  const pickBtn = document.getElementById('btnPickAttemptDetailUser');
  const clearBtn = document.getElementById('btnClearAttemptDetailUser');

  function initCollapseToggleIcon(options = {}) {
    const collapseEl = document.getElementById(String(options.collapseId || ''));
    const buttonEl = document.getElementById(String(options.buttonId || ''));
    const iconEl = document.getElementById(String(options.iconId || ''));
    if (!collapseEl || !buttonEl || !iconEl) return;

    const openIcon = String(options.openIcon || 'bi-chevron-down');
    const closeIcon = String(options.closeIcon || 'bi-chevron-up');
    const openLabel = String(options.openLabel || 'Open filters');
    const closeLabel = String(options.closeLabel || 'Close filters');

    const setState = (expanded) => {
      iconEl.classList.remove(openIcon, closeIcon);
      iconEl.classList.add(expanded ? closeIcon : openIcon);
      buttonEl.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      buttonEl.setAttribute('aria-label', expanded ? closeLabel : openLabel);
    };

    setState(collapseEl.classList.contains('show'));
    collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
    collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
  }

  initCollapseToggleIcon({
    collapseId: 'pteAttemptDetailsFilterCollapse',
    buttonId: 'pteAttemptDetailsFilterToggleBtn',
    iconId: 'pteAttemptDetailsFilterToggleIcon',
    openIcon: 'bi-chevron-down',
    closeIcon: 'bi-chevron-up',
    openLabel: 'Open filters',
    closeLabel: 'Close filters'
  });

  function esc(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function normalizeId(value) {
    return String(value || '').trim();
  }

  function setUser(row) {
    const id = normalizeId(row?.id);
    if (!id) return;
    selectedUsers.length = 0;
    selectedUsers.push({
      id,
      name: String(row?.name || row?.username || row?.email || id).trim(),
      username: String(row?.username || '').trim(),
      email: String(row?.email || '').trim()
    });
    renderSelectedUser();
  }

  function renderSelectedUser() {
    if (!selectedBox) return;
    if (!selectedUsers.length) {
      selectedBox.innerHTML = '<div class="text-muted">No specific user selected.</div>';
      return;
    }
    const row = selectedUsers[0];
    const id = normalizeId(row?.id);
    const label = String(row?.name || row?.username || row?.email || id).trim() || id;
    selectedBox.innerHTML = ''
      + '<div class="d-flex align-items-center justify-content-between gap-2 border rounded bg-white px-2 py-1">'
      + '  <div>'
      + '    <div class="fw-bold">' + esc(label) + '</div>'
      + '    <div class="x-small text-muted font-monospace">' + esc(id) + '</div>'
      + '    <input type="hidden" name="userId" value="' + esc(id) + '">'
      + '  </div>'
      + '  <button type="button" class="btn btn-outline-danger btn-sm" id="attemptDetailsRemoveUser"><i class="bi bi-x-lg"></i></button>'
      + '</div>';
    const removeBtn = document.getElementById('attemptDetailsRemoveUser');
    removeBtn?.addEventListener('click', () => {
      selectedUsers.length = 0;
      renderSelectedUser();
    });
  }

  pickBtn?.addEventListener('click', () => {
    if (!window.GenericPicker || !window.GenericPickerPresets) return;
    const contexts = window.GenericPickerContexts || {};
    const context = (typeof contexts.activeOrganizationScope === 'function')
      ? contexts.activeOrganizationScope({ label: 'Active Organization' })
      : null;
    window.GenericPicker.open(window.GenericPickerPresets.user({
      title: 'Select User',
      apiEndpoint: '/pte/attempt/ledger/picker/users',
      placeholder: 'Search users by name, username, email, or id...',
      multiselect: false,
      context,
      onSelect: (item) => {
        const selected = Array.isArray(item) ? item[0] : item;
        setUser(selected);
      }
    }));
  });

  clearBtn?.addEventListener('click', () => {
    selectedUsers.length = 0;
    renderSelectedUser();
  });

  renderSelectedUser();
})();
</script>
