<%
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const session = detail?.session || {};
  const rows = Array.isArray(detail?.items) ? detail.items : [];
  const summary = detail?.feedbackSummary || {};
  const sessionId = String(session?.id || '').trim();
  const attemptSkill = String(session?.metadata?.practice?.skill || '').trim().toLowerCase();
  const attemptStatus = String(session?.status || '').trim().toLowerCase();

  const escapeHtml = (value) => String(value == null ? '' : value)
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
  const toText = (value) => String(value == null ? '' : value).replace(/\0/g, '').trim();
  const toParagraph = (value) => escapeHtml(toText(value)).replace(/\r?\n/g, '<br>');
  const isObject = (value) => value && typeof value === 'object' && !Array.isArray(value);

  const formatQuestionTypeLabel = (value) => String(value || '')
    .trim()
    .toLowerCase()
    .split('_')
    .filter(Boolean)
    .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
    .join(' ');

  const normalizePromptToken = (value) => toText(value).toLowerCase().replace(/\s+/g, ' ').trim();

  function buildPromptContext(item) {
    const question = isObject(item?.question) ? item.question : {};
    const metadata = isObject(item?.metadata) ? item.metadata : {};
    const payload = isObject(question?.payload)
      ? question.payload
      : (
        isObject(metadata?.questionPayload)
          ? metadata.questionPayload
          : (isObject(metadata?.payload) ? metadata.payload : {})
      );
    const seenTokens = new Set();
    const context = {
      instruction: '',
      situations: [],
      body: ''
    };

    const remember = (value) => {
      const token = normalizePromptToken(value);
      if (!token) return false;
      if (seenTokens.has(token)) return false;
      seenTokens.add(token);
      return true;
    };

    const instruction = toText(payload.instructions || question.instructions || question.instructionText || '');
    if (instruction) {
      context.instruction = instruction;
      remember(instruction);
    }

    const situations = [];
    const addSituation = (value) => {
      const raw = toText(value);
      if (!raw) return;
      const body = toText(raw.replace(/^situation\s*:\s*/i, '')) || raw;
      if (!remember(body)) return;
      situations.push(body);
    };
    addSituation(payload.situationText);
    addSituation(payload.scenarioText);
    const promptText = toText(payload.promptText);
    if (/^situation\s*:/i.test(promptText)) addSituation(promptText);
    context.situations = situations;

    const bodyRows = [];
    const addBody = (value) => {
      const text = toText(value);
      if (!text) return;
      if (!remember(text)) return;
      bodyRows.push(text);
    };
    [
      payload.sourceText,
      payload.stem,
      payload.taskText,
      payload.taskBody,
      payload.questionText,
      payload.promptTextOrAudio,
      /^situation\s*:/i.test(promptText) ? '' : promptText,
      payload.transcriptWithBlanks,
      payload.passageWithBlanks,
      payload.passageHtml,
      payload.passage,
      payload.itemPrompt,
      payload.expectedTranscript
    ].forEach(addBody);
    context.body = toText(bodyRows.join('\n\n'));
    return context;
  }
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="page-heading size-md m-0"><i class="bi bi-chat-left-text me-2"></i>Attempt Feedback</h1>
      <div class="small text-muted mt-1">
        Session <span class="font-monospace"><%= sessionId || '-' %></span>
        <% if (attemptSkill) { %>| Skill: <span class="text-capitalize"><%= attemptSkill %></span><% } %>
        | Status: <span class="text-capitalize"><%= attemptStatus || '-' %></span>
      </div>
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <a href="<%= dashboardHref %>" class="btn btn-filled btn-secondary btn-md"><i class="bi bi-speedometer2 me-1"></i> PTE Dashboard</a>
      <a href="/pte/practice/attempts" class="btn btn-outline-secondary btn-md"><i class="bi bi-arrow-left me-1"></i> Back to Attempts</a>
      <a href="/pte/practice/attempts/<%= encodeURIComponent(sessionId) %>/details" class="btn btn-outline-primary btn-md"><i class="bi bi-diagram-3 me-1"></i> Lifecycle Details</a>
      <a href="/pte/practice/session/<%= encodeURIComponent(sessionId) %>" class="btn btn-outline-primary btn-md"><i class="bi bi-play-circle me-1"></i> Open Session</a>
    </div>
  </div>

  <div class="alert border <%= summary?.wasUnreadBeforeOpen ? 'alert-warning' : 'alert-light' %> mb-3">
    <div class="row g-2 small">
      <div class="col-md-4"><strong>Feedback Count:</strong> <%= Number(summary?.feedbackCount || 0) %></div>
      <div class="col-md-4"><strong>Latest Feedback:</strong> <%= summary?.latestFeedbackAtDisplay || '-' %></div>
      <div class="col-md-4"><strong>Previously Viewed:</strong> <%= summary?.previouslyViewedAtDisplay || '-' %></div>
    </div>
    <% if (summary?.wasUnreadBeforeOpen) { %>
      <div class="mt-2 small">This feedback was new and has now been marked as viewed.</div>
    <% } %>
  </div>

  <% if (!rows.length) { %>
    <div class="alert alert-warning border">No question rows were found for this attempt.</div>
  <% } %>

  <% rows.forEach((item, index) => { %>
    <% const question = item?.question || {}; %>
    <% const context = buildPromptContext(item); %>
    <% const itemId = toText(item?.id || ''); %>
    <% const questionTitle = toText(question?.title || item?.metadata?.questionTitle || `Question ${index + 1}`); %>
    <% const questionType = toText(question?.questionType || item?.questionType || ''); %>
    <% const questionSkill = toText(question?.skill || item?.skill || ''); %>
    <% const feedbackHtml = String(item?.latestFeedback || ''); %>
    <% const feedbackStamp = toText(item?.feedbackProvidedAt); %>
    <% const hasFeedback = Boolean(feedbackHtml || feedbackStamp); %>
    <% const scoring = item?.metadata && typeof item.metadata === 'object' && item.metadata.scoring && typeof item.metadata.scoring === 'object' ? item.metadata.scoring : null; %>
    <% const scoringDraft = scoring?.feedbackDraft && typeof scoring.feedbackDraft === 'object' ? scoring.feedbackDraft : null; %>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-light d-flex align-items-start justify-content-between flex-wrap gap-2">
        <div>
          <div class="fw-bold"><%= index + 1 %>. <%= questionTitle || '-' %></div>
          <div class="small text-muted">
            <span class="text-capitalize"><%= questionSkill || '-' %></span>
            | <%= formatQuestionTypeLabel(questionType) || '-' %>
            | Item <span class="font-monospace"><%= itemId || '-' %></span>
          </div>
        </div>
        <div class="small text-end">
          <div class="text-capitalize">Status: <strong><%= toText(item?.status || '-').replace(/_/g, ' ') %></strong></div>
          <div>Feedback At: <%= feedbackStamp || '-' %></div>
        </div>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-lg-6">
            <h6 class="fw-bold mb-2">Prompt Context</h6>
            <div class="border rounded p-2 bg-light-subtle mb-2">
              <div class="small text-muted fw-bold mb-1">Instruction</div>
              <div class="small"><%- context.instruction ? toParagraph(context.instruction) : '<span class="text-muted">No instruction text.</span>' %></div>
            </div>
            <% if (context.situations.length) { %>
              <% context.situations.forEach((row) => { %>
                <div class="border rounded p-2 bg-white mb-2">
                  <div class="small text-muted fw-bold mb-1">Situation</div>
                  <div class="small"><%- toParagraph(row) %></div>
                </div>
              <% }) %>
            <% } %>
            <div class="border rounded p-2 bg-light-subtle">
              <div class="small text-muted fw-bold mb-1">Question / Task</div>
              <div class="small"><%- context.body ? toParagraph(context.body) : '<span class="text-muted">No prompt text captured.</span>' %></div>
            </div>
          </div>
          <div class="col-lg-6">
            <% if (scoring) { %>
              <h6 class="fw-bold mb-2">Automatic Scoring Draft</h6>
              <div class="border rounded p-3 bg-light-subtle mb-3">
                <div class="d-flex align-items-center justify-content-between gap-2 mb-2">
                  <div class="small text-muted"><%= scoring.scorerVersion || 'pte-read-aloud-v1' %></div>
                  <span class="badge <%= scoring.status === 'scored' ? 'bg-success' : (scoring.status === 'needs_evidence' ? 'bg-warning text-dark' : 'bg-danger') %> text-capitalize"><%= String(scoring.status || '-').replace(/_/g, ' ') %></span>
                </div>
                <div class="row g-2 small mb-2">
                  <div class="col-6"><strong>Score:</strong> <%= Number(item?.scoreFinal || 0).toFixed(2) %> / <%= Number(item?.maxScore || 0).toFixed(2) %></div>
                  <div class="col-6"><strong>Errors:</strong> <%= Number(scoring?.alignment?.errorCount || 0) %></div>
                  <div class="col-6"><strong>Pronunciation:</strong> <%= Number(item?.traitScores?.pronunciation || 0) %> / 5</div>
                  <div class="col-6"><strong>Fluency:</strong> <%= Number(item?.traitScores?.fluency || 0) %> / 5</div>
                </div>
                <% if (scoringDraft) { %>
                  <div class="small fw-bold mb-1">Draft Notes</div>
                  <div class="small mb-1"><%- scoringDraft.summary ? toParagraph(scoringDraft.summary) : '' %></div>
                  <% if (Array.isArray(scoringDraft.improvements) && scoringDraft.improvements.length) { %>
                    <ul class="small mb-1 ps-3">
                      <% scoringDraft.improvements.slice(0, 3).forEach((row) => { %>
                        <li><%= row %></li>
                      <% }) %>
                    </ul>
                  <% } %>
                  <% if (scoringDraft.nextPracticeAction) { %>
                    <div class="small"><strong>Next:</strong> <%- toParagraph(scoringDraft.nextPracticeAction) %></div>
                  <% } %>
                <% } %>
              </div>
            <% } %>
            <h6 class="fw-bold mb-2">Teacher / Facilitator Feedback</h6>
            <script type="application/json" id="practice_feedback_payload_<%= itemId %>"><%- JSON.stringify(feedbackHtml || '').replace(/</g, '\\u003c') %></script>
            <div
              class="border rounded p-3 bg-white pte-student-feedback-sanitized"
              data-feedback-key="<%= itemId %>">
            </div>
            <% if (!hasFeedback) { %>
              <div class="small text-muted mt-2">No feedback has been posted for this question yet.</div>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  <% }) %>
</div>

<script src="https://cdn.jsdelivr.net/npm/dompurify@3.2.6/dist/purify.min.js"></script>
<script>
(() => {
  function sanitizeHtml(html) {
    if (window.DOMPurify && typeof window.DOMPurify.sanitize === 'function') {
      return window.DOMPurify.sanitize(String(html || ''));
    }
    return String(html || '');
  }

  function readFeedbackPayloadByKey(key) {
    const node = document.getElementById('practice_feedback_payload_' + key);
    if (!node) return '';
    try {
      return String(JSON.parse(node.textContent || '""') || '');
    } catch (_) {
      return '';
    }
  }

  document.querySelectorAll('.pte-student-feedback-sanitized').forEach((node) => {
    const key = String(node.getAttribute('data-feedback-key') || '').trim();
    const raw = readFeedbackPayloadByKey(key);
    const clean = sanitizeHtml(raw);
    node.innerHTML = clean || '<div class="text-muted">No feedback has been provided yet.</div>';
  });
})();
</script>
