<%
  const rows = Array.isArray(tests) ? tests : [];
  const active = activeSession && typeof activeSession === 'object' ? activeSession : null;
  const fmtSkill = (value) => {
    const token = String(value || '').trim().toLowerCase();
    return token ? token.charAt(0).toUpperCase() + token.slice(1) : '-';
  };
  const fmtDate = (value) => {
    const token = String(value || '').trim();
    if (!token) return '-';
    return typeof formatOrgDateTime === 'function' ? formatOrgDateTime(token) : token;
  };
%>

<div class="sections-page">
  <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="page-heading size-md m-0"><i class="bi bi-pc-display-horizontal me-2"></i>PTE MOCK EXAMS</h1>
      <div class="text-muted mt-2">Select one published registered PTE test and run it in strict mock-exam mode.</div>
    </div>
    <a href="/pte/practice/by-skills" class="btn btn-outline-secondary btn-md">
      <i class="bi bi-bullseye me-1"></i> Practice By Skills
    </a>
  </div>

  <% if (active) { %>
    <div class="card border-warning shadow-sm mb-3">
      <div class="card-body d-flex align-items-center justify-content-between flex-wrap gap-3">
        <div>
          <div class="fw-bold text-warning-emphasis"><i class="bi bi-exclamation-triangle-fill me-1"></i> In-progress mock exam</div>
          <div class="text-muted small">
            Session <span class="font-monospace"><%= active.id %></span>
            <% if (active?.metadata?.mockExam?.testTitle) { %>
              | <%= active.metadata.mockExam.testTitle %>
            <% } %>
          </div>
        </div>
        <a href="/pte/practice/mock-exams/session/<%= encodeURIComponent(active.id) %>" class="btn btn-filled btn-warning">
          Continue Exam <i class="bi bi-arrow-right ms-1"></i>
        </a>
      </div>
    </div>
  <% } %>

  <div class="row g-3">
    <% if (!rows.length) { %>
      <div class="col-12">
        <div class="alert alert-info mb-0">No published PTE tests are available for mock exams in the current organization.</div>
      </div>
    <% } %>

    <% rows.forEach((test) => { %>
      <% const errors = Array.isArray(test?.validationState?.errors) ? test.validationState.errors : []; %>
      <% const warnings = Array.isArray(test?.validationState?.warnings) ? test.validationState.warnings : []; %>
      <div class="col-12 col-xl-6">
        <div class="card h-100 border-0 shadow-sm">
          <div class="card-body d-flex flex-column gap-3">
            <div class="d-flex align-items-start justify-content-between gap-2">
              <div>
                <h2 class="h5 fw-bold mb-1"><%= test.title %></h2>
                <div class="small text-muted">
                  <span class="font-monospace"><%= test.code || test.id %></span>
                  | Rev <%= test.revisionNumber || 1 %>
                  | Published <%= fmtDate(test.publishedAt) %>
                </div>
              </div>
              <span class="badge <%= test.ready ? 'bg-success-subtle text-success-emphasis' : 'bg-danger-subtle text-danger-emphasis' %> border">
                <%= test.ready ? 'Ready' : 'Blocked' %>
              </span>
            </div>

            <div class="d-flex flex-wrap gap-2">
              <span class="badge bg-primary-subtle text-primary-emphasis border"><%= test.detectedTestTypeLabel || 'PTE Academic' %></span>
              <span class="badge bg-light text-dark border"><%= test.questionCount || 0 %> questions</span>
              <span class="badge bg-light text-dark border"><%= test.estimatedMinutes || '-' %> min estimate</span>
            </div>

            <div class="row g-2 small">
              <% Object.entries(test.skillCoverage || {}).forEach(([skill, count]) => { %>
                <div class="col-6">
                  <div class="border rounded p-2 bg-light-subtle d-flex justify-content-between">
                    <span><%= fmtSkill(skill) %></span>
                    <strong><%= count || 0 %></strong>
                  </div>
                </div>
              <% }) %>
            </div>

            <% if (warnings.length) { %>
              <div class="alert alert-warning small mb-0">
                <strong>Warnings:</strong> <%= warnings.slice(0, 2).join(' ') %><%= warnings.length > 2 ? ' ...' : '' %>
              </div>
            <% } %>

            <% if (errors.length) { %>
              <div class="alert alert-danger small mb-0">
                <strong>Cannot start:</strong> <%= errors.slice(0, 3).join(' ') %><%= errors.length > 3 ? ' ...' : '' %>
              </div>
            <% } %>

            <div class="mt-auto d-flex justify-content-end">
              <% if (test.ready && !active) { %>
                <a href="/pte/practice/mock-exams/<%= encodeURIComponent(test.id) %>/ready" class="btn btn-filled btn-primary">
                  Start Setup <i class="bi bi-arrow-right ms-1"></i>
                </a>
              <% } else { %>
                <button type="button" class="btn btn-outline-secondary" disabled>
                  <%= active ? 'Finish active exam first' : 'Not ready' %>
                </button>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    <% }) %>
  </div>
</div>
