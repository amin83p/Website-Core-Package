  function refreshFillBlankWordBankAvailability() {
    const chips = Array.from(nodes.response?.querySelectorAll('[data-fill-blank-chip]') || []);
    if (!chips.length) return;

    const inputs = Array.from(nodes.response?.querySelectorAll('input[data-response-blank-input][data-drag-fill-blank="1"]') || []);
    const usedCounts = new Map();
    inputs.forEach((input) => {
      const token = clean(input.value).toLowerCase();
      if (!token) return;
      usedCounts.set(token, (usedCounts.get(token) || 0) + 1);
    });

    const consumedCounts = new Map();
    chips.forEach((chip) => {
      const token = clean(chip.getAttribute('data-fill-blank-value') || chip.textContent || '').toLowerCase();
      if (!token) return;
      const consumedIndex = (consumedCounts.get(token) || 0) + 1;
      consumedCounts.set(token, consumedIndex);
      const consumed = consumedIndex <= (usedCounts.get(token) || 0);
      chip.classList.toggle('d-none', consumed);
      chip.classList.toggle('is-consumed', consumed);
      chip.setAttribute('aria-hidden', consumed ? 'true' : 'false');
      if (consumed) chip.classList.remove('is-dragging');
    });

    const selectedVisibleChip = chips.find((chip) => chip.classList.contains('is-selected') && !chip.classList.contains('d-none'));
    if (!selectedVisibleChip) setFillBlankChipSelection(null);
