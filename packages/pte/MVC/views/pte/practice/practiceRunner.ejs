    showNotesButton = false,
    notesButtonLabel = 'Notes',
    showTranscriptButton = false,
    transcriptButtonLabel = 'Transcript',
    transcriptText = ''
  } = {}) {
    const normalizedUrl = normalizePlayableMediaUrl(audioUrl);
    if (!normalizedUrl) return '';
    const normalizedMimeType = normalizeAudioMimeType(mimeType);
    const normalizedLabel = clean(label);
    const normalizedTranscript = normalizeTranscriptForPromptDisplay(transcriptText);
    const hasTranscriptText = !!normalizedTranscript;
    const safePlayDelaySeconds = Math.max(0, toInt(playDelaySeconds, 0));
    const safePostCountdownDelaySeconds = Math.max(0, toInt(postCountdownDelaySeconds, 0));
    const panelClass = bordered
      ? 'pte-audio-panel border rounded p-3'
      : 'pte-audio-panel pte-audio-panel-flat';
    const transcriptPanelId = `pteAudioTranscript_${Math.random().toString(36).slice(2, 10)}`;
    return ''
      + '<div class="pte-prompt-media-block mb-3" data-prompt-audio-player data-audio-play-delay-seconds="' + String(safePlayDelaySeconds) + '" data-audio-post-countdown-delay-seconds="' + String(safePostCountdownDelaySeconds) + '">'
      + (normalizedLabel ? ('  <div class="pte-audio-label">' + esc(normalizedLabel) + '</div>') : '')
      + '  <audio data-prompt-audio preload="auto" controlsList="nodownload noplaybackrate" disableRemotePlayback' + (autoPlay ? ' autoplay' : '') + '>'
      + '    <source src="' + esc(normalizedUrl) + '"' + (normalizedMimeType ? (' type="' + esc(normalizedMimeType) + '"') : '') + '>'
      + '  </audio>'
      + '  <div class="' + panelClass + '">'
      + '    <div class="pte-audio-top-row">'
      + '      <span class="badge bg-primary-subtle text-primary-emphasis border" data-audio-status><i class="bi bi-headphones me-1"></i><span data-audio-status-label>Ready</span></span>'
      + '      <span class="badge bg-light text-dark border pte-audio-time font-monospace" data-audio-time>00:00 / 00:00</span>'
      + '    </div>'
      + '    <div class="pte-audio-timer-display font-monospace" data-audio-timer-display>00:00</div>'
      + '    <div class="pte-audio-progress-wrap mb-3">'
      + '      <div class="progress" style="height:12px;">'
      + '        <div class="progress-bar bg-primary" data-audio-progress role="progressbar" style="width:0%;"></div>'
      + '      </div>'
      + '    </div>'
      + '    <div class="pte-audio-controls-row' + (showTranscriptButton ? ' has-transcript' : '') + '">'
      + '      <div class="pte-audio-controls-primary">'
      + '        <button type="button" class="btn btn-sm d-inline-flex align-items-center gap-1 pte-audio-btn" data-audio-toggle data-no-wait="true">'
      + '          <i class="bi bi-play-fill" data-audio-toggle-icon></i>'
      + '          <span data-audio-toggle-label>Play</span>'
      + '        </button>'
      + '        <button type="button" class="btn btn-sm d-inline-flex align-items-center gap-1 pte-audio-replay-btn" data-audio-replay data-no-wait="true">'
      + '          <i class="bi bi-arrow-repeat"></i><span>Replay</span>'
      + '        </button>'
      + '      </div>'
      + ((showNotesButton || showTranscriptButton)
        ? ('      <div class="pte-audio-controls-secondary">'
          + (showNotesButton
            ? ('        <button type="button" class="btn btn-sm d-inline-flex align-items-center gap-1 pte-audio-notes-btn" data-open-notes-panel data-no-wait="true">'
              + '          <i class="bi bi-journal-richtext"></i><span>' + esc(clean(notesButtonLabel) || 'Notes') + '</span>'
              + '        </button>')
            : '')
          + (showTranscriptButton
            ? ('        <button type="button" class="btn btn-sm d-inline-flex align-items-center gap-1 pte-audio-transcript-btn" data-audio-transcript-toggle data-audio-transcript-label="' + esc(clean(transcriptButtonLabel) || 'Transcript') + '" data-target="' + esc(transcriptPanelId) + '" aria-expanded="false" aria-controls="' + esc(transcriptPanelId) + '" data-no-wait="true"' + (hasTranscriptText ? '' : ' disabled') + '>'
              + '          <i class="bi bi-file-earmark-text"></i><span data-audio-transcript-toggle-label>' + esc(clean(transcriptButtonLabel) || 'Transcript') + '</span>'
              + '        </button>')
            : '')
          + '      </div>')
        : '')
      + '    </div>'
      + (showSinglePlayNote
        ? '    <div class="pte-audio-note-amber"><i class="bi bi-exclamation-triangle-fill"></i><span>This audio can only be played once in the real test.</span></div>'
        : '')
      + (showTranscriptButton
        ? ('    <div id="' + esc(transcriptPanelId) + '" class="pte-audio-transcript-panel d-none" data-audio-transcript-panel>'
          + '      <div class="pte-audio-transcript-title">Transcript</div>'
          + '      <div class="pte-audio-transcript-body">' + (hasTranscriptText ? nl2br(normalizedTranscript) : '<span class="text-muted">Transcript is not available for this question yet.</span>') + '</div>'
          + '    </div>')
        : '')
      + '  </div>'
      + '</div>';
  }

  function renderPromptAudioBlock(questionRow, assetRef, label = '', {
    autoPlay = false,
    showSinglePlayNote = true,
    playDelaySeconds = 0,
    postCountdownDelaySeconds = 1,
    showNotesButton = false,
    notesButtonLabel = 'Notes',
    showTranscriptButton = false,
    transcriptButtonLabel = 'Transcript',
    transcriptText = ''
  } = {}) {
    const audioUrl = resolveQuestionMediaUrl(questionRow, assetRef);
    return renderAudioPlayerBlockByUrl(audioUrl, label, {
      autoPlay,
      showSinglePlayNote,
      playDelaySeconds,
      postCountdownDelaySeconds,
      showNotesButton,
      notesButtonLabel,
      showTranscriptButton,
      transcriptButtonLabel,
      transcriptText
    });
  }

  function renderPromptImageBlock(questionRow, assetRef, label = 'Prompt Image', {
    showNotesButton = false,
    notesButtonLabel = 'Notes'
  } = {}) {
    const imageUrl = resolveQuestionMediaUrl(questionRow, assetRef);
    if (!imageUrl) return '';
    const normalizedLabel = clean(label);
    return ''
      + '<div class="mb-3">'
      + (normalizedLabel ? ('  <div class="small fw-bold text-uppercase text-muted mb-1">' + esc(normalizedLabel) + '</div>') : '')
      + '  <div class="pte-prompt-image-frame">'
      + '    <img src="' + esc(imageUrl) + '" alt="Question prompt image">'
      + (showNotesButton
        ? ('    <div class="pte-prompt-image-tools">'
          + '      <button type="button" class="btn btn-sm d-inline-flex align-items-center gap-1 pte-prompt-image-notes-btn" data-open-notes-panel data-no-wait="true">'
          + '        <i class="bi bi-journal-richtext"></i><span>' + esc(clean(notesButtonLabel) || 'Notes') + '</span>'
          + '      </button>'
          + '    </div>')
        : '')
      + '  </div>'
      + '</div>';
  }

  function getPromptAudioElement() {
    return nodes.prompt ? nodes.prompt.querySelector('audio[data-prompt-audio]') : null;
  }

  function stopPromptAudioPlayback({ reset = false } = {}) {
    const players = [nodes.prompt, nodes.response]
      .filter(Boolean)
      .flatMap((root) => Array.from(root.querySelectorAll('audio[data-prompt-audio]')));
    const wraps = [nodes.prompt, nodes.response]
      .filter(Boolean)
      .flatMap((root) => Array.from(root.querySelectorAll('[data-prompt-audio-player]')));
    wraps.forEach((wrap) => {
      if (wrap && typeof wrap.__cancelCountdown === 'function') {
        wrap.__cancelCountdown({ restoreReadyUi: true });
      }
    });
    players.forEach((audio) => {
      try {
        audio.pause();
        if (reset) audio.currentTime = 0;
      } catch (_) {}
    });
  }

  function initPromptAudioPlayers() {
    const roots = [nodes.prompt, nodes.response].filter(Boolean);
    roots.forEach((root) => {
      const wraps = Array.from(root.querySelectorAll('[data-prompt-audio-player]'));
      wraps.forEach((wrap) => {
        if (!wrap || wrap.dataset.bound === '1') return;
        const audio = wrap.querySelector('audio[data-prompt-audio]');
        const toggleBtn = wrap.querySelector('button[data-audio-toggle]');
        const toggleIcon = wrap.querySelector('[data-audio-toggle-icon]');
        const toggleLabel = wrap.querySelector('[data-audio-toggle-label]');
        const replayBtn = wrap.querySelector('button[data-audio-replay]');
        const transcriptToggleBtn = wrap.querySelector('button[data-audio-transcript-toggle]');
        const timeNode = wrap.querySelector('[data-audio-time]');
        const timerNode = wrap.querySelector('[data-audio-timer-display]');
        const progressNode = wrap.querySelector('[data-audio-progress]');
        const panel = wrap.querySelector('.pte-audio-panel');
        const statusWrap = wrap.querySelector('[data-audio-status]');
        const statusLabel = wrap.querySelector('[data-audio-status-label]');
        const transcriptPanel = wrap.querySelector('[data-audio-transcript-panel]');
        if (!audio || !toggleBtn || !timeNode) return;
        wrap.dataset.bound = '1';

        const playDelaySeconds = Math.max(0, toInt(wrap.dataset.audioPlayDelaySeconds, 0));
        const postCountdownDelaySeconds = Math.max(0, toInt(wrap.dataset.audioPostCountdownDelaySeconds, 0));
        let hasSuccessfulPlayback = false;
        let countdownIntervalHandle = null;
        let countdownRemainingSeconds = 0;
        let countdownActive = false;
        let countdownToken = 0;

        const clearCountdown = ({ restoreReadyUi = false } = {}) => {
          if (countdownIntervalHandle) {
            clearInterval(countdownIntervalHandle);
            countdownIntervalHandle = null;
          }
          countdownActive = false;
          countdownRemainingSeconds = 0;
          countdownToken += 1;
          if (restoreReadyUi) {
            renderToggleState();
            renderTimeState();
          }
        };

        wrap.__cancelCountdown = clearCountdown;

        const renderToggleState = () => {
          const playing = !audio.paused && !audio.ended;
          if (panel) {
            panel.classList.toggle('is-playing', playing);
            panel.classList.toggle('is-countdown', countdownActive);
          }
          if (toggleLabel) {
            toggleLabel.textContent = countdownActive
              ? 'Starting...'
              : (playing ? 'Pause' : 'Play');
          }
          if (toggleIcon) {
            toggleIcon.className = countdownActive
              ? 'bi bi-hourglass-split'
              : (playing ? 'bi bi-pause-fill' : 'bi bi-play-fill');
          }
          if (statusLabel) {
            statusLabel.textContent = countdownActive
              ? `Starting in ${Math.max(0, toInt(countdownRemainingSeconds, 0))}s`
              : (playing ? 'Playing' : (audio.ended ? 'Completed' : 'Ready'));
          }
          if (statusWrap) {
            statusWrap.setAttribute('aria-live', 'polite');
            statusWrap.classList.remove(
              'bg-primary-subtle',
              'text-primary-emphasis',
              'bg-success-subtle',
              'text-success-emphasis',
              'bg-secondary-subtle',
              'text-secondary-emphasis',
              'bg-warning-subtle',
              'text-warning-emphasis'
            );
            if (countdownActive) {
              statusWrap.classList.add('bg-warning-subtle', 'text-warning-emphasis');
            } else if (playing) {
              statusWrap.classList.add('bg-primary-subtle', 'text-primary-emphasis');
            } else if (audio.ended) {
              statusWrap.classList.add('bg-success-subtle', 'text-success-emphasis');
            } else {
              statusWrap.classList.add('bg-secondary-subtle', 'text-secondary-emphasis');
            }
          }
        };

        const renderTimeState = () => {
          if (countdownActive) {
            const remaining = Math.max(0, toInt(countdownRemainingSeconds, 0));
            timeNode.textContent = `Start in ${formatClock(remaining)}`;
            if (timerNode) timerNode.textContent = formatClock(remaining);
            if (progressNode) {
              const percent = playDelaySeconds > 0
                ? Math.max(0, Math.min(100, ((playDelaySeconds - remaining) / playDelaySeconds) * 100))
                : 0;
              progressNode.style.width = `${percent}%`;
            }
            return;
          }
          const duration = Number(audio.duration);
          const current = Number(audio.currentTime);
          const safeDuration = Number.isFinite(duration) && duration > 0 ? duration : 0;
          const safeCurrent = Number.isFinite(current) && current >= 0 ? current : 0;
          if (safeDuration > 0) {
            const percent = Math.max(0, Math.min(100, (safeCurrent / safeDuration) * 100));
            if (progressNode) progressNode.style.width = `${percent}%`;
          } else if (progressNode) {
            progressNode.style.width = '0%';
          }
          timeNode.textContent = `${formatClock(Math.round(safeCurrent))} / ${formatClock(Math.round(safeDuration))}`;
          if (timerNode) timerNode.textContent = formatClock(Math.round(safeCurrent));
        };

        const classifyAudioPlayError = (error) => {
          const name = clean(error && error.name).toLowerCase();
          const message = clean(error && error.message).toLowerCase();
          if (
            name === 'notallowederror'
            || message.includes('user didn')
            || message.includes('user gesture')
            || message.includes('autoplay')
            || message.includes('not allowed')
          ) {
            return 'blocked';
          }
          if (
            name === 'notsupportederror'
            || message.includes('no supported source')
            || message.includes('not supported')
            || message.includes('decode')
            || message.includes('decoding')
          ) {
            return 'unsupported';
          }
          if (name === 'aborterror') return 'interrupted';
          return 'unknown';
        };

        const waitForAudioPlayable = async (timeoutMs = 2500) => {
          if (Number(audio.readyState) >= 2) return;
          try { audio.load(); } catch (_) {}
          await new Promise((resolve) => {
            let done = false;
            const finalize = () => {
              if (done) return;
              done = true;
              cleanup();
              resolve();
            };
            const cleanup = () => {
              clearTimeout(timer);
              audio.removeEventListener('canplay', finalize);
              audio.removeEventListener('canplaythrough', finalize);
              audio.removeEventListener('loadeddata', finalize);
              audio.removeEventListener('error', finalize);
            };
            const timer = setTimeout(finalize, Math.max(400, toInt(timeoutMs, 2500)));
            audio.addEventListener('canplay', finalize, { once: true });
            audio.addEventListener('canplaythrough', finalize, { once: true });
            audio.addEventListener('loadeddata', finalize, { once: true });
            audio.addEventListener('error', finalize, { once: true });
          });
        };

        const primeFirstPlayback = async () => {
          if (hasSuccessfulPlayback) return;
          try { audio.currentTime = 0; } catch (_) {}
          await waitForAudioPlayable(2800);
          await new Promise((resolve) => setTimeout(resolve, 140));
        };

        const tryStartAudioPlayback = async () => {
          const sourceUrl = clean(audio.currentSrc || audio.src || '');
          if (!sourceUrl) {
            await showMessage('Audio Missing', 'This recording has no playable audio source. Please re-record and try again.', 'warning');
            return;
          }
          try {
            await primeFirstPlayback();
            if (Number(audio.readyState) < 2) await waitForAudioPlayable(2200);
            await audio.play();
            hasSuccessfulPlayback = true;
          } catch (error) {
            const playbackErrorType = classifyAudioPlayError(error);
            if (playbackErrorType === 'blocked') {
              await showMessage('Playback Blocked', 'Your browser blocked audio playback. Please click Play again.', 'warning');
              return;
            }
            if (playbackErrorType === 'unsupported') {
              await showMessage('Audio Format Not Supported', 'This browser cannot play this recording format. Please re-record or use a different browser.', 'warning');
              return;
            }
            if (playbackErrorType === 'interrupted') return;
            await showMessage('Playback Failed', 'Audio playback failed. Please click Play again.', 'warning');
          }
        };

        const playWithConfiguredDelay = async ({ replay = false } = {}) => {
          clearCountdown({ restoreReadyUi: false });
          if (replay) {
            try { audio.pause(); } catch (_) {}
            try { audio.currentTime = 0; } catch (_) {}
          }

          if (playDelaySeconds <= 0) {
            await tryStartAudioPlayback();
            return;
          }

          countdownActive = true;
          countdownRemainingSeconds = playDelaySeconds;
          const activeToken = countdownToken;
          renderToggleState();
          renderTimeState();

          countdownIntervalHandle = setInterval(async () => {
            if (activeToken !== countdownToken) return;
            countdownRemainingSeconds -= 1;
            if (countdownRemainingSeconds <= 0) {
              if (countdownIntervalHandle) {
                clearInterval(countdownIntervalHandle);
                countdownIntervalHandle = null;
              }
              countdownRemainingSeconds = 0;
              renderTimeState();
              const postDelayMs = Math.max(0, postCountdownDelaySeconds) * 1000;
              if (postDelayMs > 0) {
                await new Promise((resolve) => {
                  setTimeout(resolve, postDelayMs);
                });
                if (activeToken !== countdownToken) return;
              }
              countdownActive = false;
              renderToggleState();
              await tryStartAudioPlayback();
              if (audio.paused) renderTimeState();
              return;
            }
            renderToggleState();
            renderTimeState();
          }, 1000);
        };

        toggleBtn.addEventListener('click', async () => {
          if (countdownActive) {
            clearCountdown({ restoreReadyUi: true });
            return;
          }
          if (!audio.paused && !audio.ended) {
            try { audio.pause(); } catch (_) {}
            return;
          }
          if (strictMockExam && hasSuccessfulPlayback) {
            await showMessage('Audio Already Played', 'In strict mock exam mode, prompt audio can only be played once.', 'info');
            toggleBtn.disabled = true;
            return;
          }
          await playWithConfiguredDelay({ replay: false });
        });

        if (replayBtn) {
          replayBtn.addEventListener('click', async () => {
            if (strictMockExam) {
              await showMessage('Replay Blocked', 'In strict mock exam mode, prompt audio cannot be replayed.', 'info');
              return;
            }
            await playWithConfiguredDelay({ replay: true });
          });
        }

        if (transcriptToggleBtn && transcriptPanel) {
          transcriptToggleBtn.addEventListener('click', () => {
            const expanded = !transcriptPanel.classList.contains('d-none');
            transcriptPanel.classList.toggle('d-none', expanded);
            transcriptToggleBtn.setAttribute('aria-expanded', expanded ? 'false' : 'true');
            const labelNode = transcriptToggleBtn.querySelector('[data-audio-transcript-toggle-label]');
            const baseLabel = clean(transcriptToggleBtn.getAttribute('data-audio-transcript-label') || 'Transcript') || 'Transcript';
            if (labelNode) {
              labelNode.textContent = expanded ? baseLabel : ('Hide ' + baseLabel);
            }
          });
        }

        audio.addEventListener('loadedmetadata', renderTimeState);
        audio.addEventListener('timeupdate', renderTimeState);
        audio.addEventListener('durationchange', renderTimeState);
        audio.addEventListener('play', () => {
          clearCountdown({ restoreReadyUi: false });
          renderToggleState();
          renderTimeState();
        });
        audio.addEventListener('pause', () => {
          renderToggleState();
          renderTimeState();
        });
        audio.addEventListener('ended', () => {
          renderToggleState();
          renderTimeState();
          if (statusLabel) statusLabel.textContent = 'Completed';
          if (strictMockExam) {
            toggleBtn.disabled = true;
            if (toggleLabel) toggleLabel.textContent = 'Played';
            if (toggleIcon) toggleIcon.className = 'bi bi-check2-circle';
          }
        });
        audio.addEventListener('contextmenu', (event) => event.preventDefault());

        if (statusLabel) statusLabel.textContent = 'Ready';
        renderToggleState();
        renderTimeState();
      });
    });
  }

  function resolveTiming(payload = {}) {
    const source = payload && typeof payload === 'object' ? payload : {};
    const prepSeconds = Math.max(
      0,
      toInt(source.prepTimeSeconds, 0),
      toInt(source.preparationTimeSeconds, 0),
      toInt(source.prepSeconds, 0),
      parseMinutesToSeconds(source.planningTimeMinutes, 0)
    );
    const responseSeconds = Math.max(
      0,
      toInt(source.responseTimeSeconds, 0),
      toInt(source.recordingTimeSeconds, 0),
      toInt(source.answerTimeSeconds, 0),
      toInt(source.speakingTimeSeconds, 0),
      parseMinutesToSeconds(source.recommendedTimeMinutes, 0),
      toInt(source.timeLimitSeconds, 0)
    );
    return {
      prepSeconds,
      responseSeconds,
      hasTiming: prepSeconds > 0 || responseSeconds > 0
    };
  }

  function formatQuotaMetricLabel(value) {
    const token = clean(value).toLowerCase();
    if (!token) return 'Metric';
    return token
      .replace(/[_-]+/g, ' ')
      .replace(/\s+/g, ' ')
      .trim()
      .split(' ')
      .map((part) => (part ? (part.charAt(0).toUpperCase() + part.slice(1)) : ''))
      .join(' ');
  }

  function formatQuotaFailureMessage(message) {
    const raw = String(message == null ? '' : message);
    const normalized = clean(raw);
    if (!normalized) return '';

    if (!/insufficient activity quota/i.test(normalized)) {
      return raw;
    }

    const detailsMatch = normalized.match(/insufficient activity quota\s*:?\s*(.*)$/i);
    const detailsText = clean(detailsMatch && detailsMatch[1] ? detailsMatch[1] : '');
    const itemRegex = /([a-z_][a-z0-9_\-\s]*)\s*\(\s*need\s*([-+]?\d*\.?\d+)\s*,\s*available\s*([-+]?\d*\.?\d+)\s*\)/ig;
    const rows = [];
    let match;
    while ((match = itemRegex.exec(detailsText)) !== null) {
      const metric = formatQuotaMetricLabel(match[1]);
      const need = Number(match[2]);
      const available = Number(match[3]);
      const deficit = Number.isFinite(need) && Number.isFinite(available)
        ? Math.max(0, need - available)
        : null;
      rows.push({
        metric,
        need: Number.isFinite(need) ? need : clean(match[2]),
        available: Number.isFinite(available) ? available : clean(match[3]),
        deficit
      });
    }

    if (!rows.length) {
      return ''
        + '<div class="fw-bold text-dark mb-1">Insufficient Activity Quota</div>'
        + '<div class="fw-bold text-dark">' + esc(normalized) + '</div>';
    }

    const lineItems = rows.map((row) => {
      const needLabel = Number.isFinite(Number(row.need)) ? String(row.need) : clean(row.need);
      const availableLabel = Number.isFinite(Number(row.available)) ? String(row.available) : clean(row.available);
      const deficitLabel = row.deficit !== null ? String(row.deficit) : '-';
      return ''
        + '<div class="fw-bold text-dark">'
        + '  ' + esc(row.metric) + ': '
        + '  Need <span class="text-danger fw-bold">' + esc(needLabel) + '</span>'
        + '  | Available <span class="text-danger fw-bold">' + esc(availableLabel) + '</span>'
        + '  | Deficit <span class="text-danger fw-bold">' + esc(deficitLabel) + '</span>'
        + '</div>';
    }).join('');

    return ''
      + '<div class="fw-bold text-dark mb-1">Insufficient Activity Quota</div>'
      + '<div class="d-flex flex-column gap-1">' + lineItems + '</div>';
  }

  function showMessage(title, message, icon = 'info') {
    const displayMessage = formatQuotaFailureMessage(message);
    if (typeof window.showMessageModal === 'function') {
      return window.showMessageModal({
        title,
        message: displayMessage,
        icon,
        buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : 'btn-primary' }]
      });
    }
    return Promise.resolve();
  }

  function describeMicrophoneError(error) {
    const rawMessage = clean(error?.message || error || '', 600);
    const errorName = clean(error?.name || '').toLowerCase();
    const token = `${errorName} ${rawMessage}`.toLowerCase();
    const secureContext = !(typeof window !== 'undefined' && window.isSecureContext === false);

    if (!secureContext || token.includes('securityerror') || token.includes('secure context')) {
      return {
        key: 'insecure_context',
        inline: 'Microphone access requires HTTPS (or localhost) in a secure browser context.',
        title: 'Microphone Access Blocked',
        message: 'This page is not in a secure context.\nUse HTTPS (or localhost) and try again.'
      };
    }
    if (token.includes('notallowederror') || token.includes('permission denied') || token.includes('denied') || token.includes('permission')) {
      return {
        key: 'permission_denied',
        inline: 'Microphone permission is denied. Please allow microphone access and try again.',
        title: 'Microphone Permission Required',
        message: 'Microphone access is blocked for this site.\nPlease allow microphone in your browser site settings, then try Start Recording again.'
      };
    }
    if (token.includes('notfounderror') || token.includes('no microphone') || token.includes('device not found')) {
      return {
        key: 'device_not_found',
        inline: 'No microphone device was found.',
        title: 'No Microphone Detected',
        message: 'No microphone device was detected.\nConnect a microphone and try again.'
      };
    }
    if (token.includes('notreadableerror') || token.includes('could not start') || token.includes('track start') || token.includes('busy')) {
      return {
        key: 'device_busy',
        inline: 'Microphone is unavailable or currently in use by another app.',
        title: 'Microphone Unavailable',
        message: 'Microphone could not be started.\nClose other apps that use the microphone and try again.'
      };
    }
    if (token.includes('overconstrainederror') || token.includes('constraintnotsatisfiederror') || token.includes('invalid constraint') || token.includes('constraint')) {
      return {
        key: 'invalid_constraint',
        inline: 'Browser rejected microphone constraints. We will retry with compatibility settings.',
        title: 'Microphone Compatibility Issue',
        message: 'Your browser/device rejected the default microphone request (Invalid constraint).\nPlease retry. If it persists, reload the page or try another browser/device.'
      };
    }
    return {
      key: 'unknown',
      inline: rawMessage || 'Unable to start microphone recording.',
      title: 'Microphone Error',
      message: rawMessage || 'Unable to start microphone recording. Please try again.'
    };
  }

  function isConstraintFailure(error) {
    const name = clean(error?.name || '', 120).toLowerCase();
    const message = clean(error?.message || '', 400).toLowerCase();
    const constraint = clean(error?.constraint || '', 160).toLowerCase();
    return (
      name === 'overconstrainederror'
      || name === 'constraintnotsatisfiederror'
      || message.includes('invalid constraint')
      || (message.includes('constraint') && message.includes('invalid'))
      || Boolean(constraint)
    );
  }

  function hasLiveAudioTrack(stream) {
    if (!stream || typeof stream.getAudioTracks !== 'function') return false;
    const tracks = stream.getAudioTracks();
    if (!Array.isArray(tracks) || tracks.length === 0) return false;
    return tracks.some((track) => clean(track?.readyState || '').toLowerCase() !== 'ended');
  }

  function getLegacyGetUserMedia() {
    if (typeof navigator === 'undefined') return null;
    const fn = navigator.getUserMedia
      || navigator.webkitGetUserMedia
      || navigator.mozGetUserMedia
      || navigator.msGetUserMedia;
    return typeof fn === 'function' ? fn.bind(navigator) : null;
  }

  function isLikelySafariBrowser() {
    if (typeof navigator === 'undefined') return false;
    const ua = clean(navigator.userAgent || '', 400).toLowerCase();
    if (!ua || !ua.includes('safari')) return false;
    if (ua.includes('chrome/') || ua.includes('crios/') || ua.includes('chromium/')) return false;
    if (ua.includes('edg/') || ua.includes('edge/')) return false;
    if (ua.includes('opr/') || ua.includes('opera/')) return false;
    if (ua.includes('firefox/') || ua.includes('fxios/')) return false;
    if (ua.includes('android')) return false;
    return true;
  }

  async function requestMicrophoneStreamWithFallback() {
    if (typeof navigator === 'undefined') throw new Error('This browser does not support microphone access.');
    const modernGetUserMedia = (navigator.mediaDevices && typeof navigator.mediaDevices.getUserMedia === 'function')
      ? navigator.mediaDevices.getUserMedia.bind(navigator.mediaDevices)
      : null;
    const legacyGetUserMedia = getLegacyGetUserMedia();
    if (!modernGetUserMedia && !legacyGetUserMedia) throw new Error('This browser does not support microphone access.');
    const safariBrowser = isLikelySafariBrowser();

    const attempts = [];
    const pushAttempt = (constraints) => {
      const token = JSON.stringify(constraints || {});
      if (attempts.some((entry) => JSON.stringify(entry || {}) === token)) return;
      attempts.push(constraints);
    };

    pushAttempt({ audio: true });
    if (!safariBrowser) {
      pushAttempt({ audio: {} });
    }

    const supported = (navigator.mediaDevices && typeof navigator.mediaDevices.getSupportedConstraints === 'function')
      ? (navigator.mediaDevices.getSupportedConstraints() || {})
      : {};
    const tunedAudio = {};
    if (supported.echoCancellation) tunedAudio.echoCancellation = true;
    if (supported.noiseSuppression) tunedAudio.noiseSuppression = true;
    if (supported.autoGainControl) tunedAudio.autoGainControl = true;
    if (supported.channelCount) tunedAudio.channelCount = 1;
    if (supported.sampleRate) tunedAudio.sampleRate = { ideal: 44100 };
    if (!safariBrowser && Object.keys(tunedAudio).length) {
      pushAttempt({ audio: tunedAudio });
    }

    let lastError = null;
    if (modernGetUserMedia) {
      for (const constraints of attempts) {
        try {
          const stream = await modernGetUserMedia(constraints);
          if (hasLiveAudioTrack(stream)) return stream;
          stopStreamTracks(stream);
          const noTrackError = new Error('No live microphone track was returned.');
          noTrackError.name = 'NotFoundError';
          throw noTrackError;
        } catch (error) {
          lastError = error;
          if (!isConstraintFailure(error)) {
            throw error;
          }
        }
      }
    }

    if (legacyGetUserMedia) {
      const legacyAttempts = [{ audio: true }, { audio: {} }];
      for (const legacyConstraints of legacyAttempts) {
        try {
          const legacyStream = await new Promise((resolve, reject) => {
            legacyGetUserMedia(
              legacyConstraints,
              (stream) => resolve(stream),
              (error) => reject(error)
            );
          });
          if (hasLiveAudioTrack(legacyStream)) return legacyStream;
          stopStreamTracks(legacyStream);
          const noTrackError = new Error('No live microphone track was returned.');
          noTrackError.name = 'NotFoundError';
          throw noTrackError;
        } catch (legacyError) {
          lastError = legacyError;
          if (!isConstraintFailure(legacyError)) {
            throw legacyError;
          }
        }
      }
    }

    throw (lastError || new Error('Unable to access microphone.'));
  }

  function setButtonBusy(button, busy, label = 'Working...', options = {}) {
    if (!button) return;
    const modeToken = clean(options.mode || button.getAttribute('data-busy-mode') || '').toLowerCase();
    const disableOnly = modeToken === 'disable-only' || modeToken === 'no-spinner';
    if (disableOnly) {
      button.disabled = !!busy;
      button.setAttribute('aria-busy', busy ? 'true' : 'false');
      return;
    }
    if (busy) {
      if (!button.dataset.originalHtml) {
        button.dataset.originalHtml = button.innerHTML;
      }
      button.disabled = true;
      button.setAttribute('aria-busy', 'true');
      if (!disableOnly) {
        button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + label;
      }
      return;
    }
    button.disabled = false;
    button.setAttribute('aria-busy', 'false');
    if (button.dataset.originalHtml) {
      button.innerHTML = button.dataset.originalHtml;
      delete button.dataset.originalHtml;
    }
  }

  function revokeUrl(url) {
    if (!url) return;
    try { URL.revokeObjectURL(url); } catch (_) {}
  }

  function withTimeout(promise, timeoutMs, timeoutMessage = 'Request timed out.') {
    const ms = Math.max(1000, toInt(timeoutMs, 0) || 0);
    if (!ms) return Promise.resolve(promise);
    return new Promise((resolve, reject) => {
      const timer = setTimeout(() => {
        reject(new Error(timeoutMessage));
      }, ms);
      Promise.resolve(promise)
        .then((value) => {
          clearTimeout(timer);
          resolve(value);
        })
        .catch((error) => {
          clearTimeout(timer);
          reject(error);
        });
    });
  }

