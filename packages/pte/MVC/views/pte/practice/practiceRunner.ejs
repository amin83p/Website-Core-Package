  function formatLongClock(totalSeconds = 0) {
    const safe = Math.max(0, toInt(totalSeconds, 0));
    const hours = Math.floor(safe / 3600);
    const minutes = Math.floor((safe % 3600) / 60);
    const seconds = safe % 60;
    return `${String(hours).padStart(2, '0')}:${String(minutes).padStart(2, '0')}:${String(seconds).padStart(2, '0')}`;
  }

  function getMockRemainingSeconds() {
    const expiresAt = clean(runnerConfig.expiresAt || session?.metadata?.mockExam?.timingSnapshot?.expiresAt || '');
    if (expiresAt) {
      const end = Date.parse(expiresAt);
      if (Number.isFinite(end)) return Math.max(0, Math.floor((end - Date.now()) / 1000));
    }
    return Math.max(0, toInt(runnerConfig.remainingSeconds, 0));
  }

  function startMockExamTimer() {
    if (!strictMockExam) return;
    const timerNode = document.getElementById('pteMockExamTimer');
    if (!timerNode) return;
    let expiredHandled = false;
    const tick = () => {
      const remaining = getMockRemainingSeconds();
      timerNode.textContent = formatLongClock(remaining);
      timerNode.classList.toggle('is-critical', remaining <= 300);
      if (remaining <= 0 && !expiredHandled) {
        expiredHandled = true;
        finishSession(nodes.finishBottomBtn || timerNode).catch(() => {});
      }
    };
    tick();
    setInterval(tick, 1000);
  }

