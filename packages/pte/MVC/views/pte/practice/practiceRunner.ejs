      + '<article class="pte-reorder-card' + readOnlyClass + '" draggable="' + dragAttr + '" data-reorder-card data-reorder-index="' + String(index) + '" data-reorder-fixed-position="' + String(fixedPosition) + '" data-reorder-text="' + esc(row) + '"' + disabledAttr + '>'
      + '  <span class="pte-reorder-grip" aria-hidden="true"><i class="bi bi-grip-vertical"></i></span>'
      + '  <span class="pte-reorder-order-badge" data-reorder-position>' + String(fixedPosition) + '</span>'
      + '  <div class="pte-reorder-card-text">' + esc(row) + '</div>'
      + '</article>';
