  function isBlankTokenSegment(segment = '') {
    const token = String(segment || '');
    return /^\{\{[^}]+\}\}$/.test(token)
      || /^\[\s*blank\s*\]$/i.test(token)
      || /^_{3,}$/.test(token)
      || /^\.{3,}$/.test(token);
  }

  function resolveFillBlankKey(rawToken = '', index = 0, answerMap = {}, answerKeys = []) {
    const map = (answerMap && typeof answerMap === 'object' && !Array.isArray(answerMap)) ? answerMap : {};
    const keys = Array.isArray(answerKeys) ? answerKeys : Object.keys(map);
    const exactToken = clean(rawToken);
    if (exactToken && Object.prototype.hasOwnProperty.call(map, exactToken)) return exactToken;
    const lowered = exactToken.toLowerCase();
    if (lowered) {
      const exactCi = keys.find((key) => String(key || '').trim().toLowerCase() === lowered);
      if (exactCi) return exactCi;
    }
    const fallbackFromMap = clean(keys[index] || '');
    if (fallbackFromMap) return fallbackFromMap;
    return exactToken || `blank_${index + 1}`;
  }

  function splitReadingWordBankCandidates(text = '') {
    const source = String(text || '');
    const regex = /\b([A-Za-z][A-Za-z'-]{2,})\b/g;
    const out = [];
    const seen = new Set();
    let match = null;
    while ((match = regex.exec(source)) !== null) {
      const token = clean(match[1]);
      if (!token) continue;
      const dedupe = token.toLowerCase();
      if (seen.has(dedupe)) continue;
      seen.add(dedupe);
      out.push(token);
    }
    return out;
  }

  function buildReadingFillBlankWordBank(sourceText = '', answerMap = {}, providedOptions = [], slotCount = 0) {
    const map = (answerMap && typeof answerMap === 'object' && !Array.isArray(answerMap)) ? answerMap : {};
    const requiredWords = Object.values(map).map((row) => clean(row)).filter(Boolean);
    const providedWords = Array.isArray(providedOptions) ? providedOptions.map((row) => clean(row)).filter(Boolean) : [];
    const targetCount = Math.max(
      requiredWords.length,
      Math.max(0, Number(slotCount) || 0) + Math.ceil(Math.max(0, Number(slotCount) || 0) * 0.6)
    );

    const requiredSet = new Set(requiredWords.map((row) => row.toLowerCase()));
    const finalRows = [];
    const seen = new Set();
    const pushUnique = (token) => {
      const cleanToken = clean(token);
      if (!cleanToken) return false;
      const dedupe = cleanToken.toLowerCase();
      if (seen.has(dedupe)) return false;
      seen.add(dedupe);
      finalRows.push(cleanToken);
      return true;
    };

    requiredWords.forEach((row) => pushUnique(row));

    const supplementalSource = [];
    providedWords.forEach((row) => {
      if (!requiredSet.has(String(row || '').toLowerCase())) supplementalSource.push(row);
    });
    splitReadingWordBankCandidates(sourceText).forEach((row) => {
      const lowered = String(row || '').toLowerCase();
      if (!requiredSet.has(lowered)) supplementalSource.push(row);
    });
    const fallbackDistractors = [
      'analysis', 'context', 'approach', 'principle', 'evidence',
      'process', 'insight', 'factor', 'impact', 'pattern',
      'outcome', 'response', 'feature', 'concept', 'result'
    ];
    fallbackDistractors.forEach((row) => supplementalSource.push(row));

    const effectiveTarget = Math.max(targetCount, finalRows.length);
    for (let i = 0; i < supplementalSource.length && finalRows.length < effectiveTarget; i += 1) {
      pushUnique(supplementalSource[i]);
    }

    return finalRows;
  }

  function renderFillBlankPassageWithInputs(text = '', options = {}) {
    const source = String(text || '');
    const answerMap = (options.answerMap && typeof options.answerMap === 'object' && !Array.isArray(options.answerMap))
      ? options.answerMap
      : {};
    const answerKeys = Object.keys(answerMap);
    const responseMap = (options.responseMap && typeof options.responseMap === 'object' && !Array.isArray(options.responseMap))
      ? options.responseMap
      : {};
    const readOnly = options.readOnly === true;
    const dragDropMode = options.dragDropMode === true && !readOnly;
    const blankPattern = /(\{\{[^}]+\}\}|\[\s*blank\s*\]|_{3,}|\.{3,})/ig;
    const parts = source.split(blankPattern);
    let blankIndex = 0;
    let slotCount = 0;
    let html = '';

    parts.forEach((part) => {
      const segment = String(part || '');
      if (!isBlankTokenSegment(segment)) {
        html += esc(segment).replace(/\r?\n/g, '<br>');
        return;
      }
      const explicitKey = clean(segment.replace(/^\{\{|\}\}$/g, ''));
      const key = resolveFillBlankKey(explicitKey, blankIndex, answerMap, answerKeys);
      const value = String(responseMap[key] ?? '').trim();
      const inputAttrs = readOnly
        ? ' readonly disabled'
        : (dragDropMode ? ' readonly data-drag-fill-blank="1"' : '');
      const placeholder = `Blank ${blankIndex + 1}`;
      const inputClass = 'pte-fill-blank-input' + (dragDropMode ? ' pte-fill-blank-dropzone' : '') + (value ? '' : ' is-empty');
      html += '<input type="text" class="' + esc(inputClass) + '" data-response-blank-input data-blank-key="' + esc(key) + '" value="' + esc(value) + '" placeholder="' + esc(placeholder) + '"' + inputAttrs + '>';
      blankIndex += 1;
      slotCount += 1;
    });

    return {
      html,
      slotCount
    };
  }

  function buildReadingWritingBlankOptionRows(blankKey = '', answerMap = {}, optionsMap = {}, selectedValue = '') {
    const answerRows = (answerMap && typeof answerMap === 'object' && !Array.isArray(answerMap)) ? answerMap : {};
    const optionsRows = (optionsMap && typeof optionsMap === 'object' && !Array.isArray(optionsMap)) ? optionsMap : {};
    const ordered = [];
    const seen = new Set();
    const push = (value) => {
      const token = clean(value);
      if (!token) return;
      const dedupe = token.toLowerCase();
      if (seen.has(dedupe)) return;
      seen.add(dedupe);
      ordered.push(token);
    };

    const scopedRows = Array.isArray(optionsRows[blankKey])
      ? optionsRows[blankKey]
      : String(optionsRows[blankKey] ?? '')
        .split(/[\n,]/)
        .map((row) => clean(row))
        .filter(Boolean);
    scopedRows.forEach((row) => push(row));
    push(answerRows[blankKey]);
    push(selectedValue);
    return ordered;
  }

