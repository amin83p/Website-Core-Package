<%
  const activeSession = (session && typeof session === 'object') ? session : {};
  const itemRows = Array.isArray(items) ? items : [];
  const eventRows = Array.isArray(events) ? events : [];
  const practiceSkill = String(activeSession?.metadata?.practice?.skill || '').trim().toLowerCase();
  const mockExamMeta = (activeSession?.metadata?.mockExam && typeof activeSession.metadata.mockExam === 'object')
    ? activeSession.metadata.mockExam
    : {};
  const isStrictMockExam = (typeof strictMockExam !== 'undefined' && strictMockExam === true)
    || String(mockExamMeta.mode || '').trim().toLowerCase() === 'strict';
  const runnerConfigData = (typeof runnerConfig !== 'undefined' && runnerConfig && typeof runnerConfig === 'object')
    ? runnerConfig
    : {};
%>

