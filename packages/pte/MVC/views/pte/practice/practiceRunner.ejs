<script>
(() => {
  function parseJson(id, fallback) {
    try {
      const node = document.getElementById(id);
      return JSON.parse((node && node.textContent) || '');
    } catch (_) {
      return fallback;
    }
  }

  function clean(value) {
    return String(value || '').replace(/\0/g, '').trim();
  }

  function esc(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function nl2br(value) {
    return esc(String(value || '')).replace(/\r?\n/g, '<br>');
  }

  function toArray(value) {
    return Array.isArray(value) ? value : [];
  }

  function toInt(value, fallback = 0) {
    const numeric = Number.parseInt(String(value ?? ''), 10);
    if (!Number.isFinite(numeric) || Number.isNaN(numeric)) return Number(fallback || 0);
    return numeric;
  }

  function countWords(value = '') {
    const token = String(value || '').trim();
    if (!token) return 0;
    return token.split(/\s+/).filter(Boolean).length;
  }

  function pluralize(value = 0, singular = 'word', plural = 'words') {
    return Number(value) === 1 ? singular : plural;
  }

  function getSummarizeSpokenTextWordState(wordCount = 0, minWords = 0, maxWords = 0, options = {}) {
    const modeToken = clean(options.mode || '').toLowerCase();
    const mode = modeToken === 'dictation'
      ? 'dictation'
      : (modeToken === 'email'
        ? 'email'
        : (modeToken === 'written_summary' ? 'written_summary' : 'summary'));
    const words = Math.max(0, toInt(wordCount, 0));
    const min = Math.max(0, toInt(minWords, 0));
    const max = Math.max(0, toInt(maxWords, 0));
    const emptyMessage = mode === 'dictation'
      ? 'Start typing exactly what you hear in the audio.'
      : (mode === 'email'
        ? 'Start drafting your email with a clear purpose and tone.'
        : (mode === 'written_summary'
          ? 'Start writing a concise summary of the passage.'
          : 'Start writing your summary with the key ideas from the audio.'));
    const inRangeMessage = mode === 'dictation'
      ? 'Good progress. Keep matching the audio wording accurately.'
      : (mode === 'email'
        ? 'Great length. Keep your email clear, polite, and complete.'
        : (mode === 'written_summary'
          ? 'Great length. Keep your summary concise and accurate.'
          : 'Great length. You are within the recommended range.'));
    const minReachedMessage = mode === 'dictation'
      ? 'Length looks good. Focus on exact wording and spelling.'
      : (mode === 'email'
        ? 'Minimum length reached. Keep refining tone and structure.'
        : (mode === 'written_summary'
          ? 'Minimum length reached. Keep refining precision and clarity.'
          : 'Minimum length reached. Keep refining clarity and coherence.'));
    const maxOnlyMessage = mode === 'dictation'
      ? 'Within length guidance. Keep the dictated text precise.'
      : (mode === 'email'
        ? 'Within limit. Keep your email focused and well structured.'
        : (mode === 'written_summary'
          ? 'Within limit. Keep your summary concise and focused.'
          : 'Within limit. Keep your summary concise and focused.'));
    const openLengthMessage = mode === 'dictation'
      ? 'Keep your dictation accurate and close to the spoken text.'
      : (mode === 'email'
        ? 'Keep your email clear, relevant, and coherent.'
        : (mode === 'written_summary'
          ? 'Keep your summary concise, accurate, and coherent.'
          : 'Keep your summary concise, accurate, and coherent.'));
    if (words <= 0) {
      return {
        tone: 'neutral',
        message: emptyMessage
      };
    }
    if (min > 0 && words < min) {
      const remaining = min - words;
      return {
        tone: 'low',
        message: 'Add ' + remaining + ' more ' + pluralize(remaining) + ' to reach the minimum.'
      };
    }
    if (max > 0 && words > max) {
      const extra = words - max;
      return {
        tone: 'high',
        message: 'Reduce ' + extra + ' ' + pluralize(extra) + ' to stay within the limit.'
      };
    }
    if (min > 0 && max > 0) {
      return {
        tone: 'good',
        message: inRangeMessage
      };
    }
    if (min > 0) {
      return {
        tone: 'good',
        message: minReachedMessage
      };
    }
    if (max > 0) {
      return {
        tone: 'good',
        message: maxOnlyMessage
      };
    }
    return {
      tone: 'neutral',
      message: openLengthMessage
    };
  }

  function parseMinutesToSeconds(value, fallback = 0) {
    const numeric = Number(value);
    if (!Number.isFinite(numeric) || Number.isNaN(numeric) || numeric <= 0) return Number(fallback || 0);
    return Math.max(0, Math.floor(numeric * 60));
  }

  function parseBlankResponseMap(rawMapText = '') {
    const source = String(rawMapText || '').trim();
    if (!source) return {};
    try {
      const parsed = JSON.parse(source);
      if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return {};
      return Object.entries(parsed).reduce((acc, [key, value]) => {
        const cleanKey = clean(key);
        if (!cleanKey) return acc;
        acc[cleanKey] = String(value ?? '').trim();
        return acc;
      }, {});
    } catch (_) {
      return {};
    }
  }

  function stringifyBlankResponseMap(map = {}) {
    if (!map || typeof map !== 'object' || Array.isArray(map)) return '';
    return JSON.stringify(map);
  }

  function normalizeReorderParagraphRows(rows = []) {
    return (Array.isArray(rows) ? rows : [])
      .map((row) => clean(row))
      .filter(Boolean);
  }

  function stringifyReorderResponseOrder(rows = []) {
    return JSON.stringify(normalizeReorderParagraphRows(rows));
  }

  function parseReorderResponseOrder(rawMapText = '', paragraphItems = []) {
    const source = String(rawMapText || '').trim();
    if (!source) return [];
    const allowed = normalizeReorderParagraphRows(paragraphItems);
    const allowedSet = new Set(allowed);
    const normalizeOrder = (candidateRows = []) => {
      const used = new Set();
      const ordered = [];
      normalizeReorderParagraphRows(candidateRows).forEach((row) => {
        if (!allowedSet.has(row) || used.has(row)) return;
        used.add(row);
        ordered.push(row);
      });
      if (allowed.length) {
        allowed.forEach((row) => {
          if (used.has(row)) return;
          used.add(row);
          ordered.push(row);
        });
      }
      return ordered;
    };

    try {
      const parsed = JSON.parse(source);
      if (Array.isArray(parsed)) return normalizeOrder(parsed);
      if (parsed && typeof parsed === 'object' && Array.isArray(parsed.submittedOrder)) {
        return normalizeOrder(parsed.submittedOrder);
      }
    } catch (_) {
      // Fallback: newline-separated text list.
    }
    return normalizeOrder(source.split(/\r?\n+/g));
  }

  function hashTextSeed(value = '') {
    const source = String(value || '');
    let hash = 2166136261;
    for (let i = 0; i < source.length; i += 1) {
      hash ^= source.charCodeAt(i);
      hash += (hash << 1) + (hash << 4) + (hash << 7) + (hash << 8) + (hash << 24);
    }
    return hash >>> 0;
  }

  function createSeededRandom(seed = 1) {
    let stateSeed = (Number(seed) >>> 0) || 1;
    return () => {
      stateSeed += 0x6D2B79F5;
      let t = stateSeed;
      t = Math.imul(t ^ (t >>> 15), t | 1);
      t ^= t + Math.imul(t ^ (t >>> 7), t | 61);
      return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
    };
  }

  function buildShuffledReorderParagraphRows(rows = [], seedToken = '') {
    const source = normalizeReorderParagraphRows(rows);
    if (source.length <= 1) return source.slice();
    const out = source.slice();
    const random = createSeededRandom(hashTextSeed(seedToken || source.join('|')));
    for (let i = out.length - 1; i > 0; i -= 1) {
      const swapIndex = Math.floor(random() * (i + 1));
      const temp = out[i];
      out[i] = out[swapIndex];
      out[swapIndex] = temp;
    }
    const unchanged = out.length === source.length && out.every((row, index) => row === source[index]);
    if (unchanged) {
      const first = out.shift();
      if (first !== undefined) out.push(first);
    }
    return out;
  }

  function isReadingReorderParagraphsItem(item = null) {
