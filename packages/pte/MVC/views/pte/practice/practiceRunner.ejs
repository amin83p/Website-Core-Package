  function tokenizeHighlightIncorrectPassage(text = '') {
    const source = String(text || '');
    const parts = source.split(/([A-Za-z0-9]+(?:[’'`-][A-Za-z0-9]+)*)/g);
    const rows = [];
    let wordIndex = 0;
    parts.forEach((part) => {
      const chunk = String(part || '');
      if (!chunk) return;
      if (/^[A-Za-z0-9]+(?:[’'`-][A-Za-z0-9]+)*$/.test(chunk)) {
        rows.push({
          kind: 'word',
          text: chunk,
          normalized: normalizeHiwWordToken(chunk),
          index: wordIndex
        });
        wordIndex += 1;
      } else {
        rows.push({
          kind: 'sep',
          text: chunk
        });
      }
    });
    return rows;
  }

  function parseHighlightIncorrectMap(rawMapText = '') {
    const raw = String(rawMapText || '').trim();
    if (!raw) return {};
    try {
      const parsed = JSON.parse(raw);
      if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) return {};
      return parsed;
    } catch (_) {
      return {};
    }
  }

  function serializeHighlightIncorrectMap(selectedIndices = [], selectedWords = [], selectedPhrases = []) {
    const indices = Array.isArray(selectedIndices)
      ? selectedIndices
        .map((value) => Number.parseInt(String(value || ''), 10))
        .filter((value) => Number.isFinite(value) && !Number.isNaN(value) && value >= 0)
      : [];
    const words = Array.isArray(selectedWords)
      ? selectedWords.map((value) => clean(value)).filter(Boolean)
      : [];
    const phrases = Array.isArray(selectedPhrases)
      ? selectedPhrases.map((value) => clean(value)).filter(Boolean)
      : [];
    return JSON.stringify({
      selectedWordIndices: Array.from(new Set(indices)).sort((a, b) => a - b),
      selectedWords: words,
      selectedPhrases: phrases
    });
  }

  function splitHighlightPhraseLines(value = '') {
