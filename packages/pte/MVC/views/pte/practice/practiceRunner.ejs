  function placeNotesAroundAnchor(item, { repositionPanel = false } = {}) {
    if (!nodes.notesFab) return;
    const anchor = resolveNotesAnchorElement(item);
    if (!anchor || typeof anchor.getBoundingClientRect !== 'function') return;

    const anchorRect = anchor.getBoundingClientRect();
    const fabRect = nodes.notesFab.getBoundingClientRect();
    const fabWidth = Math.max(180, Number(fabRect.width || 0) || 220);
    const fabHeight = Math.max(36, Number(fabRect.height || 0) || 46);

    let left = anchorRect.right + 12;
    let top = anchorRect.top + 10;
    if (left + fabWidth + 8 > window.innerWidth) {
      left = Math.max(8, anchorRect.left - fabWidth - 12);
    }
    if (top + fabHeight + 8 > window.innerHeight) {
      top = Math.max(8, window.innerHeight - fabHeight - 14);
    }
    applyFixedPosition(nodes.notesFab, left, top, NOTES_FAB_POSITION_KEY);

    if (repositionPanel && nodes.notesPanel) {
      const panelRect = nodes.notesPanel.getBoundingClientRect();
      const panelWidth = Math.max(280, Number(panelRect.width || 0) || 420);
      const panelHeight = Math.max(210, Number(panelRect.height || 0) || 360);
      let panelLeft = anchorRect.right + 12;
      let panelTop = anchorRect.top + 60;
      if (panelLeft + panelWidth + 8 > window.innerWidth) {
        panelLeft = Math.max(8, anchorRect.left - panelWidth - 12);
      }
      if (panelTop + panelHeight + 8 > window.innerHeight) {
        panelTop = Math.max(8, window.innerHeight - panelHeight - 12);
      }
      applyFixedPosition(nodes.notesPanel, panelLeft, panelTop, NOTES_PANEL_POSITION_KEY);
    }
  }

  function initNotesWidgets() {
    if (nodes.notesFab) {
      const fabPos = readStoredPosition(
        NOTES_FAB_POSITION_KEY,
        Math.max(10, window.innerWidth - 250),
        Math.max(10, window.innerHeight - 86)
      );
      applyFixedPosition(nodes.notesFab, fabPos.left, fabPos.top, NOTES_FAB_POSITION_KEY);
      enableDragPositioning(nodes.notesFab, nodes.notesFab, NOTES_FAB_POSITION_KEY, {
        onDragEnd: (moved) => {
          if (moved) {
            state.notesFabSuppressClickUntil = Date.now() + 220;
          }
        }
      });
      nodes.notesFab.addEventListener('click', (event) => {
        if (Date.now() < state.notesFabSuppressClickUntil) {
          event.preventDefault();
          return;
        }
        toggleNotesPanel();
      });
    }

    if (nodes.notesPanel && nodes.notesPanelHeader) {
      const panelPos = readStoredPosition(
        NOTES_PANEL_POSITION_KEY,
        Math.max(12, (window.innerWidth * 0.5) - 210),
        Math.max(12, (window.innerHeight * 0.5) - 180)
      );
      applyFixedPosition(nodes.notesPanel, panelPos.left, panelPos.top, NOTES_PANEL_POSITION_KEY);
      enableDragPositioning(nodes.notesPanel, nodes.notesPanelHeader, NOTES_PANEL_POSITION_KEY);
    }

    nodes.notesClearBtn?.addEventListener('pointerdown', (event) => {
      event.stopPropagation();
    });
    nodes.notesCloseIconBtn?.addEventListener('pointerdown', (event) => {
      event.stopPropagation();
    });
    nodes.notesClearBtn?.addEventListener('click', async (event) => {
      event.preventDefault();
      event.stopPropagation();
      const item = getActiveItem();
      if (!item) return;
      const runtime = getItemRuntime(item);
      runtime.noteDraft = '';
      if (nodes.notesTextarea) nodes.notesTextarea.value = '';
      await showMessage('Notes Cleared', 'Current question notes were cleared.', 'success');
    });
    nodes.notesCloseIconBtn?.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      setNotesPanelOpen(false);
    });
    nodes.notesPanel?.addEventListener('click', (event) => {
      const closeBtn = event.target && typeof event.target.closest === 'function'
        ? event.target.closest('[data-notes-close="true"]')
        : null;
      if (!closeBtn) return;
      event.preventDefault();
      event.stopPropagation();
      setNotesPanelOpen(false);
    });
    nodes.notesTextarea?.addEventListener('input', () => {
      const item = getActiveItem();
      if (!item) return;
      const runtime = getItemRuntime(item);
      runtime.noteDraft = String(nodes.notesTextarea?.value || '');
    });

    window.addEventListener('resize', () => {
      if (nodes.notesFab) {
        const rect = nodes.notesFab.getBoundingClientRect();
        applyFixedPosition(nodes.notesFab, rect.left, rect.top, NOTES_FAB_POSITION_KEY);
      }
      if (nodes.notesPanel) {
        const rect = nodes.notesPanel.getBoundingClientRect();
        applyFixedPosition(nodes.notesPanel, rect.left, rect.top, NOTES_PANEL_POSITION_KEY);
      }
    });

    setNotesWidgetsVisible(false);
  }

  function openRatingModal({ afterSave = false } = {}) {
    const item = getActiveItem();
    if (!item) return false;

    updateRatingUI(item);
    const shouldLock = !isRetakeRequiredStatus(clean(item.status || 'pending'));
    setRatingLocked(shouldLock, 'Save your response first, then choose a difficulty rating.');

    if (afterSave && !state.ratingLocked && nodes.ratingMeta) {
      const rating = clean(item.selfDifficultyRating || '').toLowerCase();
      if (!rating) {
        nodes.ratingMeta.textContent = 'Response saved. Please choose a difficulty rating now.';
      }
    }

    const modal = getRatingModalInstance();
    if (modal && typeof modal.show === 'function') {
      modal.show();
      return true;
    }
    return false;
  }

  async function notifyMicrophoneError(item, error) {
    const info = describeMicrophoneError(error);
    const itemId = clean(item?.id);
    const shouldDedup = info.key === 'permission_denied' && itemId && state.speaking.lastPermissionErrorItemId === itemId;
    if (!shouldDedup) {
      await showMessage(info.title, info.message, info.key === 'unknown' ? 'error' : 'warning');
      if (itemId) state.speaking.lastPermissionErrorItemId = itemId;
    }
    return info;
  }

  function isoNow() {
    try {
      return new Date().toISOString();
    } catch (_) {
      return '';
    }
  }

  function normalizeCoachingRuntime(raw = {}) {
    const source = (raw && typeof raw === 'object') ? raw : {};
    const rawSelfCheck = (source.selfCheck && typeof source.selfCheck === 'object') ? source.selfCheck : {};
    const rawFeedback = (source.afterSubmitFeedback && typeof source.afterSubmitFeedback === 'object')
      ? source.afterSubmitFeedback
      : {};
    const rawTimestamps = (source.timestamps && typeof source.timestamps === 'object') ? source.timestamps : {};
    const hintsShown = Array.isArray(source.hintsShown)
      ? source.hintsShown.map((row) => ({
        level: Math.min(3, Math.max(1, toInt(row?.level, 1))),
        text: clean(row?.text || '', 1200),
        shownAt: clean(row?.shownAt || '', 80)
      })).filter((row) => row.text)
      : [];
    const checks = Array.isArray(rawSelfCheck.checks)
      ? rawSelfCheck.checks.map((row) => ({
        id: clean(row?.id || '', 120),
        label: clean(row?.label || '', 300),
        status: clean(row?.status || '', 20) === 'pass' ? 'pass' : 'warn',
        detail: clean(row?.detail || '', 1200)
      }))
      : [];
    const normalizeFeedbackList = (rows) => Array.isArray(rows)
      ? rows.map((row) => clean(row, 1200)).filter(Boolean).slice(0, 10)
      : [];
    const out = {
      hintLevelUsed: Math.min(3, Math.max(0, toInt(source.hintLevelUsed, 0))),
      hintsShown: hintsShown.slice(0, 40),
      selfCheck: {
        questionType: clean(rawSelfCheck.questionType || '', 120),
        passCount: Math.max(0, toInt(rawSelfCheck.passCount, 0)),
        warnCount: Math.max(0, toInt(rawSelfCheck.warnCount, 0)),
        passed: rawSelfCheck.passed === true,
        checks: checks.slice(0, 40)
      },
      afterSubmitFeedback: {
        questionType: clean(rawFeedback.questionType || '', 120),
        whatWentWell: normalizeFeedbackList(rawFeedback.whatWentWell),
        whatToImprove: normalizeFeedbackList(rawFeedback.whatToImprove),
        tryThisNext: normalizeFeedbackList(rawFeedback.tryThisNext)
      },
      timestamps: {
        firstHintAt: clean(rawTimestamps.firstHintAt || '', 80),
        lastHintAt: clean(rawTimestamps.lastHintAt || '', 80),
        lastSelfCheckAt: clean(rawTimestamps.lastSelfCheckAt || '', 80),
        lastFeedbackAt: clean(rawTimestamps.lastFeedbackAt || '', 80)
      },
      cooldownUntilMs: Math.max(0, toInt(source.cooldownUntilMs, 0))
    };
    return out;
  }

  function ensureCoachingRuntime(runtime) {
    if (!runtime || typeof runtime !== 'object') return normalizeCoachingRuntime({});
    runtime.coaching = normalizeCoachingRuntime(runtime.coaching || {});
    return runtime.coaching;
  }

  function itemSupportsCoach(item) {
    if (!item || !coachRules) return false;
    const token = normalizeQuestionTypeToken(item?.question?.questionType || item?.questionType || '');
    if (!token) return false;
    if (typeof coachRules.hasHintProfile === 'function') return coachRules.hasHintProfile(token) === true;
    return Array.isArray(coachRules.CORE_TYPES) && coachRules.CORE_TYPES.includes(token);
  }

  function hydrateRuntimeFromItem(item, runtime) {
    if (!item || !runtime || runtime.__hydratedFromItem === true) return;
    const payload = (item?.metadata && typeof item.metadata === 'object' && item.metadata.responsePayload && typeof item.metadata.responsePayload === 'object')
      ? item.metadata.responsePayload
      : {};

    const kind = normalizeQuestionTypeToken(
      payload.kind
      || item?.question?.questionType
      || item?.questionType
      || ''
    );

    runtime.textDraft = clean(payload.text || runtime.textDraft || '', 200000);
    runtime.mapText = clean(payload.mapText || runtime.mapText || '', 200000);
    runtime.selectedSingle = clean(payload.selectedSingle || runtime.selectedSingle || '');
    runtime.selectedMultiple = Array.isArray(payload.selectedMultiple)
      ? payload.selectedMultiple.map((value) => clean(value)).filter(Boolean)
      : (Array.isArray(runtime.selectedMultiple) ? runtime.selectedMultiple : []);
    runtime.selectedTrueFalse = clean(payload.selectedTrueFalse || runtime.selectedTrueFalse || '').toLowerCase();

    const speaking = runtime.speaking || {};
    runtime.speaking = {
      phase: clean(speaking.phase || payload.phase || 'idle') || 'idle',
      prepRemaining: toInt(speaking.prepRemaining, 0),
      prepTotalSeconds: toInt(speaking.prepTotalSeconds, 0),
      responseRemaining: toInt(speaking.responseRemaining, 0),
      responseTotalSeconds: toInt(speaking.responseTotalSeconds, 0),
      responseElapsedSeconds: toInt(speaking.responseElapsedSeconds, 0),
      localBlob: speaking.localBlob || null,
      localUrl: clean(speaking.localUrl || ''),
      durationSeconds: Math.max(0, Number(speaking.durationSeconds || payload.audioDurationSeconds || 0) || 0),
      uploadedArtifactId: clean(speaking.uploadedArtifactId || payload.artifactId || ''),
      uploadedArtifact: speaking.uploadedArtifact || null,
      uploadPromise: speaking.uploadPromise || null,
      lastError: clean(speaking.lastError || '', 300),
      transcript: clean(payload.transcript || speaking.transcript || runtime.transcript || '', 200000)
    };
    runtime.transcript = runtime.speaking.transcript;
    const writingTimer = (runtime.writingTimer && typeof runtime.writingTimer === 'object') ? runtime.writingTimer : {};
    runtime.writingTimer = {
      totalSeconds: Math.max(0, toInt(writingTimer.totalSeconds, 0)),
      startedAtMs: Math.max(0, toInt(writingTimer.startedAtMs, 0))
    };
    runtime.__savedResponseLocked = runtime.__savedResponseLocked === true || hasPersistedResponseData(item);

    const artifacts = Array.isArray(item?.artifacts) ? item.artifacts : [];
    const latestAudio = artifacts.find((row) => clean(row?.artifactType || '').toLowerCase() === 'audio' && resolveRecordedArtifactUrl(row))
      || artifacts.find((row) => resolveRecordedArtifactUrl(row))
      || null;
    if (!runtime.speaking.uploadedArtifact && latestAudio) {
      runtime.speaking.uploadedArtifact = latestAudio;
      runtime.speaking.uploadedArtifactId = clean(latestAudio.id || runtime.speaking.uploadedArtifactId || '');
    }

    if (kind.startsWith('speaking_')) {
      runtime.speaking.transcript = clean(
        payload.transcript || runtime.speaking.transcript || runtime.textDraft || '',
        200000
      );
      runtime.transcript = runtime.speaking.transcript;
    }

    runtime.coaching = normalizeCoachingRuntime(payload.coaching || runtime.coaching || {});
    runtime.currentViewInstanceId = clean(
      payload.viewInstanceId
      || runtime.currentViewInstanceId
      || item?.metadata?.lastViewInstanceId
      || '',
      180
    );

    runtime.__hydratedFromItem = true;
  }

  function getItemRuntime(item) {
    if (!item || typeof item !== 'object') return {};
    if (!item.__runnerRuntime || typeof item.__runnerRuntime !== 'object') {
      item.__runnerRuntime = {
        noteDraft: '',
        transcript: '',
        mapText: '',
        textDraft: '',
        selectedSingle: '',
        selectedMultiple: [],
        selectedTrueFalse: '',
        speaking: {
          phase: 'idle',
          prepRemaining: 0,
          prepTotalSeconds: 0,
          responseRemaining: 0,
          responseTotalSeconds: 0,
          responseElapsedSeconds: 0,
          localBlob: null,
          localUrl: '',
          durationSeconds: 0,
          uploadedArtifactId: '',
          uploadedArtifact: null,
          uploadPromise: null,
          lastError: ''
        },
        writingTimer: {
          totalSeconds: 0,
          startedAtMs: 0
        },
        __savedResponseLocked: false,
        currentViewInstanceId: '',
        coaching: normalizeCoachingRuntime({})
      };
    }
    hydrateRuntimeFromItem(item, item.__runnerRuntime);
    return item.__runnerRuntime;
  }

  function buildViewInstanceId(itemId = '') {
    return 'VIEW-' + clean(itemId || 'item') + '-' + Date.now() + '-' + Math.random().toString(36).slice(2, 8);
  }

  function ensureViewInstanceForItem(item, options = {}) {
    const runtime = getItemRuntime(item);
    const forceNew = options && options.forceNew === true;
    if (forceNew || !clean(runtime.currentViewInstanceId)) {
      runtime.currentViewInstanceId = buildViewInstanceId(clean(item?.id));
    }
    return clean(runtime.currentViewInstanceId);
  }

  function clearViewInstanceForItem(item) {
    const runtime = getItemRuntime(item);
    runtime.currentViewInstanceId = '';
  }

  function pickSupportedAudioMime() {
    if (typeof MediaRecorder === 'undefined' || typeof MediaRecorder.isTypeSupported !== 'function') return '';
    const candidates = [
      'audio/mp4',
      'audio/webm;codecs=opus',
      'audio/ogg;codecs=opus',
      'audio/webm',
      'audio/mpeg'
    ];
    return candidates.find((mime) => MediaRecorder.isTypeSupported(mime)) || '';
  }

  function speakingUi() {
    return {
      panel: document.getElementById('pteSpeakPanel'),
      phase: document.getElementById('pteSpeakPhaseChip'),
      timer: document.getElementById('pteSpeakTimerChip'),
      timerDisplay: document.getElementById('pteSpeakTimerDisplay'),
      progressWrap: document.getElementById('pteSpeakProgressWrap'),
      progressBar: document.getElementById('pteSpeakProgressBar'),
      progressLabel: document.getElementById('pteSpeakProgressLabel'),
      hint: document.getElementById('pteSpeakHint'),
      startBtn: document.getElementById('pteSpeakStartBtn'),
      stopBtn: document.getElementById('pteSpeakStopBtn'),
      playback: document.getElementById('pteSpeakPlayback'),
      transcript: document.querySelector('#ptePracticeResponsePanel textarea[data-response-text]')
    };
  }

  function formatSeconds(seconds) {
    const s = Math.max(0, toInt(seconds, 0));
    return `${s}s`;
  }

  function formatClock(seconds) {
    const total = Math.max(0, toInt(seconds, 0));
    const mins = Math.floor(total / 60);
    const secs = total % 60;
    return `${String(mins).padStart(2, '0')}:${String(secs).padStart(2, '0')}`;
  }

  function toPercent(numerator, denominator) {
    const num = Number(numerator);
    const den = Number(denominator);
    if (!Number.isFinite(num) || !Number.isFinite(den) || den <= 0) return 0;
    return Math.max(0, Math.min(100, Math.round((num / den) * 100)));
  }

  function getSpeakingTiming(item) {
    const question = item?.question || {};
    const payload = (question.payload && typeof question.payload === 'object') ? question.payload : {};
    const questionTiming = (question.timing && typeof question.timing === 'object') ? question.timing : {};
    const metadataTiming = (item?.metadata?.timing && typeof item.metadata.timing === 'object') ? item.metadata.timing : {};
    return resolveTiming({
      ...questionTiming,
      ...metadataTiming,
      ...payload
    });
  }

  function getQuestionTypeToken(item) {
    return normalizeQuestionTypeToken(item?.question?.questionType || item?.questionType || '');
  }

  function isWritingCountdownQuestion(item) {
    return WRITING_TYPES_WITH_COUNTDOWN.has(getQuestionTypeToken(item));
  }

  function getWritingTiming(item) {
    const question = item?.question || {};
    const payload = (question.payload && typeof question.payload === 'object') ? question.payload : {};
    const questionTiming = (question.timing && typeof question.timing === 'object') ? question.timing : {};
    const metadataTiming = (item?.metadata?.timing && typeof item.metadata.timing === 'object') ? item.metadata.timing : {};
    return resolveTiming({
      ...questionTiming,
      ...metadataTiming,
      ...payload
    });
  }

  function getWritingTimerTotalSeconds(item) {
    const qType = getQuestionTypeToken(item);
    if (!WRITING_TYPES_WITH_COUNTDOWN.has(qType)) return 0;
    const timing = getWritingTiming(item);
    const configured = Math.max(0, toInt(timing.responseSeconds, 0));
    if (configured > 0) return configured;
    return Math.max(0, toInt(WRITING_COUNTDOWN_DEFAULTS_SECONDS[qType], 0));
  }

  function ensureWritingTimerRuntime(item, totalSeconds = 0, { autoStart = false } = {}) {
    const runtime = getItemRuntime(item);
    const timer = (runtime.writingTimer && typeof runtime.writingTimer === 'object')
      ? runtime.writingTimer
      : { totalSeconds: 0, startedAtMs: 0 };
    const safeTotal = Math.max(0, toInt(totalSeconds, 0));
    if (safeTotal > 0) timer.totalSeconds = safeTotal;
    if (autoStart && safeTotal > 0 && !timer.startedAtMs) timer.startedAtMs = nowMs();
    runtime.writingTimer = timer;
    return timer;
  }

  function getWritingTimerRemainingSeconds(item, totalSeconds = 0) {
    const safeTotal = Math.max(0, toInt(totalSeconds, 0));
    if (safeTotal <= 0) return 0;
    const timer = ensureWritingTimerRuntime(item, safeTotal, { autoStart: false });
    if (!timer.startedAtMs) return safeTotal;
    const elapsed = Math.max(0, Math.floor((nowMs() - timer.startedAtMs) / 1000));
    return Math.max(0, safeTotal - elapsed);
  }

  function getWritingTimerVisualTone(remainingSeconds, totalSeconds) {
    const remaining = Math.max(0, toInt(remainingSeconds, 0));
    const total = Math.max(0, toInt(totalSeconds, 0));
    if (remaining <= 0) return 'expired';
    if (total <= 0) return 'good';
    if (remaining <= 30 || remaining <= Math.ceil(total * 0.2)) return 'critical';
    if (remaining <= 60 || remaining <= Math.ceil(total * 0.4)) return 'warn';
    return 'good';
  }

  function updateWritingTimerUi(item) {
    if (!isWritingCountdownQuestion(item)) return;
    const totalSeconds = getWritingTimerTotalSeconds(item);
    const remainingSeconds = getWritingTimerRemainingSeconds(item, totalSeconds);
    const tone = getWritingTimerVisualTone(remainingSeconds, totalSeconds);
    const applyTimerState = (wrapNode, valueNode, stateNode) => {
      if (!wrapNode || !valueNode) return;
      if (totalSeconds <= 0) {
        wrapNode.classList.add('d-none');
        return;
      }
      wrapNode.classList.remove('d-none');
      valueNode.textContent = formatClock(remainingSeconds);
      wrapNode.classList.remove('timer-good', 'timer-warn', 'timer-critical', 'timer-expired');
      wrapNode.classList.add('timer-' + tone);
      if (stateNode) stateNode.textContent = remainingSeconds <= 0 ? 'Time Up' : 'Left';
    };

    applyTimerState(
      nodes.response?.querySelector('[data-writing-timer-wrap]'),
      nodes.response?.querySelector('[data-writing-timer]'),
      nodes.response?.querySelector('[data-writing-timer-state]')
    );
    applyTimerState(
      nodes.prompt?.querySelector('[data-writing-prompt-timer-wrap]'),
      nodes.prompt?.querySelector('[data-writing-prompt-timer]'),
      nodes.prompt?.querySelector('[data-writing-prompt-timer-state]')
    );
  }

  function stopWritingCountdownTicker() {
    if (state.writing.timerHandle) {
      clearInterval(state.writing.timerHandle);
      state.writing.timerHandle = null;
    }
    state.writing.activeItemId = '';
  }

  function startWritingCountdownTicker(item) {
    stopWritingCountdownTicker();
    if (!item || !isWritingCountdownQuestion(item)) return;
    const totalSeconds = getWritingTimerTotalSeconds(item);
    if (totalSeconds <= 0) return;
    ensureWritingTimerRuntime(item, totalSeconds, { autoStart: true });
    state.writing.activeItemId = clean(item.id);
    updateWritingTimerUi(item);
    state.writing.timerHandle = setInterval(() => {
      const active = getActiveItem();
      if (!active) {
        stopWritingCountdownTicker();
        return;
      }
      const activeId = clean(active.id);
      if (!activeId || activeId !== state.writing.activeItemId) {
        stopWritingCountdownTicker();
        return;
      }
      updateWritingTimerUi(active);
    }, 1000);
  }

  function getPromptAudioUrlForItem(item) {
    const question = item?.question || {};
    const payload = (question.payload && typeof question.payload === 'object') ? question.payload : {};
    const qType = getQuestionTypeToken(item);
    if (!QUESTION_TYPES_WITH_PROMPT_AUDIO.has(qType)) return '';
    const audioRef = qType === 'speaking_answer_short_question'
      ? (payload.promptAudioAssetId || payload.promptTextOrAudio)
      : payload.promptAudioAssetId;
    return resolveQuestionMediaUrl(question, audioRef);
  }

  async function prepareRepeatSentencePracticeFlow(item, timing = {}) {
    const promptAudioUrl = getPromptAudioUrlForItem(item);
    const hasPromptAudio = !!promptAudioUrl && !!getPromptAudioElement();
    state.speaking.phase = 'idle';
    updateSpeakingUi(
      item,
      'Ready',
      hasPromptAudio
        ? 'Click Play to start a 3-second countdown, then sentence audio plays. After listening, click Start Recording.'
        : 'Prompt audio is not attached yet. Click Start Recording when you are ready.',
      timing.responseSeconds > 0 ? `Response ${formatClock(timing.responseSeconds)}` : '',
      {
        tone: 'idle',
        timerDisplay: timing.responseSeconds > 0 ? `Limit ${formatClock(timing.responseSeconds)}` : '',
        showProgress: false
      }
    );
  }

  async function prepareAnswerShortQuestionPracticeFlow(item, timing = {}) {
    const promptAudioUrl = getPromptAudioUrlForItem(item);
    const hasPromptAudio = !!promptAudioUrl && !!getPromptAudioElement();
    state.speaking.phase = 'idle';
    updateSpeakingUi(
      item,
      'Ready',
      hasPromptAudio
        ? 'Click Play to start a 3-second countdown, then audio plays. After listening, click Start Recording.'
        : 'Prompt audio is not attached yet. Click Start Recording when you are ready.',
      timing.responseSeconds > 0 ? `Response ${formatClock(timing.responseSeconds)}` : '',
      {
        tone: 'idle',
        timerDisplay: timing.responseSeconds > 0 ? `Limit ${formatClock(timing.responseSeconds)}` : '',
        showProgress: false
      }
    );
  }

  function renderSpeakingPlayback(item) {
    const ui = speakingUi();
    if (!ui.playback) return;
    const runtime = getItemRuntime(item);
    const speaking = runtime.speaking || {};
    if (speaking.localUrl) {
      ui.playback.innerHTML = ''
        + '<div class="pte-recording-playback-separator"></div>'
        + '<div class="small fw-bold text-muted mb-1">Your Recording</div>'
        + '<div class="small text-success mb-2">Recorded locally (' + formatSeconds(speaking.durationSeconds || 0) + ').</div>'
        + renderAudioPlayerBlockByUrl(speaking.localUrl, '', {
          bordered: false,
          mimeType: speaking.localBlob?.type || state.speaking.mimeType || speaking.uploadedArtifact?.mimeType || ''
        })
        + '<div class="small text-muted mt-1">' + (strictMockExam ? 'Recording captured for this response.' : 'You can listen and click Re-record if you want a better attempt.') + '</div>';
      initPromptAudioPlayers();
      return;
    }
    const uploadedArtifactUrl = resolveRecordedArtifactUrl(speaking.uploadedArtifact);
    if (speaking.uploadedArtifact && uploadedArtifactUrl) {
      ui.playback.innerHTML = ''
        + '<div class="pte-recording-playback-separator"></div>'
        + '<div class="small fw-bold text-muted mb-1">Saved Recording</div>'
        + '<div class="small text-success mb-2">Uploaded audio artifact.</div>'
        + renderAudioPlayerBlockByUrl(uploadedArtifactUrl, '', {
          bordered: false,
          mimeType: speaking.uploadedArtifact?.mimeType || ''
        });
      initPromptAudioPlayers();
      return;
    }
    ui.playback.innerHTML = '<div class="small text-muted">No recording yet.</div>';
  }

  function updateSpeakingUi(item, phaseText = '', hintText = '', timerText = '', visual = {}) {
    const ui = speakingUi();
    if (!ui.phase) return;
    const phase = clean(phaseText) || 'Ready';
    const tone = clean(visual.tone || '').toLowerCase();
    const timerDisplayText = clean(visual.timerDisplay || timerText);
    const progressLabel = clean(visual.progressLabel || '');
    const hasProgressPercent = Number.isFinite(Number(visual.progressPercent));
    const progressPercent = hasProgressPercent
      ? Math.max(0, Math.min(100, Number(visual.progressPercent)))
      : ((tone === 'recording' && visual.showProgress === true) ? 100 : 0);

    if (ui.panel) {
      ui.panel.classList.remove('pte-speak-panel-prep', 'pte-speak-panel-recording', 'pte-speak-panel-finished');
      if (tone === 'prep') ui.panel.classList.add('pte-speak-panel-prep');
      if (tone === 'recording') ui.panel.classList.add('pte-speak-panel-recording');
      if (tone === 'finished' || tone === 'recorded') ui.panel.classList.add('pte-speak-panel-finished');
    }

    let phaseClass = 'badge border';
    if (tone === 'prep') phaseClass += ' bg-warning text-dark';
    else if (tone === 'recording') phaseClass += ' bg-danger text-white';
    else if (tone === 'finished' || tone === 'recorded') phaseClass += ' bg-success text-white';
    else phaseClass += ' bg-primary-subtle text-primary-emphasis';
    ui.phase.className = phaseClass;
    ui.phase.textContent = phase;

    if (ui.hint) ui.hint.textContent = hintText || 'Use Start/Stop controls or timed auto-record for speaking responses.';

    if (ui.timer) {
      if (timerText) {
        ui.timer.style.display = 'inline-flex';
        ui.timer.textContent = timerText;
        ui.timer.className = 'badge border fw-bold ' + (
          tone === 'recording'
            ? 'bg-danger-subtle text-danger-emphasis'
            : (tone === 'prep'
              ? 'bg-warning-subtle text-warning-emphasis'
              : 'bg-light text-dark')
        );
      } else {
        ui.timer.style.display = 'none';
        ui.timer.textContent = '';
      }
    }

    if (ui.timerDisplay) {
      if (timerDisplayText) {
        ui.timerDisplay.style.display = 'block';
        ui.timerDisplay.textContent = timerDisplayText;
        ui.timerDisplay.className = 'pte-speak-timer-display ' + (
          tone === 'recording'
            ? 'pte-speak-tone-recording'
            : (tone === 'prep'
              ? 'pte-speak-tone-prep'
              : 'pte-speak-tone-finished')
        );
      } else {
        ui.timerDisplay.style.display = 'none';
        ui.timerDisplay.textContent = '';
        ui.timerDisplay.className = 'pte-speak-timer-display';
      }
    }

    if (ui.progressWrap) {
      const showProgress = visual.showProgress === true || hasProgressPercent || !!progressLabel;
      ui.progressWrap.style.display = showProgress ? '' : 'none';
    }
    if (ui.progressBar) {
      ui.progressBar.style.width = `${progressPercent}%`;
      ui.progressBar.className = 'progress-bar';
      if (tone === 'recording') ui.progressBar.classList.add('bg-danger');
      else if (tone === 'prep') ui.progressBar.classList.add('bg-warning');
      else if (tone === 'finished' || tone === 'recorded') ui.progressBar.classList.add('bg-success');
      else ui.progressBar.classList.add('bg-secondary');
      if (tone === 'recording' && !hasProgressPercent) {
        ui.progressBar.classList.add('progress-bar-striped', 'progress-bar-animated');
      }
      ui.progressBar.setAttribute('aria-valuenow', String(progressPercent));
      ui.progressBar.setAttribute('aria-valuemin', '0');
      ui.progressBar.setAttribute('aria-valuemax', '100');
    }
    if (ui.progressLabel) {
      ui.progressLabel.textContent = progressLabel;
      ui.progressLabel.style.display = progressLabel ? '' : 'none';
    }

    const speakingRuntime = getItemRuntime(item).speaking || {};
    if (ui.startBtn) {
      const isRecording = state.speaking.mediaRecorder && state.speaking.mediaRecorder.state === 'recording';
      const hasLocalRecording = Boolean(clean(speakingRuntime.localUrl) || clean(speakingRuntime.uploadedArtifactId));
      ui.startBtn.disabled = isRecording || (strictMockExam && hasLocalRecording);
      const startText = isRecording
        ? 'Recording...'
        : (tone === 'prep'
          ? 'Start Recording Now'
          : (hasLocalRecording ? (strictMockExam ? 'Recorded' : 'Re-record') : 'Start Recording'));
      ui.startBtn.innerHTML = `<i class="bi bi-mic me-1"></i>${esc(startText)}`;
    }
    if (ui.stopBtn) {
      const isRecording = state.speaking.mediaRecorder && state.speaking.mediaRecorder.state === 'recording';
      ui.stopBtn.disabled = !isRecording;
    }
    renderSpeakingPlayback(item);
    if (ui.transcript && speakingRuntime && typeof speakingRuntime === 'object') {
      if (!ui.transcript.value && speakingRuntime.transcript) {
        ui.transcript.value = speakingRuntime.transcript;
      }
    }
  }

  function clearSpeakingTimer() {
    if (state.speaking.timerHandle) {
      clearInterval(state.speaking.timerHandle);
      state.speaking.timerHandle = null;
    }
  }

  function stopStreamTracks(stream) {
    if (!stream || !Array.isArray(stream.getTracks?.())) return;
    stream.getTracks().forEach((track) => {
      try { track.stop(); } catch (_) {}
    });
  }

  async function stopSpeakingRecorder(item, { preserveBlob = true } = {}) {
    const runtime = getItemRuntime(item);
    const speaking = runtime.speaking || {};
    const recorder = state.speaking.mediaRecorder;
    if (!recorder) return;
    if (recorder.state === 'inactive') {
      state.speaking.mediaRecorder = null;
      stopStreamTracks(state.speaking.mediaStream);
      state.speaking.mediaStream = null;
      return;
    }
    await new Promise((resolve) => {
      const chunks = Array.isArray(state.speaking.recordedChunks) ? state.speaking.recordedChunks : [];
      let settled = false;
      const finalizeStop = () => {
        if (settled) return;
        settled = true;
        clearTimeout(safetyTimer);
        if (preserveBlob && chunks.length) {
          if (speaking.localUrl) revokeUrl(speaking.localUrl);
          const blobType = state.speaking.mimeType || 'audio/webm';
          speaking.localBlob = new Blob(chunks, { type: blobType });
          speaking.durationSeconds = Math.max(
            0,
            Math.round((nowMs() - state.speaking.recordStartedAtMs) / 1000)
          );
          speaking.localUrl = URL.createObjectURL(speaking.localBlob);
          // New local recording supersedes any previously uploaded artifact.
          speaking.uploadedArtifactId = '';
          speaking.uploadedArtifact = null;
        }
        state.speaking.recordedChunks = [];
        state.speaking.mediaRecorder = null;
        stopStreamTracks(state.speaking.mediaStream);
        state.speaking.mediaStream = null;
        resolve();
      };
      recorder.onstop = finalizeStop;
      const safetyTimer = setTimeout(() => {
        finalizeStop();
      }, 3000);
      try {
        recorder.stop();
      } catch (_) {
        finalizeStop();
      }
    });
    runtime.speaking = speaking;
  }

  async function startSpeakingRecorder(item) {
    const hasModernGetUserMedia = typeof navigator !== 'undefined'
      && navigator.mediaDevices
      && typeof navigator.mediaDevices.getUserMedia === 'function';
    const hasLegacyGetUserMedia = Boolean(getLegacyGetUserMedia());
    if (!hasModernGetUserMedia && !hasLegacyGetUserMedia) {
      throw new Error('This browser does not support microphone access.');
    }
    if (typeof MediaRecorder === 'undefined') {
      throw new Error('MediaRecorder API is not supported in this browser.');
    }
    if (typeof window !== 'undefined' && window.isSecureContext === false) {
      const insecureError = new Error('Microphone access requires a secure context (HTTPS or localhost).');
      insecureError.name = 'SecurityError';
      throw insecureError;
    }
    if (navigator.permissions && typeof navigator.permissions.query === 'function') {
      let micPermissionState = '';
      try {
        const status = await navigator.permissions.query({ name: 'microphone' });
        micPermissionState = clean(status?.state || '').toLowerCase();
      } catch (_) {
        // Ignore permissions API failures and rely on getUserMedia result.
      }
      if (micPermissionState === 'denied') {
        const deniedError = new Error('Microphone permission is blocked by browser settings.');
        deniedError.name = 'NotAllowedError';
        throw deniedError;
      }
    }
    const runtime = getItemRuntime(item);
    const speaking = runtime.speaking || {};
    speaking.lastError = '';
    // Starting a fresh recording means the next save/submit must upload this new blob.
    speaking.uploadedArtifactId = '';
    speaking.uploadedArtifact = null;
    speaking.responseElapsedSeconds = 0;

    if (!state.speaking.mediaStream || !hasLiveAudioTrack(state.speaking.mediaStream)) {
      if (state.speaking.mediaStream) {
        stopStreamTracks(state.speaking.mediaStream);
      }
      state.speaking.mediaStream = await requestMicrophoneStreamWithFallback();
    }
    const mimeType = pickSupportedAudioMime();
    state.speaking.mimeType = mimeType;
    const options = mimeType ? { mimeType } : undefined;
    state.speaking.mediaRecorder = new MediaRecorder(state.speaking.mediaStream, options);
    if (!state.speaking.mimeType && clean(state.speaking.mediaRecorder?.mimeType)) {
      state.speaking.mimeType = clean(state.speaking.mediaRecorder.mimeType, 120);
    }
    state.speaking.recordedChunks = [];
    state.speaking.mediaRecorder.ondataavailable = (event) => {
      if (event?.data && event.data.size > 0) {
        state.speaking.recordedChunks.push(event.data);
      }
    };
    state.speaking.recordStartedAtMs = nowMs();
    state.speaking.mediaRecorder.start(250);
    state.speaking.phase = 'recording';
    state.speaking.lastPermissionErrorItemId = '';
    speaking.phase = 'recording';
    runtime.speaking = speaking;
  }

  function startCountdown(seconds, onTick, onDone) {
    clearSpeakingTimer();
    let remaining = Math.max(0, toInt(seconds, 0));
    onTick(remaining);
    if (remaining <= 0) {
      onDone();
      return;
    }
    state.speaking.timerHandle = setInterval(() => {
      remaining -= 1;
      onTick(Math.max(0, remaining));
      if (remaining <= 0) {
        clearSpeakingTimer();
        onDone();
      }
    }, 1000);
  }

  async function beginRecordingPhase(item, timing = {}) {
    if (!item || !isSpeakingQuestion(item)) return;
    const runtime = getItemRuntime(item);
    const speaking = runtime.speaking || {};
    const itemId = clean(item.id);
    state.speaking.activeItemId = itemId;
    state.speaking.phase = 'recording';
    speaking.phase = 'recording';
    speaking.prepRemaining = 0;
    speaking.responseTotalSeconds = Math.max(0, toInt(timing.responseSeconds, 0));
    speaking.responseRemaining = speaking.responseTotalSeconds;
    speaking.responseElapsedSeconds = 0;
    runtime.speaking = speaking;
    updateSpeakingUi(
      item,
      'Recording',
      'Preparation finished. Microphone is starting now.',
      speaking.responseTotalSeconds > 0 ? `Recording ${formatClock(speaking.responseTotalSeconds)} left` : '',
      {
        tone: 'recording',
        timerDisplay: speaking.responseTotalSeconds > 0 ? `${formatClock(speaking.responseTotalSeconds)} left` : '',
        showProgress: speaking.responseTotalSeconds > 0,
        progressPercent: 0,
        progressLabel: speaking.responseTotalSeconds > 0
          ? `REC | Spoken ${formatClock(0)} / ${formatClock(speaking.responseTotalSeconds)}`
          : ''
      }
    );

    try {
      await startSpeakingRecorder(item);
    } catch (error) {
      const micError = await notifyMicrophoneError(item, error);
      speaking.lastError = clean(micError.inline || error?.message, 300);
      state.speaking.phase = 'idle';
      speaking.phase = 'idle';
      updateSpeakingUi(item, 'Ready', speaking.lastError || 'Unable to start microphone recording.', '', {
        tone: 'idle'
      });
      runtime.speaking = speaking;
      return;
    }

    if (speaking.responseTotalSeconds > 0) {
      const total = speaking.responseTotalSeconds;
      state.speaking.phaseTotalSeconds = total;
      startCountdown(
        total,
        (remaining) => {
          if (clean(state.speaking.activeItemId) !== itemId) return;
          speaking.responseRemaining = remaining;
          const elapsed = Math.max(0, total - remaining);
          speaking.responseElapsedSeconds = elapsed;
          updateSpeakingUi(
            item,
            'Recording',
            'You are recording now. Stop anytime, or wait for auto-stop at the time limit.',
            `Recording ${formatClock(remaining)} left`,
            {
              tone: 'recording',
              timerDisplay: `${formatClock(remaining)} left`,
              showProgress: true,
              progressPercent: toPercent(elapsed, total),
              progressLabel: `REC | Spoken ${formatClock(elapsed)} / ${formatClock(total)}`
            }
          );
        },
        async () => {
          if (clean(state.speaking.activeItemId) !== itemId) return;
          await stopSpeakingRecorder(item, { preserveBlob: true });
          state.speaking.phase = 'recorded';
          speaking.phase = 'recorded';
          speaking.responseRemaining = 0;
          speaking.responseElapsedSeconds = total;
          updateSpeakingUi(
            item,
            'Time Finished',
            'Response time is finished. Listen if needed, then save or submit this answer.',
            `Recorded ${formatClock(speaking.durationSeconds || total)}`,
            {
              tone: 'finished',
              timerDisplay: `${formatClock(speaking.durationSeconds || total)} spoken`,
              showProgress: true,
              progressPercent: 100,
              progressLabel: 'Recording auto-stopped at time limit.'
            }
          );
        }
      );
      runtime.speaking = speaking;
      return;
    }

    clearSpeakingTimer();
    updateSpeakingUi(
      item,
      'Recording',
      'You are recording now. Stop anytime when you finish speaking.',
      '',
      {
        tone: 'recording',
        timerDisplay: `${formatClock(0)} elapsed`,
        showProgress: true,
        progressLabel: 'REC | Spoken 00:00 (no fixed limit for this question)'
      }
    );
    state.speaking.timerHandle = setInterval(() => {
      if (clean(state.speaking.activeItemId) !== itemId) {
        clearSpeakingTimer();
        return;
      }
      const recorder = state.speaking.mediaRecorder;
      if (!recorder || recorder.state !== 'recording') {
        clearSpeakingTimer();
        return;
      }
      const elapsed = Math.max(0, Math.floor((nowMs() - state.speaking.recordStartedAtMs) / 1000));
      speaking.responseElapsedSeconds = elapsed;
      updateSpeakingUi(
        item,
        'Recording',
        'You are recording now. Stop anytime when you finish speaking.',
        '',
        {
          tone: 'recording',
          timerDisplay: `${formatClock(elapsed)} elapsed`,
          showProgress: true,
          progressLabel: `REC | Spoken ${formatClock(elapsed)} (no fixed limit for this question)`
        }
      );
    }, 1000);
    runtime.speaking = speaking;
  }

  async function runSpeakingFlow(item, { manual = false } = {}) {
    if (!item || !isSpeakingQuestion(item)) return;
    const timing = getSpeakingTiming(item);
    const runtime = getItemRuntime(item);
    const speaking = runtime.speaking || {};
    const itemId = clean(item.id);
    const questionType = getQuestionTypeToken(item);
    state.speaking.activeItemId = itemId;
    speaking.prepTotalSeconds = Math.max(0, toInt(timing.prepSeconds, 0));
    speaking.responseTotalSeconds = Math.max(0, toInt(timing.responseSeconds, 0));
    runtime.speaking = speaking;

    if (manual) {
      const recorder = state.speaking.mediaRecorder;
      if (recorder && recorder.state === 'recording') return;
      state.speaking.flowToken = Number(state.speaking.flowToken || 0) + 1;
      stopPromptAudioPlayback({ reset: true });
      clearSpeakingTimer();
      await beginRecordingPhase(item, timing);
      return;
    }

    if (questionType === 'speaking_repeat_sentence') {
      await prepareRepeatSentencePracticeFlow(item, timing);
      runtime.speaking = speaking;
      return;
    }
    if (questionType === 'speaking_answer_short_question') {
      await prepareAnswerShortQuestionPracticeFlow(item, timing);
      runtime.speaking = speaking;
      return;
    }

    if (timing.prepSeconds > 0) {
      state.speaking.phase = 'prep';
      speaking.phase = 'prep';
      state.speaking.phaseTotalSeconds = timing.prepSeconds;
      startCountdown(
        timing.prepSeconds,
        (remaining) => {
          if (clean(state.speaking.activeItemId) !== itemId) return;
          speaking.prepRemaining = remaining;
          const elapsed = Math.max(0, timing.prepSeconds - remaining);
          updateSpeakingUi(
            item,
            'Preparation',
            'Preparation time is running. You can start recording now or wait for auto-start.',
            `Prep ${formatClock(remaining)}`,
            {
              tone: 'prep',
              timerDisplay: `${formatClock(remaining)} prep`,
              showProgress: true,
              progressPercent: toPercent(elapsed, timing.prepSeconds),
              progressLabel: `Preparation ${formatClock(elapsed)} / ${formatClock(timing.prepSeconds)}`
            }
          );
        },
        async () => {
          if (state.speaking.phase !== 'prep') return;
          if (clean(state.speaking.activeItemId) !== itemId) return;
          await beginRecordingPhase(item, timing);
        }
      );
      runtime.speaking = speaking;
      return;
    }

    await beginRecordingPhase(item, timing);
    runtime.speaking = speaking;
  }

  async function stopSpeakingFlowForActiveItem({ preserveBlob = true } = {}) {
    state.speaking.flowToken = Number(state.speaking.flowToken || 0) + 1;
    stopPromptAudioPlayback({ reset: false });
    const currentItem = state.itemMap.get(clean(state.speaking.activeItemId || state.activeItemId || '')) || null;
    clearSpeakingTimer();
    if (!currentItem) {
      stopStreamTracks(state.speaking.mediaStream);
      state.speaking.mediaStream = null;
      state.speaking.mediaRecorder = null;
      return;
    }
    await stopSpeakingRecorder(currentItem, { preserveBlob });
    const timing = getSpeakingTiming(currentItem);
    const runtime = getItemRuntime(currentItem);
    const speaking = runtime.speaking || {};
    if (preserveBlob && speaking.localBlob) {
      state.speaking.phase = 'recorded';
      speaking.phase = 'recorded';
      const duration = Math.max(0, toInt(speaking.durationSeconds, 0));
      updateSpeakingUi(
        currentItem,
        'Recorded',
        'Recording stopped. You can listen and Re-record if needed, then save or submit.',
        `Recorded ${formatClock(duration)}`,
        {
          tone: 'recorded',
          timerDisplay: `${formatClock(duration)} spoken`,
          showProgress: timing.responseSeconds > 0,
          progressPercent: timing.responseSeconds > 0 ? toPercent(duration, timing.responseSeconds) : 0,
          progressLabel: timing.responseSeconds > 0
            ? `Spoken ${formatClock(duration)} / ${formatClock(timing.responseSeconds)}`
            : `Spoken ${formatClock(duration)}`
        }
      );
    } else {
      state.speaking.phase = 'idle';
      speaking.phase = 'idle';
      updateSpeakingUi(currentItem, 'Ready', 'Press Start Recording to begin your speaking response.', '', {
        tone: 'idle',
        showProgress: false
      });
    }
    runtime.speaking = speaking;
  }

  function buildRuntimeEndpoint(path, includeActionState = true) {
    if (!includeActionState || !actionStateId) return path;
    return path + (path.includes('?') ? '&' : '?') + 'actionStateId=' + encodeURIComponent(actionStateId);
  }

  function runtimeEndpoint(suffix = '') {
    const base = clean(runtimeBasePath).replace(/\/+$/, '');
    const tail = String(suffix || '').startsWith('/') ? String(suffix || '') : ('/' + String(suffix || ''));
    return base + tail;
  }

  async function postRuntime(path, runtimePlan, options = {}) {
    const includeActionState = options.includeActionState !== false;
    const body = new URLSearchParams();
    body.set('runtimePlan', JSON.stringify(runtimePlan || {}));
    if (includeActionState && actionStateId) body.set('actionStateId', actionStateId);
    const response = await fetch(buildRuntimeEndpoint(path, includeActionState), {
      method: 'POST',
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded',
        'X-AJAX-Request': 'true',
        'Accept': 'application/json'
      },
      credentials: 'include',
      body: body.toString()
    });
    const result = await response.json().catch(() => null);
    if (!response.ok || !result || result.status !== 'success') {
      throw new Error((result && result.message) || ('Request failed with status ' + response.status + '.'));
    }
    return result.results || {};
  }

  async function uploadSpeakingArtifact(item, options = {}) {
    if (!item || !isSpeakingQuestion(item)) return null;
    const runtime = getItemRuntime(item);
    const speaking = runtime.speaking || {};
    if (!speaking.localBlob) return speaking.uploadedArtifact || null;
    if (speaking.uploadedArtifactId) return speaking.uploadedArtifact || null;
    if (speaking.uploadPromise) return speaking.uploadPromise;

    const itemId = clean(item.id);
    const sessionId = clean(session.id);
    const normalizedMimeType = normalizeAudioMimeType(state.speaking.mimeType || speaking.localBlob.type || 'audio/webm');
    let extension = 'webm';
    if (normalizedMimeType.includes('ogg')) extension = 'ogg';
    if (normalizedMimeType.includes('mp4')) extension = 'mp4';
    if (normalizedMimeType.includes('mpeg') || normalizedMimeType.includes('mp3')) extension = 'mp3';
    const filename = `${itemId || 'item'}_${Date.now()}.${extension}`;

    const formData = new FormData();
    formData.append('audioFile', speaking.localBlob, filename);
    formData.append('durationSeconds', String(Math.max(0, toInt(speaking.durationSeconds, 0))));
    formData.append('actionStateId', actionStateId);
    const allowReanswer = options.allowReanswer === true || runtime.__reanswerPending === true;
    const viewInstanceId = ensureViewInstanceForItem(item);
    formData.append('runtimePlan', JSON.stringify({
      allowReanswer,
      replaceExistingResponse: allowReanswer || options.replaceExistingResponse === true || runtime.__replaceExistingResponse === true,
      viewInstanceId,
      source: {
        module: strictMockExam ? 'pte_mock_exam_ui' : 'pte_practice_runner_ui',
        eventType: strictMockExam ? 'mock_exam_audio_uploaded' : 'response_saved',
        eventId: (strictMockExam ? 'PTE-MOCK-AUDIO-' : 'PTE-PRACTICE-AUDIO-') + itemId + '-' + Date.now(),
        idempotencyKey: (strictMockExam ? 'PTE-MOCK-AUDIO-' : 'PTE-PRACTICE-AUDIO-') + itemId + '-' + nowIso()
      }
    }));

    speaking.uploadPromise = (async () => {
      const response = await fetch(
        buildRuntimeEndpoint(runtimeEndpoint('/' + encodeURIComponent(sessionId)) + '/items/' + encodeURIComponent(itemId) + '/upload-audio'),
        {
          method: 'POST',
          headers: {
            'X-AJAX-Request': 'true',
            'Accept': 'application/json'
          },
          credentials: 'include',
          body: formData
        }
      );
      const result = await response.json().catch(() => null);
      if (!response.ok || !result || result.status !== 'success') {
        throw new Error((result && result.message) || ('Audio upload failed with status ' + response.status + '.'));
      }
      const updatedItem = result?.results?.item || null;
      if (updatedItem) Object.assign(item, updatedItem);
      const artifact = result?.results?.artifact || null;
      speaking.uploadedArtifact = artifact;
      speaking.uploadedArtifactId = clean(artifact?.id || '');
      return artifact;
    })().finally(() => {
      speaking.uploadPromise = null;
    });

    runtime.speaking = speaking;
    return speaking.uploadPromise;
  }

  function getActiveItem() {
    return items[state.index] || null;
  }

  function persistCurrentDraft() {
    const prevId = clean(state.activeItemId);
    if (!prevId) return;
    const prevItem = state.itemMap.get(prevId);
    if (!prevItem) return;
    const runtime = getItemRuntime(prevItem);

    const textArea = nodes.response.querySelector('textarea[data-response-text]');
    if (textArea) {
      const value = String(textArea.value || '');
      if (isSpeakingQuestion(prevItem)) runtime.speaking.transcript = value;
      else runtime.textDraft = value;
    }
    const mapArea = nodes.response.querySelector('textarea[data-response-map]');
    if (mapArea) runtime.mapText = String(mapArea.value || '');
    const blankState = collectBlankResponseMapFromDom();
    if (blankState.slotCount > 0) {
      runtime.mapText = stringifyBlankResponseMap(blankState.map);
    }
    if (isReadingReorderParagraphsItem(prevItem)) {
      syncReorderResponseRuntimeFromDom(prevItem);
    }
    const tfSelect = nodes.response.querySelector('select[data-response-true-false]');
    if (tfSelect) runtime.selectedTrueFalse = clean(tfSelect.value).toLowerCase();
    const single = nodes.response.querySelector('input[type="radio"][name="practice_single_choice"]:checked');
    runtime.selectedSingle = clean(single?.value || '');
    runtime.selectedMultiple = Array.from(nodes.response.querySelectorAll('input[type="checkbox"][name="practice_multi_choice"]:checked'))
      .map((node) => clean(node.value))
      .filter(Boolean);
    if (nodes.notesTextarea) {
      runtime.noteDraft = String(nodes.notesTextarea.value || '');
    }
  }

  function collectResponseSummary(item) {
    const questionType = normalizeQuestionTypeToken(item?.question?.questionType || item?.questionType || '');
    const runtime = getItemRuntime(item);
    const speaking = runtime.speaking || {};
    const summary = {
      kind: questionType || 'unknown',
      payloadBytes: 0,
      textLength: 0,
      wordCount: 0,
      optionCount: 0,
      blankCount: 0,
      pairCount: 0,
      audioDurationSeconds: 0,
      artifactCount: 0
    };

    const textArea = nodes.response.querySelector('textarea[data-response-text]');
    if (textArea) {
      const text = String(textArea.value || '');
      summary.textLength = text.length;
      summary.wordCount = text.trim() ? text.trim().split(/\s+/).filter(Boolean).length : 0;
    }

    const singleChoice = nodes.response.querySelector('input[type="radio"][name="practice_single_choice"]:checked');
    if (singleChoice) summary.optionCount = 1;
    const multiChoice = Array.from(nodes.response.querySelectorAll('input[type="checkbox"][name="practice_multi_choice"]:checked'));
    if (multiChoice.length) summary.optionCount = multiChoice.length;

    const tfSelect = nodes.response.querySelector('select[data-response-true-false]');
    if (tfSelect && clean(tfSelect.value)) summary.optionCount = 1;

    const mapTextarea = nodes.response.querySelector('textarea[data-response-map]');
    if (mapTextarea) {
      const text = clean(mapTextarea.value);
      if (text) summary.textLength = Math.max(summary.textLength, text.length);
    }
    const blankState = collectBlankResponseMapFromDom();
    if (blankState.slotCount > 0) {
      summary.blankCount = blankState.filledCount;
      const blankMapText = stringifyBlankResponseMap(blankState.map);
      if (blankMapText) summary.textLength = Math.max(summary.textLength, blankMapText.length);
    }
    if (questionType === 'reading_reorder_paragraphs') {
      const payloadRows = Array.isArray(item?.question?.payload?.paragraphItems)
        ? item.question.payload.paragraphItems
        : [];
      const reorderText = mapTextarea ? String(mapTextarea.value || '') : String(runtime.mapText || '');
      const submittedOrder = parseReorderResponseOrder(reorderText, payloadRows);
      summary.optionCount = Math.max(summary.optionCount, submittedOrder.length);
      if (reorderText) summary.textLength = Math.max(summary.textLength, reorderText.length);
    }

    if (isSpeakingQuestion(item)) {
      summary.audioDurationSeconds = Math.max(0, Number(speaking.durationSeconds || 0) || 0);
      const artifactCount = Array.isArray(item.artifactIds) ? item.artifactIds.length : 0;
      summary.artifactCount = Math.max(artifactCount, speaking.uploadedArtifactId ? 1 : 0);
    } else {
      summary.artifactCount = Array.isArray(item.artifactIds) ? item.artifactIds.length : 0;
    }

    summary.payloadBytes = JSON.stringify(summary).length;
    return summary;
  }

  function collectResponsePayload(item) {
    const questionType = normalizeQuestionTypeToken(item?.question?.questionType || item?.questionType || '');
    const runtime = getItemRuntime(item);
    const speaking = runtime.speaking || {};
    const payload = {
      kind: questionType || 'unknown',
      text: '',
      mapText: '',
      selectedSingle: '',
      selectedMultiple: [],
      selectedTrueFalse: '',
      transcript: '',
      audioDurationSeconds: 0,
      artifactId: clean(speaking.uploadedArtifactId || ''),
      artifactUrl: clean(speaking.uploadedArtifact?.url || '')
    };

    const textArea = nodes.response.querySelector('textarea[data-response-text]');
    if (textArea) {
      const text = String(textArea.value || '');
      if (isSpeakingQuestion(item)) payload.transcript = text;
      else payload.text = text;
    } else if (isSpeakingQuestion(item)) {
      payload.transcript = clean(speaking.transcript || runtime.transcript || '', 200000);
    }

    if (questionType === 'reading_reorder_paragraphs') {
      syncReorderResponseRuntimeFromDom(item);
    }
    const mapTextarea = nodes.response.querySelector('textarea[data-response-map]');
    if (mapTextarea) payload.mapText = String(mapTextarea.value || '');
    else payload.mapText = clean(runtime.mapText || '', 200000);
    const blankState = collectBlankResponseMapFromDom();
    if (blankState.slotCount > 0) {
      payload.mapText = stringifyBlankResponseMap(blankState.map);
    }

    const singleChoice = nodes.response.querySelector('input[type="radio"][name="practice_single_choice"]:checked');
    if (singleChoice) payload.selectedSingle = clean(singleChoice.value || '');
    else payload.selectedSingle = clean(runtime.selectedSingle || '');

    const multiChoice = Array.from(nodes.response.querySelectorAll('input[type="checkbox"][name="practice_multi_choice"]:checked'))
      .map((node) => clean(node.value))
      .filter(Boolean);
    payload.selectedMultiple = multiChoice.length
      ? multiChoice
      : (Array.isArray(runtime.selectedMultiple) ? runtime.selectedMultiple.map((row) => clean(row)).filter(Boolean) : []);

    const tfSelect = nodes.response.querySelector('select[data-response-true-false]');
    payload.selectedTrueFalse = clean(tfSelect?.value || runtime.selectedTrueFalse || '').toLowerCase();

    if (isSpeakingQuestion(item)) {
      payload.audioDurationSeconds = Math.max(0, Number(speaking.durationSeconds || 0) || 0);
      if (!payload.artifactUrl && speaking.uploadedArtifact && speaking.uploadedArtifact.url) {
        payload.artifactUrl = clean(speaking.uploadedArtifact.url || '');
      }
      if (!payload.artifactId && speaking.uploadedArtifact && speaking.uploadedArtifact.id) {
        payload.artifactId = clean(speaking.uploadedArtifact.id || '');
      }
    }

    payload.coaching = normalizeCoachingRuntime(runtime.coaching || {});

    return payload;
  }

  function buildCoachContext(item, responsePayload = null) {
    const question = item?.question || {};
    const payload = (question.payload && typeof question.payload === 'object') ? question.payload : {};
    const questionType = normalizeQuestionTypeToken(question.questionType || item?.questionType || '');
    const runtime = getItemRuntime(item);
    const response = (responsePayload && typeof responsePayload === 'object')
      ? responsePayload
      : collectResponsePayload(item);
    return {
      questionType,
      payload,
      response,
      runtime
    };
  }

  function renderCoachFeedbackRows(title, rows = [], tone = 'neutral') {
    const listRows = Array.isArray(rows) ? rows.map((row) => clean(row)).filter(Boolean) : [];
    const className = tone === 'good'
      ? 'text-success-emphasis'
      : (tone === 'warn' ? 'text-warning-emphasis' : 'text-primary-emphasis');
    return ''
      + '<div>'
      + '  <div class="pte-coach-feedback-col-title ' + className + '">' + esc(title) + '</div>'
      + (listRows.length
        ? ('  <ul class="pte-coach-feedback-list">' + listRows.map((row) => '<li>' + esc(row) + '</li>').join('') + '</ul>')
        : '  <div class="small text-muted">No items yet.</div>')
      + '</div>';
  }

  function setCoachActionButtonsState(item, readOnly = false) {
    const canUseCoach = !!item && itemSupportsCoach(item);
    if (nodes.coachHintBtn) {
      nodes.coachHintBtn.disabled = !canUseCoach || readOnly || state.coach.hintBusy;
    }
    if (nodes.coachCheckBtn) {
      nodes.coachCheckBtn.disabled = !canUseCoach || readOnly || state.coach.checkBusy;
    }
  }

  function renderCoachPanel(item, options = {}) {
    const readOnly = options?.readOnly === true;
    if (!nodes.coachPanel || !nodes.coachSection) return;
    const supportsCoach = !!item && itemSupportsCoach(item);
    const runtime = item ? getItemRuntime(item) : null;
    const coaching = runtime ? ensureCoachingRuntime(runtime) : normalizeCoachingRuntime({});
    const hasHint = Array.isArray(coaching.hintsShown) && coaching.hintsShown.length > 0;
    const hasSelfCheck = Array.isArray(coaching.selfCheck?.checks) && coaching.selfCheck.checks.length > 0;
    const hasFeedback = Array.isArray(coaching.afterSubmitFeedback?.whatWentWell) && coaching.afterSubmitFeedback.whatWentWell.length
      || Array.isArray(coaching.afterSubmitFeedback?.whatToImprove) && coaching.afterSubmitFeedback.whatToImprove.length
      || Array.isArray(coaching.afterSubmitFeedback?.tryThisNext) && coaching.afterSubmitFeedback.tryThisNext.length;
    const hasAny = hasHint || hasSelfCheck || hasFeedback;

    if (!supportsCoach) {
      nodes.coachSection.classList.add('pte-coach-hidden');
      if (nodes.coachPanel) nodes.coachPanel.classList.add('pte-coach-hidden');
      return;
    }

    nodes.coachSection.classList.remove('pte-coach-hidden');
    nodes.coachPanel.classList.remove('pte-coach-hidden');

    if (nodes.coachStatus) {
      nodes.coachStatus.textContent = hasFeedback ? 'After Submit' : 'Before Submit';
    }

    if (nodes.coachHintCard) nodes.coachHintCard.classList.toggle('pte-coach-hidden', !hasHint);
    if (nodes.coachHintText) {
      const lastHint = hasHint ? coaching.hintsShown[coaching.hintsShown.length - 1] : null;
      nodes.coachHintText.textContent = lastHint ? String(lastHint.text || '') : '';
    }
    if (nodes.coachHintMeta) {
      const level = Math.max(0, toInt(coaching.hintLevelUsed, 0));
      const cooldownMs = Math.max(0, toInt(coaching.cooldownUntilMs, 0));
      const remainingSeconds = Math.max(0, Math.ceil((cooldownMs - nowMs()) / 1000));
      const metaRows = [];
      if (level > 0) metaRows.push('Level ' + level + ' / 3');
      if (remainingSeconds > 0) metaRows.push('Next hint in ' + remainingSeconds + 's');
      nodes.coachHintMeta.textContent = metaRows.join('  |  ');
    }

    if (nodes.coachCheckCard) nodes.coachCheckCard.classList.toggle('pte-coach-hidden', !hasSelfCheck);
    if (nodes.coachCheckList) {
      if (!hasSelfCheck) nodes.coachCheckList.innerHTML = '';
      else {
        nodes.coachCheckList.innerHTML = coaching.selfCheck.checks.map((row) => {
          const status = clean(row.status || '').toLowerCase() === 'pass' ? 'pass' : 'warn';
          const symbol = status === 'pass' ? 'PASS' : 'CHECK';
          const detail = clean(row.detail || '');
          return '<li class="pte-coach-check-item is-' + status + '"><strong>' + symbol + ':</strong> '
            + esc(row.label || 'Check')
            + (detail ? (' - ' + esc(detail)) : '')
            + '</li>';
        }).join('');
      }
    }

    if (nodes.coachFeedbackCard) nodes.coachFeedbackCard.classList.toggle('pte-coach-hidden', !hasFeedback);
    if (nodes.coachFeedbackGrid) {
      if (!hasFeedback) nodes.coachFeedbackGrid.innerHTML = '';
      else {
        nodes.coachFeedbackGrid.innerHTML = ''
          + renderCoachFeedbackRows('What Went Well', coaching.afterSubmitFeedback?.whatWentWell, 'good')
          + renderCoachFeedbackRows('What To Improve', coaching.afterSubmitFeedback?.whatToImprove, 'warn')
          + renderCoachFeedbackRows('Try This Next', coaching.afterSubmitFeedback?.tryThisNext, 'next');
      }
    }

    if (nodes.coachEmptyState) {
      const shouldHideEmpty = hasAny || readOnly;
      nodes.coachEmptyState.classList.toggle('pte-coach-hidden', shouldHideEmpty);
    }

    if (readOnly && !hasFeedback) {
      nodes.coachPanel.classList.add('pte-coach-hidden');
    } else {
      nodes.coachPanel.classList.remove('pte-coach-hidden');
    }

    setCoachActionButtonsState(item, readOnly);
  }

  function scoreNumber(value, fallback = 0) {
    const numeric = Number(value);
    return Number.isFinite(numeric) ? numeric : Number(fallback || 0);
  }

  function formatScoreNumber(value) {
    const numeric = scoreNumber(value, 0);
    return Number.isInteger(numeric) ? String(numeric) : numeric.toFixed(2);
  }

  function getScoringMetadata(item) {
    const metadata = (item?.metadata && typeof item.metadata === 'object') ? item.metadata : {};
    const scoring = (metadata.scoring && typeof metadata.scoring === 'object') ? metadata.scoring : null;
    if (!scoring) return null;
    const responseRevision = toInt(metadata.responseRevision, 0);
    const scoringRevision = toInt(scoring.responseRevision, responseRevision);
    if (responseRevision > 0 && scoringRevision > 0 && responseRevision !== scoringRevision) {
      return null;
    }
    return scoring;
  }

  function normalizeScoreFeedbackRows(rows = []) {
    if (Array.isArray(rows)) {
      return rows.map((row) => clean(row)).filter(Boolean).slice(0, 4);
    }
    const text = clean(rows);
    return text ? [text] : [];
  }

  function buildFallbackScoreFeedback(item, scoring) {
    const traitScores = (item?.traitScores && typeof item.traitScores === 'object') ? item.traitScores : {};
    const scorerKey = clean(scoring?.scorerKey).toLowerCase();
    const questionType = getQuestionTypeToken(item);
    if (
      questionType === 'reading_mcq_single'
      || questionType === 'reading_mcq_multiple'
      || questionType === 'reading_true_false'
      || questionType === 'reading_fill_in_blank'
      || questionType === 'reading_writing_fill_in_blank'
      || questionType === 'reading_reorder_paragraphs'
      || questionType === 'reading_matching'
      || scorerKey === 'reading_mcq_single'
      || scorerKey === 'reading_mcq_multiple'
      || scorerKey === 'reading_true_false'
      || scorerKey === 'reading_fill_in_blank'
      || scorerKey === 'reading_writing_fill_in_blank'
      || scorerKey === 'reading_reorder_paragraphs'
      || scorerKey === 'reading_matching'
    ) {
      const breakdown = (scoring?.aggregationBreakdown && typeof scoring.aggregationBreakdown === 'object')
        ? scoring.aggregationBreakdown
        : {};
      const scoreFinal = scoreNumber(traitScores.accuracy ?? item?.scoreFinal, 0);
      const maxScore = Math.max(0.000001, scoreNumber(scoring?.accuracy?.maxScore || scoring?.traitMax?.accuracy || item?.maxScore || 1, 1));
      const strengths = [];
      const improvements = [];

      if (scoreFinal >= maxScore) strengths.push('The response matches the keyed reading answer criteria.');
      else improvements.push('Review the keyed answer evidence and retry this reading item.');

      if (scorerKey === 'reading_mcq_multiple' || questionType === 'reading_mcq_multiple') {
        const matched = Array.isArray(breakdown.matchedCorrect) ? breakdown.matchedCorrect.length : 0;
        const required = Array.isArray(breakdown.correctOptionKeys) ? breakdown.correctOptionKeys.length : 0;
        if (matched && required) strengths.push(`Matched ${matched} of ${required} required option(s).`);
        if (Array.isArray(breakdown.extraIncorrect) && breakdown.extraIncorrect.length) {
          improvements.push(`Remove incorrect option(s): ${breakdown.extraIncorrect.join(', ')}.`);
        }
      }
      if (scorerKey === 'reading_fill_in_blank' || scorerKey === 'reading_writing_fill_in_blank' || questionType === 'reading_fill_in_blank' || questionType === 'reading_writing_fill_in_blank') {
        const correctCount = scoreNumber(breakdown.correctCount, 0);
        const blankCount = scoreNumber(breakdown.blankCount, 0);
        if (blankCount > 0) {
          strengths.push(`${correctCount}/${blankCount} blank(s) were correct.`);
          if (correctCount < blankCount) improvements.push('Focus on blank context and grammar cues for missed gaps.');
        }
      }
      if (scorerKey === 'reading_reorder_paragraphs' || questionType === 'reading_reorder_paragraphs') {
        const matchedPositions = scoreNumber(breakdown.matchedPositions, 0);
        const correctCount = scoreNumber(breakdown.correctCount, 0);
        if (correctCount > 0) strengths.push(`Matched ${matchedPositions}/${correctCount} paragraph positions.`);
      }
      if (scorerKey === 'reading_matching' || questionType === 'reading_matching') {
        const matchedCount = scoreNumber(breakdown.matchedCount, 0);
        const pairCount = scoreNumber(breakdown.pairCount, 0);
        if (pairCount > 0) strengths.push(`Matched ${matchedCount}/${pairCount} required pairs.`);
        if (scoreNumber(breakdown.incorrectCount, 0) > 0) improvements.push('Fix incorrect pair links and match each left item to its best right item.');
      }

      return {
        strengths,
        improvements,
        nextPracticeAction: scoreFinal >= maxScore
          ? 'Move to another reading item and maintain the same accuracy.'
          : 'Re-attempt this reading item and verify each choice against the passage evidence.'
      };
    }
    if (
      questionType === 'listening_mcq_single'
      || questionType === 'listening_select_missing_word'
      || scorerKey === 'listening_mcq_single'
      || scorerKey === 'listening_select_missing_word'
    ) {
      const breakdown = (scoring?.aggregationBreakdown && typeof scoring.aggregationBreakdown === 'object')
        ? scoring.aggregationBreakdown
        : {};
      const isCorrect = Boolean(breakdown.isCorrect);
      const selected = clean(breakdown.selectedOptionKey || '');
      const correct = clean(breakdown.correctOptionKey || '');
      const isSelectMissingWord = questionType === 'listening_select_missing_word' || scorerKey === 'listening_select_missing_word';
      return {
        strengths: isCorrect ? ['Selected option matches the keyed answer.'] : [],
        improvements: isCorrect
          ? []
          : [selected
            ? (`Selected "${selected}" but keyed answer is "${correct || '-'}".`)
            : 'No option was selected; choose one answer before submitting.'],
        nextPracticeAction: isCorrect
          ? (isSelectMissingWord
            ? 'Move to the next listening Select Missing Word item and keep your accuracy.'
            : 'Move to the next listening MCQ single item and keep your accuracy.')
          : (isSelectMissingWord
            ? 'Replay the audio and transcript gap, then select the best ending option.'
            : 'Replay the audio and question stem, then pick the best single answer.')
      };
    }
    if (questionType === 'listening_mcq_multiple' || scorerKey === 'listening_mcq_multiple') {
      const breakdown = (scoring?.aggregationBreakdown && typeof scoring.aggregationBreakdown === 'object')
        ? scoring.aggregationBreakdown
        : {};
      const matched = Array.isArray(breakdown.matchedCorrect) ? breakdown.matchedCorrect.length : 0;
      const required = Array.isArray(breakdown.correctOptionKeys) ? breakdown.correctOptionKeys.length : 0;
      const extraIncorrect = Array.isArray(breakdown.extraIncorrect) ? breakdown.extraIncorrect : [];
      const strengths = [];
      const improvements = [];
      if (required > 0 && matched > 0) strengths.push(`Matched ${matched}/${required} required option(s).`);
      if (!extraIncorrect.length && matched > 0) strengths.push('No incorrect options were selected.');
      if (matched < required) improvements.push('Find all required correct options before submitting.');
      if (extraIncorrect.length) improvements.push(`Remove incorrect options: ${extraIncorrect.join(', ')}.`);
      return {
        strengths,
        improvements,
        nextPracticeAction: matched >= required && !extraIncorrect.length
          ? 'Move to the next listening MCQ multiple item and maintain this precision.'
          : 'Replay the audio and verify every selected option against the prompt meaning.'
      };
    }
    if (isListeningDictationQuestion(item) || scorerKey === 'listening_dictation') {
      const breakdown = (scoring?.aggregationBreakdown && typeof scoring.aggregationBreakdown === 'object')
        ? scoring.aggregationBreakdown
        : {};
      const matched = scoreNumber(breakdown.matchedTokenCount, 0);
      const expected = scoreNumber(breakdown.expectedTokenCount, 0);
      const strengths = [];
      const improvements = [];
      if (expected > 0 && matched >= expected) strengths.push('The dictation response matches the expected transcript accurately.');
      else if (expected > 0 && matched > 0) strengths.push(`Matched ${matched}/${expected} transcript tokens in order.`);
      else improvements.push('Capture more dictated words in the same order as the audio.');
      if (expected > 0 && matched < expected) improvements.push('Replay mentally and focus on missed words and exact word order.');
      return {
        strengths,
        improvements,
        nextPracticeAction: expected > 0 && matched >= expected
          ? 'Move to another dictation item and keep the same transcription precision.'
          : 'Retry this dictation and correct the missed words before moving on.'
      };
    }
    if (isListeningFillInBlankQuestion(item) || scorerKey === 'listening_fill_in_blank') {
      const breakdown = (scoring?.aggregationBreakdown && typeof scoring.aggregationBreakdown === 'object')
        ? scoring.aggregationBreakdown
        : {};
      const correctCount = scoreNumber(breakdown.correctCount, 0);
      const blankCount = scoreNumber(breakdown.blankCount, 0);
      const answeredCount = scoreNumber(breakdown.answeredCount, 0);
      const strengths = [];
      const improvements = [];
      if (blankCount > 0 && correctCount >= blankCount) strengths.push('All blanks were completed with keyed answers.');
      else if (blankCount > 0 && correctCount > 0) strengths.push(`Correctly completed ${correctCount}/${blankCount} blank(s).`);
      else improvements.push('Use transcript context to complete more blanks accurately.');
      if (blankCount > 0 && answeredCount < blankCount) improvements.push(`Complete all blank slots (${answeredCount}/${blankCount} answered).`);
      if (blankCount > 0 && correctCount < blankCount) improvements.push('Review missed blanks and retry with exact keyed words.');
      return {
        strengths,
        improvements,
        nextPracticeAction: blankCount > 0 && correctCount >= blankCount
          ? 'Move to another listening fill-in-the-blanks item and maintain this accuracy.'
          : 'Retry this item and focus on missed or incomplete blanks before moving on.'
      };
    }
    if (isListeningHighlightIncorrectWordsQuestion(item) || scorerKey === 'listening_highlight_incorrect_words') {
      const breakdown = (scoring?.aggregationBreakdown && typeof scoring.aggregationBreakdown === 'object')
        ? scoring.aggregationBreakdown
        : {};
      const correctCount = scoreNumber(breakdown.correctCount, 0);
      const expectedCount = scoreNumber(breakdown.expectedCount, 0);
      const falsePositiveCount = scoreNumber(breakdown.falsePositiveCount, 0);
      const missedCount = scoreNumber(breakdown.missedCount, 0);
      const strengths = [];
      const improvements = [];
      if (expectedCount > 0 && correctCount >= expectedCount) strengths.push('All incorrect words were identified correctly.');
      else if (expectedCount > 0 && correctCount > 0) strengths.push(`Correctly highlighted ${correctCount}/${expectedCount} incorrect word(s).`);
      else improvements.push('Track the transcript line-by-line and highlight only clear mismatches.');
      if (falsePositiveCount > 0) improvements.push(`Remove false highlights (${falsePositiveCount}) to improve precision.`);
      if (missedCount > 0) improvements.push(`You missed ${missedCount} incorrect word(s); focus on subtle audio-text differences.`);
      return {
        strengths,
        improvements,
        nextPracticeAction: expectedCount > 0 && correctCount >= expectedCount && falsePositiveCount === 0
          ? 'Move to another HIW item and keep this precision.'
          : 'Retry this HIW item and focus on missed words while avoiding false highlights.'
      };
    }
    if (isListeningSummarizeSpokenTextQuestion(item) || scorerKey === 'listening_summarize_spoken_text') {
      const content = scoreNumber(traitScores.content, 0);
      const form = scoreNumber(traitScores.form, 0);
      const grammar = scoreNumber(traitScores.grammar, 0);
      const vocabulary = scoreNumber(traitScores.vocabulary, 0);
      const strengths = [];
      const improvements = [];
      if (content >= 2) strengths.push('Summary captures the main spoken meaning and key points.');
      else improvements.push('Cover more of the main spoken ideas and key supporting details.');
      if (form >= 1) strengths.push('Response format is within expected sentence and length rules.');
      else improvements.push('Adjust response form to match one-sentence and word-limit expectations.');
      if (grammar >= 2) strengths.push('Grammar control supports clear meaning.');
      else improvements.push('Improve grammar control and sentence structure to reduce ambiguity.');
      if (vocabulary >= 2) strengths.push('Vocabulary choice is precise and context-appropriate.');
      else improvements.push('Use more precise paraphrasing and vocabulary from the spoken context.');
      return {
        strengths,
        improvements,
        nextPracticeAction: 'Replay the audio mentally, list the main idea plus two key details, then rewrite one concise summary sentence.'
      };
    }
    if (isAnswerShortQuestion(item) || scorerKey === 'speaking_answer_short_question') {
      const vocabulary = scoreNumber(traitScores.vocabulary ?? traitScores.correctness ?? item?.scoreFinal, 0);
      const maxScore = Math.max(1, scoreNumber(item?.maxScore, 1));
      const correct = vocabulary >= maxScore;
      return {
        strengths: correct ? ['The spoken answer matched the accepted answer set.'] : [],
        improvements: correct
          ? []
          : ['The spoken answer did not match the accepted answer set. Use only the key word or short factual phrase.'],
        nextPracticeAction: correct
          ? 'Practice another short question and keep the same brief answer style.'
          : 'Replay the prompt, identify the exact factual target, then answer in one or two words.'
      };
    }
    if (isRepeatSentenceQuestion(item) || scorerKey === 'speaking_repeat_sentence') {
      const content = scoreNumber(traitScores.content, 0);
      const pronunciation = scoreNumber(traitScores.pronunciation, 0);
      const fluency = scoreNumber(traitScores.fluency, 0);
      const alignment = (scoring?.alignment && typeof scoring.alignment === 'object') ? scoring.alignment : {};
      const strengths = [];
      const improvements = [];

      if (content >= 3) strengths.push('Content recall is strong; the sentence was repeated in the correct sequence.');
      else if (content >= 2) strengths.push('The response recalled at least half of the sentence in sequence.');
      else improvements.push('Content needs more accurate recall: listen for meaning chunks and repeat the words in the same order.');

      if (pronunciation >= 4) strengths.push('Pronunciation is generally clear and easy to understand.');
      else improvements.push('Pronunciation needs improvement: make word endings, stress, and key sounds easier to understand.');

      if (fluency >= 4) strengths.push('Fluency is steady with mostly natural phrasing.');
      else improvements.push('Fluency needs improvement: reduce long pauses, restarts, filler sounds, and uneven rhythm.');

      return {
        strengths,
        improvements,
        nextPracticeAction: content < 3
          ? 'Replay the sentence, split it into 2 or 3 chunks, then repeat immediately without adding new words.'
          : ((scoreNumber(alignment.matchCount, 0) && scoreNumber(alignment.sourceWordCount, 0))
            ? 'Practice another Repeat Sentence item and keep the same word order while improving natural rhythm.'
          : 'Practice another Repeat Sentence item and keep the same recall while improving natural rhythm.')
      };
    }
    if (isRespondSituationQuestion(item) || scorerKey === 'speaking_respond_to_situation') {
      const appropriacy = scoreNumber(traitScores.appropriacy, 0);
      const pronunciation = scoreNumber(traitScores.pronunciation, 0);
      const fluency = scoreNumber(traitScores.fluency, 0);
      const strengths = [];
      const improvements = [];

      if (appropriacy >= 3) strengths.push('Appropriacy is strong; the response fits the situation, register, and listener.');
      else if (appropriacy >= 2) strengths.push('The response mostly handles the situation appropriately.');
      else improvements.push('Appropriacy needs improvement: make the purpose, register, politeness, and key details fit the situation more clearly.');

      if (pronunciation >= 4) strengths.push('Pronunciation is generally clear and easy to understand.');
      else improvements.push('Pronunciation needs improvement: make key words, endings, stress, and sounds easier to understand.');

      if (fluency >= 4) strengths.push('Fluency is steady with mostly natural phrasing.');
      else improvements.push('Fluency needs improvement: reduce long pauses, restarts, filler sounds, and uneven phrasing.');

      return {
        strengths,
        improvements,
        nextPracticeAction: appropriacy < 3
          ? 'Re-record once using a simple structure: acknowledge the situation, perform the requested action, add one detail, and close politely.'
          : 'Practice another Respond to a Situation item and keep the same register while improving natural delivery.'
      };
    }
    if (isDescribeImageQuestion(item) || scorerKey === 'speaking_describe_image') {
      const content = scoreNumber(traitScores.content, 0);
      const pronunciation = scoreNumber(traitScores.pronunciation, 0);
      const fluency = scoreNumber(traitScores.fluency, 0);
      const strengths = [];
      const improvements = [];

      if (content >= 4) strengths.push('Content coverage is strong; the response captured the main visual information.');
      else improvements.push('Content needs more coverage: state the overview, add key details, and mention an important comparison or trend.');

      if (pronunciation >= 4) strengths.push('Pronunciation is generally clear and easy to understand.');
      else improvements.push('Pronunciation needs improvement: make key nouns, numbers, and comparisons easier to understand.');

      if (fluency >= 4) strengths.push('Fluency is steady with mostly natural phrasing.');
      else improvements.push('Fluency needs improvement: reduce hesitations, uneven rhythm, long pauses, and restarts.');

      return {
        strengths,
        improvements,
        nextPracticeAction: improvements.length
          ? 'Re-record the same Describe Image item using a 4-part structure: overview, detail one, detail two, conclusion.'
          : 'Move to another Describe Image item and keep the same structure while polishing natural delivery.'
      };
    }
    const contentMax = Math.max(0, scoreNumber(scoring?.alignment?.contentMax || scoring?.sourceWordCount || Math.max(0, scoreNumber(item?.maxScore, 0) - 10), 0));
    const content = scoreNumber(traitScores.content, 0);
    const pronunciation = scoreNumber(traitScores.pronunciation, 0);
    const fluency = scoreNumber(traitScores.fluency, 0);
    const strengths = [];
    const improvements = [];

    if (contentMax > 0 && content >= contentMax * 0.8) strengths.push('Content coverage is strong; most source words were captured accurately.');
    else if (contentMax > 0) improvements.push('Content needs attention: reduce omissions, replacements, and extra words while reading the passage.');

    if (pronunciation >= 4) strengths.push('Pronunciation is generally clear and easy to understand.');
    else improvements.push('Pronunciation needs improvement: focus on clearer word endings, stress, and sounds that require listener effort.');

    if (fluency >= 4) strengths.push('Fluency is steady with mostly natural phrasing.');
    else improvements.push('Fluency needs improvement: reduce hesitations, uneven rhythm, long pauses, and restarts.');

    const nextPracticeAction = improvements.length
      ? 'Re-record the same Read Aloud item once, targeting the weakest criterion first.'
      : 'Move to another Read Aloud item and keep the same accuracy while making the rhythm more natural.';

    return {
      strengths,
      improvements,
      nextPracticeAction
    };
  }

  function resolveScoreFeedback(item, scoring) {
    const draft = (scoring?.feedbackDraft && typeof scoring.feedbackDraft === 'object') ? scoring.feedbackDraft : {};
    const fallback = buildFallbackScoreFeedback(item, scoring);
    const strengths = normalizeScoreFeedbackRows(draft.strengths);
    const improvements = normalizeScoreFeedbackRows(draft.improvements);
    const nextAction = clean(draft.nextPracticeAction || draft.nextAction || '');
    return {
      summary: clean(draft.summary || ''),
      strengths: strengths.length ? strengths : (fallback.strengths.length ? fallback.strengths : ['No criterion is strong yet; focus on the improvement list first.']),
      improvements: improvements.length ? improvements : (fallback.improvements.length ? fallback.improvements : ['No urgent criterion gap was detected in this scored evidence. Keep polishing consistency.']),
      nextPracticeAction: nextAction || fallback.nextPracticeAction
    };
  }

  function traitToneClass(value, max) {
    const safeMax = Math.max(0, scoreNumber(max, 0));
    const ratio = safeMax > 0 ? scoreNumber(value, 0) / safeMax : 0;
    if (ratio >= 0.8) return 'is-good';
    if (ratio >= 0.55) return 'is-warn';
    return 'is-low';
  }

  function traitStatusText(value, max) {
    const safeMax = Math.max(0, scoreNumber(max, 0));
    const ratio = safeMax > 0 ? scoreNumber(value, 0) / safeMax : 0;
    if (ratio >= 0.8) return 'Good';
    if (ratio >= 0.55) return 'Developing';
    return 'Needs work';
  }

  function renderScoreTrait(label, value, max) {
    const safeMax = Math.max(0, scoreNumber(max, 0));
    return ''
      + '<div class="pte-score-trait ' + traitToneClass(value, safeMax) + '">'
      + '  <div class="pte-score-trait-label">' + esc(label) + '</div>'
      + '  <div class="pte-score-trait-value">' + esc(formatScoreNumber(value)) + ' / ' + esc(formatScoreNumber(safeMax)) + '</div>'
      + '  <div class="pte-score-trait-status">' + esc(traitStatusText(value, safeMax)) + '</div>'
      + '</div>';
  }

  function renderScoreFeedbackBlock(title, rows = [], tone = '') {
    const normalized = normalizeScoreFeedbackRows(rows);
    const className = tone ? (' ' + tone) : '';
    return ''
      + '<div class="pte-score-feedback-block">'
      + '  <div class="pte-score-feedback-title' + className + '">' + esc(title) + '</div>'
      + (normalized.length
        ? ('  <ul class="pte-score-feedback-list">' + normalized.map((row) => '<li>' + esc(row) + '</li>').join('') + '</ul>')
        : '  <div class="small text-muted">No notes yet.</div>')
      + '</div>';
  }

  function collectScoringWarnings(scoring) {
    return Array.isArray(scoring?.warnings)
      ? scoring.warnings.map((row) => clean(row)).filter(Boolean)
      : [];
  }

  function isTechnicalScoringWarning(row) {
    const text = clean(row).toLowerCase();
    if (!text) return true;
    return (
      text.includes('did not return valid json')
      || text.includes('unusable structured describe image response')
      || text.includes('audio-only transcript recovery')
      || text.includes('transcript recovery returned malformed json')
      || text.includes('recovered transcript using an audio-only follow-up request')
      || text.includes('recovered read aloud transcript using an audio-only follow-up request')
      || text.includes('provider response did not include')
      || text.includes('prompt image could not be attached to the ai request')
      || text.includes('temporary capacity error')
      || text.includes('scorer retried')
      || text.includes('scorer switched this request')
      || text.includes('returned plain text instead of json')
      || text.includes('recovered labelled scoring fields')
      || text.includes('generated read aloud micro-rubric responses deterministically')
      || text.includes('generated respond to a situation micro-rubric responses deterministically')
      || text.includes('recovered read aloud micro-rubric responses')
      || text.includes('rubric recovery follow-up')
      || text.includes('recovered respond to a situation rubric trait scores')
      || text.includes('micro-rubric recovery follow-up')
      || text.includes('recovered describe image micro-rubric responses')
      || text.includes('recovered respond to a situation micro-rubric responses')
      || text.includes('using deterministic transcript fallback')
      || text.includes('audio analysis did not return usable rubric scores')
      || text.includes('audio analysis did not return usable micro-rubric responses')
      || text.includes('activity quota token recording failed')
    );
  }

  function getApplicantScoringWarnings(scoring) {
    return collectScoringWarnings(scoring)
      .filter((row) => !isTechnicalScoringWarning(row))
      .slice(0, 4);
  }

  function buildApplicantScoringProblemMessage(status, warnings = [], item = {}) {
    const token = (Array.isArray(warnings) ? warnings : []).map((row) => clean(row)).join(' ').toLowerCase();
    const isDescribe = isDescribeImageQuestion(item) || clean(item?.metadata?.scoring?.scorerKey).toLowerCase() === 'speaking_describe_image';
    const isRespond = isRespondSituationQuestion(item) || clean(item?.metadata?.scoring?.scorerKey).toLowerCase() === 'speaking_respond_to_situation';

    if (status === 'needs_evidence') {
      if (token.includes('uploaded audio')) return 'Save an audio recording before scoring this response.';
      if (token.includes('prompt image evidence')) return 'Describe Image scoring needs a prompt image, image caption, or expected key points.';
      return 'More evidence is needed before this response can be scored.';
    }

    if (token.includes('no usable transcript') || token.includes('usable transcript field')) {
      return 'The response was saved, but the AI provider did not return a usable transcript. Please retry scoring, or re-record if the audio is unclear.';
    }

    if (token.includes('transcript appears incomplete') || token.includes('may not represent the full response')) {
      return 'The response was saved, but the AI provider returned only a partial transcript, so no valid raw score was recorded. Please retry scoring, or re-record if the audio was cut off.';
    }

    if (token.includes('did not return usable rubric scores') || token.includes('did not return usable micro-rubric responses') || token.includes('valid describe image scoring json') || token.includes('did not return valid json') || token.includes('unusable structured describe image response')) {
      if (isDescribe && token.includes('did not return usable micro-rubric responses')) {
        return 'The response was saved, but the AI provider did not return usable Describe Image micro-rubric answers. Please retry scoring or use a more stable audio/vision model.';
      }
      if (isDescribe && token.includes('prompt image asset file is missing')) {
        return 'The response was saved, but the AI provider returned malformed scoring data and the prompt image file is missing. Reattach the prompt image or add reliable caption/key points, then retry scoring.';
      }
      if (isRespond && token.includes('did not return usable rubric scores')) {
        return 'The response was saved, but the AI provider did not return usable Appropriacy, Pronunciation, and Fluency scores. Please retry scoring or switch to a more stable audio model.';
      }
      if (isRespond && token.includes('did not return usable micro-rubric responses')) {
        return 'The response was saved, but the AI provider did not return usable Respond to a Situation micro-rubric answers. Please retry scoring or switch to a more stable audio model.';
      }
      return 'The response was saved, but the AI provider returned malformed scoring data, so no valid raw score was recorded. Please retry scoring or use a more stable model.';
    }

    const applicantWarnings = warnings.filter((row) => !isTechnicalScoringWarning(row)).slice(0, 2);
    return applicantWarnings.length
      ? applicantWarnings.join(' ')
      : 'The response was saved, but scoring could not produce a valid raw score yet.';
  }

  function renderScoreWarnings(scoring) {
    const warnings = getApplicantScoringWarnings(scoring);
    if (!warnings.length) return '';
    return '<ul class="pte-score-warning-list">' + warnings.map((row) => '<li>' + esc(row) + '</li>').join('') + '</ul>';
  }

  function getScorePanelTitle(item, scoring) {
    const scorerKey = clean(scoring?.scorerKey).toLowerCase();
    const questionType = getQuestionTypeToken(item);
    if (isAnswerShortQuestion(item) || scorerKey === 'speaking_answer_short_question') return 'Answer Short Question Raw Score';
    if (isRepeatSentenceQuestion(item) || scorerKey === 'speaking_repeat_sentence') return 'Repeat Sentence Raw Score';
    if (isDescribeImageQuestion(item) || scorerKey === 'speaking_describe_image') return 'Describe Image Raw Score';
    if (isRespondSituationQuestion(item) || scorerKey === 'speaking_respond_to_situation') return 'Respond to a Situation Raw Score';
    if (questionType === 'writing_write_email' || scorerKey === 'writing_write_email') return 'Write Email Raw Score';
    if (questionType === 'writing_summarize_written_text' || scorerKey === 'writing_summarize_written_text') return 'Summarize Written Text Raw Score';
    if (questionType === 'reading_mcq_single' || scorerKey === 'reading_mcq_single') return 'Reading MCQ Single Raw Score';
    if (questionType === 'reading_mcq_multiple' || scorerKey === 'reading_mcq_multiple') return 'Reading MCQ Multiple Raw Score';
    if (questionType === 'reading_true_false' || scorerKey === 'reading_true_false') return 'Reading True/False Raw Score';
    if (questionType === 'reading_fill_in_blank' || scorerKey === 'reading_fill_in_blank') return 'Reading Fill In Blank Raw Score';
    if (questionType === 'reading_writing_fill_in_blank' || scorerKey === 'reading_writing_fill_in_blank') return 'Reading & Writing Fill In Blank Raw Score';
    if (questionType === 'reading_reorder_paragraphs' || scorerKey === 'reading_reorder_paragraphs') return 'Reading Reorder Paragraphs Raw Score';
    if (questionType === 'reading_matching' || scorerKey === 'reading_matching') return 'Reading Matching Raw Score';
    if (questionType === 'listening_mcq_single' || scorerKey === 'listening_mcq_single') return 'Listening MCQ Single Raw Score';
    if (questionType === 'listening_mcq_multiple' || scorerKey === 'listening_mcq_multiple') return 'Listening MCQ Multiple Raw Score';
    if (questionType === 'listening_select_missing_word' || scorerKey === 'listening_select_missing_word') return 'Listening Select Missing Word Raw Score';
    if (questionType === 'listening_summarize_spoken_text' || scorerKey === 'listening_summarize_spoken_text') return 'Summarize Spoken Text Raw Score';
    if (questionType === 'listening_dictation' || scorerKey === 'listening_dictation') return 'Write From Dictation Raw Score';
    if (questionType === 'listening_fill_in_blank' || scorerKey === 'listening_fill_in_blank') return 'Listening Fill In the Blanks Raw Score';
    if (questionType === 'listening_highlight_incorrect_words' || scorerKey === 'listening_highlight_incorrect_words') return 'Listening Highlight Incorrect Words Raw Score';
    if (isReadAloudQuestion(item) || scorerKey === 'speaking_read_aloud') return 'Read Aloud Raw Score';
    return 'Raw Score';
  }

  function renderScoreTraitRows(item, scoring, traitScores, maxScore) {
    const scorerKey = clean(scoring?.scorerKey).toLowerCase();
    const questionType = getQuestionTypeToken(item);
    if (isAnswerShortQuestion(item) || scorerKey === 'speaking_answer_short_question') {
      return renderScoreTrait('Vocabulary', traitScores.vocabulary ?? traitScores.correctness ?? item?.scoreFinal ?? 0, Math.max(1, maxScore || 1));
    }

    if (isRepeatSentenceQuestion(item) || scorerKey === 'speaking_repeat_sentence') {
      const contentMax = Math.max(0, scoreNumber(scoring?.content?.maxScore || scoring?.traitMax?.content || 3, 3));
      const pronunciationMax = Math.max(0, scoreNumber(scoring?.pronunciation?.maxScore || scoring?.traitMax?.pronunciation || 5, 5));
      const fluencyMax = Math.max(0, scoreNumber(scoring?.fluency?.maxScore || scoring?.traitMax?.fluency || 5, 5));
      return ''
        + renderScoreTrait('Content', traitScores.content || 0, contentMax)
        + renderScoreTrait('Pronunciation', traitScores.pronunciation || 0, pronunciationMax)
        + renderScoreTrait('Fluency', traitScores.fluency || 0, fluencyMax);
    }

    if (isRespondSituationQuestion(item) || scorerKey === 'speaking_respond_to_situation') {
      const appropriacyMax = Math.max(0, scoreNumber(scoring?.appropriacy?.maxScore || scoring?.traitMax?.appropriacy || 3, 3));
      const pronunciationMax = Math.max(0, scoreNumber(scoring?.pronunciation?.maxScore || scoring?.traitMax?.pronunciation || 5, 5));
      const fluencyMax = Math.max(0, scoreNumber(scoring?.fluency?.maxScore || scoring?.traitMax?.fluency || 5, 5));
      return ''
        + renderScoreTrait('Appropriacy', traitScores.appropriacy || 0, appropriacyMax)
        + renderScoreTrait('Pronunciation', traitScores.pronunciation || 0, pronunciationMax)
        + renderScoreTrait('Fluency', traitScores.fluency || 0, fluencyMax);
    }

    if (isDescribeImageQuestion(item) || scorerKey === 'speaking_describe_image') {
      const contentMax = Math.max(0, scoreNumber(scoring?.content?.maxScore || scoring?.traitMax?.content || 5, 5));
      const pronunciationMax = Math.max(0, scoreNumber(scoring?.pronunciation?.maxScore || scoring?.traitMax?.pronunciation || 5, 5));
      const fluencyMax = Math.max(0, scoreNumber(scoring?.fluency?.maxScore || scoring?.traitMax?.fluency || 5, 5));
      return ''
        + renderScoreTrait('Content', traitScores.content || 0, contentMax)
        + renderScoreTrait('Pronunciation', traitScores.pronunciation || 0, pronunciationMax)
        + renderScoreTrait('Fluency', traitScores.fluency || 0, fluencyMax);
    }

    if (questionType === 'writing_summarize_written_text' || scorerKey === 'writing_summarize_written_text') {
      const traitMax = (scoring?.traitMax && typeof scoring.traitMax === 'object') ? scoring.traitMax : {};
      return ''
        + renderScoreTrait('Content', traitScores.content || 0, scoreNumber(scoring?.content?.maxScore || traitMax.content || 2, 2))
        + renderScoreTrait('Form', traitScores.form || 0, scoreNumber(scoring?.form?.maxScore || traitMax.form || 1, 1))
        + renderScoreTrait('Grammar', traitScores.grammar || 0, scoreNumber(scoring?.grammar?.maxScore || traitMax.grammar || 2, 2))
        + renderScoreTrait('Vocabulary', traitScores.vocabulary || 0, scoreNumber(scoring?.vocabulary?.maxScore || traitMax.vocabulary || 2, 2));
    }

    if (questionType === 'listening_summarize_spoken_text' || scorerKey === 'listening_summarize_spoken_text') {
      const traitMax = (scoring?.traitMax && typeof scoring.traitMax === 'object') ? scoring.traitMax : {};
      return ''
        + renderScoreTrait('Content', traitScores.content || 0, scoreNumber(scoring?.content?.maxScore || traitMax.content || 2, 2))
        + renderScoreTrait('Form', traitScores.form || 0, scoreNumber(scoring?.form?.maxScore || traitMax.form || 1, 1))
        + renderScoreTrait('Grammar', traitScores.grammar || 0, scoreNumber(scoring?.grammar?.maxScore || traitMax.grammar || 2, 2))
        + renderScoreTrait('Vocabulary', traitScores.vocabulary || 0, scoreNumber(scoring?.vocabulary?.maxScore || traitMax.vocabulary || 2, 2));
    }

    if (questionType === 'writing_write_email' || scorerKey === 'writing_write_email') {
      const traitMax = (scoring?.traitMax && typeof scoring.traitMax === 'object') ? scoring.traitMax : {};
      return ''
        + renderScoreTrait('Content', traitScores.content || 0, scoreNumber(scoring?.content?.maxScore || traitMax.content || 3, 3))
        + renderScoreTrait('Email Conventions', traitScores.emailConventions || 0, scoreNumber(scoring?.emailConventions?.maxScore || traitMax.emailConventions || 2, 2))
        + renderScoreTrait('Form', traitScores.form || 0, scoreNumber(scoring?.form?.maxScore || traitMax.form || 2, 2))
        + renderScoreTrait('Organization', traitScores.organization || 0, scoreNumber(scoring?.organization?.maxScore || traitMax.organization || 2, 2))
        + renderScoreTrait('Vocabulary', traitScores.vocabulary || 0, scoreNumber(scoring?.vocabulary?.maxScore || traitMax.vocabulary || 2, 2))
        + renderScoreTrait('Grammar', traitScores.grammar || 0, scoreNumber(scoring?.grammar?.maxScore || traitMax.grammar || 2, 2))
        + renderScoreTrait('Spelling', traitScores.spelling || 0, scoreNumber(scoring?.spelling?.maxScore || traitMax.spelling || 2, 2));
    }

    if (questionType === 'listening_dictation' || scorerKey === 'listening_dictation') {
      const traitMax = (scoring?.traitMax && typeof scoring.traitMax === 'object') ? scoring.traitMax : {};
      const contentMax = Math.max(0.000001, scoreNumber(scoring?.content?.maxScore || traitMax.content || maxScore || 1, 1));
      return renderScoreTrait('Content', traitScores.content ?? item?.scoreFinal ?? 0, contentMax);
    }

    if (questionType === 'listening_fill_in_blank' || scorerKey === 'listening_fill_in_blank') {
      const traitMax = (scoring?.traitMax && typeof scoring.traitMax === 'object') ? scoring.traitMax : {};
      const accuracyMax = Math.max(0.000001, scoreNumber(scoring?.accuracy?.maxScore || traitMax.accuracy || maxScore || 1, 1));
      return renderScoreTrait('Accuracy', traitScores.accuracy ?? item?.scoreFinal ?? 0, accuracyMax);
    }

    if (questionType === 'listening_highlight_incorrect_words' || scorerKey === 'listening_highlight_incorrect_words') {
      const traitMax = (scoring?.traitMax && typeof scoring.traitMax === 'object') ? scoring.traitMax : {};
      const accuracyMax = Math.max(0.000001, scoreNumber(scoring?.accuracy?.maxScore || traitMax.accuracy || maxScore || 1, 1));
      return renderScoreTrait('Accuracy', traitScores.accuracy ?? item?.scoreFinal ?? 0, accuracyMax);
    }

    if (
      questionType === 'listening_mcq_single'
      || questionType === 'listening_mcq_multiple'
      || questionType === 'listening_select_missing_word'
      || scorerKey === 'listening_mcq_single'
      || scorerKey === 'listening_mcq_multiple'
      || scorerKey === 'listening_select_missing_word'
    ) {
      const traitMax = (scoring?.traitMax && typeof scoring.traitMax === 'object') ? scoring.traitMax : {};
      const accuracyMax = Math.max(0.000001, scoreNumber(scoring?.accuracy?.maxScore || traitMax.accuracy || maxScore || 1, 1));
      return renderScoreTrait('Accuracy', traitScores.accuracy ?? item?.scoreFinal ?? 0, accuracyMax);
    }

    if (
      questionType === 'reading_mcq_single'
      || questionType === 'reading_mcq_multiple'
      || questionType === 'reading_true_false'
      || questionType === 'reading_fill_in_blank'
      || questionType === 'reading_writing_fill_in_blank'
      || questionType === 'reading_reorder_paragraphs'
      || questionType === 'reading_matching'
      || scorerKey === 'reading_mcq_single'
      || scorerKey === 'reading_mcq_multiple'
      || scorerKey === 'reading_true_false'
      || scorerKey === 'reading_fill_in_blank'
      || scorerKey === 'reading_writing_fill_in_blank'
      || scorerKey === 'reading_reorder_paragraphs'
      || scorerKey === 'reading_matching'
    ) {
      const traitMax = (scoring?.traitMax && typeof scoring.traitMax === 'object') ? scoring.traitMax : {};
      const accuracyMax = Math.max(0.000001, scoreNumber(scoring?.accuracy?.maxScore || traitMax.accuracy || maxScore || 1, 1));
      return renderScoreTrait('Accuracy', traitScores.accuracy ?? item?.scoreFinal ?? 0, accuracyMax);
    }

    const contentMax = Math.max(0, scoreNumber(scoring?.alignment?.contentMax || scoring?.sourceWordCount || Math.max(0, maxScore - 10), 0));
    return ''
      + renderScoreTrait('Content', traitScores.content || 0, contentMax)
      + renderScoreTrait('Pronunciation', traitScores.pronunciation || 0, 5)
      + renderScoreTrait('Fluency', traitScores.fluency || 0, 5);
  }

  function renderScoringPanel(item) {
    if (!nodes.scoreSection || !nodes.scorePanel) return;
    const scoring = getScoringMetadata(item);
    const scoreStatus = clean(scoring?.status || '').toLowerCase();
    const itemStatus = clean(item?.status || '').toLowerCase();
    const hasScore = scoreStatus ? scoreStatus === 'scored' : itemStatus === 'scored';
    const hasScoringAttempt = Boolean(scoring && (scoreStatus || Array.isArray(scoring.warnings)));

    if (!hasScore && !hasScoringAttempt) {
      nodes.scorePanel.innerHTML = '';
      nodes.scoreSection.classList.add('pte-score-hidden');
      return;
    }

    nodes.scoreSection.classList.remove('pte-score-hidden');

    if (!hasScore) {
      const label = scoreStatus === 'needs_evidence' ? 'More evidence needed' : (scoreStatus ? formatStatusLabel(scoreStatus) : 'Scoring not completed');
      const warningRows = collectScoringWarnings(scoring);
      const problemMessage = buildApplicantScoringProblemMessage(scoreStatus, warningRows, item);
      nodes.scorePanel.innerHTML = ''
        + '<div class="pte-score-panel is-warning">'
        + '  <div class="pte-score-head">'
        + '    <div>'
        + '      <div class="pte-score-title">' + esc(label) + '</div>'
        + '      <div class="pte-score-subtitle">' + esc(problemMessage) + '</div>'
        + renderScoreWarnings(scoring)
        + '    </div>'
        + '  </div>'
        + '</div>';
      return;
    }

    const scoreFinal = scoreNumber(item?.scoreFinal, 0);
    const maxScore = Math.max(0, scoreNumber(item?.maxScore, 0));
    const percentage = maxScore > 0 ? (scoreFinal / maxScore) * 100 : scoreNumber(item?.percentage, 0);
    const traitScores = (item?.traitScores && typeof item.traitScores === 'object') ? item.traitScores : {};
    const feedback = resolveScoreFeedback(item, scoring);
    const transcript = clean(scoring?.transcript || '');
    const writtenResponse = clean(scoring?.responseText || '');
    const scoredAt = clean(scoring?.scoredAt || '');
    const scoredAtDate = scoredAt ? new Date(scoredAt) : null;
    const scoredAtText = scoredAtDate && !Number.isNaN(scoredAtDate.getTime())
      ? ((window.AppOrgDateTime && AppOrgDateTime.formatInstant) ? AppOrgDateTime.formatInstant(scoredAtDate) : scoredAtDate.toLocaleString())
      : '';

    nodes.scorePanel.innerHTML = ''
      + '<div class="pte-score-panel">'
      + '  <div class="pte-score-head">'
      + '    <div>'
      + '      <div class="pte-score-title">' + esc(getScorePanelTitle(item, scoring)) + '</div>'
      + '      <div class="pte-score-subtitle">'
      + esc(feedback.summary || 'Rubric-based item score, not an official PTE 10-90 estimate.')
      + (scoredAtText ? (' | ' + esc(scoredAtText)) : '')
      + '      </div>'
      + '    </div>'
      + '    <div class="pte-score-total">'
      + '      <div class="pte-score-total-value">' + esc(formatScoreNumber(scoreFinal)) + ' / ' + esc(formatScoreNumber(maxScore)) + '</div>'
      + '      <div class="pte-score-total-label">' + esc(formatScoreNumber(percentage)) + '%</div>'
      + '    </div>'
      + '  </div>'
      + '  <div class="pte-score-traits">'
      + renderScoreTraitRows(item, scoring, traitScores, maxScore)
      + '  </div>'
      + '  <div class="pte-score-feedback-grid">'
      + renderScoreFeedbackBlock('Already Good', feedback.strengths, 'text-success-emphasis')
      + renderScoreFeedbackBlock('Needs Improvement', feedback.improvements, 'text-warning-emphasis')
      + renderScoreFeedbackBlock('Level-Up Step', [feedback.nextPracticeAction], 'text-primary-emphasis')
      + '  </div>'
      + (transcript
        ? ('  <div class="small text-muted mt-3"><strong>Transcript:</strong> ' + esc(transcript) + '</div>')
        : '')
      + (!transcript && writtenResponse
        ? ('  <div class="small text-muted mt-3"><strong>Written response:</strong> ' + esc(writtenResponse) + '</div>')
        : '')
      + renderScoreWarnings(scoring)
      + '</div>';
  }

  function runCoachSelfCheck(item, options = {}) {
    if (!item || !coachRules || typeof coachRules.runSelfCheck !== 'function') return null;
    persistCurrentDraft();
    const runtime = getItemRuntime(item);
    const coaching = ensureCoachingRuntime(runtime);
    const context = buildCoachContext(item);
    const result = coachRules.runSelfCheck(context);
    coaching.selfCheck = normalizeCoachingRuntime({
      selfCheck: result
    }).selfCheck;
    coaching.timestamps.lastSelfCheckAt = isoNow();
    runtime.coaching = coaching;
    renderCoachPanel(item, { readOnly: options?.readOnly === true });
    return result;
  }

  async function requestCoachHint(item) {
    if (!item || !coachRules || typeof coachRules.getHint !== 'function') return;
    const runtime = getItemRuntime(item);
    const coaching = ensureCoachingRuntime(runtime);
    const now = nowMs();
    const cooldownUntilMs = Math.max(0, toInt(coaching.cooldownUntilMs, 0));
    if (cooldownUntilMs > now) {
      const remaining = Math.max(1, Math.ceil((cooldownUntilMs - now) / 1000));
      await showMessage('Hint Cooldown', 'Please wait ' + remaining + ' second(s) before requesting another hint.', 'info');
      renderCoachPanel(item);
      return;
    }

    state.coach.hintBusy = true;
    setCoachActionButtonsState(item, false);
    try {
      persistCurrentDraft();
      const nextLevel = Math.min(3, Math.max(1, toInt(coaching.hintLevelUsed, 0) + 1));
      const context = buildCoachContext(item);
      const hint = coachRules.getHint({
        questionType: context.questionType,
        payload: context.payload,
        response: context.response,
        runtime: context.runtime,
        level: nextLevel
      });
      if (!hint || !clean(hint.text || '')) return;
      coaching.hintLevelUsed = Math.max(0, toInt(hint.level, nextLevel));
      coaching.hintsShown = Array.isArray(coaching.hintsShown) ? coaching.hintsShown : [];
      coaching.hintsShown.push({
        level: coaching.hintLevelUsed,
        text: clean(hint.text || ''),
        shownAt: isoNow()
      });
      if (coaching.hintsShown.length > 40) coaching.hintsShown = coaching.hintsShown.slice(-40);
      if (!clean(coaching.timestamps.firstHintAt || '')) coaching.timestamps.firstHintAt = isoNow();
      coaching.timestamps.lastHintAt = isoNow();
      coaching.cooldownUntilMs = nowMs() + state.coach.hintCooldownMs;
      runtime.coaching = coaching;
      renderCoachPanel(item);
    } finally {
      state.coach.hintBusy = false;
      setCoachActionButtonsState(item, false);
    }
  }

  function buildCoachAfterSubmitFeedback(item) {
    if (strictMockExam) return null;
    if (!item || !coachRules || typeof coachRules.buildAfterSubmitFeedback !== 'function') return null;
    const runtime = getItemRuntime(item);
    const coaching = ensureCoachingRuntime(runtime);
    const context = buildCoachContext(item);
    const feedback = coachRules.buildAfterSubmitFeedback(context);
    if (!feedback || typeof feedback !== 'object') return null;
    const normalized = normalizeCoachingRuntime({
      afterSubmitFeedback: feedback
    }).afterSubmitFeedback;
    coaching.afterSubmitFeedback = normalized;
    coaching.timestamps.lastFeedbackAt = isoNow();
    runtime.coaching = coaching;
    return normalized;
  }

  async function confirmCoachSelfCheckBeforeSave(item) {
    if (strictMockExam) return true;
    if (!item || !itemSupportsCoach(item)) return true;
    const selfCheck = runCoachSelfCheck(item);
    if (!selfCheck || selfCheck.passed) return true;
    const warningText = 'Self-check found ' + selfCheck.warnCount + ' item(s) to review. Do you want to submit anyway?';
    if (typeof window.showMessageModal === 'function') {
      const choice = await window.showMessageModal({
        title: 'Review Before Submit?',
        message: warningText,
        icon: 'warning',
        buttons: [
          { text: 'Review first', class: 'btn-secondary' },
          { text: 'Submit anyway', class: 'btn-warning' }
        ]
      });
      return choice === 'Submit anyway';
    }
    return window.confirm(warningText);
  }

  function refreshSummarizeSpokenTextMeta(item, textArea = null) {
    const active = item || getActiveItem();
    if (!active) return;
    const questionType = normalizeQuestionTypeToken(active?.question?.questionType || active?.questionType || '');
    const isManagedWordCountType = questionType === 'listening_summarize_spoken_text'
      || questionType === 'listening_dictation'
      || questionType === 'writing_summarize_written_text'
      || questionType === 'writing_write_email';
    if (!isManagedWordCountType) return;
    const targetArea = textArea || nodes.response?.querySelector('textarea[data-sst-editor="true"]');
    if (!targetArea) return;
    const host = targetArea.closest('[data-sst-editor-wrap="true"]') || nodes.response;
    if (!host) return;
    const countNode = host.querySelector('[data-sst-word-count]');
    const badgeNode = host.querySelector('[data-sst-word-count-badge]');
    const statusNode = host.querySelector('[data-sst-word-status]');
    const minWords = Math.max(0, toInt(targetArea.getAttribute('data-sst-min-words'), 0));
    const maxWords = Math.max(0, toInt(targetArea.getAttribute('data-sst-max-words'), 0));
    const fallbackMode = questionType === 'listening_dictation'
      ? 'dictation'
      : (questionType === 'writing_write_email'
        ? 'email'
        : (questionType === 'writing_summarize_written_text' ? 'written_summary' : 'summary'));
    const modeToken = clean(targetArea.getAttribute('data-sst-mode') || fallbackMode).toLowerCase();
    const mode = modeToken === 'dictation'
      ? 'dictation'
      : (modeToken === 'email'
        ? 'email'
        : (modeToken === 'written_summary' ? 'written_summary' : 'summary'));
    const words = countWords(targetArea.value);
    const stateMeta = getSummarizeSpokenTextWordState(words, minWords, maxWords, { mode });

    if (countNode) countNode.textContent = String(words);

    if (badgeNode) {
      badgeNode.classList.remove('tone-neutral', 'tone-low', 'tone-good', 'tone-high');
      badgeNode.classList.add('tone-' + stateMeta.tone);
    }

    if (statusNode) {
      statusNode.textContent = stateMeta.message;
      statusNode.classList.remove('text-muted', 'text-warning', 'text-success', 'text-danger');
      if (stateMeta.tone === 'low') statusNode.classList.add('text-warning');
      else if (stateMeta.tone === 'good') statusNode.classList.add('text-success');
      else if (stateMeta.tone === 'high') statusNode.classList.add('text-danger');
      else statusNode.classList.add('text-muted');
    }
  }

  function renderQuestionPrompt(item) {
    const question = item?.question || {};
    const payload = (question.payload && typeof question.payload === 'object') ? question.payload : {};
    const qType = normalizeQuestionTypeToken(question.questionType || item?.questionType || '');
    const instructionText = clean(payload.instructions || question.instructions || '');
    const taskTitle = clean(
      payload.taskTitle
      || payload.promptTitle
      || payload.sourceTitle
      || payload.stemTitle
      || question.title
      || item?.metadata?.questionTitle
      || ''
    );
    const normalizePromptToken = (value) => clean(value).toLowerCase().replace(/\s+/g, ' ').trim();
    let html = '';
    let hasPromptBody = false;
    const promptTokenSet = new Set();

    const rememberToken = (value) => {
      const token = normalizePromptToken(value);
      if (token) promptTokenSet.add(token);
    };

    const appendPromptBody = (value, className = 'mb-2') => {
      const text = clean(value);
      const token = normalizePromptToken(text);
      if (!token || promptTokenSet.has(token)) return;
      promptTokenSet.add(token);
      hasPromptBody = true;
      html += '<div class="' + className + '">' + nl2br(text) + '</div>';
    };

    const buildPromptInfoPopover = (infoLines = [], ariaLabel = 'Prompt details') => {
      const normalizedInfoLines = Array.isArray(infoLines)
        ? infoLines.map((line) => clean(line)).filter(Boolean)
        : [];
      if (!normalizedInfoLines.length) return '';
      const infoPopoverId = `ptePromptInfo_${Math.random().toString(36).slice(2, 10)}`;
      return ''
        + '<span class="pte-situation-info-wrap" data-situation-info-wrap>'
        + '  <button type="button" class="pte-situation-info-btn" data-situation-info-toggle data-no-wait="true" aria-label="' + esc(clean(ariaLabel) || 'Prompt details') + '" aria-expanded="false" aria-controls="' + esc(infoPopoverId) + '" title="' + esc(normalizedInfoLines.join('\n')) + '">i</button>'
        + '  <div id="' + esc(infoPopoverId) + '" class="pte-situation-info-popover" role="tooltip">'
        + normalizedInfoLines.map((line) => ('<div class="pte-situation-info-line">' + esc(line) + '</div>')).join('')
        + '  </div>'
        + '</span>';
    };

    const appendSituationBlock = (value, { vivid = false, infoLines = [] } = {}) => {
      const raw = clean(value);
      if (!raw) return;
      const body = clean(raw.replace(/^situation\s*:\s*/i, '')) || raw;
      const token = normalizePromptToken(body);
      if (!token || promptTokenSet.has(token)) return;
      promptTokenSet.add(token);
      hasPromptBody = true;
      if (vivid) {
        const infoPopoverMarkup = buildPromptInfoPopover(infoLines, 'Situation details');
        html += ''
          + '<div class="pte-hiw-wrap mb-3">'
          + '  <div class="pte-hiw-label">'
          + '    <span>Situation</span>'
          + infoPopoverMarkup
          + '  </div>'
          + '  <div class="pte-hiw-passage pte-hiw-passage-static">' + nl2br(body) + '</div>'
          + '</div>';
      } else {
        html += ''
          + '<div class="mb-3">'
          + '  <div class="small fw-bold text-uppercase text-muted mb-1">Situation</div>'
          + '  <div class="border rounded p-2 bg-white">' + nl2br(body) + '</div>'
          + '</div>';
      }
    };

    const appendGenericPromptBodies = () => {
      appendPromptBody(payload.sourceText, 'mb-2');
      appendPromptBody(payload.stem, 'fw-bold mb-2');
      appendSituationBlock(payload.situationText);
      appendSituationBlock(payload.scenarioText);
      const promptText = clean(payload.promptText);
      if (/^situation\s*:/i.test(promptText)) appendSituationBlock(promptText);
      else appendPromptBody(promptText, 'mb-2');
      appendPromptBody(payload.transcriptWithBlanks, 'mb-2');
      appendPromptBody(payload.passageWithBlanks, 'mb-2');
      appendPromptBody(payload.promptTextOrAudio, 'mb-2');
      if (payload.expectedTranscript && !hasPromptBody) {
        appendPromptBody(payload.expectedTranscript, 'mb-2');
      }
    };

    const appendWritingScenarioBlock = (value, { infoLines = [] } = {}) => {
      const raw = clean(value);
      if (!raw) return;
      const body = clean(raw.replace(/^scenario(\s+text)?\s*:\s*/i, '').replace(/^situation\s*:\s*/i, '')) || raw;
      const token = normalizePromptToken(body);
      if (!token || promptTokenSet.has(token)) return;
      promptTokenSet.add(token);
      hasPromptBody = true;
      const infoPopoverMarkup = buildPromptInfoPopover(infoLines, 'Scenario details');
      html += ''
        + '<div class="pte-hiw-wrap mb-3">'
        + '  <div class="pte-hiw-label"><span>Scenario Text</span>' + infoPopoverMarkup + '</div>'
        + '  <div class="pte-hiw-passage pte-hiw-passage-static">' + nl2br(body) + '</div>'
        + '</div>';
    };

    const appendWritingSourceBlock = (value, { infoLines = [] } = {}) => {
      const raw = clean(value);
      if (!raw) return;
      const body = clean(raw.replace(/^source(\s+text)?\s*:\s*/i, '').replace(/^passage\s*:\s*/i, '')) || raw;
      const token = normalizePromptToken(body);
      if (!token || promptTokenSet.has(token)) return;
      promptTokenSet.add(token);
      hasPromptBody = true;
      const infoPopoverMarkup = buildPromptInfoPopover(infoLines, 'Source details');
      html += ''
        + '<div class="pte-hiw-wrap mb-3">'
        + '  <div class="pte-hiw-label"><span>Source Text</span>' + infoPopoverMarkup + '</div>'
        + '  <div class="pte-hiw-passage pte-hiw-passage-static">' + nl2br(body) + '</div>'
        + '</div>';
    };

    const appendWritingPromptBlock = (value, label = 'Prompt') => {
      const raw = clean(value);
      if (!raw) return;
      const body = raw;
      const token = normalizePromptToken(body);
      if (!token || promptTokenSet.has(token)) return;
      promptTokenSet.add(token);
      hasPromptBody = true;
      html += ''
        + '<div class="pte-hiw-wrap mb-3">'
        + '  <div class="pte-hiw-label">' + esc(label || 'Prompt') + '</div>'
        + '  <div class="pte-hiw-passage pte-hiw-passage-static">' + nl2br(body) + '</div>'
        + '</div>';
    };

    const appendReadAloudSourceBlock = (value) => {
      const raw = clean(value);
      if (!raw) return;
      const body = clean(raw.replace(/^source(\s+text)?\s*:\s*/i, '').replace(/^passage\s*:\s*/i, '')) || raw;
      const token = normalizePromptToken(body);
      if (!token || promptTokenSet.has(token)) return;
      promptTokenSet.add(token);
      hasPromptBody = true;
      html += ''
        + '<div class="pte-hiw-wrap mb-3">'
        + '  <div class="pte-hiw-label">Passage</div>'
        + '  <div class="pte-hiw-passage pte-hiw-passage-static">' + nl2br(body) + '</div>'
        + '</div>';
    };

    const appendReadingPassageBlock = (value, label = 'Passage') => {
      const raw = clean(value);
      if (!raw) return;
      const body = clean(raw.replace(/^source(\s+text)?\s*:\s*/i, '').replace(/^passage\s*:\s*/i, '')) || raw;
      const token = normalizePromptToken(body);
      if (!token || promptTokenSet.has(token)) return;
      promptTokenSet.add(token);
      hasPromptBody = true;
      html += ''
        + '<div class="pte-hiw-wrap mb-3">'
        + '  <div class="pte-hiw-label">' + esc(label || 'Passage') + '</div>'
        + '  <div class="pte-hiw-passage pte-hiw-passage-static">' + nl2br(body) + '</div>'
        + '</div>';
    };

    if (instructionText) {
      html += ''
        + '<div class="mb-4">'
        + '  <h6 class="pte-tier-title mb-2">Instruction</h6>'
        + '  <div class="pte-question-instruction-text">' + nl2br(instructionText) + '</div>'
        + '</div>';
      rememberToken(instructionText);
    }
    if (taskTitle) rememberToken(taskTitle);

    switch (qType) {
      case 'speaking_read_aloud': {
        html += '<div class="pte-writing-summary-chip mb-2"><i class="bi bi-megaphone-fill"></i><span>Read Aloud</span></div>';
        hasPromptBody = true;
        appendReadAloudSourceBlock(payload.sourceText || payload.promptText || payload.stem || payload.promptTextOrAudio);
        appendPromptBody(payload.promptText, 'mb-2');
        break;
      }
      case 'speaking_repeat_sentence': {
        const repeatSentenceTranscript = clean(payload.expectedTranscript || payload.transcript || '');
        const audioBlock = renderPromptAudioBlock(question, payload.promptAudioAssetId, '', {
          autoPlay: false,
          showSinglePlayNote: true,
          playDelaySeconds: 3,
          showNotesButton: true,
          notesButtonLabel: 'Speaking Notes',
          showTranscriptButton: true,
          transcriptButtonLabel: 'Transcript',
          transcriptText: repeatSentenceTranscript
        });
        if (audioBlock) {
          html += audioBlock;
          hasPromptBody = true;
        } else {
          html += '<div class="small text-warning mb-2">Prompt audio is not attached yet.</div>';
        }
        appendPromptBody(payload.promptTextOrAudio, 'mb-2');
        break;
      }
      case 'speaking_describe_image': {
        const imageBlock = renderPromptImageBlock(question, payload.imageAssetId, '', {
          showNotesButton: true,
          notesButtonLabel: 'Speaking Notes'
        });
        if (imageBlock) {
          html += imageBlock;
          hasPromptBody = true;
        } else {
          html += '<div class="small text-warning mb-2">Prompt image is not attached yet.</div>';
        }
        appendPromptBody(payload.imageCaption, 'small text-muted mb-2');
        appendPromptBody(payload.sourceText, 'mb-2');
        break;
      }
      case 'speaking_respond_to_situation': {
        const roleParts = [
          clean(payload.role) ? ('Role: ' + clean(payload.role)) : '',
          clean(payload.audience) ? ('Audience: ' + clean(payload.audience)) : '',
          clean(payload.targetFunction) ? ('Function: ' + clean(payload.targetFunction)) : '',
          clean(payload.targetRegister) ? ('Register: ' + clean(payload.targetRegister)) : ''
        ].filter(Boolean);
        appendSituationBlock(payload.situationText || payload.scenarioText || payload.promptText, {
          vivid: true,
          infoLines: roleParts
        });
        appendPromptBody(payload.promptText, 'mb-2');
        break;
      }
      case 'speaking_answer_short_question': {
        const asqAudioRef = clean(payload.promptAudioAssetId) || clean(payload.promptTextOrAudio);
        const asqAudioUrl = resolveQuestionMediaUrl(question, asqAudioRef);
        const asqTranscriptText = clean(payload.transcript);
        const audioBlock = renderAudioPlayerBlockByUrl(asqAudioUrl, '', {
          autoPlay: false,
          showSinglePlayNote: true,
          playDelaySeconds: 3,
          showNotesButton: true,
          notesButtonLabel: 'Speaking Notes',
          showTranscriptButton: true,
          transcriptButtonLabel: 'Transcript',
          transcriptText: asqTranscriptText
        });
        if (audioBlock) {
          html += audioBlock;
          hasPromptBody = true;
        }
        if (!asqAudioUrl) {
          appendPromptBody(payload.promptTextOrAudio || payload.promptText || payload.stem, 'mb-2');
        } else {
          appendPromptBody(payload.promptText || payload.stem, 'mb-2');
        }
        if (asqTranscriptText) {
          hasPromptBody = true;
          rememberToken(asqTranscriptText);
        }
        break;
      }
      case 'writing_write_email': {
        const emailTimerTotalSeconds = getWritingTimerTotalSeconds(item);
        const emailTimerSeed = emailTimerTotalSeconds > 0
          ? formatClock(getWritingTimerRemainingSeconds(item, emailTimerTotalSeconds))
          : '';
        const metaParts = [
          clean(payload.senderRole) ? ('Sender: ' + clean(payload.senderRole)) : '',
          clean(payload.recipientRole) ? ('Recipient: ' + clean(payload.recipientRole)) : '',
          clean(payload.purpose) ? ('Purpose: ' + clean(payload.purpose)) : '',
          clean(payload.targetRegister) ? ('Register: ' + clean(payload.targetRegister)) : ''
        ].filter(Boolean);
        html += '<div class="pte-writing-badge-row mb-2">'
          + '<div class="pte-writing-summary-chip"><i class="bi bi-envelope-paper-fill"></i><span>Writing Email</span></div>'
          + (emailTimerTotalSeconds > 0
            ? ('<span class="pte-writing-prompt-timer timer-summary timer-good" data-writing-prompt-timer-wrap>'
              + '  <i class="bi bi-hourglass-split"></i>'
              + '  <span data-writing-prompt-timer>' + esc(emailTimerSeed) + '</span>'
              + '  <span class="timer-state" data-writing-prompt-timer-state>Left</span>'
              + '</span>')
            : '')
          + '</div>';
        hasPromptBody = true;
        appendWritingScenarioBlock(payload.scenarioText || payload.situationText || payload.promptText || payload.stem, {
          infoLines: metaParts
        });
        appendPromptBody(payload.promptText, 'mb-2');
        break;
      }
      case 'writing_summarize_written_text': {
        const summaryTimerTotalSeconds = getWritingTimerTotalSeconds(item);
        const summaryTimerSeed = summaryTimerTotalSeconds > 0
          ? formatClock(getWritingTimerRemainingSeconds(item, summaryTimerTotalSeconds))
          : '';
        const summaryMeta = [
          clean(payload.sourceTitle) ? ('Source: ' + clean(payload.sourceTitle)) : '',
          toInt(payload.minWords, 0) > 0
            ? ('Word Limit: ' + toInt(payload.minWords, 0) + (toInt(payload.maxWords, 0) > 0 ? (' - ' + toInt(payload.maxWords, 0)) : '+'))
            : '',
          toInt(payload.recommendedTimeMinutes, 0) > 0
            ? ('Time: ' + toInt(payload.recommendedTimeMinutes, 0) + ' min')
            : ''
        ].filter(Boolean);
        html += '<div class="pte-writing-badge-row mb-2">'
          + '<div class="pte-writing-summary-chip"><i class="bi bi-pencil-square"></i><span>Summarize Written Text</span></div>'
          + (summaryTimerTotalSeconds > 0
            ? ('<span class="pte-writing-prompt-timer timer-summary timer-good" data-writing-prompt-timer-wrap>'
              + '  <i class="bi bi-hourglass-split"></i>'
              + '  <span data-writing-prompt-timer>' + esc(summaryTimerSeed) + '</span>'
              + '  <span class="timer-state" data-writing-prompt-timer-state>Left</span>'
              + '</span>')
            : '')
          + '</div>';
        hasPromptBody = true;
        appendWritingSourceBlock(payload.sourceText || payload.promptText || payload.stem, {
          infoLines: summaryMeta
        });
        appendPromptBody(payload.promptText, 'mb-2');
        break;
      }
      case 'writing_short_answer': {
        appendWritingPromptBlock(payload.promptText || payload.stem || payload.sourceText, 'Prompt');
        break;
      }
      case 'writing_essay': {
        appendWritingPromptBlock(payload.promptText || payload.stem || payload.sourceText, 'Prompt');
        break;
      }
      case 'listening_mcq_single':
      case 'listening_mcq_multiple':
      case 'listening_summarize_spoken_text':
      case 'listening_fill_in_blank':
      case 'listening_select_missing_word':
      case 'listening_highlight_incorrect_words':
      case 'listening_dictation': {
        const listeningTranscriptText = getListeningTranscriptForPrompt(payload, qType);
        const audioBlock = renderPromptAudioBlock(question, payload.promptAudioAssetId, 'Listening Audio', {
          autoPlay: false,
          playDelaySeconds: 3,
          showNotesButton: true,
          notesButtonLabel: 'Listening Notes',
          showTranscriptButton: true,
          transcriptButtonLabel: 'Transcript',
          transcriptText: listeningTranscriptText
        });
        if (audioBlock) {
          html += audioBlock;
          hasPromptBody = true;
        } else {
          html += '<div class="small text-warning mb-2">Listening audio is not attached yet.</div>';
        }
        appendPromptBody(payload.stem, 'fw-bold mb-2');
        if (qType === 'listening_fill_in_blank') {
          // Keep prompt compact; response panel provides the blank-completion interaction.
        } else if (qType === 'listening_select_missing_word') {
          // Keep prompt compact for missing-word items; response panel is enough.
        } else if (qType === 'listening_highlight_incorrect_words') {
          // Keep prompt area concise; interactive transcript appears in response panel.
        }
        appendPromptBody(payload.promptText, 'mb-2');
        break;
      }
      case 'reading_mcq_single':
      case 'reading_mcq_multiple':
      case 'reading_true_false': {
        appendReadingPassageBlock(payload.passageHtml || payload.sourceText, 'Passage');
        appendPromptBody(payload.stem, 'fw-bold mb-2');
        appendPromptBody(payload.promptText, 'mb-2');
        break;
      }
      case 'reading_fill_in_blank':
      case 'reading_writing_fill_in_blank':
        appendPromptBody(payload.stem, 'fw-bold mb-2');
        // Keep prompt compact; response panel provides the blank-completion interaction.
        break;
      case 'reading_reorder_paragraphs': {
        const rows = Array.isArray(payload.paragraphItems) ? payload.paragraphItems : [];
        appendPromptBody(payload.passageTitle, 'fw-bold mb-2');
        if (rows.length >= 2) {
          // Keep prompt concise; instruction already explains the reorder task.
        }
        appendPromptBody(payload.stem, 'fw-bold mb-2');
        break;
      }
      case 'reading_matching':
      case 'listening_matching': {
        if (qType === 'listening_matching') {
          const listeningMatchingTranscript = getListeningTranscriptForPrompt(payload, qType);
          const audioBlockWithTools = renderPromptAudioBlock(question, payload.promptAudioAssetId, 'Listening Audio', {
            autoPlay: false,
            playDelaySeconds: 3,
            showNotesButton: true,
            notesButtonLabel: 'Listening Notes',
            showTranscriptButton: true,
            transcriptButtonLabel: 'Transcript',
            transcriptText: listeningMatchingTranscript
          });
          if (audioBlockWithTools) {
            html += audioBlockWithTools;
            hasPromptBody = true;
          } else {
            html += '<div class="small text-warning mb-2">Listening audio is not attached yet.</div>';
          }
        }
        appendPromptBody(payload.stem, 'fw-bold mb-2');
        const leftCount = Array.isArray(payload.leftItems) ? payload.leftItems.length : 0;
        const rightCount = Array.isArray(payload.rightItems) ? payload.rightItems.length : 0;
        if (leftCount || rightCount) {
          html += '<div class="small text-muted mb-2">Matching Items: Left ' + leftCount + ' / Right ' + rightCount + '</div>';
          hasPromptBody = true;
        }
        break;
      }
      default:
        appendGenericPromptBodies();
        break;
    }

    if (!hasPromptBody && payload.imageAssetId) {
      const imageBlock = renderPromptImageBlock(question, payload.imageAssetId, 'Prompt Image');
      if (imageBlock) {
        html += imageBlock;
        hasPromptBody = true;
      }
    }

    if (
      isSpeakingQuestion(item)
      && qType !== 'speaking_answer_short_question'
      && qType !== 'speaking_repeat_sentence'
      && qType !== 'speaking_read_aloud'
      && qType !== 'speaking_respond_to_situation'
    ) {
      const timing = getSpeakingTiming(item);
      const prepText = timing.prepSeconds > 0 ? ('Prep ' + timing.prepSeconds + 's') : '';
      const responseText = timing.responseSeconds > 0 ? ('Response ' + timing.responseSeconds + 's') : '';
      const timingLabel = [prepText, responseText].filter(Boolean).join(' / ');
      if (timingLabel) {
        html += '<div class="badge bg-primary-subtle text-primary-emphasis border mt-1">' + esc(timingLabel) + '</div>';
      }
    }

    if (!html) {
      html = '<div class="text-muted">Prompt preview is not available for this type yet. Continue with response actions for runtime tracking.</div>';
    }

    if (
      Array.isArray(payload.options)
      && payload.options.length
      && !qType.includes('matching')
      && !qType.includes('mcq_multiple')
      && !qType.includes('mcq_single')
      && qType !== 'listening_select_missing_word'
    ) {
      html += '<hr><div class="small fw-bold mb-1">Options</div><ul class="small mb-0">';
      payload.options.forEach((opt) => {
        const key = clean(opt && (opt.key || opt.id || ''));
        const text = clean(opt && (opt.text || opt.label || opt.value || ''));
        html += '<li><span class="font-monospace">' + esc(key || '-') + '</span> - ' + esc(text || '-') + '</li>';
      });
      html += '</ul>';
    }

    return html;
  }

  function renderResponsePanel(item, options = {}) {
    const question = item?.question || {};
    const payload = (question.payload && typeof question.payload === 'object') ? question.payload : {};
    const qType = normalizeQuestionTypeToken(question.questionType || item.questionType || '');
    const speakingTiming = isSpeakingQuestion(item)
      ? getSpeakingTiming(item)
      : { prepSeconds: 0, responseSeconds: 0 };
    const runtime = getItemRuntime(item);
    const readOnly = options?.readOnly === true;
    const canReanswer = options?.canReanswer === true;
    const disabledAttr = readOnly ? ' disabled' : '';
    const readOnlyAttr = readOnly ? ' readonly' : '';
    let html = '';

    if (isSpeakingQuestion(item)) {
      html = ''
        + '<div id="pteSpeakPanel" class="pte-speak-panel border rounded p-3 bg-light-subtle mb-3">'
        + '  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">'
        + '    <div class="d-flex align-items-center flex-wrap gap-2">'
        + '      <span id="pteSpeakPhaseChip" class="badge bg-primary-subtle text-primary-emphasis border">Ready</span>'
        + (speakingTiming.responseSeconds > 0
          ? ('      <span class="badge bg-primary-subtle text-primary-emphasis border">Response ' + esc(formatSeconds(speakingTiming.responseSeconds)) + '</span>')
          : '')
        + '    </div>'
        + '    <span id="pteSpeakTimerChip" class="badge bg-light text-dark border" style="display:none;"></span>'
        + '  </div>'
        + '  <div id="pteSpeakTimerDisplay" class="pte-speak-timer-display"></div>'
        + '  <div id="pteSpeakProgressWrap" class="pte-speak-progress-wrap" style="display:none;">'
        + '    <div class="progress mb-1" style="height: 12px;">'
        + '      <div id="pteSpeakProgressBar" class="progress-bar bg-secondary" role="progressbar" style="width:0%;"></div>'
        + '    </div>'
        + '    <div id="pteSpeakProgressLabel" class="small fw-bold text-muted mb-2" style="display:none;"></div>'
        + '  </div>'
        + '  <div id="pteSpeakHint" class="small text-muted mb-2">' + (readOnly ? 'Saved speaking response (review mode).' : 'Speaking response requires microphone recording.') + '</div>'
        + '  <div class="d-flex align-items-center gap-2 flex-wrap mb-2">'
        + '    <button type="button" id="pteSpeakStartBtn" class="btn btn-outline-primary btn-sm"' + disabledAttr + '><i class="bi bi-mic me-1"></i>Start Recording</button>'
        + '    <button type="button" id="pteSpeakStopBtn" class="btn btn-outline-danger btn-sm" disabled><i class="bi bi-stop-circle me-1"></i>Stop</button>'
        + '  </div>'
        + '  <div id="pteSpeakPlayback"></div>'
        + '</div>';
    } else if (qType.includes('mcq_single') || qType === 'listening_select_missing_word') {
      const options = Array.isArray(payload.options) ? payload.options : [];
      const choiceRows = options.map((row, index) => {
        const key = clean(row && (row.key || row.id || String.fromCharCode(65 + index)));
        const text = clean(row && (row.text || row.label || row.value || ''));
        const checked = runtime.selectedSingle && runtime.selectedSingle === key ? ' checked' : '';
        return ''
          + '<label class="pte-choice-response-item" for="practice_single_' + index + '">'
          + '  <input class="form-check-input" type="radio" name="practice_single_choice" id="practice_single_' + index + '" value="' + esc(key) + '"' + checked + disabledAttr + '>'
          + '  <span class="pte-choice-response-key">' + esc(key) + '</span>'
          + '  <span class="pte-choice-response-text">' + esc(text) + '</span>'
          + '</label>';
      }).join('');
      html = ''
        + '<div class="pte-response-focus-wrap">'
        + '  <div class="pte-response-focus-title">Response</div>'
        + '  <div class="pte-choice-response-list">' + choiceRows + '</div>'
        + '</div>';
    } else if (qType.includes('mcq_multiple')) {
      const options = Array.isArray(payload.options) ? payload.options : [];
      const selectedSet = new Set(Array.isArray(runtime.selectedMultiple) ? runtime.selectedMultiple : []);
      const choiceRows = options.map((row, index) => {
        const key = clean(row && (row.key || row.id || String.fromCharCode(65 + index)));
        const text = clean(row && (row.text || row.label || row.value || ''));
        const checked = selectedSet.has(key) ? ' checked' : '';
        return ''
          + '<label class="pte-choice-response-item" for="practice_multi_' + index + '">'
          + '  <input class="form-check-input" type="checkbox" name="practice_multi_choice" id="practice_multi_' + index + '" value="' + esc(key) + '"' + checked + disabledAttr + '>'
          + '  <span class="pte-choice-response-key">' + esc(key) + '</span>'
          + '  <span class="pte-choice-response-text">' + esc(text) + '</span>'
          + '</label>';
      }).join('');
      html = ''
        + '<div class="pte-response-focus-wrap">'
        + '  <div class="pte-response-focus-title">Response</div>'
        + '  <div class="pte-choice-response-list">' + choiceRows + '</div>'
        + '</div>';
    } else if (qType.includes('true_false')) {
      html = ''
        + '<label class="form-label fw-bold">Select</label>'
        + '<select class="form-select" data-response-true-false' + disabledAttr + '>'
        + '  <option value="">-- Select --</option>'
        + '  <option value="true"' + (runtime.selectedTrueFalse === 'true' ? ' selected' : '') + '>True</option>'
        + '  <option value="false"' + (runtime.selectedTrueFalse === 'false' ? ' selected' : '') + '>False</option>'
        + '  <option value="not_given"' + (runtime.selectedTrueFalse === 'not_given' ? ' selected' : '') + '>Not Given</option>'
        + '</select>';
    } else if (qType === 'listening_highlight_incorrect_words') {
      const displayText = clean(
        payload.transcriptText
        || payload.promptText
        || payload.stem
        || payload.transcript
      );
      const hiwUi = buildHighlightIncorrectResponseUi(displayText, runtime, { readOnly });
      runtime.textDraft = hiwUi.responseText;
      runtime.mapText = hiwUi.mapText;
      html = ''
        + '<div class="pte-hiw-wrap mb-3">'
        + '  <div class="pte-hiw-label">Displayed Transcript</div>'
        + '  <div class="pte-hiw-passage" data-hiw-passage>' + (hiwUi.html || '<span class="text-muted">No transcript text is available.</span>') + '</div>'
        + '</div>'
        + '<label class="form-label fw-bold">Response</label>'
        + '<textarea class="form-control" rows="4" data-response-text readonly aria-readonly="true" placeholder="Highlighted words will appear here automatically...">' + esc(hiwUi.responseText || '') + '</textarea>'
        + '<div class="small text-muted mt-2"><span data-hiw-selected-count>' + String(hiwUi.selectedWords.length) + '</span> word(s) highlighted.</div>';
    } else if (
      qType === 'listening_summarize_spoken_text'
      || qType === 'listening_dictation'
      || qType === 'writing_summarize_written_text'
      || qType === 'writing_write_email'
    ) {
      const responseText = String(runtime.textDraft || '');
      const isDictation = qType === 'listening_dictation';
      const isWritingSummary = qType === 'writing_summarize_written_text';
      const isWriteEmail = qType === 'writing_write_email';
      const isSst = qType === 'listening_summarize_spoken_text';
      const minWords = isDictation ? 0 : Math.max(0, toInt(payload.minWords, 0));
      const maxWords = isDictation ? 0 : Math.max(0, toInt(payload.maxWords, 0));
      const words = countWords(responseText);
      const mode = isDictation
        ? 'dictation'
        : (isWriteEmail ? 'email' : (isWritingSummary ? 'written_summary' : 'summary'));
      const meta = getSummarizeSpokenTextWordState(words, minWords, maxWords, { mode });
      const toneClass = 'tone-' + meta.tone;
      const statusClass = meta.tone === 'low'
        ? 'text-warning'
        : (meta.tone === 'good'
          ? 'text-success'
          : (meta.tone === 'high' ? 'text-danger' : 'text-muted'));
      const rangeLabel = minWords > 0
        ? (maxWords > 0 ? (minWords + ' - ' + maxWords + ' words') : (minWords + '+ words'))
        : (maxWords > 0 ? ('Up to ' + maxWords + ' words') : 'Open length');
      const editorTitle = isDictation
        ? 'Dictation Draft'
        : (isWriteEmail ? 'Email Draft' : 'Summary Draft');
      const editorSubtitle = isDictation
        ? 'Type exactly what you hear. Edit carefully before saving.'
        : (isWriteEmail
          ? 'Write a clear email response that addresses the situation, purpose, and required points.'
          : (isWritingSummary
            ? 'Write one concise sentence that captures the passage meaning accurately.'
            : 'Write a clear, well-structured summary in your own words. Edit freely before saving.'));
      const editorPlaceholder = isDictation
        ? 'Type the dictated text here...'
        : (isWriteEmail
          ? 'Write your email response here...'
          : (isWritingSummary ? 'Write your one-sentence summary here...' : 'Start your spoken-text summary here...'));
      const requiredPoints = Array.isArray(payload.requiredPoints)
        ? payload.requiredPoints.map((row) => clean(row)).filter(Boolean)
        : [];
      const registerText = clean(payload.targetRegister || payload.expectedTone || '');
      const footerTip = isDictation
        ? 'Focus: capture the sentence exactly as spoken.'
        : (isWriteEmail
          ? ('Target length: ' + rangeLabel
            + (requiredPoints.length ? (' | Cover ' + requiredPoints.length + ' required point' + (requiredPoints.length === 1 ? '' : 's')) : '')
            + (registerText ? (' | Tone: ' + registerText) : ''))
          : ('Target length: ' + rangeLabel));
      const autoCapitalize = isWriteEmail || isSst || isWritingSummary ? 'sentences' : 'off';
      const writingTimerTotalSeconds = (!readOnly && (isWriteEmail || isWritingSummary))
        ? getWritingTimerTotalSeconds(item)
        : 0;
      const writingTimerSeed = writingTimerTotalSeconds > 0
        ? formatClock(getWritingTimerRemainingSeconds(item, writingTimerTotalSeconds))
        : '';
      html = ''
        + '<div class="pte-summary-editor-wrap" data-sst-editor-wrap="true">'
        + '  <div class="pte-summary-editor-head">'
        + '    <div>'
        + '      <div class="pte-summary-editor-title">' + esc(editorTitle) + '</div>'
        + '      <div class="pte-summary-editor-subtitle">' + esc(editorSubtitle) + '</div>'
        + '    </div>'
        + '    <div class="pte-summary-editor-meta">'
        + (writingTimerTotalSeconds > 0
          ? ('      <span class="pte-summary-editor-timer timer-good" data-writing-timer-wrap>'
            + '        <i class="bi bi-hourglass-split"></i>'
            + '        <span data-writing-timer>' + esc(writingTimerSeed) + '</span>'
            + '        <span class="timer-state" data-writing-timer-state>Left</span>'
            + '      </span>')
          : '')
        + '      <span class="pte-summary-editor-count ' + esc(toneClass) + '" data-sst-word-count-badge>'
        + '        <i class="bi bi-text-paragraph"></i>'
        + '        <span data-sst-word-count>' + String(words) + '</span> words'
        + '      </span>'
        + '    </div>'
        + '  </div>'
        + '  <textarea class="pte-summary-editor-textarea" rows="10" data-response-text data-sst-editor="true" data-sst-mode="' + esc(mode) + '" data-sst-min-words="' + String(minWords) + '" data-sst-max-words="' + String(maxWords) + '"' + readOnlyAttr + ' spellcheck="true" autocapitalize="' + esc(autoCapitalize) + '" placeholder="' + esc(editorPlaceholder) + '">' + esc(responseText) + '</textarea>'
        + '  <div class="pte-summary-editor-footer">'
        + '    <div class="pte-summary-editor-tip"><i class="bi bi-lightbulb me-1"></i>' + esc(footerTip) + '</div>'
        + '    <div class="pte-summary-editor-status ' + esc(statusClass) + '" data-sst-word-status>' + esc(meta.message) + '</div>'
        + '  </div>'
        + '</div>';
    } else if (qType === 'reading_fill_in_blank' || qType === 'listening_fill_in_blank' || qType === 'reading_writing_fill_in_blank') {
      const isReadingFillBlank = qType === 'reading_fill_in_blank';
      const isReadingWritingFillBlank = qType === 'reading_writing_fill_in_blank';
      const sourceText = clean(
        payload.passageWithBlanks
        || payload.transcriptWithBlanks
        || payload.transcriptWithGap
        || payload.promptText
        || payload.stem
      );
      const answerMap = (payload.blankAnswerMap && typeof payload.blankAnswerMap === 'object' && !Array.isArray(payload.blankAnswerMap))
        ? payload.blankAnswerMap
        : {};
      const runtimeMap = parseBlankResponseMap(runtime.mapText || '');
      const rendered = isReadingWritingFillBlank
        ? renderReadingWritingFillBlankPassageWithDropdowns(sourceText, {
          answerMap,
          optionsMap: (payload.blankOptionsMap && typeof payload.blankOptionsMap === 'object' && !Array.isArray(payload.blankOptionsMap))
            ? payload.blankOptionsMap
            : {},
          responseMap: runtimeMap,
          readOnly
        })
        : renderFillBlankPassageWithInputs(sourceText, {
          answerMap,
          responseMap: runtimeMap,
          readOnly,
          dragDropMode: isReadingFillBlank
        });

        if (rendered.slotCount > 0) {
          const authoredWordBankRows = Array.isArray(payload.bankOptions)
            ? payload.bankOptions.map((row) => clean(row)).filter(Boolean)
            : [];
          const wordBankRows = isReadingFillBlank
            ? buildReadingFillBlankWordBank(sourceText, answerMap, authoredWordBankRows, rendered.slotCount)
            : authoredWordBankRows;
        html = ''
          + '<div class="pte-hiw-wrap pte-fill-blank-wrap">'
          + '  <div class="pte-hiw-passage pte-fill-blank-passage pte-hiw-passage-fillblank">' + rendered.html + '</div>';
        if (isReadingWritingFillBlank) {
          html += '<div class="pte-fill-blank-wordbank-tip mt-2">Tip: select one best option for each blank.</div>';
        } else if (wordBankRows.length) {
          if (isReadingFillBlank) {
            html += ''
              + '<div class="pte-fill-blank-wordbank pte-fill-blank-wordbank-drag" data-fill-blank-wordbank>'
              +      wordBankRows.map((row, index) => (
                '<button type="button" class="pte-fill-blank-chip" draggable="' + (readOnly ? 'false' : 'true') + '" data-fill-blank-chip data-fill-blank-value="' + esc(row) + '" data-fill-blank-chip-index="' + String(index) + '"' + (readOnly ? ' disabled aria-disabled="true"' : '') + '>'
                  + esc(row)
                + '</button>'
              )).join('')
              + '  <div class="pte-fill-blank-wordbank-tip">Tip: drag a word to a blank, or click a word then click a blank. Click a filled blank to clear it.</div>'
              + '</div>';
          } else {
            html += '<div class="pte-fill-blank-wordbank">'
              + wordBankRows.map((row) => '<span class="badge rounded-pill bg-light text-dark border">' + esc(row) + '</span>').join('')
              + '</div>';
          }
        }
        html += '</div>';
      } else {
        html = '<textarea class="form-control" rows="6" data-response-map' + readOnlyAttr + ' placeholder="Enter your blank responses as JSON map...">' + esc(runtime.mapText || '') + '</textarea>';
      }
    } else if (qType === 'reading_reorder_paragraphs') {
      const authoredRows = Array.isArray(payload.paragraphItems) ? payload.paragraphItems : [];
      const paragraphRows = normalizeReorderParagraphRows(authoredRows);
      const fixedOrderMap = new Map(paragraphRows.map((row, index) => [row, index + 1]));
      const runtimeOrderFromMap = parseReorderResponseOrder(runtime.mapText || '', paragraphRows);
      const runtimeOrder = normalizeReorderParagraphRows(runtime.reorderOrder || []);
      let effectiveOrder = runtimeOrderFromMap.length === paragraphRows.length
        ? runtimeOrderFromMap
        : (runtimeOrder.length === paragraphRows.length ? runtimeOrder : []);
      if (effectiveOrder.length !== paragraphRows.length) {
        const seedToken = [
          clean(session?.id || ''),
          clean(item?.id || ''),
          clean(item?.questionVersionId || ''),
          paragraphRows.join('|')
        ].join('|');
        effectiveOrder = buildShuffledReorderParagraphRows(paragraphRows, seedToken);
      }
      runtime.reorderOrder = effectiveOrder.slice();
      runtime.mapText = stringifyReorderResponseOrder(effectiveOrder);
      html = paragraphRows.length >= 2
        ? ''
          + '<div class="pte-hiw-wrap pte-fill-blank-wrap pte-reorder-wrap">'
          + '  <div class="pte-hiw-label pte-fill-blank-label">Reorder Paragraphs</div>'
          + '  <div class="pte-reorder-subtitle">Drag each paragraph card to arrange a coherent order.</div>'
          +        renderReorderParagraphList(effectiveOrder, { readOnly, fixedOrderMap })
          + '  <textarea class="d-none" data-response-map data-reorder-map="1" ' + (readOnly ? 'readonly' : '') + '>'
          + esc(runtime.mapText || '')
          + '</textarea>'
          + (readOnly ? '' : '<div class="pte-reorder-tip">Tip: drag and drop cards vertically to reorder them before saving.</div>')
          + '</div>'
        : '<textarea class="form-control" rows="6" data-response-map' + readOnlyAttr + ' placeholder="Enter paragraph order as JSON array or newline text...">' + esc(runtime.mapText || '') + '</textarea>';
    } else if (qType.includes('matching') || qType.includes('fill_in_blank')) {
      html = '<textarea class="form-control" rows="6" data-response-map' + readOnlyAttr + ' placeholder="Enter your response map / order / blanks in JSON or text form...">' + esc(runtime.mapText || '') + '</textarea>';
    } else {
      html = '<textarea class="form-control" rows="8" data-response-text' + readOnlyAttr + ' placeholder="Type your response...">' + esc(runtime.textDraft || '') + '</textarea>';
    }

    if (readOnly) {
      const showReviewModeLabel = qType !== 'speaking_answer_short_question';
      const reviewHeadClass = showReviewModeLabel
        ? 'd-flex align-items-center justify-content-between flex-wrap gap-2 mb-2'
        : 'd-flex align-items-center justify-content-end flex-wrap gap-2 mb-2';
      const reviewHead = ''
        + '<div class="' + reviewHeadClass + '">'
        + (showReviewModeLabel
          ? '  <div class="small fw-bold text-muted">Review Mode: Saved response is shown below.</div>'
          : '')
        + '</div>';
      nodes.response.innerHTML = reviewHead + (html || '<div class="text-muted">No response input required.</div>');
      refreshFillBlankDropzoneState();
      if (qType === 'reading_reorder_paragraphs') syncReorderResponseRuntimeFromDom(item);
      refreshSummarizeSpokenTextMeta(item);
      if (isSpeakingQuestion(item)) renderSpeakingPlayback(item);
      initPromptAudioPlayers();
      renderCoachPanel(item, { readOnly: true });
      return;
    }

    nodes.response.innerHTML = html || '<div class="text-muted">No response input required.</div>';
    refreshFillBlankDropzoneState();
    if (qType === 'reading_reorder_paragraphs') syncReorderResponseRuntimeFromDom(item);
    refreshSummarizeSpokenTextMeta(item);
    renderCoachPanel(item, { readOnly: false });
  }

  function refreshQuestionNav() {
    nodes.nav.innerHTML = items.map((item, index) => {
      const status = clean(item.status || 'pending').toLowerCase() || 'pending';
      const isCurrent = index === state.index;
      const badgeClass = getStatusBadgeClass(status);
      return ''
        + '<button type="button" class="btn btn-sm text-start border pte-practice-nav-btn ' + (isCurrent ? 'border-primary bg-light' : 'border-light') + '" data-index="' + index + '">'
        + '  <div class="d-flex align-items-center justify-content-between gap-2">'
        + '    <span class="fw-bold">Q' + (index + 1) + '</span>'
        + '    <span class="badge ' + badgeClass + '">' + esc(formatStatusLabel(status)) + '</span>'
        + '  </div>'
        + '  <div class="small text-muted">' + esc(formatQuestionTypeLabel(clean(item.questionType || item?.question?.questionType)) || '-') + '</div>'
        + '</button>';
    }).join('');

    nodes.nav.querySelectorAll('.pte-practice-nav-btn').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const index = Number.parseInt(clean(btn.getAttribute('data-index')), 10);
        if (!Number.isFinite(index) || index < 0 || index >= items.length) return;
        persistCurrentDraft();
        await stopSpeakingFlowForActiveItem({ preserveBlob: true });
        state.index = index;
        await renderActiveQuestion();
      });
    });
  }

  function refreshProgress() {
    const answered = items.filter((row) => isAnsweredStatus(row.status)).length;
    const pct = items.length ? Math.round((answered / items.length) * 100) : 0;
    const progressText = answered + ' / ' + items.length + ' answered';
    if (nodes.progressBar) nodes.progressBar.style.width = pct + '%';
    if (nodes.progressText) nodes.progressText.textContent = progressText;
    if (nodes.topProgressBar) nodes.topProgressBar.style.width = pct + '%';
    if (nodes.topProgressText) nodes.topProgressText.textContent = progressText;
  }

  function formatRatingLabel(rating = '') {
    const token = clean(rating).toLowerCase();
    if (!token) return '';
    return token
      .split('_')
      .map((part) => part ? (part.charAt(0).toUpperCase() + part.slice(1)) : '')
      .join(' ')
      .trim();
  }

  function setRatingButtonsBusy(busy, activeRating = '') {
    const active = clean(activeRating).toLowerCase();
    (Array.isArray(nodes.ratingButtons) ? nodes.ratingButtons : []).forEach((btn) => {
      const token = clean(btn.getAttribute('data-difficulty-rating')).toLowerCase();
      btn.disabled = !!busy || !!state.ratingLocked;
      btn.classList.toggle('is-saving', !!busy && active && token === active);
    });
  }

  function updateRatingUI(item) {
    const rating = clean(item.selfDifficultyRating || '').toLowerCase();
    (Array.isArray(nodes.ratingButtons) ? nodes.ratingButtons : []).forEach((btn) => {
      const token = clean(btn.getAttribute('data-difficulty-rating')).toLowerCase();
      const selected = !!rating && token === rating;
      btn.classList.toggle('is-selected', selected);
      btn.setAttribute('aria-pressed', selected ? 'true' : 'false');
    });
    if (!nodes.ratingMeta) return;
    if (!rating) {
      nodes.ratingMeta.textContent = 'No difficulty rating saved yet.';
      return;
    }
    const ratedAt = clean(item.selfDifficultyRatedAt);
    nodes.ratingMeta.textContent = 'Saved as ' + formatRatingLabel(rating) + (ratedAt ? (' at ' + ((window.AppOrgDateTime && AppOrgDateTime.formatInstant) ? AppOrgDateTime.formatInstant(ratedAt) : new Date(ratedAt).toLocaleString())) : '.');
  }

  function setRatingLocked(locked, hintText = '') {
    state.ratingLocked = !!locked;
    setRatingButtonsBusy(state.ratingInFlight, '');
    if (!nodes.ratingMeta) return;
    if (!state.ratingLocked) return;
    const item = getActiveItem();
    const hasRating = !!clean(item?.selfDifficultyRating || '');
    if (!hasRating && hintText) nodes.ratingMeta.textContent = hintText;
  }

  function canScoreAutomatedItem(item) {
    if (!item || !isAutomatedScoringQuestion(item)) return false;
    if (isSessionClosedForEditing()) return false;
    const status = clean(item.status || '').toLowerCase();
    if (!canRescoreSameRevision && (status === 'scored' || status === 'feedback_provided')) return false;
    return ['saved', 'submitted', 'auto_submitted', 'scored', 'feedback_provided'].includes(status);
  }

  function syncScoreButtonForItem(item) {
    if (!nodes.scoreBtn) return;
    if (strictMockExam) {
      nodes.scoreBtn.classList.add('d-none');
      nodes.scoreBtn.disabled = true;
      return;
    }
    const canScore = canScoreAutomatedItem(item);
    nodes.scoreBtn.classList.toggle('d-none', !canScore);
    nodes.scoreBtn.disabled = !canScore;
  }

  function renderStartGate(actionLabel = 'Start', message = '', mode = 'start') {
    const isRestart = clean(mode).toLowerCase() === 'restart';
    const buttonClass = isRestart
      ? 'btn btn-filled btn-warning btn-lg px-5 py-3 fw-bold'
      : 'btn btn-filled btn-primary btn-lg px-5 py-3 fw-bold';
    return ''
      + '<div class="border rounded p-5 text-center bg-light-subtle">'
      + '  <button type="button" id="ptePracticeStartBtn" data-start-mode="' + esc(mode) + '" class="' + buttonClass + '">'
      + '    <i class="bi bi-play-circle me-1"></i>' + esc(actionLabel)
      + '  </button>'
      + '  <div class="small text-muted mt-3">' + esc(message || '') + '</div>'
      + '</div>';
  }

  function resetItemForRestart(item) {
    if (!item || typeof item !== 'object') return;
    const runtime = getItemRuntime(item);
    runtime.__reanswerPending = true;
    runtime.__replaceExistingResponse = true;
    runtime.textDraft = '';
    runtime.mapText = '';
    runtime.selectedSingle = '';
    runtime.selectedMultiple = [];
    runtime.selectedTrueFalse = '';
    runtime.transcript = '';
    const speaking = runtime.speaking || {};
    if (speaking.localUrl) revokeUrl(speaking.localUrl);
    runtime.speaking = {
      phase: 'idle',
      prepRemaining: 0,
      prepTotalSeconds: 0,
      responseRemaining: 0,
      responseTotalSeconds: 0,
      responseElapsedSeconds: 0,
      localBlob: null,
      localUrl: '',
      durationSeconds: 0,
      uploadedArtifactId: '',
      uploadedArtifact: null,
      uploadPromise: null,
      lastError: ''
    };
    runtime.writingTimer = {
      totalSeconds: 0,
      startedAtMs: 0
    };
    runtime.__savedResponseLocked = false;
    runtime.currentViewInstanceId = '';
    runtime.coaching = normalizeCoachingRuntime({});
    if (Array.isArray(item.artifactIds)) item.artifactIds = [];
    if (Array.isArray(item.artifacts)) item.artifacts = [];
    item.responseSummary = {};
    item.scoreRaw = 0;
    item.scoreFinal = 0;
    item.percentage = 0;
    item.traitScores = {};
    item.isCorrect = null;
    item.scoreRevisionCount = 0;
    const metadata = (item.metadata && typeof item.metadata === 'object') ? item.metadata : {};
    item.metadata = {
      ...metadata,
      responsePayload: {},
      scoring: null,
      latestResponseIsReanswer: false,
      lastScoringClearedAt: nowIso()
    };
    item.selfDifficultyRating = '';
    item.selfDifficultyRatedAt = '';
    item.status = 'in_progress';
    if (nodes.scorePanel) nodes.scorePanel.innerHTML = '';
    if (nodes.scoreSection) nodes.scoreSection.classList.add('pte-score-hidden');
    if (nodes.scoreBtn) {
      nodes.scoreBtn.classList.add('d-none');
      nodes.scoreBtn.disabled = true;
    }
  }

  async function startOrRestartCurrentQuestion(restart = false) {
    const item = getActiveItem();
    if (!item) return;
    const itemId = clean(item.id);
    if (!itemId) return;
    const startButton = document.getElementById('ptePracticeStartBtn');
    setButtonBusy(startButton, true, restart ? 'Restarting...' : 'Starting...');
    try {
      await stopSpeakingFlowForActiveItem({ preserveBlob: false });
      if (restart) resetItemForRestart(item);
      await ensureItemStarted(item);
      state.openedItemIds.add(itemId);
      await renderActiveQuestion();
      if (isSpeakingQuestion(item)) {
        await runSpeakingFlow(item, { manual: false });
      }
    } catch (error) {
      await showMessage(restart ? 'Restart Failed' : 'Start Failed', error.message || 'Unable to start this question.', 'error');
    } finally {
      setButtonBusy(startButton, false);
    }
  }

  async function ensureItemStarted(item) {
    const itemId = clean(item.id);
    if (!itemId) return;
    if (state.startedInFlight.has(itemId)) return;
    state.startedInFlight.add(itemId);
    try {
      const viewInstanceId = ensureViewInstanceForItem(item, { forceNew: true });
      const result = await postRuntime(runtimeEndpoint('/' + encodeURIComponent(clean(session.id))) + '/items/' + encodeURIComponent(itemId) + '/start', {
        viewInstanceId,
        source: {
          module: strictMockExam ? 'pte_mock_exam_ui' : 'pte_practice_runner_ui',
          eventType: strictMockExam ? 'mock_exam_question_started' : 'question_started',
          eventId: (strictMockExam ? 'PTE-MOCK-STARTITEM-' : 'PTE-PRACTICE-STARTITEM-') + itemId + '-' + Date.now()
        }
      });
      if (result.item) Object.assign(item, result.item);
      state.startedItemIds.add(itemId);
    } catch (_) {
      // Keep UI usable if start event fails.
    } finally {
      state.startedInFlight.delete(itemId);
    }
  }

  async function ensureSpeakingArtifactSaved(item, options = {}) {
    if (!item || !isSpeakingQuestion(item)) return;
    await stopSpeakingFlowForActiveItem({ preserveBlob: true });
    const runtime = getItemRuntime(item);
    const speaking = runtime.speaking || {};
    if (!speaking.localBlob || speaking.uploadedArtifactId) return;
    await uploadSpeakingArtifact(item, options);
    renderSpeakingPlayback(item);
  }

  async function renderActiveQuestion() {
    const item = getActiveItem();
    if (!item) return;
    persistCurrentDraft();
    await stopSpeakingFlowForActiveItem({ preserveBlob: true });
    stopWritingCountdownTicker();
    resetHighlightIncorrectDragState();

    state.activeItemId = clean(item.id);
    state.speaking.activeItemId = state.activeItemId;
    state.viewOpenedAtMs = nowMs();

    const question = item.question || {};
    const runtime = getItemRuntime(item);
    const title = clean(question.title || item?.metadata?.questionTitle || ('Question ' + (state.index + 1)));
    const status = clean(item.status || 'pending').toLowerCase() || 'pending';
    const isAnsweredByPersistedData = !strictMockExam && hasPersistedResponseData(item);
    let isOpen = state.openedItemIds.has(state.activeItemId);
    const isRetakeRequired = isRetakeRequiredStatus(status) || isAnsweredByPersistedData;
    const sessionClosed = isSessionClosedForEditing();
    syncClosedSessionWarningUi();
    const canReanswer = isRetakeRequired && !sessionClosed;
    const showNotesWidgets = strictMockExam ? false : shouldShowNotesForItem(item);

    if (strictMockExam && !sessionClosed && !isRetakeRequired && !finalItemStatus(status) && !isOpen) {
      state.openedItemIds.add(state.activeItemId);
      isOpen = true;
      await ensureItemStarted(item);
    }

    syncScoreButtonForItem(item);
    renderScoringPanel(item);

    nodes.title.textContent = title || ('Question ' + (state.index + 1));
    if (nodes.reanswerHeadBtn) {
      nodes.reanswerHeadBtn.classList.toggle('d-none', !isRetakeRequired);
      nodes.reanswerHeadBtn.disabled = !canReanswer;
      nodes.reanswerHeadBtn.title = canReanswer
        ? 'Re-answer this question'
        : 'This practice session is finished. Re-answer is not available.';
    }
    nodes.statusBadge.textContent = formatStatusLabel(status);
    nodes.statusBadge.className = 'badge ' + getStatusBadgeClass(status);
    refreshQuestionNav();
    refreshProgress();
    nodes.seenTime.textContent = 'Seen: ' + Number(item.totalSeenSeconds || 0) + ' sec';
    syncNotesUiForItem(item);

    if (isOpen) {
      ensureViewInstanceForItem(item);
    }

    if (!isOpen && !isRetakeRequired && !sessionClosed) {
      setNotesWidgetsVisible(false);
      nodes.prompt.innerHTML = renderStartGate(
        'Start',
        'Click Start to reveal this question and begin answering.',
        'start'
      );
      initPromptAudioPlayers();
      nodes.response.innerHTML = '<div class="small text-muted">Question and response controls will appear after you start.</div>';
      renderCoachPanel(item, { readOnly: true });
      if (nodes.saveBtn) nodes.saveBtn.disabled = true;
      updateRatingUI(item);
      setRatingLocked(true, 'Save your response first, then choose a difficulty rating.');
      if (nodes.finishBottomBtn && !strictMockExam) {
        nodes.finishBottomBtn.disabled = false;
        nodes.finishBottomBtn.title = '';
      }
      return;
    }

    nodes.prompt.innerHTML = renderQuestionPrompt(item);
    initPromptAudioPlayers();

    if (isRetakeRequired) {
      setNotesWidgetsVisible(showNotesWidgets);
      renderResponsePanel(item, { readOnly: true, canReanswer });
      setFillBlankChipSelection(null);
      placeNotesAroundAnchor(item, { repositionPanel: true });
      if (nodes.saveBtn) nodes.saveBtn.disabled = true;
      if (nodes.finishBottomBtn && strictMockExam) {
        nodes.finishBottomBtn.classList.toggle('d-none', state.index < items.length - 1);
        nodes.finishBottomBtn.disabled = state.index < items.length - 1;
      }
      if (nodes.finishBottomBtn && !strictMockExam) {
        nodes.finishBottomBtn.disabled = false;
        nodes.finishBottomBtn.title = '';
      }
      updateRatingUI(item);
      setRatingLocked(true, canReanswer
        ? 'Use Re-answer to replace this response.'
        : 'This practice session is finished. Re-answer is disabled.');
      return;
    }

    if (sessionClosed) {
      setNotesWidgetsVisible(showNotesWidgets);
      renderResponsePanel(item, { readOnly: true, canReanswer: false });
      setFillBlankChipSelection(null);
      placeNotesAroundAnchor(item, { repositionPanel: true });
      if (nodes.saveBtn) nodes.saveBtn.disabled = true;
      if (nodes.scoreBtn) nodes.scoreBtn.disabled = true;
      if (nodes.finishBottomBtn && strictMockExam) {
        nodes.finishBottomBtn.classList.toggle('d-none', state.index < items.length - 1);
        nodes.finishBottomBtn.disabled = true;
      }
      if (nodes.finishBottomBtn && !strictMockExam) {
        nodes.finishBottomBtn.disabled = true;
        nodes.finishBottomBtn.title = 'This practice is already finished.';
      }
      updateRatingUI(item);
      setRatingLocked(true, 'This session is not active. Start a new practice session to continue.');
      return;
    }

    setNotesWidgetsVisible(showNotesWidgets);
    renderResponsePanel(item, { readOnly: false });
    setFillBlankChipSelection(null);
    startWritingCountdownTicker(item);
    placeNotesAroundAnchor(item, { repositionPanel: true });
    if (nodes.saveBtn) {
      const lockSavedResponse = !strictMockExam
        && (runtime.__savedResponseLocked === true || isAnsweredByPersistedData)
        && !runtime.__reanswerPending;
      nodes.saveBtn.disabled = !!lockSavedResponse;
      nodes.saveBtn.title = lockSavedResponse ? 'Response is already saved. Use Re-answer to change it.' : '';
      if (strictMockExam) {
        nodes.saveBtn.innerHTML = '<i class="bi bi-check2-square me-1"></i>' + (state.index >= items.length - 1 ? 'Submit Response' : 'Submit and Next');
      }
    }
    if (nodes.finishBottomBtn && strictMockExam) {
      nodes.finishBottomBtn.classList.toggle('d-none', state.index < items.length - 1);
      nodes.finishBottomBtn.disabled = true;
    }
    if (nodes.finishBottomBtn && !strictMockExam) {
      nodes.finishBottomBtn.disabled = false;
      nodes.finishBottomBtn.title = '';
    }
    updateRatingUI(item);
    setRatingLocked(!isRetakeRequired, 'Save your response first, then choose a difficulty rating.');
    if (strictMockExam && isSpeakingQuestion(item)) {
      if (!runtime.__strictAutoFlowStarted) {
        runtime.__strictAutoFlowStarted = true;
        setTimeout(() => {
          runSpeakingFlow(item, { manual: false }).catch(() => {});
        }, 150);
      }
    }
  }

  function seenSecondsForCurrentView() {
    if (!state.viewOpenedAtMs) return 0;
    return Math.max(0, Math.floor((nowMs() - state.viewOpenedAtMs) / 1000));
  }

  async function submitStrictCurrentItem() {
    if (isSessionClosedForEditing()) {
      await warnClosedSessionAndStop();
      return;
    }
    const item = getActiveItem();
    if (!item) return;
    const itemId = clean(item.id);
    if (!itemId || !state.openedItemIds.has(itemId)) {
      await showMessage('Question Not Ready', 'The current mock exam question has not started yet.', 'info');
      return;
    }
    persistCurrentDraft();
    setButtonBusy(nodes.saveBtn, true, 'Submitting...');
    try {
      const runtime = getItemRuntime(item);
      await withTimeout(
        ensureSpeakingArtifactSaved(item, {
          allowReanswer: false,
          replaceExistingResponse: false
        }),
        20000,
        'Saving audio took too long. Please try again.'
      );
      const summary = collectResponseSummary(item);
      const responsePayload = collectResponsePayload(item);
      responsePayload.viewInstanceId = ensureViewInstanceForItem(item);
      const viewInstanceId = clean(runtime.currentViewInstanceId);
      const result = await withTimeout(
        postRuntime(runtimeEndpoint('/' + encodeURIComponent(clean(session.id))) + '/items/' + encodeURIComponent(itemId) + '/submit', {
          responseSummary: summary,
          responsePayload,
          disableAutoScoring: true,
          seenSeconds: seenSecondsForCurrentView(),
          timeSpentSeconds: seenSecondsForCurrentView(),
          viewInstanceId,
          source: {
            module: 'pte_mock_exam_ui',
            eventType: 'mock_exam_question_submitted',
            eventId: 'PTE-MOCK-SUBMIT-' + itemId + '-' + Date.now()
          }
        }),
        25000,
        'Submitting response timed out. Please try again.'
      );
      if (result.session) Object.assign(session, result.session);
      if (result.item) Object.assign(item, result.item);
      clearViewInstanceForItem(item);
      state.openedItemIds.delete(itemId);
      refreshQuestionNav();
      refreshProgress();
      await stopSpeakingFlowForActiveItem({ preserveBlob: false });
      if (state.index < items.length - 1) {
        state.index += 1;
        await renderActiveQuestion();
        return;
      }
      await renderActiveQuestion();
      await showMessage('Last Response Submitted', 'You have submitted the last question. Click Finish Exam to complete the mock exam.', 'success');
    } catch (error) {
      if (/Attempt session is not active\./i.test(String(error?.message || ''))) {
        state.sessionForcedClosed = true;
        await renderActiveQuestion();
        await warnClosedSessionAndStop();
        return;
      }
      await showMessage('Submit Failed', error.message || 'Unable to submit this response.', 'error');
    } finally {
      setButtonBusy(nodes.saveBtn, false);
    }
  }

  async function saveResponseItem() {
    if (isSessionClosedForEditing()) {
      await warnClosedSessionAndStop();
      return;
    }
    if (strictMockExam) {
      await submitStrictCurrentItem();
      return;
    }
    const item = getActiveItem();
    if (!item) return;
    const itemId = clean(item.id);
    if (!itemId || !state.openedItemIds.has(itemId)) {
      await showMessage('Start Required', 'Please click Start before saving this response.', 'info');
      return;
    }
    persistCurrentDraft();
    const proceed = await confirmCoachSelfCheckBeforeSave(item);
    if (!proceed) return;
    setButtonBusy(nodes.saveBtn, true, 'Saving...');
    try {
      const runtime = getItemRuntime(item);
      const allowReanswer = runtime.__reanswerPending === true;
      await withTimeout(
        ensureSpeakingArtifactSaved(item, {
          allowReanswer,
          replaceExistingResponse: allowReanswer || runtime.__replaceExistingResponse === true
        }),
        20000,
        'Saving audio took too long. Please try again.'
      );
      const summary = collectResponseSummary(item);
      const responsePayload = collectResponsePayload(item);
      buildCoachAfterSubmitFeedback(item);
      responsePayload.coaching = normalizeCoachingRuntime(runtime.coaching || {});
      responsePayload.viewInstanceId = ensureViewInstanceForItem(item);
      const viewInstanceId = clean(runtime.currentViewInstanceId);
      const result = await withTimeout(
        postRuntime(runtimeEndpoint('/' + encodeURIComponent(clean(session.id))) + '/items/' + encodeURIComponent(clean(item.id)) + '/save', {
          responseSummary: summary,
          responsePayload,
          allowReanswer,
          replaceExistingResponse: allowReanswer || runtime.__replaceExistingResponse === true,
          seenSeconds: seenSecondsForCurrentView(),
          viewInstanceId,
          source: {
            module: 'pte_practice_runner_ui',
            eventType: 'response_saved',
            eventId: 'PTE-PRACTICE-SAVE-' + clean(item.id) + '-' + Date.now()
          }
        }),
        25000,
        'Saving response timed out. Please try again.'
      );
      if (result.item) Object.assign(item, result.item);
      runtime.__savedResponseLocked = true;
      runtime.__reanswerPending = false;
      runtime.__replaceExistingResponse = false;
      clearViewInstanceForItem(item);
      state.openedItemIds.delete(itemId);
      refreshQuestionNav();
      refreshProgress();
      await renderActiveQuestion();
      const opened = openRatingModal({ afterSave: true });
      if (!opened) {
        await showMessage('Saved', 'Response saved. You can now choose a difficulty rating.', 'success');
      }
    } catch (error) {
      if (/Attempt session is not active\./i.test(String(error?.message || ''))) {
        state.sessionForcedClosed = true;
        await renderActiveQuestion();
        await warnClosedSessionAndStop();
        return;
      }
      await showMessage('Save Failed', error.message || 'Unable to save response.', 'error');
    } finally {
      setButtonBusy(nodes.saveBtn, false);
    }
  }

  function buildScoreResultMessage(result, item) {
    const scoredItem = result?.item || item || {};
    const autoScoring = result?.autoScoring || {};
    const autoStatus = clean(autoScoring.status || '').toLowerCase();
    const metadataStatus = clean(scoredItem?.metadata?.scoring?.status || '').toLowerCase();
    const itemStatus = clean(scoredItem.status || '').toLowerCase();
    const status = autoStatus || metadataStatus || itemStatus;
    const hasCurrentScore = status === 'scored' || (!autoStatus && !metadataStatus && itemStatus === 'scored');
    const scoreFinal = Number(scoredItem.scoreFinal || 0);
    const maxScore = Number(scoredItem.maxScore || 0);
    const percentage = Number(scoredItem.percentage || 0);
    if (hasCurrentScore) {
      const scoreText = maxScore > 0
        ? (scoreFinal + ' / ' + maxScore + ' (' + percentage.toFixed(2) + '%)')
        : String(scoreFinal);
      return {
        title: 'Scored',
        message: getScorePanelTitle(scoredItem, scoredItem?.metadata?.scoring || {}) + ': ' + scoreText + '.',
        icon: 'success'
      };
    }

    const warnings = Array.isArray(autoScoring?.result?.warnings)
      ? autoScoring.result.warnings
      : collectScoringWarnings(scoredItem?.metadata?.scoring || {});
    return {
      title: status === 'needs_evidence' ? 'More Evidence Needed' : 'Scoring Not Completed',
      message: buildApplicantScoringProblemMessage(status, warnings, scoredItem),
      icon: status === 'needs_evidence' ? 'warning' : 'error'
    };
  }

  function getScoringWaitQuestionLabel(item) {
    const scorerTitle = getScorePanelTitle(item, getScoringMetadata(item) || {});
    const fromTitle = clean(scorerTitle.replace(/\s+Raw\s+Score$/i, ''));
    if (fromTitle && fromTitle !== 'Raw Score') return fromTitle;
    return formatQuestionTypeLabel(item?.question?.questionType || item?.questionType || '') || 'Speaking Response';
  }

  function showScoringWaitModal(item, responsePayload = {}, responseSummary = {}) {
    if (typeof window.showLoading !== 'function') return null;
    const questionLabel = getScoringWaitQuestionLabel(item);
    const positionLabel = items.length > 0
      ? `Question ${Math.max(1, state.index + 1)} of ${items.length}`
      : 'Practice question';
    const startedAtMs = Date.now();
    const buildNote = () => {
      const elapsedSeconds = Math.max(0, Math.floor((Date.now() - startedAtMs) / 1000));
      return `${positionLabel} • ${questionLabel} • Elapsed ${formatClock(elapsedSeconds)}`;
    };

    const token = window.showLoading({
      title: 'Scoring Response',
      note: buildNote(),
      operation: ''
    });
    const timerId = setInterval(() => {
      if (typeof window.updateLoading !== 'function') return;
      window.updateLoading({
        title: 'Scoring Response',
        note: buildNote(),
        operation: ''
      });
    }, 1000);
    return { token, timerId };
  }

  function hideScoringWaitModal(handle = null) {
    if (typeof window.hideLoading !== 'function') return;
    if (!handle) return;
    if (typeof handle === 'object') {
      if (handle.timerId) clearInterval(handle.timerId);
      if (handle.token) window.hideLoading(handle.token);
      return;
    }
    window.hideLoading(handle);
  }

  async function scoreSavedAutomatedItem() {
    const item = getActiveItem();
    if (!item) return;
    if (!canScoreAutomatedItem(item)) {
      const message = canRescoreSameRevision
        ? 'Save a scorable response before scoring it. Already scored responses can be scored again.'
        : 'Save a scorable response before scoring it. Re-scoring the same saved response is disabled for standard users.';
      await showMessage('Score Unavailable', message, 'info');
      return;
    }

    setButtonBusy(nodes.scoreBtn, true, 'Scoring...');
    let scoringLoadingToken = null;
    try {
      const runtime = getItemRuntime(item);
      const responsePayload = collectResponsePayload(item);
      const responseSummary = collectResponseSummary(item);
      const responseRevision = toInt(item?.metadata?.responseRevision, 0);
      responsePayload.coaching = normalizeCoachingRuntime(runtime.coaching || {});
      if (responseRevision > 0) responsePayload.responseRevision = responseRevision;
      const statusToken = clean(item?.status || '').toLowerCase();
      const forceRescore = canRescoreSameRevision && (statusToken === 'scored' || statusToken === 'feedback_provided');
      scoringLoadingToken = showScoringWaitModal(item, responsePayload, responseSummary);
      const result = await withTimeout(
        postRuntime(runtimeEndpoint('/' + encodeURIComponent(clean(session.id))) + '/items/' + encodeURIComponent(clean(item.id)) + '/score', {
          responseSummary,
          responsePayload,
          responseRevision,
          forceRescore,
          source: {
            module: 'pte_practice_runner_ui',
            eventType: clean(getQuestionTypeToken(item) || 'speaking_item') + '_score_requested',
            eventId: 'PTE-PRACTICE-SCORE-' + clean(item.id) + '-' + Date.now()
          }
        }, { includeActionState: false }),
        45000,
        'Scoring response timed out. Please try again.'
      );

      if (result.session) Object.assign(session, result.session);
      if (result.item) Object.assign(item, result.item);
      refreshQuestionNav();
      refreshProgress();
      await renderActiveQuestion();
      const info = buildScoreResultMessage(result, item);
      hideScoringWaitModal(scoringLoadingToken);
      scoringLoadingToken = null;
      await showMessage(info.title, info.message, info.icon);
    } catch (error) {
      hideScoringWaitModal(scoringLoadingToken);
      scoringLoadingToken = null;
      await showMessage('Scoring Failed', error.message || 'Unable to score this response.', 'error');
    } finally {
      hideScoringWaitModal(scoringLoadingToken);
      setButtonBusy(nodes.scoreBtn, false);
      syncScoreButtonForItem(getActiveItem());
    }
  }

  async function reanswerCurrentItem() {
    const item = getActiveItem();
    if (!item) return;
    if (strictMockExam) {
      await showMessage('Re-answer Unavailable', 'Re-answer is not available during strict mock exams.', 'info');
      return;
    }
    if (isSessionClosedForEditing()) {
      await showMessage('Practice Finished', 'This session is finished. Re-answer is not available.', 'warning');
      return;
    }
    const confirmed = await confirmReanswerOverwrite();
    if (!confirmed) return;
    resetItemForRestart(item);
    state.openedItemIds.add(clean(item.id));
    await renderActiveQuestion();
    if (isSpeakingQuestion(item)) {
      await runSpeakingFlow(item, { manual: false });
    }
  }

  async function rateCurrentItem(selectedRating = '') {
    const item = getActiveItem();
    if (!item) return;
    if (state.ratingInFlight) return;
    if (state.ratingLocked) return;
    const rating = clean(selectedRating).toLowerCase();
    if (!rating) {
      return;
    }
    const previousRating = clean(item.selfDifficultyRating || '').toLowerCase();
    const previousRatedAt = clean(item.selfDifficultyRatedAt || '');
    item.selfDifficultyRating = rating;
    updateRatingUI(item);
    if (nodes.ratingMeta) {
      nodes.ratingMeta.textContent = `Saving ${formatRatingLabel(rating)}...`;
    }
    state.ratingInFlight = true;
    setRatingButtonsBusy(true, rating);
    try {
      const result = await postRuntime(runtimeEndpoint('/' + encodeURIComponent(clean(session.id))) + '/items/' + encodeURIComponent(clean(item.id)) + '/rate', {
        rating,
        source: {
          module: 'pte_practice_runner_ui',
          eventType: 'difficulty_rated',
          eventId: 'PTE-PRACTICE-RATE-' + clean(item.id) + '-' + Date.now()
        }
      });
      if (result.item) Object.assign(item, result.item);
      updateRatingUI(item);
      const modal = getRatingModalInstance();
      if (modal && typeof modal.hide === 'function') {
        modal.hide();
      }
    } catch (error) {
      item.selfDifficultyRating = previousRating;
      item.selfDifficultyRatedAt = previousRatedAt;
      updateRatingUI(item);
      await showMessage('Rating Failed', error.message || 'Unable to save rating.', 'error');
    } finally {
      state.ratingInFlight = false;
      setRatingButtonsBusy(false, '');
    }
  }

  async function autoSkipCurrentItemIfNeeded(item, reason = 'navigate') {
    if (strictMockExam) return;
    if (!item) return;
    const itemId = clean(item.id);
    if (!itemId) return;
    if (!state.openedItemIds.has(itemId)) return;
    if (!isSkippableStatus(item.status || 'pending')) {
      state.openedItemIds.delete(itemId);
      return;
    }

    try {
      const viewInstanceId = ensureViewInstanceForItem(item);
      const result = await postRuntime(runtimeEndpoint('/' + encodeURIComponent(clean(session.id))) + '/items/' + encodeURIComponent(itemId) + '/skip', {
        seenSeconds: seenSecondsForCurrentView(),
        viewInstanceId,
        source: {
          module: 'pte_practice_runner_ui',
          eventType: 'question_skipped',
          eventId: 'PTE-PRACTICE-SKIP-' + itemId + '-' + Date.now(),
          reason: clean(reason).toLowerCase() || 'navigate'
        }
      });
      if (result.item) Object.assign(item, result.item);
    } catch (_) {
      // Keep navigation resilient even if skip logging fails.
    } finally {
      clearViewInstanceForItem(item);
      state.openedItemIds.delete(itemId);
    }
  }

  async function goNextQuestion(triggerBtn = nodes.nextBtn) {
    if (strictMockExam) {
      await showMessage('Submit Required', 'Use Submit and Next to move forward in strict mock exam mode.', 'info');
      return;
    }
    if (state.navigationInFlight) return;
    state.navigationInFlight = true;
    setButtonBusy(triggerBtn, true, 'Moving...', { mode: 'disable-only' });
    const item = getActiveItem();
    try {
      if (!item) return;
      persistCurrentDraft();
      await autoSkipCurrentItemIfNeeded(item, 'next');
      await stopSpeakingFlowForActiveItem({ preserveBlob: true });
      if (state.index < items.length - 1) {
        state.index += 1;
        await renderActiveQuestion();
        return;
      }
      await showMessage('End of Session', 'You reached the last question. You can finish the practice session now.', 'info');
    } finally {
      setButtonBusy(triggerBtn, false);
      state.navigationInFlight = false;
    }
  }

  async function goPreviousQuestion(triggerBtn = nodes.prevBtn) {
    if (strictMockExam) {
      await showMessage('Previous Blocked', 'Strict mock exam mode does not allow going back to previous questions.', 'info');
      return;
    }
    if (state.navigationInFlight) return;
    state.navigationInFlight = true;
    setButtonBusy(triggerBtn, true, 'Moving...', { mode: 'disable-only' });
    const item = getActiveItem();
    try {
      if (!item) return;
      persistCurrentDraft();
      await autoSkipCurrentItemIfNeeded(item, 'previous');
      await stopSpeakingFlowForActiveItem({ preserveBlob: true });
      if (state.index > 0) {
        state.index -= 1;
        await renderActiveQuestion();
        return;
      }
      await showMessage('Start of Session', 'You are already on the first question.', 'info');
    } finally {
      setButtonBusy(triggerBtn, false);
      state.navigationInFlight = false;
    }
  }

  async function finishSession(triggerBtn) {
    if (isSessionClosedForEditing()) {
      await warnClosedSessionAndStop();
      return;
    }
    const proceed = await confirmFinishWithIncompleteItems();
    if (!proceed) return;
    setButtonBusy(triggerBtn, true, 'Finishing...');
    try {
      persistCurrentDraft();
      stopWritingCountdownTicker();
      if (!strictMockExam) await autoSkipCurrentItemIfNeeded(getActiveItem(), 'finish');
      await stopSpeakingFlowForActiveItem({ preserveBlob: true });
      const result = await postRuntime(runtimeEndpoint('/' + encodeURIComponent(clean(session.id))) + '/finish', {
        source: {
          module: strictMockExam ? 'pte_mock_exam_ui' : 'pte_practice_runner_ui',
          eventType: strictMockExam ? 'mock_exam_finished' : 'attempt_finished',
          eventId: (strictMockExam ? 'PTE-MOCK-FINISH-' : 'PTE-PRACTICE-FINISH-') + clean(session.id) + '-' + Date.now()
        }
      });
      const status = clean(result?.session?.status || '');
      await showMessage(strictMockExam ? 'Mock Exam Finished' : 'Session Finished', (strictMockExam ? 'Mock exam' : 'Practice session') + ' is now ' + (status || 'finished') + '.', 'success');
      window.location.href = clean(result?.redirectUrl || '') || completionUrl;
    } catch (error) {
      await showMessage('Finish Failed', error.message || 'Unable to finish session.', 'error');
    } finally {
      setButtonBusy(triggerBtn, false);
    }
  }

  function resetHighlightIncorrectDragState() {
    state.hiw.dragging = false;
    state.hiw.moved = false;
    state.hiw.pointerId = null;
    state.hiw.startIndex = -1;
    state.hiw.startWasSelected = false;
  }

  function onHighlightIncorrectPointerDown(event) {
    const wordNode = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('[data-hiw-word-index]')
      : null;
    if (!wordNode) return;
    const item = getActiveItem();
    if (!item || !isHighlightIncorrectWordsType(item)) return;
    if (wordNode.getAttribute('data-hiw-readonly') === '1') return;
    if (event.pointerType === 'mouse' && event.button !== 0) return;
    event.preventDefault();

    const startIndex = Number.parseInt(String(wordNode.getAttribute('data-hiw-word-index') || ''), 10);
    const startWasSelected = wordNode.classList.contains('is-selected');
    state.hiw.dragging = true;
    state.hiw.moved = false;
    state.hiw.pointerId = event.pointerId;
    state.hiw.startIndex = Number.isFinite(startIndex) ? startIndex : -1;
    state.hiw.startWasSelected = !!startWasSelected;

    setHighlightIncorrectWordSelected(wordNode, true);
    syncHighlightIncorrectResponseFromDom(item);

    if (typeof wordNode.setPointerCapture === 'function') {
      try { wordNode.setPointerCapture(event.pointerId); } catch (_) {}
    }
  }

  function onHighlightIncorrectPointerOver(event) {
    if (!state.hiw.dragging) return;
    if (state.hiw.pointerId !== null && event.pointerId !== state.hiw.pointerId) return;
    const wordNode = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('[data-hiw-word-index]')
      : null;
    if (!wordNode || wordNode.getAttribute('data-hiw-readonly') === '1') return;
    const index = Number.parseInt(String(wordNode.getAttribute('data-hiw-word-index') || ''), 10);
    if (Number.isFinite(index) && index !== state.hiw.startIndex) {
      state.hiw.moved = true;
    }
    if (setHighlightIncorrectWordSelected(wordNode, true)) {
      const item = getActiveItem();
      if (item && isHighlightIncorrectWordsType(item)) {
        syncHighlightIncorrectResponseFromDom(item);
      }
    }
  }

  function onHighlightIncorrectPointerEnd(event) {
    if (!state.hiw.dragging) return;
    if (state.hiw.pointerId !== null && event?.pointerId !== undefined && event.pointerId !== state.hiw.pointerId) return;
    const item = getActiveItem();
    if (!item || !isHighlightIncorrectWordsType(item)) {
      resetHighlightIncorrectDragState();
      return;
    }

    if (!state.hiw.moved && state.hiw.startIndex >= 0) {
      const startNode = findHighlightIncorrectWordNode(state.hiw.startIndex);
      if (startNode && startNode.getAttribute('data-hiw-readonly') !== '1') {
        setHighlightIncorrectWordSelected(startNode, !state.hiw.startWasSelected);
      }
    }
    syncHighlightIncorrectResponseFromDom(item);
    resetHighlightIncorrectDragState();
  }

  function onFillBlankDragStart(event) {
    const chip = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('[data-fill-blank-chip]')
      : null;
    if (!chip) return;
    if (chip.disabled) {
      event.preventDefault();
      return;
    }
    const value = clean(chip.getAttribute('data-fill-blank-value') || chip.textContent || '');
    if (!value) {
      event.preventDefault();
      return;
    }
    if (!isReadingFillBlankActiveItem()) {
      event.preventDefault();
      return;
    }
    try {
      if (event.dataTransfer) {
        event.dataTransfer.setData('text/plain', value);
        event.dataTransfer.effectAllowed = 'copy';
      }
    } catch (_) {}
    chip.classList.add('is-dragging');
  }

  function onFillBlankDragEnd(event) {
    const chip = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('[data-fill-blank-chip]')
      : null;
    if (!chip) return;
    chip.classList.remove('is-dragging');
    const inputs = Array.from(nodes.response?.querySelectorAll('input[data-response-blank-input][data-drag-fill-blank="1"]') || []);
    inputs.forEach((input) => input.classList.remove('drop-active'));
  }

  function onFillBlankDragOver(event) {
    const input = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('input[data-response-blank-input][data-drag-fill-blank="1"]')
      : null;
    if (!input || input.disabled || !isReadingFillBlankActiveItem()) return;
    event.preventDefault();
    if (event.dataTransfer) event.dataTransfer.dropEffect = 'copy';
    input.classList.add('drop-active');
  }

  function onFillBlankDragLeave(event) {
    const input = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('input[data-response-blank-input][data-drag-fill-blank="1"]')
      : null;
    if (!input) return;
    input.classList.remove('drop-active');
  }

  function onFillBlankDrop(event) {
    const input = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('input[data-response-blank-input][data-drag-fill-blank="1"]')
      : null;
    if (!input || input.disabled || !isReadingFillBlankActiveItem()) return;
    event.preventDefault();
    input.classList.remove('drop-active');
    const value = clean(event.dataTransfer?.getData('text/plain') || '');
    if (!value) return;
    assignFillBlankValueToInput(input, value);
  }

  function clearReorderDropTargets() {
    getReorderParagraphCards().forEach((card) => card.classList.remove('drop-target'));
  }

  function onReorderDragStart(event) {
    const card = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('[data-reorder-card]')
      : null;
    if (!card) return;
    if (!isReadingReorderParagraphsItem()) {
      event.preventDefault();
      return;
    }
    if (card.getAttribute('aria-disabled') === 'true') {
      event.preventDefault();
      return;
    }
    const index = toInt(card.getAttribute('data-reorder-index'), -1);
    if (index < 0) {
      event.preventDefault();
      return;
    }
    state.reorder.draggingIndex = index;
    card.classList.add('is-dragging');
    try {
      if (event.dataTransfer) {
        event.dataTransfer.effectAllowed = 'move';
        event.dataTransfer.setData('text/plain', String(index));
      }
    } catch (_) {}
  }

  function onReorderDragEnd(event) {
    const card = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('[data-reorder-card]')
      : null;
    if (card) card.classList.remove('is-dragging');
    state.reorder.draggingIndex = -1;
    clearReorderDropTargets();
  }

  function onReorderDragOver(event) {
    const card = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('[data-reorder-card]')
      : null;
    if (!card || !isReadingReorderParagraphsItem()) return;
    if (card.getAttribute('aria-disabled') === 'true') return;
    event.preventDefault();
    if (event.dataTransfer) event.dataTransfer.dropEffect = 'move';
    clearReorderDropTargets();
    card.classList.add('drop-target');
  }

  function onReorderDragLeave(event) {
    const card = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('[data-reorder-card]')
      : null;
    if (!card) return;
    card.classList.remove('drop-target');
  }

  function onReorderDrop(event) {
    const targetCard = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('[data-reorder-card]')
      : null;
    if (!targetCard || !isReadingReorderParagraphsItem()) return;
    if (targetCard.getAttribute('aria-disabled') === 'true') return;
    event.preventDefault();

    const listNode = targetCard.closest('[data-reorder-list]');
    if (!listNode) return;

    let sourceIndex = Number.isInteger(state.reorder.draggingIndex) ? state.reorder.draggingIndex : -1;
    if (sourceIndex < 0) {
      sourceIndex = toInt(event.dataTransfer?.getData('text/plain'), -1);
    }
    const targetIndex = toInt(targetCard.getAttribute('data-reorder-index'), -1);
    const cards = Array.from(listNode.querySelectorAll('[data-reorder-card]'));
    if (sourceIndex < 0 || targetIndex < 0) return;
    if (sourceIndex >= cards.length || targetIndex >= cards.length) return;
    if (sourceIndex === targetIndex) {
      clearReorderDropTargets();
      return;
    }

    const sourceCard = cards[sourceIndex];
    if (!sourceCard) return;

    const targetRect = targetCard.getBoundingClientRect();
    const dropBefore = Number.isFinite(event.clientY)
      ? (event.clientY < (targetRect.top + (targetRect.height / 2)))
      : true;
    if (dropBefore) listNode.insertBefore(sourceCard, targetCard);
    else listNode.insertBefore(sourceCard, targetCard.nextSibling);

    syncReorderResponseRuntimeFromDom(getActiveItem());
    clearReorderDropTargets();
  }

  nodes.response?.addEventListener('click', async (event) => {
    const fillBlankChip = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('[data-fill-blank-chip]')
      : null;
    if (fillBlankChip) {
      if (!isReadingFillBlankActiveItem()) return;
      if (fillBlankChip.disabled) return;
      const isSelected = fillBlankChip.classList.contains('is-selected');
      setFillBlankChipSelection(isSelected ? null : fillBlankChip);
      return;
    }

    const fillBlankInput = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('input[data-response-blank-input][data-drag-fill-blank="1"]')
      : null;
    if (fillBlankInput) {
      if (!isReadingFillBlankActiveItem()) return;
      if (fillBlankInput.disabled) return;
      if (state.fillBlank.activeWord) {
        assignFillBlankValueToInput(fillBlankInput, state.fillBlank.activeWord);
        setFillBlankChipSelection(null);
      } else if (clean(fillBlankInput.value)) {
        assignFillBlankValueToInput(fillBlankInput, '');
      }
      return;
    }

    const target = event.target && typeof event.target.closest === 'function'
      ? event.target.closest('button')
      : null;
    if (!target) return;
    if (target.hasAttribute('data-open-notes-panel')) {
      toggleNotesPanel();
      return;
    }
    if (target.id === 'ptePracticeStartBtn') {
      target.disabled = true;
      const mode = clean(target.getAttribute('data-start-mode')).toLowerCase();
      await startOrRestartCurrentQuestion(mode === 'restart');
      return;
    }
    const item = getActiveItem();
    if (!item || !isSpeakingQuestion(item)) return;
    if (target.id === 'pteSpeakStartBtn') {
      target.disabled = true;
      await runSpeakingFlow(item, { manual: true });
      return;
    }
    if (target.id === 'pteSpeakStopBtn') {
      target.disabled = true;
      await stopSpeakingFlowForActiveItem({ preserveBlob: true });
      return;
    }
  });

  nodes.prompt?.addEventListener('click', async (event) => {
    const clickNode = event.target && typeof event.target.closest === 'function'
      ? event.target
      : null;
    if (!clickNode) return;
    const infoToggleBtn = clickNode.closest('button[data-situation-info-toggle]');
    if (infoToggleBtn) {
      event.preventDefault();
      const infoWrap = infoToggleBtn.closest('[data-situation-info-wrap]');
      if (!infoWrap) return;
      const shouldOpen = !infoWrap.classList.contains('is-open');
      const openWraps = Array.from(nodes.prompt?.querySelectorAll('[data-situation-info-wrap].is-open') || []);
      openWraps.forEach((wrap) => {
        wrap.classList.remove('is-open');
        const btn = wrap.querySelector('button[data-situation-info-toggle]');
        if (btn) btn.setAttribute('aria-expanded', 'false');
      });
      infoWrap.classList.toggle('is-open', shouldOpen);
      infoToggleBtn.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
      return;
    }
    if (!clickNode.closest('[data-situation-info-wrap]')) {
      const openWraps = Array.from(nodes.prompt?.querySelectorAll('[data-situation-info-wrap].is-open') || []);
      openWraps.forEach((wrap) => {
        wrap.classList.remove('is-open');
        const btn = wrap.querySelector('button[data-situation-info-toggle]');
        if (btn) btn.setAttribute('aria-expanded', 'false');
      });
    }
    const target = clickNode.closest('button');
    if (!target) return;
    if (target.hasAttribute('data-open-notes-panel')) {
      toggleNotesPanel();
      return;
    }
    if (target.id !== 'ptePracticeStartBtn') return;
    target.disabled = true;
    const mode = clean(target.getAttribute('data-start-mode')).toLowerCase();
    await startOrRestartCurrentQuestion(mode === 'restart');
  });

  nodes.response?.addEventListener('input', (event) => {
    const item = getActiveItem();
    if (!item) return;
    const runtime = getItemRuntime(item);
    if (event.target && event.target.matches('textarea[data-response-text]')) {
      if (isSpeakingQuestion(item)) runtime.speaking.transcript = String(event.target.value || '');
      else runtime.textDraft = String(event.target.value || '');
      refreshSummarizeSpokenTextMeta(item, event.target);
    }
    if (event.target && event.target.matches('textarea[data-response-map]')) {
      runtime.mapText = String(event.target.value || '');
    }
    if (event.target && event.target.matches('[data-response-blank-input]')) {
      const blankState = collectBlankResponseMapFromDom();
      runtime.mapText = stringifyBlankResponseMap(blankState.map);
      refreshFillBlankDropzoneState();
    }
  });
  nodes.response?.addEventListener('change', (event) => {
    const item = getActiveItem();
    if (!item) return;
    if (event.target && event.target.matches('select[data-response-blank-input]')) {
      const runtime = getItemRuntime(item);
      const blankState = collectBlankResponseMapFromDom();
      runtime.mapText = stringifyBlankResponseMap(blankState.map);
      refreshFillBlankDropzoneState();
    }
  });
  nodes.response?.addEventListener('dragstart', onFillBlankDragStart);
  nodes.response?.addEventListener('dragend', onFillBlankDragEnd);
  nodes.response?.addEventListener('dragover', onFillBlankDragOver);
  nodes.response?.addEventListener('dragleave', onFillBlankDragLeave);
  nodes.response?.addEventListener('drop', onFillBlankDrop);
  nodes.response?.addEventListener('dragstart', onReorderDragStart);
  nodes.response?.addEventListener('dragend', onReorderDragEnd);
  nodes.response?.addEventListener('dragover', onReorderDragOver);
  nodes.response?.addEventListener('dragleave', onReorderDragLeave);
  nodes.response?.addEventListener('drop', onReorderDrop);
  nodes.response?.addEventListener('pointerdown', onHighlightIncorrectPointerDown);
  nodes.response?.addEventListener('pointerover', onHighlightIncorrectPointerOver);
  window.addEventListener('pointerup', onHighlightIncorrectPointerEnd);
  window.addEventListener('pointercancel', onHighlightIncorrectPointerEnd);

  nodes.reanswerHeadBtn?.addEventListener('click', async () => {
    if (nodes.reanswerHeadBtn.disabled) return;
    nodes.reanswerHeadBtn.disabled = true;
    try {
      await reanswerCurrentItem();
    } finally {
      const item = getActiveItem();
      const status = clean(item?.status || '').toLowerCase();
      const sessionClosed = isSessionClosedForEditing();
      nodes.reanswerHeadBtn.disabled = !(isRetakeRequiredStatus(status) && !sessionClosed);
    }
  });
  nodes.saveBtn?.addEventListener('click', () => saveResponseItem());
  nodes.scoreBtn?.addEventListener('click', () => scoreSavedAutomatedItem());
  nodes.coachHintBtn?.addEventListener('click', async () => {
    const item = getActiveItem();
    if (!item || !itemSupportsCoach(item)) return;
    if (!state.openedItemIds.has(clean(item.id))) {
      await showMessage('Start Required', 'Please click Start before using coaching tools.', 'info');
      return;
    }
    await requestCoachHint(item);
  });
  nodes.coachCheckBtn?.addEventListener('click', async () => {
    const item = getActiveItem();
    if (!item || !itemSupportsCoach(item)) return;
    if (!state.openedItemIds.has(clean(item.id))) {
      await showMessage('Start Required', 'Please click Start before running self-check.', 'info');
      return;
    }
    state.coach.checkBusy = true;
    setCoachActionButtonsState(item, false);
    try {
      const result = runCoachSelfCheck(item);
      if (!result) return;
      const title = result.passed ? 'Self-Check Passed' : 'Self-Check Review';
      const message = result.passed
        ? 'All deterministic checks passed. You can submit when ready.'
        : ('Self-check found ' + result.warnCount + ' item(s) to review before submit.');
      await showMessage(title, message, result.passed ? 'success' : 'warning');
    } finally {
      state.coach.checkBusy = false;
      setCoachActionButtonsState(item, false);
    }
  });
  nodes.showQuestionsBtn?.addEventListener('click', () => {
    applySidebarLayout(false);
  });
  nodes.hideQuestionsBtn?.addEventListener('click', () => {
    applySidebarLayout(true);
  });
  nodes.prevBtn?.addEventListener('click', () => goPreviousQuestion());
  nodes.nextBtn?.addEventListener('click', () => goNextQuestion());
  (Array.isArray(nodes.ratingButtons) ? nodes.ratingButtons : []).forEach((btn) => {
    btn.addEventListener('click', () => {
      const rating = clean(btn.getAttribute('data-difficulty-rating')).toLowerCase();
      rateCurrentItem(rating);
    });
  });
  nodes.finishBottomBtn?.addEventListener('click', () => finishSession(nodes.finishBottomBtn));
  window.addEventListener('beforeunload', () => {
    stopWritingCountdownTicker();
    stopSpeakingFlowForActiveItem({ preserveBlob: false }).catch(() => {});
  });

  initNotesWidgets();
  applySidebarLayout(strictMockExam ? true : readSidebarCollapsedPreference(), { persist: false });
  if (nodes.finishBottomBtn && strictMockExam) {
    nodes.finishBottomBtn.classList.toggle('d-none', state.index < items.length - 1);
    nodes.finishBottomBtn.disabled = true;
  }
  startMockExamTimer();
  renderActiveQuestion().catch(() => {});
})();
</script>
