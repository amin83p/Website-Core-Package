      .filter(Boolean);
  }

  function tokenizeHighlightPhrase(phrase = '') {
    return String(phrase || '')
      .split(/[^A-Za-z0-9â€™'`-]+/g)
      .map((part) => normalizeHiwWordToken(part))
      .filter(Boolean);
  }

  function tryMatchHighlightPhrase(wordTokens = [], phraseTokens = [], fromIndex = 0, selectedSet = new Set()) {
    if (!Array.isArray(wordTokens) || !Array.isArray(phraseTokens) || !phraseTokens.length) return -1;
    const start = Math.max(0, Number.parseInt(String(fromIndex || ''), 10) || 0);
    for (let i = start; i <= (wordTokens.length - phraseTokens.length); i += 1) {
      let ok = true;
      for (let j = 0; j < phraseTokens.length; j += 1) {
        if (wordTokens[i + j] !== phraseTokens[j]) {
          ok = false;
          break;
        }
        if (selectedSet && selectedSet.has(i + j)) {
          ok = false;
          break;
        }
      }
      if (ok) return i;
    }
    return -1;
  }

  function resolveHighlightIncorrectSelection(rows = [], runtime = {}) {
    const wordRows = Array.isArray(rows) ? rows.filter((row) => row && row.kind === 'word') : [];
    const maxIndex = wordRows.length - 1;
    const mapData = parseHighlightIncorrectMap(runtime?.mapText || '');
    const selectedSet = new Set();

    const mapIndices = Array.isArray(mapData.selectedWordIndices) ? mapData.selectedWordIndices : [];
    mapIndices.forEach((value) => {
      const numeric = Number.parseInt(String(value || ''), 10);
      if (Number.isFinite(numeric) && !Number.isNaN(numeric) && numeric >= 0 && numeric <= maxIndex) {
        selectedSet.add(numeric);
      }
    });
    if (selectedSet.size > 0) return selectedSet;

    const wordTokens = wordRows.map((row) => normalizeHiwWordToken(row.text));

    const mapPhrases = Array.isArray(mapData.selectedPhrases) ? mapData.selectedPhrases : [];
    const textPhrases = splitHighlightPhraseLines(runtime?.textDraft || '');
    const targetPhrases = (mapPhrases.length ? mapPhrases : textPhrases)
      .map((line) => tokenizeHighlightPhrase(line))
      .filter((tokens) => tokens.length > 0);

    if (targetPhrases.length) {
      let cursor = 0;
      targetPhrases.forEach((phraseTokens) => {
        if (!phraseTokens.length) return;
        let startIndex = tryMatchHighlightPhrase(wordTokens, phraseTokens, cursor, selectedSet);
        if (startIndex < 0) startIndex = tryMatchHighlightPhrase(wordTokens, phraseTokens, 0, selectedSet);
        if (startIndex < 0) return;
        for (let j = 0; j < phraseTokens.length; j += 1) {
          selectedSet.add(startIndex + j);
        }
        cursor = startIndex + phraseTokens.length;
      });
      if (selectedSet.size > 0) return selectedSet;
    }

    const mapWords = Array.isArray(mapData.selectedWords) ? mapData.selectedWords : [];
    const targetWords = mapWords
      .map((value) => normalizeHiwWordToken(value))
      .filter(Boolean);
    if (!targetWords.length) return selectedSet;

    let cursor = 0;
    targetWords.forEach((targetToken) => {
      let matchedIndex = -1;
      for (let i = cursor; i < wordTokens.length; i += 1) {
        if (wordTokens[i] === targetToken && !selectedSet.has(i)) {
          matchedIndex = i;
          break;
        }
      }
      if (matchedIndex < 0) {
        for (let i = 0; i < wordTokens.length; i += 1) {
          if (wordTokens[i] === targetToken && !selectedSet.has(i)) {
            matchedIndex = i;
            break;
          }
        }
      }
      if (matchedIndex < 0) return;
      selectedSet.add(matchedIndex);
      cursor = matchedIndex + 1;
    });
    return selectedSet;
  }

  function buildHighlightSelectionGroups(selectedRows = []) {
    const rows = Array.isArray(selectedRows)
      ? selectedRows
        .filter((row) => row && Number.isFinite(row.index) && !Number.isNaN(row.index) && row.index >= 0)
        .sort((a, b) => a.index - b.index)
      : [];
    if (!rows.length) return [];

    const groups = [];
    let current = [rows[0]];
    for (let i = 1; i < rows.length; i += 1) {
      const row = rows[i];
      const prev = rows[i - 1];
      if (row.index === prev.index + 1) {
        current.push(row);
        continue;
      }
      groups.push(current);
      current = [row];
    }
    if (current.length) groups.push(current);

    return groups.map((groupRows) => ({
      indices: groupRows.map((row) => row.index),
      words: groupRows.map((row) => row.text).filter(Boolean),
      line: groupRows.map((row) => row.text).filter(Boolean).join(' ')
    }));
  }

  function buildHighlightIncorrectResponseUi(displayText = '', runtime = {}, options = {}) {
    const readOnly = options.readOnly === true;
    const rows = tokenizeHighlightIncorrectPassage(displayText);
    const selectedSet = resolveHighlightIncorrectSelection(rows, runtime);
    const selectedWords = [];
    const selectedIndices = [];
    let html = '';

    rows.forEach((row) => {
      if (row.kind !== 'word') {
        html += esc(row.text);
        return;
      }
      const selected = selectedSet.has(row.index);
      if (selected) {
        selectedWords.push(row.text);
        selectedIndices.push(row.index);
      }
      html += ''
        + '<span'
        + ' class="pte-hiw-word' + (selected ? ' is-selected' : '') + (readOnly ? ' is-readonly' : '') + '"'
        + ' data-hiw-word-index="' + String(row.index) + '"'
        + ' data-hiw-word="' + esc(row.text) + '"'
        + ' data-hiw-readonly="' + (readOnly ? '1' : '0') + '"'
        + ' aria-pressed="' + (selected ? 'true' : 'false') + '"'
        + '>'
        + esc(row.text)
        + '</span>';
    });

    const selectedRows = selectedIndices.map((index, idx) => ({
      index,
      text: selectedWords[idx] || ''
    }));
    const groups = buildHighlightSelectionGroups(selectedRows);
    const responseText = groups.map((row) => row.line).filter(Boolean).join('\n');
    const selectedPhrases = groups.map((row) => row.line).filter(Boolean);
    const mapText = serializeHighlightIncorrectMap(selectedIndices, selectedWords, selectedPhrases);
    return {
      html,
      selectedWords,
      selectedIndices,
      selectedPhrases,
      responseText,
      mapText
    };
  }

  function getHighlightIncorrectWordNodes() {
    return Array.from(nodes.response?.querySelectorAll('[data-hiw-word-index]') || []);
  }

  function findHighlightIncorrectWordNode(index) {
    const key = Number.parseInt(String(index || ''), 10);
    if (!Number.isFinite(key) || Number.isNaN(key) || key < 0) return null;
    return nodes.response?.querySelector('[data-hiw-word-index="' + String(key) + '"]') || null;
  }

  function setHighlightIncorrectWordSelected(wordNode, selected) {
    if (!wordNode) return false;
    const next = !!selected;
    const prev = wordNode.classList.contains('is-selected');
    if (prev === next) return false;
    wordNode.classList.toggle('is-selected', next);
    wordNode.setAttribute('aria-pressed', next ? 'true' : 'false');
    return true;
  }

  function syncHighlightIncorrectResponseFromDom(item) {
    if (!item || !isHighlightIncorrectWordsType(item)) return;
    const words = getHighlightIncorrectWordNodes();
    if (!words.length) return;
    const selectedRows = words
      .filter((node) => node.classList.contains('is-selected'))
      .map((node) => ({
        index: Number.parseInt(String(node.getAttribute('data-hiw-word-index') || ''), 10),
        text: clean(node.getAttribute('data-hiw-word') || node.textContent || '')
      }))
      .filter((row) => Number.isFinite(row.index) && !Number.isNaN(row.index) && row.index >= 0)
      .sort((a, b) => a.index - b.index);

    const selectedIndices = selectedRows.map((row) => row.index);
    const selectedWords = selectedRows.map((row) => row.text).filter(Boolean);
    const groups = buildHighlightSelectionGroups(selectedRows);
    const selectedPhrases = groups.map((row) => row.line).filter(Boolean);
    const responseText = selectedPhrases.join('\n');
    const mapText = serializeHighlightIncorrectMap(selectedIndices, selectedWords, selectedPhrases);

    const textArea = nodes.response?.querySelector('textarea[data-response-text]');
    if (textArea && textArea.value !== responseText) {
      textArea.value = responseText;
    }
    const countNode = nodes.response?.querySelector('[data-hiw-selected-count]');
    if (countNode) {
      countNode.textContent = String(selectedWords.length);
    }
    const runtime = getItemRuntime(item);
    runtime.textDraft = responseText;
    runtime.mapText = mapText;
  }

  function nowMs() {
    return Date.now();
  }

  function nowIso() {
    return new Date().toISOString();
  }

  function isAnsweredStatus(status) {
    const token = clean(status).toLowerCase();
    return ['saved', 'submitted', 'auto_submitted', 'scored', 'feedback_provided'].includes(token);
  }

  function hasPersistedResponseData(item) {
    if (!item || typeof item !== 'object') return false;
    if (isAnsweredStatus(item.status || '')) return true;

    const payload = (item?.metadata && typeof item.metadata === 'object' && item.metadata.responsePayload && typeof item.metadata.responsePayload === 'object')
      ? item.metadata.responsePayload
      : {};
    const hasPayloadText = !!clean(payload.text || payload.transcript || payload.mapText || '', 200000);
    const hasPayloadSelection = !!clean(payload.selectedSingle || payload.selectedTrueFalse || '', 120)
      || (Array.isArray(payload.selectedMultiple) && payload.selectedMultiple.length > 0);
    const hasPayloadArtifactRef = !!clean(payload.artifactId || payload.audioArtifactId || payload.audioAssetId || '', 180);
    if (hasPayloadText || hasPayloadSelection || hasPayloadArtifactRef) return true;

    const summary = (item?.responseSummary && typeof item.responseSummary === 'object') ? item.responseSummary : {};
    const hasSummaryValue = Object.values(summary).some((value) => {
      if (typeof value === 'string') return !!clean(value);
      if (typeof value === 'number') return Number.isFinite(value) && value > 0;
      if (Array.isArray(value)) return value.length > 0;
      return false;
    });
    if (hasSummaryValue) return true;

    const artifacts = Array.isArray(item?.artifacts) ? item.artifacts : [];
    return artifacts.length > 0;
  }

  function finalItemStatus(status) {
    const token = clean(status).toLowerCase();
    return ['submitted', 'auto_submitted', 'scored', 'feedback_provided', 'abandoned'].includes(token);
  }

  function isRetakeRequiredStatus(status) {
    if (strictMockExam) return finalItemStatus(status);
    return isAnsweredStatus(status);
  }

  function isSkippableStatus(status) {
    const token = clean(status).toLowerCase();
    if (!token) return true;
    if (token === 'abandoned') return false;
    return !isAnsweredStatus(token);
  }

  function summarizeIncompleteItemsForFinish() {
    const summary = {
      notStarted: 0,
      notSaved: 0,
      total: Array.isArray(items) ? items.length : 0,
      unresolved: []
    };
    (Array.isArray(items) ? items : []).forEach((row, index) => {
      const status = clean(row?.status || 'pending').toLowerCase() || 'pending';
      if (isAnsweredStatus(status)) return;
      const bucket = status === 'pending' ? 'notStarted' : 'notSaved';
      summary[bucket] += 1;
      summary.unresolved.push({
        index: index + 1,
        status: formatStatusLabel(status)
      });
    });
    summary.totalIncomplete = summary.notStarted + summary.notSaved;
    return summary;
  }

  function buildIncompleteFinishWarningMessage(summary = {}) {
    const notStarted = Math.max(0, toInt(summary.notStarted, 0));
    const notSaved = Math.max(0, toInt(summary.notSaved, 0));
    const total = Math.max(0, toInt(summary.totalIncomplete, 0));
    if (!total) return '';
    const sample = Array.isArray(summary.unresolved) ? summary.unresolved.slice(0, 6) : [];
    const sampleLines = sample.map((row) => ('Q' + String(row.index) + ' - ' + clean(row.status || 'Pending'))).join('<br>');
    const extra = Math.max(0, (Array.isArray(summary.unresolved) ? summary.unresolved.length : 0) - sample.length);
    const moreLine = extra > 0 ? ('<br>and ' + String(extra) + ' more...') : '';
    return ''
      + '<div class="fw-bold mb-2">Some questions are not completed yet.</div>'
      + '<div class="mb-2">Not started: <strong>' + String(notStarted) + '</strong></div>'
      + '<div class="mb-2">Started but not saved/submitted: <strong>' + String(notSaved) + '</strong></div>'
      + '<div class="small text-muted">You can still finish now, but those questions will remain incomplete.</div>'
      + (sampleLines ? ('<hr class="my-2"><div class="small">' + sampleLines + moreLine + '</div>') : '');
  }

  async function confirmFinishWithIncompleteItems() {
    const summary = summarizeIncompleteItemsForFinish();
    if (!summary.totalIncomplete) return true;
    const message = buildIncompleteFinishWarningMessage(summary);
    if (typeof window.showMessageModal === 'function') {
      const choice = await window.showMessageModal({
        title: 'Incomplete Questions Detected',
        message,
        icon: 'warning',
        buttons: [
          { text: 'Back to Questions', class: 'btn-secondary' },
          { text: strictMockExam ? 'Finish Exam Anyway' : 'Finish Practice Anyway', class: 'btn-danger' }
        ]
      });
      return choice === (strictMockExam ? 'Finish Exam Anyway' : 'Finish Practice Anyway');
    }
    return Promise.resolve(window.confirm('Some questions are not started or not saved. Finish anyway?'));
  }

  function formatStatusLabel(status = '') {
    const token = clean(status).toLowerCase();
    if (!token) return 'Pending';
    return token
      .split('_')
      .map((part) => part ? (part.charAt(0).toUpperCase() + part.slice(1)) : '')
      .join(' ')
      .trim() || 'Pending';
  }

  function getStatusBadgeClass(status = '') {
    const token = clean(status).toLowerCase();
    if (!token || token === 'pending') return 'pte-status-chip status-pending';
    if (token === 'in_progress') return 'pte-status-chip status-in-progress';
    if (token === 'abandoned') return 'pte-status-chip status-abandoned';
    if (['saved', 'scored', 'feedback_provided'].includes(token)) return 'pte-status-chip status-saved';
    if (['submitted', 'auto_submitted', 'finished'].includes(token)) return 'pte-status-chip status-submitted';
    return 'pte-status-chip status-default';
  }

  function normalizeQuestionTypeToken(questionType) {
    const raw = clean(questionType).toLowerCase();
    if (!raw) return '';
    const compact = raw
      .replace(/[\s-]+/g, '_')
      .replace(/_+/g, '_')
      .replace(/^_+|_+$/g, '');
    if (!compact) return '';
    if (compact.startsWith('speaking_')) return compact;
    const speakingAliases = new Set([
      'read_aloud',
      'repeat_sentence',
      'describe_image',
      'respond_to_situation',
      'answer_short_question'
    ]);
    if (speakingAliases.has(compact)) return `speaking_${compact}`;
    return compact;
  }

  function isSpeakingType(questionType, questionSkill = '') {
    const token = normalizeQuestionTypeToken(questionType);
    if (token.startsWith('speaking_')) return true;
    return clean(questionSkill).toLowerCase() === 'speaking';
  }

  function shouldShowNotesForItem(item = null) {
    const token = normalizeQuestionTypeToken(
      item?.question?.questionType
      || item?.questionType
      || ''
    );
    const skill = clean(item?.question?.skill || item?.skill || '').toLowerCase();
    return !(
      token.startsWith('reading_')
      || token.startsWith('writing_')
      || skill === 'reading'
      || skill === 'writing'
    );
  }

  function isHighlightIncorrectWordsType(itemOrType = null) {
    if (typeof itemOrType === 'string') {
      return normalizeQuestionTypeToken(itemOrType) === 'listening_highlight_incorrect_words';
    }
    const token = normalizeQuestionTypeToken(
      itemOrType?.question?.questionType
      || itemOrType?.questionType
      || ''
    );
    return token === 'listening_highlight_incorrect_words';
  }

  function formatQuestionTypeLabel(questionType) {
    const token = normalizeQuestionTypeToken(questionType);
    if (!token) return '';
    return token
      .split('_')
      .map((part) => part ? (part.charAt(0).toUpperCase() + part.slice(1)) : '')
      .join(' ')
      .trim();
  }

  function buildNotesMeta(item) {
    const token = normalizeQuestionTypeToken(item?.question?.questionType || item?.questionType || '');
    const skill = clean(item?.question?.skill || item?.skill || '').toLowerCase();

    if (token === 'speaking_repeat_sentence' || token === 'listening_dictation' || token === 'listening_fill_in_blank') {
      return {
        label: 'Transcript Notes',
        placeholder: 'Write transcript notes for this question...',
        iconClass: 'bi bi-journal-richtext'
      };
    }
    if (token === 'speaking_describe_image') {
      return {
        label: 'Image Notes',
        placeholder: 'Write image observation notes...',
        iconClass: 'bi bi-image'
      };
    }
    if (token === 'speaking_respond_to_situation') {
      return {
        label: 'Situation Notes',
        placeholder: 'Write quick situation response notes...',
        iconClass: 'bi bi-chat-left-quote'
      };
    }
    if (token === 'writing_write_email') {
      return {
        label: 'Email Notes',
        placeholder: 'Write email planning notes (points, tone, structure)...',
        iconClass: 'bi bi-envelope-paper'
      };
    }
    if (token.startsWith('writing_')) {
      return {
        label: 'Writing Notes',
        placeholder: 'Write your writing notes...',
        iconClass: 'bi bi-pencil-square'
      };
    }
    if (token.startsWith('reading_') || skill === 'reading') {
      return {
        label: 'Reading Notes',
        placeholder: 'Write reading notes...',
        iconClass: 'bi bi-book'
      };
    }
    if (token.startsWith('listening_') || skill === 'listening') {
      return {
        label: 'Listening Notes',
        placeholder: 'Write listening notes...',
        iconClass: 'bi bi-headphones'
      };
    }
    if (token.startsWith('speaking_') || skill === 'speaking') {
      return {
        label: 'Speaking Notes',
        placeholder: 'Write speaking notes...',
        iconClass: 'bi bi-mic'
      };
    }
    return {
      label: 'Question Notes',
      placeholder: 'Write notes for this question...',
      iconClass: 'bi bi-sticky'
    };
  }

  function readStoredPosition(storageKey, fallbackLeft, fallbackTop) {
    let left = Number(fallbackLeft || 0);
    let top = Number(fallbackTop || 0);
    try {
      const raw = localStorage.getItem(storageKey);
      if (raw) {
        const parsed = JSON.parse(raw);
        if (parsed && Number.isFinite(Number(parsed.left)) && Number.isFinite(Number(parsed.top))) {
          left = Number(parsed.left);
          top = Number(parsed.top);
        }
      }
    } catch (_) {}
    return { left, top };
  }

  function saveStoredPosition(storageKey, left, top) {
    try {
      localStorage.setItem(storageKey, JSON.stringify({ left, top }));
    } catch (_) {}
  }

  function clampPositionToViewport(element, left, top, margin = 8) {
    const rect = element?.getBoundingClientRect ? element.getBoundingClientRect() : { width: 260, height: 90 };
    const width = Math.max(60, Number(rect.width || 0) || 0);
    const height = Math.max(40, Number(rect.height || 0) || 0);
    const maxLeft = Math.max(margin, window.innerWidth - width - margin);
    const maxTop = Math.max(margin, window.innerHeight - height - margin);
    return {
      left: Math.max(margin, Math.min(Number(left || 0), maxLeft)),
      top: Math.max(margin, Math.min(Number(top || 0), maxTop))
    };
  }

  function applyFixedPosition(element, left, top, storageKey = '') {
    if (!element) return;
    const clamped = clampPositionToViewport(element, left, top, 8);
    element.style.left = `${clamped.left}px`;
    element.style.top = `${clamped.top}px`;
    element.style.right = 'auto';
    element.style.bottom = 'auto';
    if (storageKey) saveStoredPosition(storageKey, clamped.left, clamped.top);
  }

  function enableDragPositioning(element, handle, storageKey, { onDragEnd } = {}) {
    if (!element || !handle) return;
    let drag = null;

    handle.addEventListener('pointerdown', (event) => {
      if (event.button !== 0) return;
      const interactiveTarget = event.target && typeof event.target.closest === 'function'
        ? event.target.closest('button, a, input, textarea, select, [role="button"], [data-no-drag]')
        : null;
      if (interactiveTarget) return;
      const rect = element.getBoundingClientRect();
      drag = {
        pointerId: event.pointerId,
        startX: event.clientX,
        startY: event.clientY,
        originLeft: rect.left,
        originTop: rect.top,
        moved: false
      };
      try {
        handle.setPointerCapture(event.pointerId);
      } catch (_) {}
      event.preventDefault();
    });

    handle.addEventListener('pointermove', (event) => {
      if (!drag || drag.pointerId !== event.pointerId) return;
      const dx = event.clientX - drag.startX;
      const dy = event.clientY - drag.startY;
      if (!drag.moved && (Math.abs(dx) > 3 || Math.abs(dy) > 3)) drag.moved = true;
      applyFixedPosition(element, drag.originLeft + dx, drag.originTop + dy, storageKey);
      event.preventDefault();
    });

    const endDrag = (event) => {
      if (!drag || drag.pointerId !== event.pointerId) return;
      const moved = !!drag.moved;
      drag = null;
      try {
        handle.releasePointerCapture(event.pointerId);
      } catch (_) {}
      if (typeof onDragEnd === 'function') onDragEnd(moved);
    };

    handle.addEventListener('pointerup', endDrag);
    handle.addEventListener('pointercancel', endDrag);
  }

  const QUESTION_TYPES_WITH_PROMPT_AUDIO = new Set([
    'speaking_repeat_sentence',
    'speaking_answer_short_question',
    'listening_summarize_spoken_text',
    'listening_mcq_single',
    'listening_mcq_multiple',
    'listening_fill_in_blank',
    'listening_select_missing_word',
    'listening_highlight_incorrect_words',
    'listening_dictation',
    'listening_matching'
  ]);
  const WRITING_TYPES_WITH_COUNTDOWN = new Set([
    'writing_summarize_written_text',
    'writing_write_email'
  ]);
  const WRITING_COUNTDOWN_DEFAULTS_SECONDS = Object.freeze({
    writing_summarize_written_text: 10 * 60,
    writing_write_email: 9 * 60
  });

  function normalizeTranscriptForPromptDisplay(value = '') {
    return clean(value)
      .replace(/\{\{\s*\d+\s*\}\}/g, '_____')
      .replace(/\[\s*_+\s*\]/g, '_____');
  }

  function getListeningTranscriptForPrompt(payload = {}, qType = '') {
    const source = payload && typeof payload === 'object' ? payload : {};
    const token = normalizeQuestionTypeToken(qType);
    const candidates = [];
    if (token === 'listening_highlight_incorrect_words') {
      candidates.push(source.transcriptText, source.transcript, source.promptText);
    } else if (token === 'listening_fill_in_blank') {
      candidates.push(
        source.transcriptText,
        source.transcript,
        source.transcriptWithGap,
        source.transcriptWithBlanks,
        source.passageWithBlanks
      );
    } else if (token === 'listening_select_missing_word') {
      candidates.push(source.transcriptWithGap, source.transcriptText, source.transcript);
    } else {
      candidates.push(
        source.transcriptText,
        source.transcript,
        source.transcriptWithGap,
        source.transcriptWithBlanks,
        source.passageWithBlanks
      );
    }
    for (const row of candidates) {
      const text = normalizeTranscriptForPromptDisplay(row);
      if (text) return text;
    }
    return '';
  }

  function resolveQuestionMediaUrl(questionRow, assetRef) {
    const tokenRaw = clean(assetRef);
    const token = tokenRaw.toLowerCase();
    if (!token) return '';
    if (/^https?:\/\//i.test(tokenRaw)) return tokenRaw;
    if (/^\/uploads\//i.test(tokenRaw)) return tokenRaw;
    if (/^uploads\//i.test(tokenRaw)) return '/' + tokenRaw;

    const mediaRows = toArray(questionRow && questionRow.mediaAssets);
    const media = mediaRows.find((row) => {
      const keys = [
        row && row.id,
        row && row.name,
        row && row.originalName,
        row && row.filename,
        row && row.path,
        row && row.url
      ]
        .map((value) => clean(value).toLowerCase())
        .filter(Boolean);
      return keys.includes(token);
    }) || null;
    if (!media) return '';
    if (clean(media.url)) return clean(media.url);
    if (clean(media.path)) {
      const normalized = clean(media.path).replace(/\\/g, '/');
      const match = normalized.match(/\/uploads\/(.+)$/i);
      if (match && match[1]) return '/uploads/' + String(match[1]).replace(/^\/+/, '');
    }
    return '';
  }

  function normalizePlayableMediaUrl(value) {
    const tokenRaw = clean(value);
    if (!tokenRaw) return '';
    if (/^https?:\/\//i.test(tokenRaw)) return tokenRaw;
    if (/^blob:/i.test(tokenRaw)) return tokenRaw;
    if (/^data:audio\//i.test(tokenRaw)) return tokenRaw;

    const token = tokenRaw.replace(/\\/g, '/');
    if (/^\/uploads\//i.test(token)) return token;
    if (/^uploads\//i.test(token)) return '/' + token;
    const uploadsMatch = token.match(/\/uploads\/(.+)$/i);
    if (uploadsMatch && uploadsMatch[1]) {
      return '/uploads/' + String(uploadsMatch[1]).replace(/^\/+/, '');
    }
    if (/^\//.test(token)) return token;
    return token;
  }

  function normalizeAudioMimeType(value) {
    const token = clean(value).toLowerCase();
    if (!token) return '';
    return token.startsWith('audio/') ? token : '';
  }

  function resolveRecordedArtifactUrl(artifact) {
    if (!artifact || typeof artifact !== 'object') return '';
    const candidates = [artifact.url, artifact.path, artifact.filePath];
    for (const candidate of candidates) {
      const normalized = normalizePlayableMediaUrl(candidate);
      if (normalized) return normalized;
    }
    return '';
  }

  function renderAudioPlayerBlockByUrl(audioUrl, label = 'Audio', {
    autoPlay = false,
    showSinglePlayNote = false,
    bordered = true,
    playDelaySeconds = 0,
    postCountdownDelaySeconds = 1,
