  function renderReorderParagraphList(rows = [], options = {}) {
    const readOnly = options.readOnly === true;
    const fixedOrderMap = (options.fixedOrderMap instanceof Map) ? options.fixedOrderMap : new Map();
    const normalized = normalizeReorderParagraphRows(rows);
