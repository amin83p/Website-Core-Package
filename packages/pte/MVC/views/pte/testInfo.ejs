<%
  const pageData = page || {};
  const hero = pageData.hero || {};
  const showcase = Array.isArray(pageData.imageShowcase) ? pageData.imageShowcase : [];
  const highlights = Array.isArray(pageData.highlights) ? pageData.highlights : [];
  const applicantFeatures = Array.isArray(pageData.applicantFeatures) ? pageData.applicantFeatures : [];
  const learningPath = Array.isArray(pageData.learningPath) ? pageData.learningPath : [];
  const pteOverview = pageData.pteOverview || {};
  const ptePoints = Array.isArray(pteOverview.points) ? pteOverview.points : [];
  const testTypes = Array.isArray(pageData.testTypes) ? pageData.testTypes : [];
  const skillGroups = Array.isArray(pageData.skillGroups) ? pageData.skillGroups : [];
  const skillTaskCount = skillGroups.reduce((total, group) => total + (Array.isArray(group.items) ? group.items.length : 0), 0);
  const finalCta = pageData.finalCta || {};
  const firstFeature = applicantFeatures[0] || {};
  const skillVisualFallbacks = [
    { key: 'speaking', icon: 'bi-mic-fill', label: 'Speak with confidence', body: 'Build clear spoken answers with rhythm, structure, and exam-style timing.' },
    { key: 'writing', icon: 'bi-pencil-square', label: 'Write with control', body: 'Practice concise summaries and organized written responses for timed tasks.' },
    { key: 'reading', icon: 'bi-book-half', label: 'Read with accuracy', body: 'Improve comprehension, detail spotting, and decision-making under time pressure.' },
    { key: 'listening', icon: 'bi-headphones', label: 'Listen with focus', body: 'Train dictation, spoken meaning, and audio attention for common listening tasks.' }
  ];
  const skillVisualMap = {
    speaking: skillVisualFallbacks[0],
    writing: skillVisualFallbacks[1],
    reading: skillVisualFallbacks[2],
    listening: skillVisualFallbacks[3]
  };
  const getSkillVisual = (group, index) => {
    const key = String(group?.title || '').trim().toLowerCase();
    return skillVisualMap[key] || skillVisualFallbacks[index % skillVisualFallbacks.length];
  };
%>

<section class="pte-public-page">
  <section class="pte-hero-intro" aria-labelledby="pteLandingTitle">
    <div class="pte-hero-orbit" aria-hidden="true">
      <span></span>
      <span></span>
      <span></span>
    </div>
    <div class="pte-hero-copy">
      <div class="pte-eyebrow"><%= hero.eyebrow || 'PTE Practice App' %></div>
      <h1 id="pteLandingTitle"><%= hero.title || 'Prepare for PTE with guided practice.' %></h1>
      <% if (hero.subtitle) { %>
        <p><%= hero.subtitle %></p>
      <% } %>

      <div class="pte-hero-actions">
        <a class="btn pte-btn-primary" href="<%= hero.primaryHref || '/pte/join' %>">
          <i class="bi bi-person-plus-fill me-2"></i><%= hero.primaryLabel || 'Join And Start Practicing' %>
        </a>
        <a class="btn pte-btn-secondary" href="<%= hero.secondaryHref || '/login' %>">
          <i class="bi bi-box-arrow-in-right me-2"></i><%= hero.secondaryLabel || 'Sign In' %>
        </a>
      </div>
    </div>

    <div class="pte-highlight-row" aria-label="PTE practice highlights">
      <% highlights.forEach((item) => { %>
        <div class="pte-highlight-chip">
          <strong><%= item.value || '' %></strong>
          <span><%= item.label || '' %></span>
        </div>
      <% }) %>
    </div>
  </section>

  <section class="pte-showcase-block" aria-label="PTE public page image showcase">
    <div id="pteApplicantImageShowcase" class="carousel slide pte-showcase-carousel" data-bs-ride="carousel" data-bs-interval="4500" data-bs-pause="false">

      <div class="carousel-inner pte-showcase-inner">
        <% showcase.forEach((item, index) => { %>
          <% const hasSlideCaption = Boolean((item.title || '').trim() || (item.caption || '').trim()); %>
          <div class="carousel-item pte-showcase-item <%= index === 0 ? 'active' : '' %>" data-bs-interval="<%= Number(item.durationMs) > 0 ? Number(item.durationMs) : 4500 %>">
            <img src="<%= item.src %>" alt="<%= item.alt || item.title || 'PTE practice image' %>" class="pte-showcase-image">
            <% if (hasSlideCaption) { %>
              <div class="pte-image-caption">
                <% if ((item.title || '').trim()) { %>
                  <span><%= item.title %></span>
                <% } %>
                <% if ((item.caption || '').trim()) { %>
                  <small><%= item.caption %></small>
                <% } %>
              </div>
            <% } %>
          </div>
        <% }) %>
      </div>

      <% if (showcase.length > 1) { %>
        <div class="pte-showcase-controls">
          <button type="button" class="pte-showcase-control-btn" data-no-wait="true" data-pte-showcase-prev aria-label="Previous image">
            <i class="bi bi-chevron-left"></i>
            <span class="visually-hidden">Previous image</span>
          </button>
          <button type="button" class="pte-showcase-control-btn" data-no-wait="true" data-pte-showcase-toggle aria-label="Pause slideshow">
            <i class="bi bi-pause-fill" data-pte-showcase-toggle-icon></i>
            <span class="visually-hidden" data-pte-showcase-toggle-text>Pause</span>
          </button>
          <button type="button" class="pte-showcase-control-btn" data-no-wait="true" data-pte-showcase-next aria-label="Next image">
            <i class="bi bi-chevron-right"></i>
            <span class="visually-hidden">Next image</span>
          </button>
        </div>
      <% } %>
    </div>
  </section>

  <section class="pte-section pte-feature-section" aria-labelledby="pteFeaturesTitle">
    <div class="pte-section-heading">
      <span>Applicant Features</span>
      <h2 id="pteFeaturesTitle">Everything is focused on practice, feedback, and exam confidence.</h2>
      <p>
        This page is for applicants. The tools below are the learner-facing parts of the PTE module, not the internal question-management workflow.
      </p>
    </div>

    <div class="pte-feature-showcase">
      <article class="pte-feature-focus-card" id="pteFeatureFocusCard" aria-live="polite">
        <div class="pte-feature-focus-icon">
          <i class="bi <%= firstFeature.icon || 'bi-check2-circle' %>" data-feature-focus-icon></i>
        </div>
        <div class="pte-feature-focus-copy">
          <span>Focused Feature</span>
          <h3 data-feature-focus-title><%= firstFeature.title || '' %></h3>
          <p data-feature-focus-body><%= firstFeature.body || '' %></p>
        </div>
      </article>

      <div class="pte-feature-grid">
      <% applicantFeatures.forEach((feature) => { %>
        <article
          class="pte-feature-card"
          tabindex="0"
          data-feature-icon="<%= feature.icon || 'bi-check2-circle' %>"
          data-feature-title="<%= feature.title || '' %>"
          data-feature-body="<%= feature.body || '' %>">
          <div class="pte-feature-icon"><i class="bi <%= feature.icon || 'bi-check2-circle' %>"></i></div>
          <h3><%= feature.title || '' %></h3>
          <p><%= feature.body || '' %></p>
        </article>
      <% }) %>
      </div>
    </div>
  </section>

  <section class="pte-section pte-path-section" aria-labelledby="ptePathTitle">
    <div class="pte-section-heading pte-section-heading-compact">
      <span>How You Use It</span>
      <h2 id="ptePathTitle">A simple path from joining to improving.</h2>
    </div>

    <div class="pte-path-list">
      <% learningPath.forEach((item) => { %>
        <article class="pte-path-item">
          <div class="pte-path-step"><%= item.step || '' %></div>
          <div>
            <h3><%= item.title || '' %></h3>
            <p><%= item.body || '' %></p>
            <% if (item.href) { %>
              <a class="pte-path-link" href="<%= item.href %>">
                <span><%= item.linkLabel || 'Learn More' %></span>
                <i class="bi bi-arrow-right"></i>
              </a>
            <% } %>
          </div>
        </article>
      <% }) %>
    </div>
  </section>

  <section class="pte-section pte-info-section" aria-labelledby="pteInfoTitle">
    <div class="pte-info-main">
      <div class="pte-section-heading pte-section-heading-left">
        <span>General PTE Information</span>
        <h2 id="pteInfoTitle">What applicants should know about PTE.</h2>
      </div>
      <p class="pte-info-lead"><%= pteOverview.intro || '' %></p>
      <ul class="pte-info-points">
        <% ptePoints.forEach((point) => { %>
          <li><i class="bi bi-check2"></i><span><%= point %></span></li>
        <% }) %>
      </ul>
    </div>

    <aside class="pte-info-side" aria-label="PTE test types">
      <% testTypes.forEach((item) => { %>
        <article class="pte-type-card">
          <h3><%= item.title || '' %></h3>
          <p><%= item.body || '' %></p>
        </article>
      <% }) %>
    </aside>
  </section>

  <section class="pte-section pte-skills-section" aria-labelledby="pteSkillsTitle">
    <div class="pte-skills-header">
      <div class="pte-section-heading pte-section-heading-left">
        <span>Practice Areas</span>
        <h2 id="pteSkillsTitle">Build the skills that appear across PTE tasks.</h2>
      </div>

      <% if (skillGroups.length) { %>
        <div class="pte-skills-metrics" aria-label="Practice area summary">
          <div>
            <strong><%= skillGroups.length %></strong>
            <span>Skill Areas</span>
          </div>
          <div>
            <strong><%= skillTaskCount %></strong>
            <span>Task Types</span>
          </div>
        </div>
      <% } %>
    </div>

    <% if (skillGroups.length) { %>
      <div id="pteSkillShowcase" class="carousel slide pte-skill-showcase" data-bs-ride="carousel" data-bs-interval="4200" data-bs-touch="true">
        <div class="carousel-indicators pte-skill-tabs">
          <% skillGroups.forEach((group, index) => {
            const visual = getSkillVisual(group, index);
          %>
            <button
              type="button"
              data-bs-target="#pteSkillShowcase"
              data-bs-slide-to="<%= index %>"
              class="<%= index === 0 ? 'active' : '' %>"
              aria-current="<%= index === 0 ? 'true' : 'false' %>"
              aria-label="Show <%= group.title || ('skill ' + (index + 1)) %> practice">
              <i class="bi <%= visual.icon %>"></i>
              <span><%= group.title || ('Skill ' + (index + 1)) %></span>
            </button>
          <% }) %>
        </div>

        <div class="carousel-inner pte-skill-carousel-inner">
          <% skillGroups.forEach((group, index) => {
            const visual = getSkillVisual(group, index);
            const items = Array.isArray(group.items) ? group.items : [];
          %>
            <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
              <article class="pte-skill-slide pte-skill-slide--<%= visual.key %>">
                <div class="pte-skill-visual">
                  <div class="pte-skill-orbit" aria-hidden="true">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                  <div class="pte-skill-icon">
                    <i class="bi <%= visual.icon %>"></i>
                  </div>
                  <p class="pte-skill-kicker">Skill <%= String(index + 1).padStart(2, '0') %></p>
                  <h3><%= group.title || '' %></h3>
                  <p><%= visual.body %></p>
                </div>

                <div class="pte-skill-task-panel">
                  <div class="pte-skill-task-head">
                    <span><%= visual.label %></span>
                    <strong><%= items.length %> task<%= items.length === 1 ? '' : 's' %></strong>
                  </div>
                  <div class="pte-skill-task-list">
                    <% items.forEach((item, itemIndex) => { %>
                      <div class="pte-skill-task">
                        <span><%= itemIndex + 1 %></span>
                        <p><%= item %></p>
                      </div>
                    <% }) %>
                  </div>
                </div>
              </article>
            </div>
          <% }) %>
        </div>

        <% if (skillGroups.length > 1) { %>
          <button class="carousel-control-prev pte-skill-control pte-skill-control-prev" type="button" data-bs-target="#pteSkillShowcase" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous skill</span>
          </button>
          <button class="carousel-control-next pte-skill-control pte-skill-control-next" type="button" data-bs-target="#pteSkillShowcase" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next skill</span>
          </button>
        <% } %>
      </div>
    <% } %>
  </section>

  <section class="pte-final-cta" aria-labelledby="pteFinalCtaTitle">
    <div>
      <span>Join The Practice Space</span>
      <h2 id="pteFinalCtaTitle"><%= finalCta.title || 'Ready to start your PTE preparation?' %></h2>
      <p><%= finalCta.body || '' %></p>
    </div>
    <div class="pte-final-actions">
      <a class="btn pte-btn-light" href="<%= finalCta.primaryHref || '/pte/join' %>">
        <i class="bi bi-arrow-right-circle-fill me-2"></i><%= finalCta.primaryLabel || 'Create Account' %>
      </a>
      <a class="btn pte-btn-outline-light" href="<%= finalCta.secondaryHref || '/contact' %>">
        <i class="bi bi-chat-dots-fill me-2"></i><%= finalCta.secondaryLabel || 'Ask A Question' %>
      </a>
    </div>
  </section>
</section>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const showcaseCarousel = document.getElementById('pteApplicantImageShowcase');
  if (showcaseCarousel) {
    const items = Array.from(showcaseCarousel.querySelectorAll('.carousel-item'));
    const controls = showcaseCarousel.querySelector('.pte-showcase-controls');
    const prevButton = controls?.querySelector('[data-pte-showcase-prev]');
    const nextButton = controls?.querySelector('[data-pte-showcase-next]');
    const toggleButton = controls?.querySelector('[data-pte-showcase-toggle]');
    const toggleIcon = controls?.querySelector('[data-pte-showcase-toggle-icon]');
    const toggleText = controls?.querySelector('[data-pte-showcase-toggle-text]');
    const hasMultipleSlides = items.length > 1;
    let isPaused = false;

    if (controls) {
      controls.classList.toggle('is-hidden', !hasMultipleSlides);
      controls.setAttribute('aria-hidden', hasMultipleSlides ? 'false' : 'true');
    }

    if (window.bootstrap?.Carousel && hasMultipleSlides) {
      const carousel = window.bootstrap.Carousel.getOrCreateInstance(showcaseCarousel, {
        interval: 4500,
        pause: false,
        ride: 'carousel',
        wrap: true
      });

      const setPlayState = (paused) => {
        isPaused = Boolean(paused);
        if (toggleIcon) {
          toggleIcon.className = isPaused ? 'bi bi-play-fill' : 'bi bi-pause-fill';
        }
        if (toggleText) {
          toggleText.textContent = isPaused ? 'Play slideshow' : 'Pause slideshow';
        }
        if (toggleButton) {
          toggleButton.setAttribute('aria-label', isPaused ? 'Play slideshow' : 'Pause slideshow');
        }
      };

      const pause = () => {
        carousel.pause();
        setPlayState(true);
      };

      const play = () => {
        carousel.cycle();
        setPlayState(false);
      };

      prevButton?.addEventListener('click', () => {
        carousel.prev();
      });
      nextButton?.addEventListener('click', () => {
        carousel.next();
      });
      toggleButton?.addEventListener('click', () => {
        if (isPaused) {
          play();
        } else {
          pause();
        }
      });
      setPlayState(false);
      carousel.cycle();
    }
  }

  const featureShowcase = document.querySelector('.pte-feature-showcase');
  const featureGrid = featureShowcase?.querySelector('.pte-feature-grid');
  const focusCard = featureShowcase?.querySelector('#pteFeatureFocusCard');
  if (!featureShowcase || !featureGrid || !focusCard) return;

  const featureCards = Array.from(featureGrid.querySelectorAll('.pte-feature-card'));
  const focusIcon = focusCard.querySelector('[data-feature-focus-icon]');
  const focusTitle = focusCard.querySelector('[data-feature-focus-title]');
  const focusBody = focusCard.querySelector('[data-feature-focus-body]');
  const featureThemeVars = [
    '--feature-accent',
    '--feature-accent-strong',
    '--feature-line',
    '--feature-wash',
    '--feature-wash-2',
    '--feature-shadow'
  ];
  let focusedFeatureCard = null;

  const clearFeatureFocus = () => {
    focusedFeatureCard = null;
    featureShowcase.classList.remove('is-feature-focus');
    featureCards.forEach((card) => card.classList.remove('is-feature-active'));
  };

  const setFeatureFocus = (card) => {
    if (!card) return;
    if (focusedFeatureCard === card) return;
    focusedFeatureCard = card;
    const computed = window.getComputedStyle(card);
    featureThemeVars.forEach((varName) => {
      const value = computed.getPropertyValue(varName);
      if (value) focusCard.style.setProperty(varName, value);
    });
    if (focusIcon) focusIcon.className = `bi ${card.dataset.featureIcon || 'bi-check2-circle'}`;
    if (focusTitle) focusTitle.textContent = card.dataset.featureTitle || '';
    if (focusBody) focusBody.textContent = card.dataset.featureBody || '';
    featureShowcase.classList.add('is-feature-focus');
    featureCards.forEach((item) => item.classList.toggle('is-feature-active', item === card));
  };

  featureCards.forEach((card) => {
    card.addEventListener('pointerenter', () => setFeatureFocus(card));
    card.addEventListener('focus', () => setFeatureFocus(card));
  });

  featureShowcase.addEventListener('mouseleave', clearFeatureFocus);
  featureShowcase.addEventListener('focusout', () => {
    window.setTimeout(() => {
      if (!featureShowcase.contains(document.activeElement)) clearFeatureFocus();
    }, 0);
  });
});
</script>

