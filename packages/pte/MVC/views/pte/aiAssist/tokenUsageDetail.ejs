<%
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const aiAssistDashboardHref = '/dashboard/section-nav/PTE_AI_ASSISST';
  const usage = record || {};
  const consumedAtDisplay = usage.consumedAtDisplay || (usage.consumedAt ? new Date(usage.consumedAt).toLocaleString() : '-');
  const status = String(usage.status || '').trim().toLowerCase();
  const statusClass = status === 'success' ? 'bg-success' : (status === 'failed' ? 'bg-danger' : 'bg-secondary');
%>

<%- include('../../partials/tablePages-start', {
  title,
  newUrl: null,
  newLabel: null,
  user,
  tableName: 'PTE_AI_Token_Usage_Detail',
  btn_export: false,
  print: false,
  headerManageBtns: [
    '<a href="' + dashboardHref + '" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> PTE Dashboard</a>',
    '<a href="' + aiAssistDashboardHref + '" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-robot me-1"></i> PTE AI Assist</a>'
  ],
  manageBtns: [
    '<a href="/pte/ai-assisst/token-usage" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-arrow-left me-1"></i> Back to Token Usage</a>',
    '<a href="/pte/ai-assisst/scoring-settings" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-sliders me-1"></i> Scoring Settings</a>'
  ]
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white d-flex align-items-center justify-content-between flex-wrap gap-2">
    <h6 class="mb-0 fw-bold">Usage Record</h6>
    <span class="badge <%= statusClass %> text-capitalize"><%= status || '-' %></span>
  </div>
  <div class="card-body">
    <div class="row g-3">
      <div class="col-md-4">
        <div class="small text-muted text-uppercase">ID</div>
        <div class="font-monospace"><%= usage.id || '-' %></div>
      </div>
      <div class="col-md-4">
        <div class="small text-muted text-uppercase">Date-Time</div>
        <div><%= consumedAtDisplay %></div>
      </div>
      <div class="col-md-4">
        <div class="small text-muted text-uppercase">Organization</div>
        <div class="font-monospace"><%= usage.orgId || '-' %></div>
      </div>
    </div>

    <hr>

    <div class="row g-3">
      <div class="col-md-4">
        <div class="small text-muted text-uppercase">User</div>
        <div><%= usage.userLabel || usage.userId || '-' %></div>
        <div class="x-small text-muted font-monospace"><%= usage.userId || '-' %></div>
      </div>
      <div class="col-md-4">
        <div class="small text-muted text-uppercase">Section</div>
        <div><%= usage.section || '-' %></div>
      </div>
      <div class="col-md-4">
        <div class="small text-muted text-uppercase">Operation</div>
        <div><%= usage.operation || '-' %></div>
      </div>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-md-6">
        <div class="small text-muted text-uppercase">Object ID</div>
        <div class="font-monospace"><%= usage.objectId || '-' %></div>
      </div>
      <div class="col-md-6">
        <div class="small text-muted text-uppercase">Request Label</div>
        <div><%= usage.requestLabel || '-' %></div>
      </div>
    </div>

    <hr>

    <div class="row g-3">
      <div class="col-md-4">
        <div class="small text-muted text-uppercase">Provider ID</div>
        <div class="text-lowercase"><%= usage.providerId || '-' %></div>
      </div>
      <div class="col-md-4">
        <div class="small text-muted text-uppercase">Provider Record</div>
        <div><%= usage.providerRecordName || '-' %></div>
        <div class="x-small text-muted font-monospace"><%= usage.providerRecordId || '-' %></div>
      </div>
      <div class="col-md-4">
        <div class="small text-muted text-uppercase">Model</div>
        <div><%= usage.modelUsed || '-' %></div>
      </div>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-md-3">
        <div class="small text-muted text-uppercase">Prompt Tokens</div>
        <div class="fw-bold"><%= Number(usage.promptTokenCount || 0) %></div>
      </div>
      <div class="col-md-3">
        <div class="small text-muted text-uppercase">Candidates Tokens</div>
        <div class="fw-bold"><%= Number(usage.candidatesTokenCount || 0) %></div>
      </div>
      <div class="col-md-3">
        <div class="small text-muted text-uppercase">Total Tokens</div>
        <div class="fw-bold"><%= Number(usage.totalTokenCount || 0) %></div>
      </div>
      <div class="col-md-3">
        <div class="small text-muted text-uppercase">Cached Tokens</div>
        <div class="fw-bold"><%= Number(usage.cachedContentTokenCount || 0) %></div>
      </div>
    </div>

    <hr>

    <div class="row g-3">
      <div class="col-md-12">
        <div class="small text-muted text-uppercase">Error Message</div>
        <% if (usage.errorMessage) { %>
          <div class="text-danger"><%= usage.errorMessage %></div>
        <% } else { %>
          <div class="text-muted">No error was recorded for this event.</div>
        <% } %>
      </div>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-md-12">
        <div class="small text-muted text-uppercase">Request Metadata</div>
        <pre class="bg-light border rounded p-3 small mb-0"><%= JSON.stringify(usage.requestMeta || {}, null, 2) %></pre>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/tablePages-end') %>
