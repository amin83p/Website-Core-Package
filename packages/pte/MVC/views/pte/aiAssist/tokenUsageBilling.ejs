<%
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const aiAssistDashboardHref = '/dashboard/section-nav/PTE_AI_ASSISST';
  const stateFilters = (filters && typeof filters === 'object') ? filters : {};
  const selectedOrgRow = (selectedOrg && typeof selectedOrg === 'object') ? selectedOrg : null;
  const selectedUserRows = Array.isArray(selectedUsers) ? selectedUsers : [];
  const billingState = (billing && typeof billing === 'object') ? billing : null;
  const dailyRows = Array.isArray(billingState?.dailyRows) ? billingState.dailyRows : [];
  const modelRows = Array.isArray(billingState?.modelRows) ? billingState.modelRows : [];
  const totals = (billingState?.totals && typeof billingState.totals === 'object') ? billingState.totals : {};
  const analysis = (billingState?.analysis && typeof billingState.analysis === 'object') ? billingState.analysis : {};
  const billingHasData = Boolean(billingState);
%>

<%- include('../../../../../../MVC/views/partials/tablePages-start', {
  title,
  newUrl: null,
  newLabel: null,
  user,
  tableName: billingHasData ? (tableName || 'PTE_AI_Token_Usage_Billing') : null,
  btn_export: false,
  print: false,
  headerManageBtns: [
    '<a href="' + dashboardHref + '" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> PTE Dashboard</a>',
    '<a href="' + aiAssistDashboardHref + '" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-robot me-1"></i> PTE AI Assist</a>'
  ],
  manageBtns: [
    '<a href="/pte/ai-assisst/token-usage" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-arrow-left me-1"></i> Token Usage</a>',
    '<a href="/pte/ai-assisst/api-providers" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-key-fill me-1"></i> API Providers</a>',
    '<a href="/pte/ai-assisst/scoring-settings" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-sliders me-1"></i> Scoring Settings</a>'
  ]
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white fw-bold">
    <i class="bi bi-receipt-cutoff me-2"></i>Billing Filters
  </div>
  <div class="card-body">
    <form method="GET" action="/pte/ai-assisst/token-usage/billing" id="pteAiTokenBillingFilterForm">
      <input type="hidden" name="apply" value="1">
      <div class="row g-3 align-items-end">
        <div class="col-lg-6">
          <label class="form-label fw-bold">Organization</label>
          <% if (isSuperUser) { %>
            <div class="d-flex align-items-center gap-2 mb-1">
              <button type="button" class="btn btn-outline-primary btn-sm" id="btnPickBillingOrg">
                <i class="bi bi-building me-1"></i> Select Organization
              </button>
              <button type="button" class="btn btn-outline-secondary btn-sm" id="btnClearBillingOrg">Clear</button>
            </div>
            <div id="billingSelectedOrgBox" class="border rounded bg-light-subtle p-2 small mb-0"></div>
            <input type="hidden" name="orgId" id="billingOrgIdInput" value="<%= stateFilters.orgId || '' %>">
          <% } else { %>
            <div class="border rounded bg-light-subtle p-2">
              <div class="fw-bold"><%= activeOrg?.name || activeOrg?.id || '-' %></div>
              <div class="x-small text-muted font-monospace"><%= activeOrg?.id || '-' %></div>
            </div>
            <input type="hidden" name="orgId" id="billingOrgIdInput" value="<%= stateFilters.orgId || activeOrg?.id || '' %>">
          <% } %>
        </div>
        <div class="col-lg-3">
          <label class="form-label fw-bold">Start Date-Time</label>
          <input type="datetime-local" class="form-control size-md" name="startAt" id="billingStartAtInput" value="<%= stateFilters.startAt || '' %>">
        </div>
        <div class="col-lg-3">
          <label class="form-label fw-bold">End Date-Time</label>
          <input type="datetime-local" class="form-control size-md" name="endAt" id="billingEndAtInput" value="<%= stateFilters.endAt || '' %>">
        </div>
      </div>

      <div class="row g-3 align-items-start mt-1">
        <div class="col-12">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-1">
            <label class="form-label mb-0 fw-bold">Users</label>
            <div class="d-flex align-items-center gap-2">
              <button type="button" class="btn btn-outline-primary btn-sm" id="btnPickBillingUsers">
                <i class="bi bi-people me-1"></i> Select Users
              </button>
              <button type="button" class="btn btn-outline-secondary btn-sm" id="btnClearBillingUsers">Clear Users</button>
            </div>
          </div>
          <div id="billingSelectedUsersBox" class="border rounded bg-light-subtle p-2 small"></div>
          <div class="form-text">Leave users empty to include all accessible users in the selected organization.</div>
        </div>
      </div>

      <div class="d-flex justify-content-end gap-2 mt-3">
        <a href="/pte/ai-assisst/token-usage/billing" class="btn btn-outline-secondary btn-md">Reset</a>
        <button type="submit" class="btn btn-filled btn-primary btn-md">
          <i class="bi bi-bar-chart-line me-1"></i> Build Billing
        </button>
      </div>
    </form>
  </div>
</div>

<% if (billingError) { %>
  <div class="alert alert-warning border-0 shadow-sm mb-3">
    <i class="bi bi-exclamation-triangle me-2"></i><%= billingError %>
  </div>
<% } %>

<% if (billingHasData) { %>
  <div class="row g-3 mb-3">
    <div class="col-md-3 col-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="small text-muted">Calls</div>
          <div class="h4 m-0"><%= Number(totals.callCount || 0).toLocaleString() %></div>
        </div>
      </div>
    </div>
    <div class="col-md-3 col-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="small text-muted">Total Tokens</div>
          <div class="h4 m-0"><%= Number(totals.totalTokens || 0).toLocaleString() %></div>
        </div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="small text-muted">Prompt</div>
          <div class="h5 m-0"><%= Number(totals.promptTokens || 0).toLocaleString() %></div>
        </div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="small text-muted">Output</div>
          <div class="h5 m-0"><%= Number(totals.outputTokens || 0).toLocaleString() %></div>
        </div>
      </div>
    </div>
    <div class="col-md-2 col-6">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="small text-muted">Cached</div>
          <div class="h5 m-0"><%= Number(totals.cachedTokens || 0).toLocaleString() %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-xl-8">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-bold">
          <i class="bi bi-bar-chart-fill me-2"></i>Daily Token Consumption
        </div>
        <div class="card-body">
          <div class="chart-shell">
            <canvas id="pteBillingDailyChart" width="1200" height="360"></canvas>
          </div>
          <div class="small text-muted mt-2">Each bar shows total token usage for that day.</div>
        </div>
      </div>
    </div>
    <div class="col-xl-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white fw-bold">
          <i class="bi bi-clipboard-data me-2"></i>Consumption Analysis
        </div>
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">Range Days</span>
            <span class="fw-bold"><%= Number(analysis.rangeDayCount || 0).toLocaleString() %></span>
          </div>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">Active Days</span>
            <span class="fw-bold"><%= Number(analysis.activeDayCount || 0).toLocaleString() %></span>
          </div>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">Avg Tokens / Call</span>
            <span class="fw-bold"><%= Number(analysis.avgTokensPerCall || 0).toFixed(2) %></span>
          </div>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">Avg Calls / Day</span>
            <span class="fw-bold"><%= Number(analysis.avgCallsPerDay || 0).toFixed(2) %></span>
          </div>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">Avg Tokens / Day</span>
            <span class="fw-bold"><%= Number(analysis.avgTokensPerDay || 0).toFixed(2) %></span>
          </div>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">Avg Calls / Active Day</span>
            <span class="fw-bold"><%= Number(analysis.avgCallsPerActiveDay || 0).toFixed(2) %></span>
          </div>
          <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-muted small">Avg Tokens / Active Day</span>
            <span class="fw-bold"><%= Number(analysis.avgTokensPerActiveDay || 0).toFixed(2) %></span>
          </div>
          <div class="d-flex justify-content-between align-items-center">
            <span class="text-muted small">Avg Tokens / Model</span>
            <span class="fw-bold"><%= Number(analysis.avgModelTokens || 0).toFixed(2) %></span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mt-3">
    <div class="card-header bg-white fw-bold">
      <i class="bi bi-table me-2"></i>Model Usage
    </div>
    <div class="card-body p-0">
      <div class="table-scroll-wrapper">
        <table class="table-responsive size-md mb-0" id="first-table">
          <thead>
            <tr>
              <th>Model</th>
              <th>Calls</th>
              <th>Prompt Tokens</th>
              <th>Output Tokens</th>
              <th>Total Tokens</th>
              <th>Cached Tokens</th>
            </tr>
          </thead>
          <tbody>
            <% if (!modelRows.length) { %>
              <tr><td colspan="6" class="text-center text-muted py-3">No model usage data found for the selected filters.</td></tr>
            <% } %>
            <% modelRows.forEach((row) => { %>
              <tr>
                <td><span class="badge bg-light text-dark border"><%= row.modelUsed || '(unspecified model)' %></span></td>
                <td><%= Number(row.callCount || 0).toLocaleString() %></td>
                <td><%= Number(row.promptTokens || 0).toLocaleString() %></td>
                <td><%= Number(row.outputTokens || 0).toLocaleString() %></td>
                <td class="fw-semibold"><%= Number(row.totalTokens || 0).toLocaleString() %></td>
                <td><%= Number(row.cachedTokens || 0).toLocaleString() %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
<% } else { %>
  <div class="card border-0 shadow-sm">
    <div class="card-body text-muted">
      Select organization, users, and date-time range, then click <strong>Build Billing</strong> to generate token consumption analytics.
    </div>
  </div>
<% } %>

<%- include('../../../../../../MVC/views/partials/tablePages-end') %>
<%- include('../../../../../../MVC/views/partials/modal_GenericPicker', { user }) %>
<%- include('../../../../../../MVC/views/partials/modal') %>

<script>
(() => {
  const isSuperUser = <%- JSON.stringify(Boolean(isSuperUser)) %>;
  const form = document.getElementById('pteAiTokenBillingFilterForm');
  if (!form) return;

  const orgIdInput = document.getElementById('billingOrgIdInput');
  const selectedOrgBox = document.getElementById('billingSelectedOrgBox');
  const selectedUsersBox = document.getElementById('billingSelectedUsersBox');
  const btnPickOrg = document.getElementById('btnPickBillingOrg');
  const btnClearOrg = document.getElementById('btnClearBillingOrg');
  const btnPickUsers = document.getElementById('btnPickBillingUsers');
  const btnClearUsers = document.getElementById('btnClearBillingUsers');
  const startAtInput = document.getElementById('billingStartAtInput');
  const endAtInput = document.getElementById('billingEndAtInput');
  const dailyRows = <%- JSON.stringify(dailyRows || []).replace(/</g, '\\u003c') %>;

  const state = {
    selectedOrg: <%- JSON.stringify(selectedOrgRow || null).replace(/</g, '\\u003c') %>,
    selectedUsers: <%- JSON.stringify(selectedUserRows || []).replace(/</g, '\\u003c') %>
  };

  function esc(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function normalizeId(value) {
    return String(value || '').trim();
  }

  function showMessage(title, message, icon = 'info') {
    if (typeof window.showMessageModal === 'function') {
      return window.showMessageModal({
        title,
        icon,
        message,
        buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : 'btn-primary' }]
      });
    }
    alert(String(message || ''));
    return Promise.resolve();
  }

  function renderSelectedOrg() {
    if (!selectedOrgBox) return;
    const row = state.selectedOrg && typeof state.selectedOrg === 'object' ? state.selectedOrg : null;
    if (!row || !normalizeId(row.id || row.orgId)) {
      selectedOrgBox.innerHTML = '<div class="text-muted">No organization selected.</div>';
      if (orgIdInput) orgIdInput.value = '';
      return;
    }
    const id = normalizeId(row.id || row.orgId);
    const name = String(row.name || row.displayName || id).trim() || id;
    selectedOrgBox.innerHTML = ''
      + '<div class="fw-bold">' + esc(name) + '</div>'
      + '<div class="x-small text-muted font-monospace">' + esc(id) + '</div>';
    if (orgIdInput) orgIdInput.value = id;
  }

  function renderSelectedUsers() {
    if (!selectedUsersBox) return;
    const rows = Array.isArray(state.selectedUsers) ? state.selectedUsers : [];
    if (!rows.length) {
      selectedUsersBox.innerHTML = '<div class="text-muted">All users under selected organization.</div>';
      return;
    }
    selectedUsersBox.innerHTML = rows.map((row, index) => {
      const id = normalizeId(row?.id);
      const label = String(row?.name || row?.username || row?.email || id).trim() || id;
      return ''
        + '<div class="d-flex align-items-center justify-content-between gap-2 border rounded bg-white px-2 py-1 mb-2">'
        + '  <div class="text-break">'
        + '    <div class="fw-bold">' + esc(label) + '</div>'
        + '    <div class="x-small text-muted font-monospace">' + esc(id) + '</div>'
        + '    <input type="hidden" name="userIds" value="' + esc(id) + '">'
        + '  </div>'
        + '  <button type="button" class="btn btn-outline-danger btn-sm billing-remove-user" data-index="' + index + '">'
        + '    <i class="bi bi-x-lg"></i>'
        + '  </button>'
        + '</div>';
    }).join('');

    selectedUsersBox.querySelectorAll('.billing-remove-user').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = Number.parseInt(String(btn.getAttribute('data-index') || ''), 10);
        if (!Number.isFinite(idx) || idx < 0 || idx >= state.selectedUsers.length) return;
        state.selectedUsers.splice(idx, 1);
        renderSelectedUsers();
      });
    });
  }

  btnPickOrg?.addEventListener('click', () => {
    if (!isSuperUser || !window.GenericPicker || !window.GenericPickerPresets) return;
    window.GenericPicker.open(window.GenericPickerPresets.organization({
      title: 'Select Organization',
      icon: 'bi-building',
      apiEndpoint: '/pte/ai-assisst/token-usage/billing/picker/organizations',
      placeholder: 'Search organizations...',
      multiselect: false,
      onSelect: (item) => {
        const row = item || {};
        const id = normalizeId(row.id || row.orgId);
        if (!id) return;
        state.selectedOrg = {
          id,
          orgId: id,
          name: String(row.name || row.displayName || id).trim() || id
        };
        state.selectedUsers = [];
        renderSelectedOrg();
        renderSelectedUsers();
      }
    }));
  });

  btnClearOrg?.addEventListener('click', () => {
    if (!isSuperUser) return;
    state.selectedOrg = null;
    state.selectedUsers = [];
    renderSelectedOrg();
    renderSelectedUsers();
  });

  btnPickUsers?.addEventListener('click', async () => {
    if (!window.GenericPicker || !window.GenericPickerPresets) return;
    const orgId = normalizeId(orgIdInput?.value || state.selectedOrg?.id || '');
    if (!orgId) {
      await showMessage('Organization Required', 'Please select an organization first.', 'warning');
      return;
    }

    const endpoint = '/pte/ai-assisst/token-usage/picker/users?orgId=' + encodeURIComponent(orgId);
    window.GenericPicker.open(window.GenericPickerPresets.user({
      title: 'Select Users',
      icon: 'bi-people',
      apiEndpoint: endpoint,
      placeholder: 'Search users by name, username, email, or id...',
      multiselect: true,
      onSelect: (items) => {
        const rows = Array.isArray(items) ? items : [items];
        rows.forEach((row) => {
          const id = normalizeId(row?.id);
          if (!id) return;
          if (state.selectedUsers.some((userRow) => normalizeId(userRow?.id) === id)) return;
          state.selectedUsers.push({
            id,
            name: String(row?.name || row?.username || row?.email || id).trim() || id,
            username: String(row?.username || '').trim(),
            email: String(row?.email || '').trim()
          });
        });
        renderSelectedUsers();
      }
    }));
  });

  btnClearUsers?.addEventListener('click', () => {
    state.selectedUsers = [];
    renderSelectedUsers();
  });

  form.addEventListener('submit', async (event) => {
    const orgId = normalizeId(orgIdInput?.value || '');
    const startAt = String(startAtInput?.value || '').trim();
    const endAt = String(endAtInput?.value || '').trim();
    if (!orgId) {
      event.preventDefault();
      await showMessage('Organization Required', 'Please select an organization to build billing.', 'warning');
      return;
    }
    if (!startAt || !endAt) {
      event.preventDefault();
      await showMessage('Date-Time Required', 'Please choose both start and end date-time values.', 'warning');
      return;
    }
    renderSelectedUsers();
  });

  function drawDailyBarChart(canvas, rows) {
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const dpr = window.devicePixelRatio || 1;
    const cssWidth = canvas.clientWidth || canvas.width;
    const cssHeight = canvas.clientHeight || canvas.height;
    canvas.width = Math.floor(cssWidth * dpr);
    canvas.height = Math.floor(cssHeight * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.clearRect(0, 0, cssWidth, cssHeight);

    if (!Array.isArray(rows) || !rows.length) {
      ctx.fillStyle = '#6c757d';
      ctx.font = '14px sans-serif';
      ctx.fillText('No daily token data in selected range.', 12, 24);
      return;
    }

    const leftPad = 76;
    const topPad = 12;
    const rightPad = 12;
    const bottomPad = 82;
    const chartWidth = Math.max(120, cssWidth - leftPad - rightPad);
    const chartHeight = Math.max(120, cssHeight - topPad - bottomPad);

    const values = rows.map((row) => Number(row?.totalTokens || 0));
    const maxValue = Math.max(1, ...values);
    const barGradient = ctx.createLinearGradient(0, topPad, 0, topPad + chartHeight);
    barGradient.addColorStop(0, '#f97316');
    barGradient.addColorStop(1, '#fb923c');

    function formatYAxisValue(value) {
      const n = Number(value || 0);
      if (!Number.isFinite(n)) return '0';
      if (n >= 1000000) return (n / 1000000).toFixed(n >= 10000000 ? 0 : 1) + 'M';
      if (n >= 1000) return (n / 1000).toFixed(n >= 10000 ? 0 : 1) + 'K';
      return Math.round(n).toLocaleString();
    }

    ctx.strokeStyle = '#94a3b8';
    ctx.lineWidth = 1.25;
    ctx.beginPath();
    ctx.moveTo(leftPad, topPad);
    ctx.lineTo(leftPad, topPad + chartHeight);
    ctx.lineTo(cssWidth - rightPad, topPad + chartHeight);
    ctx.stroke();

    ctx.fillStyle = '#1f2937';
    ctx.font = '12px system-ui, -apple-system, Segoe UI, Roboto, sans-serif';
    ctx.textAlign = 'right';
    ctx.textBaseline = 'middle';
    const yTicks = 5;
    for (let i = 0; i <= yTicks; i += 1) {
      const v = (maxValue * i) / yTicks;
      const y = topPad + chartHeight - ((chartHeight * i) / yTicks);
      ctx.fillText(formatYAxisValue(v), leftPad - 10, y);
      ctx.strokeStyle = 'rgba(15, 23, 42, 0.12)';
      ctx.lineWidth = 1;
      ctx.beginPath();
      ctx.moveTo(leftPad, y);
      ctx.lineTo(cssWidth - rightPad, y);
      ctx.stroke();
    }

    const barGap = rows.length > 22 ? 2 : 4;
    const barWidth = Math.max(8, Math.floor((chartWidth - (barGap * (rows.length - 1))) / Math.max(1, rows.length)));
    const stepX = barWidth + barGap;

    rows.forEach((row, idx) => {
      const value = Number(row?.totalTokens || 0);
      const barHeight = Math.max(1, (value / maxValue) * chartHeight);
      const x = leftPad + (idx * stepX);
      const y = topPad + chartHeight - barHeight;

      ctx.fillStyle = barGradient;
      ctx.fillRect(x, y, barWidth, barHeight);
      ctx.strokeStyle = '#ea580c';
      ctx.lineWidth = 0.8;
      ctx.strokeRect(x + 0.4, y + 0.4, Math.max(1, barWidth - 0.8), Math.max(1, barHeight - 0.8));

      if (idx % Math.ceil(rows.length / 9 || 1) === 0 || rows.length <= 10) {
        const label = String(row?.day || '');
        ctx.save();
        ctx.translate(x + (barWidth / 2), topPad + chartHeight + 18);
        ctx.rotate(-Math.PI / 4);
        ctx.fillStyle = '#1f2937';
        ctx.font = '11px system-ui, -apple-system, Segoe UI, Roboto, sans-serif';
        ctx.textAlign = 'left';
        ctx.textBaseline = 'middle';
        ctx.fillText(label, 0, 0);
        ctx.restore();
      }
    });
  }

  function renderDailyChart() {
    drawDailyBarChart(document.getElementById('pteBillingDailyChart'), dailyRows);
  }

  if (document.getElementById('pteBillingDailyChart')) {
    renderDailyChart();
    window.addEventListener('resize', () => {
      clearTimeout(window.__pteBillingChartResizeTimer);
      window.__pteBillingChartResizeTimer = setTimeout(renderDailyChart, 180);
    });
  }

  renderSelectedOrg();
  renderSelectedUsers();
})();
</script>

<style>
  .chart-shell {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 10px;
    background: linear-gradient(180deg, #fff 0%, #f8f9fa 100%);
    padding: 8px;
    overflow-x: auto;
    overflow-y: hidden;
  }
  .chart-shell canvas {
    width: 100%;
    height: 320px;
    display: block;
  }
</style>
