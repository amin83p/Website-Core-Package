<%
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const aiAssistDashboardHref = '/dashboard/section-nav/PTE_AI_ASSISST';
  const stateFilters = (filters && typeof filters === 'object') ? filters : {};
  const selectedStatus = String(stateFilters?.status || '').trim().toLowerCase();
  const sections = Array.isArray(filterOptions?.sections) ? filterOptions.sections : [];
  const operations = Array.isArray(filterOptions?.operations) ? filterOptions.operations : [];
  const providers = Array.isArray(filterOptions?.providers) ? filterOptions.providers : [];
  const totalMatchedRows = Number(pagination?.totalItems ?? (Array.isArray(data) ? data.length : 0));
  const selectedUsersCount = Array.isArray(selectedUsers) ? selectedUsers.length : 0;

  function toList(input) {
    if (Array.isArray(input)) return input.map((item) => String(item || '').trim()).filter(Boolean);
    const token = String(input || '').trim();
    if (!token) return [];
    return token.split(',').map((item) => String(item || '').trim()).filter(Boolean);
  }

  const hasTokenUsageAdvancedFilters = Boolean(
    String(stateFilters.section || '').trim()
    || String(stateFilters.operation || '').trim()
    || String(stateFilters.modelUsed || '').trim()
    || String(stateFilters.objectId || '').trim()
    || String(stateFilters.requestLabel || '').trim()
  );

  const hasTokenUsageFiltersApplied = Boolean(
    String(stateFilters.startDate || '').trim()
    || String(stateFilters.endDate || '').trim()
    || String(stateFilters.status || '').trim()
    || String(stateFilters.providerId || '').trim()
    || toList(stateFilters.userIds || stateFilters.userId).length
    || hasTokenUsageAdvancedFilters
  );
%>

<%- include('../../../../../../MVC/views/partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print: true,
  headerManageBtns: [
    '<a href="' + dashboardHref + '" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> PTE Dashboard</a>',
    '<a href="' + aiAssistDashboardHref + '" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-robot me-1"></i> PTE AI Assist</a>'
  ],
  manageBtns: [
    '<a href="/pte/ai-assisst/api-providers" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-key-fill me-1"></i> API Providers</a>',
    '<a href="/pte/ai-assisst/scoring-settings" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-sliders me-1"></i> Scoring Settings</a>',
    '<a href="/pte/ai-assisst/token-usage/billing" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-receipt-cutoff me-1"></i> Billing</a>'
  ]
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
    <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter Token Usage</div>
    <button
      id="pteAiUsageFilterToggleBtn"
      type="button"
      class="btn btn-outline-secondary btn-sm px-2"
      data-bs-toggle="collapse"
      data-bs-target="#pteAiUsageFilterCollapse"
      aria-expanded="<%= hasTokenUsageFiltersApplied ? 'true' : 'false' %>"
      aria-controls="pteAiUsageFilterCollapse"
      aria-label="<%= hasTokenUsageFiltersApplied ? 'Close filters' : 'Open filters' %>">
      <i id="pteAiUsageFilterToggleIcon" class="bi <%= hasTokenUsageFiltersApplied ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
    </button>
  </div>
  <div class="collapse<%= hasTokenUsageFiltersApplied ? ' show' : '' %>" id="pteAiUsageFilterCollapse">
    <form method="GET" action="/pte/ai-assisst/token-usage" id="pteAiTokenUsageFilterForm" class="card-body p-3">
      <% if (filters?.q) { %><input type="hidden" name="q" value="<%= filters.q %>"><% } %>
      <% if (filters?.type) { %><input type="hidden" name="type" value="<%= filters.type %>"><% } %>
      <% if (filters?.searchFields) { %><input type="hidden" name="searchFields" value="<%= filters.searchFields %>"><% } %>

      <div class="row g-3 align-items-end">
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Date From</label>
          <input type="date" class="form-control size-md" name="startDate" value="<%= filters?.startDate || '' %>">
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Date To</label>
          <input type="date" class="form-control size-md" name="endDate" value="<%= filters?.endDate || '' %>">
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Status</label>
          <select class="form-select size-md" name="status">
            <option value="">All</option>
            <% (statusOptions || []).forEach((row) => { %>
              <% const value = String(row?.value || '').trim().toLowerCase(); %>
              <option value="<%= value %>" <%= value === selectedStatus ? 'selected' : '' %>><%= row?.label || row?.value || value %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Provider</label>
          <select class="form-select size-md" name="providerId">
            <option value="">All Providers</option>
            <% providers.forEach((providerId) => { %>
              <% const token = String(providerId || '').trim().toLowerCase(); %>
              <option value="<%= token %>" <%= token === String(filters?.providerId || '').trim().toLowerCase() ? 'selected' : '' %>><%= token %></option>
            <% }) %>
          </select>
        </div>
      </div>

      <div class="row g-3 align-items-start mt-1">
        <div class="col-12">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-1">
            <label class="form-label mb-0">Users</label>
            <div class="d-flex align-items-center gap-2">
              <button type="button" class="btn btn-outline-primary btn-sm" id="btnPickAiUsageUsers">
                <i class="bi bi-people me-1"></i> Select Users
              </button>
              <button type="button" class="btn btn-outline-secondary btn-sm" id="btnClearAiUsageUsers">Clear Users</button>
            </div>
          </div>
          <div id="aiUsageSelectedUsersBox" class="border rounded bg-light-subtle p-2 small"></div>
        </div>
      </div>

      <div class="border rounded-3 bg-light-subtle p-2 mt-3">
        <div class="d-flex align-items-center justify-content-between">
          <div class="small fw-bold text-uppercase text-muted">Advanced Filters</div>
          <button
            id="pteAiUsageAdvancedToggleBtn"
            type="button"
            class="btn btn-outline-secondary btn-sm px-2"
            data-bs-toggle="collapse"
            data-bs-target="#pteAiUsageAdvancedFilterCollapse"
            aria-expanded="<%= hasTokenUsageAdvancedFilters ? 'true' : 'false' %>"
            aria-controls="pteAiUsageAdvancedFilterCollapse"
            aria-label="<%= hasTokenUsageAdvancedFilters ? 'Close advanced filters' : 'Open advanced filters' %>">
            <i id="pteAiUsageAdvancedToggleIcon" class="bi <%= hasTokenUsageAdvancedFilters ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
          </button>
        </div>
        <div class="collapse mt-2<%= hasTokenUsageAdvancedFilters ? ' show' : '' %>" id="pteAiUsageAdvancedFilterCollapse">
          <div class="row g-3">
            <div class="col-md-6 col-xl-4">
              <label class="form-label">Section</label>
              <select class="form-select size-md" name="section">
                <option value="">All Sections</option>
                <% sections.forEach((section) => { %>
                  <% const token = String(section || '').trim().toUpperCase(); %>
                  <option value="<%= token %>" <%= token === String(filters?.section || '').trim().toUpperCase() ? 'selected' : '' %>><%= token %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6 col-xl-4">
              <label class="form-label">Operation</label>
              <select class="form-select size-md" name="operation">
                <option value="">All Operations</option>
                <% operations.forEach((operation) => { %>
                  <% const token = String(operation || '').trim().toUpperCase(); %>
                  <option value="<%= token %>" <%= token === String(filters?.operation || '').trim().toUpperCase() ? 'selected' : '' %>><%= token %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-6 col-xl-4">
              <label class="form-label">Model</label>
              <input type="text" class="form-control size-md" name="modelUsed" value="<%= filters?.modelUsed || '' %>">
            </div>
            <div class="col-md-6 col-xl-6">
              <label class="form-label">Object ID</label>
              <input type="text" class="form-control size-md font-monospace" name="objectId" value="<%= filters?.objectId || '' %>">
            </div>
            <div class="col-md-6 col-xl-6">
              <label class="form-label">Request Label</label>
              <input type="text" class="form-control size-md" name="requestLabel" value="<%= filters?.requestLabel || '' %>">
            </div>
          </div>
        </div>
      </div>

      <div class="row g-3 align-items-start mt-1">
        <div class="col-12 d-flex justify-content-xl-end gap-2 pt-xl-2">
          <a href="/pte/ai-assisst/token-usage" class="btn btn-outline-secondary btn-md">Reset</a>
          <button type="submit" class="btn btn-filled btn-primary btn-md">
            <i class="bi bi-funnel me-1"></i> Apply
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div class="small text-muted">
      Matched rows: <span class="fw-bold text-dark"><%= totalMatchedRows.toLocaleString() %></span>
    </div>
    <div class="small text-muted">
      Selected users: <span class="fw-bold text-dark"><%= Number(selectedUsersCount || 0).toLocaleString() %></span>
    </div>
  </div>
</div>

<%- include('../../../../../../MVC/views/partials/tablePages-search', {
  placeholder: 'Search token usage by id, section, operation, object id, provider, model, status, or error...',
  fields: searchableFields || []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Date / User</th>
        <th>Section / Operation</th>
        <th>Provider / Model</th>
        <th>Object / Request</th>
        <th>Tokens</th>
        <th>Status</th>
        <th class="text-end pe-4">Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || data.length === 0) { %>
        <tr>
          <td colspan="7" class="text-center py-4 text-muted">No PTE AI token usage records found for the selected filters.</td>
        </tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <% const status = String(item?.status || '').trim().toLowerCase(); %>
        <% const statusClass = status === 'success' ? 'bg-success' : (status === 'failed' ? 'bg-danger' : 'bg-secondary'); %>
        <tr>
          <td class="ps-4">
            <div class="small fw-bold text-dark"><%= item?.consumedAtDisplay || '-' %></div>
            <div class="x-small text-muted"><%= item?.userLabel || item?.userId || '-' %></div>
            <div class="x-small text-muted font-monospace">Org: <%= item?.orgId || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item?.id || '-' %></div>
          </td>
          <td>
            <div class="small fw-bold text-dark"><%= item?.section || '-' %></div>
            <div class="x-small text-muted"><%= item?.operation || '-' %></div>
          </td>
          <td>
            <div class="small fw-bold text-dark text-lowercase"><%= item?.providerId || '-' %></div>
            <div class="x-small text-muted"><%= item?.modelUsed || '-' %></div>
            <div class="x-small text-muted"><%= item?.providerRecordName || '-' %></div>
          </td>
          <td>
            <div class="small font-monospace text-dark"><%= item?.objectId || '-' %></div>
            <div class="x-small text-muted"><%= item?.requestLabel || '-' %></div>
          </td>
          <td>
            <div class="x-small text-muted">Prompt: <strong><%= Number(item?.promptTokenCount || 0) %></strong></div>
            <div class="x-small text-muted">Candidates: <strong><%= Number(item?.candidatesTokenCount || 0) %></strong></div>
            <div class="x-small text-muted">Total: <strong><%= Number(item?.totalTokenCount || 0) %></strong></div>
            <div class="x-small text-muted">Cached: <strong><%= Number(item?.cachedContentTokenCount || 0) %></strong></div>
          </td>
          <td>
            <div class="mb-1">
              <span class="badge <%= statusClass %> text-capitalize"><%= status || '-' %></span>
            </div>
            <% if (item?.errorMessage) { %>
              <div class="x-small text-danger text-break"><%= item.errorMessage %></div>
            <% } else { %>
              <div class="x-small text-muted">No error</div>
            <% } %>
          </td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= item.id %>"
                title="Row actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                <a href="/pte/ai-assisst/token-usage/<%= encodeURIComponent(item.id) %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-eye me-2"></i>View Detail
                </a>
                <a href="/pte/ai-assisst/token-usage?objectId=<%= encodeURIComponent(item.objectId || '') %>" class="btn btn-outline-secondary btn-sm">
                  <i class="bi bi-funnel me-2"></i>Filter by Object
                </a>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../../../../../../MVC/views/partials/pagination', {
  pagination: pagination,
  filters: filters,
  baseUrlPath: newUrl
}) %>

<%- include('../../../../../../MVC/views/partials/tablePages-end') %>
<%- include('../../../../../../MVC/views/partials/modal_GenericPicker', { user }) %>
<%- include('../../../../../../MVC/views/partials/modal') %>

<script>
(() => {
  const form = document.getElementById('pteAiTokenUsageFilterForm');
  if (!form) return;

  const selectedUsers = <%- JSON.stringify(selectedUsers || []).replace(/</g, '\\u003c') %>;
  const selectedUsersBox = document.getElementById('aiUsageSelectedUsersBox');
  const btnPickUsers = document.getElementById('btnPickAiUsageUsers');
  const btnClearUsers = document.getElementById('btnClearAiUsageUsers');

  function initCollapseToggleIcon(options = {}) {
    const collapseEl = document.getElementById(String(options.collapseId || ''));
    const buttonEl = document.getElementById(String(options.buttonId || ''));
    const iconEl = document.getElementById(String(options.iconId || ''));
    if (!collapseEl || !buttonEl || !iconEl) return;

    const openIcon = String(options.openIcon || 'bi-chevron-down');
    const closeIcon = String(options.closeIcon || 'bi-chevron-up');

    const setState = (expanded) => {
      iconEl.classList.remove(openIcon, closeIcon);
      iconEl.classList.add(expanded ? closeIcon : openIcon);
      buttonEl.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      buttonEl.setAttribute('aria-label', expanded ? 'Close filters' : 'Open filters');
    };

    setState(collapseEl.classList.contains('show'));
    collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
    collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
  }

  initCollapseToggleIcon({
    collapseId: 'pteAiUsageFilterCollapse',
    buttonId: 'pteAiUsageFilterToggleBtn',
    iconId: 'pteAiUsageFilterToggleIcon',
    openIcon: 'bi-chevron-down',
    closeIcon: 'bi-chevron-up'
  });
  initCollapseToggleIcon({
    collapseId: 'pteAiUsageAdvancedFilterCollapse',
    buttonId: 'pteAiUsageAdvancedToggleBtn',
    iconId: 'pteAiUsageAdvancedToggleIcon',
    openIcon: 'bi-chevron-down',
    closeIcon: 'bi-chevron-up'
  });

  function esc(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function normalizeId(value) {
    return String(value || '').trim();
  }

  function renderSelectedUsers() {
    if (!selectedUsersBox) return;
    if (!selectedUsers.length) {
      selectedUsersBox.innerHTML = '<div class="text-muted">No users selected.</div>';
      return;
    }
    selectedUsersBox.innerHTML = selectedUsers.map((row, index) => {
      const id = normalizeId(row?.id);
      const label = String(row?.name || row?.username || row?.email || id).trim() || id;
      return ''
        + '<div class="d-flex align-items-center justify-content-between gap-2 border rounded bg-white px-2 py-1 mb-2">'
        + '  <div class="text-break">'
        + '    <div class="fw-bold">' + esc(label) + '</div>'
        + '    <div class="x-small text-muted font-monospace">' + esc(id) + '</div>'
        + '    <input type="hidden" name="userIds" value="' + esc(id) + '">'
        + '  </div>'
        + '  <button type="button" class="btn btn-outline-danger btn-sm ai-usage-remove-user" data-index="' + index + '">'
        + '    <i class="bi bi-x-lg"></i>'
        + '  </button>'
        + '</div>';
    }).join('');

    selectedUsersBox.querySelectorAll('.ai-usage-remove-user').forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = Number.parseInt(String(btn.getAttribute('data-index') || ''), 10);
        if (!Number.isFinite(idx) || idx < 0 || idx >= selectedUsers.length) return;
        selectedUsers.splice(idx, 1);
        renderSelectedUsers();
      });
    });
  }

  btnPickUsers?.addEventListener('click', () => {
    if (!window.GenericPicker || !window.GenericPickerPresets) return;
    const contexts = window.GenericPickerContexts || {};
    const context = (typeof contexts.activeOrganizationScope === 'function')
      ? contexts.activeOrganizationScope({ label: 'Active Organization' })
      : null;

    window.GenericPicker.open(window.GenericPickerPresets.user({
      title: 'Select Users',
      apiEndpoint: '/pte/ai-assisst/token-usage/picker/users',
      placeholder: 'Search users by name, username, email, or id...',
      multiselect: true,
      context,
      onSelect: (items) => {
        const rows = Array.isArray(items) ? items : [items];
        rows.forEach((row) => {
          const id = normalizeId(row?.id);
          if (!id) return;
          if (selectedUsers.some((userRow) => normalizeId(userRow?.id) === id)) return;
          selectedUsers.push({
            id,
            name: String(row?.name || row?.username || row?.email || id).trim(),
            username: String(row?.username || '').trim(),
            email: String(row?.email || '').trim()
          });
        });
        renderSelectedUsers();
      }
    }));
  });

  btnClearUsers?.addEventListener('click', () => {
    selectedUsers.length = 0;
    renderSelectedUsers();
  });

  form.addEventListener('submit', () => {
    renderSelectedUsers();
  });

  renderSelectedUsers();
})();
</script>
