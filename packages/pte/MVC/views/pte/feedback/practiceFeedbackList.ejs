<%
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const stateFilters = (filters && typeof filters === 'object') ? filters : {};
  const statusRowsRaw = Array.isArray(filterOptions?.statuses) && filterOptions.statuses.length
    ? filterOptions.statuses
    : (Array.isArray(filterOptions?.sessionStatuses) ? filterOptions.sessionStatuses : []);
  const skillRowsRaw = Array.isArray(filterOptions?.skills) ? filterOptions.skills : [];
  const selectedStatus = String(stateFilters?.status || '').trim().toLowerCase();
  const selectedSkill = String(stateFilters?.skill || '').trim().toLowerCase();
  const selectedWithFeedback = String(stateFilters?.withFeedback || '').trim().toLowerCase();
  const totalMatchedRows = Number(pagination?.totalItems ?? (Array.isArray(data) ? data.length : 0));
  const hasPracticeFeedbackFiltersApplied = Boolean(
    String(stateFilters?.status || '').trim()
    || String(stateFilters?.skill || '').trim()
    || String(stateFilters?.withFeedback || '').trim()
    || String(stateFilters?.startedFrom || '').trim()
    || String(stateFilters?.startedTo || '').trim()
  );
%>

<%- include('partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print: true,
  manageBtns: [
    '<a href="' + dashboardHref + '" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> PTE Dashboard</a>',
    '<a href="/pte/practice/by-skills" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-bullseye me-1"></i> Practice Runner</a>'
  ]
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
    <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter PTE Feedback On Practice</div>
    <button
      id="pteFeedbackPracticeFilterToggleBtn"
      type="button"
      class="btn btn-outline-secondary btn-sm px-2"
      data-bs-toggle="collapse"
      data-bs-target="#pteFeedbackPracticeFilterCollapse"
      aria-expanded="<%= hasPracticeFeedbackFiltersApplied ? 'true' : 'false' %>"
      aria-controls="pteFeedbackPracticeFilterCollapse"
      aria-label="<%= hasPracticeFeedbackFiltersApplied ? 'Close filters' : 'Open filters' %>">
      <i id="pteFeedbackPracticeFilterToggleIcon" class="bi <%= hasPracticeFeedbackFiltersApplied ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
    </button>
  </div>
  <div class="collapse<%= hasPracticeFeedbackFiltersApplied ? ' show' : '' %>" id="pteFeedbackPracticeFilterCollapse">
    <form method="GET" action="/pte/feedback/practice" id="ptePracticeFeedbackFilterForm" class="card-body p-3">
      <% if (stateFilters?.q) { %><input type="hidden" name="q" value="<%= stateFilters.q %>"><% } %>
      <% if (stateFilters?.type) { %><input type="hidden" name="type" value="<%= stateFilters.type %>"><% } %>
      <% if (stateFilters?.searchFields) { %><input type="hidden" name="searchFields" value="<%= stateFilters.searchFields %>"><% } %>

      <div class="row g-3 align-items-end">
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Status</label>
          <select class="form-select size-md" name="status">
            <option value="">All Statuses</option>
            <% statusRowsRaw.forEach((row) => { %>
              <% const value = String(row?.value || row || '').trim().toLowerCase(); %>
              <% const label = String(row?.label || value || '').trim(); %>
              <option value="<%= value %>" <%= value === selectedStatus ? 'selected' : '' %>><%= label || value %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Skill</label>
          <select class="form-select size-md" name="skill">
            <option value="">All Skills</option>
            <% skillRowsRaw.forEach((row) => { %>
              <% const value = String(row?.value || row || '').trim().toLowerCase(); %>
              <% const label = String(row?.label || value || '').trim(); %>
              <option value="<%= value %>" <%= value === selectedSkill ? 'selected' : '' %>><%= label || value %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">With Feedback</label>
          <select class="form-select size-md" name="withFeedback">
            <option value="" <%= !selectedWithFeedback ? 'selected' : '' %>>All</option>
            <option value="yes" <%= selectedWithFeedback === 'yes' ? 'selected' : '' %>>Yes</option>
            <option value="no" <%= selectedWithFeedback === 'no' ? 'selected' : '' %>>No</option>
          </select>
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Started From</label>
          <input type="date" class="form-control size-md" name="startedFrom" value="<%= stateFilters?.startedFrom || '' %>">
        </div>
      </div>

      <div class="row g-3 mt-1 align-items-end">
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Started To</label>
          <input type="date" class="form-control size-md" name="startedTo" value="<%= stateFilters?.startedTo || '' %>">
        </div>
        <div class="col-md-6 col-xl-9 d-flex justify-content-xl-end gap-2 pt-xl-4">
          <a href="/pte/feedback/practice" class="btn btn-outline-secondary btn-md">Reset</a>
          <button type="submit" class="btn btn-filled btn-primary btn-md">
            <i class="bi bi-funnel me-1"></i> Apply
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div class="small text-muted">
      Matched rows: <span class="fw-bold text-dark"><%= totalMatchedRows.toLocaleString() %></span>
    </div>
    <div class="small text-muted">
      Showing page: <span class="fw-bold text-dark"><%= Number(pagination?.currentPage || 1) %> / <%= Number(pagination?.totalPages || 1) %></span>
    </div>
  </div>
</div>

<%- include('partials/tablePages-search', {
  placeholder: 'Search sessions by id, student, status, or skill...',
  fields: searchableFields || []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Session</th>
        <th>Student</th>
        <th>Status / Skill</th>
        <th>Question Progress</th>
        <th>Timeline</th>
        <th class="text-end pe-4">Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || data.length === 0) { %>
        <tr>
          <td colspan="6" class="text-center py-4 text-muted">No started skill-practice sessions found for the selected filters.</td>
        </tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <% const status = String(item.status || '').toLowerCase(); %>
        <% const statusClass = status === 'finished' ? 'bg-success' : (status === 'in_progress' ? 'bg-primary' : (status === 'submitted' ? 'bg-info text-dark' : 'bg-secondary')); %>
        <% const feedbackCount = Number(item.feedbackCount || 0); %>
        <% const totalQuestions = Number(item.totalQuestions || 0); %>
        <% const submittedQuestions = Number(item.submittedQuestions || 0); %>
        <tr>
          <td class="ps-4">
            <% if (item.practiceName) { %>
              <div class="small fw-bold text-dark"><%= item.practiceName %></div>
            <% } %>
            <div class="x-small text-muted font-monospace mt-1"><%= item.id || '-' %></div>
            <div class="x-small text-muted font-monospace">Org: <%= item.orgId || '-' %></div>
          </td>
          <td>
            <div class="small fw-bold text-dark"><%= item.userLabel || item.userId || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.userId || '-' %></div>
          </td>
          <td>
            <div class="x-small mb-1">
              <span class="badge <%= statusClass %> text-capitalize"><%= status || '-' %></span>
            </div>
            <div class="small text-capitalize"><%= item.practiceSkill || '-' %></div>
          </td>
          <td>
            <div class="small"><strong><%= submittedQuestions %></strong> / <%= totalQuestions %> submitted</div>
            <div class="x-small text-muted">Feedback on <%= feedbackCount %> question(s)</div>
          </td>
          <td>
            <div class="x-small text-muted">Started</div>
            <div class="small"><%= item.startedAtDisplay || '-' %></div>
            <div class="x-small text-muted mt-1">Finished</div>
            <div class="small"><%= item.finishedAtDisplay || '-' %></div>
          </td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= item.id %>"
                title="Row actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                <a href="/pte/feedback/practice/<%= encodeURIComponent(item.id) %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-eye me-2"></i>View Feedback
                </a>
                <% if (canCreateFeedback) { %>
                  <a href="/pte/feedback/practice/<%= encodeURIComponent(item.id) %>/edit" class="btn btn-outline-success btn-sm">
                    <i class="bi bi-chat-left-text me-2"></i>Feedback
                  </a>
                <% } %>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/pagination', {
  pagination: pagination,
  filters: filters,
  baseUrlPath: newUrl
}) %>

<%- include('partials/tablePages-end') %>

<script>
(() => {
  function initCollapseToggleIcon(options = {}) {
    const collapseEl = document.getElementById(String(options.collapseId || ''));
    const buttonEl = document.getElementById(String(options.buttonId || ''));
    const iconEl = document.getElementById(String(options.iconId || ''));
    if (!collapseEl || !buttonEl || !iconEl) return;

    const openIcon = String(options.openIcon || 'bi-chevron-down');
    const closeIcon = String(options.closeIcon || 'bi-chevron-up');
    const openLabel = String(options.openLabel || 'Open filters');
    const closeLabel = String(options.closeLabel || 'Close filters');

    const setState = (expanded) => {
      iconEl.classList.remove(openIcon, closeIcon);
      iconEl.classList.add(expanded ? closeIcon : openIcon);
      buttonEl.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      buttonEl.setAttribute('aria-label', expanded ? closeLabel : openLabel);
    };

    setState(collapseEl.classList.contains('show'));
    collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
    collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
  }

  initCollapseToggleIcon({
    collapseId: 'pteFeedbackPracticeFilterCollapse',
    buttonId: 'pteFeedbackPracticeFilterToggleBtn',
    iconId: 'pteFeedbackPracticeFilterToggleIcon',
    openIcon: 'bi-chevron-down',
    closeIcon: 'bi-chevron-up',
    openLabel: 'Open filters',
    closeLabel: 'Close filters'
  });
})();
</script>
