  function resolveAiAssistTranscriptionSummary(rawMeta, questionTypeKey) {
    const meta = (rawMeta && typeof rawMeta === 'object') ? rawMeta : {};
    const status = cleanText(meta.status).toLowerCase();
    const normalizedType = cleanText(questionTypeKey).toLowerCase();
    const supportedTypes = new Set([
      'listening_mcq_single',
      'listening_select_missing_word',
      'listening_mcq_multiple',
      'listening_fill_in_blank',
      'listening_highlight_incorrect_words',
      'listening_dictation',
      'listening_summarize_spoken_text'
    ]);
    const supportsTranscriptionMeta = supportedTypes.has(normalizedType);
    if (!supportsTranscriptionMeta && !status) return null;

    let wholeFileLabel = 'N/A';
    let toneClass = 'text-secondary';
    if (status === 'full') {
      wholeFileLabel = 'Yes';
      toneClass = 'text-success';
    } else if (status === 'possibly_partial') {
      wholeFileLabel = 'No (may be partial)';
      toneClass = 'text-warning';
    } else if (status === 'failed') {
      wholeFileLabel = 'No';
      toneClass = 'text-danger';
    } else if (status === 'not_attempted' || status === 'not_applicable') {
      wholeFileLabel = 'N/A';
      toneClass = 'text-secondary';
    } else if (typeof meta.wholeFile === 'boolean') {
      wholeFileLabel = meta.wholeFile ? 'Yes' : 'No';
      toneClass = meta.wholeFile ? 'text-success' : 'text-warning';
    } else if (supportsTranscriptionMeta) {
      wholeFileLabel = 'Unknown';
      toneClass = 'text-warning';
    }

    return {
      wholeFileLabel,
      toneClass,
      message: cleanText(meta.message)
    };
  }

