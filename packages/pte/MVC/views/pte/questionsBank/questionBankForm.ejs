    const previousType = cleanText(questionTypeSelect.value);
    const rows = (Array.isArray(typeRegistry) ? typeRegistry : [])
      .filter((row) => {
        if (!selectedTestType) return false;
        if (selectedSkill && String(row.skill || '').toLowerCase() !== selectedSkill) return false;
        const typeTestTypes = Array.isArray(row.testTypes)
          ? row.testTypes.map((item) => cleanText(item).toLowerCase()).filter(Boolean)
          : [];
        return !typeTestTypes.length || typeTestTypes.includes(selectedTestType);
      });

    questionTypeSelect.innerHTML = '<option value="">-- Select Question Type --</option>'
      + rows.map((row) => {
        const key = cleanText(row.key);
        const selected = key && key === previousType ? 'selected' : '';
        return '<option value="' + esc(key) + '" ' + selected + '>' + esc(row.label || key) + '</option>';
      }).join('');

    if (previousType && !rows.some((row) => cleanText(row.key) === previousType)) {
      questionTypeSelect.value = '';
