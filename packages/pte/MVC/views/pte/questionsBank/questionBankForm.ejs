  function normalizeMcqCorrectOptionKeys(mode = 'single', rawValue = '') {
    const normalizedMode = cleanText(mode).toLowerCase() === 'multiple' ? 'multiple' : 'single';
    if (normalizedMode === 'single') {
      if (Array.isArray(rawValue)) {
        const first = cleanText(rawValue[0]);
        return new Set(first ? [first] : []);
      }
      const token = cleanText(rawValue);
      return new Set(token ? [token] : []);
    }

    const out = [];
    const seen = new Set();
    const tokens = Array.isArray(rawValue)
      ? rawValue
      : String(rawValue == null ? '' : rawValue).split(/[\r\n,]+/);
    tokens.forEach((item) => {
      const token = cleanText(item);
      if (!token) return;
      const lowered = token.toLowerCase();
      if (seen.has(lowered)) return;
      seen.add(lowered);
      out.push(token);
    });
    return new Set(out);
  }

  function formatMcqCorrectOptionKeysForInput(mode = 'single', values = []) {
    const normalizedMode = cleanText(mode).toLowerCase() === 'multiple' ? 'multiple' : 'single';
    const keys = Array.from(normalizeMcqCorrectOptionKeys(normalizedMode, values));
    if (normalizedMode === 'multiple') return keys.join('\n');
    return keys[0] || '';
  }

  function normalizeMcqSingleOptionRows(rawOptions) {
    const rows = Array.isArray(rawOptions) ? rawOptions : [];
