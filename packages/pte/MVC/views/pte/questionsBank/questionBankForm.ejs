  function orderFieldsForDisplay(typeDef, fields = [], scope = 'payload') {
    const typeKey = cleanText(typeDef?.key).toLowerCase();
    const source = Array.isArray(fields) ? fields.slice() : [];
    if (scope === 'payload' && typeKey === 'listening_mcq_multiple') {
      const weight = Object.freeze({
        transcript: 10,
        explanation: 20,
        partialcreditenabled: 30,
        allowreplay: 40
      });
      return source.sort((left, right) => {
        const leftKey = cleanText(left?.key).toLowerCase();
        const rightKey = cleanText(right?.key).toLowerCase();
        const leftOrder = Object.prototype.hasOwnProperty.call(weight, leftKey) ? weight[leftKey] : 999;
        const rightOrder = Object.prototype.hasOwnProperty.call(weight, rightKey) ? weight[rightKey] : 999;
        return leftOrder - rightOrder;
      });
    }
    return source;
  }

