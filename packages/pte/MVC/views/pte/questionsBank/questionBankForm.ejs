  function appendActionState(url, tokenOverride = '') {
    const base = String(url || '').trim();
    const token = cleanText(tokenOverride) || actionStateId;
    if (!base || !token) return base;
    try {
      const parsed = new URL(base, window.location.origin);
      parsed.searchParams.set('actionStateId', token);
      return parsed.toString();
    } catch (_) {
      // Fall back to simple append if URL parsing is unavailable.
    }
    if (/[?&]actionStateId=/.test(base)) {
      return base.replace(/([?&]actionStateId=)[^&#]*/i, '$1' + encodeURIComponent(token));
    }
    return base + (base.includes('?') ? '&' : '?') + 'actionStateId=' + encodeURIComponent(token);
  }

  async function issueFormActionState(operation = 'update') {
    const operationToken = cleanText(operation || 'update').toLowerCase() || 'update';
    const targetId = isEdit ? cleanText(routeId) : '';
    const endpoint = '/pte/questions-bank/mutation-token/' + encodeURIComponent(operationToken)
      + (targetId ? ('/' + encodeURIComponent(targetId)) : '');
    const response = await fetch(endpoint, {
      method: 'POST',
      headers: {
        'X-AJAX-Request': 'true',
        'Accept': 'application/json',
        'X-Action-State-Id': ''
      },
      credentials: 'include'
    });
    const result = await response.json().catch(() => null);
    if (!response.ok || !result || result.status !== 'success') {
      throw new Error((result && result.message) || 'Unable to verify this action. Please refresh and try again.');
    }
    const token = cleanText(result?.results?.actionStateId || '');
    if (!token) throw new Error('Unable to verify this action. Please refresh and try again.');
    return token;
  }

  function appendFormActionTarget(url, body = null) {
    const base = String(url || '').trim();
    const targetId = isEdit ? cleanText(routeId) : '';
    if (!targetId) return base;
    if (body && typeof body.set === 'function') body.set('id', targetId);
    return base + (base.includes('?') ? '&' : '?') + 'id=' + encodeURIComponent(targetId);
  }

  function updateScoringProfileVersionLabel() {
    if (!scoringProfileVersionNode) return;
    scoringProfileVersionNode.textContent = String(Number(state.scoringProfileVersion || 1) || 1);
  }

  function updateScoringModeHint() {
    if (!scoringModeHintNode) return;
    if (state.useQuestionScoringOverride) {
      scoringModeHintNode.textContent = 'Question-level scoring override is ON. Changes in this tab apply only to this question.';
      return;
    }
    scoringModeHintNode.innerHTML = 'Question-level scoring override is OFF. This question uses latest global defaults for this question type. '
      + '<a href="/pte/scoring/defaults" target="_blank" rel="noopener">Manage global values</a>.';
  }

  function getScoringProfileKey() {
    const testType = cleanText(testTypeSelect ? testTypeSelect.value : '').toLowerCase();
    const questionType = cleanText(questionTypeSelect ? questionTypeSelect.value : '').toLowerCase();
    if (!testType || !questionType) return '';
    return `${testType}::${questionType}`;
  }

  async function loadGlobalScoringProfile(options = {}) {
    const profileKey = getScoringProfileKey();
    if (!profileKey) return;
    const force = options?.force === true;
    if (!force && profileKey === state.lastScoringGlobalKey) return;

    const [testType, questionType] = profileKey.split('::');
    const endpoint = appendActionState('/pte/questions-bank/scoring/profile'
      + '?testType=' + encodeURIComponent(testType)
      + '&questionType=' + encodeURIComponent(questionType));
    try {
      const response = await fetch(endpoint, {
        method: 'GET',
        headers: {
          'X-AJAX-Request': 'true',
          Accept: 'application/json'
        },
        credentials: 'include'
      });
      const result = await response.json().catch(() => null);
      if (!response.ok || !result || result.status !== 'success') {
        throw new Error((result && result.message) || ('Unable to load scoring profile (status ' + response.status + ').'));
      }
      const profile = result.results && typeof result.results === 'object' ? result.results : {};
      state.scoringGlobal = profile.scoringConfig && typeof profile.scoringConfig === 'object'
        ? JSON.parse(JSON.stringify(profile.scoringConfig))
        : {};
      state.scoringProfileVersion = Number(profile.profileVersion || state.scoringProfileVersion || 1) || 1;
      state.lastScoringGlobalKey = profileKey;
      updateScoringProfileVersionLabel();
    } catch (error) {
      if (options?.notifyOnError === true) {
        await showModal('Scoring Defaults', error.message || 'Unable to load scoring defaults for this type.', 'warning');
      }
    }
  }

  function renderCopyQuestionItem(item) {
    const statusToken = cleanText(item?.status).toLowerCase();
    const statusClass = statusToken === 'published'
      ? 'bg-success'
      : (statusToken === 'draft' ? 'bg-primary' : 'bg-light text-dark border');
    return ''
      + '<div class="d-flex justify-content-between align-items-start gap-2">'
      + '  <div class="overflow-hidden">'
      + '    <div class="fw-bold text-dark text-truncate">' + esc(item?.title || '-') + '</div>'
      + '    <div class="x-small text-muted">Code: <span class="font-monospace">' + esc(item?.code || '-') + '</span></div>'
      + '    <div class="x-small text-muted font-monospace">' + esc(item?.id || '-') + '</div>'
      + '  </div>'
      + '  <div class="text-end flex-shrink-0">'
      + '    <div><span class="badge ' + statusClass + ' text-capitalize">' + esc(statusToken || '-') + '</span></div>'
      + '    <div class="x-small text-muted mt-1">' + esc(item?.questionType || '-') + '</div>'
      + '  </div>'
      + '</div>';
  }

  function cacheButtonHtml(button) {
    if (!button) return;
    if (!button.dataset.defaultHtml) button.dataset.defaultHtml = button.innerHTML;
  }

  function setButtonBusy(button, label) {
    if (!button) return;
    cacheButtonHtml(button);
    button.disabled = true;
    button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + esc(label);
  }

  function restoreButton(button) {
    if (!button) return;
    if (button.dataset.defaultHtml) button.innerHTML = button.dataset.defaultHtml;
    button.disabled = false;
  }

  function clearNewFileObjectUrls() {
    newFileObjectUrls.forEach((url) => {
      try { window.URL.revokeObjectURL(url); } catch (_) {}
    });
    newFileObjectUrls = [];
    state.stagedMediaAssets = [];
  }

  function formatBytes(bytes) {
    const value = Number(bytes || 0);
    if (!Number.isFinite(value) || value <= 0) return '0 B';
    const units = ['B', 'KB', 'MB', 'GB'];
    let size = value;
    let idx = 0;
    while (size >= 1024 && idx < units.length - 1) {
      size /= 1024;
      idx += 1;
    }
    return size.toFixed(idx === 0 ? 0 : 2) + ' ' + units[idx];
  }

  function formatDateTime(iso) {
    const token = cleanText(iso);
    if (!token) return '-';
    const parsed = new Date(token);
    if (Number.isNaN(parsed.getTime())) return '-';
    return parsed.toLocaleString();
  }

  function deepClone(value, fallback = null) {
    try {
      if (value === undefined) return fallback;
      return JSON.parse(JSON.stringify(value));
    } catch (_) {
      return fallback;
    }
  }

  function getSelectedTypeDef() {
    const raw = typeMap.get(String(questionTypeSelect.value || '').trim()) || null;
    if (!raw || typeof raw !== 'object') return null;
    const typeDef = deepClone(raw, {});
    const typeKey = cleanText(typeDef.key).toLowerCase();
    if (typeKey === 'speaking_answer_short_question') {
      const optionalFields = Array.isArray(typeDef.optionalFields) ? typeDef.optionalFields : [];
      const hasTranscriptOptional = optionalFields.some((field) => cleanText(field?.key).toLowerCase() === 'transcript');
      if (!hasTranscriptOptional) {
        optionalFields.unshift({
          key: 'transcript',
          label: 'Prompt Transcript',
          input: 'textarea',
          required: false,
          max: 5000,
          default: '',
          helper: 'Optional transcript for practice mode and review.'
        });
      }
      typeDef.optionalFields = optionalFields;

      const payloadFields = Array.isArray(typeDef.payloadFields) ? typeDef.payloadFields.slice() : [];
      const hasTranscriptPayload = payloadFields.some((fieldKey) => cleanText(fieldKey).toLowerCase() === 'transcript');
      if (!hasTranscriptPayload) {
        const promptIndex = payloadFields.findIndex((fieldKey) => cleanText(fieldKey).toLowerCase() === 'prompttextoraudio');
        if (promptIndex >= 0) payloadFields.splice(promptIndex + 1, 0, 'transcript');
        else payloadFields.unshift('transcript');
      }
      typeDef.payloadFields = payloadFields;
    }
    return typeDef;
  }

  function toArray(value) {
    return Array.isArray(value) ? value : [];
  }

  function toInt(value, fallback = 0) {
    const numeric = Number.parseInt(String(value || ''), 10);
    if (!Number.isFinite(numeric) || Number.isNaN(numeric)) return fallback;
    return numeric;
  }

  function toFloat(value, fallback = 0) {
    const numeric = Number(value);
    if (!Number.isFinite(numeric) || Number.isNaN(numeric)) return fallback;
    return Number(numeric.toFixed(6));
  }

  function textList(value) {
    if (Array.isArray(value)) return value.map((item) => cleanText(item)).filter(Boolean);
    const token = cleanText(value);
    return token ? [token] : [];
  }

  function nl2brEsc(value) {
    return esc(String(value || '')).replace(/\r?\n/g, '<br>');
  }

  function renderTextWithBlankSlots(value) {
    const text = String(value || '');
    if (!text) return '<span class="text-muted">-</span>';
    return text
      .split(/(\{\{[^}]+\}\})/g)
      .map((part) => {
        if (/^\{\{[^}]+\}\}$/.test(part)) {
          return '<span class="d-inline-block px-2 py-0 border-bottom border-2 border-primary-subtle mx-1">_____</span>';
        }
        return esc(part);
      })
      .join('')
      .replace(/\r?\n/g, '<br>');
  }

  function renderMissingWordGapPrompt(value) {
    const text = String(value || '');
    if (!text) return '<span class="text-muted">-</span>';
    return text
      .split(/(\{\{[^}]+\}\}|\[\s*blank\s*\]|_{3,}|\.{3,})/ig)
      .map((part) => {
        if (/^(\{\{[^}]+\}\}|\[\s*blank\s*\]|_{3,}|\.{3,})$/i.test(part)) {
          return '<span class="d-inline-block px-2 py-0 border-bottom border-2 border-primary mx-1">_____</span>';
        }
        return esc(part);
      })
      .join('')
      .replace(/\r?\n/g, '<br>');
  }

  function isListeningFillInBlankType(typeDef = null) {
    return cleanText(typeDef?.key).toLowerCase() === 'listening_fill_in_blank';
  }

  function isReadingFillInBlankType(typeDef = null) {
    const key = cleanText(typeDef?.key).toLowerCase();
    return key === 'reading_fill_in_blank' || key === 'reading_writing_fill_in_blank';
  }

  function isReadingWritingFillInBlankType(typeDef = null) {
    return cleanText(typeDef?.key).toLowerCase() === 'reading_writing_fill_in_blank';
  }

  function isFillInBlankType(typeDef = null) {
    return isListeningFillInBlankType(typeDef) || isReadingFillInBlankType(typeDef);
  }

  function isListeningHighlightIncorrectWordsType(typeDef = null) {
    return cleanText(typeDef?.key).toLowerCase() === 'listening_highlight_incorrect_words';
  }

  function tokenizeHighlightIncorrectWords(text = '') {
    const source = String(text || '');
    const regex = /[A-Za-z0-9]+(?:[-'’][A-Za-z0-9]+)*/g;
    const out = [];
    let match = null;
    while ((match = regex.exec(source)) !== null) {
      const raw = cleanText(match[0]);
      if (!raw) continue;
      out.push({
        raw,
        norm: raw.toLowerCase()
      });
    }
    return out;
  }

  function extractHighlightIncorrectWords(sourceTranscript = '', displayTranscript = '') {
    const sourceWords = tokenizeHighlightIncorrectWords(sourceTranscript);
    const displayWords = tokenizeHighlightIncorrectWords(displayTranscript);
    const out = [];
    const seen = new Set();

    if (!sourceWords.length || !displayWords.length) return out;

    let i = 0;
    let j = 0;
    while (i < sourceWords.length || j < displayWords.length) {
      const sourceWord = sourceWords[i] || null;
      const displayWord = displayWords[j] || null;
      if (!sourceWord && !displayWord) break;

      if (sourceWord && displayWord && sourceWord.norm === displayWord.norm) {
        i += 1;
        j += 1;
        continue;
      }

      const nextSource = sourceWords[i + 1] || null;
      if (sourceWord && displayWord && nextSource && nextSource.norm === displayWord.norm) {
        i += 1;
        continue;
      }

      const nextDisplay = displayWords[j + 1] || null;
      if (sourceWord && displayWord && nextDisplay && sourceWord.norm === nextDisplay.norm) {
        if (!seen.has(displayWord.norm)) {
          out.push(displayWord.raw);
          seen.add(displayWord.norm);
        }
        j += 1;
        continue;
      }

      if (displayWord && !seen.has(displayWord.norm)) {
        out.push(displayWord.raw);
        seen.add(displayWord.norm);
      }
      if (sourceWord) i += 1;
      if (displayWord) j += 1;
    }

    return out;
  }

  function normalizeListeningBlankToken(rawToken = '', fallbackIndex = 1) {
    const token = String(rawToken || '');
    const fallback = Math.max(1, Number.parseInt(String(fallbackIndex), 10) || 1);
    const match = token.match(/\{\{\s*(\d+)\s*\}\}/) || token.match(/(\d+)/);
    const numeric = match
      ? Math.max(1, Number.parseInt(String(match[1]), 10) || fallback)
      : fallback;
    return '{{' + numeric + '}}';
  }

  function extractListeningBlankTokensInOrder(text = '') {
    const source = String(text || '');
    const regex = /\{\{\s*(\d+)\s*\}\}/g;
    const out = [];
    const seen = new Set();
    let match = null;
    while ((match = regex.exec(source)) !== null) {
      const token = '{{' + Math.max(1, Number.parseInt(String(match[1]), 10) || 1) + '}}';
      const dedupe = token.toLowerCase();
      if (seen.has(dedupe)) continue;
      seen.add(dedupe);
      out.push(token);
    }
    return out;
  }

  function parseListeningBlankAnswerMapJson(rawText = '') {
    const token = String(rawText || '').trim();
    if (!token) return {};
    let parsed = null;
    try {
      parsed = JSON.parse(token);
    } catch (_) {
      throw new Error('Blank Answer Map JSON is invalid.');
    }
    if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {
      throw new Error('Blank Answer Map JSON must be an object.');
    }
    const out = {};
    Object.keys(parsed).forEach((rawKey, index) => {
      const normalizedKey = normalizeListeningBlankToken(rawKey, index + 1);
      const answer = String(parsed[rawKey] == null ? '' : parsed[rawKey]).trim();
      if (!answer) return;
      out[normalizedKey] = answer;
    });
    return out;
  }

  function escapeRegexLiteral(value = '') {
    return String(value || '').replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
  }

  function buildListeningBlankSequentialState(transcriptValue = '', blankMapValue = {}) {
    const transcript = String(transcriptValue || '');
    const sourceMap = (blankMapValue && typeof blankMapValue === 'object' && !Array.isArray(blankMapValue))
      ? blankMapValue
      : {};
    const placeholders = extractListeningBlankTokensInOrder(transcript);
    if (!placeholders.length) {
      return {
        transcriptWithBlanks: transcript,
        blankAnswerMap: {}
      };
    }

    const tokenMap = new Map();
    const normalizedMap = {};
    placeholders.forEach((token, index) => {
      const nextToken = '{{' + (index + 1) + '}}';
      tokenMap.set(token, nextToken);
      const answer = String(sourceMap[token] == null ? '' : sourceMap[token]).trim();
      if (answer) normalizedMap[nextToken] = answer;
    });
    const normalizedTranscript = transcript.replace(/\{\{\s*(\d+)\s*\}\}/g, (_, rawIndex) => {
      const numeric = Math.max(1, Number.parseInt(String(rawIndex), 10) || 1);
      const normalizedToken = '{{' + numeric + '}}';
      return tokenMap.get(normalizedToken) || normalizedToken;
    });
    return {
      transcriptWithBlanks: normalizedTranscript,
      blankAnswerMap: normalizedMap
    };
  }

  function getFillBlankEditorNodes() {
    const typeDef = getSelectedTypeDef();
    if (!isFillInBlankType(typeDef)) return null;
    const isReadingType = isReadingFillInBlankType(typeDef);
    const editedFieldKey = isReadingType ? 'passageWithBlanks' : 'transcriptWithBlanks';
    const sourceFieldKey = isReadingType ? 'sourcePassage' : 'sourceTranscript';
    const editedNode = form.querySelector('[data-field-scope="payload"][data-field-key="' + editedFieldKey + '"]');
    const blankMapNode = form.querySelector('[data-field-scope="payload"][data-field-key="blankAnswerMap"]');
    if (!editedNode || !blankMapNode) return null;
    const sourceNode = form.querySelector('[data-field-scope="payload"][data-field-key="' + sourceFieldKey + '"]');
    const summaryNode = cleanText(blankMapNode.id)
      ? form.querySelector('[data-fill-blank-summary-for="' + cleanText(blankMapNode.id) + '"]')
      : null;
    return {
      typeKey: cleanText(typeDef?.key).toLowerCase(),
      editedNode,
      blankMapNode,
      sourceNode,
      summaryNode,
      editedLabel: isReadingType ? 'Passage With Blanks' : 'Transcript With Blanks',
      actionLabel: isReadingType ? 'Mark as Blank' : 'Create Blank From Selection',
      sourceLabel: isReadingType ? 'Original Passage (Untouched)' : 'Source Transcript'
    };
  }

  function resolveLineAndColumn(text = '', index = 0) {
    const boundedIndex = Math.max(0, Math.min(String(text || '').length, Number(index) || 0));
    const prefix = String(text || '').slice(0, boundedIndex);
    const lines = prefix.split(/\r?\n/);
    const line = Math.max(1, lines.length);
    const column = Math.max(1, String(lines[lines.length - 1] || '').length + 1);
    return { line, column };
  }

  function buildFillBlankTokenRows(editedText = '', blankMap = {}) {
    const out = [];
    const text = String(editedText || '');
    const sourceMap = (blankMap && typeof blankMap === 'object' && !Array.isArray(blankMap)) ? blankMap : {};
    const regex = /\{\{\s*(\d+)\s*\}\}/g;
    const seen = new Set();
    let match = null;
    while ((match = regex.exec(text)) !== null) {
      const token = '{{' + Math.max(1, Number.parseInt(String(match[1]), 10) || 1) + '}}';
      if (seen.has(token)) continue;
      seen.add(token);
      const position = resolveLineAndColumn(text, match.index);
      out.push({
        token,
        answer: String(sourceMap[token] == null ? '' : sourceMap[token]).trim(),
        line: position.line,
        column: position.column
      });
    }
    return out;
  }

  function refreshFillBlankSummary(nodes = null) {
    const editorNodes = nodes || getFillBlankEditorNodes();
    if (!editorNodes || !editorNodes.summaryNode) return;
    const summaryNode = editorNodes.summaryNode;
    let parsedMap = {};
    let mapError = '';
    try {
      parsedMap = parseListeningBlankAnswerMapJson(editorNodes.blankMapNode.value);
    } catch (error) {
      mapError = cleanText(error?.message || 'Blank Answer Map JSON is invalid.');
    }

    const normalized = buildListeningBlankSequentialState(editorNodes.editedNode.value, parsedMap);
    const rows = buildFillBlankTokenRows(normalized.transcriptWithBlanks, normalized.blankAnswerMap);
    if (mapError) {
      summaryNode.classList.remove('d-none');
      summaryNode.classList.add('border-danger-subtle', 'bg-danger-subtle');
      summaryNode.classList.remove('border-success-subtle', 'bg-success-subtle');
      summaryNode.textContent = mapError;
      return;
    }
    summaryNode.classList.remove('border-danger-subtle', 'bg-danger-subtle');
    summaryNode.classList.add('border-success-subtle', 'bg-success-subtle');
    if (!rows.length) {
      summaryNode.classList.add('d-none');
      summaryNode.textContent = '';
      return;
    }
    summaryNode.classList.remove('d-none');
    summaryNode.innerHTML = rows
      .map((row, index) => {
        const answer = row.answer || '(missing answer)';
        return '<div class="small mb-1">'
          + '<span class="fw-semibold me-1">#' + (index + 1) + '</span>'
          + '<span class="font-monospace me-1">' + esc(row.token) + '</span>'
          + '<span class="text-muted me-1">at L' + row.line + ':C' + row.column + '</span>'
          + '<span>' + esc(answer) + '</span>'
          + '</div>';
      })
      .join('');
  }

  function getHighlightIncorrectWordsEditorNodes() {
    const typeDef = getSelectedTypeDef();
    if (!isListeningHighlightIncorrectWordsType(typeDef)) return null;
    const sourceTranscriptNode = form.querySelector('[data-field-scope="payload"][data-field-key="transcript"]');
    const displayTranscriptNode = form.querySelector('[data-field-scope="payload"][data-field-key="transcriptText"]');
    const incorrectWordsNode = form.querySelector('[data-field-scope="payload"][data-field-key="incorrectWords"]');
    if (!sourceTranscriptNode || !displayTranscriptNode || !incorrectWordsNode) return null;
    return {
      sourceTranscriptNode,
      displayTranscriptNode,
      incorrectWordsNode
    };
  }

  async function applyFillBlankFromSelection() {
    const nodes = getFillBlankEditorNodes();
    if (!nodes) return;
    const transcriptNode = nodes.editedNode;
    const blankMapNode = nodes.blankMapNode;
    if (transcriptNode.disabled || blankMapNode.disabled) return;

    const selectionStart = Number(transcriptNode.selectionStart);
    const selectionEnd = Number(transcriptNode.selectionEnd);
    if (!Number.isFinite(selectionStart) || !Number.isFinite(selectionEnd) || selectionEnd <= selectionStart) {
      await showModal('Fill in the Blanks', 'Select one or more words in ' + nodes.editedLabel + ' first, then click "' + nodes.actionLabel + '".', 'warning');
      return;
    }

    const selectedRaw = String(transcriptNode.value || '').slice(selectionStart, selectionEnd);
    const leadingWhitespaceMatch = selectedRaw.match(/^\s*/);
    const trailingWhitespaceMatch = selectedRaw.match(/\s*$/);
    const leadingWhitespace = leadingWhitespaceMatch ? leadingWhitespaceMatch[0] : '';
    const trailingWhitespace = trailingWhitespaceMatch ? trailingWhitespaceMatch[0] : '';
    const selectedCore = selectedRaw.slice(
      leadingWhitespace.length,
      Math.max(leadingWhitespace.length, selectedRaw.length - trailingWhitespace.length)
    );
    const selectedText = selectedCore.trim();
    if (!selectedText) {
      await showModal('Fill in the Blanks', 'Selected text is empty. Select visible words or phrase(s) first.', 'warning');
      return;
    }
    if (/\{\{\s*\d+\s*\}\}/.test(selectedText)) {
      const isReadingMode = nodes.typeKey === 'reading_fill_in_blank' || nodes.typeKey === 'reading_writing_fill_in_blank';
      const plainWordLabel = isReadingMode ? 'passage' : 'transcript';
      await showModal('Fill in the Blanks', 'Selection already contains placeholder token(s). Select plain ' + plainWordLabel + ' words instead.', 'warning');
      return;
    }

    let blankMap = {};
    try {
      blankMap = parseListeningBlankAnswerMapJson(blankMapNode.value);
    } catch (error) {
      await showModal('Fill in the Blanks', error.message || 'Blank Answer Map JSON is invalid.', 'error');
      return;
    }

    const currentTranscript = String(transcriptNode.value || '');
    const existingTokens = extractListeningBlankTokensInOrder(currentTranscript);
    const maxToken = existingTokens.reduce((max, token) => {
      const numeric = Number.parseInt((String(token).match(/\d+/) || [0])[0], 10) || 0;
      return Math.max(max, numeric);
    }, 0);
    const provisionalToken = '{{' + (maxToken + 1000) + '}}';

    const replacementToken = leadingWhitespace + provisionalToken + trailingWhitespace;
    const nextTranscript = currentTranscript.slice(0, selectionStart)
      + replacementToken
      + currentTranscript.slice(selectionEnd);
    blankMap[provisionalToken] = selectedText;

    const normalized = buildListeningBlankSequentialState(nextTranscript, blankMap);
    transcriptNode.value = normalized.transcriptWithBlanks;
    blankMapNode.value = JSON.stringify(normalized.blankAnswerMap, null, 2);
    refreshFillBlankSummary(nodes);

    transcriptNode.dispatchEvent(new Event('input', { bubbles: true }));
    blankMapNode.dispatchEvent(new Event('input', { bubbles: true }));
  }

  async function syncFillBlankMapFromEditedPassage() {
    const nodes = getFillBlankEditorNodes();
    if (!nodes) return;
    const transcriptNode = nodes.editedNode;
    const blankMapNode = nodes.blankMapNode;
    if (transcriptNode.disabled || blankMapNode.disabled) return;

    let blankMap = {};
    try {
      blankMap = parseListeningBlankAnswerMapJson(blankMapNode.value);
    } catch (error) {
      await showModal('Fill in the Blanks', error.message || 'Blank Answer Map JSON is invalid.', 'error');
      return;
    }

    const normalized = buildListeningBlankSequentialState(transcriptNode.value, blankMap);
    transcriptNode.value = normalized.transcriptWithBlanks;
    blankMapNode.value = JSON.stringify(normalized.blankAnswerMap, null, 2);
    refreshFillBlankSummary(nodes);

    transcriptNode.dispatchEvent(new Event('input', { bubbles: true }));
    blankMapNode.dispatchEvent(new Event('input', { bubbles: true }));
  }

  async function copyFillBlankSourceToEditedPassage() {
    const nodes = getFillBlankEditorNodes();
    if (!nodes || !nodes.sourceNode) return;
    if (nodes.sourceNode.disabled || nodes.editedNode.disabled || nodes.blankMapNode.disabled) return;
    const sourceText = String(nodes.sourceNode.value || '').trim();
    if (!sourceText) {
      await showModal('Fill in the Blanks', nodes.sourceLabel + ' is empty. Add original passage text first.', 'warning');
      if (typeof nodes.sourceNode.focus === 'function') nodes.sourceNode.focus();
      return;
    }
    nodes.editedNode.value = sourceText;
    let map = {};
    try {
      map = parseListeningBlankAnswerMapJson(nodes.blankMapNode.value);
    } catch (error) {
      await showModal('Fill in the Blanks', error.message || 'Blank Answer Map JSON is invalid.', 'error');
      return;
    }
    const normalized = buildListeningBlankSequentialState(nodes.editedNode.value, map);
    nodes.editedNode.value = normalized.transcriptWithBlanks;
    nodes.blankMapNode.value = JSON.stringify(normalized.blankAnswerMap, null, 2);
    refreshFillBlankSummary(nodes);
    nodes.editedNode.dispatchEvent(new Event('input', { bubbles: true }));
    nodes.blankMapNode.dispatchEvent(new Event('input', { bubbles: true }));
  }

  async function analyzeHighlightIncorrectWordsFromText() {
    const nodes = getHighlightIncorrectWordsEditorNodes();
    if (!nodes) return;
    if (nodes.sourceTranscriptNode.disabled || nodes.displayTranscriptNode.disabled || nodes.incorrectWordsNode.disabled) return;

    const sourceTranscript = String(nodes.sourceTranscriptNode.value || '').trim();
    const displayTranscript = String(nodes.displayTranscriptNode.value || '').trim();
    if (!sourceTranscript) {
      await showModal('Analyze Text', 'Source Transcript is required before analyzing differences.', 'warning');
      if (typeof nodes.sourceTranscriptNode.focus === 'function') nodes.sourceTranscriptNode.focus();
      return;
    }
    if (!displayTranscript) {
      await showModal('Analyze Text', 'Transcript Text is required before analyzing differences.', 'warning');
      if (typeof nodes.displayTranscriptNode.focus === 'function') nodes.displayTranscriptNode.focus();
      return;
    }

    const changedWords = extractHighlightIncorrectWords(sourceTranscript, displayTranscript);
    nodes.incorrectWordsNode.value = changedWords.join('\n');
    nodes.incorrectWordsNode.dispatchEvent(new Event('input', { bubbles: true }));
    if (!changedWords.length) {
      await showModal('Analyze Text', 'No changed words were detected. Update Transcript Text so some words differ from Source Transcript, then analyze again.', 'warning');
      return;
    }
    await showModal('Analyze Text', `${changedWords.length} changed word(s) extracted into Incorrect Words.`, 'success');
  }

  function getTypeMediaInputSet(typeDef = null) {
    const behavior = (typeDef && typeof typeDef.editorBehavior === 'object') ? typeDef.editorBehavior : {};
    const mediaInputs = Array.isArray(behavior.mediaInputs) ? behavior.mediaInputs : [];
    return new Set(mediaInputs.map((item) => cleanText(item)).filter(Boolean));
  }

  function inferMediaKindForField(field) {
    const keyToken = cleanText(field?.key).toLowerCase();
    const labelToken = cleanText(field?.label).toLowerCase();
    const token = keyToken + ' ' + labelToken;
    if (token.includes('audio')) return 'audio';
    if (token.includes('image') || token.includes('picture') || token.includes('photo')) return 'image';
    return 'any';
  }

  function getFileExtension(name = '') {
    const token = cleanText(name);
    const dot = token.lastIndexOf('.');
    if (dot < 0) return '';
    return token.slice(dot + 1).toLowerCase();
  }

  function inferMediaKindFromHints({ mimeType = '', value = '' } = {}) {
    const mime = cleanText(mimeType).toLowerCase();
    const extension = getFileExtension(value);
    const audioExt = new Set(['mp3', 'wav', 'm4a', 'aac', 'ogg', 'webm', 'flac']);
    const imageExt = new Set(['jpg', 'jpeg', 'png', 'gif', 'bmp', 'webp', 'svg', 'ico', 'tif', 'tiff']);
    if (mime.startsWith('audio/') || audioExt.has(extension)) return 'audio';
    if (mime.startsWith('image/') || imageExt.has(extension)) return 'image';
    return 'any';
  }

  function isMediaRowCompatible(row = {}, mediaKind = 'any') {
    const kind = cleanText(mediaKind).toLowerCase() || 'any';
    if (kind === 'any') return true;
    const mime = cleanText(row.mimeType).toLowerCase();
    const extension = getFileExtension(row.filename || row.originalName || row.name || row.path || row.url);
    const audioExt = new Set(['mp3', 'wav', 'm4a', 'aac', 'ogg', 'webm', 'flac']);
    const imageExt = new Set(['jpg', 'jpeg', 'png', 'gif', 'bmp', 'webp', 'svg']);
    if (kind === 'audio') {
      return mime.startsWith('audio/') || audioExt.has(extension);
    }
    if (kind === 'image') {
      return mime.startsWith('image/') || imageExt.has(extension);
    }
    return true;
  }

  function buildAssignableMediaRows(mediaKind = 'any') {
    const merged = []
      .concat(Array.isArray(state.mediaAssets) ? state.mediaAssets : [])
      .concat(Array.isArray(state.stagedMediaAssets) ? state.stagedMediaAssets : []);
    const out = [];
    const seen = new Set();
    merged.forEach((raw) => {
      const row = raw && typeof raw === 'object' ? raw : {};
      if (!isMediaRowCompatible(row, mediaKind)) return;
      const dedupeKey = [
        cleanText(row.id).toLowerCase(),
        cleanText(row.path).toLowerCase(),
        cleanText(row.url).toLowerCase(),
        cleanText(row.filename).toLowerCase(),
        cleanText(row.originalName).toLowerCase(),
        cleanText(row.name).toLowerCase()
      ].find(Boolean);
      if (!dedupeKey || seen.has(dedupeKey)) return;
      seen.add(dedupeKey);
      out.push(row);
    });
    return out;
  }

  function getMediaReferenceToken(row = {}) {
    const id = cleanText(row.id);
    if (id && !/^NEW_UPLOAD_/i.test(id)) return id;
    return cleanText(row.filename)
      || cleanText(row.originalName)
      || cleanText(row.name)
      || cleanText(row.path)
      || cleanText(row.url);
  }

  function isDirectMediaReferenceToken(value = '') {
    const token = cleanText(value);
    if (!token) return false;
    if (/^https?:\/\//i.test(token)) return true;
    if (/^\/uploads\//i.test(token)) return true;
    if (/^uploads\//i.test(token)) return true;
    if (/^\/pte\/questions-bank\//i.test(token)) return true;
    if (/^pte\/questions-bank\//i.test(token)) return true;
    return false;
  }

  function buildMediaOptionLabel(row = {}) {
    const name = cleanText(row.originalName) || cleanText(row.filename) || cleanText(row.name) || '(media)';
    const source = cleanText(row.source).toLowerCase();
    const sourceLabel = source === 'new_upload' ? 'New upload' : 'Attached';
    return `${name} (${sourceLabel})`;
  }

  function buildMediaSelectOptionsHtml(currentValue = '', mediaKind = 'any') {
    const rows = buildAssignableMediaRows(mediaKind);
    const selectedToken = cleanText(currentValue);
    const seen = new Set();
    let html = '<option value="">-- Select Media Reference --</option>';

    rows.forEach((row) => {
      const token = getMediaReferenceToken(row);
      if (!token) return;
      const key = token.toLowerCase();
      if (seen.has(key)) return;
      seen.add(key);
      const selected = selectedToken && selectedToken.toLowerCase() === key ? 'selected' : '';
      html += '<option value="' + esc(token) + '" ' + selected + '>' + esc(buildMediaOptionLabel(row)) + '</option>';
    });

    if (selectedToken && !seen.has(selectedToken.toLowerCase())) {
      const matchedRow = findMediaAssetByRef(selectedToken);
      if (matchedRow) {
        const canonicalToken = getMediaReferenceToken(matchedRow);
        const canonicalKey = cleanText(canonicalToken).toLowerCase();
        if (canonicalToken && !seen.has(canonicalKey)) {
          html += '<option value="' + esc(canonicalToken) + '" selected>'
            + esc(buildMediaOptionLabel(matchedRow) + ' (current)')
            + '</option>';
          seen.add(canonicalKey);
        }
      } else if (isDirectMediaReferenceToken(selectedToken)) {
        html += '<option value="' + esc(selectedToken) + '" selected>' + esc(selectedToken + ' (current)') + '</option>';
      }
    }
    return html;
  }

  function isResolvableMediaToken(tokenValue = '', mediaKind = 'any') {
    const token = cleanText(tokenValue);
    if (!token) return true;
    const matched = findMediaAssetByRef(token);
    if (matched && isMediaRowCompatible(matched, mediaKind)) return true;
    return isDirectMediaReferenceToken(token);
  }

  function assignMediaTokenToInput(inputId, tokenValue) {
    const input = document.getElementById(cleanText(inputId));
    if (!input) return false;
    input.value = cleanText(tokenValue);
    input.dispatchEvent(new Event('input', { bubbles: true }));
    refreshMediaFieldSelectOptions();
    return true;
  }

  function refreshMediaFieldSelectOptions() {
    const selectors = form.querySelectorAll('[data-media-select-target]');
    selectors.forEach((selectNode) => {
      const targetId = cleanText(selectNode.getAttribute('data-media-select-target'));
      const mediaKind = cleanText(selectNode.getAttribute('data-media-kind')).toLowerCase() || 'any';
      const targetNode = document.getElementById(targetId);
      const currentValue = cleanText(targetNode ? targetNode.value : selectNode.value);
      selectNode.innerHTML = buildMediaSelectOptionsHtml(currentValue, mediaKind);
      if (currentValue) {
        selectNode.value = currentValue;
        if (!cleanText(selectNode.value)) {
          const matchedRow = findMediaAssetByRef(currentValue);
          const canonicalToken = matchedRow ? cleanText(getMediaReferenceToken(matchedRow)) : '';
          if (canonicalToken) selectNode.value = canonicalToken;
        }
        if (!cleanText(selectNode.value) && !isResolvableMediaToken(currentValue, mediaKind)) {
          if (targetNode) {
            targetNode.value = '';
            targetNode.dispatchEvent(new Event('input', { bubbles: true }));
          }
        }
      }
    });
  }

  function findMediaAssetByRef(assetRef) {
    const token = cleanText(assetRef).toLowerCase();
    if (!token) return null;
    return buildAssignableMediaRows('any').find((row) => {
      const candidates = [row?.id, row?.name, row?.originalName, row?.filename, row?.path, row?.url]
        .map((item) => cleanText(item).toLowerCase())
        .filter(Boolean);
      return candidates.includes(token);
    }) || null;
  }

  function resolveMediaUrl(assetRef) {
    const token = cleanText(assetRef);
    if (!token) return '';
    if (/^https?:\/\//i.test(token)) return token;
    if (/^\/uploads\//i.test(token)) return token;
    if (/^uploads\//i.test(token)) return '/' + token;
    const media = findMediaAssetByRef(assetRef);
    if (!media) return '';
    if (cleanText(media.url)) return cleanText(media.url);
    if (cleanText(media.path)) {
      const normalizedPath = cleanText(media.path).replace(/\\/g, '/');
      const uploadsMatch = normalizedPath.match(/\/uploads\/(.+)$/i);
      if (uploadsMatch && uploadsMatch[1]) {
        return '/uploads/' + uploadsMatch[1].replace(/^\/+/, '');
      }
    }
    if (routeId && cleanText(media.id)) {
      return '/pte/questions-bank/' + encodeURIComponent(routeId) + '/media/' + encodeURIComponent(cleanText(media.id)) + '/download';
    }
    return '';
  }

  function buildMediaFileName(row = {}, fallbackToken = '') {
    const byRow = cleanText(row.originalName)
      || cleanText(row.filename)
      || cleanText(row.name);
    if (byRow) return byRow;
    const token = cleanText(fallbackToken);
    if (!token) return 'Media File';
    const normalized = token.replace(/\\/g, '/');
    const segments = normalized.split('/').filter(Boolean);
    return segments.length ? segments[segments.length - 1] : token;
  }

  async function openAssignedMediaPreview(inputId, preferredKind = 'any') {
    const targetInput = document.getElementById(cleanText(inputId));
    if (!targetInput) return;
    const token = cleanText(targetInput.value);
    if (!token) {
      await showModal('View File', 'No file is assigned to this field yet.', 'warning');
      return;
    }

    const mediaRow = findMediaAssetByRef(token);
    const mediaUrl = resolveMediaUrl(token);
    if (!mediaUrl) {
      await showModal('View File', `Unable to resolve this media reference: ${token}`, 'warning');
      return;
    }

    const fileName = buildMediaFileName(mediaRow || {}, token);
    const mimeType = cleanText(mediaRow && mediaRow.mimeType);
    const detectedKind = inferMediaKindFromHints({
      mimeType,
      value: cleanText(mediaRow && (mediaRow.filename || mediaRow.originalName || mediaRow.name || mediaRow.path || mediaRow.url)) || mediaUrl
    });
    const preferred = cleanText(preferredKind).toLowerCase();
    const finalKind = detectedKind !== 'any'
      ? detectedKind
      : ((preferred === 'audio' || preferred === 'image') ? preferred : 'any');

    if (finalKind === 'image' && window.ImageViewer && typeof window.ImageViewer.open === 'function') {
      window.ImageViewer.open(mediaUrl, fileName, mimeType);
      return;
    }
    if (finalKind === 'audio' && window.AudioPreviewModal && typeof window.AudioPreviewModal.open === 'function') {
      window.AudioPreviewModal.open(mediaUrl, fileName, mimeType);
      return;
    }
    window.open(mediaUrl, '_blank', 'noopener');
  }

  function renderAudioBlock(assetRef, title = 'Audio Prompt') {
    const token = cleanText(assetRef);
    if (!token) {
      return '<div class="alert alert-light border py-2 mb-3"><div class="fw-bold mb-1">' + esc(title) + '</div><div class="text-muted small">No audio asset selected.</div></div>';
    }
    const mediaUrl = resolveMediaUrl(token);
    if (!mediaUrl) {
      return '<div class="alert alert-warning py-2 mb-3"><div class="fw-bold mb-1">' + esc(title) + '</div><div class="small">Audio reference: <span class="font-monospace">' + esc(token) + '</span> (upload/attach file to play in preview)</div></div>';
    }
    return ''
      + '<div class="alert alert-light border py-2 mb-3">'
      + '  <div class="fw-bold mb-1">' + esc(title) + '</div>'
      + '  <audio controls preload="metadata" style="width:100%;">'
      + '    <source src="' + esc(mediaUrl) + '">'
      + '    Your browser does not support audio playback.'
      + '  </audio>'
      + '</div>';
  }

  function renderImageBlock(assetRef, title = 'Image Prompt') {
    const token = cleanText(assetRef);
    if (!token) {
      return '<div class="alert alert-light border py-2 mb-3"><div class="fw-bold mb-1">' + esc(title) + '</div><div class="text-muted small">No image asset selected.</div></div>';
    }
    const mediaUrl = resolveMediaUrl(token);
    if (!mediaUrl) {
      return '<div class="alert alert-warning py-2 mb-3"><div class="fw-bold mb-1">' + esc(title) + '</div><div class="small">Image reference: <span class="font-monospace">' + esc(token) + '</span> (upload/attach file to display in preview)</div></div>';
    }
    return ''
      + '<div class="alert alert-light border py-2 mb-3">'
      + '  <div class="fw-bold mb-2">' + esc(title) + '</div>'
      + '  <img src="' + esc(mediaUrl) + '" alt="Preview image" class="img-fluid rounded border">'
      + '</div>';
