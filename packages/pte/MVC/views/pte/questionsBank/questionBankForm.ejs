        + '  <td class="text-end"><div class="d-flex justify-content-end gap-2">'
        + (downloadUrl ? ('<a href="' + esc(downloadUrl) + '" target="_blank" rel="noopener" class="btn btn-outline-primary btn-sm"><i class="bi bi-download me-1"></i>Download</a>') : '')
        + (isCoreEditable ? '<button type="button" class="btn btn-outline-danger btn-sm" data-remove-media="' + esc(mediaId) + '"><i class="bi bi-trash me-1"></i>Remove</button>' : '')
        + '  </div></td>'
        + '</tr>';
