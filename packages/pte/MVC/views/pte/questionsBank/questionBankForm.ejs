    renderTypeFields();
  });

  if (useQuestionScoringOverrideSwitch) {
    useQuestionScoringOverrideSwitch.addEventListener('change', async () => {
      if (!isScoringEditable) {
        useQuestionScoringOverrideSwitch.checked = Boolean(state.useQuestionScoringOverride);
        return;
      }

      if (state.useQuestionScoringOverride) {
        captureCurrentFieldDrafts();
      }
      state.useQuestionScoringOverride = Boolean(useQuestionScoringOverrideSwitch.checked);
      updateScoringModeHint();
      if (!state.useQuestionScoringOverride) {
        await loadGlobalScoringProfile({ force: true, notifyOnError: true });
      }
      renderTypeFields({ skipCapture: true });
      updatePreviewSnapshot();
    });
  }

  if (validateBtn) {
    validateBtn.addEventListener('click', () => validateViaBackend());
  }

  if (aiAssistBtn) {
    aiAssistBtn.addEventListener('click', () => runAiAssistForTypeFields());
  }

  if (aiAssistApplyBtn) {
    aiAssistApplyBtn.addEventListener('click', () => applySelectedAiSuggestions());
  }

  if (aiAssistBody) {
    aiAssistBody.addEventListener('change', (event) => {
      const node = event.target.closest('[data-ai-assist-index]');
      if (!node) return;
      const index = Number(node.getAttribute('data-ai-assist-index'));
      if (!Number.isFinite(index)) return;
      if (!Array.isArray(state.aiAssistSuggestions) || !state.aiAssistSuggestions[index]) return;
      state.aiAssistSuggestions[index].selected = Boolean(node.checked);
    });
  }

  if (btnRefreshPreview) {
    btnRefreshPreview.addEventListener('click', () => {
      updatePreviewSnapshot();
    });
  }

  if (btnOpenSavedMediaLibrary) {
    btnOpenSavedMediaLibrary.addEventListener('click', async () => {
      if (!isCoreEditable) return;
      state.pendingMediaAssignTarget = null;
      await openSavedMediaManager({
        mode: 'attach',
        mediaKind: 'any',
        maxSelection: MAX_FILES,
        defaultView: 'list'
      });
    });
  }

  if (btnCopyFromQuestion) {
    btnCopyFromQuestion.addEventListener('click', () => {
      openCopyFromQuestionPicker();
    });
  }

  if (btnStudentPreview) {
    btnStudentPreview.addEventListener('click', async () => {
      try {
        const plan = buildPlan();
        openStudentPreviewModal(plan);
      } catch (error) {
        await showModal('Preview', error.message || 'Unable to render preview for current draft.', 'warning');
      }
    });
  }

  if (btnExamPreview) {
    btnExamPreview.addEventListener('click', async () => {
      try {
        const plan = buildPlan();
        if (!examPreviewForm || !examPreviewPlanInput) {
          throw new Error('Exam preview form is not available.');
        }
        examPreviewPlanInput.value = JSON.stringify(plan);
        if (examPreviewActionInput) {
          examPreviewActionInput.value = actionStateId;
        }
        examPreviewForm.submit();
      } catch (error) {
        await showModal('Exam Preview', error.message || 'Unable to open exam preview for current draft.', 'warning');
      }
    });
  }

  document.querySelectorAll('#pteQbTabs .nav-link').forEach((tabButton) => {
    tabButton.addEventListener('shown.bs.tab', () => {
      const activeTarget = getActiveTabTarget();
      currentStepIndex = Math.max(0, tabTargets.indexOf(activeTarget));
      refreshWizardButtons();
    });
  });

  if (btnPrevStep) btnPrevStep.addEventListener('click', () => showStep(currentStepIndex - 1));
  if (btnNextStep) btnNextStep.addEventListener('click', () => showStep(currentStepIndex + 1));

  form.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (isSubmitting || !isScoringEditable) return;
    const valid = await validateBeforeSubmit();
    if (!valid) return;
    if (currentStepIndex !== tabTargets.length - 1) {
      showStep(currentStepIndex + 1);
      return;
    }

    let plan = null;
    try {
      plan = buildPlan();
      planInput.value = JSON.stringify(plan);
    } catch (error) {
      await showModal('Validation', error.message || 'Unable to build question payload.', 'error');
      return;
    }

    isSubmitting = true;
    if (btnSave) setButtonBusy(btnSave, 'Saving...');
    if (btnCancel) btnCancel.disabled = true;

    try {
      const saveActionStateId = await issueFormActionState(isEdit ? 'update' : 'create');
      const formActionStateInput = document.getElementById('pteQbActionStateId');
      if (formActionStateInput) formActionStateInput.value = saveActionStateId;
      const formData = new FormData(form);
      formData.set('questionPlan', JSON.stringify(plan));
      formData.set('actionStateId', saveActionStateId);
      const submitUrl = appendActionState(form.action, saveActionStateId);

      const response = await fetch(submitUrl, {
        method: 'POST',
        headers: {
          'X-AJAX-Request': 'true',
          'Accept': 'application/json',
          'X-Action-State-Id': saveActionStateId
        },
        body: formData,
        credentials: 'include'
      });

      const result = await response.json().catch(() => null);
      if (!response.ok || !result || result.status !== 'success') {
        throw new Error((result && result.message) || ('Request failed with status ' + response.status + '.'));
      }

      await showModal('Success', result.message || 'Question saved successfully.', 'success');
      window.location.href = '/pte/questions-bank';
    } catch (error) {
      await showModal('Save Failed', error.message || 'Unexpected save error.', 'error');
      isSubmitting = false;
      restoreButton(btnSave);
      restoreButton(btnCancel);
    }
  });

  if (btnCancel) {
    cacheButtonHtml(btnCancel);
    btnCancel.addEventListener('click', (event) => {
      if (isSubmitting) {
        event.preventDefault();
        return;
      }
      setButtonBusy(btnCancel, 'Cancelling...');
      if (btnSave) btnSave.disabled = true;
    });
  }

  if (btnSave) cacheButtonHtml(btnSave);

  function initializeFromExisting() {
    if (testTypeSelect) {
      testTypeSelect.value = cleanText(initial.testType).toLowerCase();
    }
    skillSelect.value = cleanText(initial.skill).toLowerCase();
    if (useQuestionScoringOverrideSwitch) {
      useQuestionScoringOverrideSwitch.checked = Boolean(state.useQuestionScoringOverride);
    }
    updateScoringModeHint();
    updateScoringProfileVersionLabel();
    updateQuestionTypeOptions();
    questionTypeSelect.value = cleanText(initial.questionType).toLowerCase();
    renderTypeFields();
    renderExistingMedia();
    renderNewFiles();
    updatePreviewSnapshot();
    if (!state.useQuestionScoringOverride || !Object.keys(state.scoringGlobal || {}).length) {
      loadGlobalScoringProfile({ force: true })
        .then(() => {
          if (!state.useQuestionScoringOverride) {
            renderTypeFields({ skipCapture: true });
          }
        })
        .catch(() => {});
    }
  }

  initializeFromExisting();
  bindModalFallbackDismiss(studentPreviewModalEl, studentPreviewModal);
  bindModalFallbackDismiss(aiAssistModalEl, aiAssistModal);
  bindModalFallbackDismiss(mediaManagerModalEl, mediaManagerModal);
  if (mediaManagerModalEl) {
    mediaManagerModalEl.addEventListener('hidden.bs.modal', () => {
      state.pendingMediaAssignTarget = null;
    });
  }
  bindFallbackEscapeClose();
  refreshAiAssistButtonState();
  currentStepIndex = Math.max(0, tabTargets.indexOf(getActiveTabTarget()));
  if (previewMode) {
    try {
      openStudentPreviewModal(buildPlan());
    } catch (_) {
      openStudentPreviewModal(null);
    }
  }
  refreshWizardButtons();
  window.addEventListener('beforeunload', clearNewFileObjectUrls);
})();
</script>
