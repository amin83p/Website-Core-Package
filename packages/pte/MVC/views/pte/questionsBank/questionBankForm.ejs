    } else if (inputType === 'select') {
      const options = Array.isArray(field.options) ? field.options : [];
      control = '<select class="form-select size-md" id="' + esc(id) + '" data-field-scope="' + esc(scopePrefix) + '" data-field-key="' + esc(field.key) + '" data-field-input="' + esc(inputType) + '" ' + disabled + '>'
        + options.map((option) => {
          const value = cleanText(option.value || option);
          const label = cleanText(option.label || option.value || option);
          const selected = String(rawValue || '') === value ? 'selected' : '';
          return '<option value="' + esc(value) + '" ' + selected + '>' + esc(label) + '</option>';
        }).join('')
        + '</select>';
    } else if (inputType === 'list_string') {
      const rows = Array.isArray(rawValue) ? rawValue : [];
      if (isReadingReorderCorrectOrderField) {
        fieldColClass = 'col-md-12 mb-3';
        control = '<textarea class="form-control size-md font-monospace" rows="5" id="' + esc(id) + '" data-field-scope="' + esc(scopePrefix) + '" data-field-key="' + esc(field.key) + '" data-field-input="' + esc(inputType) + '" data-reorder-correct-order="true" readonly>'
          + esc(rows.join('\n')) + '</textarea>'
          + '<div class="form-text small">Auto-synced from paragraph list order. Edit paragraph list above to change the correct order.</div>';
      } else {
        control = '<textarea class="form-control size-md font-monospace" rows="4" id="' + esc(id) + '" data-field-scope="' + esc(scopePrefix) + '" data-field-key="' + esc(field.key) + '" data-field-input="' + esc(inputType) + '" ' + disabled + '>'
          + esc(rows.join('\n')) + '</textarea>'
