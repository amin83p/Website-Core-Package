  function collectReorderParagraphBuilderRows(nodes) {
    if (!nodes || !nodes.builder) return [];
    return Array.from(nodes.builder.querySelectorAll('[data-reorder-paragraph-text]'))
      .map((node) => String(node.value || '').trim())
      .filter(Boolean);
  }

  function syncReorderParagraphJsonFromListEditor() {
    const nodes = getReorderParagraphBuilderNodes();
    if (!nodes) return;
    const rows = collectReorderParagraphBuilderRows(nodes);
    nodes.paragraphsInput.value = buildReorderParagraphItemsJsonText(rows);
    nodes.correctOrderInput.value = buildReorderCorrectOrderText(rows);
    showReorderParagraphBuilderWarning(nodes.builder, '');
  }

  function syncReorderParagraphBuilderFromJsonEditor() {
    const nodes = getReorderParagraphBuilderNodes();
    if (!nodes) return;
    const parsed = parseReorderParagraphItemsJsonText(nodes.paragraphsInput.value);
    if (parsed.error) {
      showReorderParagraphBuilderWarning(nodes.builder, parsed.error);
      return;
    }
    showReorderParagraphBuilderWarning(nodes.builder, '');
    renderReorderParagraphBuilderRows(nodes, parsed.paragraphs);
    nodes.correctOrderInput.value = buildReorderCorrectOrderText(parsed.paragraphs);
  }

  function getReadingWritingBlankOptionsBuilderNodes() {
    const typeDef = getSelectedTypeDef();
    if (!isReadingWritingFillInBlankType(typeDef)) return null;
    const optionsInput = form.querySelector('[data-field-scope="payload"][data-field-key="blankOptionsMap"][data-rw-fib-options-json="true"]');
    const answerMapInput = form.querySelector('[data-field-scope="payload"][data-field-key="blankAnswerMap"]');
    if (!optionsInput || !answerMapInput) return null;
    const optionsInputId = cleanText(optionsInput.id);
    if (!optionsInputId) return null;
    const builder = form.querySelector('[data-rw-fib-builder][data-rw-fib-options-input="' + optionsInputId + '"]');
    if (!builder) return null;
    return { optionsInput, answerMapInput, builder, optionsInputId };
  }

  function showReadingWritingBlankOptionsBuilderWarning(builder, message = '') {
    if (!builder) return;
    const warningNode = builder.querySelector('[data-rw-fib-warning]');
    if (!warningNode) return;
    const token = cleanText(message);
    if (!token) {
      warningNode.classList.add('d-none');
      warningNode.textContent = '';
      return;
    }
    warningNode.classList.remove('d-none');
    warningNode.textContent = token;
  }

  function renderReadingWritingBlankOptionsBuilderRows(nodes, answerMap = {}, optionsMap = {}) {
    if (!nodes || !nodes.builder) return;
    const tbody = nodes.builder.querySelector('[data-rw-fib-options-list]');
    if (!tbody) return;
    const disabledAttr = nodes.optionsInput.disabled ? 'disabled' : '';
    tbody.innerHTML = renderReadingWritingBlankOptionsRowsHtml(answerMap, optionsMap, disabledAttr);
  }

  function syncReadingWritingBlankOptionsBuilderFromJsonEditor() {
    const nodes = getReadingWritingBlankOptionsBuilderNodes();
    if (!nodes) return;

    let answerMap = {};
    try {
      answerMap = parseListeningBlankAnswerMapJson(nodes.answerMapInput.value);
    } catch (error) {
      showReadingWritingBlankOptionsBuilderWarning(nodes.builder, cleanText(error?.message || 'Blank Answer Map JSON is invalid.'));
      return;
    }

    const parsedOptions = parseReadingWritingBlankOptionsMapJsonText(nodes.optionsInput.value);
    const normalizedOptionsMap = normalizeReadingWritingBlankOptionsMapFromAnswerMap(answerMap, parsedOptions.map);
    nodes.optionsInput.value = buildReadingWritingBlankOptionsMapJsonText(normalizedOptionsMap);
    renderReadingWritingBlankOptionsBuilderRows(nodes, answerMap, normalizedOptionsMap);

    const underFilled = sortFillBlankTokenKeys(Object.keys(answerMap))
      .map((blankKey) => ({
        blankKey,
        count: Array.isArray(normalizedOptionsMap[blankKey]) ? normalizedOptionsMap[blankKey].length : 0
      }))
      .filter((row) => row.count < 4);

    const warnings = [];
    if (parsedOptions.error) warnings.push(parsedOptions.error);
    if (underFilled.length) {
      warnings.push('Some blanks still need options: ' + underFilled.map((row) => `${row.blankKey} (${row.count}/4)`).join(', ') + '.');
    }
    showReadingWritingBlankOptionsBuilderWarning(nodes.builder, warnings.join(' '));
  }

  async function applyReorderAutoSplitFromSource() {
    const typeDef = getSelectedTypeDef();
    if (cleanText(typeDef?.key).toLowerCase() !== 'reading_reorder_paragraphs') {
      await showModal('Auto Split', 'This action is only available for Reading - Reorder Paragraphs.', 'warning');
      return;
    }

    const sourceNode = form.querySelector('[data-field-scope="payload"][data-field-key="sourcePassage"]');
    const nodes = getReorderParagraphBuilderNodes();
    if (!sourceNode || !nodes) {
      await showModal('Auto Split', 'Paragraph builder controls are not available.', 'warning');
      return;
    }

    const sourceText = String(sourceNode.value || '').trim();
    if (!sourceText) {
      await showModal('Auto Split', 'Paste the full passage first.', 'warning');
      if (typeof sourceNode.focus === 'function') sourceNode.focus();
      return;
    }

    const paragraphs = splitReorderSourcePassageIntoParagraphs(sourceText).map((row) => cleanText(row)).filter(Boolean);
    if (paragraphs.length < 2) {
      await showModal('Auto Split', 'Unable to split into at least two paragraphs. Add paragraph breaks or edit manually.', 'warning');
      return;
    }

    nodes.paragraphsInput.value = buildReorderParagraphItemsJsonText(paragraphs);
    syncReorderParagraphBuilderFromJsonEditor();
    updatePreviewSnapshot();
    await showModal('Auto Split', `Generated ${paragraphs.length} paragraph item(s) and synced correct order.`, 'success');
  }

  function isMissingFieldValue(field, value) {
    const inputType = cleanText(field?.input).toLowerCase();
    if (inputType === 'list_string') return !Array.isArray(value) || !value.length;
    if (inputType === 'json') {
      const jsonKind = cleanText(field?.jsonKind).toLowerCase();
      if (jsonKind === 'array') return !Array.isArray(value) || !value.length;
      if (jsonKind === 'object') return !value || typeof value !== 'object' || Array.isArray(value) || !Object.keys(value).length;
      return value === undefined || value === null || value === '';
    }
    if (inputType === 'boolean') return value !== true && value !== false;
    return value === undefined || value === null || String(value).trim() === '';
  }

  function resolveScoringReadinessSource(typeDef) {
    if (!typeDef) return {};
    if (!state.useQuestionScoringOverride) {
      return (state.scoringGlobal && typeof state.scoringGlobal === 'object') ? state.scoringGlobal : {};
    }
    try {
      return collectFieldsByScope('scoring');
    } catch (_) {
      const fallback = (state.scoringDraft && typeof state.scoringDraft === 'object') ? state.scoringDraft : {};
      const out = {};
      const scoringFields = Array.isArray(typeDef.scoringFields) ? typeDef.scoringFields : [];
      scoringFields.forEach((field) => {
        const key = cleanText(field?.key);
        if (!key) return;
        if (Object.prototype.hasOwnProperty.call(fallback, key)) {
          out[key] = fallback[key];
          return;
        }
        if (Object.prototype.hasOwnProperty.call(field || {}, 'default')) {
          out[key] = field.default;
        }
      });
      return out;
    }
  }

  function buildScoringReadinessWarnings(typeDef, scoringSource) {
    const warnings = [];
    const scoringFields = Array.isArray(typeDef?.scoringFields) ? typeDef.scoringFields : [];
    const requiredScoringFields = scoringFields.filter((field) => field && field.required);
    requiredScoringFields.forEach((field) => {
      const key = cleanText(field.key);
      if (!key) return;
      const value = Object.prototype.hasOwnProperty.call(scoringSource, key) ? scoringSource[key] : undefined;
      if (isMissingFieldValue(field, value)) {
        warnings.push(`${cleanText(field.label || key)} is required for scorer readiness.`);
      }
    });

    const questionType = cleanText(typeDef?.key).toLowerCase();
    const traitKeys = Array.isArray(SCORING_TRAIT_KEYS_BY_TYPE[questionType]) ? SCORING_TRAIT_KEYS_BY_TYPE[questionType] : [];
    const traitWeights = scoringSource && typeof scoringSource.traitWeights === 'object' && !Array.isArray(scoringSource.traitWeights)
      ? scoringSource.traitWeights
      : null;
    if (traitKeys.length && traitWeights) {
      const missingTraitKeys = traitKeys.filter((key) => !Object.prototype.hasOwnProperty.call(traitWeights, key));
      if (missingTraitKeys.length) {
        warnings.push(`Trait Weights must include: ${missingTraitKeys.join(', ')}.`);
      } else {
        const sum = traitKeys.reduce((acc, key) => acc + Number(traitWeights[key] || 0), 0);
        if (!Number.isFinite(sum) || Math.abs(sum - 1) > 0.01) {
          warnings.push('Trait Weights must sum to 1.00 (+/- 0.01).');
        }
      }
    }

    const idealWpmMin = Number.parseInt(String(scoringSource?.idealWpmMin ?? ''), 10);
    const idealWpmMax = Number.parseInt(String(scoringSource?.idealWpmMax ?? ''), 10);
    if (Number.isFinite(idealWpmMin) && Number.isFinite(idealWpmMax) && idealWpmMax < idealWpmMin) {
      warnings.push('Ideal WPM Maximum must be greater than or equal to Ideal WPM Minimum.');
    }
    return warnings;
  }

  function refreshScoringReadiness(typeDef = null) {
    if (!scoringReadinessNode) return;
    const selectedTypeDef = typeDef || getSelectedTypeDef();
    if (!selectedTypeDef) {
      scoringReadinessNode.classList.add('d-none');
      scoringReadinessNode.textContent = '';
      return;
    }

    const scoringSource = resolveScoringReadinessSource(selectedTypeDef);
    const warnings = buildScoringReadinessWarnings(selectedTypeDef, scoringSource);
    if (!warnings.length) {
      scoringReadinessNode.classList.add('d-none');
      scoringReadinessNode.textContent = '';
      return;
    }

    const uniqueWarnings = Array.from(new Set(warnings.map((item) => cleanText(item)).filter(Boolean)));
    scoringReadinessNode.textContent = `Scoring readiness: ${uniqueWarnings.join(' ')}`;
    scoringReadinessNode.classList.remove('d-none');
  }

  function collectFieldsByScope(scope) {
    const out = {};
    const selector = '[data-field-scope="' + scope + '"]';
    const nodes = form.querySelectorAll(selector);
    nodes.forEach((node) => {
      const key = String(node.getAttribute('data-field-key') || '').trim();
      const inputType = String(node.getAttribute('data-field-input') || 'text').trim().toLowerCase();
      if (!key) return;
      let rawValue = '';
      if (inputType === 'boolean') rawValue = node.checked;
      else rawValue = node.value;

      const fieldDef = (() => {
        const typeDef = getSelectedTypeDef();
        if (!typeDef) return null;
        const allFields = []
          .concat(Array.isArray(typeDef.requiredFields) ? typeDef.requiredFields : [])
          .concat(Array.isArray(typeDef.optionalFields) ? typeDef.optionalFields : [])
          .concat(Array.isArray(typeDef.scoringFields) ? typeDef.scoringFields : []);
        return allFields.find((field) => String(field.key || '') === key) || null;
      })();
      if (!fieldDef) return;
      out[key] = parseFieldValue(fieldDef, rawValue);
    });
    return out;
  }

  function removeExistingMedia(mediaId) {
    const id = cleanText(mediaId);
    if (!id) return;
    const removedRows = state.mediaAssets.filter((row) => cleanText(row.id) === id);
    state.mediaAssets = state.mediaAssets.filter((row) => cleanText(row.id) !== id);
    if (removedRows.length) {
      clearRemovedMediaReferences(removedRows);
    }
    renderExistingMedia();
  }

  function buildMediaRefTokensForRow(row = {}) {
    const candidates = [
      cleanText(row.id),
      cleanText(row.name),
      cleanText(row.originalName),
      cleanText(row.filename),
      cleanText(row.path),
      cleanText(row.url),
      cleanText(getMediaReferenceToken(row))
    ].filter(Boolean);
    const lowered = new Set(candidates.map((item) => item.toLowerCase()));
    if (cleanText(row.path)) {
      const normalizedPath = cleanText(row.path).replace(/\\/g, '/');
      const uploadsMatch = normalizedPath.match(/\/uploads\/(.+)$/i);
      if (uploadsMatch && uploadsMatch[1]) {
        lowered.add(('/uploads/' + uploadsMatch[1].replace(/^\/+/, '')).toLowerCase());
      }
    }
    return lowered;
  }

  function clearRemovedMediaReferences(rows = []) {
    const removedTokenSet = new Set();
    (Array.isArray(rows) ? rows : []).forEach((row) => {
      buildMediaRefTokensForRow(row).forEach((token) => removedTokenSet.add(token));
    });
    if (!removedTokenSet.size) return;

    const selectors = form.querySelectorAll('[data-media-select-target]');
    selectors.forEach((selectNode) => {
      const targetId = cleanText(selectNode.getAttribute('data-media-select-target'));
      const targetNode = targetId ? document.getElementById(targetId) : null;
      if (!targetNode) return;
      const token = cleanText(targetNode.value).toLowerCase();
      if (!token || !removedTokenSet.has(token)) return;
      targetNode.value = '';
      targetNode.dispatchEvent(new Event('input', { bubbles: true }));
    });
  }

  function normalizeSavedMediaRow(row, index) {
    const source = row && typeof row === 'object' ? row : {};
    const fallbackName = 'Saved file ' + (index + 1);
    const pathToken = cleanText(source.path);
    const urlToken = cleanText(source.url);
    return {
      id: cleanText(source.id) || ('LIB_' + (index + 1)),
      name: cleanText(source.name) || cleanText(source.originalName) || cleanText(source.filename) || fallbackName,
      originalName: cleanText(source.originalName) || cleanText(source.name) || cleanText(source.filename) || fallbackName,
      filename: cleanText(source.filename) || cleanText(source.name) || fallbackName,
      path: pathToken,
      url: urlToken,
      mimeType: cleanText(source.mimeType),
      size: Number(source.size || 0) || 0,
      uploadDate: cleanText(source.uploadDate),
      comment: '',
      source: cleanText(source.source) || 'saved_library'
    };
  }

  function addSavedMediaToQuestion(row) {
    const media = normalizeSavedMediaRow(row, 0);
    const existing = state.mediaAssets.find((item) => {
      const samePath = media.path && cleanText(item.path) && cleanText(item.path) === media.path;
      const sameUrl = media.url && cleanText(item.url) && cleanText(item.url) === media.url;
      const sameId = media.id && cleanText(item.id) === media.id;
      return samePath || sameUrl || sameId;
    });
    if (existing) {
      return { row: existing, added: false };
    }
    state.mediaAssets.push(media);
    renderExistingMedia();
    return { row: media, added: true };
  }

  function mergeSavedMediaLibraryRows(rows = [], options = {}) {
    const incoming = Array.isArray(rows) ? rows : [];
    const prepend = options && options.prepend === true;
    const base = prepend
      ? incoming.concat(Array.isArray(state.savedMediaLibrary) ? state.savedMediaLibrary : [])
      : incoming;
    const out = [];
    const seen = new Set();
    base.forEach((raw, index) => {
      const row = normalizeSavedMediaRow(raw, index);
      const key = [
        cleanText(row.id).toLowerCase(),
        cleanText(row.path).toLowerCase(),
        cleanText(row.url).toLowerCase(),
        cleanText(row.filename).toLowerCase(),
        cleanText(row.originalName).toLowerCase()
      ].find(Boolean);
      if (!key || seen.has(key)) return;
      seen.add(key);
      out.push(row);
    });
    state.savedMediaLibrary = out;
    return out;
  }

  function normalizeFolderToken(value) {
    const token = cleanText(value).replace(/\\/g, '/');
    if (!token || token === '/' || token === '.') return '';
    return token
      .split('/')
      .map((part) => cleanText(part))
      .filter(Boolean)
      .join('/');
  }

  function setAiAssistWaitingModal(isBusy) {
    if (isBusy) {
      if (typeof window.showLoading === 'function') {
        if (!aiAssistLoadingToken) {
          aiAssistLoadingToken = window.showLoading({
            title: 'AI Assist',
            note: 'Please wait while we generate suggestions.',
            operation: 'Question Type Analysis'
          });
        } else if (typeof window.updateLoading === 'function') {
          window.updateLoading({
            title: 'AI Assist',
            note: 'Please wait while we generate suggestions.',
            operation: 'Question Type Analysis'
          });
        }
      }
      return;
    }

    if (typeof window.hideLoading === 'function') {
      if (aiAssistLoadingToken) window.hideLoading(aiAssistLoadingToken);
      else window.hideLoading();
    }
    aiAssistLoadingToken = null;
  }

  async function loadSavedMediaLibrary(options = {}) {
    const folder = normalizeFolderToken(options && options.folder);
    const endpointBase = appendActionState('/pte/questions-bank/media/library');
    const endpoint = folder
      ? (endpointBase + (endpointBase.includes('?') ? '&' : '?') + 'folder=' + encodeURIComponent(folder))
      : endpointBase;
    const response = await fetch(endpoint, {
      method: 'GET',
      headers: {
        'X-AJAX-Request': 'true',
        'Accept': 'application/json'
      },
      credentials: 'include'
    });
    const result = await response.json().catch(() => null);
    if (!response.ok || !result || result.status !== 'success') {
      throw new Error((result && result.message) || ('Unable to load media library (status ' + response.status + ').'));
    }

    const rows = Array.isArray(result.results)
      ? result.results.map((row, index) => normalizeSavedMediaRow(row, index))
      : [];
    state.savedMediaLibrary = rows;
    if (mediaManagerModalApi && typeof mediaManagerModalApi.setRows === 'function') {
      mediaManagerModalApi.setRows(rows);
    }
    const defaultPageSize = Number.parseInt(String(result?.defaults?.pageSize || result?.pageSize || ''), 10);
    return {
      rows,
      message: cleanText(result.message) || ('Loaded ' + rows.length + ' saved media file(s).'),
      folders: Array.isArray(result.folders) ? result.folders : [],
      currentFolder: normalizeFolderToken(result.currentFolder || folder),
      parentFolder: normalizeFolderToken(result.parentFolder),
      defaultFolder: normalizeFolderToken(result.defaultFolder || '<%= mediaDefaultFolder %>'),
      defaults: Number.isFinite(defaultPageSize) && !Number.isNaN(defaultPageSize) && defaultPageSize > 0
        ? { pageSize: defaultPageSize }
        : null
    };
  }

  async function uploadSavedMediaLibraryFiles(files = [], options = {}) {
    const inputFiles = Array.isArray(files) ? files.filter(Boolean) : [];
    if (!inputFiles.length) {
      throw new Error('No files selected for upload.');
    }
    const formData = new FormData();
    inputFiles.forEach((file) => formData.append('files', file));
    const providedActionStateToken = cleanText(options && options.actionStateToken);
    const actionStateToken = providedActionStateToken || await issueFormActionState('update');
    formData.set('actionStateId', actionStateToken);
    const endpoint = appendFormActionTarget(
      appendActionState('/pte/questions-bank/media/upload', actionStateToken),
      formData
    );
    const response = await fetch(endpoint, {
      method: 'POST',
      headers: {
        'X-AJAX-Request': 'true',
        'Accept': 'application/json',
        'X-Action-State-Id': actionStateToken
      },
      body: formData,
      credentials: 'include'
    });
    const result = await response.json().catch(() => null);
    if (!response.ok || !result || result.status !== 'success') {
      throw new Error((result && result.message) || ('Upload failed with status ' + response.status + '.'));
    }
    const rows = Array.isArray(result.results)
      ? result.results.map((row, index) => normalizeSavedMediaRow(row, index))
      : [];
    mergeSavedMediaLibraryRows(rows, { prepend: true });
    return {
      rows,
      message: cleanText(result.message) || ('Uploaded ' + rows.length + ' file(s).')
    };
  }

  async function persistStagedMediaForAiAssist() {
    const stagedFiles = Array.from((filesInput && filesInput.files) || []).filter(Boolean);
    if (!stagedFiles.length) {
      return { uploadedCount: 0, attachedCount: 0 };
    }

    const uploadResult = await uploadSavedMediaLibraryFiles(stagedFiles);
    const uploadedRows = Array.isArray(uploadResult?.rows) ? uploadResult.rows : [];
    let attachedCount = 0;
    uploadedRows.forEach((row) => {
      const addResult = addSavedMediaToQuestion(row);
      if (addResult && addResult.added) attachedCount += 1;
    });

    if (filesInput) {
      const dt = new DataTransfer();
      filesInput.files = dt.files;
    }
    state.stagedMediaAssets = [];
    renderNewFiles();

    return {
      uploadedCount: uploadedRows.length,
      attachedCount
    };
  }

  async function openSavedMediaManager(context = {}) {
    if (!isCoreEditable) return false;
    if (!mediaManagerModalApi || typeof mediaManagerModalApi.open !== 'function') {
      await showModal('Saved Media Library', 'Media manager is not available in this environment.', 'warning');
      return false;
    }

    if (typeof mediaManagerModalApi.setModalCompat === 'function') {
      mediaManagerModalApi.setModalCompat({
        open: openModalCompat,
        close: closeModalCompat,
        modalEl: mediaManagerModalEl,
        modalInstance: mediaManagerModal
      });
    }

    if (Array.isArray(state.savedMediaLibrary) && state.savedMediaLibrary.length && typeof mediaManagerModalApi.setRows === 'function') {
      mediaManagerModalApi.setRows(state.savedMediaLibrary);
    }

    const mode = cleanText(context.mode).toLowerCase() === 'assign' ? 'assign' : 'attach';
    const mediaKind = ['audio', 'image', 'any'].includes(cleanText(context.mediaKind).toLowerCase())
      ? cleanText(context.mediaKind).toLowerCase()
      : 'any';
    const maxSelection = Math.max(1, Number(context.maxSelection || (mode === 'assign' ? 1 : MAX_FILES)) || 1);
    const requestedDefaultView = cleanText(context.defaultView).toLowerCase();
    const defaultView = ['tile', 'thumbs', 'list', 'detail'].includes(requestedDefaultView)
      ? requestedDefaultView
      : (mode === 'attach' ? 'list' : 'tile');

    await mediaManagerModalApi.open({
      title: 'Saved Media Library',
      mode,
      mediaKind,
      maxSelection,
      defaultView,
      forceRefresh: true,
      defaultFolder: '<%= mediaDefaultFolder %>',
      onRefresh: async (query = {}) => {
        return loadSavedMediaLibrary({ folder: query && query.folder });
      },
      onUpload: async (files) => {
        const result = await uploadSavedMediaLibraryFiles(files);
        return {
          rows: result.rows,
          message: result.message
        };
      },
      onApply: async (selectedRows) => {
        const rows = Array.isArray(selectedRows) ? selectedRows : [];
        if (!rows.length) throw new Error('Select at least one file.');
        const assignTarget = state.pendingMediaAssignTarget;

        if (mode === 'assign') {
          if (!assignTarget || !assignTarget.inputId) {
            throw new Error('Media target field is unavailable.');
          }
          const selected = rows[0];
          if (!isMediaRowCompatible(selected, assignTarget.mediaKind || 'any')) {
            const expected = assignTarget.mediaKind === 'audio'
              ? 'audio'
              : (assignTarget.mediaKind === 'image' ? 'image' : 'media');
            throw new Error('Selected file is not a compatible ' + expected + ' asset for this field.');
          }
          const mediaResult = addSavedMediaToQuestion(selected);
          const token = mediaResult && mediaResult.row ? getMediaReferenceToken(mediaResult.row) : '';
          if (!token || !assignMediaTokenToInput(assignTarget.inputId, token)) {
            throw new Error('Unable to assign selected media to the requested field.');
          }
          state.pendingMediaAssignTarget = null;
          return;
        }

        let addedCount = 0;
        let duplicateCount = 0;
        rows.forEach((row) => {
          const mediaResult = addSavedMediaToQuestion(row);
          if (mediaResult && mediaResult.added) addedCount += 1;
          else duplicateCount += 1;
        });
        state.pendingMediaAssignTarget = null;
        if (!addedCount && duplicateCount) {
          throw new Error('Selected media file(s) are already attached to this question.');
        }
      }
    });

    return true;
  }

  function renderExistingMedia() {
