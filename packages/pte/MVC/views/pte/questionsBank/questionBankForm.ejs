      existingMediaWrap.classList.add('d-none');
      existingMediaBody.innerHTML = '';
      refreshMediaFieldSelectOptions();
      updatePreviewSnapshot();
      return;
    }
    existingMediaWrap.classList.remove('d-none');

    existingMediaBody.innerHTML = state.mediaAssets.map((row, index) => {
      const mediaId = cleanText(row.id) || String(index);
      const fileLabel = esc(row.originalName || row.filename || row.name || '(file)');
      const meta = esc(formatBytes(row.size));
      const comment = esc(row.comment || '');
      const directUrl = cleanText(row.url);
      const routedUrl = routeId
        ? ('/pte/questions-bank/' + encodeURIComponent(routeId) + '/media/' + encodeURIComponent(mediaId) + '/download')
        : '';
