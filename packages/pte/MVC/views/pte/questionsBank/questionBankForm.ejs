          + '    <i class="bi bi-text-paragraph me-1"></i>Auto Split Into Paragraph List'
          + '  </button>'
          + '</div>'
          + '<div class="form-text small">Paste the full passage here, then click <b>Auto Split Into Paragraph List</b> to generate paragraph items and correct order automatically.</div>';
      }
      if (isFillBlankEditedField) {
        const actionLabel = isReadingFillPassageField ? 'Mark as Blank' : 'Create Blank From Selection';
        const tokenSource = isReadingFillPassageField ? 'passage' : 'transcript';
        control += ''
          + '<div class="d-flex flex-wrap align-items-center gap-2 mt-2">'
          + '  <button type="button" class="btn btn-outline-primary btn-sm" data-no-wait="true" data-fill-blank-from-selection="' + esc(id) + '" ' + disabled + '>'
          + '    <i class="bi bi-highlighter me-1"></i>' + esc(actionLabel)
          + '  </button>'
          + '</div>'
          + '<div class="form-text small">Select one or more ' + esc(tokenSource) + ' words (highlight inside this textarea), then click <b>' + esc(actionLabel) + '</b>. Placeholders are re-numbered by text order.</div>'
