<%
  const q = (question && typeof question === 'object') ? question : {};
  const isEdit = Boolean(q.id);
  const routeId = String(q.id || '').trim();
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
  const options = (formOptions && typeof formOptions === 'object') ? formOptions : {};
  const statuses = Array.isArray(options.statuses) ? options.statuses : [];
  const testTypes = Array.isArray(options.testTypes) ? options.testTypes : [];
  const skills = Array.isArray(options.skills) ? options.skills : [];
  const difficulties = Array.isArray(options.difficulties) ? options.difficulties : [];
  const questionTypes = Array.isArray(options.questionTypes) ? options.questionTypes : [];
  const matrix = Array.isArray(typeMatrix) ? typeMatrix : [];
  const activeOrgId = String((user && user.activeOrgId) || '').trim();
  const mediaDefaultFolder = String((typeof locals.mediaDefaultFolder !== 'undefined' && locals.mediaDefaultFolder) ? locals.mediaDefaultFolder : 'PTE/Question_Bank').trim() || 'PTE/Question_Bank';
  const mediaLibraryPathText = activeOrgId
    ? (`uploads/ORG_${activeOrgId}/${mediaDefaultFolder}`)
    : `uploads/ORG_<activeOrgId>/${mediaDefaultFolder}`;
  const actionUrl = isEdit
    ? ('/pte/questions-bank/edit/' + encodeURIComponent(routeId))
    : '/pte/questions-bank/new';
  const statusToken = String(q.status || 'draft').trim().toLowerCase();
  const isCoreEditable = !isEdit || statusToken === 'draft';
  const isScoringEditable = !isEdit || statusToken === 'draft' || statusToken === 'published';
  const isPublishedScoringOnly = isEdit && statusToken === 'published';
  const isReadOnly = !isScoringEditable;
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-heading size-md m-0"><%= isEdit ? 'Edit Question' : 'New Question' %></h1>
    <div class="d-flex flex-column align-items-end gap-1">
      <% if (isEdit) { %>
        <span class="badge bg-primary border font-monospace">ID: <%= q.id %></span>
      <% } %>
      <div class="d-flex align-items-center gap-2">
        <% if (isCoreEditable) { %>
          <button type="button" class="btn btn-outline-primary btn-sm" id="qbBtnCopyFromQuestion">
            <i class="bi bi-copy me-1"></i> Copy Question
          </button>
        <% } %>
        <a href="/pte/questions-bank" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back to List</a>
      </div>
    </div>
  </div>

  <div class="form-container wide" style="max-width: 1450px;">
    <% if (isPublishedScoringOnly) { %>
      <div class="alert alert-info mb-3">
        <div class="fw-bold mb-1">Published Question: Scoring-Only Edit Mode</div>
        This question is <span class="text-capitalize"><%= statusToken %></span>. You can update fields in the <strong>Scoring / Response</strong> tab. Basic, type, and media fields are locked.
      </div>
    <% } else if (isEdit && isReadOnly) { %>
      <div class="alert alert-warning mb-3">
        <div class="fw-bold mb-1">Immutable Version</div>
        This question is <span class="text-capitalize"><%= statusToken %></span> and cannot be edited directly. Use <strong>Revise</strong> to create a new draft.
      </div>
    <% } %>

    <form
      id="pteQuestionBankForm"
      action="<%= actionUrl %>"
      method="POST"
      enctype="multipart/form-data"
    >
      <input type="hidden" name="actionStateId" id="pteQbActionStateId" value="<%= asid %>">
      <input type="hidden" name="questionPlan" id="pteQbPlanInput" value="">

      <script type="application/json" id="pteQbInitial"><%- JSON.stringify(q || {}).replace(/</g, '\\u003c') %></script>
      <script type="application/json" id="pteQbFormOptions"><%- JSON.stringify(options || {}).replace(/</g, '\\u003c') %></script>
      <script type="application/json" id="pteQbMatrix"><%- JSON.stringify(matrix || []).replace(/</g, '\\u003c') %></script>
      <script type="application/json" id="pteQbTypes"><%- JSON.stringify(questionTypes || []).replace(/</g, '\\u003c') %></script>

      <ul class="nav nav-tabs mb-4" id="pteQbTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#qb-tab-basic" type="button">Basic Info</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#qb-tab-type" type="button">Type Fields</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#qb-tab-scoring" type="button">Scoring / Response</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#qb-tab-media" type="button">Media</button></li>
      </ul>

      <div class="tab-content">
          <div class="tab-pane fade show active" id="qb-tab-basic">
            <div class="row">
              <div class="col-md-6 mb-3">
                <label class="form-label">Question Title *</label>
                <input type="text" class="form-control size-md" id="qbTitleInput" value="<%= q.title || '' %>" maxlength="260" <%= isCoreEditable ? '' : 'disabled' %>>
              </div>
              <div class="col-md-3 mb-3">
                <label class="form-label">Internal Code</label>
                <input type="text" class="form-control size-md font-monospace" id="qbCodeInput" value="<%= q.code || '' %>" maxlength="120" <%= isCoreEditable ? '' : 'disabled' %>>
              </div>
              <div class="col-md-3 mb-3">
                <label class="form-label">Status</label>
                <select class="form-select size-md text-capitalize" id="qbStatusSelect" disabled>
                  <% statuses.forEach((st) => { %>
                    <% const selected = String(st.value || '').toLowerCase() === statusToken; %>
                    <option value="<%= st.value %>" <%= selected ? 'selected' : '' %>><%= st.label || st.value %></option>
                  <% }) %>
                </select>
                <div class="form-text">Lifecycle actions are available on the list page.</div>
              </div>
            </div>

            <div class="row">
              <div class="col-md-3 mb-3">
                <label class="form-label">Test Type *</label>
                <select class="form-select size-md" id="qbTestTypeSelect" <%= isCoreEditable ? '' : 'disabled' %>>
                  <option value="">-- Select Test Type --</option>
                  <% testTypes.forEach((row) => { %>
                    <% const selected = String(row.value || '').toLowerCase() === String(q.testType || '').toLowerCase(); %>
                    <option value="<%= row.value %>" <%= selected ? 'selected' : '' %>><%= row.label || row.value %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-3 mb-3">
                <label class="form-label">Skill *</label>
                <select class="form-select size-md text-capitalize" id="qbSkillSelect" <%= isCoreEditable ? '' : 'disabled' %>>
                  <option value="">-- Select Skill --</option>
                  <% skills.forEach((skill) => { %>
                    <% const selected = String(skill.value || '').toLowerCase() === String(q.skill || '').toLowerCase(); %>
                    <option value="<%= skill.value %>" <%= selected ? 'selected' : '' %>><%= skill.label || skill.value %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-4 mb-3">
                <label class="form-label">Question Type *</label>
                <select class="form-select size-md" id="qbQuestionTypeSelect" <%= isCoreEditable ? '' : 'disabled' %>>
                  <option value="">-- Select Question Type --</option>
                </select>
                <div class="form-text" id="qbTypeHelpText">Select a test type and skill to filter question types.</div>
              </div>
              <div class="col-md-2 mb-3">
                <label class="form-label">Difficulty</label>
                <select class="form-select size-md text-capitalize" id="qbDifficultySelect" <%= isCoreEditable ? '' : 'disabled' %>>
                  <% difficulties.forEach((df) => { %>
                    <% const selected = String(df.value || '').toLowerCase() === String(q.difficulty || 'medium').toLowerCase(); %>
                    <option value="<%= df.value %>" <%= selected ? 'selected' : '' %>><%= df.label || df.value %></option>
                  <% }) %>
                </select>
              </div>
            </div>

            <div class="row">
              <div class="col-md-4 mb-3">
                <label class="form-label d-block">Practice Availability</label>
                <div class="form-check form-switch mt-1">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    id="qbPracticeEnabledSwitch"
                    <%= q.practiceEnabled === false ? '' : 'checked' %>
                    <%= isCoreEditable ? '' : 'disabled' %>>
                  <label class="form-check-label" for="qbPracticeEnabledSwitch">
                    Available in Practice Mode
                  </label>
                </div>
                <div class="form-text">Only published versions with this enabled can be selected in PTE Practice.</div>
              </div>
            </div>

            <div class="row">
              <div class="col-md-12 mb-3">
                <label class="form-label">Tags (comma-separated)</label>
                <input type="text" class="form-control size-md" id="qbTagsInput" value="<%= Array.isArray(q.tags) ? q.tags.join(', ') : '' %>" <%= isCoreEditable ? '' : 'disabled' %>>
              </div>
            </div>

            <div class="row">
              <div class="col-md-12 mb-3">
                <label class="form-label">Instructions</label>
                <textarea class="form-control size-md" id="qbInstructionsInput" rows="3" maxlength="10000" <%= isCoreEditable ? '' : 'disabled' %>><%= q.instructions || '' %></textarea>
              </div>
            </div>

            <div class="row">
              <div class="col-md-12 mb-3">
                <label class="form-label">Internal Notes</label>
                <textarea class="form-control size-md" id="qbInternalNotesInput" rows="3" maxlength="10000" <%= isCoreEditable ? '' : 'disabled' %>><%= q.internalNotes || '' %></textarea>
              </div>
            </div>
          </div>

          <div class="tab-pane fade pte-qb-type-pane" id="qb-tab-type">
            <div class="d-flex justify-content-between align-items-start mb-2">
              <h6 class="fw-bold m-0">Type-Specific Fields</h6>
              <div class="text-end">
                <button type="button" class="btn btn-outline-primary btn-sm" id="qbAiAssistBtn" title="Available for supported question types in this phase." <%= isCoreEditable ? '' : 'disabled' %>>
                  <i class="bi bi-robot me-1"></i> AI Assist
                </button>
                <div id="qbAiAssistHelpText" class="form-text mt-1 mb-0">Available for supported question types in this phase.</div>
              </div>
            </div>
            <div id="qbTypePurpose" class="form-text mb-3">Select a question type to load field behavior.</div>
            <div id="qbRequiredFieldsWrap" class="mb-4">
              <h6 class="fw-bold mb-2">Required Fields</h6>
              <div id="qbRequiredFieldsContainer"></div>
            </div>
            <div id="qbOptionalFieldsWrap">
              <h6 class="fw-bold mb-2">Optional Fields</h6>
              <div id="qbOptionalFieldsContainer"></div>
            </div>
            <div id="qbHiddenFieldsWrap" class="mt-4 d-none">
              <h6 class="fw-semibold text-muted mb-2">Hidden / Not Applicable Fields</h6>
              <div id="qbHiddenFieldsContainer" class="small text-muted"></div>
            </div>
          </div>

          <div class="tab-pane fade" id="qb-tab-scoring">
            <div class="card border-0 shadow-sm mb-3">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-2">
                  <h6 class="m-0 fw-bold"><i class="bi bi-sliders me-2"></i>Scoring Configuration</h6>
                  <button type="button" class="btn btn-outline-primary btn-sm" id="qbValidateBtn" <%= isScoringEditable ? '' : 'disabled' %>>
                    <i class="bi bi-check2-square me-1"></i> Validate Draft
                  </button>
                </div>
                <div id="qbScoringReadiness" class="alert alert-warning py-2 small d-none mb-2"></div>
                <div class="form-check form-switch mb-3">
                  <input
                    class="form-check-input"
                    type="checkbox"
                    id="qbUseQuestionScoringOverrideSwitch"
                    <%= (q.useQuestionScoringOverride === true) ? 'checked' : '' %>
                    <%= isScoringEditable ? '' : 'disabled' %>>
                  <label class="form-check-label" for="qbUseQuestionScoringOverrideSwitch">
                    Enable question-level scoring override
                  </label>
                </div>
                <div id="qbScoringModeHint" class="form-text mb-2">
                  When off, this question uses the latest global defaults for its question type. Manage global values in
                  <a href="/pte/scoring/defaults" target="_blank" rel="noopener">PTE Scoring Defaults</a>.
                </div>
                <div class="form-text mb-2">
                  Global profile version: <span class="fw-semibold" id="qbScoringProfileVersion"><%= Number(q.scoringProfileVersion || 1) %></span>
                </div>
                <div id="qbScoringContainer"></div>
              </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
              <div class="card-body">
                <h6 class="fw-bold mb-2"><i class="bi bi-diagram-3 me-2"></i>Response Contract</h6>
                <pre id="qbResponseShape" class="bg-light border rounded p-3 mb-0 small">Select a question type to view response shape.</pre>
              </div>
            </div>

            <div class="card border-0 shadow-sm">
              <div class="card-body">
                <h6 class="fw-bold mb-2"><i class="bi bi-list-check me-2"></i>Validation Rules</h6>
                <ul id="qbValidationRules" class="small mb-0"></ul>
              </div>
            </div>
          </div>

          <div class="tab-pane fade" id="qb-tab-media">
            <div class="alert alert-light border shadow-sm">
              <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                <h6 class="fw-bold mb-0"><i class="bi bi-paperclip me-2"></i>Question Media Assets</h6>
                <button type="button" id="qbBtnOpenSavedMediaLibrary" class="btn btn-outline-primary btn-sm" <%= isCoreEditable ? '' : 'disabled' %>>
                  <i class="bi bi-collection-play me-1"></i> Use Saved Media
                </button>
              </div>
              <p class="small text-muted mb-3">
                Use media assets for prompts, audio, and references. Added files are attached to this question version.
              </p>

              <div id="qbExistingMediaWrap" class="mb-3 d-none">
                <div class="fw-bold mb-2">Existing Media</div>
                <div class="table-responsive">
                  <table class="table table-sm align-middle">
                    <thead>
                      <tr>
                        <th style="width: 30%;">File</th>
                        <th style="width: 45%;">Comment</th>
                        <th style="width: 25%;" class="text-end">Actions</th>
                      </tr>
                    </thead>
                    <tbody id="qbExistingMediaBody"></tbody>
                  </table>
                </div>
              </div>

              <div id="qbFileUploadBox" class="p-4 border border-primary border-2 border-dashed rounded text-center bg-light" style="cursor: pointer;">
                <i class="bi bi-cloud-arrow-up fs-2 text-primary mb-2"></i>
                <p class="mb-1 fw-bold">Click to Browse or Drag media files here</p>
                <p class="small text-muted mb-0" id="qbFileCountText">No files selected</p>
              </div>

              <input type="file" id="qbFilesInput" name="mediaFiles" multiple class="d-none" <%= isCoreEditable ? '' : 'disabled' %>>

              <div id="qbNewFilesWrap" class="mt-3 d-none">
                <div class="fw-bold mb-2">New Uploads</div>
                <div class="table-responsive">
                  <table class="table table-sm align-middle">
                    <thead>
                      <tr>
                        <th style="width: 45%;">File</th>
                        <th style="width: 45%;">Comment</th>
                        <th style="width: 10%;" class="text-end"></th>
                      </tr>
                    </thead>
                    <tbody id="qbNewFilesBody"></tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>

      </div>

      <div class="button-row mt-4 pt-3 border-top d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div class="d-flex align-items-center flex-wrap gap-2">
          <button type="button" id="qbBtnPrevStep" class="btn btn-outline-primary btn-md" data-no-wait="true">Back</button>
          <button type="button" id="qbBtnNextStep" class="btn btn-filled btn-primary btn-md fw-bold px-4" data-no-wait="true">Next</button>
          <% if (isScoringEditable) { %>
            <button type="submit" id="qbBtnSave" class="btn btn-filled btn-success btn-md fw-bold px-4 d-none"><%= isEdit ? (isPublishedScoringOnly ? 'Update Scoring' : 'Update Draft') : 'Save Draft' %></button>
          <% } %>
          <a href="/pte/questions-bank" class="btn btn-filled btn-secondary btn-md" id="qbBtnCancel">Cancel</a>
        </div>
        <div class="d-flex align-items-center flex-wrap gap-2 ms-auto">
          <button type="button" id="qbBtnStudentPreview" class="btn btn-outline-info btn-md">
            <i class="bi bi-eye me-1"></i> Student Preview
          </button>
          <button type="button" id="qbBtnExamPreview" class="btn btn-outline-dark btn-md">
            <i class="bi bi-arrows-fullscreen me-1"></i> Exam Fullscreen
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<form id="qbExamPreviewForm" action="/pte/questions-bank/preview/exam" method="POST" target="_blank" class="d-none">
  <input type="hidden" name="actionStateId" id="qbExamPreviewActionState" value="<%= asid %>">
  <input type="hidden" name="questionPlan" id="qbExamPreviewPlan" value="">
</form>

<div class="modal fade" id="qbStudentPreviewModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold"><i class="bi bi-display me-2"></i>Student Preview</h5>
        <div class="d-flex align-items-center gap-2 ms-auto">
          <button type="button" class="btn btn-filled btn-primary btn-sm fw-bold px-3 shadow-sm" id="qbBtnRefreshPreview">
            <i class="bi bi-arrow-repeat me-1"></i> Refresh Preview
          </button>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
      </div>
      <div class="modal-body">
        <div id="qbStudentPreviewBody" class="border rounded p-3 bg-white small mb-3">
          Select a question type and click <strong>Student Preview</strong> to render how learners will see this question in test mode.
        </div>
        <div class="card border-0 shadow-sm mb-3">
          <div class="card-body">
            <h6 class="fw-bold mb-2"><i class="bi bi-eye me-2"></i>Student-Facing Preview Notes</h6>
            <div id="qbPreviewNotes" class="small text-muted">Select a question type to see preview behavior.</div>
          </div>
        </div>
        <div class="card border-0 shadow-sm">
          <div class="card-body">
            <h6 class="fw-bold mb-2">Current Draft Snapshot</h6>
            <pre id="qbPreviewSnapshot" class="bg-light border rounded p-3 small mb-0"></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/modal_MediaManager') %>
<%- include('../../partials/modal_ImageViewer') %>
<%- include('../../partials/modal_AudioPreview') %>

<div class="modal fade" id="qbAiAssistModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 12px;">
      <div class="modal-header d-flex align-items-center border-bottom-0 pb-0">
        <i class="bi bi-robot fs-4 text-primary me-2"></i>
        <h5 class="modal-title fw-bold mb-0">AI Assist Suggestions</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body py-4">
        <div id="qbAiAssistSummary" class="alert alert-light border small mb-3">
          Review generated payload and scoring suggestions and uncheck any field you do not want to apply.
        </div>
        <div id="qbAiAssistAlert" class="alert alert-light border py-2 small d-none mb-3"></div>
        <div class="table-responsive border rounded-3">
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th style="width: 6%;" class="text-center">Use</th>
                <th style="width: 16%;">Field</th>
                <th style="width: 39%;">Current Value</th>
                <th style="width: 39%;">Suggested Value</th>
              </tr>
            </thead>
            <tbody id="qbAiAssistBody">
              <tr>
                <td colspan="4" class="text-center text-muted py-4">Run AI Assist to generate suggestions.</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer border-top-0 pt-0">
        <button type="button" class="btn btn-secondary btn-filled btn-sm px-4" data-bs-dismiss="modal" id="qbAiAssistCancelBtn">Cancel</button>
        <button type="button" class="btn btn-primary btn-filled btn-sm px-4" id="qbAiAssistApplyBtn">
          <i class="bi bi-check2-square me-1"></i>Apply Selected
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/modal_GenericPicker') %>

<script>
(() => {
  const form = document.getElementById('pteQuestionBankForm');
  if (!form) return;

  const isEdit = <%= isEdit ? 'true' : 'false' %>;
  const routeId = '<%= routeId %>';
  const isCoreEditable = <%= isCoreEditable ? 'true' : 'false' %>;
  const isScoringEditable = <%= isScoringEditable ? 'true' : 'false' %>;
  const isPublishedScoringOnly = <%= isPublishedScoringOnly ? 'true' : 'false' %>;
  const previewMode = <%= previewMode ? 'true' : 'false' %>;
  const actionStateId = document.getElementById('pteQbActionStateId')?.value || '';

  const titleInput = document.getElementById('qbTitleInput');
  const codeInput = document.getElementById('qbCodeInput');
  const testTypeSelect = document.getElementById('qbTestTypeSelect');
  const skillSelect = document.getElementById('qbSkillSelect');
  const questionTypeSelect = document.getElementById('qbQuestionTypeSelect');
  const difficultySelect = document.getElementById('qbDifficultySelect');
  const practiceEnabledSwitch = document.getElementById('qbPracticeEnabledSwitch');
  const tagsInput = document.getElementById('qbTagsInput');
  const instructionsInput = document.getElementById('qbInstructionsInput');
  const internalNotesInput = document.getElementById('qbInternalNotesInput');
  const planInput = document.getElementById('pteQbPlanInput');

  const requiredFieldsContainer = document.getElementById('qbRequiredFieldsContainer');
  const optionalFieldsContainer = document.getElementById('qbOptionalFieldsContainer');
  const hiddenFieldsWrap = document.getElementById('qbHiddenFieldsWrap');
  const hiddenFieldsContainer = document.getElementById('qbHiddenFieldsContainer');
  const typePurposeNode = document.getElementById('qbTypePurpose');
  const typeHelpText = document.getElementById('qbTypeHelpText');
  const scoringContainer = document.getElementById('qbScoringContainer');
  const scoringReadinessNode = document.getElementById('qbScoringReadiness');
  const useQuestionScoringOverrideSwitch = document.getElementById('qbUseQuestionScoringOverrideSwitch');
  const scoringModeHintNode = document.getElementById('qbScoringModeHint');
  const scoringProfileVersionNode = document.getElementById('qbScoringProfileVersion');
  const responseShapeNode = document.getElementById('qbResponseShape');
  const validationRulesNode = document.getElementById('qbValidationRules');
  const previewNotesNode = document.getElementById('qbPreviewNotes');
  const previewSnapshotNode = document.getElementById('qbPreviewSnapshot');
  const studentPreviewBody = document.getElementById('qbStudentPreviewBody');
  const validateBtn = document.getElementById('qbValidateBtn');
  const aiAssistBtn = document.getElementById('qbAiAssistBtn');
  const btnRefreshPreview = document.getElementById('qbBtnRefreshPreview');
  const studentPreviewModalEl = document.getElementById('qbStudentPreviewModal');
  const studentPreviewModal = (window.bootstrap && window.bootstrap.Modal && studentPreviewModalEl)
    ? new window.bootstrap.Modal(studentPreviewModalEl)
    : null;
  const aiAssistModalEl = document.getElementById('qbAiAssistModal');
  const aiAssistModal = (window.bootstrap && window.bootstrap.Modal && aiAssistModalEl)
    ? new window.bootstrap.Modal(aiAssistModalEl)
    : null;
  const aiAssistBody = document.getElementById('qbAiAssistBody');
  const aiAssistAlert = document.getElementById('qbAiAssistAlert');
  const aiAssistSummary = document.getElementById('qbAiAssistSummary');
  const aiAssistApplyBtn = document.getElementById('qbAiAssistApplyBtn');
  const aiAssistCancelBtn = document.getElementById('qbAiAssistCancelBtn');
  const aiAssistHelpText = document.getElementById('qbAiAssistHelpText');
  const mediaManagerModalEl = document.getElementById('mediaManagerModal');
  const mediaManagerModal = (window.bootstrap && window.bootstrap.Modal && mediaManagerModalEl)
    ? new window.bootstrap.Modal(mediaManagerModalEl)
    : null;
  const mediaManagerModalApi = (window.MediaManagerModal && typeof window.MediaManagerModal.open === 'function')
    ? window.MediaManagerModal
    : null;
  const btnOpenSavedMediaLibrary = document.getElementById('qbBtnOpenSavedMediaLibrary');

