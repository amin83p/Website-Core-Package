      }

      const parsed = parseMcqSingleOptionsJsonText(nodes.optionsInput.value);
      if (parsed.error) {
        await showModal('Options Builder', parsed.error, 'warning');
        return;
      }
      const existingKeys = new Set(parsed.options.map((row) => cleanText(row.key).toLowerCase()).filter(Boolean));
      if (existingKeys.has(optionKey.toLowerCase())) {
        await showModal('Options Builder', 'Option key already exists. Use a unique key.', 'warning');
        return;
      }

      parsed.options.push({ key: optionKey, text: optionText });
      nodes.optionsInput.value = buildMcqSingleOptionsJsonText(parsed.options);
      if (keyInput) keyInput.value = '';
      if (textInput) textInput.value = '';
      syncSingleMcqBuilderFromJsonEditor();
