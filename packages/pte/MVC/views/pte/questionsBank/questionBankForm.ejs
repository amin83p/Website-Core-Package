        const key = cleanText(item.key || item.id || '');
        const text = String(item.text == null ? (item.label == null ? '' : item.label) : item.text);
        return { key, text: String(text || '') };
      }
      if (typeof item === 'string') {
        const fallbackKey = String.fromCharCode(65 + (index % 26));
        return { key: fallbackKey, text: item };
      }
      return { key: '', text: '' };
    });
  }

