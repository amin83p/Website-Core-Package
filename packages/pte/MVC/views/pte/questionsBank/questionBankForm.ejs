    const isFillBlankEditedField = isListeningFillTranscriptField || isReadingFillPassageField;
    const isListeningFillBlankMapField = scopePrefix === 'payload'
      && isListeningFillType
      && cleanText(field?.key).toLowerCase() === 'blankanswermap'
      && inputType === 'json';
    const isReadingFillBlankMapField = scopePrefix === 'payload'
      && isReadingFillType
      && cleanText(field?.key).toLowerCase() === 'blankanswermap'
