        control = ''
          + '<div class="mb-2">'
          + renderReadingWritingBlankOptionsBuilderHtml({
            inputId: id,
            answerMapValue,
            optionsMapValue: rawValue,
            disabled: isDisabled
          })
          + '</div>'
          + '<div class="border rounded p-2 bg-white">'
          + '  <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#' + esc(jsonCollapseId) + '" aria-expanded="false" aria-controls="' + esc(jsonCollapseId) + '">'
          + '    <i class="bi bi-code-slash me-1"></i> Raw JSON (Advanced)'
