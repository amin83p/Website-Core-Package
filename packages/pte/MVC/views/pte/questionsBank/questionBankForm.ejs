      const rowIndex = toInt(removeOptionBtn.getAttribute('data-mcq-option-row-index'), -1);
      if (rowIndex < 0) return;
      const parsed = parseMcqSingleOptionsJsonText(nodes.optionsInput.value);
      if (parsed.error) {
