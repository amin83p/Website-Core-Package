        const jsonCollapseId = id + '_rawJsonCollapse';
        control = ''
          + '<div class="mb-2">'
          + renderReorderParagraphBuilderHtml({
            inputId: id,
            paragraphsValue: rawValue,
            correctOrderValue: currentCorrectOrderValue,
