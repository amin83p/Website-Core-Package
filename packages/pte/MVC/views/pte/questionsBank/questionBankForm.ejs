  function sortFillBlankTokenKeys(keys = []) {
    return (Array.isArray(keys) ? keys : [])
      .map((item) => cleanText(item))
      .filter(Boolean)
      .sort((left, right) => {
        const leftMatch = left.match(/\{\{\s*(\d+)\s*\}\}/);
        const rightMatch = right.match(/\{\{\s*(\d+)\s*\}\}/);
        const leftNum = leftMatch ? Number.parseInt(leftMatch[1], 10) : Number.MAX_SAFE_INTEGER;
        const rightNum = rightMatch ? Number.parseInt(rightMatch[1], 10) : Number.MAX_SAFE_INTEGER;
        if (leftNum !== rightNum) return leftNum - rightNum;
        return left.localeCompare(right);
      });
  }

  function normalizeReadingWritingBlankOptionRows(value) {
    const rows = Array.isArray(value)
      ? value
      : String(value == null ? '' : value)
        .split(/[\n,]/)
        .map((item) => String(item || '').trim())
        .filter(Boolean);
    const out = [];
    const seen = new Set();
    rows.forEach((item) => {
      const token = cleanText(item);
      if (!token) return;
      const dedupeKey = token.toLowerCase();
      if (seen.has(dedupeKey)) return;
      seen.add(dedupeKey);
      out.push(token);
    });
    return out;
  }

  function parseReadingWritingBlankOptionsMapJsonText(rawText = '') {
    const token = String(rawText || '').trim();
    if (!token) return { map: {}, error: '' };
    let parsed = null;
    try {
      parsed = JSON.parse(token);
    } catch (_) {
      return { map: {}, error: 'Blank Options Map JSON is invalid.' };
    }
    if (!parsed || typeof parsed !== 'object' || Array.isArray(parsed)) {
      return { map: {}, error: 'Blank Options Map JSON must be an object.' };
    }
    const out = {};
    Object.keys(parsed).forEach((rawKey, index) => {
      const normalizedKey = normalizeListeningBlankToken(rawKey, index + 1);
      out[normalizedKey] = normalizeReadingWritingBlankOptionRows(parsed[rawKey]);
    });
    return { map: out, error: '' };
  }

  function normalizeReadingWritingBlankOptionsMapFromAnswerMap(answerMap = {}, optionsMap = {}) {
    const sourceAnswerMap = (answerMap && typeof answerMap === 'object' && !Array.isArray(answerMap)) ? answerMap : {};
    const sourceOptionsMap = (optionsMap && typeof optionsMap === 'object' && !Array.isArray(optionsMap)) ? optionsMap : {};
    const orderedKeys = sortFillBlankTokenKeys(Object.keys(sourceAnswerMap));
    const out = {};
    orderedKeys.forEach((blankKey) => {
      const correctAnswer = cleanText(sourceAnswerMap[blankKey]);
      const baseRows = normalizeReadingWritingBlankOptionRows(sourceOptionsMap[blankKey]);
      const merged = [];
      const seen = new Set();
      const pushOption = (rawValue) => {
        const token = cleanText(rawValue);
        if (!token) return;
        const dedupeKey = token.toLowerCase();
        if (seen.has(dedupeKey)) return;
        seen.add(dedupeKey);
        merged.push(token);
      };
      pushOption(correctAnswer);
      baseRows.forEach((row) => pushOption(row));
      out[blankKey] = merged.slice(0, 4);
    });
    return out;
  }

  function buildReadingWritingBlankOptionsMapJsonText(map = {}) {
    const sourceMap = (map && typeof map === 'object' && !Array.isArray(map)) ? map : {};
    const normalized = {};
    sortFillBlankTokenKeys(Object.keys(sourceMap)).forEach((blankKey) => {
      normalized[blankKey] = normalizeReadingWritingBlankOptionRows(sourceMap[blankKey]).slice(0, 4);
    });
    return JSON.stringify(normalized, null, 2);
  }

  function renderReadingWritingBlankOptionsRowsHtml(answerMap = {}, optionsMap = {}, disabledAttr = '') {
    const orderedKeys = sortFillBlankTokenKeys(Object.keys(answerMap || {}));
    if (!orderedKeys.length) {
      return '<tr><td colspan="3" class="small text-muted text-center py-3">Create blanks first, then add 4 options per blank.</td></tr>';
    }
    return orderedKeys.map((blankKey) => {
      const correctAnswer = cleanText(answerMap[blankKey]);
      const options = normalizeReadingWritingBlankOptionRows(optionsMap[blankKey]).slice(0, 4);
      const optionsHtml = options.length
        ? options.map((optionText, optionIndex) => {
          const isCorrect = correctAnswer && cleanText(optionText).toLowerCase() === correctAnswer.toLowerCase();
          return ''
            + '<div class="d-flex align-items-center justify-content-between gap-2 rounded border bg-white px-2 py-1 mb-1">'
            + '  <span>' + esc(optionText) + (isCorrect ? ' <span class="badge bg-success-subtle text-success-emphasis border border-success-subtle ms-1">Correct</span>' : '') + '</span>'
            + '  <button type="button" class="btn btn-sm btn-outline-danger py-0 px-1" data-rw-fib-option-remove data-rw-fib-blank-key="' + esc(blankKey) + '" data-rw-fib-option-index="' + optionIndex + '" ' + disabledAttr + '><i class="bi bi-x-lg"></i></button>'
            + '</div>';
        }).join('')
        : '<div class="small text-muted">No options yet.</div>';
      const countClass = options.length === 4 ? 'text-success' : 'text-warning';
      return ''
        + '<tr data-rw-fib-blank-key="' + esc(blankKey) + '">'
        + '  <td class="align-top">'
        + '    <div class="fw-semibold font-monospace">' + esc(blankKey) + '</div>'
        + '    <div class="small text-muted">Answer: ' + esc(correctAnswer || '(missing)') + '</div>'
        + '  </td>'
        + '  <td class="align-top">' + optionsHtml + '</td>'
        + '  <td class="align-top">'
        + '    <div class="input-group input-group-sm mb-2">'
        + '      <input type="text" class="form-control" data-rw-fib-option-new-text data-rw-fib-blank-key="' + esc(blankKey) + '" maxlength="180" placeholder="Add option... (4 total)" ' + disabledAttr + '>'
        + '      <button type="button" class="btn btn-primary" data-rw-fib-option-add data-rw-fib-blank-key="' + esc(blankKey) + '" ' + disabledAttr + '><i class="bi bi-plus-lg"></i></button>'
        + '    </div>'
        + '    <div class="small ' + countClass + '">' + options.length + '/4 options</div>'
        + '  </td>'
        + '</tr>';
    }).join('');
  }

  function renderReadingWritingBlankOptionsBuilderHtml({
    inputId,
    answerMapValue,
    optionsMapValue,
    disabled
  }) {
    const disabledAttr = disabled ? 'disabled' : '';
    const answerMap = (answerMapValue && typeof answerMapValue === 'object' && !Array.isArray(answerMapValue)) ? answerMapValue : {};
    const optionsMap = normalizeReadingWritingBlankOptionsMapFromAnswerMap(answerMap, optionsMapValue);
    return ''
      + '<div class="border rounded p-2 bg-light-subtle" data-rw-fib-builder data-rw-fib-options-input="' + esc(inputId) + '">'
      + '  <div class="d-flex align-items-center justify-content-between gap-2 mb-2">'
      + '    <div class="fw-semibold small">Per-Blank Options Builder</div>'
      + '    <div class="small text-muted">Each blank must have exactly 4 options (including the correct answer).</div>'
      + '  </div>'
      + '  <div class="small text-danger d-none mb-2" data-rw-fib-warning></div>'
      + '  <div class="table-responsive">'
      + '    <table class="table table-sm align-middle mb-0">'
      + '      <thead class="table-light">'
      + '        <tr>'
      + '          <th style="width: 18%;">Blank</th>'
      + '          <th>Options</th>'
      + '          <th style="width: 34%;">Add</th>'
      + '        </tr>'
      + '      </thead>'
      + '      <tbody data-rw-fib-options-list>'
      + renderReadingWritingBlankOptionsRowsHtml(answerMap, optionsMap, disabledAttr)
      + '      </tbody>'
      + '    </table>'
      + '  </div>'
      + '</div>';
  }

  function renderFieldControl(field, scopePrefix, sourceData) {
    const inputType = String(field.input || 'text').toLowerCase();
    const id = getFieldInputId(scopePrefix, field.key);
    const rawValue = sourceData && Object.prototype.hasOwnProperty.call(sourceData, field.key)
      ? sourceData[field.key]
      : field.default;
    const canEditField = scopePrefix === 'scoring'
      ? (isScoringEditable && state.useQuestionScoringOverride)
      : isCoreEditable;
    const disabled = canEditField ? '' : 'disabled';
    const isDisabled = disabled === 'disabled';
    const isMediaField = scopePrefix === 'payload' && getTypeMediaInputSet(getSelectedTypeDef()).has(cleanText(field.key));
    const isSingleMcqOptions = isSingleMcqOptionsField(field, scopePrefix);
    const isMultipleMcqOptions = isMultipleMcqOptionsField(field, scopePrefix);
    const isMcqOptionsBuilder = isSingleMcqOptions || isMultipleMcqOptions;
    const isSingleMcqCorrect = isSingleMcqCorrectOptionField(field, scopePrefix);
    const isMultipleMcqCorrect = isMultipleMcqCorrectOptionField(field, scopePrefix);
    const isMcqCorrectField = isSingleMcqCorrect || isMultipleMcqCorrect;
    const isListeningFillType = isListeningFillInBlankType(getSelectedTypeDef());
    const isReadingFillType = isReadingFillInBlankType(getSelectedTypeDef());
    const isReadingWritingFillType = isReadingWritingFillInBlankType(getSelectedTypeDef());
    const isReadingReorderType = cleanText(getSelectedTypeDef()?.key).toLowerCase() === 'reading_reorder_paragraphs';
    const isHighlightIncorrectWordsType = isListeningHighlightIncorrectWordsType(getSelectedTypeDef());
    const isReadingFillSourceField = scopePrefix === 'payload'
      && isReadingFillType
      && cleanText(field?.key).toLowerCase() === 'sourcepassage'
      && inputType === 'textarea';
    const isReadingFillPassageField = scopePrefix === 'payload'
      && isReadingFillType
      && cleanText(field?.key).toLowerCase() === 'passagewithblanks'
      && inputType === 'textarea';
    const isReadingWritingFillPassageField = scopePrefix === 'payload'
      && isReadingWritingFillType
      && cleanText(field?.key).toLowerCase() === 'passagewithblanks'
      && inputType === 'textarea';
    const isListeningFillTranscriptField = scopePrefix === 'payload'
