  function renderNewFiles() {
    clearNewFileObjectUrls();
    const files = Array.from((filesInput && filesInput.files) || []);
    if (!files.length) {
      newFilesWrap.classList.add('d-none');
      newFilesBody.innerHTML = '';
      fileCountText.textContent = 'No files selected';
      if (uploadBox) uploadBox.classList.remove('bg-success', 'bg-opacity-10', 'border-success');
      refreshMediaFieldSelectOptions();
      return;
    }

    newFilesWrap.classList.remove('d-none');
    fileCountText.innerHTML = '<span class="text-success fw-bold">' + files.length + ' file(s) selected.</span>';
    if (uploadBox) uploadBox.classList.add('bg-success', 'bg-opacity-10', 'border-success');

    const stagedRows = [];
    newFilesBody.innerHTML = files.map((file, index) => {
      let objectUrl = '';
      try { objectUrl = window.URL.createObjectURL(file); } catch (_) { objectUrl = ''; }
      if (objectUrl) newFileObjectUrls.push(objectUrl);
      stagedRows.push({
        id: 'NEW_UPLOAD_' + (index + 1),
        name: cleanText(file.name),
        originalName: cleanText(file.name),
        filename: cleanText(file.name),
        path: '',
        url: objectUrl,
        mimeType: cleanText(file.type, 120),
        size: Number(file.size || 0) || 0,
        uploadDate: new Date().toISOString(),
        comment: '',
        source: 'new_upload'
      });
      const downloadAction = objectUrl
        ? '<a href="' + esc(objectUrl) + '" download="' + esc(file.name) + '" class="btn btn-outline-primary btn-sm"><i class="bi bi-download"></i></a>'
        : '';
      return ''
        + '<tr>'
        + '  <td><div class="fw-bold">' + esc(file.name) + '</div><div class="x-small text-muted">' + esc(formatBytes(file.size)) + '</div></td>'
        + '  <td><input type="text" class="form-control form-control-sm" name="mediaCommentNew" data-new-media-comment="' + index + '" placeholder="Comment"></td>'
        + '  <td class="text-end"><div class="d-inline-flex gap-1">' + downloadAction + '<button type="button" class="btn btn-outline-danger btn-sm" data-remove-new-file="' + index + '"><i class="bi bi-x-lg"></i></button></div></td>'
        + '</tr>';
    }).join('');
    state.stagedMediaAssets = stagedRows;
    refreshMediaFieldSelectOptions();
