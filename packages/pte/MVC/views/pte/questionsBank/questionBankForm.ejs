          + '    <i class="bi bi-code-slash me-1"></i> Raw JSON (Advanced)'
          + '  </button>'
          + '  <div class="collapse mt-2" id="' + esc(jsonCollapseId) + '">'
          + '    <textarea class="form-control size-md font-monospace" rows="8" id="' + esc(id) + '" data-field-scope="' + esc(scopePrefix) + '" data-field-key="' + esc(field.key) + '" data-field-input="' + esc(inputType) + '" data-field-json-kind="' + esc(field.jsonKind || 'any') + '" data-reorder-paragraphs-json="true" ' + disabled + '>'
          + esc(jsonText) + '</textarea>'
