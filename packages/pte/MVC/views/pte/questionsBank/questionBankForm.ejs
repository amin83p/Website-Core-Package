  function getActiveTabTarget() {
    const active = document.querySelector('#pteQbTabs .nav-link.active');
    return active ? String(active.getAttribute('data-bs-target') || '').trim() : tabTargets[0];
  }

  function showStep(index) {
    const bounded = Math.max(0, Math.min(tabTargets.length - 1, Number(index) || 0));
    const target = tabTargets[bounded];
    const tabButton = document.querySelector('#pteQbTabs .nav-link[data-bs-target="' + target + '"]');
    if (!tabButton) return;
    const tab = (window.bootstrap && window.bootstrap.Tab) ? new window.bootstrap.Tab(tabButton) : null;
    if (tab) tab.show();
    currentStepIndex = bounded;
    refreshWizardButtons();
  }

  function refreshWizardButtons() {
    if (btnPrevStep) btnPrevStep.classList.toggle('d-none', currentStepIndex === 0);
    if (btnNextStep) btnNextStep.classList.toggle('d-none', currentStepIndex === tabTargets.length - 1);
    if (btnSave) btnSave.classList.toggle('d-none', currentStepIndex !== tabTargets.length - 1);
  }

  function buildPlan() {
    const typeDef = getSelectedTypeDef();
    if (!typeDef) throw new Error('Please select a valid question type.');
    const basePayload = (state.payloadDraft && typeof state.payloadDraft === 'object') ? state.payloadDraft : {};
    const baseScoring = (state.scoringDraft && typeof state.scoringDraft === 'object') ? state.scoringDraft : {};
    const collectedPayload = collectFieldsByScope('payload');
    const collectedScoring = collectFieldsByScope('scoring');
    const payload = {};
    const payloadKeys = Array.isArray(typeDef.payloadFields) ? typeDef.payloadFields : [];
    payloadKeys.forEach((key) => {
      const fieldKey = cleanText(key);
      if (!fieldKey) return;
      if (Object.prototype.hasOwnProperty.call(collectedPayload, fieldKey)) payload[fieldKey] = collectedPayload[fieldKey];
      else if (Object.prototype.hasOwnProperty.call(basePayload, fieldKey)) payload[fieldKey] = basePayload[fieldKey];
    });
    const scoringConfig = {};
    const scoringKeys = Array.isArray(typeDef.scoringFields)
      ? typeDef.scoringFields.map((row) => cleanText(row?.key)).filter(Boolean)
      : [];
    scoringKeys.forEach((fieldKey) => {
      if (Object.prototype.hasOwnProperty.call(collectedScoring, fieldKey)) scoringConfig[fieldKey] = collectedScoring[fieldKey];
      else if (Object.prototype.hasOwnProperty.call(baseScoring, fieldKey)) scoringConfig[fieldKey] = baseScoring[fieldKey];
    });

    const mediaComments = {};
    existingMediaBody.querySelectorAll('[data-media-comment]').forEach((input) => {
      const mediaId = cleanText(input.getAttribute('data-media-comment'));
      if (!mediaId) return;
      mediaComments[mediaId] = String(input.value || '');
    });
    const mediaAssets = state.mediaAssets.map((row) => ({
      ...row,
      comment: Object.prototype.hasOwnProperty.call(mediaComments, cleanText(row.id))
        ? mediaComments[cleanText(row.id)]
        : (row.comment || '')
    }));

    const plan = {
      code: cleanText(codeInput.value),
      title: cleanText(titleInput.value),
      testType: cleanText(testTypeSelect ? testTypeSelect.value : '').toLowerCase(),
      skill: cleanText(skillSelect.value).toLowerCase(),
      questionType: cleanText(questionTypeSelect.value).toLowerCase(),
      difficulty: cleanText(difficultySelect.value).toLowerCase() || 'medium',
      practiceEnabled: Boolean(practiceEnabledSwitch ? practiceEnabledSwitch.checked : true),
      tags: parseTags(tagsInput.value),
      instructions: String(instructionsInput.value || ''),
      internalNotes: String(internalNotesInput.value || ''),
      payload,
      scoringConfig,
      useQuestionScoringOverride: Boolean(state.useQuestionScoringOverride),
      applyScoringAsGlobal: false,
      mediaAssets
    };
    if (isEdit) {
      plan.id = routeId;
      plan.familyId = cleanText(initial.familyId);
      plan.parentVersionId = cleanText(initial.parentVersionId);
      plan.revisionNumber = Number(initial.revisionNumber || 1);
      plan.isLatestRevision = initial.isLatestRevision !== false;
      plan.status = cleanText(initial.status || 'draft').toLowerCase();
    }
    return plan;
  }

  function applyQuestionTemplate(template) {
    const source = template && typeof template === 'object' ? template : {};
    titleInput.value = cleanText(source.title);
    codeInput.value = cleanText(source.code);

    if (testTypeSelect) {
      testTypeSelect.value = cleanText(source.testType).toLowerCase();
    }
    skillSelect.value = cleanText(source.skill).toLowerCase();
    updateQuestionTypeOptions();
    questionTypeSelect.value = cleanText(source.questionType).toLowerCase();
    difficultySelect.value = cleanText(source.difficulty).toLowerCase() || 'medium';
    if (practiceEnabledSwitch) {
      practiceEnabledSwitch.checked = source.practiceEnabled !== false;
    }
    tagsInput.value = Array.isArray(source.tags) ? source.tags.map((row) => cleanText(row)).filter(Boolean).join(', ') : '';
    instructionsInput.value = String(source.instructions || '');
    internalNotesInput.value = String(source.internalNotes || '');
    state.useQuestionScoringOverride = true;
    if (useQuestionScoringOverrideSwitch) {
      useQuestionScoringOverrideSwitch.checked = true;
    }

    state.payloadDraft = (source.payload && typeof source.payload === 'object' && !Array.isArray(source.payload))
      ? JSON.parse(JSON.stringify(source.payload))
      : {};
    state.scoringDraft = (source.scoringConfig && typeof source.scoringConfig === 'object' && !Array.isArray(source.scoringConfig))
      ? JSON.parse(JSON.stringify(source.scoringConfig))
      : {};
    state.lastScoringGlobalKey = '';
    state.mediaAssets = Array.isArray(source.mediaAssets)
      ? source.mediaAssets.map((row) => (row && typeof row === 'object' ? { ...row } : row)).filter(Boolean)
      : [];

    clearNewFileObjectUrls();
    if (filesInput) {
      const dt = new DataTransfer();
      filesInput.files = dt.files;
    }

    renderTypeFields({ skipCapture: true });
    updateScoringModeHint();
    renderExistingMedia();
    renderNewFiles();
    updatePreviewSnapshot();
    refreshWizardButtons();
  }

  function openCopyFromQuestionPicker() {
    if (!isCoreEditable) return;
    if (!window.GenericPicker || typeof window.GenericPicker.open !== 'function') {
      showModal('Copy Question', 'Generic picker is not available on this page.', 'warning');
      return;
    }
    const contexts = window.GenericPickerContexts || {};
    const context = (typeof contexts.activeOrganizationScope === 'function')
      ? contexts.activeOrganizationScope({ label: 'Active Organization' })
      : null;
    const endpointQuery = new URLSearchParams();
    endpointQuery.set('status__in', 'draft,published,retired');
    endpointQuery.set('limit', '25');
    if (actionStateId) endpointQuery.set('actionStateId', actionStateId);
    const endpoint = '/pte/questions-bank?' + endpointQuery.toString();

    window.GenericPicker.open({
      title: 'Copy From Question',
      icon: 'bi-copy',
      apiEndpoint: endpoint,
      placeholder: 'Search questions to copy...',
      context,
      renderer: renderCopyQuestionItem,
      onSelect: async (item) => {
        const sourceQuestionId = cleanText(item?.id);
        if (!sourceQuestionId) return;
        if (isEdit && routeId && routeId === sourceQuestionId) {
          await showModal('Copy Question', 'Select a different question to copy from.', 'warning');
          return;
        }

        if (btnCopyFromQuestion) setButtonBusy(btnCopyFromQuestion, 'Copying...');
        try {
          const response = await fetch(
            appendActionState('/pte/questions-bank/api/template/' + encodeURIComponent(sourceQuestionId)),
            {
              headers: {
                'X-AJAX-Request': 'true',
                Accept: 'application/json'
              },
              credentials: 'include'
            }
          );
          const result = await response.json().catch(() => null);
          if (!response.ok || !result || result.status !== 'success') {
            throw new Error((result && result.message) || 'Failed to load question template.');
          }
          applyQuestionTemplate(result.template || {});
          await showModal('Template Applied', `Question data was copied from ${sourceQuestionId}. Media assets are referenced only (no duplicate upload).`, 'success');
        } catch (error) {
          await showModal('Copy Failed', error.message || 'Failed to copy question template.', 'error');
        } finally {
          restoreButton(btnCopyFromQuestion);
        }
      }
    });
  }

  async function validateBeforeSubmit() {
    if (!isScoringEditable) {
      await showModal('Read Only', 'This question version is immutable. Use Revise to create a new draft.', 'warning');
      return false;
    }
    if (!isCoreEditable) {
      try {
        const scoringOnlyPlan = buildPlan();
        if (Number(scoringOnlyPlan.scoringConfig.maxScore || 0) <= 0) {
          throw new Error('Scoring max score must be greater than 0.');
        }
        return true;
      } catch (error) {
        await showModal('Validation', error.message || 'Please review scoring fields.', 'warning');
        showStep(2);
        return false;
      }
    }
    if (!cleanText(titleInput.value)) {
      await showModal('Validation', 'Question title is required.', 'warning');
      showStep(0);
      return false;
    }
    if (!cleanText(testTypeSelect ? testTypeSelect.value : '')) {
      await showModal('Validation', 'Test type is required.', 'warning');
      showStep(0);
      return false;
    }
    if (!cleanText(skillSelect.value)) {
      await showModal('Validation', 'Skill is required.', 'warning');
      showStep(0);
      return false;
    }
    if (!cleanText(questionTypeSelect.value)) {
      await showModal('Validation', 'Question type is required.', 'warning');
      showStep(0);
      return false;
    }

    try {
      const plan = buildPlan();
      const typeDef = getSelectedTypeDef();
      const requiredFields = Array.isArray(typeDef.requiredFields) ? typeDef.requiredFields : [];
      for (const field of requiredFields) {
        const value = plan.payload[field.key];
        const inputType = String(field.input || '').toLowerCase();
        if (inputType === 'list_string') {
          if (!Array.isArray(value) || !value.length) throw new Error(field.label + ' is required.');
        } else if (inputType === 'json') {
          if (field.jsonKind === 'array' && (!Array.isArray(value) || !value.length)) throw new Error(field.label + ' is required.');
          if (field.jsonKind === 'object' && (!value || typeof value !== 'object' || Array.isArray(value) || !Object.keys(value).length)) throw new Error(field.label + ' is required.');
        } else if (inputType === 'boolean') {
          // boolean required is always present
        } else if (value === undefined || value === null || String(value).trim() === '') {
          throw new Error(field.label + ' is required.');
        }
      }
      if (Number(plan.scoringConfig.maxScore || 0) <= 0) {
        throw new Error('Scoring max score must be greater than 0.');
      }
      return true;
    } catch (error) {
      await showModal('Validation', error.message || 'Please review type-specific fields.', 'warning');
      showStep(1);
      return false;
    }
  }

  function updatePreviewSnapshot() {
    let snapshot = {};
    try {
      snapshot = buildPlan();
    } catch (_) {
      snapshot = {
        code: cleanText(codeInput.value),
        title: cleanText(titleInput.value),
        testType: cleanText(testTypeSelect ? testTypeSelect.value : ''),
        skill: cleanText(skillSelect.value),
        questionType: cleanText(questionTypeSelect.value)
      };
    }
    previewSnapshotNode.textContent = JSON.stringify(snapshot, null, 2);
    renderStudentPreview(snapshot);
    refreshScoringReadiness(getSelectedTypeDef());
  }

  async function validateViaBackend() {
    try {
      const plan = buildPlan();
      const validateActionStateId = await issueFormActionState('read-all');
      const body = new URLSearchParams();
      body.set('questionPlan', JSON.stringify(plan));
      body.set('actionStateId', validateActionStateId);
      const endpoint = appendFormActionTarget(
        '/pte/questions-bank/validate?actionStateId=' + encodeURIComponent(validateActionStateId),
        body
      );
      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'X-AJAX-Request': 'true',
          'Accept': 'application/json',
          'X-Action-State-Id': validateActionStateId
        },
        credentials: 'include',
        body: body.toString()
      });
      const result = await response.json().catch(() => null);
      if (!response.ok || !result || result.status !== 'success') {
        throw new Error((result && result.message) || ('Validation failed with status ' + response.status + '.'));
      }
      const info = result.results || {};
      if (info.isValid) {
        await showModal('Validation', 'Draft validation succeeded.', 'success');
      } else {
        await showModal('Validation', (Array.isArray(info.errors) ? info.errors.join('\n') : 'Validation failed.'), 'warning');
      }
    } catch (error) {
      await showModal('Validation Failed', error.message || 'Unexpected validation error.', 'error');
    }
  }

  async function runAiAssistForTypeFields() {
    if (!isCoreEditable || !aiAssistBtn) return;
    const selectedType = cleanText(questionTypeSelect ? questionTypeSelect.value : '').toLowerCase();
    if (!isAiAssistSupportedType(selectedType)) {
      await showModal('AI Assist', getAiAssistUnsupportedMessage(), 'warning');
      return;
    }

    let plan = null;
    try {
      plan = buildPlan();
    } catch (error) {
      await showModal('AI Assist', error.message || 'Unable to build question plan.', 'warning');
      return;
    }

    const requiredPayloadMeta = AI_ASSIST_REQUIRED_PAYLOAD_FIELDS[selectedType] || null;
    if (requiredPayloadMeta) {
      const requiredKeys = Array.isArray(requiredPayloadMeta.keys)
        ? requiredPayloadMeta.keys.map((item) => cleanText(item)).filter(Boolean)
        : [cleanText(requiredPayloadMeta.key)].filter(Boolean);
      const missingKey = requiredKeys.find((key) => !cleanText(plan?.payload?.[key]));
      if (missingKey) {
        await showModal('AI Assist', `${requiredPayloadMeta.label} is required before using AI Assist.`, 'warning');
        showStep(1);
        const requiredInput = form.querySelector('[data-field-scope="payload"][data-field-key="' + missingKey + '"]');
        if (requiredInput && typeof requiredInput.focus === 'function') requiredInput.focus();
        return;
      }
    }
    if (selectedType === 'reading_writing_fill_in_blank') {
      const blankAnswerMap = (plan?.payload?.blankAnswerMap && typeof plan.payload.blankAnswerMap === 'object' && !Array.isArray(plan.payload.blankAnswerMap))
        ? plan.payload.blankAnswerMap
        : {};
      if (!Object.keys(blankAnswerMap).length) {
        await showModal('AI Assist', 'Blank Answer Map JSON must include at least one blank before AI Assist can suggest per-blank options.', 'warning');
        showStep(1);
        const blankMapInput = form.querySelector('[data-field-scope="payload"][data-field-key="blankAnswerMap"]');
        if (blankMapInput && typeof blankMapInput.focus === 'function') blankMapInput.focus();
        return;
      }
    }

    setButtonBusy(aiAssistBtn, 'Analyzing...');
    setAiAssistWaitingModal(true);
    try {
      const stagedUploadResult = await persistStagedMediaForAiAssist();
      try {
        plan = buildPlan();
      } catch (error) {
        throw new Error(error.message || 'Unable to build question plan.');
      }
      const aiAssistActionStateId = await issueFormActionState('update');
      const body = new URLSearchParams();
      body.set('questionPlan', JSON.stringify(plan));
      body.set('actionStateId', aiAssistActionStateId);
      const endpoint = appendFormActionTarget(
        '/pte/questions-bank/ai-assist/type-fields?actionStateId=' + encodeURIComponent(aiAssistActionStateId),
        body
      );

      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'X-AJAX-Request': 'true',
          'Accept': 'application/json',
          'X-Action-State-Id': aiAssistActionStateId
        },
        credentials: 'include',
        body: body.toString()
      });

      const result = await response.json().catch(() => null);
      if (!response.ok || !result || result.status !== 'success') {
        throw new Error((result && result.message) || ('AI Assist failed with status ' + response.status + '.'));
      }

      const aiResult = (result.results && typeof result.results === 'object') ? result.results : {};
      if (aiResult.supported === false) {
        const warningMessage = Array.isArray(aiResult.warnings) && aiResult.warnings.length
          ? aiResult.warnings.join('\n')
          : (result.message || 'This question type is not supported in this phase.');
        await showModal('AI Assist', warningMessage, 'warning');
        return;
      }

      const suggestions = Array.isArray(aiResult.suggestions) ? aiResult.suggestions : [];
      if (!suggestions.length) {
        const warningMessage = Array.isArray(aiResult.warnings) && aiResult.warnings.length
          ? aiResult.warnings.join('\n')
          : 'No suggestions were generated for the current draft.';
        await showModal('AI Assist', warningMessage, 'warning');
        return;
      }

      state.aiAssistSuggestions = suggestions.map((row) => ({
        scope: cleanText(row.scope).toLowerCase() === 'scoring' ? 'scoring' : 'payload',
        fieldKey: cleanText(row.fieldKey),
        label: cleanText(row.label) || cleanText(row.fieldKey),
        inputType: cleanText(row.inputType).toLowerCase() || 'text',
        currentValue: cloneAiValue(row.currentValue),
        suggestedValue: cloneAiValue(row.suggestedValue),
        selected: true
      }));

      const providerMeta = (aiResult.providerMeta && typeof aiResult.providerMeta === 'object') ? aiResult.providerMeta : {};
      const providerLabel = cleanText(providerMeta.providerLabel || providerMeta.providerId || '');
      const modelUsed = cleanText(providerMeta.modelUsed || '');
      const payloadCount = state.aiAssistSuggestions.filter((row) => cleanText(row.scope).toLowerCase() !== 'scoring').length;
      const scoringCount = state.aiAssistSuggestions.length - payloadCount;
      const transcriptionSummary = resolveAiAssistTranscriptionSummary(aiResult.transcriptionMeta, selectedType);
      if (aiAssistSummary) {
        aiAssistSummary.innerHTML = 'Review generated suggestions and uncheck any field you do not want to apply.'
          + '<br><span class="text-muted">Payload fields: <strong>' + payloadCount + '</strong> | Scoring fields: <strong>' + scoringCount + '</strong></span>'
          + (providerLabel ? ('<br><span class="text-muted">Provider: <strong>' + esc(providerLabel) + '</strong>' + (modelUsed ? (' | Model: <strong>' + esc(modelUsed) + '</strong>') : '') + '</span>') : '')
          + (transcriptionSummary
            ? ('<br><span class="' + esc(transcriptionSummary.toneClass) + '"><i class="bi bi-file-earmark-text me-1"></i>Whole file transcribed: <strong>'
              + esc(transcriptionSummary.wholeFileLabel) + '</strong>'
              + (transcriptionSummary.message ? (' | ' + esc(transcriptionSummary.message)) : '')
              + '</span>')
            : '');
      }

      const warnings = Array.isArray(aiResult.warnings) ? aiResult.warnings.filter((item) => cleanText(item)) : [];
      const stagedUploadNotice = stagedUploadResult && Number(stagedUploadResult.uploadedCount || 0) > 0
        ? (
          Number(stagedUploadResult.attachedCount || 0) > 0
            ? `${Number(stagedUploadResult.attachedCount || 0)} staged media file(s) were uploaded and attached automatically before AI Assist.`
            : `${Number(stagedUploadResult.uploadedCount || 0)} staged media file(s) were uploaded automatically before AI Assist.`
        )
        : '';

      if (warnings.length || stagedUploadNotice) {
        const messageParts = [];
        if (stagedUploadNotice) messageParts.push(stagedUploadNotice);
        if (warnings.length) messageParts.push(warnings.join(' | '));
        showAiAssistAlert(messageParts.join(' | '), warnings.length ? 'warning' : 'info');
      } else {
        showAiAssistAlert('', 'info');
      }

      renderAiAssistRows();
      const opened = openModalCompat(aiAssistModal, aiAssistModalEl);
      if (!opened) {
        await showModal('AI Assist', 'AI Assist selection modal is not available in this environment.', 'warning');
      }
    } catch (error) {
      await showModal('AI Assist Failed', error.message || 'Unexpected AI Assist error.', 'error');
    } finally {
      setAiAssistWaitingModal(false);
      restoreButton(aiAssistBtn);
      refreshAiAssistButtonState();
    }
  }

  async function applySelectedAiSuggestions() {
    const rows = Array.isArray(state.aiAssistSuggestions) ? state.aiAssistSuggestions : [];
    if (!rows.length) {
      await showModal('AI Assist', 'No suggestions are available to apply.', 'warning');
      return;
    }

    const selectedIndexes = new Set();
    if (aiAssistBody) {
      aiAssistBody.querySelectorAll('[data-ai-assist-index]').forEach((node) => {
        const idx = Number(node.getAttribute('data-ai-assist-index'));
        if (Number.isFinite(idx) && node.checked) selectedIndexes.add(idx);
      });
    }

    if (!selectedIndexes.size) {
      await showModal('AI Assist', 'Select at least one field to apply.', 'warning');
      return;
    }

    // Snapshot current inputs so AI apply merges into the latest in-form values.
    captureCurrentFieldDrafts();
    const selectedType = cleanText(questionTypeSelect ? questionTypeSelect.value : '').toLowerCase();
    const nextPayload = {
      ...(state.payloadDraft && typeof state.payloadDraft === 'object' ? state.payloadDraft : {})
    };
    const nextScoring = {
      ...(state.scoringDraft && typeof state.scoringDraft === 'object' ? state.scoringDraft : {})
    };

    let appliedCount = 0;
    let appliedPayloadCount = 0;
    let appliedScoringCount = 0;
    rows.forEach((row, index) => {
      if (!selectedIndexes.has(index)) return;
      const scope = cleanText(row.scope).toLowerCase() === 'scoring' ? 'scoring' : 'payload';
      const key = cleanText(row.fieldKey);
      if (!key) return;
      const suggestedValue = cloneAiValue(row.suggestedValue);
      if (suggestedValue === undefined) return;
      if (scope === 'scoring') {
        nextScoring[key] = suggestedValue;
        appliedScoringCount += 1;
      } else {
        nextPayload[key] = suggestedValue;
        if (
          (selectedType === 'reading_mcq_single' || selectedType === 'reading_reorder_paragraphs' || selectedType === 'reading_writing_fill_in_blank')
          && key === 'passageTitle'
          && titleInput
          && !cleanText(titleInput.value)
          && cleanText(suggestedValue)
        ) {
          titleInput.value = cleanText(suggestedValue);
        }
        appliedPayloadCount += 1;
      }
      appliedCount += 1;
    });

    if (!appliedCount) {
      await showModal('AI Assist', 'No valid selected suggestions were found.', 'warning');
      return;
    }

    if (appliedScoringCount > 0 && !state.useQuestionScoringOverride) {
      state.useQuestionScoringOverride = true;
      if (useQuestionScoringOverrideSwitch) {
        useQuestionScoringOverrideSwitch.checked = true;
      }
      updateScoringModeHint();
    }

    state.payloadDraft = nextPayload;
    state.scoringDraft = nextScoring;
    closeModalCompat(aiAssistModal, aiAssistModalEl);
    renderTypeFields({ skipCapture: true });
    await showModal('AI Assist', `${appliedCount} field(s) were updated from AI suggestions. (${appliedPayloadCount} payload, ${appliedScoringCount} scoring)`, 'success');
  }

