  function renderTypeFields(options = {}) {
    const skipCapture = Boolean(options && options.skipCapture);
    const typeDef = getSelectedTypeDef();
    if (!skipCapture) {
      captureCurrentFieldDrafts();
    }
    requiredFieldsContainer.innerHTML = '';
    optionalFieldsContainer.innerHTML = '';
    scoringContainer.innerHTML = '';
    responseShapeNode.textContent = 'Select a question type to view response shape.';
    validationRulesNode.innerHTML = '';
    previewNotesNode.textContent = 'Select a question type to see preview behavior.';
    typePurposeNode.textContent = 'Select a question type to load field behavior.';
    hiddenFieldsWrap.classList.add('d-none');

    if (!typeDef) {
      requiredFieldsContainer.innerHTML = '<div class="text-muted">No type selected.</div>';
      optionalFieldsContainer.innerHTML = '<div class="text-muted">No optional fields available.</div>';
      scoringContainer.innerHTML = '<div class="text-muted">No scoring fields available.</div>';
      refreshScoringReadiness(null);
      updatePreviewSnapshot();
      refreshAiAssistButtonState();
      return;
    }

    typePurposeNode.innerHTML = '<div class="fw-bold mb-1">' + esc(typeDef.label || typeDef.key) + '</div><div>' + esc(typeDef.purpose || '') + '</div>';
    const payload = (state.payloadDraft && typeof state.payloadDraft === 'object') ? state.payloadDraft : {};
    const scoring = state.useQuestionScoringOverride
      ? ((state.scoringDraft && typeof state.scoringDraft === 'object') ? state.scoringDraft : {})
      : ((state.scoringGlobal && typeof state.scoringGlobal === 'object') ? state.scoringGlobal : {});

    const requiredFields = Array.isArray(typeDef.requiredFields) ? typeDef.requiredFields : [];
    const optionalFields = orderFieldsForDisplay(typeDef, Array.isArray(typeDef.optionalFields) ? typeDef.optionalFields : [], 'payload');

    requiredFieldsContainer.innerHTML = '<div class="row">' + requiredFields.map((field) => renderFieldControl(field, 'payload', payload)).join('') + '</div>';
    optionalFieldsContainer.innerHTML = optionalFields.length
      ? ('<div class="row">' + optionalFields.map((field) => renderFieldControl(field, 'payload', payload)).join('') + '</div>')
      : '<div class="text-muted">No optional fields for this type.</div>';

    const scoringFields = Array.isArray(typeDef.scoringFields) ? typeDef.scoringFields : [];
    scoringContainer.innerHTML = scoringFields.length
      ? ('<div class="row">' + scoringFields.map((field) => renderFieldControl(field, 'scoring', scoring)).join('') + '</div>')
      : '<div class="text-muted">No scoring fields defined.</div>';

    if (Array.isArray(typeDef.hiddenFields) && typeDef.hiddenFields.length) {
      hiddenFieldsWrap.classList.remove('d-none');
      hiddenFieldsContainer.textContent = typeDef.hiddenFields.join(', ');
    }

    responseShapeNode.textContent = JSON.stringify(typeDef.responseShape || {}, null, 2);
    validationRulesNode.innerHTML = (Array.isArray(typeDef.validationRules) ? typeDef.validationRules : [])
      .map((rule) => '<li>' + esc(rule) + '</li>')
      .join('') || '<li>No rules defined.</li>';
    previewNotesNode.innerHTML = (Array.isArray(typeDef.previewRules) ? typeDef.previewRules : [])
      .map((rule) => '<div class="mb-1">- ' + esc(rule) + '</div>')
      .join('') || '<div>- No preview notes.</div>';

    refreshScoringReadiness(typeDef);
    refreshMediaFieldSelectOptions();
    syncSingleMcqBuilderFromJsonEditor();
    syncReorderParagraphBuilderFromJsonEditor();
    refreshFillBlankSummary();
    syncReadingWritingBlankOptionsBuilderFromJsonEditor();
    updatePreviewSnapshot();
    refreshAiAssistButtonState();
  }

  function getSingleMcqBuilderNodes() {
    const typeDef = getSelectedTypeDef();
    const mode = getMcqBuilderMode(typeDef);
    if (!mode) return null;
    const correctFieldKey = getMcqCorrectFieldKey(mode);
    const optionsInput = form.querySelector('[data-field-scope="payload"][data-field-key="options"]');
    const correctInput = form.querySelector('[data-field-scope="payload"][data-field-key="' + cleanText(correctFieldKey) + '"]');
    if (!optionsInput || !correctInput) return null;
    const optionsInputId = cleanText(optionsInput.id);
    if (!optionsInputId) return null;
    const builder = form.querySelector('[data-mcq-builder-wrap][data-mcq-options-input="' + optionsInputId + '"]');
    if (!builder) return null;
    return { optionsInput, correctInput, builder, optionsInputId, mode, correctFieldKey };
  }

  function showSingleMcqBuilderWarning(builder, message = '') {
    if (!builder) return;
    const warningNode = builder.querySelector('[data-mcq-options-warning]');
    if (!warningNode) return;
    const token = cleanText(message);
    if (!token) {
      warningNode.classList.add('d-none');
      warningNode.textContent = '';
      return;
    }
    warningNode.classList.remove('d-none');
    warningNode.textContent = token;
  }

  function renderSingleMcqBuilderList(nodes, rows = []) {
    if (!nodes || !nodes.builder) return;
    const tbody = nodes.builder.querySelector('[data-mcq-options-list]');
    if (!tbody) return;
    const correctOptionValue = nodes.mode === 'multiple'
      ? Array.from(normalizeMcqCorrectOptionKeys('multiple', nodes.correctInput.value))
      : cleanText(nodes.correctInput.value);
    tbody.innerHTML = renderMcqSingleOptionsRowsHtml(
      rows,
      correctOptionValue,
      nodes.optionsInputId,
      nodes.optionsInput.disabled ? 'disabled' : '',
      nodes.mode
    );
  }

  function collectSingleMcqBuilderRows(nodes) {
    if (!nodes || !nodes.builder) return [];
    return Array.from(nodes.builder.querySelectorAll('tr[data-mcq-option-row-index]')).map((rowNode) => ({
      key: cleanText(rowNode.querySelector('[data-mcq-option-key]')?.value),
      text: String(rowNode.querySelector('[data-mcq-option-text]')?.value || '')
    }));
  }

  function syncSingleMcqJsonFromListEditor() {
    const nodes = getSingleMcqBuilderNodes();
    if (!nodes) return;
    const rows = collectSingleMcqBuilderRows(nodes);
    nodes.optionsInput.value = buildMcqSingleOptionsJsonText(rows);

    const keys = new Set(rows.map((row) => cleanText(row.key)).filter(Boolean));
    if (nodes.mode === 'multiple') {
      const nextCorrectOptionKeys = Array.from(nodes.builder.querySelectorAll('[data-mcq-option-correct]:checked'))
        .map((node) => toInt(node.getAttribute('data-mcq-option-row-index'), -1))
        .filter((rowIndex) => rowIndex >= 0 && rowIndex < rows.length)
        .map((rowIndex) => cleanText(rows[rowIndex].key))
        .filter((key) => key && keys.has(key));
      nodes.correctInput.value = formatMcqCorrectOptionKeysForInput('multiple', nextCorrectOptionKeys);
    } else {
      const checkedRadio = nodes.builder.querySelector('[data-mcq-option-correct]:checked');
      let nextCorrectOptionKey = cleanText(nodes.correctInput.value);
      if (checkedRadio) {
        const rowIndex = toInt(checkedRadio.getAttribute('data-mcq-option-row-index'), -1);
        if (rowIndex >= 0 && rowIndex < rows.length) {
          nextCorrectOptionKey = cleanText(rows[rowIndex].key);
        }
      }
      if (!keys.has(nextCorrectOptionKey)) {
        nextCorrectOptionKey = '';
      }
      nodes.correctInput.value = nextCorrectOptionKey;
    }
    showSingleMcqBuilderWarning(nodes.builder, '');
  }

  function syncSingleMcqBuilderFromJsonEditor() {
    const nodes = getSingleMcqBuilderNodes();
    if (!nodes) return;
    const parsed = parseMcqSingleOptionsJsonText(nodes.optionsInput.value);
    if (parsed.error) {
      showSingleMcqBuilderWarning(nodes.builder, parsed.error);
      return;
    }

    showSingleMcqBuilderWarning(nodes.builder, '');
    const keys = new Set(parsed.options.map((row) => cleanText(row.key)).filter(Boolean));
    if (nodes.mode === 'multiple') {
      const nextCorrectOptionKeys = Array.from(normalizeMcqCorrectOptionKeys('multiple', nodes.correctInput.value))
        .filter((key) => keys.has(key));
      nodes.correctInput.value = formatMcqCorrectOptionKeysForInput('multiple', nextCorrectOptionKeys);
    } else {
      const currentCorrectOptionKey = cleanText(nodes.correctInput.value);
      if (currentCorrectOptionKey && !keys.has(currentCorrectOptionKey)) {
        nodes.correctInput.value = '';
      }
    }
    renderSingleMcqBuilderList(nodes, parsed.options);
  }

  function getReorderParagraphBuilderNodes() {
    const typeDef = getSelectedTypeDef();
    if (cleanText(typeDef?.key).toLowerCase() !== 'reading_reorder_paragraphs') return null;
    const paragraphsInput = form.querySelector('[data-field-scope="payload"][data-field-key="paragraphItems"][data-reorder-paragraphs-json="true"]');
    const correctOrderInput = form.querySelector('[data-field-scope="payload"][data-field-key="correctOrder"][data-reorder-correct-order="true"]');
    if (!paragraphsInput || !correctOrderInput) return null;
    const paragraphsInputId = cleanText(paragraphsInput.id);
    if (!paragraphsInputId) return null;
    const builder = form.querySelector('[data-reorder-paragraph-builder][data-reorder-paragraph-input="' + paragraphsInputId + '"]');
    if (!builder) return null;
    return { paragraphsInput, correctOrderInput, builder, paragraphsInputId };
  }

  function showReorderParagraphBuilderWarning(builder, message = '') {
    if (!builder) return;
    const warningNode = builder.querySelector('[data-reorder-paragraph-warning]');
    if (!warningNode) return;
    const token = cleanText(message);
    if (!token) {
      warningNode.classList.add('d-none');
      warningNode.textContent = '';
      return;
    }
    warningNode.classList.remove('d-none');
    warningNode.textContent = token;
  }

  function renderReorderParagraphBuilderRows(nodes, rows = []) {
    if (!nodes || !nodes.builder) return;
    const tbody = nodes.builder.querySelector('[data-reorder-paragraph-list]');
    if (!tbody) return;
    const disabledAttr = nodes.paragraphsInput.disabled ? 'disabled' : '';
    tbody.innerHTML = renderReorderParagraphRowsHtml(rows, disabledAttr);
    const previewNode = nodes.builder.querySelector('[data-reorder-correct-order-preview]');
    if (previewNode) {
      const normalized = normalizeReorderParagraphRows(rows);
      previewNode.innerHTML = normalized.length
        ? normalized.map((row) => '<li class="mb-1">' + esc(row) + '</li>').join('')
        : '<li class="text-muted">No paragraphs yet.</li>';
