    } else if (inputType === 'number' || inputType === 'integer') {
      const step = inputType === 'integer' ? '1' : '0.000001';
      const minAttr = Number.isFinite(Number(field.min)) ? (' min="' + Number(field.min) + '"') : '';
      control = '<input type="number" step="' + step + '"' + minAttr + ' class="form-control size-md" id="' + esc(id) + '" data-field-scope="' + esc(scopePrefix) + '" data-field-key="' + esc(field.key) + '" data-field-input="' + esc(inputType) + '" value="' + esc(rawValue == null ? '' : rawValue) + '" ' + disabled + '>';
    } else if (inputType === 'boolean') {
      const checked = rawValue === true ? 'checked' : '';
