  function normalizeOptionRows(options) {
    const rows = toArray(options);
    return rows.map((item, index) => {
      if (item && typeof item === 'object' && !Array.isArray(item)) {
        const key = cleanText(item.key || item.id || String.fromCharCode(65 + index));
        return {
          key: key || String(index + 1),
          text: cleanText(item.text || item.label || item.value || '')
        };
      }
      return {
        key: String.fromCharCode(65 + index),
        text: cleanText(item)
      };
    }).filter((row) => row.text);
  }

  function renderOptionControls(options, { multiple = false } = {}) {
    const rows = normalizeOptionRows(options);
    if (!rows.length) return '<div class="text-muted small">No options configured yet.</div>';
    return rows.map((row) => {
      const inputType = multiple ? 'checkbox' : 'radio';
      const inputName = multiple ? ('ans_' + row.key) : 'answer_single';
      return ''
        + '<label class="d-flex align-items-start gap-2 mb-2">'
        + '  <input type="' + inputType + '" disabled name="' + esc(inputName) + '" class="mt-1">'
        + '  <span><span class="badge bg-light text-dark border me-2 font-monospace">' + esc(row.key) + '</span>' + esc(row.text) + '</span>'
        + '</label>';
    }).join('');
  }

  function renderSimpleList(items, emptyLabel = 'No items configured.') {
    const rows = textList(items);
    if (!rows.length) return '<div class="text-muted small">' + esc(emptyLabel) + '</div>';
    return '<ul class="mb-0 small">' + rows.map((row) => '<li>' + esc(row) + '</li>').join('') + '</ul>';
  }

  function renderMatchingRows(leftItems, rightItems) {
    const left = textList(leftItems);
    const right = textList(rightItems);
    if (!left.length || !right.length) return '<div class="text-muted small">Add left/right items to preview matching layout.</div>';
    const rightOptions = right.map((item) => '<option>' + esc(item) + '</option>').join('');
    return ''
      + '<div class="table-responsive"><table class="table table-sm align-middle mb-0">'
      + '<thead><tr><th style="width:45%;">Left</th><th style="width:55%;">Match To</th></tr></thead><tbody>'
      + left.map((item) => ''
        + '<tr>'
