<%
  const pageState = (typeof data !== 'undefined' && data && typeof data === 'object') ? data : {};
  const pageData = pageState.page || {};
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const safeJson = JSON.stringify(pageState).replace(/</g, '\\u003c');
  const hero = pageData.hero || {};
  const cta = pageData.finalCta || {};
  const overview = pageData.pteOverview || {};
  const pageJson = JSON.stringify(pageData || {});
%>

<div class="sections-page pte-public-page-settings">
  <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
    <div>
      <h1 class="page-heading size-md m-0"><i class="bi bi-window-sidebar me-2"></i><%= title || 'PTE Public Page' %></h1>
      <div class="text-muted mt-2">Manage the content shown on the public PTE landing page at <span class="font-monospace">/pte</span>.</div>
    </div>
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <a href="<%= dashboardHref %>" class="btn btn-filled btn-secondary btn-md">
        <i class="bi bi-speedometer2 me-1"></i> PTE Dashboard
      </a>
      <a href="/pte" target="_blank" rel="noopener" class="btn btn-outline-primary btn-md">
        <i class="bi bi-box-arrow-up-right me-1"></i> Preview Public Page
      </a>
    </div>
  </div>

  <div id="ptePublicPageMessage" class="alert d-none" role="status"></div>
  <div class="alert alert-info">
    Settings are saved for the configured Public PTE organization
    <span class="fw-bold font-monospace"><%= pageState.orgId || '-' %></span>.
    Slider media should use existing <span class="font-monospace">/uploads/...</span> URLs from File Manager.
  </div>

  <script id="ptePublicPageInitialData" type="application/json"><%- safeJson %></script>
  <input type="hidden" id="ptePublicPageActionStateId" value="<%= actionStateId || '' %>">

  <style>
    .pte-public-page-settings .settings-card {
      border: 1px solid #dfe7f1;
      border-radius: 1rem;
      background: #fff;
      box-shadow: 0 0.55rem 1.4rem rgba(15, 37, 70, 0.06);
      margin-bottom: 1rem;
      overflow: hidden;
    }
    .pte-public-page-settings .settings-card-header {
      background: linear-gradient(135deg, #f8fbff, #edf6f3);
      border-bottom: 1px solid #e6edf5;
      padding: 0.9rem 1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .pte-public-page-settings .settings-card-header h2 {
      font-size: 1rem;
      font-weight: 800;
      margin: 0;
    }
    .pte-public-page-settings .settings-card-body {
      padding: 1rem;
    }
    .pte-public-page-settings .settings-card.is-collapsed .settings-card-header {
      border-bottom: 0;
    }
    .pte-public-page-settings .settings-card-toggle {
      min-width: 104px;
    }
    .pte-public-page-settings .settings-card-grid {
      margin-bottom: 1.25rem;
    }
    .pte-public-page-settings .settings-card-grid .settings-card {
      margin-bottom: 0;
    }
    .pte-public-page-settings .repeatable-row {
      border: 1px solid #e4ebf4;
      border-radius: 0.85rem;
      background: #fbfdff;
      padding: 0.85rem;
      margin-bottom: 0.75rem;
    }
    .pte-public-page-settings .repeatable-row:last-child {
      margin-bottom: 0;
    }
    .pte-public-page-settings .row-tools {
      display: flex;
      justify-content: space-between;
      gap: 0.75rem;
      align-items: center;
      margin-bottom: 0.75rem;
    }
    .pte-public-page-settings textarea {
      min-height: 88px;
    }
  </style>

  <form id="ptePublicPageSettingsForm" action="/pte/public-page" method="POST">
    <input type="hidden" name="pageJson" id="ptePublicPagePageJson" value="<%= pageJson %>">
    <section class="settings-card">
      <div class="settings-card-header">
        <h2><i class="bi bi-megaphone me-2"></i>Hero</h2>
        <button type="button" class="btn btn-outline-secondary btn-sm settings-card-toggle" data-toggle-settings-card aria-expanded="true">
          <i class="bi bi-chevron-up me-1"></i><span>Collapse</span>
        </button>
      </div>
      <div class="settings-card-body">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label">Eyebrow</label>
            <input class="form-control" id="heroEyebrow" value="<%= hero.eyebrow || '' %>">
          </div>
          <div class="col-md-8">
            <label class="form-label">Title</label>
            <input class="form-control" id="heroTitle" value="<%= hero.title || '' %>">
          </div>
          <div class="col-12">
            <label class="form-label">Subtitle</label>
            <textarea class="form-control" id="heroSubtitle"><%= hero.subtitle || '' %></textarea>
          </div>
          <div class="col-md-3">
            <label class="form-label">Guest Primary Label</label>
            <input class="form-control" id="heroPrimaryLabel" value="<%= hero.primaryLabel || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Guest Primary Link</label>
            <input class="form-control" id="heroPrimaryHref" value="<%= hero.primaryHref || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Guest Secondary Label</label>
            <input class="form-control" id="heroSecondaryLabel" value="<%= hero.secondaryLabel || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Guest Secondary Link</label>
            <input class="form-control" id="heroSecondaryHref" value="<%= hero.secondaryHref || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Signed-in Primary Label</label>
            <input class="form-control" id="heroSignedInPrimaryLabel" value="<%= hero.signedInPrimaryLabel || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Signed-in Primary Link</label>
            <input class="form-control" id="heroSignedInPrimaryHref" value="<%= hero.signedInPrimaryHref || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Signed-in Secondary Label</label>
            <input class="form-control" id="heroSignedInSecondaryLabel" value="<%= hero.signedInSecondaryLabel || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Signed-in Secondary Link</label>
            <input class="form-control" id="heroSignedInSecondaryHref" value="<%= hero.signedInSecondaryHref || '' %>">
          </div>
        </div>
      </div>
    </section>

    <section class="settings-card">
      <div class="settings-card-header">
        <h2><i class="bi bi-images me-2"></i>Slider Images</h2>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="imageShowcase">
            <i class="bi bi-plus-circle me-1"></i>Add Image
          </button>
          <button type="button" class="btn btn-outline-secondary btn-sm settings-card-toggle" data-toggle-settings-card aria-expanded="true">
            <i class="bi bi-chevron-up me-1"></i><span>Collapse</span>
          </button>
        </div>
      </div>
      <div class="settings-card-body" id="imageShowcaseRows"></div>
    </section>

    <div class="row g-3 settings-card-grid">
      <div class="col-xl-6">
        <section class="settings-card h-100">
          <div class="settings-card-header">
            <h2><i class="bi bi-lightning-charge me-2"></i>Highlights</h2>
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="highlights">Add Highlight</button>
              <button type="button" class="btn btn-outline-secondary btn-sm settings-card-toggle" data-toggle-settings-card aria-expanded="true">
                <i class="bi bi-chevron-up me-1"></i><span>Collapse</span>
              </button>
            </div>
          </div>
          <div class="settings-card-body" id="highlightsRows"></div>
        </section>
      </div>
      <div class="col-xl-6">
        <section class="settings-card h-100">
          <div class="settings-card-header">
            <h2><i class="bi bi-list-ol me-2"></i>Learning Path</h2>
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="learningPath">Add Step</button>
              <button type="button" class="btn btn-outline-secondary btn-sm settings-card-toggle" data-toggle-settings-card aria-expanded="true">
                <i class="bi bi-chevron-up me-1"></i><span>Collapse</span>
              </button>
            </div>
          </div>
          <div class="settings-card-body" id="learningPathRows"></div>
        </section>
      </div>
    </div>

    <section class="settings-card">
      <div class="settings-card-header">
        <h2><i class="bi bi-grid-3x3-gap me-2"></i>Applicant Features</h2>
        <div class="d-flex align-items-center gap-2 flex-wrap">
          <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="applicantFeatures">Add Feature</button>
          <button type="button" class="btn btn-outline-secondary btn-sm settings-card-toggle" data-toggle-settings-card aria-expanded="true">
            <i class="bi bi-chevron-up me-1"></i><span>Collapse</span>
          </button>
        </div>
      </div>
      <div class="settings-card-body" id="applicantFeaturesRows"></div>
    </section>

    <section class="settings-card">
      <div class="settings-card-header">
        <h2><i class="bi bi-info-circle me-2"></i>General PTE Information</h2>
        <button type="button" class="btn btn-outline-secondary btn-sm settings-card-toggle" data-toggle-settings-card aria-expanded="true">
          <i class="bi bi-chevron-up me-1"></i><span>Collapse</span>
        </button>
      </div>
      <div class="settings-card-body">
        <label class="form-label">Overview Intro</label>
        <textarea class="form-control mb-3" id="overviewIntro"><%= overview.intro || '' %></textarea>
        <label class="form-label">Overview Points <span class="text-muted fw-normal">(one per line)</span></label>
        <textarea class="form-control" id="overviewPoints"><%= (Array.isArray(overview.points) ? overview.points : []).join('\n') %></textarea>
      </div>
    </section>

    <div class="row g-3 settings-card-grid">
      <div class="col-xl-6">
        <section class="settings-card h-100">
          <div class="settings-card-header">
            <h2><i class="bi bi-card-text me-2"></i>Test Types</h2>
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="testTypes">Add Test Type</button>
              <button type="button" class="btn btn-outline-secondary btn-sm settings-card-toggle" data-toggle-settings-card aria-expanded="true">
                <i class="bi bi-chevron-up me-1"></i><span>Collapse</span>
              </button>
            </div>
          </div>
          <div class="settings-card-body" id="testTypesRows"></div>
        </section>
      </div>
      <div class="col-xl-6">
        <section class="settings-card h-100">
          <div class="settings-card-header">
            <h2><i class="bi bi-mortarboard me-2"></i>Skill Groups</h2>
            <div class="d-flex align-items-center gap-2 flex-wrap">
              <button type="button" class="btn btn-outline-primary btn-sm" data-add-row="skillGroups">Add Skill Group</button>
              <button type="button" class="btn btn-outline-secondary btn-sm settings-card-toggle" data-toggle-settings-card aria-expanded="true">
                <i class="bi bi-chevron-up me-1"></i><span>Collapse</span>
              </button>
            </div>
          </div>
          <div class="settings-card-body" id="skillGroupsRows"></div>
        </section>
      </div>
    </div>

    <section class="settings-card">
      <div class="settings-card-header">
        <h2><i class="bi bi-send-check me-2"></i>Final Call To Action</h2>
        <button type="button" class="btn btn-outline-secondary btn-sm settings-card-toggle" data-toggle-settings-card aria-expanded="true">
          <i class="bi bi-chevron-up me-1"></i><span>Collapse</span>
        </button>
      </div>
      <div class="settings-card-body">
        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label">Guest Title</label>
            <input class="form-control" id="ctaTitle" value="<%= cta.title || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">Signed-in Title</label>
            <input class="form-control" id="ctaSignedInTitle" value="<%= cta.signedInTitle || '' %>">
          </div>
          <div class="col-md-6">
            <label class="form-label">Guest Body</label>
            <textarea class="form-control" id="ctaBody"><%= cta.body || '' %></textarea>
          </div>
          <div class="col-md-6">
            <label class="form-label">Signed-in Body</label>
            <textarea class="form-control" id="ctaSignedInBody"><%= cta.signedInBody || '' %></textarea>
          </div>
          <div class="col-md-3">
            <label class="form-label">Guest Primary Label</label>
            <input class="form-control" id="ctaPrimaryLabel" value="<%= cta.primaryLabel || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Guest Primary Link</label>
            <input class="form-control" id="ctaPrimaryHref" value="<%= cta.primaryHref || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Guest Secondary Label</label>
            <input class="form-control" id="ctaSecondaryLabel" value="<%= cta.secondaryLabel || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Guest Secondary Link</label>
            <input class="form-control" id="ctaSecondaryHref" value="<%= cta.secondaryHref || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Signed-in Primary Label</label>
            <input class="form-control" id="ctaSignedInPrimaryLabel" value="<%= cta.signedInPrimaryLabel || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Signed-in Primary Link</label>
            <input class="form-control" id="ctaSignedInPrimaryHref" value="<%= cta.signedInPrimaryHref || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Signed-in Secondary Label</label>
            <input class="form-control" id="ctaSignedInSecondaryLabel" value="<%= cta.signedInSecondaryLabel || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Signed-in Secondary Link</label>
            <input class="form-control" id="ctaSignedInSecondaryHref" value="<%= cta.signedInSecondaryHref || '' %>">
          </div>
        </div>
      </div>
    </section>

    <div class="d-flex justify-content-end gap-2 mb-4">
      <button type="button" class="btn btn-outline-secondary" id="ptePublicPageReloadBtn">
        <i class="bi bi-arrow-clockwise me-1"></i>Reload
      </button>
      <button type="submit" class="btn btn-filled btn-success" id="ptePublicPageSaveBtn">
        <i class="bi bi-check2-circle me-1"></i>Save Public Page
      </button>
    </div>
  </form>
</div>

<%- include('partials/modal') %>

<script>
(() => {
  function clean(value) {
    return String(value == null ? '' : value).trim();
  }

  function esc(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function parseJsonScript(id, fallback) {
    try {
      const node = document.getElementById(id);
      return JSON.parse((node && node.textContent) || '');
    } catch (_) {
      return fallback;
    }
  }

  function splitLines(value) {
    return String(value || '')
      .split(/\r?\n/)
      .map((line) => clean(line))
      .filter(Boolean);
  }

  async function showModal(title, message, icon) {
    if (typeof window.showMessageModal === 'function') {
      return window.showMessageModal({
        title,
        message,
        icon: icon || 'info',
        buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : 'btn-primary' }]
      });
    }
    const box = document.getElementById('ptePublicPageMessage');
    if (box) {
      box.className = 'alert ' + (icon === 'error' ? 'alert-danger' : 'alert-success');
      box.textContent = message;
      box.classList.remove('d-none');
      box.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    return 'OK';
  }

  const initial = parseJsonScript('ptePublicPageInitialData', { page: {} });
  const state = { page: initial.page || {} };

  const schemas = {
    imageShowcase: {
      container: 'imageShowcaseRows',
      empty: { src: '', alt: '', title: '', caption: '', durationMs: 4500, active: true, order: 10 },
      fields: [
        ['src', 'Image URL', 'input', 12],
        ['title', 'Title', 'input', 4],
        ['alt', 'Alt Text', 'input', 4],
        ['durationMs', 'Duration (ms)', 'number', 2],
        ['caption', 'Caption', 'textarea', 4]
      ]
    },
    highlights: {
      container: 'highlightsRows',
      empty: { value: '', label: '', active: true, order: 10 },
      fields: [
        ['value', 'Value', 'input', 4],
        ['label', 'Label', 'input', 8]
      ]
    },
    applicantFeatures: {
      container: 'applicantFeaturesRows',
      empty: { icon: 'bi-check2-circle', title: '', body: '', active: true, order: 10 },
      fields: [
        ['icon', 'Icon Class', 'input', 3],
        ['title', 'Title', 'input', 3],
        ['body', 'Body', 'textarea', 6]
      ]
    },
    learningPath: {
      container: 'learningPathRows',
      empty: { step: '', title: '', body: '', href: '', linkLabel: '', active: true, order: 10 },
      fields: [
        ['step', 'Step', 'input', 2],
        ['title', 'Title', 'input', 4],
        ['href', 'Optional Link', 'input', 3],
        ['linkLabel', 'Link Label', 'input', 3],
        ['body', 'Body', 'textarea', 12]
      ]
    },
    testTypes: {
      container: 'testTypesRows',
      empty: { title: '', body: '', active: true, order: 10 },
      fields: [
        ['title', 'Title', 'input', 4],
        ['body', 'Body', 'textarea', 8]
      ]
    },
    skillGroups: {
      container: 'skillGroupsRows',
      empty: { title: '', items: [], active: true, order: 10 },
      fields: [
        ['title', 'Skill Title', 'input', 4],
        ['items', 'Tasks (one per line)', 'lines', 8]
      ]
    }
  };

  function rowFieldHtml(key, row, field) {
    const [name, label, type, col] = field;
    const value = name === 'items' && Array.isArray(row[name]) ? row[name].join('\n') : clean(row[name]);
    const id = key + '_' + name + '_' + Math.random().toString(36).slice(2);
    const inputType = type === 'number' ? 'number' : 'text';
    if (type === 'textarea' || type === 'lines') {
      return '<div class="col-md-' + col + '">'
        + '<label class="form-label" for="' + id + '">' + esc(label) + '</label>'
        + '<textarea class="form-control" id="' + id + '" data-field="' + esc(name) + '" data-type="' + esc(type) + '">' + esc(value) + '</textarea>'
        + '</div>';
    }
    return '<div class="col-md-' + col + '">'
      + '<label class="form-label" for="' + id + '">' + esc(label) + '</label>'
      + '<input type="' + inputType + '" class="form-control" id="' + id + '" data-field="' + esc(name) + '" value="' + esc(value) + '"' + (type === 'number' ? ' min="1000" max="60000" step="100"' : '') + '>'
      + '</div>';
  }

  function renderRows(key) {
    const schema = schemas[key];
    const container = document.getElementById(schema.container);
    if (!container) return;
    const rows = Array.isArray(state.page[key]) ? state.page[key] : [];
    if (!rows.length) {
      container.innerHTML = '<div class="text-muted small border rounded p-3 bg-light">No rows yet.</div>';
      return;
    }
    container.innerHTML = rows.map((row, index) => {
      const active = row.active !== false ? ' checked' : '';
      return '<div class="repeatable-row" data-key="' + esc(key) + '" data-index="' + index + '">'
        + '<div class="row-tools">'
        + '<div class="d-flex align-items-center gap-2">'
        + '<span class="badge bg-light text-dark border">Row ' + (index + 1) + '</span>'
        + '<label class="small text-muted mb-0">Order</label>'
        + '<input type="number" class="form-control form-control-sm" style="width: 90px" data-field="order" value="' + esc(row.order || ((index + 1) * 10)) + '">'
        + '<div class="form-check form-switch mb-0">'
        + '<input class="form-check-input" type="checkbox" data-field="active"' + active + '>'
        + '<label class="form-check-label small">Active</label>'
        + '</div>'
        + '</div>'
        + '<button type="button" class="btn btn-outline-danger btn-sm" data-remove-row="' + esc(key) + '" data-index="' + index + '"><i class="bi bi-trash me-1"></i>Remove</button>'
        + '</div>'
        + '<div class="row g-3">'
        + schema.fields.map((field) => rowFieldHtml(key, row, field)).join('')
        + '</div>'
        + '</div>';
    }).join('');
  }

  function renderAllRows() {
    Object.keys(schemas).forEach(renderRows);
  }

  function collectRows(key) {
    const schema = schemas[key];
    const container = document.getElementById(schema.container);
    if (!container) return [];
    return Array.from(container.querySelectorAll('.repeatable-row')).map((rowEl) => {
      const row = {};
      row.order = Number.parseInt(clean(rowEl.querySelector('[data-field="order"]')?.value), 10) || 0;
      row.active = rowEl.querySelector('[data-field="active"]')?.checked !== false;
      schema.fields.forEach(([name, , type]) => {
        const el = rowEl.querySelector('[data-field="' + name + '"]');
        if (!el) return;
        row[name] = type === 'lines'
          ? splitLines(el.value)
          : (type === 'number'
            ? Number.parseInt(el.value, 10) || 0
            : clean(el.value));
      });
      return row;
    });
  }

  function value(id) {
    return clean(document.getElementById(id)?.value);
  }

  function collectPage() {
    return {
      hero: {
        eyebrow: value('heroEyebrow'),
        title: value('heroTitle'),
        subtitle: value('heroSubtitle'),
        primaryLabel: value('heroPrimaryLabel'),
        primaryHref: value('heroPrimaryHref'),
        secondaryLabel: value('heroSecondaryLabel'),
        secondaryHref: value('heroSecondaryHref'),
        signedInPrimaryLabel: value('heroSignedInPrimaryLabel'),
        signedInPrimaryHref: value('heroSignedInPrimaryHref'),
        signedInSecondaryLabel: value('heroSignedInSecondaryLabel'),
        signedInSecondaryHref: value('heroSignedInSecondaryHref')
      },
      imageShowcase: collectRows('imageShowcase'),
      highlights: collectRows('highlights'),
      applicantFeatures: collectRows('applicantFeatures'),
      learningPath: collectRows('learningPath'),
      pteOverview: {
        intro: value('overviewIntro'),
        points: splitLines(document.getElementById('overviewPoints')?.value || '')
      },
      testTypes: collectRows('testTypes'),
      skillGroups: collectRows('skillGroups'),
      finalCta: {
        title: value('ctaTitle'),
        body: value('ctaBody'),
        primaryLabel: value('ctaPrimaryLabel'),
        primaryHref: value('ctaPrimaryHref'),
        secondaryLabel: value('ctaSecondaryLabel'),
        secondaryHref: value('ctaSecondaryHref'),
        signedInTitle: value('ctaSignedInTitle'),
        signedInBody: value('ctaSignedInBody'),
        signedInPrimaryLabel: value('ctaSignedInPrimaryLabel'),
        signedInPrimaryHref: value('ctaSignedInPrimaryHref'),
        signedInSecondaryLabel: value('ctaSignedInSecondaryLabel'),
        signedInSecondaryHref: value('ctaSignedInSecondaryHref')
      }
    };
  }

  function syncPageJson(pageOverride = null) {
    const page = pageOverride || collectPage();
    const pageInput = document.getElementById('ptePublicPagePageJson');
    if (pageInput) pageInput.value = JSON.stringify(page);
    return page;
  }

  document.addEventListener('click', (event) => {
    const collapseBtn = event.target.closest('[data-toggle-settings-card]');
    if (collapseBtn) {
      const card = collapseBtn.closest('.settings-card');
      const body = card ? card.querySelector('.settings-card-body') : null;
      if (!card || !body) return;
      const collapsed = !card.classList.contains('is-collapsed');
      card.classList.toggle('is-collapsed', collapsed);
      body.hidden = collapsed;
      collapseBtn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
      const icon = collapseBtn.querySelector('i');
      const label = collapseBtn.querySelector('span');
      if (icon) {
        icon.classList.toggle('bi-chevron-up', !collapsed);
        icon.classList.toggle('bi-chevron-down', collapsed);
      }
      if (label) label.textContent = collapsed ? 'Expand' : 'Collapse';
      return;
    }

    const addBtn = event.target.closest('[data-add-row]');
    if (addBtn) {
      const key = addBtn.getAttribute('data-add-row');
      const schema = schemas[key];
      if (!schema) return;
      state.page[key] = collectRows(key);
      const next = { ...schema.empty, order: ((state.page[key] || []).length + 1) * 10 };
      state.page[key].push(next);
      renderRows(key);
      syncPageJson();
      return;
    }

    const removeBtn = event.target.closest('[data-remove-row]');
    if (removeBtn) {
      const key = removeBtn.getAttribute('data-remove-row');
      const index = Number.parseInt(removeBtn.getAttribute('data-index'), 10);
      if (!schemas[key] || Number.isNaN(index)) return;
      state.page[key] = collectRows(key).filter((_, rowIndex) => rowIndex !== index);
      renderRows(key);
      syncPageJson();
    }
  });

  document.getElementById('ptePublicPageReloadBtn')?.addEventListener('click', () => {
    window.location.reload();
  });

  const settingsForm = document.getElementById('ptePublicPageSettingsForm');
  settingsForm?.addEventListener('input', () => {
    syncPageJson();
  });
  settingsForm?.addEventListener('change', () => {
    syncPageJson();
  });

  settingsForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const saveBtn = document.getElementById('ptePublicPageSaveBtn');
    const originalHtml = saveBtn ? saveBtn.innerHTML : '';
    if (saveBtn) {
      saveBtn.disabled = true;
      saveBtn.innerHTML = '<i class="bi bi-hourglass-split me-1"></i>Saving...';
    }

    try {
      const pagePayload = syncPageJson();
      const response = await fetch('/pte/public-page', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-AJAX-Request': 'true'
        },
        body: JSON.stringify({
          page: pagePayload
        })
      });
      const json = await response.json();
      if (!response.ok || json.status !== 'success') {
        throw new Error(json.message || 'Unable to save PTE public page settings.');
      }
      state.page = json.data?.page || collectPage();
      renderAllRows();
      await showModal('Saved', json.message || 'PTE public page settings saved.', 'success');
    } catch (error) {
      await showModal('Save Failed', error.message || 'Unable to save PTE public page settings.', 'error');
    } finally {
      if (saveBtn) {
        saveBtn.disabled = false;
        saveBtn.innerHTML = originalHtml;
      }
    }
  });

  renderAllRows();
  syncPageJson();
})();
</script>
