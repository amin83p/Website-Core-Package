<%
  const isArchivedMode = archivedMode === true;
  const dashboardHref = typeof pteSectionDashboardHref === 'string' && pteSectionDashboardHref
    ? pteSectionDashboardHref
    : '/dashboard';
  const peopleDashboardHref = typeof ptePeopleSectionDashboardHref === 'string' && ptePeopleSectionDashboardHref
    ? ptePeopleSectionDashboardHref
    : '/dashboard/section-nav/PTE_PEOPLE';
  const secondaryManageBtn = isArchivedMode
    ? '<a href="/pte/teachers" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-list-check me-1"></i> Active Teachers</a>'
    : '<a href="/pte/teachers/archived" class="btn btn-outline-secondary btn-md mb-2"><i class="bi bi-archive me-1"></i> Archived Teachers</a>';
%>

<%- include('../../../../../../MVC/views/partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print: true,
  headerManageBtns: [
    '<a href="' + dashboardHref + '" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> PTE Dashboard</a>',
    '<a href="' + peopleDashboardHref + '" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-people-fill me-1"></i> PTE People Dashboard</a>'
  ],
  manageBtns: [
    secondaryManageBtn
  ]
}) %>

<%- include('../../../../../../MVC/views/partials/tablePages-search', {
  placeholder: 'Search teachers by teacher id, person, user, notes, or status...',
  fields: searchableFields || []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Teacher</th>
        <th>Person</th>
        <th>User Account</th>
        <th>Courses</th>
        <th>Status</th>
        <th class="text-end pe-4">Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || data.length === 0) { %>
        <tr>
          <td colspan="6" class="text-center py-4 text-muted">No teachers found.</td>
        </tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <% const display = item.display || {}; %>
        <% const courses = Array.isArray(item.courses) ? item.courses : []; %>
        <% const statusIsArchived = String(item.status || '').toLowerCase() === 'archived'; %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-dark"><%= item.teacherId || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.id || '-' %></div>
          </td>
          <td>
            <div class="fw-bold text-dark"><%= display.personName || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.personId || '-' %></div>
          </td>
          <td>
            <div class="fw-bold text-dark"><%= display.userName || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.userId || '-' %></div>
            <div class="x-small text-muted"><%= display.email || '-' %></div>
          </td>
          <td>
            <div class="small text-dark"><%= courses.length %> course(s)</div>
            <div class="x-small text-muted">
              <% if (courses.length) { %>
                <%= courses.slice(0, 2).map((row) => (row.name ? (row.name + ' (' + row.id + ')') : row.id)).join(', ') %><%= courses.length > 2 ? ', ...' : '' %>
              <% } else { %>
                -
              <% } %>
            </div>
          </td>
          <td>
            <span class="badge <%= statusIsArchived ? 'bg-secondary' : 'bg-success' %>"><%= statusIsArchived ? 'Archived' : 'Active' %></span>
          </td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= item.id %>"
                title="Row actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                <a href="/pte/teachers/edit/<%= item.id %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-pencil-square me-2"></i>Edit
                </a>
                <% if (!statusIsArchived) { %>
                  <button class="btn btn-outline-danger btn-sm delete-btn" data-id="<%= item.id %>" data-delete-url="/pte/teachers/delete/<%= item.id %>">
                    <i class="bi bi-archive me-2"></i>Archive
                  </button>
                <% } else { %>
                  <button class="btn btn-outline-success btn-sm pte-recover-btn" data-id="<%= item.id %>">
                    <i class="bi bi-arrow-counterclockwise me-2"></i>Recover
                  </button>
                <% } %>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../../../../../../MVC/views/partials/pagination', {
  pagination: pagination,
  filters: filters,
  baseUrlPath: newUrl
}) %>

<%- include('../../../../../../MVC/views/partials/tablePages-end') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const actionStateRef = document.getElementById('actionStateIdRef');
  const actionStateId = actionStateRef ? String(actionStateRef.getAttribute('data-id') || '').trim() : '';

  async function showMessage(title, message, icon = 'info') {
    if (typeof window.showMessageModal === 'function') {
      await window.showMessageModal({
        title,
        message,
        icon,
        buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : 'btn-primary' }]
      });
      return;
    }
    alert(title + ': ' + message);
  }

  document.querySelectorAll('.pte-recover-btn').forEach((button) => {
    button.addEventListener('click', async () => {
      const id = String(button.getAttribute('data-id') || '').trim();
      if (!id) return;

      button.disabled = true;
      const originalHtml = button.innerHTML;
      button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Recovering...';

      try {
        const url = '/pte/teachers/recover/' + encodeURIComponent(id)
          + '?actionStateId=' + encodeURIComponent(actionStateId);
        const response = await fetch(url, {
          method: 'POST',
          headers: {
            'X-AJAX-Request': 'true',
            'Accept': 'application/json'
          },
          credentials: 'include'
        });
        const data = await response.json();
        if (!response.ok || !data || data.status !== 'success') {
          throw new Error((data && data.message) || ('Request failed with status ' + response.status + '.'));
        }
        await showMessage('Success', data.message || 'Teacher recovered successfully.', 'success');
        window.location.reload();
      } catch (error) {
        await showMessage('Recover Failed', error.message || 'Unexpected recover error.', 'error');
        button.disabled = false;
        button.innerHTML = originalHtml;
      }
    });
  });
});
</script>
