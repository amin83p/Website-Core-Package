<%- include('../partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print,
  manageBtns: [
    `<a href="/credit" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>`
  ]
}) %>

<%- include('../partials/tablePages-search', {
  placeholder: 'Search customers...',
  fields: []
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="draggable dragable ps-4" data-column="customerCode">Customer Code <span class="sort-icon"></span></th>
        <th class="draggable dragable" data-column="personName">Person <span class="sort-icon"></span></th>
        <th class="draggable dragable" data-column="personId">Person ID <span class="sort-icon"></span></th>
        <th class="draggable dragable text-center" data-column="status">Status <span class="sort-icon"></span></th>
        <th class="text-end pe-4" data-column="actions">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if((data || []).length === 0) { %>
        <tr><td colspan="5" class="text-center py-4 text-muted">No credit customers found.</td></tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-primary"><%= item.customerCode || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.id %></div>
          </td>
          <td>
            <div class="fw-bold text-dark"><%= item.personName || '-' %></div>
            <div class="small text-muted"><%= item.personEmail || '-' %></div>
          </td>
          <td class="font-monospace small"><%= item.personId || '-' %></td>
          <td class="text-center">
            <% const s = String(item.status || '').toLowerCase(); %>
            <% if (s === 'active') { %>
              <span class="badge bg-success">ACTIVE</span>
            <% } else { %>
              <span class="badge bg-secondary"><%= String(item.status || 'INACTIVE').toUpperCase() %></span>
            <% } %>
          </td>
          <td class="table-actions text-end pe-4">
            <a href="/credit/customers/edit/<%= item.id %>" class="btn btn-sm btn-filled btn-edit">Edit</a>
            <button class="btn btn-sm btn-filled btn-delete delete-btn" data-id="<%= item.id %>">Delete</button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="credit/customers" hidden></span>

<%- include('../partials/pagination', { 
  pagination, 
  filters, 
  baseUrlPath: 'credit/customers'
}) %>
<%- include('../partials/tablePages-end') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async (event) => {
      event.preventDefault();
      const id = btn.getAttribute('data-id');
      if (!id) return;

      let approved = false;
      if (typeof showMessageModal === 'function') {
        const result = await showMessageModal({
          title: 'Confirm Deletion',
          icon: 'warning',
          message: 'Delete this customer registration?',
          buttons: [
            { text: 'Cancel', class: 'btn-secondary', value: false },
            { text: 'Delete', class: 'btn-danger', value: true }
          ]
        });
        approved = (result === true || result === 'Delete' || (result && result.value === true));
      } else {
        approved = confirm('Delete this customer registration?');
      }
      if (!approved) return;

      const response = await fetch(`/credit/customers/delete/${encodeURIComponent(id)}`, {
        method: 'DELETE',
        headers: { 'X-AJAX-Request': 'true' }
      });
      const payload = await response.json();
      if (payload.status !== 'success') {
        if (typeof showMessageModal === 'function') {
          await showMessageModal({ title: 'Error', icon: 'error', message: payload.message || 'Delete failed.', buttons: [{ text: 'OK', class: 'btn-danger' }] });
        }
        return;
      }
      window.location.reload();
    });
  });
});
</script>
