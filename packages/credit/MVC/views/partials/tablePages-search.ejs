<div class="card-container size-md">
  <%
    const resolvedReloadHref = (typeof newUrl !== 'undefined' && newUrl !== null && String(newUrl).trim())
      ? `/${String(newUrl).trim().replace(/^\/+/, '')}`
      : '';
  %>
  <div class="search-container mb-3">
    <div class="search-wrapper">
      <label for="searchField" class="form-label me-2">Search by:</label>
      <select id="searchField" class="form-select search-select me-2">
        <!-- will be written by code-->
      </select>
      <input
        type="text"
        id="searchInput"
        class="form-control search-input"
        placeholder="<%= placeholder %>">
    <div class="search-actions-inline d-inline-flex align-items-center gap-1">
      <button
        type="button"
        class="btn btn-secondary btn-filled js-open-advanced-search w-auto" 
        title="Advanced search (server-side)">
        <i class="bi bi-sliders me-1"></i>
        DB Search
      </button>
      <a
        href="<%= resolvedReloadHref || '#' %>"
        class="btn btn-filled btn-secondary w-auto"
        id="resetQueryBtn"
        onclick="if (this.getAttribute('href') === '#') { window.location.href = window.location.pathname; return false; }">
        <i class="bi bi-arrow-clockwise me-1"></i>Reload
      </a>
    </div>
    
      </div>
  </div>

  <div class="d-flex justify-content-end mb-2">
  <div class="form-check form-switch">
    <input class="form-check-input" type="checkbox" id="tableFitToggle">
    <label class="form-check-label fw-bold" for="tableFitToggle">Fit to Screen</label>
  </div>
</div>
