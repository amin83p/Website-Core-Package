<%
  const modalId = String(htmlEditorModalId || 'htmlTemplateEditorModal').trim();
  const editorId = String(htmlEditorModalEditorId || (modalId + 'Editor')).trim();
%>
<style>
  #<%= modalId %> .modal-dialog {
    width: min(1600px, 96vw);
    max-width: min(1600px, 96vw);
    height: 94vh;
    margin: 1.25rem auto;
  }
  #<%= modalId %> .modal-content {
    height: 100%;
  }
  #<%= modalId %> .modal-body {
    overflow: auto;
  }
</style>

<div class="modal fade" id="<%= modalId %>" tabindex="-1" aria-labelledby="<%= modalId %>Label" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-light">
        <h5 class="modal-title d-flex align-items-center gap-2" id="<%= modalId %>Label">
          <i class="bi bi-envelope-paper text-primary"></i>
          <span class="js-html-template-modal-title">Template Editor</span>
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-2">
        <%- include('./htmlTemplateEditor', {
          id: editorId,
          sourceId: editorId + 'Source',
          name: '_htmlTemplateModalBuffer',
          label: 'Template Content',
          value: '',
          rows: 16,
          mode: 'design',
          preview: true,
          helper: 'Saved output is stored in the target template field.',
          tokenPlaceholderText: 'Type a placeholder token (for example {{RESET_CODE}})'
        }) %>

        <div class="border rounded p-2 bg-light-subtle small d-none js-html-template-modal-tokens-wrap">
          <div class="text-muted fw-semibold mb-2">Quick Tokens</div>
          <div class="d-flex flex-wrap gap-2 js-html-template-modal-tokens"></div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary js-html-template-modal-save">
          <i class="bi bi-check2-circle me-1"></i>Save To Field
        </button>
      </div>
    </div>
  </div>
</div>
