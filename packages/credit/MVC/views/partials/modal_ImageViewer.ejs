<div class="modal fade" id="imageViewerModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-xl">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; overflow: hidden; height: 85vh; display: flex; flex-direction: column;">
      <div class="modal-header border-bottom-0 pb-2 bg-white align-items-center z-index-10">
        <h5 class="modal-title fw-bold text-dark d-flex align-items-center gap-2 text-truncate">
          <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
            <i class="bi bi-file-image"></i>
          </div>
          <span id="imgViewerTitle" class="fs-6">Image Preview</span>
        </h5>

        <div class="ms-auto d-flex align-items-center gap-2">
          <a href="#" id="imgViewerDownload" class="btn btn-sm btn-light border text-dark fw-bold rounded-pill px-3" download>
            <i class="bi bi-download me-1"></i> Download
          </a>
          <button type="button" class="btn-close ms-1" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
      </div>

      <div class="modal-body p-0 bg-secondary-subtle position-relative overflow-hidden d-flex align-items-center justify-content-center flex-grow-1 user-select-none" id="imgContainer">
        <img id="imgViewerTarget" src="" alt="Preview"
             style="max-width: 95%; max-height: 95%; transition: transform 0.2s ease-out; cursor: grab;">

        <button type="button"
                id="imgViewerPrevBtn"
                data-no-wait="true"
                class="btn btn-light border position-absolute top-50 start-0 translate-middle-y ms-3 d-none"
                onclick="ImageViewer.prev()"
                title="Previous image">
          <i class="bi bi-chevron-left fs-4"></i>
        </button>

        <button type="button"
                id="imgViewerNextBtn"
                data-no-wait="true"
                class="btn btn-light border position-absolute top-50 end-0 translate-middle-y me-3 d-none"
                onclick="ImageViewer.next()"
                title="Next image">
          <i class="bi bi-chevron-right fs-4"></i>
        </button>

        <div id="imgViewerCounter"
             class="position-absolute top-0 start-50 translate-middle-x mt-2 px-3 py-1 bg-white border rounded-pill shadow-sm small text-muted d-none"></div>

        <div class="position-absolute bottom-0 start-50 translate-middle-x mb-4 p-2 bg-white rounded-pill shadow-sm border d-flex gap-2 z-index-20">
          <button type="button" data-no-wait="true" class="btn btn-light rounded-circle btn-sm" onclick="ImageViewer.zoom(-0.2)" title="Zoom Out"><i class="bi bi-dash-lg"></i></button>
          <button type="button" data-no-wait="true" class="btn btn-light rounded-circle btn-sm" onclick="ImageViewer.reset()" title="Reset"><i class="bi bi-arrows-fullscreen"></i></button>
          <button type="button" data-no-wait="true" class="btn btn-light rounded-circle btn-sm" onclick="ImageViewer.zoom(0.2)" title="Zoom In"><i class="bi bi-plus-lg"></i></button>
          <div class="vr mx-1"></div>
          <button type="button" data-no-wait="true" class="btn btn-light rounded-circle btn-sm" onclick="ImageViewer.rotate(-90)" title="Rotate Left"><i class="bi bi-arrow-counterclockwise"></i></button>
          <button type="button" data-no-wait="true" class="btn btn-light rounded-circle btn-sm" onclick="ImageViewer.rotate(90)" title="Rotate Right"><i class="bi bi-arrow-clockwise"></i></button>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
window.ImageViewer = (() => {
  let scale = 1;
  let rotation = 0;
  let isDragging = false;
  let startX;
  let startY;
  let translateX = 0;
  let translateY = 0;
  let galleryItems = [];
  let galleryIndex = -1;

  const modalEl = document.getElementById('imageViewerModal');
  let bsModal = null;
  const imgEl = document.getElementById('imgViewerTarget');
  const titleEl = document.getElementById('imgViewerTitle');
  const downloadBtn = document.getElementById('imgViewerDownload');
  const container = document.getElementById('imgContainer');
  const prevBtn = document.getElementById('imgViewerPrevBtn');
  const nextBtn = document.getElementById('imgViewerNextBtn');
  const counterEl = document.getElementById('imgViewerCounter');

  const IMAGE_EXTENSIONS = ['.jpg', '.jpeg', '.png', '.gif', '.webp', '.svg', '.bmp', '.ico', '.tiff'];
  const AUDIO_EXTENSIONS = ['.mp3', '.wav', '.m4a', '.aac', '.ogg', '.webm', '.flac'];
  const INTERACTIVE_SELECTOR = 'button, a, .btn';

  function init() {
    if (!modalEl) return;

    modalEl.addEventListener('hidden.bs.modal', () => {
      imgEl.src = '';
      resetState();
      galleryItems = [];
      galleryIndex = -1;
      updateGalleryUi();
    });

    if (imgEl && container) {
      container.addEventListener('mousedown', (event) => {
        if (event.target && event.target.closest(INTERACTIVE_SELECTOR)) return;
        if (event.target !== imgEl && event.target !== container) return;
        isDragging = true;
        startX = event.clientX - translateX;
        startY = event.clientY - translateY;
        imgEl.style.cursor = 'grabbing';
      });

      window.addEventListener('mouseup', () => {
        isDragging = false;
        if (imgEl) imgEl.style.cursor = 'grab';
      });

      window.addEventListener('mousemove', (event) => {
        if (!isDragging) return;
        event.preventDefault();
        translateX = event.clientX - startX;
        translateY = event.clientY - startY;
        applyTransform();
      });

      container.addEventListener('wheel', (event) => {
        event.preventDefault();
        const delta = Math.sign(event.deltaY) * -0.1;
        zoom(delta);
      });
    }

    window.addEventListener('keydown', (event) => {
      if (!modalEl.classList.contains('show')) return;
      if (event.key === 'ArrowLeft') {
        prev();
      } else if (event.key === 'ArrowRight') {
        next();
      }
    });
  }

  function isFileImage(url, mimeType, filename) {
    if (mimeType && mimeType.startsWith('image/')) return true;

    if (url) {
      const cleanUrl = String(url).split('?')[0].toLowerCase();
      if (IMAGE_EXTENSIONS.some((ext) => cleanUrl.endsWith(ext))) return true;
    }

    if (filename) {
      const cleanName = String(filename).trim().toLowerCase();
      if (IMAGE_EXTENSIONS.some((ext) => cleanName.endsWith(ext))) return true;
    }

    return false;
  }

  function isFileAudio(url, mimeType, filename) {
    if (mimeType && mimeType.startsWith('audio/')) return true;

    if (url) {
      const cleanUrl = String(url).split('?')[0].toLowerCase();
      if (AUDIO_EXTENSIONS.some((ext) => cleanUrl.endsWith(ext))) return true;
    }

    if (filename) {
      const cleanName = String(filename).trim().toLowerCase();
      if (AUDIO_EXTENSIONS.some((ext) => cleanName.endsWith(ext))) return true;
    }

    return false;
  }

  function applyTransform() {
    if (!imgEl) return;
    imgEl.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale}) rotate(${rotation}deg)`;
  }

  function resetState() {
    scale = 1;
    rotation = 0;
    translateX = 0;
    translateY = 0;
    applyTransform();
  }

  function normalizeGalleryItems(gallery = []) {
    if (!Array.isArray(gallery)) return [];
    return gallery
      .map((item) => {
        if (!item || typeof item !== 'object') return null;
        const url = String(item.url || '').trim();
        if (!url) return null;
        return {
          url,
          name: String(item.name || 'Image').trim() || 'Image',
          mimeType: String(item.mimeType || '').trim()
        };
      })
      .filter(Boolean);
  }

  function updateGalleryUi() {
    const hasGallery = galleryItems.length > 1 && galleryIndex >= 0;
    if (prevBtn) prevBtn.classList.toggle('d-none', !hasGallery || galleryIndex <= 0);
    if (nextBtn) nextBtn.classList.toggle('d-none', !hasGallery || galleryIndex >= galleryItems.length - 1);
    if (counterEl) {
      counterEl.classList.toggle('d-none', !hasGallery);
      if (hasGallery) counterEl.textContent = `${galleryIndex + 1} / ${galleryItems.length}`;
    }
  }

  function showCurrentGalleryItem({ keepTransform = false } = {}) {
    if (galleryIndex < 0 || galleryIndex >= galleryItems.length) return;
    const item = galleryItems[galleryIndex];
    if (!keepTransform) resetState();
    imgEl.src = item.url;
    titleEl.textContent = item.name;
    downloadBtn.href = item.url;
    downloadBtn.download = item.name;
    updateGalleryUi();
  }

  async function open(url, filename = 'Image', mimeType = null, options = {}) {
    const fileUrl = String(url || '').trim();
    const fileName = String(filename || 'Image').trim() || 'Image';
    const fileMime = String(mimeType || '').trim();

    if (!isFileImage(fileUrl, fileMime, fileName)) {
      if (isFileAudio(fileUrl, fileMime, fileName) && window.AudioPreviewModal && typeof window.AudioPreviewModal.open === 'function') {
        window.AudioPreviewModal.open(fileUrl, fileName, fileMime || 'audio/*');
        return;
      }

      if (typeof showMessageModal === 'function') {
        const result = await showMessageModal({
          title: 'Preview Unavailable',
          message: `This file (<b>${fileName}</b>) cannot be previewed in the modal.<br><br>Do you want to open it in a new tab?`,
          icon: 'info',
          buttons: [
            { text: 'Cancel', class: 'btn-secondary' },
            { text: 'Open File', class: 'btn-primary' }
          ]
        });
        if (result === 'Open File') {
          window.open(fileUrl, '_blank');
        }
      } else if (confirm(`Preview unavailable for ${fileName}.\nOpen in new tab?`)) {
        window.open(fileUrl, '_blank');
      }
      return;
    }

    if (!bsModal) bsModal = new bootstrap.Modal(modalEl);

    const normalizedOptions = (options && typeof options === 'object') ? options : {};
    const inputGallery = normalizeGalleryItems(normalizedOptions.gallery || []);

    if (inputGallery.length > 0) {
      galleryItems = inputGallery;
      const requestedIndex = Number.parseInt(String(normalizedOptions.index), 10);
      if (Number.isFinite(requestedIndex) && requestedIndex >= 0 && requestedIndex < galleryItems.length) {
        galleryIndex = requestedIndex;
      } else {
        galleryIndex = Math.max(0, galleryItems.findIndex((item) => item.url === fileUrl));
        if (galleryIndex < 0) galleryIndex = 0;
      }
    } else {
      galleryItems = [{ url: fileUrl, name: fileName, mimeType: fileMime }];
      galleryIndex = 0;
    }

    showCurrentGalleryItem();
    bsModal.show();
  }

  function zoom(amount) {
    scale += amount;
    if (scale < 0.1) scale = 0.1;
    if (scale > 5) scale = 5;
    applyTransform();
  }

  function rotate(deg) {
    rotation += deg;
    applyTransform();
  }

  function next() {
    if (galleryIndex < 0 || galleryIndex >= galleryItems.length - 1) return;
    galleryIndex += 1;
    showCurrentGalleryItem();
  }

  function prev() {
    if (galleryIndex <= 0) return;
    galleryIndex -= 1;
    showCurrentGalleryItem();
  }

  document.addEventListener('DOMContentLoaded', init);

  return {
    open,
    zoom,
    rotate,
    reset: resetState,
    next,
    prev
  };
})();
</script>
