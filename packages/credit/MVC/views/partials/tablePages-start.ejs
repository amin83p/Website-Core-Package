<div class="sections-page">
  <div id="process-data">
    <span id="urlRef" data-id="<%= typeof newUrl !== 'undefined' && newUrl != null ? newUrl : '' %>" hidden></span>
    <span id="user-id" data-id="<%= user.id %>" hidden></span>
    <%
      const u = user || {};
      const activeOrgId = String(u.activeOrgId || u.primaryOrgId || '').trim();
      const activeOrg = Array.isArray(u.allowedOrgs)
        ? u.allowedOrgs.find((o) => String(o?.orgId || '') === activeOrgId)
        : null;
      const activeOrgName = String(
        activeOrg?.name ||
        activeOrg?.orgName ||
        activeOrg?.organizationName ||
        u.activeOrgName ||
        ''
      ).trim();
      const activeOrgRoles = Array.isArray(activeOrg?.roles) && activeOrg.roles.length
        ? activeOrg.roles
        : (activeOrg?.role ? [activeOrg.role] : []);
      const hasAdminOrgRole = activeOrgRoles
        .map((r) => String(r || '').trim().toLowerCase())
        .some((r) => ['admin', 'owner', 'superadmin', 'super_admin', 'system_admin'].includes(r));
      const adminCtx = typeof adminContext !== 'undefined' && adminContext ? adminContext : {};
      const isPrintAdmin = Boolean(adminCtx.isRequestAdmin || adminCtx.isSystemAdmin || adminCtx.isSuperAdmin || hasAdminOrgRole);
      const requestingUserName = String(
        u.identity?.displayName ||
        (u.name && typeof u.name === 'object' ? `${u.name.first || ''} ${u.name.last || ''}` : '') ||
        u.name ||
        u.username ||
        u.email ||
        u.id ||
        ''
      ).trim();
    %>
    <span id="activeOrgIdRef" data-id="<%= activeOrgId %>" hidden></span>
    <span id="activeOrgNameRef" data-name="<%= activeOrgName %>" hidden></span>
    <span id="printAdminRef" data-is-admin="<%= isPrintAdmin ? 'true' : 'false' %>" hidden></span>
    <span id="requestingUserNameRef" data-name="<%= requestingUserName %>" hidden></span>
    <% if (typeof actionStateId !== 'undefined' && actionStateId !== null) { %>
      <span id="actionStateIdRef" data-id="<%= actionStateId %>" hidden></span>
    <% } %>
    <% if (typeof tableName !== 'undefined' && tableName !== null) { %>
      <span id="tableName" data-id="<%= tableName %>" hidden></span>
    <% } %>
  </div>

  <%
    const resolvedHeaderManageBtns = (typeof headerManageBtns !== 'undefined' && Array.isArray(headerManageBtns))
      ? headerManageBtns
      : [];
    const resolvedHeadingPrefixHtml = (typeof headingPrefixHtml !== 'undefined' && headingPrefixHtml !== null)
      ? String(headingPrefixHtml)
      : '';
    const resolvedLeadingBtns = (typeof optionalLeadingBtns !== 'undefined' && Array.isArray(optionalLeadingBtns))
      ? optionalLeadingBtns
      : [];
    const resolvedManageBtns = (typeof manageBtns !== 'undefined' && Array.isArray(manageBtns))
      ? manageBtns
      : [];
    const pinDashboardToToolbar = typeof dashboardInManageRow !== 'undefined' && dashboardInManageRow;
    const useExplicitHeaderBtns = resolvedHeaderManageBtns.length > 0;

    let dashboardBtnForHeader = null;
    let nonDashboardManageBtns = [];

    if (useExplicitHeaderBtns) {
      nonDashboardManageBtns = resolvedManageBtns;
    } else {
      const dashboardBtn = pinDashboardToToolbar
        ? null
        : (resolvedManageBtns.find((btn) =>
            /dashboard/i.test(String(btn || ''))
          ) || null);
      dashboardBtnForHeader = dashboardBtn
        ? String(dashboardBtn).replace(/\bmb-2\b/g, '')
        : null;
      nonDashboardManageBtns = resolvedManageBtns.filter((btn) => btn !== dashboardBtn);
    }
  %>

  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div class="d-flex align-items-center flex-wrap gap-2">
      <% if (resolvedHeadingPrefixHtml) { %>
        <%- resolvedHeadingPrefixHtml.replace(/\bmb-2\b/g, '').trim() %>
      <% } %>
      <h1 class="page-heading size-md text-start m-0"><%= title %></h1>
    </div>
    <% if (useExplicitHeaderBtns) { %>
      <div class="d-flex align-items-center flex-wrap gap-2">
        <% resolvedHeaderManageBtns.forEach((btn) => { %>
          <%- String(btn || '').replace(/\bmb-2\b/g, '') %>
        <% }) %>
      </div>
    <% } else if (dashboardBtnForHeader) { %>
      <div class="d-flex align-items-center">
        <%- dashboardBtnForHeader %>
      </div>
    <% } %>
  </div>
  <% if (typeof belowHeadingInclude !== 'undefined' && belowHeadingInclude) { %>
    <%- include(belowHeadingInclude) %>
  <% } %>
  <% if (typeof userId !== 'undefined' && userId !== null) { %>
    <div class="text-muted small mb-2">User Id Data: <%= userId %></div>
  <% } %>

<div class="d-flex align-items-center justify-content-between mb-3 flex-wrap">
  <div class="d-flex align-items-center flex-wrap">
    <% if (resolvedLeadingBtns.length) { %>
      <% resolvedLeadingBtns.forEach(btn => { %>
        <%- btn %>
      <% }) %>
    <% } %>
    <%
      const resolvedNewHref = (typeof newHref !== 'undefined' && newHref !== null && String(newHref).trim())
        ? String(newHref).trim()
        : ((typeof newUrl !== 'undefined' && newUrl !== null && String(newUrl).trim())
          ? `/${String(newUrl).trim()}/new`
          : null);
      const resolvedNewLabel = (typeof newLabel !== 'undefined' && newLabel !== null && String(newLabel).trim())
        ? String(newLabel).trim()
        : 'New';
    %>
    <% if (typeof newLabel !== 'undefined' && newLabel !== null) { %>       
      <% if (resolvedNewHref) { %>
        <a href="<%= resolvedNewHref %>" class="btn btn-filled btn-add btn-md me-2 mb-2"><i class="bi bi-plus-circle me-1"></i><%= resolvedNewLabel %></a>
      <% } %>
    <% } %>

    <% if (typeof optionalBtnsBeforePrint !== 'undefined' && Array.isArray(optionalBtnsBeforePrint)) { %>
      <% optionalBtnsBeforePrint.forEach(btn => { %>
        <%- btn %>
      <% }) %>
    <% } %>

    <% if (typeof print !== 'undefined' && print) { %>
      <button id="printTableBtn" class="btn btn-filled btn-edit btn-md me-2 mb-2">🖨 Print</button>
    <% } %>

    <% if (typeof newLabel !== 'undefined' && newLabel !== null) { %>       
      <% if (typeof newUrl !== 'undefined' && newUrl !== null) { %>       
      <button id="openBatchModalBtn" class="btn btn-filled btn-add btn-md me-2 mb-2">📦 Import</button>
      <% } %>
    <% } %>

    <% if (typeof btn_export !== 'undefined' && btn_export !== null && btn_export) { %>
      <%
        const exportPathRaw = (typeof exportDataBaseUrl !== 'undefined' && exportDataBaseUrl != null && String(exportDataBaseUrl).trim())
          ? String(exportDataBaseUrl).trim()
          : (typeof newUrl !== 'undefined' && newUrl != null ? String(newUrl).trim() : '');
        const exportPathNorm = exportPathRaw.replace(/^\/+/, '');
        const exportDataBaseAttr = exportPathNorm ? `/${exportPathNorm}` : '';
      %>
      <button type="button" 
        class="btn btn-filled btn-success btn-md open-export-modal me-2 mb-2" 
        data-base-url="<%= exportDataBaseAttr %>"> <i class="bi bi-cloud-download me-1 mb-2"></i> Export
      </button>
    <% } %>

    <% if (typeof tableName !== 'undefined' && tableName !== null) { %>
      <button id="firstTableSettingsBtn" class="btn btn-filled btn-light btn-md me-2 mb-2">⚙ Table</button>
    <% } %>

    <% if (typeof optionalBtns !== 'undefined' && Array.isArray(optionalBtns)) { %>
      <% optionalBtns.forEach(btn => { %>
        <%- btn %>
      <% }) %>
    <% } %>
  </div>
  <div>
    <% if (nonDashboardManageBtns.length) { %>
      <% nonDashboardManageBtns.forEach(btn => { %>
        <%- btn %>
      <% }) %>
    <% } %>
</div>    
</div>

<% if (typeof print !== 'undefined' && print) { %>
<div class="modal fade" id="printSettingsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-printer me-2"></i>Print Settings</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="form-check form-switch mb-3">
          <input class="form-check-input" type="checkbox" role="switch" id="printSettingIncludeOrg" checked <%= isPrintAdmin ? '' : 'disabled' %>>
          <label class="form-check-label fw-bold" for="printSettingIncludeOrg">Show Organization</label>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold">Organization Name</label>
          <input type="text" class="form-control" id="printSettingOrgName" placeholder="Organization name" <%= isPrintAdmin ? '' : 'readonly' %>>
        </div>

        <div class="form-check form-switch mb-2">
          <input class="form-check-input" type="checkbox" role="switch" id="printSettingIncludeHeaderNote" <%= isPrintAdmin ? '' : 'disabled' %>>
          <label class="form-check-label fw-bold" for="printSettingIncludeHeaderNote">Add Custom Text</label>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold">Custom Text (Optional)</label>
          <textarea class="form-control" id="printSettingHeaderNote" rows="3" placeholder="Add any extra note to show on the print header..."></textarea>
          <div class="form-text small">This is saved in your browser for the next print.</div>
          <div class="form-text small">If you still see browser header/footer items (like a URL or date/time), disable "Headers and footers" in the print dialog.</div>
        </div>

        <div class="row g-2">
          <div class="col-6">
            <label class="form-label fw-bold">Orientation</label>
            <select class="form-select" id="printSettingOrientation" <%= isPrintAdmin ? '' : 'disabled' %>>
              <option value="landscape">Landscape</option>
              <option value="portrait">Portrait</option>
            </select>
          </div>
          <div class="col-6">
            <label class="form-label fw-bold">Density</label>
            <select class="form-select" id="printSettingDensity" <%= isPrintAdmin ? '' : 'disabled' %>>
              <option value="compact">Compact</option>
              <option value="normal">Normal</option>
            </select>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="printSettingsApplyBtn"><i class="bi bi-printer me-1"></i>Print</button>
      </div>
    </div>
  </div>
</div>
<% } %>



