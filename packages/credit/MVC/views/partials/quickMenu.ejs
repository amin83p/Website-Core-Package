<div class="modal fade" id="quickMenuModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">

      <div class="modal-header border-bottom bg-light py-3 px-4">
        <div class="input-group input-group-lg">
          <span class="input-group-text bg-transparent border-0 ps-0 text-primary">
            <i class="bi bi-search"></i>
          </span>
          <input type="text" id="quickMenuSearch" class="form-control border-0 bg-transparent shadow-none fw-bold text-dark" 
                 placeholder="Type to find a module..." autocomplete="off" style="font-size: 1.1rem;">
        </div>
      </div>

      <div class="modal-body p-0" style="height: 60vh; overflow-y: auto;">
        
        <div id="quickMenuLoading" class="text-center py-5 text-muted small">
          <div class="spinner-border spinner-border-sm text-primary mb-2" role="status"></div>
          <div>Loading modules...</div>
        </div>

        <div id="quickMenuGrid" class="list-group list-group-flush">
          </div>
        
        <div id="quickMenuEmpty" class="text-center py-5 d-none text-muted">
          <i class="bi bi-grid-fill fs-4 d-block mb-2 opacity-25"></i>
          <span id="qmEmptyMsg">No modules found.</span>
        </div>

      </div>
      
      <div class="modal-footer bg-light py-2 px-4 justify-content-between align-items-center">
        <small class="text-muted fw-bold" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.5px;">
          Quick Navigation
        </small>
        <small class="text-muted" style="font-size: 0.7rem;">
          <span class="badge bg-white border text-secondary me-1 shadow-sm">ESC</span> to close
        </small>
      </div>
    </div>
  </div>
</div>