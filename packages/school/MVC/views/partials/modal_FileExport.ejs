<style>
  .status-update {
    padding: 6px 12px;
    border-bottom: 1px solid #eee;
    font-size: 0.85rem;
  }
  .status-update:last-child {
    border-bottom: none;
  }
  /* Custom scrollbar for log window */
  #exportDetailedStatus::-webkit-scrollbar {
    width: 6px;
  }
  #exportDetailedStatus::-webkit-scrollbar-thumb {
    background-color: #ccc;
    border-radius: 4px;
  }
</style>

<div class="modal fade" id="fileExportModal" tabindex="-100" aria-labelledby="fileExportModalLabel" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 550px;">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">

      <div class="modal-header border-bottom-0 pb-0 bg-white">
        <h5 class="modal-title fw-bold text-primary" id="fileExportModalLabel">
          <i class="bi bi-cloud-download-fill me-2"></i>Export Data
        </h5>
        <button type="button" class="btn-close close-on-complete" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body pt-2">
        
        <div class="alert alert-light border shadow-sm d-flex align-items-center p-3 mb-4 rounded-3">
          <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center me-3" 
               style="width: 48px; height: 48px; min-width: 48px;">
            <i class="bi bi-file-earmark-spreadsheet fs-4"></i>
          </div>
          <div>
            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">
                Data Extraction
            </div>
            <div class="fw-bold fs-5 text-dark">Download Records</div>
          </div>
        </div>

        <form id="fileExportForm">
          <input type="hidden" name="filters" id="exportFilters">

          <div id="exportSetupContent">
            
            <div class="mb-4">
              <label class="form-label fw-bold text-secondary small text-uppercase">1. Choose Source</label>
              
              <div class="list-group shadow-sm rounded-3">
                <label class="list-group-item list-group-item-action d-flex gap-3 py-3" style="cursor: pointer;">
                  <input class="form-check-input flex-shrink-0" type="radio" name="exportSource" id="sourcePage" value="page" checked style="font-size: 1.2rem;">
                  <span class="d-flex gap-2 w-100 justify-content-between">
                    <span>
                      <span class="fw-bold d-block text-dark">Visible Table (Current Page)</span>
                      <small class="text-muted">Fast. Exports exactly what you see on screen.</small>
                    </span>
                    <i class="bi bi-eye text-muted fs-5"></i>
                  </span>
                </label>

                <label class="list-group-item list-group-item-action d-flex gap-3 py-3" style="cursor: pointer;">
                  <input class="form-check-input flex-shrink-0" type="radio" name="exportSource" id="sourceDB" value="db" style="font-size: 1.2rem;">
                  <span class="d-flex gap-2 w-100 justify-content-between">
                    <span>
                      <span class="fw-bold d-block text-dark">Full Database (Server)</span>
                      <small class="text-muted">Secure. Exports all matching records. <span class="badge bg-warning text-dark scale-75">Admin</span></small>
                    </span>
                    <i class="bi bi-database text-muted fs-5"></i>
                  </span>
                </label>
              </div>
            </div>

            <div class="mb-2">
              <label for="exportFormat" class="form-label fw-bold text-secondary small text-uppercase">2. Choose Format</label>
              <div class="input-group">
                <span class="input-group-text bg-light border-end-0"><i class="bi bi-filetype-csv"></i></span>
                <select class="form-select border-start-0 ps-0" id="exportFormat" name="exportFormat">
                    <option value="csv" selected>CSV (Excel Compatible)</option>
                    <option value="json">JSON (Structured Data)</option>
                </select>
              </div>
            </div>
          </div>

          <div id="exportProgressContent" style="display:none;">
            <div class="d-flex justify-content-between mb-1">
                <span class="fw-bold text-primary small">Exporting...</span>
                <span class="small text-muted" id="exportPercentText">0%</span>
            </div>
            <div id="exportProgress" class="progress mb-3" style="height: 10px;">
              <div id="exportProgressBar" class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 0%"></div>
            </div>
            
            <div class="card bg-light border-0">
                <div class="card-header bg-transparent border-bottom-0 py-1 px-3">
                    <small class="text-muted fw-bold">Process Log</small>
                </div>
                <div id="exportDetailedStatus" class="card-body p-0" style="height: 150px; overflow-y: auto; font-family: monospace;">
                    </div>
            </div>
          </div>
          
        </form>
      </div>

      <div class="modal-footer bg-light border-top-0 py-3">
        <button type="button" class="btn btn-secondary btn-sm rounded-pill px-4 close-on-complete" data-bs-dismiss="modal" id="closeExportModalBtn" style="display:none;">Close</button>
        
        <a id="downloadExportBtn" class="btn btn-success btn-sm rounded-pill px-4 shadow-sm" style="display:none;" href="#">
            <i class="bi bi-download me-2"></i>Save File
        </a>

        <button type="button" class="btn btn-secondary btn-sm rounded-pill px-4" data-bs-dismiss="modal" id="cancelExportBtn">Cancel</button>
        <button type="submit" class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm" id="startExportBtn" form="fileExportForm">
            Start Export <i class="bi bi-arrow-right ms-1"></i>
        </button>
      </div>

    </div>
  </div>
</div>