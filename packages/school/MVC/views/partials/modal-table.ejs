<div class="modal fade" id="tableSettingsModal" tabindex="-100">
  <div class="modal-dialog modal-lg modal-dialog-centered"> 
    <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">

      <div class="modal-header border-bottom-0 pb-0 bg-white">
        <h5 class="modal-title fw-bold text-primary">
            <i class="bi bi-sliders me-2"></i>Customize View
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>

      <div class="modal-body pt-2">

        <div class="alert alert-light border shadow-sm d-flex align-items-center p-3 mb-4 rounded-3">
            <div class="rounded-circle bg-info-subtle text-info d-flex align-items-center justify-content-center me-3" 
                 style="width: 48px; height: 48px; min-width: 48px;">
              <i class="bi bi-table fs-4"></i>
            </div>
            <div>
              <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">
                  Display Settings
              </div>
              <div class="fw-bold fs-5 text-dark">Column Configuration</div>
            </div>
        </div>

        <div class="border rounded-3 overflow-hidden bg-white shadow-sm">
            <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                <table class="table table-hover table-striped mb-0 align-middle" id="columnSettingsTable">
                <thead class="table-light sticky-top">
                    <tr class="text-uppercase small text-muted">
                    <th class="ps-3" style="width: 60px;">Move</th>
                    <th class="text-center" style="width: 60px;">Show</th>
                    <th>Original Name</th>
                    <th>Custom Label</th>
                    <th style="width: 120px;">Width (px)</th> 
                    </tr>
                </thead>
                <tbody class="border-top-0">
                    </tbody>
                </table>
            </div>
        </div>
      </div>

      <div class="modal-footer bg-light border-top-0 py-3 d-flex justify-content-between">
        <button id="resetSettings" class="btn btn-warning btn-sm rounded-pill px-4 shadow-sm text-dark">
            <i class="bi bi-arrow-counterclockwise me-1"></i> Reset Default
        </button>

        <div>
            <button id="cancelSettings" class="btn btn-secondary btn-sm rounded-pill px-4 me-2" data-bs-dismiss="modal">Cancel</button>
            <button id="saveSettings" class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm">
                <i class="bi bi-check-lg me-1"></i> Save Changes
            </button>
        </div>
      </div>

    </div>
  </div>
</div>

<div class="modal fade" id="tableSearchModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-md modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">
          <i class="bi bi-search me-2 text-primary"></i>
          Advanced search
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <form id="tableSearchModalForm">
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label" for="tsmQuery">Query</label>
            <input class="form-control" id="tsmQuery" name="q" placeholder="Type something...">
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label" for="tsmField">Search in</label>
              <select class="form-select" id="tsmField" name="searchFields">
                <option value="">All fields</option>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label" for="tsmType">Match</label>
              <select class="form-select" id="tsmType" name="type">
                <option value="contains" selected>Contains</option>
                <option value="startswith">Starts with</option>
                <option value="exactmatch">Exact match</option>
              </select>
            </div>
          </div>

          <div class="form-text text-muted mt-2">
            This runs on the server and can filter beyond the rows currently shown.
          </div>
        </div>

        <div class="modal-footer">
          <button type="button" class="btn btn-secondary btn-filled" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary btn-filled">
            <i class="bi bi-funnel me-1"></i>
            Apply
          </button>
        </div>
      </form>
    </div>

  </div>


</div>
  <script type="application/json" id="tableSearchConfigJson">
    <%
      const _isDefined = typeof searchableFields !== 'undefined' && searchableFields !== null;
    %>
    <%- JSON.stringify({
      searchableFields: _isDefined? searchableFields : []
    }) %>
  </script>
