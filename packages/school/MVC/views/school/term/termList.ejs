<%- include('partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print: true,
  headerManageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>',
    '<a href="/dashboard/section-nav/SCHOOL_ACADEMIA" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-backpack2 me-1"></i> School Academia</a>'
  ],
  manageBtns: [
    `
      <a href="/school/terms/new-wizard" class="btn btn-filled btn-primary btn-md mb-2">
        <i class="bi bi-signpost-split me-1"></i> Wizard
      </a>
  `]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search terms...',
  fields: []
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Code / Name</th>
        <th>Period</th>
        <th>Operational Dates</th>
        <th>Status</th>
        <th>Description</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (data.length === 0) { %>
        <tr><td colspan="6" class="text-center py-4 text-muted">No terms found.</td></tr>
      <% } %>
      <% data.forEach(item => { %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-dark"><%= item.name %></div>
            <div class="x-small text-muted font-monospace"><%= item.code || 'NO-CODE' %> | <%= item.id %></div>
          </td>
          <td>
            <div class="small fw-bold text-dark"><%= item.startDate || '-' %></div>
            <div class="x-small text-muted">to <%= item.endDate || '-' %></div>
          </td>
          <td>
            <div class="x-small text-muted">Classes</div>
            <div class="small text-dark"><%= item.classesStartDate || '-' %> to <%= item.classesEndDate || '-' %></div>
            <div class="x-small text-muted mt-1">Add/Drop: <%= item.addDropDeadline || '-' %></div>
            <div class="x-small text-muted">Payment Due: <%= item.paymentDueDate || '-' %></div>
          </td>
          <td>
            <% let badge = 'bg-secondary'; %>
            <% if (item.status === 'active' || item.status === 'started') badge = 'bg-success'; %>
            <% if (item.status === 'draft' || item.status === 'planned') badge = 'bg-warning text-dark'; %>
            <% if (item.status === 'finished') badge = 'bg-info text-dark'; %>
            <% if (item.status === 'cancelled' || item.status === 'archived') badge = 'bg-danger'; %>
            <span class="badge <%= badge %>"><%= (item.status || 'unknown').toUpperCase() %></span>
          </td>
          <td>
            <div class="small text-muted"><%= item.description || '-' %></div>
          </td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= item.id %>"
                title="Term Actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                <a href="/school/terms/edit-wizard/<%= item.id %>" class="btn btn-outline-info btn-sm">
                  <i class="bi bi-magic me-2"></i>Wizard
                </a>
                <a href="/school/terms/edit/<%= item.id %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-pencil-square me-2"></i>Edit
                </a>
                <button class="btn btn-outline-danger btn-sm delete-btn" data-id="<%= item.id %>">
                  <i class="bi bi-trash me-2"></i>Delete
                </button>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/terms" hidden></span>

<%- include('partials/pagination', {
  pagination: pagination,
  filters: filters,
  baseUrlPath: 'school/terms'
}) %>

<%- include('partials/tablePages-end') %>
