      '<div class="col-lg-2 col-md-4"><label class="form-label fw-bold small">Start Date</label><input type="date" id="hubSessionStartDate" class="form-control form-control-sm" value="' + escapeHtml(filters.startDate || '') + '"></div>',
      '<div class="col-lg-2 col-md-4"><label class="form-label fw-bold small">End Date</label><input type="date" id="hubSessionEndDate" class="form-control form-control-sm" value="' + escapeHtml(filters.endDate || '') + '"></div>',
      '<div class="col-lg-2 col-md-4"><label class="form-label fw-bold small">Start Time</label><input type="time" id="hubSessionStartTime" class="form-control form-control-sm" value="' + escapeHtml(filters.startTime || '') + '"></div>',
