  function applyHubAttendanceStudentVisibility(scopeRoot, visibilityKey, allStudents) {
    const rootEl = scopeRoot || document;
    const visible = ensureHubAttendanceVisibility(visibilityKey, allStudents);
    rootEl.querySelectorAll('tr.hub-attendance-student-row[data-person-id]').forEach(function (row) {
      const id = String(row.getAttribute('data-person-id') || '').trim();
      row.classList.toggle('is-student-hidden', !(id && visible.has(id)));
    });
    const countLabel = rootEl.querySelector('.hub-student-filter-count');
    if (countLabel) {
      const total = Array.isArray(allStudents) ? allStudents.length : 0;
      countLabel.textContent = String(Math.min(visible.size, total)) + '/' + String(total);
    }
  }

  function mountHubStudentFilterDropdownOutside(dropdownRoot) {
    const toggle = dropdownRoot && dropdownRoot.querySelector
      ? dropdownRoot.querySelector('[data-bs-toggle="dropdown"]')
      : null;
    const menu = dropdownRoot && dropdownRoot.querySelector
      ? dropdownRoot.querySelector('.dropdown-menu')
      : null;
    if (!toggle || !menu || typeof bootstrap === 'undefined' || !bootstrap.Dropdown) return null;

    const existing = bootstrap.Dropdown.getInstance(toggle);
    if (existing) existing.dispose();

    const instance = new bootstrap.Dropdown(toggle, {
      autoClose: 'outside',
      popperConfig: function (defaultConfig) {
        const config = typeof defaultConfig === 'object' && defaultConfig ? Object.assign({}, defaultConfig) : {};
        config.strategy = 'fixed';
        const modifiers = Array.isArray(config.modifiers) ? config.modifiers.slice() : [];
        modifiers.push({
          name: 'preventOverflow',
          options: { boundary: 'viewport', padding: 8 }
        });
        modifiers.push({
          name: 'flip',
          options: { fallbackPlacements: ['bottom-start', 'top-start', 'bottom-end', 'top-end'] }
        });
        config.modifiers = modifiers;
        return config;
      }
    });

    if (toggle.dataset.studentFilterOutsideBound === '1') return instance;
    toggle.dataset.studentFilterOutsideBound = '1';

    toggle.addEventListener('show.bs.dropdown', function () {
      if (menu.parentElement !== document.body) {
        menu.dataset.returnToParent = '1';
        document.body.appendChild(menu);
      }
      menu.classList.add('attendance-student-filter-menu-floating', 'show');
    });

    toggle.addEventListener('hidden.bs.dropdown', function () {
      menu.classList.remove('attendance-student-filter-menu-floating', 'show');
      if (menu.dataset.returnToParent === '1' && dropdownRoot.isConnected) {
        dropdownRoot.appendChild(menu);
        delete menu.dataset.returnToParent;
      }
    });

    return instance;
  }

  function bindHubAttendanceStudentVisibility(scopeRoot, visibilityKey, allStudents, onChanged) {
    const rootEl = scopeRoot || document;
    const dropdown = rootEl.querySelector('.hub-student-filter-dropdown');
    if (!dropdown) return;
    const menu = dropdown.querySelector('.dropdown-menu') || dropdown;
    const visible = ensureHubAttendanceVisibility(visibilityKey, allStudents);

    mountHubStudentFilterDropdownOutside(dropdown);

    menu.querySelectorAll('.hub-student-visibility-check').forEach(function (input) {
      input.addEventListener('change', function () {
        const id = String(input.value || '').trim();
        if (!id) return;
        if (input.checked) visible.add(id);
        else visible.delete(id);
        applyHubAttendanceStudentVisibility(rootEl, visibilityKey, allStudents);
        if (typeof onChanged === 'function') onChanged();
      });
    });

    menu.querySelector('.hub-student-select-all')?.addEventListener('click', function (event) {
      event.preventDefault();
      event.stopPropagation();
      const next = new Set();
      (Array.isArray(allStudents) ? allStudents : []).forEach(function (student) {
        const id = String(student && student.personId ? student.personId : '').trim();
        if (id) next.add(id);
      });
      hubAttendanceState.visibilityByKey[String(visibilityKey || 'default')] = next;
      menu.querySelectorAll('.hub-student-visibility-check').forEach(function (input) { input.checked = true; });
      applyHubAttendanceStudentVisibility(rootEl, visibilityKey, allStudents);
      if (typeof onChanged === 'function') onChanged();
    });

    menu.querySelector('.hub-student-clear-all')?.addEventListener('click', function (event) {
      event.preventDefault();
      event.stopPropagation();
      hubAttendanceState.visibilityByKey[String(visibilityKey || 'default')] = new Set();
      menu.querySelectorAll('.hub-student-visibility-check').forEach(function (input) { input.checked = false; });
      applyHubAttendanceStudentVisibility(rootEl, visibilityKey, allStudents);
      if (typeof onChanged === 'function') onChanged();
    });
  }

  function hubAttendanceToYmd(date) {
    if (!date || Number.isNaN(date.getTime())) return '';
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return y + '-' + m + '-' + d;
  }

  function setHubAttendanceRange(range) {
    const startEl = document.getElementById('hubAttendanceStartDate');
    const endEl = document.getElementById('hubAttendanceEndDate');
    if (!startEl || !endEl) return;

    const today = hubTodayDate();
    const startOfDay = new Date(today.getFullYear(), today.getMonth(), today.getDate());
    const day = today.getDay() || 7;
    let start = null;
    let end = null;

    if (range === 'today') {
      start = new Date(startOfDay);
      end = new Date(startOfDay);
    } else if (range === 'twoWeeks') {
      start = new Date(startOfDay);
      start.setDate(startOfDay.getDate() - (day - 1));
      end = new Date(start);
      end.setDate(start.getDate() + 13);
    } else if (range === 'thisWeek') {
      start = new Date(startOfDay);
      start.setDate(startOfDay.getDate() - (day - 1));
      end = new Date(start);
      end.setDate(start.getDate() + 6);
    } else if (range === 'prevWeek') {
      start = new Date(startOfDay);
      start.setDate(startOfDay.getDate() - (day - 1) - 7);
      end = new Date(start);
      end.setDate(start.getDate() + 6);
    } else if (range === 'thisMonth') {
      start = new Date(today.getFullYear(), today.getMonth(), 1);
      end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
    } else if (range === 'prevMonth') {
      start = new Date(today.getFullYear(), today.getMonth() - 1, 1);
      end = new Date(today.getFullYear(), today.getMonth(), 0);
    } else if (range === 'allTime') {
      startEl.value = '';
      endEl.value = '';
      return;
    }

    startEl.value = hubAttendanceToYmd(start);
    endEl.value = hubAttendanceToYmd(end);
  }

