      '<button type="button" class="btn btn-outline-primary btn-sm" data-hub-workspace-reload="sessions"><i class="bi bi-arrow-clockwise me-1"></i> ' + (notLoaded ? 'Load Sessions' : 'Refresh') + '</button>',
      '<a href="' + escapeHtml(section.sourceUrl || '/school/sessions') + '" class="btn btn-primary btn-sm" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right me-1"></i> Open Full Page</a>',
