  const hubTimesheetManagementState = {
    periods: [],
    years: [],
    selectedYear: '',
    rows: [],
    period: null
  };

  function formatHubTimesheetHours(value) {
    const num = Number(value || 0);
    if (!Number.isFinite(num)) return '0.00';
    return num.toFixed(2);
  }

  function getHubTimesheetPeriodYear(period) {
    const raw = String(period?.startDate || period?.endDate || period?.submissionDeadline || '').trim();
    const match = raw.match(/^(\d{4})-/);
    return match ? match[1] : '';
  }

  function refreshHubTimesheetManagementYears() {
    const years = Array.from(new Set((Array.isArray(hubTimesheetManagementState.periods) ? hubTimesheetManagementState.periods : [])
      .map(getHubTimesheetPeriodYear)
      .filter(Boolean)))
      .sort(function (a, b) { return String(b).localeCompare(String(a)); });
    hubTimesheetManagementState.years = years;
    if (!years.length) {
      hubTimesheetManagementState.selectedYear = '';
      return;
    }
    if (!hubTimesheetManagementState.selectedYear || !years.includes(String(hubTimesheetManagementState.selectedYear))) {
      const currentYear = hubOrgYear();
      hubTimesheetManagementState.selectedYear = years.includes(currentYear) ? currentYear : years[0];
    }
  }

  function renderHubTimesheetManagementYearOptions() {
    const select = document.getElementById('hubTimesheetManagementYear');
    if (!select) return;
    const years = Array.isArray(hubTimesheetManagementState.years) ? hubTimesheetManagementState.years : [];
    select.innerHTML = years.length
      ? years.map(function (year) {
        return '<option value="' + escapeHtml(year) + '"' + (String(year) === String(hubTimesheetManagementState.selectedYear) ? ' selected' : '') + '>' + escapeHtml(year) + '</option>';
      }).join('')
      : '<option value="">No years available</option>';
  }

  function timesheetManagementStatusBadgeClass(status) {
    const value = String(status || '').toLowerCase();
    if (['approved', 'processed', 'completed', 'paid'].includes(value)) return 'text-bg-success';
    if (['submitted', 'review', 'pending_review'].includes(value)) return 'text-bg-info';
    if (['rejected', 'cancelled', 'void'].includes(value)) return 'text-bg-danger';
    if (['draft', 'not_started', 'missing'].includes(value)) return 'text-bg-secondary';
    return 'text-bg-primary';
  }

  function renderTimesheetManagementRoleBadges(roles) {
    const list = Array.isArray(roles) ? roles : [];
    if (!list.length) return '<span class="text-muted small">-</span>';
    return list.map(function (role) {
      return '<span class="badge rounded-pill text-bg-light border me-1">' + escapeHtml(toHubTitleCase(role)) + '</span>';
    }).join('');
  }

  async function fetchHubTimesheetManagementJson(url) {
    const response = await fetch(url, {
      headers: {
        Accept: 'application/json',
        'X-Requested-With': 'XMLHttpRequest'
      },
      credentials: 'same-origin'
    });
    const result = await response.json().catch(function () {
      return { status: 'error', message: 'Unable to read the server response.' };
    });
    if (!response.ok || result.status !== 'success') {
      throw new Error(result.message || 'Timesheet Management request failed.');
    }
    return result;
  }

  function renderHubTimesheetManagementPeriodOptions() {
    renderHubTimesheetManagementYearOptions();
    const select = document.getElementById('hubTimesheetManagementPeriodId');
    if (!select) return;
    const current = String(select.value || '');
    const selectedYear = String(hubTimesheetManagementState.selectedYear || '');
    const periods = (Array.isArray(hubTimesheetManagementState.periods) ? hubTimesheetManagementState.periods : [])
      .filter(function (period) {
        return !selectedYear || getHubTimesheetPeriodYear(period) === selectedYear;
      });
    select.innerHTML = '<option value="">Select a timesheet period...</option>' + periods.map(function (period) {
      const id = String(period.id || '');
      const dateWindow = [formatHubTimesheetDate(period.startDate), formatHubTimesheetDate(period.endDate)]
        .filter(function (item) { return item && item !== '-'; })
        .join(' to ');
      const label = String(period.name || period.title || period.id || 'Timesheet Period') + (dateWindow ? ' - ' + dateWindow : '');
      return '<option value="' + escapeHtml(id) + '"' + (id === current ? ' selected' : '') + '>' + escapeHtml(label) + '</option>';
    }).join('');
    if (current && periods.some(function (period) { return String(period.id || '') === current; })) {
      select.value = current;
    } else if (current) {
      select.value = '';
      hubTimesheetManagementState.period = null;
      hubTimesheetManagementState.rows = [];
    }
  }

  function updateTimesheetManagementMeta() {
    const meta = document.getElementById('hubTimesheetManagementPeriodMeta');
    const count = document.getElementById('hubTimesheetManagementRosterCount');
    const period = hubTimesheetManagementState.period || null;
    const rows = Array.isArray(hubTimesheetManagementState.rows) ? hubTimesheetManagementState.rows : [];
    if (meta) {
      meta.innerHTML = period
        ? [
          '<span class="badge text-bg-light border me-2">' + escapeHtml(period.name || period.id || 'Selected Period') + '</span>',
          '<span class="text-muted">Window: ' + escapeHtml(formatHubTimesheetDate(period.startDate)) + ' to ' + escapeHtml(formatHubTimesheetDate(period.endDate)) + '</span>',
          period.submissionDeadline ? '<span class="text-muted ms-2">Deadline: ' + escapeHtml(formatHubTimesheetDeadline(period)) + '</span>' : ''
        ].join('')
        : '<span class="text-muted">Select a period, then load the roster.</span>';
    }
    if (count) {
      count.textContent = rows.length ? rows.length + ' eligible person row(s) loaded.' : 'No roster loaded yet.';
    }
  }

  function renderTimesheetManagementRows(notLoaded) {
    const host = document.getElementById('hubTimesheetManagementRosterHost');
    if (!host) return;
    const term = String(document.getElementById('hubTimesheetManagementPersonSearch')?.value || '').trim().toLowerCase();
    const rows = (Array.isArray(hubTimesheetManagementState.rows) ? hubTimesheetManagementState.rows : []).filter(function (row) {
      if (!term) return true;
      const haystack = [
        row.personId,
        row.name,
        row.email,
        Array.isArray(row.roles) ? row.roles.join(' ') : '',
        row.departmentHint,
        row.status,
        row.timesheetId
      ].filter(Boolean).join(' ').toLowerCase();
      return haystack.includes(term);
    });

    if (notLoaded || !hubTimesheetManagementState.period) {
      host.innerHTML = '<div class="hub-empty"><div><i class="bi bi-table display-6 d-block mb-3"></i><div class="fw-semibold">Timesheet Management is ready.</div><div class="text-muted small mt-1">Select a timesheet period and click Load Roster to review eligible teachers and staff.</div></div></div>';
      updateTimesheetManagementMeta();
      return;
    }

    if (!rows.length) {
      host.innerHTML = '<div class="hub-empty"><div><i class="bi bi-search display-6 d-block mb-3"></i><div class="fw-semibold">No roster rows found.</div><div class="text-muted small mt-1">Try clearing the person search or select another period.</div></div></div>';
      updateTimesheetManagementMeta();
      return;
    }

    const body = rows.map(function (row) {
      const searchText = [row.personId, row.name, row.email, row.departmentHint, row.status, Array.isArray(row.roles) ? row.roles.join(' ') : ''].filter(Boolean).join(' ');
      const openUrl = row.openUrl || ('/school/timesheets/editor/' + encodeURIComponent(hubTimesheetManagementState.period.id || '') + '?teacherId=' + encodeURIComponent(row.personId || ''));
      return [
        '<tr data-hub-workspace-row data-search-text="' + escapeHtml(searchText) + '">',
        '<td class="ps-3"><div class="fw-semibold">' + escapeHtml(row.name || row.personId || 'Unknown Person') + '</div><div class="small text-muted">#' + escapeHtml(row.personId || '-') + (row.email ? ' - ' + escapeHtml(row.email) : '') + '</div></td>',
        '<td>' + renderTimesheetManagementRoleBadges(row.roles) + '</td>',
        '<td><span class="text-muted">' + escapeHtml(row.departmentHint || 'No Department / Manual') + '</span></td>',
        '<td><span class="badge ' + timesheetManagementStatusBadgeClass(row.status) + '">' + escapeHtml(toHubTitleCase(row.status || 'not_started')) + '</span></td>',
        '<td><span class="fw-bold">' + escapeHtml(formatHubTimesheetHours(row.totalHours)) + '</span><span class="text-muted small ms-1">hrs</span></td>',
        '<td class="text-end pe-3"><div class="hub-workspace-actions">',
        '<a class="btn btn-outline-primary btn-sm" href="' + escapeHtml(openUrl) + '" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right me-1"></i>Open Timesheet</a>',
        '<button type="button" class="btn btn-outline-secondary btn-sm" data-hub-timesheet-management-summary-person="' + escapeHtml(row.personId || '') + '" data-person-name="' + escapeHtml(row.name || row.personId || 'Person') + '"><i class="bi bi-pie-chart me-1"></i>Department Summary</button>',
        '</div></td>',
        '</tr>'
      ].join('');
    }).join('');

    host.innerHTML = [
      '<div class="hub-table-wrap">',
      '<table class="table table-hover align-middle hub-workspace-table">',
      '<thead><tr><th class="ps-3">Person</th><th>Roles</th><th>Department Hint</th><th>Status</th><th>Total Hours</th><th class="text-end pe-3">Actions</th></tr></thead>',
      '<tbody>', body, '</tbody>',
      '</table>',
      '</div>'
    ].join('');
    updateTimesheetManagementMeta();
  }

