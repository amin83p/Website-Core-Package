  function setHubActivityDateRange(range) {
    const fromEl = document.getElementById('hubActivityDateFrom');
    const toEl = document.getElementById('hubActivityDateTo');
    if (!fromEl || !toEl) return;
    const today = hubTodayDate();
    let start = new Date(today);
    let end = new Date(today);

    if (range === 'allTime') {
      fromEl.value = '';
      toEl.value = '';
      loadWorkspaceSection('activities');
      return;
    }

    if (range === 'thisMonth') {
      start = new Date(today.getFullYear(), today.getMonth(), 1);
      end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
    } else if (range === 'upcoming') {
      fromEl.value = hubDateToIso(today);
      toEl.value = '';
      loadWorkspaceSection('activities');
      return;
    }

    fromEl.value = hubDateToIso(start);
    toEl.value = hubDateToIso(end);
    loadWorkspaceSection('activities');
  }

