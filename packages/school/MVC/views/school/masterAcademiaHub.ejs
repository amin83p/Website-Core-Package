  function findModule(type) {
    return modules.find((item) => item.type === type) || null;
  }

  function setStatus(message, tone) {
    if (!els.status) return;
    const text = String(message || '').trim();
    els.status.className = 'alert alert-' + (tone || 'info') + ' ' + (text ? '' : 'd-none');
    els.status.textContent = text;
  }

  function setTabLoading(type, loading) {
    root.querySelectorAll('[data-hub-tab]').forEach(function (tab) {
      if (tab.getAttribute('data-hub-tab') === type) tab.classList.toggle('hub-tab-loading', loading === true);
    });
  }

  function setLoading(isLoading, type) {
    state.loading = isLoading;
    if (els.searchButton) els.searchButton.disabled = isLoading;
    root.querySelectorAll('[data-hub-refresh]').forEach(function (btn) {
      btn.classList.toggle('disabled', isLoading);
    });
    if (type) setTabLoading(type, isLoading);
  }

  function syncActiveTab() {
    els.tabs.forEach(function (tab) {
      tab.classList.toggle('active', tab.getAttribute('data-hub-tab') === state.currentType);
    });
    const module = findModule(state.currentType);
    if (els.openDirectory) {
      if (module && module.directoryUrl) {
        els.openDirectory.href = module.directoryUrl;
        els.openDirectory.classList.remove('disabled');
      } else {
        els.openDirectory.href = '#';
        els.openDirectory.classList.add('disabled');
      }
    }
  }

  function updateCount(type, total) {
    els.counts.forEach(function (badge) {
      if (badge.getAttribute('data-hub-count') === type) {
        badge.textContent = Number.isFinite(Number(total)) ? String(total) : '-';
      }
    });
  }

  function renderEmpty(message, icon) {
    if (!els.list) return;
    els.list.innerHTML = [
      '<div class="hub-empty">',
      '<div>',
      '<i class="bi ' + escapeHtml(icon || 'bi-search') + ' display-6 d-block mb-3"></i>',
      '<div class="fw-semibold">' + escapeHtml(message || 'Start searching to find records.') + '</div>',
      '</div>',
      '</div>'
    ].join('');
  }

  function renderSearchPrompt() {
    const module = findModule(state.currentType);
    const label = module ? module.label : 'records';
    renderEmpty('Type at least 2 characters to search ' + label + '.', 'bi-search');
  }

  function renderRows(rows) {
    if (!els.list) return;
    if (!Array.isArray(rows) || !rows.length) {
      renderEmpty('No matching active records were found.');
      return;
    }

    const body = rows.map(function (row, idx) {
      const actions = Array.isArray(row.actions) ? row.actions : [];
      const actionLinks = actions.map(function (action) {
        if (action.command === 'person-current-month-schedule') {
          return [
            '<button type="button" class="btn btn-outline-' + escapeHtml(action.tone || 'info') + ' btn-sm" data-hub-person-action="person-current-month-schedule"',
            ' data-record-id="' + escapeHtml(action.recordId || row.id || '') + '"',
            ' data-person-id="' + escapeHtml(action.personId || row.personId || '') + '"',
            ' data-person-name="' + escapeHtml(action.personName || row.name || '') + '"',
            ' data-person-role="' + escapeHtml(action.role || '') + '"',
            ' data-person-role-label="' + escapeHtml(action.roleLabel || '') + '">',
            '<i class="' + escapeHtml(action.icon || 'bi bi-calendar-month') + ' me-1"></i>' + escapeHtml(action.label || 'Current Month Schedule'),
            '</button>'
          ].join('');
        }
        return [
          '<a class="btn btn-outline-' + escapeHtml(action.tone || 'secondary') + ' btn-sm" href="' + escapeHtml(action.href || '#') + '" target="_blank" rel="noopener">',
          '<i class="' + escapeHtml(action.icon || 'bi bi-box-arrow-up-right') + ' me-1"></i>' + escapeHtml(action.label || 'Open'),
          '</a>'
        ].join('');
      }).join('');
      const cardId = 'schoolHubCardDetails_' + escapeHtml(row.id || idx);

      return [
        '<article class="hub-person-card" data-hub-card>',
        '<div class="d-flex justify-content-between align-items-start gap-2">',
        '<div class="min-w-0">',
        '<div class="fw-semibold text-truncate">' + hubStudentNameHtml(row.name || '-', row.id) + '</div>',
        '<div class="text-muted small font-monospace">' + escapeHtml(row.id || '') + '</div>',
        '</div>',
        '<div class="d-flex align-items-center gap-2 flex-shrink-0">',
        '<span class="badge text-bg-light border">' + escapeHtml(row.status || 'Active') + '</span>',
        '<button type="button" class="btn btn-outline-secondary btn-sm hub-card-toggle" data-hub-card-toggle aria-expanded="false" aria-controls="' + cardId + '">',
        '<i class="bi bi-chevron-down"></i>',
        '</button>',
        '</div>',
        '</div>',
        '<div class="hub-card-details" id="' + cardId + '">',
        '<div class="small text-muted">',
        '<div><i class="bi bi-person-badge me-1"></i>' + escapeHtml(row.personId || '-') + '</div>',
        '<div><i class="bi bi-envelope me-1"></i>' + escapeHtml(row.email || '-') + '</div>',
        '<div><i class="bi bi-telephone me-1"></i>' + escapeHtml(row.phone || '-') + '</div>',
        '</div>',
        '<div class="d-flex justify-content-between align-items-center gap-2 mt-2">',
        '<span class="small text-muted">' + escapeHtml(row.detailLabel || 'Detail') + '</span>',
        '<span class="small text-end">' + escapeHtml(row.detail || '-') + '</span>',
        '</div>',
        '<div class="hub-card-actions mt-3">',
        actionLinks || '<span class="text-muted small">No actions</span>',
        '</div>',
        '</div>',
        '</article>'
      ].join('');
    }).join('');

    const pagination = state.pagination || {};
    const hasMore = Number(pagination.currentPage || 1) < Number(pagination.totalPages || 1);
    const totalItems = Number(pagination.totalItems || rows.length || 0);
    const footer = hasMore
      ? [
        '<div class="hub-load-more-wrap">',
        '<button type="button" class="btn btn-outline-primary btn-sm" id="schoolMasterHubLoadMore">',
        '<i class="bi bi-plus-circle me-1"></i> Load More',
        '</button>',
        '<div class="text-muted small mt-2">Showing ' + escapeHtml(rows.length) + ' of ' + escapeHtml(totalItems) + '</div>',
        '</div>'
      ].join('')
      : '<div class="text-muted small text-center py-2">Showing ' + escapeHtml(rows.length) + ' of ' + escapeHtml(totalItems) + '</div>';

    els.list.innerHTML = '<div class="hub-person-list">' + body + footer + '</div>';
    const loadMoreBtn = document.getElementById('schoolMasterHubLoadMore');
    if (loadMoreBtn) {
      loadMoreBtn.addEventListener('click', function () {
        searchCurrent({ append: true });
      });
    }
    els.list.querySelectorAll('[data-hub-card-toggle]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const card = btn.closest('[data-hub-card]');
        if (!card) return;
        const expanded = !card.classList.contains('is-expanded');
        card.classList.toggle('is-expanded', expanded);
        btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        btn.innerHTML = expanded ? '<i class="bi bi-chevron-up"></i>' : '<i class="bi bi-chevron-down"></i>';
      });
    });
    els.list.querySelectorAll('[data-hub-person-action="person-current-month-schedule"]').forEach(function (btn) {
      btn.addEventListener('click', async function () {
        btn.disabled = true;
        try {
          await openPersonCurrentMonthSchedule({
            recordId: btn.getAttribute('data-record-id') || '',
            personId: btn.getAttribute('data-person-id') || '',
            personName: btn.getAttribute('data-person-name') || '',
            role: btn.getAttribute('data-person-role') || '',
            roleLabel: btn.getAttribute('data-person-role-label') || ''
          });
        } finally {
          btn.disabled = false;
        }
      });
    });
  }

  async function openPersonCurrentMonthSchedule(personInput) {
    const personId = String(personInput?.personId || '').trim();
    const role = String(personInput?.role || '').trim().toLowerCase();
    const roleLabel = String(personInput?.roleLabel || role || 'School Person').trim();
    if (!personId) {
      await showHubMessage({
        title: 'Current Month Schedule',
        icon: 'warning',
        message: 'This ' + roleLabel.toLowerCase() + ' is not linked to a person record, so their schedule cannot be loaded.'
      });
      return;
    }

    openWorkspaceSection('schedule');
    if (workspaceState.currentSection !== 'schedule' || !document.getElementById('hubScheduleStartDate')) {
      await showHubMessage({
        title: 'Current Month Schedule',
        icon: 'warning',
        message: 'The Schedule workspace is busy or unavailable. Please try again.'
      });
      return;
    }
    let person = hubScheduleState.persons.find(function (item) { return item.id === personId; });
    if (!person) {
      person = {
        id: personId,
        recordId: String(personInput?.recordId || '').trim(),
        name: String(personInput?.personName || personId).trim(),
        availableRoles: [{ key: role, label: roleLabel }],
        selectedRole: role
      };
      hubScheduleState.persons.push(person);
    } else {
      person.recordId = String(personInput?.recordId || person.recordId || '').trim();
      person.name = String(personInput?.personName || person.name || personId).trim();
      if (!(Array.isArray(person.availableRoles) && person.availableRoles.some(function (item) { return item?.key === role; }))) {
        person.availableRoles = (Array.isArray(person.availableRoles) ? person.availableRoles : []).concat({ key: role, label: roleLabel });
      }
      person.selectedRole = role;
    }

    hubScheduleState.activePersonId = personId;
    setHubScheduleRange('month');
    await loadHubSchedulePerson(person);
    if (els.workspace && typeof els.workspace.scrollIntoView === 'function') {
      els.workspace.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  function updateHeader(result) {
    const module = result && result.module ? result.module : findModule(state.currentType);
    if (els.eyebrow) els.eyebrow.textContent = module ? module.sectionId : 'Directory';
    if (els.title) els.title.textContent = module ? module.label : 'School Master Hub';
    if (els.meta) {
      const refreshed = result && result.refreshedAt ? formatHubInstant(result.refreshedAt) : 'not loaded yet';
      els.meta.textContent = String(result && result.total != null ? result.total : 0) + ' matching records. Last refreshed: ' + refreshed + '.';
    }
  }

  async function searchCurrent(options) {
    if (!state.currentType || state.loading) return;
    const opts = options || {};
    const term = opts.append === true
      ? String(state.lastSearch || '').trim()
      : String((els.search && els.search.value) || '').trim();
    if (opts.append !== true) state.lastSearch = term;
    syncActiveTab();

    if (term.length < 2) {
      updateCount(state.currentType, '-');
      state.page = 1;
      state.loadedRows = [];
      state.pagination = null;
      setStatus('', 'info');
      renderSearchPrompt();
      return;
    }

    const type = state.currentType;
    state.page = opts.append === true ? Number(state.page || 1) + 1 : 1;
    const query = new URLSearchParams({
      type: type,
      page: String(state.page || 1),
      q: term
    });

    setLoading(true, type);
    setStatus('Searching ' + (findModule(type)?.label || 'records') + '...', 'info');
    if (typeof window.showLoading === 'function') {
      window.showLoading('Searching ' + (findModule(type)?.label || 'records') + '...');
    }

    try {
      const response = await fetch('/school/master-hub/api/list?' + query.toString(), {
        headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        credentials: 'same-origin'
      });
      const contentType = response.headers.get('content-type') || '';
      const payload = contentType.includes('application/json') ? await response.json() : { status: 'error', message: await response.text() };
      if (!response.ok || payload.status !== 'success') throw new Error(payload.message || 'Unable to search list.');
      updateHeader(payload);
      updateCount(type, payload.total);
      state.pagination = payload.pagination || null;
      state.loadedRows = opts.append === true
        ? state.loadedRows.concat(payload.rows || [])
        : (payload.rows || []);
      renderRows(state.loadedRows);
      setStatus('', 'info');
    } catch (error) {
      renderEmpty(error.message || 'Unable to search list.', 'bi-exclamation-triangle');
      setStatus(error.message || 'Unable to search list.', 'danger');
    } finally {
      if (typeof window.hideLoading === 'function') {
        window.hideLoading({ force: true });
      }
      setLoading(false, type);
    }
  }

  if (els.search) {
    els.search.addEventListener('keydown', function (event) {
      if (event.key !== 'Enter') return;
      event.preventDefault();
      searchCurrent();
    });
  }
  if (els.searchButton) {
    els.searchButton.addEventListener('click', function () {
      searchCurrent();
    });
  }

  if (els.refreshCurrent) {
    els.refreshCurrent.addEventListener('click', searchCurrent);
  }

  if (els.taskSettings) {
    els.taskSettings.addEventListener('click', function (event) {
      event.preventDefault();
      event.stopPropagation();
      openTaskSettings();
    });
  }

  els.workspaceButtons.forEach(function (button) {
    button.addEventListener('click', function (event) {
      event.preventDefault();
      event.stopPropagation();
      openWorkspaceSection(button.getAttribute('data-hub-workspace-section') || '');
    });
  });

  function syncSidebarToggle() {
    if (!els.collapseSidebar) return;
    const collapsed = root.classList.contains('hub-sidebar-collapsed');
    els.collapseSidebar.title = collapsed ? 'Expand sidebar' : 'Collapse sidebar';
    els.collapseSidebar.innerHTML = collapsed
      ? '<i class="bi bi-layout-sidebar-inset-reverse"></i>'
      : '<i class="bi bi-layout-sidebar-inset"></i>';
  }

  if (els.collapseSidebar) {
    els.collapseSidebar.addEventListener('click', function () {
      root.classList.toggle('hub-sidebar-collapsed');
      syncSidebarToggle();
    });
  }

  root.querySelectorAll('[data-hub-tab]').forEach(function (tab) {
    tab.addEventListener('click', function (event) {
      if (event.target && event.target.closest('[data-hub-refresh]')) return;
      state.currentType = tab.getAttribute('data-hub-tab') || state.currentType;
      state.page = 1;
      state.lastSearch = '';
      state.loadedRows = [];
      state.pagination = null;
      if (els.search) els.search.value = '';
      updateCount(state.currentType, '-');
      syncActiveTab();
      renderSearchPrompt();
      setStatus('', 'info');
    });
  });

  root.querySelectorAll('[data-hub-refresh]').forEach(function (btn) {
    btn.addEventListener('click', function (event) {
      event.preventDefault();
      event.stopPropagation();
      state.currentType = btn.getAttribute('data-hub-refresh') || state.currentType;
      searchCurrent();
    });
  });

  document.addEventListener('keydown', async function (event) {
    const key = String(event.key || '').toLowerCase();
    const isReloadShortcut = event.key === 'F5' || ((event.ctrlKey || event.metaKey) && key === 'r');
    const isCloseShortcut = (event.ctrlKey || event.metaKey) && key === 'w';

    if (isReloadShortcut) {
      event.preventDefault();
      event.stopPropagation();
      const shouldReload = await confirmHubReload({
        title: 'Reload Master Hub',
        message: 'Reloading will clear the current in-page Master Hub view. Continue?'
      });
      if (shouldReload) {
        window.location.reload();
      }
      return;
    }

    if (isCloseShortcut) {
      event.preventDefault();
      event.stopPropagation();
      await showCloseLimitationMessage();
    }
  });

  function confirmMasterHubUnload(event) {
    const message = 'Leave School Master Hub? Your current in-page workspace state may be cleared.';
    event.preventDefault();
    event.returnValue = message;
    return message;
  }

  window.addEventListener('beforeunload', confirmMasterHubUnload);
  window.onbeforeunload = confirmMasterHubUnload;

  if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
  restartTaskTimer();
  syncSidebarToggle();
  syncActiveTab();
  renderSearchPrompt();
}());
</script>
