  async function postHubSessionMutation(url, payload, loadingMessage) {
    if (typeof window.showLoading === 'function') window.showLoading(loadingMessage || 'Updating sessions...');
    try {
      const response = await fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          Accept: 'application/json',
          'X-Requested-With': 'XMLHttpRequest',
          'X-AJAX-Request': 'true'
        },
        credentials: 'same-origin',
        body: JSON.stringify(payload || {})
      });
      const result = await response.json().catch(function () {
        return { status: 'error', message: 'Unable to read server response.' };
      });
      if (!response.ok || result.status !== 'success') throw new Error(result.message || 'Operation failed.');
      return result;
    } finally {
      if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
    }
  }

  async function lockSelectedHubSessions() {
    const refs = getVisibleSelectedSessionRefs();
    if (!refs.length) {
      await showHubMessage({ title: 'Lock Sessions', icon: 'warning', message: 'Select at least one visible session first.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
      return;
    }
    const selected = await showHubMessage({
      title: 'Lock Selected Sessions',
      icon: 'warning',
      message: 'Lock ' + refs.length + ' selected session(s)? Locked sessions cannot be edited from attendance/session screens unless the user can override locks.',
      buttons: [
        { text: 'Cancel', class: 'btn-secondary' },
        { text: 'Lock Sessions', class: 'btn-danger' }
      ]
    });
    if (selected !== 'Lock Sessions') return;
    try {
      const result = await postHubSessionMutation('/school/master-hub/api/workspace/sessions/lock', { sessionRefs: refs }, 'Locking selected sessions...');
      await showHubMessage({ title: 'Sessions Locked', icon: 'success', message: result.message || 'Selected sessions were locked.', buttons: [{ text: 'OK', class: 'btn-success' }] });
