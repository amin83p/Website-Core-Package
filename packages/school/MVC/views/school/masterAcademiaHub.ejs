      '<div class="col-xl-2 col-md-4"><label class="form-label fw-bold small" for="hubActivityDepartmentId">Department</label><select id="hubActivityDepartmentId" class="form-select form-select-sm">' + departmentOptions + '</select></div>',
      '<div class="col-xl-2 col-md-4"><label class="form-label fw-bold small" for="hubActivityStatus">Status</label><select id="hubActivityStatus" class="form-select form-select-sm">' + statusOptions + '</select></div>',
      '<div class="col-xl-2 col-md-4"><label class="form-label fw-bold small" for="hubActivityVisibilityScope">Calendar Scope</label><select id="hubActivityVisibilityScope" class="form-select form-select-sm">' + scopeOptions + '</select></div>',
