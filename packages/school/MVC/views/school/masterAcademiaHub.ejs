  function bindHolidayWorkspaceControls() {
    const loadButton = els.workspace.querySelector('[data-hub-load-workspace="holidays"]');
    if (loadButton) {
      loadButton.addEventListener('click', function () {
        loadWorkspaceSection('holidays');
      });
    }
    const yearSelect = document.getElementById('hubHolidayYear');
    if (yearSelect) {
      yearSelect.addEventListener('change', function () {
        workspaceState.holidaysYear = String(yearSelect.value || hubOrgYear());
        loadWorkspaceSection('holidays');
      });
    }
    const addButton = document.getElementById('hubHolidayAddBtn');
    if (addButton) {
      addButton.addEventListener('click', function () {
        openHubHolidayModal({});
      });
    }
    els.workspace.querySelectorAll('[data-hub-holiday-edit]').forEach(function (button) {
      button.addEventListener('click', function () {
        openHubHolidayModal({
          id: button.getAttribute('data-id') || '',
          date: button.getAttribute('data-date') || '',
          title: button.getAttribute('data-title') || '',
          type: button.getAttribute('data-type') || 'National Holiday',
          notes: button.getAttribute('data-notes') || ''
        });
      });
    });
    els.workspace.querySelectorAll('[data-hub-holiday-delete]').forEach(function (button) {
      button.addEventListener('click', function () {
        deleteHubHoliday(button.getAttribute('data-id') || '', button.getAttribute('data-title') || 'Holiday');
      });
    });
