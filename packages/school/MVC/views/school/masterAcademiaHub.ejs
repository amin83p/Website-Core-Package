  function timesheetPeriodBadgeClass(status) {
    const value = String(status || '').toLowerCase();
    if (value === 'processed') return 'text-bg-success';
    if (value === 'locked') return 'text-bg-warning';
    return 'text-bg-primary';
  }

  function formatHubTimesheetDate(dateValue) {
    const raw = String(dateValue || '').trim();
    if (!raw) return '-';
    try {
      return formatHubDateKey(raw, { month: 'short', day: 'numeric', year: 'numeric' });
    } catch (error) {
      return raw;
    }
  }

  function formatHubTimesheetDeadline(row) {
    const date = formatHubTimesheetDate(row && row.submissionDeadline);
    const time = String((row && row.submissionDeadlineTime) || '23:59').trim() || '23:59';
    return date === '-' ? '-' : date + ' at ' + time;
  }

  function appendTimesheetPeriodWorkspaceQuery(requestQuery) {
    const values = {
      status: hubInputValue('hubTimesheetPeriodStatus'),
      periodStartDate: hubInputValue('hubTimesheetPeriodStartDate'),
      periodEndDate: hubInputValue('hubTimesheetPeriodEndDate'),
      deadlineStartDate: hubInputValue('hubTimesheetPeriodDeadlineStartDate'),
      deadlineEndDate: hubInputValue('hubTimesheetPeriodDeadlineEndDate')
    };
    Object.keys(values).forEach(function (key) {
      if (values[key]) requestQuery.set(key, values[key]);
    });
  }

  function setHubTimesheetPeriodRange(range) {
    const periodStartEl = document.getElementById('hubTimesheetPeriodStartDate');
    const periodEndEl = document.getElementById('hubTimesheetPeriodEndDate');
    const deadlineStartEl = document.getElementById('hubTimesheetPeriodDeadlineStartDate');
    const deadlineEndEl = document.getElementById('hubTimesheetPeriodDeadlineEndDate');
    if (!periodStartEl || !periodEndEl || !deadlineStartEl || !deadlineEndEl) return;
    const today = hubTodayDate();
    let start = new Date(today);
    let end = new Date(today);

    deadlineStartEl.value = '';
    deadlineEndEl.value = '';

    if (range === 'allTime') {
      periodStartEl.value = '';
      periodEndEl.value = '';
      loadWorkspaceSection('timesheet-periods');
      return;
    }

    if (range === 'thisMonth') {
      start = new Date(today.getFullYear(), today.getMonth(), 1);
      end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
    } else if (range === 'upcoming') {
      periodStartEl.value = hubDateToIso(today);
      periodEndEl.value = '';
      loadWorkspaceSection('timesheet-periods');
      return;
    }

    periodStartEl.value = hubDateToIso(start);
    periodEndEl.value = hubDateToIso(end);
    loadWorkspaceSection('timesheet-periods');
  }

  function bindTimesheetPeriodWorkspaceControls() {
    const loadButtons = els.workspace.querySelectorAll('[data-hub-timesheet-period-load]');
    loadButtons.forEach(function (button) {
      button.addEventListener('click', function () { loadWorkspaceSection('timesheet-periods'); });
    });
    const resetButton = document.getElementById('hubTimesheetPeriodReset');
    if (resetButton) {
      resetButton.addEventListener('click', function () {
        ['hubTimesheetPeriodStatus', 'hubTimesheetPeriodStartDate', 'hubTimesheetPeriodEndDate', 'hubTimesheetPeriodDeadlineStartDate', 'hubTimesheetPeriodDeadlineEndDate'].forEach(function (id) {
          const el = document.getElementById(id);
          if (el) el.value = '';
        });
        workspaceState.serverSearch['timesheet-periods'] = '';
        const searchInput = document.getElementById('hubServerSearch_timesheet-periods');
        if (searchInput) searchInput.value = '';
        loadWorkspaceSection('timesheet-periods');
      });
    }
    root.querySelectorAll('[data-hub-timesheet-period-range]').forEach(function (button) {
      button.addEventListener('click', function () {
        setHubTimesheetPeriodRange(button.getAttribute('data-hub-timesheet-period-range') || 'activeToday');
      });
    });
    bindWorkspaceSearchControls('timesheet-periods');
