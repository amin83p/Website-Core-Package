<script src="/scripts/scheduleCompletionDisplay.js"></script>
<script>
(function () {
  function formatHubDateKey(dateValue, options = {}) {
    const raw = String(dateValue || '').trim();
    if (!raw) return '-';
    if (window.AppOrgDateTime && typeof window.AppOrgDateTime.formatDateKey === 'function') {
      return window.AppOrgDateTime.formatDateKey(raw, options);
    }
    return raw;
  }

  function formatHubInstant(value) {
    if (value === undefined || value === null || value === '') return 'just now';
    if (window.AppOrgDateTime && typeof window.AppOrgDateTime.formatInstant === 'function') {
      return window.AppOrgDateTime.formatInstant(value);
    }
    const date = new Date(value);
    return Number.isNaN(date.getTime()) ? 'just now' : date.toLocaleString();
  }

  function hubTodayIso() {
    if (window.AppOrgDateTime && window.AppOrgDateTime.today) {
      return String(window.AppOrgDateTime.today);
    }
    return '';
  }

  function hubOrgYear() {
    if (window.AppOrgDateTime && typeof window.AppOrgDateTime.orgYear === 'function') {
      const year = String(window.AppOrgDateTime.orgYear() || '').trim();
      if (year) return year;
    }
    return hubTodayIso().slice(0, 4);
  }

  function hubTodayDate() {
    if (window.AppOrgDateTime && typeof window.AppOrgDateTime.dateKeyToDate === 'function') {
      const parsed = window.AppOrgDateTime.dateKeyToDate(hubTodayIso());
      if (parsed) return parsed;
    }
    return new Date();
  }

  function hubDateToIso(date) {
    if (window.AppOrgDateTime && typeof window.AppOrgDateTime.dateToDateKey === 'function') {
      return window.AppOrgDateTime.dateToDateKey(date);
    }
    if (!(date instanceof Date) || Number.isNaN(date.getTime())) return '';
    const local = new Date(date.getTime() - (date.getTimezoneOffset() * 60000));
    return local.toISOString().slice(0, 10);
  }

  const root = document.querySelector('[data-master-hub]');
  if (!root) return;

  const canManageAllTasks = root.getAttribute('data-can-manage-all-tasks') === 'true';
  const TASK_ADMIN_SHOW_ALL_KEY = 'school_tasks_admin_show_all';

  function readTaskAdminShowAll() {
    try {
      return window.localStorage.getItem(TASK_ADMIN_SHOW_ALL_KEY) === 'true';
    } catch (error) {
      return false;
    }
  }

  function writeTaskAdminShowAll(value) {
    try {
      window.localStorage.setItem(TASK_ADMIN_SHOW_ALL_KEY, value ? 'true' : 'false');
    } catch (error) {
      // ignore storage errors
    }
  }

  let modules = [];
  try {
    modules = JSON.parse(root.getAttribute('data-modules') || '[]');
  } catch (error) {
    modules = [];
  }

  const state = {
    currentType: root.getAttribute('data-default-type') || (modules[0] && modules[0].type) || '',
    page: 1,
    loading: false,
    lastSearch: '',
    loadedRows: [],
    pagination: null
  };

  const els = {
    tabs: root.querySelectorAll('[data-hub-tab]'),
    counts: root.querySelectorAll('[data-hub-count]'),
    title: document.getElementById('schoolMasterHubTitle'),
    eyebrow: document.getElementById('schoolMasterHubEyebrow'),
    meta: document.getElementById('schoolMasterHubMeta'),
    list: document.getElementById('schoolMasterHubList'),
    status: document.getElementById('schoolMasterHubStatus'),
    search: document.getElementById('schoolMasterHubSearch'),
    searchButton: document.getElementById('schoolMasterHubSearchButton'),
    refreshCurrent: document.getElementById('schoolMasterHubRefreshCurrent'),
    openDirectory: document.getElementById('schoolMasterHubOpenDirectory'),
    collapseSidebar: document.getElementById('schoolMasterHubCollapseSidebar'),
    taskCount: document.getElementById('schoolMasterHubTaskCount'),
    taskSettings: document.getElementById('schoolMasterHubTaskSettings'),
    workspace: document.getElementById('schoolMasterHubWorkspace'),
    workspaceButtons: root.querySelectorAll('[data-hub-workspace-section]')
  };

  function escapeHtml(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function hubStudentNameHtml(name, studentRecordId, className) {
    if (typeof schoolRenderStudentNameHtml === 'function') {
      return schoolRenderStudentNameHtml(name, studentRecordId, { className: className || 'text-decoration-none fw-semibold' });
    }
    return escapeHtml(name || '-');
  }

  async function showHubMessage(options) {
    if (typeof window.showMessageModal === 'function') {
      return window.showMessageModal(options || {});
    }
    return null;
  }

  async function confirmHubReload({ title = 'Reload Master Hub', message = 'Reload this Master Hub view?' } = {}) {
    const selected = await showHubMessage({
      title,
      icon: 'warning',
      message,
      buttons: [
        { text: 'Cancel', class: 'btn-secondary' },
        { text: 'Reload', class: 'btn-primary' }
      ]
    });
    return selected === 'Reload';
  }

  async function showCloseLimitationMessage() {
    return showHubMessage({
      title: 'Close Master Hub',
      icon: 'info',
      message: 'Browser tab close is controlled by the browser, so the app cannot replace it with this message modal. Use in-page navigation when you want a modal-confirmed exit.',
      buttons: [
        { text: 'OK', class: 'btn-primary' }
      ]
    });
  }

  const taskState = {
    intervalSeconds: 60,
    timer: null,
    loading: false
  };

  function setTaskCount(value, muted) {
    if (!els.taskCount) return;
    els.taskCount.textContent = String(value == null ? '-' : value);
    els.taskCount.classList.toggle('is-muted', Boolean(muted));
  }

  async function refreshTaskCount() {
    if (taskState.loading || !els.taskCount) return;
    taskState.loading = true;

    try {
      let taskCountUrl = '/school/master-hub/api/task-count';
      if (canManageAllTasks && !workspaceState.taskShowAll) {
        taskCountUrl += '?assignment=mine';
      }
      const response = await fetch(taskCountUrl, {
        headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        credentials: 'same-origin'
      });
      const payload = await response.json().catch(function () {
        return { status: 'error', message: 'Unable to read task count.' };
      });
      if (!response.ok || payload.status !== 'success') {
        throw new Error(payload.message || 'Unable to read task count.');
      }
      setTaskCount(payload.unresolvedCount || 0, false);
    } catch (error) {
      setTaskCount('-', true);
    } finally {
      taskState.loading = false;
    }
  }

  function restartTaskTimer() {
    if (taskState.timer) {
      window.clearInterval(taskState.timer);
      taskState.timer = null;
    }

    refreshTaskCount();
    taskState.timer = window.setInterval(refreshTaskCount, Math.max(10, taskState.intervalSeconds) * 1000);
  }

  function applyTaskInterval(value) {
    const parsed = Number(value);
    taskState.intervalSeconds = Number.isFinite(parsed) && parsed >= 10 ? parsed : 60;
    restartTaskTimer();
  }

  async function openTaskSettings() {
    if (typeof window.showMessageModal !== 'function') {
      renderWorkspaceStatus('Message modal is not available on this page.', 'bi-exclamation-triangle', 'danger');
      return;
    }

    const inputId = 'schoolMasterHubTaskIntervalInput';
    const selected = await window.showMessageModal({
      title: 'Task refresh timer',
      icon: 'info',
      size: 'md',
      message: [
        '<p class="mb-3">Set how often Master Hub checks unresolved or incomplete tasks while this page remains open.</p>',
        '<label class="form-label fw-semibold" for="' + inputId + '">Interval timer, in seconds</label>',
        '<div class="input-group">',
        '<input type="number" class="form-control" id="' + inputId + '" min="10" step="5" value="' + escapeHtml(taskState.intervalSeconds || 60) + '">',
        '<span class="input-group-text">seconds</span>',
        '</div>',
        '<div class="form-text">Default is 60 seconds. Minimum allowed value is 10 seconds.</div>'
      ].join(''),
      buttons: [
        { text: 'Cancel', class: 'btn-secondary' },
        { text: 'Save Timer', class: 'btn-primary' }
      ]
    });

    if (selected === 'Save Timer') {
      const input = document.getElementById(inputId);
      applyTaskInterval(input ? input.value : 60);
    }
  }

  const workspaceState = {
    currentSection: '',
    loading: false,
    serverSearch: {
      tasks: '',
      classes: '',
      activities: '',
      sessions: '',
      'session-issues': '',
      'timesheet-periods': '',
      'timesheet-management': '',
      'report-assignments': '',
      'report-instances': '',
      holidays: ''
    },
    holidaysYear: String((typeof orgToday !== 'undefined' && orgToday) ? String(orgToday).slice(0, 4) : hubTodayIso().slice(0, 4))
    ,
    taskShowAll: canManageAllTasks ? readTaskAdminShowAll() : false,
    taskPersonId: '',
    taskPersonName: '',
    activityPersonId: '',
    activityPersonName: '',
    reportAssignmentTeacherPersonId: '',
    reportAssignmentTeacherName: '',
    reportAssignmentScope: '',
    academicLedgerStudents: []
  };

  const workspaceSections = {
    tasks: {
      label: 'School Tasks',
      endpoint: '/school/master-hub/api/workspace/tasks',
      sourceUrl: '/school/tasks',
      icon: 'bi bi-list-task'
    },
    classes: {
      label: 'Classes',
      endpoint: '/school/master-hub/api/workspace/classes',
      sourceUrl: '/school/classes',
      icon: 'bi bi-easel-fill'
    },
    activities: {
      label: 'Activities',
      endpoint: '/school/master-hub/api/workspace/activities',
      sourceUrl: '/school/activities',
      icon: 'bi bi-list-check'
    },
    'timesheet-periods': {
      label: 'Timesheet Periods',
      endpoint: '/school/master-hub/api/workspace/timesheet-periods',
      sourceUrl: '/school/timesheetPeriods',
      icon: 'bi bi-calendar-week-fill'
    },
    'timesheet-management': {
      label: 'Timesheet Management',
      endpoint: '/school/master-hub/api/workspace/timesheet-management',
      sourceUrl: '/school/timesheets/manage',
      icon: 'bi bi-table'
    },
    'report-assignments': {
      label: 'Report Assignments',
      endpoint: '/school/master-hub/api/workspace/report-assignments',
      sourceUrl: '/school/reports/assignments',
      icon: 'bi bi-clipboard2-check-fill'
    },
    'report-instances': {
      label: 'Report Instances',
      endpoint: '/school/master-hub/api/workspace/report-instances',
      sourceUrl: '/school/reports/instances',
      icon: 'bi bi-file-earmark-text-fill'
    },
    holidays: {
      label: 'Holidays',
      endpoint: '/school/master-hub/api/workspace/holidays',
      sourceUrl: '/school/holidays',
      icon: 'bi bi-calendar-event-fill'
    },
    'academic-ledger': {
      label: 'Academic Ledger',
      endpoint: '/school/master-hub/api/workspace/academic-ledger',
      sourceUrl: '/school/academic-ledger',
      icon: 'bi bi-journal-bookmark-fill'
    }
  };

  function setWorkspaceButtons(activeKey) {
    els.workspaceButtons.forEach(function (button) {
      const key = button.getAttribute('data-hub-workspace-section') || '';
      const segment = button.closest('.hub-section-segment');
      if (segment) {
        segment.classList.toggle('is-active', key === activeKey);
      }
    });
  }

  function renderWorkspaceStatus(message, icon, tone) {
    if (!els.workspace) return;
    els.workspace.innerHTML = [
      '<div class="hub-stage-empty text-' + escapeHtml(tone || 'muted') + '">',
      '<div class="text-center px-4">',
      '<i class="bi ' + escapeHtml(icon || 'bi-grid-1x2-fill') + ' display-5 d-block mb-3"></i>',
      '<h2 class="h5">' + escapeHtml(message || 'Select a section to begin.') + '</h2>',
      '</div>',
      '</div>'
    ].join('');
  }

  function statusBadgeClass(status) {
    const value = String(status || '').toLowerCase();
    if (value === 'resolved') return 'text-bg-success';
    if (value === 'in_progress') return 'text-bg-primary';
    if (value === 'dismissed') return 'text-bg-secondary';
    return 'text-bg-warning';
  }

  function severityBadgeClass(severity) {
    const value = String(severity || '').toLowerCase();
    if (value === 'critical' || value === 'high') return 'text-bg-danger';
    if (value === 'warning' || value === 'medium') return 'text-bg-warning';
    if (value === 'success' || value === 'low') return 'text-bg-success';
    return 'text-bg-info';
  }

  function workspaceToolbarHtml(key, options) {
    const opts = options || {};
    const label = opts.label || 'records';
    const serverValue = workspaceState.serverSearch[key] || '';
    return [
      '<div class="hub-workspace-toolbar">',
      '<div class="row g-2 align-items-end">',
      '<div class="col-lg-6">',
      '<label class="form-label small fw-semibold" for="hubServerSearch_' + escapeHtml(key) + '">DB Search</label>',
      '<div class="input-group">',
      '<input type="search" class="form-control form-control-sm" id="hubServerSearch_' + escapeHtml(key) + '" data-hub-server-search-input="' + escapeHtml(key) + '" value="' + escapeHtml(serverValue) + '" placeholder="Search ' + escapeHtml(label) + ' in database...">',
