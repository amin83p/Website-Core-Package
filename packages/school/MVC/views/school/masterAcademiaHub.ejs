  function normalizeSessionStatusCode(value) {
    return String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
  }

  function toSessionStatusLabel(status) {
    const normalized = normalizeSessionStatusCode(status);
    if (!normalized) return 'Status';
    return normalized.replace(/_/g, ' ').replace(/\b\w/g, function (ch) { return ch.toUpperCase(); });
  }

  function normalizeHubHexColor(value, fallback) {
    const raw = String(value || '').trim();
    const normalized = raw.startsWith('#') ? raw : '#' + raw;
    return /^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(normalized) ? normalized : (fallback || '#e2e3e5');
  }

  function hubColorToRgba(value, alpha, fallback) {
    const hex = normalizeHubHexColor(value, fallback || '#e2e3e5').replace('#', '');
    const full = hex.length === 3 ? hex.split('').map(function (ch) { return ch + ch; }).join('') : hex;
    const r = Number.parseInt(full.slice(0, 2), 16);
    const g = Number.parseInt(full.slice(2, 4), 16);
    const b = Number.parseInt(full.slice(4, 6), 16);
    const safeAlpha = Math.max(0, Math.min(1, Number(alpha)));
    return 'rgba(' + r + ', ' + g + ', ' + b + ', ' + safeAlpha + ')';
  }

  function buildSessionStatusMetaMap(statusMeta) {
    const map = new Map();
    (Array.isArray(statusMeta) ? statusMeta : []).forEach(function (row) {
      const code = normalizeSessionStatusCode(row && row.code);
      if (code) map.set(code, row);
    });
    return map;
  }

  function buildSessionStatusBadgeHtml(status, statusMap) {
    const normalized = normalizeSessionStatusCode(status);
    const meta = statusMap.get(normalized);
    if (meta) {
      return '<span class="status-badge border" style="background:' + escapeHtml(meta.colorBg || '#e2e3e5') + ';color:' + escapeHtml(meta.colorText || '#41464b') + ';border-color:' + escapeHtml(meta.colorBorder || '#c6c8ca') + ' !important;">' + escapeHtml(meta.label || toSessionStatusLabel(normalized)) + '</span>';
    }
    return '<span class="status-badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle">' + escapeHtml(toSessionStatusLabel(normalized || 'other')) + '</span>';
  }

  function buildSessionCaseBadgeHtml(caseSummary) {
    if (!caseSummary || !caseSummary.hasCases) return '';
    const tone = String(caseSummary.badgeTone || 'muted').trim().toLowerCase();
    const classMap = {
      danger: 'bg-danger-subtle text-danger-emphasis border-danger-subtle',
      warning: 'bg-warning-subtle text-warning-emphasis border-warning-subtle',
      info: 'bg-info-subtle text-info-emphasis border-info-subtle',
      muted: 'bg-secondary-subtle text-secondary-emphasis border-secondary-subtle'
    };
    const label = caseSummary.badgeLabel || (String(caseSummary.totalCount || '0') + ' case(s)');
    const title = [
      'Cases: ' + String(caseSummary.totalCount || 0),
      'Active: ' + String(caseSummary.activeCount || 0),
      'Urgent: ' + String(caseSummary.urgentCount || 0),
      'Warning: ' + String(caseSummary.warningCount || 0),
      'Info: ' + String(caseSummary.infoCount || 0),
      'Resolved/closed: ' + String(caseSummary.resolvedCount || 0)
    ].join(' | ');
    return '<span class="badge border ms-1 ' + (classMap[tone] || classMap.muted) + '" title="' + escapeHtml(title) + '"><i class="bi bi-exclamation-diamond-fill me-1"></i>' + escapeHtml(label) + '</span>';
  }

  function buildSessionMakeupBadgeHtml(row) {
    if (row && row.makeup && row.makeup.isMakeup) {
      return '<span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle ms-1"><i class="bi bi-arrow-return-left me-1"></i>Make-up</span>';
    }
    const count = Array.isArray(row && row.makeupHistory) ? row.makeupHistory.length : 0;
    if (count > 0) {
      return '<span class="badge bg-success-subtle text-success-emphasis border border-success-subtle ms-1"><i class="bi bi-calendar-check me-1"></i>' + escapeHtml(String(count)) + ' make-up</span>';
    }
    if (row && row.makeUpRequired === true) {
      return '<span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle ms-1"><i class="bi bi-calendar-plus me-1"></i>Make-up available</span>';
    }
    return '';
  }

  function formatHubSessionLockBadge(row) {
    if (!row || (row.locked !== true && String(row.locked) !== 'true')) return '';
    if (String(row.lockReason || '') === 'timesheet_approved') {
      return '<span class="badge bg-warning text-dark border ms-1"><i class="bi bi-lock-fill me-1"></i>Timesheet Locked</span>';
    }
    return '<span class="badge bg-dark-subtle text-dark border ms-1"><i class="bi bi-lock-fill me-1"></i>Locked</span>';
  }

  function buildSessionRowStyle(status, locked, statusMap) {
    const normalized = normalizeSessionStatusCode(status);
    const meta = statusMap.get(normalized);
    const colorBg = normalizeHubHexColor(meta && meta.colorBg, normalized === 'holiday' ? '#fff3cd' : '#e2e3e5');
    const colorBorder = normalizeHubHexColor(meta && meta.colorBorder, normalized === 'holiday' ? '#ffe69c' : '#c6c8ca');
    const baseLayer = 'linear-gradient(' + hubColorToRgba(colorBg, 0.20, colorBg) + ', ' + hubColorToRgba(colorBg, 0.20, colorBg) + ')';
    const lockLayer = locked
      ? ', repeating-linear-gradient(-45deg, ' + hubColorToRgba('#6c757d', 0.08, '#6c757d') + ' 0 10px, ' + hubColorToRgba('#adb5bd', 0.18, '#adb5bd') + ' 10px 20px)'
      : '';
    return [
      'background-color:' + hubColorToRgba(colorBg, locked ? 0.14 : 0.20, colorBg),
      'background-image:' + baseLayer + lockLayer,
      'border-left:4px solid ' + (locked ? '#6c757d' : colorBorder)
    ].join(';');
  }

  function hubInputValue(id) {
    const el = document.getElementById(id);
    return el ? String(el.value || '').trim() : '';
  }

  let hubSessionTeacherSelections = [];
  let hubSessionIssueTeacherSelections = [];
  let hubSessionIssueStudentSelections = [];
  let hubSessionIssueClassSelections = [];
  let hubReportAssignmentClassSelections = [];
  let hubReportInstanceClassSelections = [];
  let hubReportInstanceTeacherSelections = [];
  let hubReportInstanceStudentSelections = [];
  let hubSessionRowsByKey = new Map();
  let hubSessionStatusMeta = [];
  let hubSessionCanUpdateSessions = false;

  function resolveHubTeacherId(item) {
    if (!item || typeof item !== 'object') return '';
    return String(item.personId || item.teacherPersonId || (item.person && item.person.id) || item.id || item._id || '').trim();
  }

  function formatHubTeacherName(item, fallbackId) {
    if (!item || typeof item !== 'object') return String(fallbackId || '').trim();
    const direct = String(item.displayName || item.fullName || item.personName || item.name || item.title || '').trim();
    if (direct && direct !== '[object Object]') return direct;
    const personName = item.person && item.person.name ? item.person.name : null;
    const nameObject = item.name && typeof item.name === 'object' ? item.name : personName;
    if (nameObject && typeof nameObject === 'object') {
      const fromObject = [
        nameObject.first || nameObject.given || '',
        nameObject.middle || '',
        nameObject.last || nameObject.family || ''
      ].map(function (part) { return String(part || '').trim(); }).filter(Boolean).join(' ');
      if (fromObject) return fromObject;
    }
    const fromFlat = [
      item.firstName || item.first || '',
      item.middleName || item.middle || '',
      item.lastName || item.last || ''
    ].map(function (part) { return String(part || '').trim(); }).filter(Boolean).join(' ');
    return fromFlat || String(fallbackId || item.id || '').trim();
  }

  function splitHubIdList(value) {
    return String(value || '').split(',').map(function (item) {
      return item.trim();
    }).filter(Boolean);
  }

  function sameHubIdList(first, second) {
    const left = splitHubIdList(first).join(',');
    const right = splitHubIdList(second).join(',');
    return left === right;
  }

  function getHubSessionTeacherDisplay(filterValue) {
    const ids = splitHubIdList(filterValue);
    if (!ids.length) return '';
    const selectionMap = new Map(hubSessionTeacherSelections.map(function (item) {
      return [String(item.id || '').trim(), item];
    }));
    return ids.map(function (id) {
      const selected = selectionMap.get(id);
      return selected ? (selected.name || selected.id) : id;
    }).join(', ');
  }

  function renderHubSessionTeacherChips() {
    const container = document.getElementById('hubSessionTeacherChips');
    if (!container) return;
    if (!hubSessionTeacherSelections.length) {
      container.innerHTML = '<div class="text-muted small">No teacher filter selected.</div>';
      return;
    }
    container.innerHTML = hubSessionTeacherSelections.map(function (item) {
      return [
        '<span class="badge rounded-pill text-bg-light border d-inline-flex align-items-center gap-1 px-2 py-1 me-1 mb-1">',
        '<span>' + escapeHtml(item.name || item.id) + '</span>',
        '<button type="button" class="btn-close btn-close-sm ms-1" style="font-size:0.62rem;" aria-label="Remove ' + escapeHtml(item.name || item.id) + '" data-hub-session-remove-teacher="' + escapeHtml(item.id) + '"></button>',
        '</span>'
      ].join('');
    }).join('');
  }

  function syncHubSessionTeacherInputs() {
    const idEl = document.getElementById('hubSessionTeacherId');
    const nameEl = document.getElementById('hubSessionTeacherName');
    const ids = hubSessionTeacherSelections.map(function (item) { return item.id; }).filter(Boolean);
    if (idEl) idEl.value = ids.join(',');
    if (nameEl) nameEl.value = hubSessionTeacherSelections.map(function (item) { return item.name || item.id; }).join(', ');
    renderHubSessionTeacherChips();
  }

  function appendSessionWorkspaceQuery(requestQuery) {
    const values = {
      startDate: hubInputValue('hubSessionStartDate'),
      endDate: hubInputValue('hubSessionEndDate'),
      startTime: hubInputValue('hubSessionStartTime'),
      endTime: hubInputValue('hubSessionEndTime'),
      teacherId: hubInputValue('hubSessionTeacherId'),
      classId: hubInputValue('hubSessionClassId'),
      status: hubInputValue('hubSessionStatus')
    };

    Object.keys(values).forEach(function (key) {
      if (values[key]) requestQuery.set(key, values[key]);
    });
    const hasCasesEl = document.getElementById('hubSessionHasCases');
    if (hasCasesEl && hasCasesEl.checked) requestQuery.set('hasCases', '1');
  }

  function setHubSessionDateRange(range) {
    const startEl = document.getElementById('hubSessionStartDate');
    const endEl = document.getElementById('hubSessionEndDate');
    if (!startEl || !endEl) return;
    const today = hubTodayDate();
    let start = new Date(today);
    let end = new Date(today);

    if (range === 'allTime') {
      startEl.value = '';
      endEl.value = '';
      loadWorkspaceSection('sessions');
      return;
    }
    if (range === 'thisWeek') {
      const day = today.getDay() || 7;
      start.setDate(today.getDate() - (day - 1));
      end = new Date(start);
      end.setDate(start.getDate() + 6);
    } else if (range === 'thisMonth') {
      start = new Date(today.getFullYear(), today.getMonth(), 1);
      end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
    }

    startEl.value = hubDateToIso(start);
    endEl.value = hubDateToIso(end);
    loadWorkspaceSection('sessions');
  }

  function truncateHubText(value, maxLength) {
    const text = String(value || '').trim();
    if (!text) return '-';
    const limit = Number(maxLength || 40);
    return text.length > limit ? text.slice(0, limit) + '...' : text;
  }

  function openHubSessionTeacherPicker() {
    if (!window.GenericPicker || !window.GenericPickerPresets) {
      showHubMessage({ title: 'Teacher Picker', icon: 'warning', message: 'Teacher picker is not available yet.' });
      return;
    }
    window.GenericPicker.open(window.GenericPickerPresets.teacher({
      title: 'Filter by Teachers',
      placeholder: 'Search teachers, select one or more...',
