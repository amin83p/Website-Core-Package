  const hubScheduleState = {
    persons: [],
    activePersonId: '',
    eventsByPersonId: {},
    statusMetaByPersonId: {},
    loadedPersonIds: new Set(),
    loadingPersonId: '',
    viewMode: 'auto'
  };

  function resolveHubSchedulePersonId(item) {
    return String(item?.personId || item?.id || item?._id || '').trim();
  }

  function formatHubSchedulePersonName(item, fallbackId) {
    const direct = String(item?.displayName || item?.fullName || item?.label || item?.personName || item?.name || '').trim();
    if (direct && direct !== '[object Object]') return direct;
    const objectName = item?.name && typeof item.name === 'object' ? item.name : null;
    if (objectName) {
      const fromObject = [objectName.first, objectName.middle, objectName.last]
        .map(function (part) { return String(part || '').trim(); })
        .filter(Boolean)
        .join(' ');
      if (fromObject) return fromObject;
    }
    const fromParts = [item?.firstName, item?.middleName, item?.lastName]
      .map(function (part) { return String(part || '').trim(); })
      .filter(Boolean)
      .join(' ');
    return fromParts || String(fallbackId || '').trim();
  }

  function normalizeHubScheduleRole(value) {
    return String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
  }

  function isHubScheduleLeaveEvent(event) {
    return [
      event?.eventType,
      event?.targetType,
      event?.status,
      event?.role,
      event?.roleLabel
    ].map(function (value) {
      return String(value || '').trim().toLowerCase();
    }).some(function (value) {
      return value === 'leave_request' || value === 'approved_leave' || value === 'approved_leave_snapshot' || value === 'leave';
    });
  }

  function buildHubScheduleStatusMap(statusMeta) {
    const map = new Map();
    (Array.isArray(statusMeta) ? statusMeta : []).forEach(function (row) {
      const code = normalizeSessionStatusCode(row && row.code);
      if (code) map.set(code, row);
    });
    return map;
  }

  function hubScheduleStatusLabel(status, statusMap) {
    const normalized = normalizeSessionStatusCode(status);
    const meta = statusMap.get(normalized);
    if (meta && meta.label) return meta.label;
    if (normalized === 'approved_leave' || normalized === 'approved_leave_snapshot') return 'Approved Leave';
    return toSessionStatusLabel(normalized || 'scheduled');
  }

  function hubScheduleStatusBadge(status, statusMap) {
    const normalized = normalizeSessionStatusCode(status);
    const meta = statusMap.get(normalized);
    if (meta) {
      return '<span class="status-badge border" style="background:' + escapeHtml(meta.colorBg || '#e2e3e5') + ';color:' + escapeHtml(meta.colorText || '#41464b') + ';border-color:' + escapeHtml(meta.colorBorder || '#c6c8ca') + ' !important;">' + escapeHtml(meta.label || hubScheduleStatusLabel(status, statusMap)) + '</span>';
    }
    if (normalized === 'approved_leave' || normalized === 'approved_leave_snapshot') {
      return '<span class="status-badge border" style="background:#fff3cd;color:#7a4d00;border-color:#f59f00 !important;">Approved Leave</span>';
    }
    return '<span class="status-badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle">' + escapeHtml(hubScheduleStatusLabel(status, statusMap)) + '</span>';
  }

  function getHubScheduleRange() {
    const today = hubTodayIso();
    return {
      startDate: hubInputValue('hubScheduleStartDate') || today,
      endDate: hubInputValue('hubScheduleEndDate') || today
    };
  }

  function hubScheduleHasCasesOnly() {
    const el = document.getElementById('hubScheduleHasCases');
    return Boolean(el && el.checked);
  }

  function setHubScheduleRange(range) {
    const startEl = document.getElementById('hubScheduleStartDate');
    const endEl = document.getElementById('hubScheduleEndDate');
    if (!startEl || !endEl) return;
    const today = hubTodayDate();
    let start = new Date(today);
    let end = new Date(today);

    if (range === 'week') {
      const day = today.getDay() || 7;
      start.setDate(today.getDate() - (day - 1));
      end = new Date(start);
      end.setDate(start.getDate() + 6);
    } else if (range === 'lastMonth') {
      start = new Date(today.getFullYear(), today.getMonth() - 1, 1);
      end = new Date(today.getFullYear(), today.getMonth(), 0);
    } else if (range === 'lastTwoMonth') {
      start = new Date(today.getFullYear(), today.getMonth() - 2, 1);
      end = new Date(today.getFullYear(), today.getMonth(), 0);
    } else if (range === 'lastThreeMonth') {
      start = new Date(today.getFullYear(), today.getMonth() - 3, 1);
      end = new Date(today.getFullYear(), today.getMonth(), 0);
    } else if (range === 'first15') {
      start = new Date(today.getFullYear(), today.getMonth(), 1);
      end = new Date(today.getFullYear(), today.getMonth(), 15);
    } else if (range === 'second15') {
      start = new Date(today.getFullYear(), today.getMonth(), 16);
      end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
    } else if (range === 'month') {
      start = new Date(today.getFullYear(), today.getMonth(), 1);
      end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
    } else if (range === 'twoMonth') {
      start = new Date(today.getFullYear(), today.getMonth(), 1);
      end = new Date(today.getFullYear(), today.getMonth() + 2, 0);
    } else if (range === 'threeMonth') {
      start = new Date(today.getFullYear(), today.getMonth(), 1);
      end = new Date(today.getFullYear(), today.getMonth() + 3, 0);
    }

    startEl.value = hubDateToIso(start);
    endEl.value = hubDateToIso(end);
    hubScheduleState.eventsByPersonId = {};
    hubScheduleState.statusMetaByPersonId = {};
    hubScheduleState.loadedPersonIds.clear();
    hubScheduleState.viewMode = 'auto';
    refreshHubScheduleActiveView();
  }

  function activeHubSchedulePerson() {
    return hubScheduleState.persons.find(function (person) {
      return person.id === hubScheduleState.activePersonId;
    }) || null;
  }

  function renderHubScheduleTabs() {
    const host = document.getElementById('hubSchedulePersonTabs');
    if (!host) return;
    if (!hubScheduleState.persons.length) {
      host.innerHTML = '<div class="text-muted small">Select one or more school people to create schedule tabs.</div>';
      return;
    }
    host.innerHTML = hubScheduleState.persons.map(function (person) {
      const active = person.id === hubScheduleState.activePersonId;
      return [
        '<button type="button" class="btn btn-sm ' + (active ? 'btn-primary' : 'btn-outline-primary') + ' hub-schedule-person-tab" data-hub-schedule-person-tab="' + escapeHtml(person.id) + '">',
        '<i class="bi bi-person-circle"></i>',
        '<span>' + escapeHtml(person.name || person.id) + '</span>',
        '<span class="badge ' + (active ? 'text-bg-light' : 'text-bg-primary') + '">' + escapeHtml((person.availableRoles || []).length || 'All') + '</span>',
        '</button>'
      ].join('');
    }).join('');
  }

  function renderHubScheduleRoleOptions(person) {
    const roleSelect = document.getElementById('hubScheduleRole');
    if (!roleSelect) return;
    const currentRole = String(person?.selectedRole || '').trim();
    const roles = Array.isArray(person?.availableRoles) ? person.availableRoles : [];
    roleSelect.innerHTML = '<option value="">All Roles</option>' + roles.map(function (role) {
      const key = String(role?.key || '').trim();
      if (!key) return '';
      return '<option value="' + escapeHtml(key) + '"' + (key === currentRole ? ' selected' : '') + '>' + escapeHtml(role.label || toSessionStatusLabel(key)) + '</option>';
    }).join('');
  }

  const HUB_TIMELINE_START_HOUR = 7;
  const HUB_TIMELINE_END_HOUR = 22;
  const HUB_TIMELINE_TOTAL_MINUTES = (HUB_TIMELINE_END_HOUR - HUB_TIMELINE_START_HOUR) * 60;

  function hubScheduleTimeToMinutes(timeStr) {
    if (!timeStr) return 0;
    const parts = String(timeStr || '').split(':').map(Number);
    const hour = Number(parts[0] || 0);
    const minute = Number(parts[1] || 0);
    return (hour * 60) + minute;
  }

  function hubScheduleCalculatePosition(startStr, endStr) {
    let startMin = hubScheduleTimeToMinutes(startStr);
    let endMin = hubScheduleTimeToMinutes(endStr);
    const timelineStartMin = HUB_TIMELINE_START_HOUR * 60;
    const timelineEndMin = HUB_TIMELINE_END_HOUR * 60;
    if (startMin < timelineStartMin) startMin = timelineStartMin;
    if (endMin > timelineEndMin) endMin = timelineEndMin;
    if (endMin <= startMin) endMin = startMin + 30;
    return {
      left: ((startMin - timelineStartMin) / HUB_TIMELINE_TOTAL_MINUTES) * 100,
      width: ((endMin - startMin) / HUB_TIMELINE_TOTAL_MINUTES) * 100,
      startMin,
      endMin
    };
  }

  function isReportScheduleEvent(event) {
    return String(event?.eventType || '').trim().toLowerCase() === 'report_task'
      || Boolean(String(event?.assignmentId || '').trim());
  }

  function buildReportPriorityMarker(event) {
    if (!isReportScheduleEvent(event)) return '';
    return '<span class="report-priority-marker" role="img" aria-label="Important report" title="Important report"><i class="bi bi-stars" aria-hidden="true"></i></span>';
  }

  function getHubScheduleEventTitle(event) {
    return String(event?.className || event?.title || event?.label || event?.classId || 'Schedule Item').trim();
  }

  function getHubScheduleEventDetailsUrl(event) {
    return String(event?.detailsUrl || '').trim() || (
      event?.sessionId && event?.classId
        ? '/school/classes/' + encodeURIComponent(event.classId) + '/sessions/' + encodeURIComponent(event.sessionId)
        : ''
    );
  }

  function groupHubScheduleEventsByDate(events) {
    const grouped = {};
    (Array.isArray(events) ? events : []).forEach(function (event) {
      const date = String(event?.date || '').trim();
      if (!date) return;
      if (!grouped[date]) grouped[date] = [];
      grouped[date].push(event);
    });
    Object.keys(grouped).forEach(function (date) {
      grouped[date].sort(function (a, b) {
        const aStart = hubScheduleTimeToMinutes(a?.start);
        const bStart = hubScheduleTimeToMinutes(b?.start);
        if (aStart !== bStart) return aStart - bStart;
        return getHubScheduleEventTitle(a).localeCompare(getHubScheduleEventTitle(b));
      });
    });
    return grouped;
  }

  function hubScheduleEventScanBadge(event, statusMap) {
    const scd = window.ScheduleCompletionDisplay;
    if (!scd) return hubScheduleStatusBadge(event && event.status, statusMap);
    const scan = scd.resolveScheduleCompletionScan(event, statusMap);
    return scd.buildScheduleStatusBadge(scan, hubScheduleStatusLabel(event && event.status, statusMap), '');
  }

  function renderHubScheduleLegend(mode) {
    const host = document.getElementById('hubScheduleLegend');
    if (!host) return;
    if (mode === 'calendar') {
      host.innerHTML = '<div class="text-primary fw-bold"><i class="bi bi-circle-fill small"></i> Active Day</div><div class="text-success fw-bold"><i class="bi bi-check-circle-fill small"></i> Complete count</div><div class="text-warning fw-bold"><i class="bi bi-clock-history small"></i> Pending count</div><div class="text-danger fw-bold"><i class="bi bi-exclamation-circle-fill"></i> Conflict Day</div><div class="text-danger fw-bold"><i class="bi bi-stars me-1"></i> Important report</div><div class="text-warning fw-bold"><i class="bi bi-circle-fill small"></i> Leave Day</div><div class="text-muted small">Click any day to load its day view</div><button type="button" class="btn btn-sm btn-outline-primary" data-hub-schedule-view-timeline aria-label="Switch to day view" title="Show scheduled sessions in the colored time timeline"><i class="bi bi-calendar-day me-1"></i>Switch to day view</button>';
      return;
    }
    if (mode === 'timeline') {
      host.innerHTML = '<div class="text-primary fw-bold"><i class="bi bi-calendar-day me-1"></i> Day view</div><div><span class="d-inline-block rounded-circle" style="width:12px;height:12px;background:#0dcaf0;"></span> Teacher/Staff</div><div><span class="d-inline-block rounded-circle" style="width:12px;height:12px;background:#0d6efd;"></span> Student</div><div><span class="d-inline-block rounded-circle" style="width:12px;height:12px;background:#ffd43b;"></span> Approved Leave</div><div class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> Complete</div><div class="text-warning fw-bold"><i class="bi bi-clock-history"></i> Pending</div><div class="text-danger fw-bold"><span class="d-inline-block rounded-circle" style="width:12px;height:12px;background:#dc3545;"></span> Overlap</div><div class="text-danger fw-bold"><i class="bi bi-stars me-1"></i> Important report</div><button type="button" class="btn btn-sm btn-outline-primary" data-hub-schedule-view-month aria-label="Switch to month view" title="Show the calendar month view"><i class="bi bi-calendar3 me-1"></i>Switch to month view</button>';
      return;
    }
    if (mode === 'single') {
      host.innerHTML = '<div class="text-success fw-bold"><i class="bi bi-check-circle-fill"></i> Complete</div><div class="text-warning fw-bold"><i class="bi bi-clock-history"></i> Pending</div><div class="text-muted small">Vertical full-detail day view</div>';
      return;
    }
    host.innerHTML = '<div class="text-muted small">Vertical full-detail view for selected day</div>';
  }

  function renderHubScheduleSingleDayView(eventsByDate, statusMap) {
    const scd = window.ScheduleCompletionDisplay;
    const dates = Object.keys(eventsByDate || {}).sort();
    if (!dates.length) {
      return '<div class="alert alert-light text-center border py-4 text-muted">No schedule items found for this day.</div>';
    }
    let html = '<div class="single-day-list">';
    dates.forEach(function (dateStr) {
      const dateObj = new Date(dateStr + 'T00:00:00');
      const displayDate = dateObj.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
      const dayEvents = eventsByDate[dateStr] || [];
      const hasConflict = dayEvents.some(function (event) { return event?.hasOverlap; });
      const daySummary = scd ? scd.summarizeDayCompletion(dayEvents, statusMap) : null;
      const completionChip = scd && daySummary ? scd.buildDayCompletionChip(daySummary) : '';
      html += '<div class="day-card"><div class="day-card-header ' + (hasConflict ? 'conflict' : '') + '"><span>' + escapeHtml(displayDate) + '</span><span class="d-flex align-items-center gap-2 flex-wrap justify-content-end">' + completionChip + '<span class="badge ' + (hasConflict ? 'bg-danger' : 'bg-primary') + '">' + escapeHtml(dayEvents.length) + ' item' + (dayEvents.length === 1 ? '' : 's') + '</span></span></div>';
      dayEvents.forEach(function (event) {
        const leave = isHubScheduleLeaveEvent(event);
        const title = getHubScheduleEventTitle(event);
        const detailUrl = getHubScheduleEventDetailsUrl(event);
        const scan = scd ? scd.resolveScheduleCompletionScan(event, statusMap) : null;
        const rowClasses = scd
          ? scd.buildScheduleRowClasses(scan, 'event-row ' + (event?.hasOverlap ? 'overlap ' : ''))
          : 'event-row ' + (event?.hasOverlap ? 'overlap ' : '') + (leave ? 'leave-event' : '');
        const scanIcon = scd ? scd.buildScheduleScanIcon(scan) : '';
        const statusBadge = hubScheduleEventScanBadge(event, statusMap);
        const caseBadge = buildSessionCaseBadgeHtml(event?.caseSummary);
        html += [
          '<div class="' + rowClasses + '">',
          '<div class="schedule-scan-cell">' + scanIcon + '</div>',
          '<div class="event-time">' + escapeHtml(event?.start || '-') + ' - ' + escapeHtml(event?.end || '-') + '</div>',
          '<div>',
          '<div class="fw-bold">' + buildReportPriorityMarker(event) + escapeHtml(title) + '</div>',
          '<div class="mt-1 d-flex flex-wrap gap-2 align-items-center">',
          '<span class="badge ' + (leave ? 'bg-warning-subtle text-warning-emphasis border border-warning-subtle' : 'bg-primary-subtle text-primary border') + '">' + escapeHtml(leave ? 'Approved Leave' : (event?.role || event?.roleLabel || '-')) + '</span>',
          caseBadge,
          statusBadge,
          '<span class="text-muted small">' + escapeHtml(Number(event?.duration || 0).toFixed(2)) + ' h</span>',
          event?.hasOverlap ? '<span class="badge bg-danger">Overlap</span>' : '',
          '</div>',
          '</div>',
          '<div class="event-actions">' + (detailUrl ? '<a class="btn btn-sm btn-outline-primary" href="' + escapeHtml(detailUrl) + '" target="_blank" rel="noopener">Open</a>' : '<span class="text-muted small">No details</span>') + '</div>',
          '</div>'
        ].join('');
      });
      html += '</div>';
    });
    return html + '</div>';
  }

  function renderHubScheduleTimelineView(eventsByDate, statusMap) {
    const scd = window.ScheduleCompletionDisplay;
    let html = '';
    Object.keys(eventsByDate || {}).sort().forEach(function (dateStr) {
      const dayEvents = eventsByDate[dateStr] || [];
      const dateObj = new Date(dateStr + 'T00:00:00');
      const displayDate = dateObj.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
      const tracks = [];
      const hasConflict = dayEvents.some(function (event) { return event?.hasOverlap; });

      dayEvents.forEach(function (event) {
        const pos = hubScheduleCalculatePosition(event?.start, event?.end);
        event.__hubPos = pos;
        let placed = false;
        for (let i = 0; i < tracks.length; i += 1) {
          const lastEvent = tracks[i][tracks[i].length - 1];
          if (lastEvent.__hubPos.endMin <= pos.startMin) {
            tracks[i].push(event);
            event.__hubTrackIndex = i;
            placed = true;
            break;
          }
        }
        if (!placed) {
          tracks.push([event]);
          event.__hubTrackIndex = tracks.length - 1;
        }
      });

      const bodyHeight = Math.max(76, tracks.length * 64 + 14);
      html += '<div class="timeline-container shadow-sm ' + (hasConflict ? 'border-danger' : '') + '"><div class="timeline-header ' + (hasConflict ? 'conflict' : '') + '"><span>' + escapeHtml(displayDate) + '</span><span>' + (hasConflict ? '<i class="bi bi-exclamation-triangle-fill me-1"></i> Conflict Detected' : '') + '</span></div><div class="timeline-body pb-3" style="height:' + escapeHtml(bodyHeight) + 'px;">';

      dayEvents.forEach(function (event) {
        const topPos = (event.__hubTrackIndex * 62) + 7;
        const leave = isHubScheduleLeaveEvent(event);
        const roleText = String(event?.role || event?.roleLabel || '').toLowerCase();
        const cssClass = leave ? 'event-leave' : (roleText.includes('teacher') || roleText.includes('staff') ? 'role-teacher' : 'role-student');
        const title = getHubScheduleEventTitle(event);
        const detailUrl = getHubScheduleEventDetailsUrl(event);
        const encodedDetailUrl = encodeURIComponent(detailUrl);
        const caseBadge = buildSessionCaseBadgeHtml(event?.caseSummary);
        const scan = scd ? scd.resolveScheduleCompletionScan(event, statusMap) : null;
        const blockClasses = scd
          ? scd.buildScheduleBlockClasses(scan, 'event-block ' + cssClass + ' ' + (event?.hasOverlap ? 'border-danger border-2' : ''))
          : 'event-block ' + cssClass + ' ' + (event?.hasOverlap ? 'border-danger border-2' : '');
        const scanIcon = scd && scan && scan.state !== 'leave' ? '<i class="bi ' + escapeHtml(scan.iconClass) + ' block-scan-icon" aria-hidden="true"></i>' : '';
        html += [
          '<div class="' + blockClasses + '"',
          ' style="left:' + escapeHtml(event.__hubPos.left) + '%;width:' + escapeHtml(event.__hubPos.width) + '%;top:' + escapeHtml(topPos) + 'px;"',
          ' title="' + escapeHtml(title) + ' | ' + escapeHtml(event?.start || '-') + ' - ' + escapeHtml(event?.end || '-') + '"',
          detailUrl ? ' onclick="window.open(decodeURIComponent(\'' + escapeHtml(encodedDetailUrl) + '\'), \'_blank\')"' : '',
          '>',
          scanIcon,
          '<div class="fw-bold text-truncate">' + buildReportPriorityMarker(event) + ' ' + escapeHtml(title) + '</div>',
          caseBadge ? '<div class="mt-1">' + caseBadge + '</div>' : '',
          '<div class="event-meta x-small"><span class="text-truncate">' + escapeHtml(event?.start || '-') + ' - ' + escapeHtml(event?.end || '-') + '</span>' + hubScheduleEventScanBadge(event, statusMap) + '</div>',
          '</div>'
        ].join('');
      });

      html += '<div class="hour-markers">';
      for (let hour = HUB_TIMELINE_START_HOUR; hour < HUB_TIMELINE_END_HOUR; hour += 1) {
        const label = hour > 12 ? (hour - 12) + 'p' : (hour === 12 ? '12p' : hour + 'a');
        html += '<div class="hour-marker"><span class="hour-label">' + escapeHtml(label) + '</span></div>';
      }
      html += '</div></div></div>';
    });
    return html || '<div class="alert alert-light text-center border py-4 text-muted">No schedule items found in this range.</div>';
  }

  function renderHubScheduleCalendarView(eventsByDate, startStr, endStr, statusMap) {
    const scd = window.ScheduleCompletionDisplay;
    let current = new Date(startStr + 'T00:00:00');
    current.setDate(1);
    const end = new Date(endStr + 'T00:00:00');
    end.setMonth(end.getMonth() + 1);
    end.setDate(0);
    let html = '<div class="row g-4">';
    while (current <= end) {
      const year = current.getFullYear();
      const month = current.getMonth();
      const monthName = current.toLocaleString('default', { month: 'long', year: 'numeric' });
      const firstDayIndex = new Date(year, month, 1).getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      html += '<div class="col-md-6 col-lg-4"><div class="card h-100 shadow-sm border-0"><div class="card-header bg-dark text-white text-center fw-bold py-2">' + escapeHtml(monthName) + '</div><div class="card-body p-2 bg-light"><div class="cal-grid">';
      ['S','M','T','W','T','F','S'].forEach(function (day) {
        html += '<div class="text-center x-small fw-bold text-muted mb-1">' + escapeHtml(day) + '</div>';
      });
      for (let blank = 0; blank < firstDayIndex; blank += 1) html += '<div class="cal-day empty"></div>';
      for (let dayNo = 1; dayNo <= daysInMonth; dayNo += 1) {
        const dateStr = year + '-' + String(month + 1).padStart(2, '0') + '-' + String(dayNo).padStart(2, '0');
        const dayEvents = eventsByDate[dateStr] || [];
        const hasConflict = dayEvents.some(function (event) { return event?.hasOverlap; });
        const hasLeave = dayEvents.some(isHubScheduleLeaveEvent);
        const count = dayEvents.length;
        const reportEvent = dayEvents.find(isReportScheduleEvent);
        const reportMarker = reportEvent ? buildReportPriorityMarker(reportEvent) : '';
        let classes = 'cal-day ';
        let badge = '';
        if (hasConflict) {
          classes += 'conflict';
          badge = '<div class="cal-badge bg-danger">' + escapeHtml(count) + '</div>';
        } else if (hasLeave) {
          classes += 'leave';
          badge = '<div class="cal-badge bg-warning text-dark">' + escapeHtml(count) + '</div>';
        } else if (count > 0) {
          classes += 'active';
          badge = scd
            ? scd.buildCalendarDayBadges(dayEvents, statusMap, { hasConflict: false, hasLeave: false })
            : '<div class="cal-badge bg-primary">' + escapeHtml(count) + '</div>';
        } else {
          classes += 'empty';
        }
        html += '<div class="' + classes + '" data-hub-schedule-date="' + escapeHtml(dateStr) + '">' + reportMarker + '<span class="d-block">' + escapeHtml(dayNo) + '</span>' + badge + '</div>';
      }
      html += '</div></div></div></div>';
      current.setMonth(current.getMonth() + 1);
    }
    return html + '</div>';
  }

  function renderHubScheduleEvents(person) {
    const host = document.getElementById('hubScheduleEvents');
    if (!host) return;
    if (!person) {
      host.innerHTML = '<div class="hub-empty"><div><i class="bi bi-people display-6 d-block mb-3"></i><div class="fw-semibold">Select people to view schedules.</div></div></div>';
      renderHubScheduleLegend('empty');
      return;
    }
    const events = Array.isArray(hubScheduleState.eventsByPersonId[person.id]) ? hubScheduleState.eventsByPersonId[person.id] : [];
    const statusMap = buildHubScheduleStatusMap(hubScheduleState.statusMetaByPersonId[person.id] || []);
    const hasLoaded = hubScheduleState.loadedPersonIds.has(person.id);
    if (hubScheduleState.loadingPersonId === person.id) {
      host.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div><div class="mt-2 text-muted small">Loading schedule for ' + escapeHtml(person.name || person.id) + '...</div></div>';
      renderHubScheduleLegend('loading');
      return;
    }
    if (!hasLoaded) {
      host.innerHTML = '<div class="hub-empty"><div><i class="bi bi-arrow-clockwise display-6 d-block mb-3"></i><div class="fw-semibold">Schedule is ready to load for ' + escapeHtml(person.name || person.id) + '.</div><div class="text-muted small mt-1">Set the date range and role, then click <strong>Load Tab</strong> or <strong>Load All</strong>.</div></div></div>';
      renderHubScheduleLegend('empty');
      return;
    }
    if (!events.length) {
      host.innerHTML = '<div class="hub-empty"><div><i class="bi bi-calendar-x display-6 d-block mb-3"></i><div class="fw-semibold">No schedule items found for ' + escapeHtml(person.name || person.id) + '.</div></div></div>';
      renderHubScheduleLegend('empty');
      return;
    }
    const grouped = groupHubScheduleEventsByDate(events);
    const range = getHubScheduleRange();
    const startDate = new Date(range.startDate + 'T00:00:00');
    const endDate = new Date(range.endDate + 'T00:00:00');
    const diffDays = Math.ceil((endDate - startDate) / (1000 * 60 * 60 * 24));
    let mode = 'calendar';
    let content = '';
    if (hubScheduleState.viewMode === 'timeline') {
      mode = 'timeline';
      content = renderHubScheduleTimelineView(grouped, statusMap);
    } else if (hubScheduleState.viewMode === 'calendar') {
      mode = 'calendar';
      content = renderHubScheduleCalendarView(grouped, range.startDate, range.endDate, statusMap);
    } else if (range.startDate === range.endDate || diffDays <= 0) {
      mode = 'timeline';
      content = renderHubScheduleTimelineView(grouped, statusMap);
    } else if (diffDays <= 10) {
      mode = 'timeline';
      content = renderHubScheduleTimelineView(grouped, statusMap);
    } else {
      mode = 'calendar';
      content = renderHubScheduleCalendarView(grouped, range.startDate, range.endDate, statusMap);
    }
    renderHubScheduleLegend(mode);
    host.innerHTML = '<div class="hub-schedule-visual">' + content + '</div>';
  }

  function renderHubScheduleSummary(person) {
    const host = document.getElementById('hubScheduleSummary');
    if (!host) return;
    const events = person ? (hubScheduleState.eventsByPersonId[person.id] || []) : [];
    const totals = new Map();
    (Array.isArray(events) ? events : []).forEach(function (event) {
      const duration = Number(event?.duration || 0);
      if (!Number.isFinite(duration) || duration <= 0) return;
      const labels = Array.isArray(event?.hourCategoryLabels) && event.hourCategoryLabels.length
        ? event.hourCategoryLabels
        : (function () {
          if (isHubScheduleLeaveEvent(event)) return ['Approved Leave'];
          const schoolRoles = new Set();
          [].concat(event?.roles || [], event?.role || '', event?.roleLabel || '').forEach(function (value) {
            String(value || '').split('/').map(function (part) { return part.trim(); }).filter(Boolean).forEach(function (part) {
              const normalized = String(part || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_');
              const label = normalized === 'teacher' || normalized.indexOf('school_teacher') >= 0
                ? 'Teacher'
                : (normalized === 'student' || normalized.indexOf('school_student') >= 0
                  ? 'Student'
                  : (normalized === 'staff' || normalized.indexOf('school_staff') >= 0 ? 'Staff' : ''));
              if (label) schoolRoles.add(label);
            });
          });
          if (schoolRoles.size) return Array.from(schoolRoles);
          const fallback = String(event?.roleLabel || event?.role || 'Schedule').trim();
          return fallback ? [fallback] : ['Schedule'];
        })();
      labels.forEach(function (label) {
        totals.set(label, Number(totals.get(label) || 0) + duration);
      });
    });
    if (!person || !totals.size) {
      host.innerHTML = '';
      return;
    }
    host.innerHTML = Array.from(totals.entries()).map(function ([label, hours]) {
      return '<span class="schedule-hours-chip hours-category-default me-1 mb-1"><span class="schedule-hours-dot"></span><span>' + escapeHtml(label) + ': ' + escapeHtml(hours.toFixed(2)) + ' h</span></span>';
    }).join('');
  }

  function refreshHubScheduleActiveView() {
    const person = activeHubSchedulePerson();
    renderHubScheduleTabs();
    renderHubScheduleRoleOptions(person);
    renderHubScheduleSummary(person);
    renderHubScheduleEvents(person);
  }

  async function loadHubSchedulePerson(person) {
    if (!person) return;
    const range = getHubScheduleRange();
    const roleSelect = document.getElementById('hubScheduleRole');
    const role = person.id === hubScheduleState.activePersonId ? String(roleSelect?.value || person.selectedRole || '').trim() : String(person.selectedRole || '').trim();
    person.selectedRole = role;
    hubScheduleState.loadingPersonId = person.id;
    refreshHubScheduleActiveView();
    if (typeof window.showLoading === 'function') window.showLoading('Loading schedule for ' + (person.name || person.id) + '...');
    try {
      const params = new URLSearchParams({
        personId: person.id,
        startDate: range.startDate,
        endDate: range.endDate
      });
      if (role) params.set('role', role);
      if (hubScheduleHasCasesOnly()) params.set('hasCases', '1');
      const response = await fetch('/school/schedules/api/person-schedule?' + params.toString(), {
        headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        credentials: 'same-origin'
      });
      const payload = await response.json().catch(function () {
        return { status: 'error', message: 'Unable to load schedule.' };
      });
      if (!response.ok || payload.status !== 'success') throw new Error(payload.message || 'Unable to load schedule.');
      hubScheduleState.eventsByPersonId[person.id] = Array.isArray(payload.events) ? payload.events : [];
      hubScheduleState.statusMetaByPersonId[person.id] = Array.isArray(payload.statusMeta) ? payload.statusMeta : [];
      hubScheduleState.loadedPersonIds.add(person.id);
      if (Array.isArray(payload.availableRoles)) person.availableRoles = payload.availableRoles;
      person.selectedRole = payload.selectedRole || role;
    } catch (error) {
      hubScheduleState.eventsByPersonId[person.id] = [];
      showHubMessage({ title: 'Schedule', icon: 'danger', message: error.message || 'Unable to load schedule.' });
    } finally {
      hubScheduleState.loadingPersonId = '';
      if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
      refreshHubScheduleActiveView();
    }
  }

  function loadActiveHubSchedulePerson() {
    const person = activeHubSchedulePerson();
    if (person) loadHubSchedulePerson(person);
  }

  async function loadAllHubSchedulePeople() {
    for (const person of hubScheduleState.persons) {
      // eslint-disable-next-line no-await-in-loop
      await loadHubSchedulePerson(person);
    }
  }

  async function loadAllActiveHubScheduleTeachers() {
    if (typeof window.showLoading === 'function') window.showLoading('Loading active teachers...');
    try {
      const response = await fetch('/school/schedules/api/active-teachers', {
        headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        credentials: 'same-origin'
      });
      const payload = await response.json().catch(function () {
        return { status: 'error', message: 'Unable to load active teachers.' };
      });
      if (!response.ok || payload.status !== 'success') throw new Error(payload.message || 'Unable to load active teachers.');
      const rows = Array.isArray(payload.items) ? payload.items : (Array.isArray(payload.data) ? payload.data : []);
      if (!rows.length) {
        showHubMessage({ title: 'Schedule', icon: 'info', message: 'No active teachers were found for the active organization.' });
        return;
      }
      hubScheduleState.persons = rows.map(function (item) {
        const id = resolveHubSchedulePersonId(item);
        return {
          id,
          name: formatHubSchedulePersonName(item, id),
          availableRoles: Array.isArray(item?.availableRoles) ? item.availableRoles : [{ key: 'teacher', label: 'Teacher' }],
          selectedRole: 'teacher'
        };
      }).filter(function (person) { return !!person.id; });
      hubScheduleState.activePersonId = hubScheduleState.persons[0]?.id || '';
      hubScheduleState.eventsByPersonId = {};
      hubScheduleState.statusMetaByPersonId = {};
      hubScheduleState.loadedPersonIds.clear();
      refreshHubScheduleActiveView();
      await loadAllHubSchedulePeople();
    } catch (error) {
      showHubMessage({ title: 'Schedule', icon: 'danger', message: error.message || 'Unable to load active teachers.' });
    } finally {
      if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
    }
  }

  function openHubSchedulePersonPicker() {
    if (!window.GenericPicker) {
      showHubMessage({ title: 'Schedule Picker', icon: 'warning', message: 'Generic picker is not available yet.' });
      return;
    }
    window.GenericPicker.open({
      title: 'Select School People',
      icon: 'bi-people-fill',
      apiEndpoint: '/school/schedules/api/school-person-picker',
      placeholder: 'Search school people...',
      multiselect: true,
      context: window.GenericPickerContexts
        ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
        : undefined,
      renderer: function (item) {
        const personId = escapeHtml(resolveHubSchedulePersonId(item));
        const name = escapeHtml(formatHubSchedulePersonName(item, personId));
        const roleBadges = (Array.isArray(item?.availableRoles) ? item.availableRoles : [])
          .map(function (role) { return '<span class="badge bg-light text-secondary border me-1">' + escapeHtml(role.label || role.key || '') + '</span>'; })
          .join('');
        return '<div><div class="fw-bold text-dark">' + name + '</div><div class="small text-muted font-monospace">' + personId + '</div><div class="mt-1">' + roleBadges + '</div></div>';
      },
      onSelect: function (items) {
        (Array.isArray(items) ? items : [items]).forEach(function (item) {
          const id = resolveHubSchedulePersonId(item);
          if (!id || hubScheduleState.persons.some(function (person) { return person.id === id; })) return;
          hubScheduleState.persons.push({
            id,
            name: formatHubSchedulePersonName(item, id),
            availableRoles: Array.isArray(item?.availableRoles) ? item.availableRoles : [],
            selectedRole: ''
          });
        });
        if (!hubScheduleState.activePersonId && hubScheduleState.persons.length) {
          hubScheduleState.activePersonId = hubScheduleState.persons[0].id;
        }
        refreshHubScheduleActiveView();
      }
    });
  }

