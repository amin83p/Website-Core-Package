    modal.querySelector('#hubEditSessionTeacherName').value = row.teacherName || '';
    modal.querySelector('#hubEditSessionRoom').value = row.room || '';
    modal.querySelector('#hubEditSessionNotes').value = row.notes || '';
    modal.querySelector('#hubEditSessionLocked').checked = row.locked === true || String(row.locked) === 'true';
    modal.querySelector('#hubEditSessionContext').innerHTML = '<strong>' + escapeHtml(row.className || row.classId || 'Class') + '</strong><div class="text-muted font-monospace">' + escapeHtml(row.sessionId || '') + '</div>';
    const statusSelect = modal.querySelector('#hubEditSessionStatus');
    const selectedStatus = normalizeSessionStatusCode(row.status || '');
    const statusOptions = (Array.isArray(hubSessionStatusMeta) ? hubSessionStatusMeta : []).slice().sort(function (a, b) {
      const ao = Number(a?.sortOrder ?? a?.order ?? 999);
      const bo = Number(b?.sortOrder ?? b?.order ?? 999);
      if (ao !== bo) return ao - bo;
      return String(a?.label || a?.code || '').localeCompare(String(b?.label || b?.code || ''));
    }).map(function (meta) {
      const code = normalizeSessionStatusCode(meta && meta.code);
      return code ? '<option value="' + escapeHtml(code) + '"' + (code === selectedStatus ? ' selected' : '') + '>' + escapeHtml(meta.label || toSessionStatusLabel(code)) + '</option>' : '';
    }).join('');
    statusSelect.innerHTML = statusOptions || '<option value="' + escapeHtml(selectedStatus || 'scheduled') + '">' + escapeHtml(toSessionStatusLabel(selectedStatus || 'scheduled')) + '</option>';
    if (window.bootstrap) window.bootstrap.Modal.getOrCreateInstance(modal).show();
  }

  function buildHubSessionActionHtml(rowKey, row) {
    const detailUrl = '/school/classes/' + encodeURIComponent(row.classId || '') + '/sessions/' + encodeURIComponent(row.sessionId || '');
    return '<div class="btn-group btn-group-sm">'
      + (hubSessionCanUpdateSessions && row.makeUpRequired === true ? '<button type="button" class="btn btn-light border text-warning" data-hub-session-makeup="' + escapeHtml(rowKey) + '"><i class="bi bi-calendar-plus me-1"></i>Make-up</button>' : '')
      + (hubSessionCanUpdateSessions ? '<button type="button" class="btn btn-light border text-primary" data-hub-session-edit="' + escapeHtml(rowKey) + '"><i class="bi bi-pencil-square me-1"></i>Edit</button>' : '')
      + '<a class="btn btn-light border text-primary" href="' + escapeHtml(detailUrl) + '" target="_blank" rel="noopener"><i class="bi bi-box-arrow-in-right me-1"></i>Open</a>'
      + '</div>';
  }

  function bindHubSessionRowActions(rowEl) {
    if (!rowEl) return;
    rowEl.querySelectorAll('[data-hub-session-edit]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const key = btn.getAttribute('data-hub-session-edit') || '';
        openHubSessionEditModal(hubSessionRowsByKey.get(key));
      });
    });
    rowEl.querySelectorAll('[data-hub-session-makeup]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const key = btn.getAttribute('data-hub-session-makeup') || '';
        openHubSessionMakeupModal(hubSessionRowsByKey.get(key));
      });
    });
  }

  function patchHubSessionTableRow(rowKey, updatedRow) {
    const rowEl = Array.from(document.querySelectorAll('[data-session-key]')).find(function (node) {
      return node.getAttribute('data-session-key') === rowKey;
    });
    if (!rowEl || !updatedRow) return;
    const statusMap = buildSessionStatusMetaMap(hubSessionStatusMeta);
    const dateLabel = updatedRow.date
      ? formatHubDateKey(updatedRow.date, { weekday: 'short', month: 'short', day: 'numeric' })
      : '-';
    const commentsIcon = updatedRow.hasComments ? '<i class="bi bi-chat-dots-fill text-primary ms-1" title="Interactive notes inside"></i>' : '';
    const searchText = [
      updatedRow.sessionId,
      updatedRow.classId,
      updatedRow.className,
      updatedRow.teacherName,
      updatedRow.date,
      updatedRow.startTime,
      updatedRow.endTime,
      updatedRow.status,
      updatedRow.notes
    ].join(' ');
    rowEl.setAttribute('data-search-text', searchText);
    rowEl.setAttribute('style', buildSessionRowStyle(updatedRow.status, updatedRow.locked === true, statusMap));
    rowEl.classList.toggle('session-row-locked', updatedRow.locked === true);
    const cells = rowEl.children;
    if (cells[1]) cells[1].innerHTML = escapeHtml(dateLabel) + '<div class="small text-muted">' + escapeHtml(updatedRow.date || '') + '</div>';
    if (cells[2]) cells[2].innerHTML = '<i class="bi bi-clock me-1"></i>' + escapeHtml(updatedRow.startTime || '00:00') + ' - ' + escapeHtml(updatedRow.endTime || '00:00');
    if (cells[4]) cells[4].innerHTML = escapeHtml(updatedRow.teacherName || 'Unassigned');
    if (cells[5]) cells[5].innerHTML = buildSessionStatusBadgeHtml(updatedRow.status, statusMap)
      + buildSessionCaseBadgeHtml(updatedRow.caseSummary)
      + buildSessionMakeupBadgeHtml(updatedRow)
      + formatHubSessionLockBadge(updatedRow);
    if (cells[6]) cells[6].innerHTML = escapeHtml(truncateHubText(updatedRow.notes, 42)) + commentsIcon;
    if (cells[7]) cells[7].innerHTML = buildHubSessionActionHtml(rowKey, updatedRow);
    bindHubSessionRowActions(rowEl);
  }

  async function saveHubSessionEditModal() {
    const modal = ensureHubSessionEditModal();
    const button = modal.querySelector('#hubEditSessionSave');
    const oldHtml = button ? button.innerHTML : '';
    const payload = {
      classId: hubInputValue('hubEditSessionClassId'),
      sessionId: hubInputValue('hubEditSessionSessionId'),
      date: hubInputValue('hubEditSessionDate'),
      startTime: hubInputValue('hubEditSessionStart'),
      endTime: hubInputValue('hubEditSessionEnd'),
      teacherId: hubInputValue('hubEditSessionTeacherId'),
      teacherName: hubInputValue('hubEditSessionTeacherName'),
      status: hubInputValue('hubEditSessionStatus'),
      room: hubInputValue('hubEditSessionRoom'),
      notes: hubInputValue('hubEditSessionNotes'),
      locked: document.getElementById('hubEditSessionLocked')?.checked === true
    };
    try {
      if (button) {
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
      }
      const result = await postHubSessionMutation('/school/master-hub/api/workspace/sessions/update', payload, 'Saving session...');
      if (window.bootstrap) window.bootstrap.Modal.getOrCreateInstance(modal).hide();
      await showHubMessage({ title: 'Session Updated', icon: 'success', message: result.message || 'Session updated.', buttons: [{ text: 'OK', class: 'btn-success' }] });
      const rowKey = String(payload.classId || '') + '::' + String(payload.sessionId || '');
      const existingRow = hubSessionRowsByKey.get(rowKey) || {};
      const sessionRow = result?.result?.session || {};
      const updatedRow = {
        ...existingRow,
        date: sessionRow.date || payload.date,
        startTime: sessionRow.startTime || payload.startTime,
        endTime: sessionRow.endTime || payload.endTime,
        status: sessionRow.status || payload.status,
        locked: sessionRow.locked === true || String(sessionRow.locked) === 'true',
        teacherId: sessionRow?.delivery?.deliveredBy || payload.teacherId,
        teacherName: sessionRow?.delivery?.deliveredByName || payload.teacherName,
        room: sessionRow.room || payload.room,
        notes: sessionRow.notes || payload.notes
      };
      hubSessionRowsByKey.set(rowKey, updatedRow);
      patchHubSessionTableRow(rowKey, updatedRow);
    } catch (error) {
      await showHubMessage({ title: 'Session Update Failed', icon: 'error', message: error.message || 'Could not update session.', buttons: [{ text: 'Close', class: 'btn-secondary' }] });
    } finally {
      if (button) {
        button.disabled = false;
        button.innerHTML = oldHtml;
      }
    }
  }

