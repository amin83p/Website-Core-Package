  async function createHubMakeupSessionFromModal() {
    const modal = ensureHubSessionMakeupModal();
    const button = modal.querySelector('#hubMakeupSessionCreate');
    const oldHtml = button ? button.innerHTML : '';
    const classId = hubInputValue('hubMakeupSessionClassId');
    const sessionId = hubInputValue('hubMakeupSessionSessionId');
    const payload = {
      date: hubInputValue('hubMakeupSessionDate'),
      startTime: hubInputValue('hubMakeupSessionStart'),
      endTime: hubInputValue('hubMakeupSessionEnd'),
      makeupDurationPercent: hubInputValue('hubMakeupSessionDurationPercent') || hubMakeupDefaultPercent || 100,
      teacherId: hubInputValue('hubMakeupSessionTeacherId'),
      teacherName: hubInputValue('hubMakeupSessionTeacherName'),
      room: hubInputValue('hubMakeupSessionRoom'),
      reason: hubInputValue('hubMakeupSessionReason')
    };
    if (!payload.date) {
      await showHubMessage({ title: 'Date Required', icon: 'warning', message: 'Please select the make-up session date.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
      return;
    }
    try {
      if (button) {
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Creating...';
      }
      if (typeof window.showLoading === 'function') window.showLoading('Creating make-up session...');
      const submitMakeup = async function (bodyPayload) {
        const response = await fetch('/school/classes/' + encodeURIComponent(classId) + '/sessions/' + encodeURIComponent(sessionId) + '/makeup', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            Accept: 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
            'X-AJAX-Request': 'true'
          },
          credentials: 'same-origin',
          body: JSON.stringify(bodyPayload || {})
        });
        const parsed = await response.json().catch(function () {
          return { status: 'error', message: 'Unable to read server response.' };
        });
        return { response, parsed };
      };
      let responseAndPayload = await submitMakeup(payload);
      let result = responseAndPayload.parsed;
      if (result.status === 'warning' && result.code === 'MAKEUP_SESSION_WARNINGS') {
        const warningList = Array.isArray(result?.data?.warnings) && result.data.warnings.length
          ? '<ul>' + result.data.warnings.map(function (item) { return '<li>' + escapeHtml(item) + '</li>'; }).join('') + '</ul>'
          : '';
        if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
        const selected = await showHubMessage({
          title: 'Review Make-up Warnings',
          icon: 'warning',
          message: (result.message || 'Review warnings before creating this make-up session.') + warningList,
          buttons: [{ text: 'Cancel', class: 'btn-secondary' }, { text: 'Create Anyway', class: 'btn-warning' }]
        });
        if (selected !== 'Create Anyway') return;
        if (typeof window.showLoading === 'function') window.showLoading('Creating make-up session...');
        responseAndPayload = await submitMakeup({ ...payload, force: true });
        result = responseAndPayload.parsed;
      }
      if (!responseAndPayload.response.ok || result.status !== 'success') throw new Error(result.message || 'Could not create make-up session.');
      if (window.bootstrap) window.bootstrap.Modal.getOrCreateInstance(modal).hide();
      const warnings = Array.isArray(result?.data?.warnings) && result.data.warnings.length
        ? '<hr><strong>Warnings</strong><ul>' + result.data.warnings.map(function (item) { return '<li>' + escapeHtml(item) + '</li>'; }).join('') + '</ul>'
        : '';
      await showHubMessage({ title: 'Make-up Session Created', icon: result?.data?.warnings?.length ? 'warning' : 'success', message: (result.message || 'Make-up session created.') + warnings, buttons: [{ text: 'OK', class: 'btn-success' }] });
      hubWorkspaceNodeCache.delete('sessions');
      loadWorkspaceSection('sessions');
    } catch (error) {
      await showHubMessage({ title: 'Make-up Session Failed', icon: 'error', message: error.message || 'Could not create make-up session.', buttons: [{ text: 'Close', class: 'btn-secondary' }] });
    } finally {
      if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
      if (button) {
        button.disabled = false;
        button.innerHTML = oldHtml;
      }
    }
  }

