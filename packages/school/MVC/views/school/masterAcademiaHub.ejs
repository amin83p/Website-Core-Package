  const hubWorkspaceNodeCache = new Map();

  function preserveCurrentHubWorkspace(nextKey) {
    const currentKey = String(workspaceState.currentSection || '').trim().toLowerCase();
    if (!currentKey || currentKey === String(nextKey || '').trim().toLowerCase() || !els.workspace) return;
    let bucket = hubWorkspaceNodeCache.get(currentKey);
    if (!bucket) {
      bucket = document.createElement('div');
      hubWorkspaceNodeCache.set(currentKey, bucket);
    }
    while (els.workspace.firstChild) {
      bucket.appendChild(els.workspace.firstChild);
    }
  }

  function restoreHubWorkspaceFromCache(key) {
    const cacheKey = String(key || '').trim().toLowerCase();
    const bucket = hubWorkspaceNodeCache.get(cacheKey);
    if (!bucket || !bucket.childNodes.length || !els.workspace) return false;
    while (els.workspace.firstChild) {
      els.workspace.removeChild(els.workspace.firstChild);
    }
    while (bucket.firstChild) {
      els.workspace.appendChild(bucket.firstChild);
    }
    workspaceState.currentSection = cacheKey;
    setWorkspaceButtons(cacheKey);
    if (cacheKey === 'schedule') refreshHubScheduleActiveView();
    return true;
  }

  async function loadWorkspaceSection(sectionKey) {
    const key = String(sectionKey || '').trim().toLowerCase();
    if (key === 'sessions' && !workspaceSections.sessions) {
      workspaceSections.sessions = {
        label: 'Sessions',
        endpoint: '/school/master-hub/api/workspace/sessions',
        icon: 'bi bi-calendar2-week-fill'
      };
    }
    if (key === 'activities' && !workspaceSections.activities) {
      workspaceSections.activities = {
        label: 'Activities',
        endpoint: '/school/master-hub/api/workspace/activities',
        sourceUrl: '/school/activities',
        icon: 'bi bi-list-check'
      };
    }
    if (key === 'session-issues' && !workspaceSections['session-issues']) {
      workspaceSections['session-issues'] = {
        label: 'Session Issues',
        endpoint: '/school/master-hub/api/workspace/session-issues',
        icon: 'bi bi-exclamation-triangle-fill'
      };
    }
    if (key === 'schedule' && !workspaceSections.schedule) {
      workspaceSections.schedule = {
        label: 'Schedule',
        endpoint: '/school/master-hub/api/workspace/schedule',
        icon: 'bi bi-calendar-check-fill'
      };
    }
    if (key === 'attendance' && !workspaceSections.attendance) {
      workspaceSections.attendance = {
        label: 'Attendance',
        endpoint: '/school/master-hub/api/workspace/attendance',
        icon: 'bi bi-clipboard-check-fill'
      };
    }
    if (key === 'timesheet-periods' && !workspaceSections['timesheet-periods']) {
      workspaceSections['timesheet-periods'] = {
        label: 'Timesheet Periods',
        endpoint: '/school/master-hub/api/workspace/timesheet-periods',
        sourceUrl: '/school/timesheetPeriods',
        icon: 'bi bi-calendar-week-fill'
      };
    }
    if (key === 'timesheet-management' && !workspaceSections['timesheet-management']) {
      workspaceSections['timesheet-management'] = {
        label: 'Timesheet Management',
        endpoint: '/school/master-hub/api/workspace/timesheet-management',
        sourceUrl: '/school/timesheets/manage',
        icon: 'bi bi-table'
      };
    }
    if (key === 'leave-requests' && !workspaceSections['leave-requests']) {
      workspaceSections['leave-requests'] = {
        label: 'Leave Requests',
        endpoint: '/school/master-hub/api/workspace/leave-requests',
        icon: 'bi bi-calendar-heart'
      };
    }
    if (key === 'report-assignments' && !workspaceSections['report-assignments']) {
      workspaceSections['report-assignments'] = {
        label: 'Report Assignments',
        endpoint: '/school/master-hub/api/workspace/report-assignments',
        sourceUrl: '/school/reports/assignments',
        icon: 'bi bi-clipboard2-check-fill'
      };
    }
    if (key === 'report-instances' && !workspaceSections['report-instances']) {
      workspaceSections['report-instances'] = {
        label: 'Report Instances',
        endpoint: '/school/master-hub/api/workspace/report-instances',
        sourceUrl: '/school/reports/instances',
        icon: 'bi bi-file-earmark-text-fill'
      };
    }
    if (key === 'holidays' && !workspaceSections.holidays) {
      workspaceSections.holidays = {
        label: 'Holidays',
        endpoint: '/school/master-hub/api/workspace/holidays',
        icon: 'bi bi-calendar-event-fill'
      };
    }
    if (key === 'academic-ledger' && !workspaceSections['academic-ledger']) {
      workspaceSections['academic-ledger'] = {
        label: 'Academic Ledger',
        endpoint: '/school/master-hub/api/workspace/academic-ledger',
        sourceUrl: '/school/academic-ledger',
        icon: 'bi bi-journal-bookmark-fill'
      };
    }
    const config = workspaceSections[key];
    if (!config || workspaceState.loading) return;

    preserveCurrentHubWorkspace(key);
    if (restoreHubWorkspaceFromCache(key)) return;

    const requestQuery = new URLSearchParams();
    const serverSearch = String(workspaceState.serverSearch[key] || '').trim();
    if (serverSearch) requestQuery.set('q', serverSearch);
    if (key === 'tasks') {
      if (canManageAllTasks && !workspaceState.taskShowAll) {
        requestQuery.set('assignment', 'mine');
      } else if (workspaceState.taskPersonId) {
        requestQuery.set('assignedPersonId', workspaceState.taskPersonId);
        if (workspaceState.taskPersonName) requestQuery.set('assignedPersonName', workspaceState.taskPersonName);
      }
    }
    if (key === 'activities') appendActivityWorkspaceQuery(requestQuery);
    if (key === 'sessions') appendSessionWorkspaceQuery(requestQuery);
    if (key === 'session-issues') appendSessionIssueWorkspaceQuery(requestQuery);
    if (key === 'timesheet-periods') appendTimesheetPeriodWorkspaceQuery(requestQuery);
    if (key === 'report-assignments') appendReportAssignmentWorkspaceQuery(requestQuery);
    if (key === 'report-instances') appendReportInstanceWorkspaceQuery(requestQuery);
    if (key === 'holidays') requestQuery.set('year', workspaceState.holidaysYear || hubOrgYear());

    workspaceState.currentSection = key;
    workspaceState.loading = true;
    setWorkspaceButtons(key);
    renderWorkspaceStatus('Loading ' + config.label + '...', 'bi-arrow-repeat', 'muted');
    if (typeof window.showLoading === 'function') {
      window.showLoading('Loading ' + config.label + '...');
    }

    try {
      const requestUrl = config.endpoint + (requestQuery.toString() ? '?' + requestQuery.toString() : '');
      const response = await fetch(requestUrl, {
        headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        credentials: 'same-origin'
      });
      const payload = await response.json().catch(function () {
        return { status: 'error', message: 'Unable to load this section.' };
      });
      if (!response.ok || payload.status !== 'success') {
        throw new Error(payload.message || 'Unable to load this section.');
      }

      if (key === 'tasks') {
        renderTaskWorkspace(payload);
        setTaskCount(payload.unresolvedCount || 0, false);
      } else if (key === 'classes') {
        renderClassWorkspace(payload);
      } else if (key === 'activities') {
        renderActivityWorkspace(payload);
      } else if (key === 'sessions') {
        renderSessionWorkspace(payload);
      } else if (key === 'session-issues') {
        renderSessionIssueWorkspace(payload);
      } else if (key === 'schedule') {
        renderScheduleWorkspace(payload);
      } else if (key === 'attendance') {
        renderAttendanceWorkspace(payload);
      } else if (key === 'timesheet-periods') {
        renderTimesheetPeriodWorkspace(payload);
      } else if (key === 'timesheet-management') {
        renderTimesheetManagementWorkspace(payload);
      } else if (key === 'leave-requests') {
        renderLeaveRequestWorkspace(payload);
      } else if (key === 'report-assignments') {
        renderReportAssignmentWorkspace(payload);
      } else if (key === 'report-instances') {
        renderReportInstanceWorkspace(payload);
      } else if (key === 'holidays') {
        renderHolidayWorkspace(payload);
      } else if (key === 'academic-ledger') {
        renderAcademicLedgerWorkspace(payload);
      }
    } catch (error) {
      renderWorkspaceStatus(error.message || 'Unable to load this section.', 'bi-exclamation-triangle', 'danger');
    } finally {
      if (typeof window.hideLoading === 'function') {
        window.hideLoading({ force: true });
      }
      workspaceState.loading = false;
    }
  }

