  function openHubHolidayModal(row) {
    const modalEl = document.getElementById('hubHolidayModal');
    const form = document.getElementById('hubHolidayForm');
    if (!modalEl || !form) return;
    const selectedYear = String(document.getElementById('hubHolidayYear')?.value || workspaceState.holidaysYear || hubOrgYear());
    const fallbackDate = selectedYear + '-01-01';
    document.getElementById('hubHolidayModalTitle').textContent = row.id ? 'Edit Holiday' : 'Add Holiday';
    document.getElementById('hubHolidayId').value = row.id || '';
    document.getElementById('hubHolidayDate').value = row.date || fallbackDate;
    document.getElementById('hubHolidayTitle').value = row.title || '';
    document.getElementById('hubHolidayType').value = row.type || 'National Holiday';
    document.getElementById('hubHolidayNotes').value = row.notes || '';
    if (typeof bootstrap !== 'undefined') {
      bootstrap.Modal.getOrCreateInstance(modalEl).show();
    }
  }

  async function saveHubHoliday() {
    const form = document.getElementById('hubHolidayForm');
    const saveButton = document.getElementById('hubHolidaySaveBtn');
    if (!form || !saveButton) return;
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }
    const originalHtml = saveButton.innerHTML;
    saveButton.disabled = true;
    saveButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
    try {
      const payload = {
        id: document.getElementById('hubHolidayId')?.value || '',
        date: document.getElementById('hubHolidayDate')?.value || '',
        title: document.getElementById('hubHolidayTitle')?.value || '',
        type: document.getElementById('hubHolidayType')?.value || 'National Holiday',
        notes: document.getElementById('hubHolidayNotes')?.value || ''
      };
      const response = await fetch('/school/holidays/save', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
        credentials: 'same-origin',
        body: JSON.stringify(payload)
      });
      const result = await response.json().catch(function () {
        return { status: 'error', message: 'Unable to save holiday.' };
      });
      const guarded = typeof window.applyGuardedApiResult === 'function'
        ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Processed' })
        : { stop: false };
      if (guarded.stop) return;
      if (!response.ok || result.status !== 'success') throw new Error(result.message || 'Unable to save holiday.');
      const modalEl = document.getElementById('hubHolidayModal');
      if (modalEl && typeof bootstrap !== 'undefined') bootstrap.Modal.getOrCreateInstance(modalEl).hide();
      await showHubMessage({ title: 'Holiday Saved', icon: 'success', message: result.message || 'Holiday saved successfully.', buttons: [{ text: 'OK', class: 'btn-success' }] });
      workspaceState.holidaysYear = String(payload.date || '').slice(0, 4) || workspaceState.holidaysYear;
      loadWorkspaceSection('holidays');
    } catch (error) {
      await showHubMessage({ title: 'Save Failed', icon: 'error', message: error.message || 'Unable to save holiday.', buttons: [{ text: 'Close', class: 'btn-danger' }] });
    } finally {
      saveButton.disabled = false;
      saveButton.innerHTML = originalHtml;
    }
  }

  async function deleteHubHoliday(id, title) {
    if (!id) return;
    const selected = await showHubMessage({
      title: 'Delete Holiday',
      icon: 'warning',
      message: 'Delete "' + title + '" from the holiday list?',
      buttons: [
        { text: 'Cancel', class: 'btn-secondary' },
        { text: 'Delete', class: 'btn-danger' }
      ]
    });
    if (selected !== 'Delete') return;
    try {
      const response = await fetch('/school/holidays/delete/' + encodeURIComponent(id), {
        method: 'DELETE',
        headers: { Accept: 'application/json', 'X-AJAX-Request': 'true' },
        credentials: 'same-origin'
      });
      const result = await response.json().catch(function () {
        return { status: 'error', message: 'Unable to delete holiday.' };
      });
      const guarded = typeof window.applyGuardedApiResult === 'function'
        ? await window.applyGuardedApiResult(result, { busyTitle: 'Delete In Progress', replayTitle: 'Delete Already Processed' })
        : { stop: false };
      if (guarded.stop) return;
      if (!response.ok || result.status !== 'success') throw new Error(result.message || 'Unable to delete holiday.');
      await showHubMessage({ title: 'Holiday Deleted', icon: 'success', message: result.message || 'Holiday removed successfully.', buttons: [{ text: 'OK', class: 'btn-success' }] });
      loadWorkspaceSection('holidays');
    } catch (error) {
      await showHubMessage({ title: 'Delete Failed', icon: 'error', message: error.message || 'Unable to delete holiday.', buttons: [{ text: 'Close', class: 'btn-danger' }] });
    }
  }

