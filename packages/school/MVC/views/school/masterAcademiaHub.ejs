      linear-gradient(135deg, rgba(2, 132, 199, 0.11), rgba(34, 197, 94, 0.09)),
      #f8fafc;
    border-bottom: 1px solid rgba(15, 23, 42, 0.08);
  }

  .school-master-hub .hub-content {
    padding: 1rem 1.25rem 1.25rem;
  }

  .school-master-hub .hub-sidebar-content {
    flex: 1;
    min-height: 0;
    padding: 1rem;
    overflow: auto;
  }

  .school-master-hub .hub-table-wrap {
    overflow: auto;
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 1rem;
  }

  .school-master-hub .hub-table {
    min-width: 980px;
    margin-bottom: 0;
  }

  .school-master-hub .hub-person-list {
    display: grid;
    gap: 0.75rem;
  }

  .school-master-hub .hub-person-card {
    border: 1px solid rgba(15, 23, 42, 0.08);
    border-radius: 1rem;
    background: rgba(255, 255, 255, 0.86);
    box-shadow: 0 12px 24px rgba(15, 23, 42, 0.06);
    padding: 0.9rem;
  }

  .school-master-hub .hub-person-card:hover {
    border-color: rgba(2, 132, 199, 0.28);
  }

  .school-master-hub .hub-card-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .school-master-hub .hub-card-details {
    display: none;
    margin-top: 0.75rem;
    padding-top: 0.75rem;
    border-top: 1px solid rgba(15, 23, 42, 0.08);
  }

  .school-master-hub .hub-person-card.is-expanded .hub-card-details {
    display: block;
  }

  .school-master-hub .hub-card-toggle {
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
  }

  .school-master-hub .hub-card-actions .btn {
    white-space: nowrap;
  }

  .school-master-hub .hub-load-more-wrap {
    display: grid;
    place-items: center;
    padding: 0.25rem 0 1rem;
  }

  .school-master-hub .hub-row-actions {
    min-width: 158px;
  }

  .school-master-hub .hub-action-menu {
    min-width: 12rem;
  }

  .school-master-hub .hub-empty {
    min-height: 220px;
    display: grid;
    place-items: center;
    text-align: center;
    color: #64748b;
  }

  @media (max-width: 991.98px) {
    .school-master-hub .hub-section-panel {
      margin-left: 1rem;
    }

    .school-master-hub .hub-section-panel-inner {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }

    .school-master-hub .hub-shell {
      grid-template-columns: 1fr;
    }

    .school-master-hub .hub-sidebar {
      position: static;
      min-height: auto;
    }

    .school-master-hub .hub-sidebar-inner {
      min-height: auto;
    }
  }
</style>

<div class="container-fluid school-master-hub hub-sidebar-collapsed py-3"
     data-master-hub
     data-modules='<%- JSON.stringify(safeModules) %>'
     data-default-type="<%= initialType %>"
     data-can-manage-all-tasks="<%= canManageAllTasksFlag ? 'true' : 'false' %>">
  <div class="hub-page-header d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
    <div>
      <div class="text-uppercase text-muted small fw-bold">School Package</div>
      <h1 class="h3 mb-1">Master Academia Hub</h1>
      <p class="text-muted mb-0">Review school people records from one full-width workspace.</p>
    </div>
    <a href="<%= schoolSectionDashboardHref || '/school' %>" class="btn btn-outline-secondary btn-sm">
      <i class="bi bi-speedometer2 me-1"></i> Academia Dashboard
    </a>
  </div>

  <div class="hub-section-panel" aria-label="School Master Hub sections">
    <div class="hub-section-panel-inner">
      <div class="hub-section-segment hub-task-segment">
        <span class="hub-task-count is-muted" id="schoolMasterHubTaskCount">-</span>
        <button type="button" class="hub-section-main-link" data-hub-workspace-section="tasks">
          <span><i class="bi bi-list-task me-1"></i> School Tasks</span>
        </button>
        <button type="button" class="hub-task-gear" id="schoolMasterHubTaskSettings" aria-label="Task refresh settings">
          <i class="bi bi-gear-fill"></i>
        </button>
      </div>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="classes">
        <span><i class="bi bi-easel-fill me-1"></i> Class</span>
      </button>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="activities">
        <span><i class="bi bi-list-check me-1"></i> Activities</span>
      </button>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="sessions">
        <span><i class="bi bi-calendar2-week-fill me-1"></i> Sessions</span>
      </button>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="session-issues">
        <span><i class="bi bi-exclamation-triangle-fill me-1"></i> Session Issues</span>
      </button>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="schedule">
        <span><i class="bi bi-calendar-check-fill me-1"></i> Schedule</span>
      </button>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="attendance">
        <span><i class="bi bi-clipboard-check-fill me-1"></i> Attendance</span>
      </button>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="timesheet-periods">
        <span><i class="bi bi-calendar-week-fill me-1"></i> Timesheet Periods</span>
      </button>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="timesheet-management">
        <span><i class="bi bi-table me-1"></i> Timesheet Management</span>
      </button>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="report-assignments">
        <span><i class="bi bi-clipboard2-check-fill me-1"></i> Report Assignments</span>
      </button>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="report-instances">
        <span><i class="bi bi-file-earmark-text-fill me-1"></i> Report Instances</span>
      </button>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="leave-requests">
        <span><i class="bi bi-calendar-heart me-1"></i> Leave Requests</span>
      </button>
      <button type="button" class="hub-section-segment" data-hub-workspace-section="academic-ledger">
        <span><i class="bi bi-journal-bookmark-fill me-1"></i> Academic Ledger</span>
      </button>
    </div>
  </div>

  <% if (!safeModules.length) { %>
    <div class="hub-main">
      <div class="hub-empty">
        <div>
          <i class="bi bi-shield-lock display-5 d-block mb-3"></i>
          <h2 class="h5">No people directory access</h2>
          <p class="mb-0">You need access to Students, Teachers, or Staff to use the School Master Hub.</p>
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="hub-shell">
      <aside class="hub-sidebar">
        <div class="hub-sidebar-inner">
          <div class="hub-sidebar-header d-flex align-items-center justify-content-between gap-2">
            <div class="hub-sidebar-header-text">
              <div class="text-uppercase text-muted small fw-bold">People Lists</div>
              <div class="fw-semibold">Choose a directory</div>
            </div>
            <button type="button"
                    class="btn btn-outline-secondary btn-sm hub-collapse-toggle"
                    id="schoolMasterHubCollapseSidebar"
                    title="Collapse sidebar">
              <i class="bi bi-layout-sidebar-inset"></i>
            </button>
          </div>
          <div class="hub-tabs" id="schoolMasterHubTabs">
            <% safeModules.forEach((item) => { %>
              <div class="hub-tab-shell">
                <button type="button"
                        class="hub-tab position-relative"
                        data-hub-tab="<%= item.type %>">
                  <span class="hub-tab-main d-flex align-items-center justify-content-center gap-2">
                    <i class="<%= item.icon %> <%= item.color || '' %>"></i>
                    <span class="hub-tab-label">
                      <span class="fw-semibold d-block"><%= item.label %></span>
                    </span>
                  </span>
                </button>
                <% if (item.directoryUrl) { %>
                  <a class="btn btn-outline-secondary btn-sm hub-tab-open-section"
                     href="<%= item.directoryUrl %>"
                     target="_blank"
                     rel="noopener"
                     title="Open <%= item.label %> in a new tab"
                     aria-label="Open <%= item.label %> in a new tab">
                    <i class="bi bi-box-arrow-up-right"></i>
                  </a>
                <% } %>
              </div>
            <% }); %>
          </div>

          <div class="hub-sidebar-content">
            <div class="mb-3">
              <label for="schoolMasterHubSearch" class="form-label fw-semibold">Search selected list</label>
              <div class="input-group">
                <input type="search"
                       id="schoolMasterHubSearch"
                       class="form-control"
                       placeholder="Search name, email, phone, ID, status, or department">
                <button type="button" class="btn btn-primary" id="schoolMasterHubSearchButton">
                  <i class="bi bi-search me-1"></i> Search
                </button>
              </div>
            </div>
            <div id="schoolMasterHubStatus" class="alert alert-info d-none" role="status"></div>
            <div id="schoolMasterHubList"></div>
          </div>
        </div>
      </aside>

      <main class="hub-main">
        <section class="hub-hero d-none">
          <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
            <div>
              <div class="text-uppercase text-muted small fw-bold" id="schoolMasterHubEyebrow">Directory</div>
              <h2 class="h4 mb-1" id="schoolMasterHubTitle">Loading...</h2>
              <p class="text-muted mb-0" id="schoolMasterHubMeta">Preparing the workspace.</p>
            </div>
            <div class="d-flex gap-2">
              <a href="#" class="btn btn-outline-primary btn-sm disabled" id="schoolMasterHubOpenDirectory">
                <i class="bi bi-box-arrow-up-right me-1"></i> Open Directory
              </a>
              <button type="button" class="btn btn-primary btn-sm" id="schoolMasterHubRefreshCurrent">
                <i class="bi bi-arrow-clockwise me-1"></i> Refresh
              </button>
            </div>
          </div>
        </section>

        <section class="hub-workspace" id="schoolMasterHubWorkspace" data-hub-workspace>
          <div class="hub-stage-empty">
            <div class="text-center px-4">
              <i class="bi bi-grid-1x2-fill display-5 d-block mb-3"></i>
              <h2 class="h5 text-slate-600">Master Hub canvas</h2>
              <p class="mb-0">Select a section button above to work inside the hub, or select a person on the left.</p>
            </div>
          </div>
        </section>
      </main>
    </div>
  <% } %>
</div>

<%- include('partials/modal', { user }) %>
