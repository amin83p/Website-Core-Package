          'hubActivityPaid',
          'hubActivityPersonControl',
          'hubActivityDateFrom',
          'hubActivityDateTo',
          'hubActivityAssigneePersonId',
          'hubActivityAssigneePersonName'
        ].forEach(function (id) {
          const el = document.getElementById(id);
          if (el) el.value = '';
        });
        workspaceState.serverSearch.activities = '';
        workspaceState.activityPersonId = '';
        workspaceState.activityPersonName = '';
        const searchInput = document.getElementById('hubServerSearch_activities');
        if (searchInput) searchInput.value = '';
        loadWorkspaceSection('activities');
      });
    }
  }

  function renderActivityRows(rows, notLoaded) {
    if (!Array.isArray(rows) || !rows.length) {
      return notLoaded
        ? '<tr><td colspan="8" class="text-center text-muted py-5"><i class="bi bi-arrow-clockwise d-block fs-2 mb-2"></i>Set filters if needed, then click <strong>Load Activities</strong>.</td></tr>'
        : '<tr><td colspan="8" class="text-center text-muted py-5"><i class="bi bi-search d-block fs-2 mb-2"></i>No activities found matching these filters.</td></tr>';
    }

    return rows.map(function (row) {
      const actions = (Array.isArray(row.actions) ? row.actions : []).map(function (action) {
        return '<a class="btn btn-outline-' + escapeHtml(action.tone || 'primary') + ' btn-sm" href="' + escapeHtml(action.href || '#') + '" target="_blank" rel="noopener"><i class="' + escapeHtml(action.icon || 'bi bi-box-arrow-up-right') + ' me-1"></i>' + escapeHtml(action.label || 'Open') + '</a>';
      }).join('');
      const assigneeNames = Array.isArray(row.assigneeNames) ? row.assigneeNames : [];
      const assigneePreview = assigneeNames.slice(0, 3).join(', ');
      const extraAssignees = Math.max(0, Number(row.assigneeCount || 0) - 3);
      const personControlBadge = row.hasPersonControls
        ? '<span class="badge text-bg-warning-subtle text-warning-emphasis border border-warning-subtle">Person Controls</span>'
        : '<span class="badge text-bg-light border text-dark">Open Access</span>';
      const scopeRuleLabel = row.visibilityScope === 'individual'
        ? 'Allowed: ' + escapeHtml(String(row.allowedPersonCount || 0))
        : 'Excluded: ' + escapeHtml(String(row.excludedPersonCount || 0));
      const entryExclusionLabel = Number(row.entryExcludedCount || 0) > 0
        ? '<div class="small text-muted">Session exclusions: ' + escapeHtml(String(row.entryExcludedCount || 0)) + '</div>'
        : '';
      const searchText = [
        row.id,
        row.title,
        row.categoryName,
        row.departmentName,
        row.status,
        row.visibilityScope,
        row.location,
        row.dateLabel,
        row.startTime,
        row.endTime,
        assigneeNames.join(' '),
        row.notes
      ].join(' ');

      return [
        '<tr data-hub-workspace-row data-search-text="' + escapeHtml(searchText) + '">',
        '<td class="ps-4">',
        '<div class="fw-semibold text-primary">' + escapeHtml(row.title || row.id || 'Activity') + '</div>',
        '<div class="small text-muted font-monospace">' + escapeHtml(row.id || '') + '</div>',
        (row.location ? '<div class="small text-muted"><i class="bi bi-geo-alt me-1"></i>' + escapeHtml(row.location) + '</div>' : ''),
        '</td>',
        '<td><div class="fw-semibold">' + escapeHtml(row.categoryName || row.categoryId || '-') + '</div><div class="small text-muted">' + escapeHtml(row.departmentName || row.departmentId || '-') + '</div></td>',
        '<td><div class="fw-semibold">' + escapeHtml(row.dateLabel || '-') + '</div><div class="small text-muted">' + escapeHtml(row.startTime || '--:--') + ' - ' + escapeHtml(row.endTime || '--:--') + '</div></td>',
        '<td><div class="fw-semibold">' + escapeHtml(String(row.sessionCount || 1)) + ' work session' + (Number(row.sessionCount || 1) === 1 ? '' : 's') + '</div><div class="small text-muted">' + escapeHtml(Number(row.totalDurationHours || 0).toFixed(2)) + ' total hour(s)</div></td>',
        '<td><div class="fw-semibold">' + escapeHtml(String(row.assigneeCount || 0)) + ' assigned</div><div class="small text-muted">' + escapeHtml(assigneePreview || '-') + (extraAssignees ? ' +' + escapeHtml(String(extraAssignees)) + ' more' : '') + '</div></td>',
        '<td><span class="badge ' + escapeHtml(activityScopeBadgeClass(row.visibilityScope)) + '">' + escapeHtml(row.visibilityScope === 'individual' ? 'Individual' : 'School / Public') + '</span><div class="mt-1">' + activityPaidBadgeHtml(row) + '</div><div class="mt-1">' + personControlBadge + '</div><div class="small text-muted mt-1">' + scopeRuleLabel + '</div>' + entryExclusionLabel + '</td>',
        '<td><span class="badge ' + escapeHtml(activityStatusBadgeClass(row.status)) + '">' + escapeHtml(toHubTitleCase(row.status || 'draft')) + '</span></td>',
        '<td class="pe-4 text-end"><div class="hub-workspace-actions">' + (actions || '<span class="text-muted small">No actions</span>') + '</div></td>',
        '</tr>'
      ].join('');
    }).join('');
  }

