  function bindReportInstanceWorkspaceControls() {
    const loadBtn = document.getElementById('hubReportInstanceFilterLoad');
    if (loadBtn) loadBtn.addEventListener('click', function () { loadWorkspaceSection('report-instances'); });
    const resetBtn = document.getElementById('hubReportInstanceReset');
    if (resetBtn) resetBtn.addEventListener('click', function () {
      ['hubReportInstanceStartDate', 'hubReportInstanceEndDate', 'hubReportInstanceTemplate', 'hubReportInstanceStatus'].forEach(function (id) {
        const el = document.getElementById(id);
        if (el) el.value = '';
      });
      hubReportInstanceClassSelections = [];
      hubReportInstanceTeacherSelections = [];
      hubReportInstanceStudentSelections = [];
      syncReportInstanceInputs();
      workspaceState.serverSearch['report-instances'] = '';
      const searchInput = document.getElementById('hubServerSearch_report-instances');
      if (searchInput) searchInput.value = '';
      loadWorkspaceSection('report-instances');
    });
    root.querySelectorAll('[data-hub-report-instance-range]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        setHubReportInstanceDateRange(btn.getAttribute('data-hub-report-instance-range') || 'today');
      });
    });
    ['hubReportInstanceTemplate', 'hubReportInstanceStatus'].forEach(function (id) {
      const el = document.getElementById(id);
      if (el) el.addEventListener('change', function () { loadWorkspaceSection('report-instances'); });
    });
    const openTeacher = document.getElementById('hubReportInstanceOpenTeacherPicker');
    if (openTeacher) openTeacher.addEventListener('click', openHubReportInstanceTeacherPicker);
    const openStudent = document.getElementById('hubReportInstanceOpenStudentPicker');
    if (openStudent) openStudent.addEventListener('click', openHubReportInstanceStudentPicker);
    const openClass = document.getElementById('hubReportInstanceOpenClassPicker');
    if (openClass) openClass.addEventListener('click', openHubReportInstanceClassPicker);
    const clearTeacher = document.getElementById('hubReportInstanceClearTeacher');
    if (clearTeacher) clearTeacher.addEventListener('click', function () {
      hubReportInstanceTeacherSelections = [];
      syncReportInstanceInputs();
      loadWorkspaceSection('report-instances');
    });
    const clearStudent = document.getElementById('hubReportInstanceClearStudent');
    if (clearStudent) clearStudent.addEventListener('click', function () {
      hubReportInstanceStudentSelections = [];
      syncReportInstanceInputs();
      loadWorkspaceSection('report-instances');
    });
    const clearClass = document.getElementById('hubReportInstanceClearClass');
    if (clearClass) clearClass.addEventListener('click', function () {
      hubReportInstanceClassSelections = [];
      syncReportInstanceInputs();
      loadWorkspaceSection('report-instances');
    });
    const teacherChips = document.getElementById('hubReportInstanceTeacherChips');
    if (teacherChips) teacherChips.addEventListener('click', function (event) {
      const btn = event.target && event.target.closest('[data-hub-report-instance-remove-teacher]');
      if (!btn) return;
      const removeId = btn.getAttribute('data-hub-report-instance-remove-teacher') || '';
      hubReportInstanceTeacherSelections = hubReportInstanceTeacherSelections.filter(function (item) { return item.id !== removeId; });
      syncReportInstanceInputs();
      loadWorkspaceSection('report-instances');
    });
    const studentChips = document.getElementById('hubReportInstanceStudentChips');
    if (studentChips) studentChips.addEventListener('click', function (event) {
      const btn = event.target && event.target.closest('[data-hub-report-instance-remove-student]');
      if (!btn) return;
      const removeId = btn.getAttribute('data-hub-report-instance-remove-student') || '';
      hubReportInstanceStudentSelections = hubReportInstanceStudentSelections.filter(function (item) { return item.id !== removeId; });
      syncReportInstanceInputs();
      loadWorkspaceSection('report-instances');
    });
    const classChips = document.getElementById('hubReportInstanceClassChips');
    if (classChips) classChips.addEventListener('click', function (event) {
      const btn = event.target && event.target.closest('[data-hub-report-instance-remove-class]');
      if (!btn) return;
      const removeId = btn.getAttribute('data-hub-report-instance-remove-class') || '';
      hubReportInstanceClassSelections = hubReportInstanceClassSelections.filter(function (item) { return item.id !== removeId; });
      syncReportInstanceInputs();
      loadWorkspaceSection('report-instances');
    });
    const loadButton = els.workspace.querySelector('[data-hub-load-workspace="report-instances"]');
    if (loadButton) loadButton.addEventListener('click', function () { loadWorkspaceSection('report-instances'); });
    bindWorkspaceSearchControls('report-instances');
  }

  function reportInstanceStatusBadgeClass(status, isPendingAssignment) {
    if (isPendingAssignment === true) return 'text-bg-info';
    const value = String(status || '').trim().toLowerCase();
    if (value === 'submitted') return 'text-bg-success';
    if (value === 'locked') return 'text-bg-dark';
    if (value === 'draft') return 'text-bg-warning';
    return 'text-bg-secondary';
  }

  function renderReportInstanceRows(rows) {
    if (!Array.isArray(rows) || !rows.length) {
      return '<div class="hub-empty"><div><i class="bi bi-file-earmark-x display-6 d-block mb-3"></i><div class="fw-semibold">No report instances found.</div><div class="text-muted small mt-1">Try clearing filters or open the full page for details.</div></div></div>';
    }

    const body = rows.map(function (row) {
      const actions = (Array.isArray(row.actions) ? row.actions : []).map(function (action) {
        return '<a class="btn btn-outline-' + escapeHtml(action.tone || 'secondary') + ' btn-sm" href="' + escapeHtml(action.href || '#') + '" target="_blank" rel="noopener"><i class="' + escapeHtml(action.icon || 'bi bi-box-arrow-up-right') + ' me-1"></i>' + escapeHtml(action.label || 'Open') + '</a>';
      }).join('');
      const statusLabel = row.isPendingAssignment ? 'Pending assignment' : toHubTitleCase(row.status || 'draft');
      const instanceLabel = row.isPendingAssignment ? 'Pending report' : (row.id || '-');
      const searchText = [
        row.id,
        row.assignmentId,
        row.classTitle,
        row.templateTitle,
        row.teacherName,
        row.studentName,
        row.status,
        row.sessionDate
      ].filter(Boolean).join(' ');
      return [
        '<tr data-hub-workspace-row data-search-text="' + escapeHtml(searchText) + '">',
        '<td class="ps-3"><div class="fw-bold text-primary">' + escapeHtml(instanceLabel) + '</div><div class="x-small text-muted">Assignment: ' + escapeHtml(row.assignmentId || '-') + '</div><div class="x-small text-muted">' + escapeHtml(row.sessionDate || 'No session date') + '</div></td>',
        '<td><div class="fw-semibold">' + escapeHtml(row.classTitle || '-') + '</div><div class="x-small text-muted">Template: ' + escapeHtml(row.templateTitle || '-') + '</div></td>',
        '<td><div class="fw-semibold">' + escapeHtml(row.teacherName || '-') + '</div>' + ((row.teacherId && row.teacherName && row.teacherName !== row.teacherId) ? '<div class="x-small text-muted font-monospace">' + escapeHtml(row.teacherId) + '</div>' : '') + '</td>',
        '<td><div>' + hubStudentNameHtml(row.studentName || 'Whole class', row.studentRecordId) + '</div>' + ((row.studentId && row.studentName && row.studentName !== row.studentId && row.studentName !== 'Whole class') ? '<div class="x-small text-muted font-monospace">' + escapeHtml(row.studentId) + '</div>' : '') + '</td>',
        '<td><span class="badge ' + escapeHtml(reportInstanceStatusBadgeClass(row.status, row.isPendingAssignment)) + '">' + escapeHtml(statusLabel) + '</span></td>',
        '<td class="text-end pe-3"><div class="hub-workspace-actions">' + (actions || '<span class="text-muted small">No actions</span>') + '</div></td>',
        '</tr>'
      ].join('');
    }).join('');

    return [
      '<div class="hub-table-wrap">',
      '<table class="table table-hover align-middle hub-workspace-table">',
      '<thead><tr><th class="ps-3">Instance</th><th>Class / Template</th><th>Teacher</th><th>Student</th><th>Status</th><th class="text-end pe-3">Actions</th></tr></thead>',
      '<tbody>', body, '</tbody>',
      '</table>',
      '</div>'
    ].join('');
  }

