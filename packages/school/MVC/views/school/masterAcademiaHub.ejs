  function appendReportInstanceWorkspaceQuery(requestQuery) {
    const values = {
      dueDateStart: hubInputValue('hubReportInstanceStartDate'),
      dueDateEnd: hubInputValue('hubReportInstanceEndDate'),
      templateId: hubInputValue('hubReportInstanceTemplate'),
      status: hubInputValue('hubReportInstanceStatus'),
      classId: hubInputValue('hubReportInstanceClassId'),
      teacherPersonId: hubInputValue('hubReportInstanceTeacherId'),
      studentPersonId: hubInputValue('hubReportInstanceStudentId')
    };
    Object.keys(values).forEach(function (key) {
      if (values[key]) requestQuery.set(key, values[key]);
    });
  }

  function setHubReportInstanceDateRange(range) {
    const startEl = document.getElementById('hubReportInstanceStartDate');
    const endEl = document.getElementById('hubReportInstanceEndDate');
    if (!startEl || !endEl) return;
    const today = hubTodayDate();
    let start = new Date(today);
    let end = new Date(today);

    if (range === 'allTime') {
      startEl.value = '';
      endEl.value = '';
      loadWorkspaceSection('report-instances');
      return;
    }
    if (range === 'thisWeek') {
      const day = today.getDay() || 7;
      start.setDate(today.getDate() - (day - 1));
      end = new Date(start);
      end.setDate(start.getDate() + 6);
    } else if (range === 'last7') {
      start.setDate(today.getDate() - 6);
    } else if (range === 'thisMonth') {
      start = new Date(today.getFullYear(), today.getMonth(), 1);
      end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
    }
    startEl.value = hubDateToIso(start);
    endEl.value = hubDateToIso(end);
    loadWorkspaceSection('report-instances');
  }

  function openHubReportInstanceTeacherPicker() {
    if (!window.GenericPicker || !window.GenericPickerPresets) {
      showHubMessage({ title: 'Teacher Picker', icon: 'warning', message: 'Teacher picker is not available yet.' });
      return;
    }
    window.GenericPicker.open(window.GenericPickerPresets.teacher({
      title: 'Filter Report Instances by Teachers',
      placeholder: 'Search teachers, select one or more...',
      multiselect: true,
      context: window.GenericPickerContexts
        ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
        : undefined,
      onSelect: function (items) {
        (Array.isArray(items) ? items : [items]).forEach(function (item) {
          const id = resolveHubTeacherId(item);
          const name = formatHubTeacherName(item, id);
          if (id && !hubReportInstanceTeacherSelections.some(function (row) { return row.id === id; })) {
            hubReportInstanceTeacherSelections.push({ id, name });
          }
        });
        syncReportInstanceInputs();
        loadWorkspaceSection('report-instances');
      }
    }));
  }

