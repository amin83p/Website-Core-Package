  async function showHubInlineMessage(title, message, icon) {
    if (typeof showMessageModal === 'function') {
      return showMessageModal({
        title: title || 'Master Hub',
        icon: icon || 'info',
        message: message || '',
        buttons: [{ text: 'OK', class: 'btn-primary', value: true }]
      });
    }
    return null;
  }

  async function loadHubAttendanceMatrix() {
    const classId = String(document.getElementById('hubAttendanceClassId')?.value || '').trim();
    const classNameEl = document.getElementById('hubAttendanceClassName');
    const startDate = String(document.getElementById('hubAttendanceStartDate')?.value || '').trim();
    const endDate = String(document.getElementById('hubAttendanceEndDate')?.value || '').trim();
    const loadBtn = document.getElementById('hubAttendanceLoad');
    const status = document.getElementById('hubAttendanceStatus');

    if (!classId) {
      await showHubInlineMessage('Attendance', 'Please select a class before loading attendance.', 'warning');
      return;
    }

    const originalHtml = loadBtn ? loadBtn.innerHTML : '';
    if (loadBtn) {
      loadBtn.disabled = true;
      loadBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Loading';
    }
    if (status) status.innerHTML = '<div class="text-muted small"><i class="bi bi-arrow-repeat me-1"></i> Loading attendance matrix...</div>';
    if (typeof window.showLoading === 'function') window.showLoading('Loading attendance matrix...');

    try {
      const params = new URLSearchParams({ classId: classId });
      if (startDate) params.set('startDate', startDate);
      if (endDate) params.set('endDate', endDate);
      const response = await fetch('/school/attendances/api/data?' + params.toString(), {
        cache: 'no-store',
        headers: { Accept: 'application/json', 'X-AJAX-Request': 'true' },
        credentials: 'same-origin'
      });
      const result = await response.json().catch(function () {
        return { status: 'error', message: 'Unable to load attendance matrix.' };
      });
      const guarded = typeof window.applyGuardedApiResult === 'function'
        ? await window.applyGuardedApiResult(result, { busyTitle: 'Load In Progress', replayTitle: 'Load Already Completed' })
        : { stop: false };
      if (guarded.stop) return;
      if (!response.ok || result.status !== 'success') throw new Error(result.message || 'Unable to load attendance matrix.');

      hubAttendanceState.data = result;
      hubAttendanceState.batch = [];
      hubAttendanceState.activeBatchClassKey = '';
      resetHubAttendanceVisibility();
      if (classNameEl) classNameEl.value = result.className || classNameEl.value || classId;
      renderHubAttendanceMatrix(result);
    } catch (error) {
      if (status) status.innerHTML = '<div class="text-danger small"><i class="bi bi-exclamation-triangle me-1"></i>' + escapeHtml(error.message || 'Unable to load attendance matrix.') + '</div>';
      await showHubInlineMessage('Attendance', error.message || 'Unable to load attendance matrix.', 'error');
    } finally {
      if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
      if (loadBtn) {
        loadBtn.disabled = false;
        loadBtn.innerHTML = originalHtml;
      }
    }
  }

  async function loadHubAttendanceMatrixForClass(classRow, startDate, endDate) {
    const classId = String(classRow?.id || classRow?.classId || '').trim();
    if (!classId) return { status: 'error', className: 'Unknown Class', message: 'Class id is missing.' };
    const params = new URLSearchParams({ classId: classId });
    if (startDate) params.set('startDate', startDate);
    if (endDate) params.set('endDate', endDate);
    const response = await fetch('/school/attendances/api/data?' + params.toString(), {
      cache: 'no-store',
      headers: { Accept: 'application/json', 'X-AJAX-Request': 'true' },
      credentials: 'same-origin'
    });
    const result = await response.json().catch(function () {
      return { status: 'error', message: 'Unable to load attendance matrix.' };
    });
    const guarded = typeof window.applyGuardedApiResult === 'function'
      ? await window.applyGuardedApiResult(result, { busyTitle: 'Load In Progress', replayTitle: 'Load Already Completed' })
      : { stop: false };
    if (guarded.stop) return { status: 'skipped', classId, className: classRow?.title || classRow?.name || classId };
    if (!response.ok || result.status !== 'success') {
      return {
        status: 'error',
        classId,
        className: classRow?.title || classRow?.name || classId,
        message: result.message || 'Unable to load attendance matrix.'
      };
    }
    return result;
  }

  async function loadAllActiveHubAttendanceClasses() {
    const startDate = String(document.getElementById('hubAttendanceStartDate')?.value || '').trim();
    const endDate = String(document.getElementById('hubAttendanceEndDate')?.value || '').trim();
    const status = document.getElementById('hubAttendanceStatus');
    const output = document.getElementById('hubAttendanceResult');
    const button = document.getElementById('hubAttendanceLoadActiveClasses');
    const originalHtml = button ? button.innerHTML : '';

    if (button) {
      button.disabled = true;
      button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Loading';
    }
    if (status) status.innerHTML = '<div class="text-muted small"><i class="bi bi-arrow-repeat me-1"></i> Loading active classes...</div>';
    if (output) output.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div><div class="mt-2 text-muted small">Loading attendance for active classes...</div></div>';
    if (typeof window.showLoading === 'function') window.showLoading('Loading attendance for active classes...');

    try {
      const response = await fetch('/school/attendances/api/active-classes', {
        cache: 'no-store',
        headers: { Accept: 'application/json', 'X-AJAX-Request': 'true' },
        credentials: 'same-origin'
      });
      const payload = await response.json().catch(function () {
        return { status: 'error', message: 'Unable to load active classes.' };
      });
      if (!response.ok || payload.status !== 'success') throw new Error(payload.message || 'Unable to load active classes.');
      const classes = Array.isArray(payload.items) ? payload.items : (Array.isArray(payload.data) ? payload.data : []);
      if (!classes.length) {
        hubAttendanceState.data = null;
        hubAttendanceState.batch = [];
        hubAttendanceState.activeBatchClassKey = '';
        resetHubAttendanceVisibility();
        if (status) status.innerHTML = '<div class="text-muted small"><i class="bi bi-info-circle me-1"></i>No active classes found for the active organization.</div>';
        if (output) output.innerHTML = '<div class="hub-empty"><div><i class="bi bi-easel display-6 d-block mb-3"></i><div class="fw-semibold">No active classes found.</div></div></div>';
        return;
      }

      const results = [];
      for (const classRow of classes) {
        if (status) status.innerHTML = '<div class="text-muted small"><i class="bi bi-arrow-repeat me-1"></i> Loading ' + escapeHtml(classRow.title || classRow.name || classRow.id || 'class') + '...</div>';
        // eslint-disable-next-line no-await-in-loop
        results.push(await loadHubAttendanceMatrixForClass(classRow, startDate, endDate));
      }
      hubAttendanceState.data = null;
      hubAttendanceState.batch = results.filter(function (row) { return row && row.status !== 'skipped'; });
      hubAttendanceState.activeBatchClassKey = getHubAttendanceBatchClassKey(hubAttendanceState.batch[0], 0);
      resetHubAttendanceVisibility();
      renderHubAttendanceBatch(hubAttendanceState.batch);
    } catch (error) {
      if (status) status.innerHTML = '<div class="text-danger small"><i class="bi bi-exclamation-triangle me-1"></i>' + escapeHtml(error.message || 'Unable to load active classes.') + '</div>';
      await showHubInlineMessage('Attendance', error.message || 'Unable to load active classes.', 'error');
    } finally {
      if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
      if (button) {
        button.disabled = false;
        button.innerHTML = originalHtml;
      }
    }
  }

  function hubAttendanceStatusIcon(status) {
    const value = String(status || '').trim().toLowerCase();
    if (value === 'present') return '<i class="bi bi-check-circle-fill attendance-status-present" title="Present"></i>';
    if (value === 'late') return '<i class="bi bi-clock-fill attendance-status-late" title="Late"></i>';
    if (value === 'excused') return '<i class="bi bi-envelope-paper-fill attendance-status-excused" title="Excused"></i>';
    if (value === 'absent') return '<i class="bi bi-x-circle-fill attendance-status-absent" title="Absent"></i>';
    if (value === 'acf') return '<i class="bi bi-camera-video-off-fill attendance-status-acf" title="Absent Camera Off"></i>';
    return '<i class="bi bi-dash attendance-status-na" title="No record"></i>';
  }

  function buildHubAttendanceLegendHtml(enabledStatuses) {
    const enabled = new Set(
      (Array.isArray(enabledStatuses) && enabledStatuses.length
        ? enabledStatuses
        : ['present', 'late', 'excused', 'absent', 'acf', 'not_applicable']
      ).map(function (s) { return String(s || '').trim().toLowerCase(); })
    );
    const parts = [];
    if (enabled.has('present')) parts.push('<span class="me-3"><i class="bi bi-check-circle-fill attendance-status-present"></i> Present</span>');
    if (enabled.has('late')) parts.push('<span class="me-3"><i class="bi bi-clock-fill attendance-status-late"></i> Late</span>');
    if (enabled.has('excused')) parts.push('<span class="me-3"><i class="bi bi-envelope-paper-fill attendance-status-excused"></i> Excused</span>');
    if (enabled.has('absent')) parts.push('<span class="me-3"><i class="bi bi-x-circle-fill attendance-status-absent"></i> Absent</span>');
    if (enabled.has('acf')) parts.push('<span class="me-3"><i class="bi bi-camera-video-off-fill attendance-status-acf"></i> ACF</span>');
    if (enabled.has('not_applicable')) parts.push('<span><i class="bi bi-dash attendance-status-na"></i> N/A</span>');
    return '<div class="small text-muted">' + parts.join('') + '</div>';
  }

  function getHubAttendanceBatchClassKey(row, index) {
    return String(row?.classId || row?.id || row?.className || ('class-' + String(index + 1))).trim();
  }

  function renderHubAttendanceMatrix(result) {
    const output = document.getElementById('hubAttendanceResult');
    const status = document.getElementById('hubAttendanceStatus');
    if (!output || !result) return;

    const tableSearch = String(document.getElementById('hubAttendanceTableSearch')?.value || '').trim().toLowerCase();
    const sessions = Array.isArray(result.sessions) ? result.sessions : [];
    const allStudents = Array.isArray(result.matrix) ? result.matrix : [];
    const visibilityKey = String(result.classId || 'single').trim() || 'single';
    const visibleIds = ensureHubAttendanceVisibility(visibilityKey, allStudents);
    const matrix = allStudents.filter(function (student) {
      const personId = String(student.personId || '').trim();
      if (!personId || !visibleIds.has(personId)) return false;
      if (!tableSearch) return true;
      return [student.name, student.personId].filter(Boolean).join(' ').toLowerCase().includes(tableSearch);
    });
    const startDate = String(document.getElementById('hubAttendanceStartDate')?.value || '').trim();
    const endDate = String(document.getElementById('hubAttendanceEndDate')?.value || '').trim();

    if (status) {
      status.innerHTML = [
        '<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">',
        '<div><div class="fw-bold">' + escapeHtml(result.className || 'Class Attendance') + '</div>',
        '<div class="text-muted small">' + escapeHtml(String(matrix.length)) + ' visible students, ' + escapeHtml(String(sessions.length)) + ' sessions. Last loaded: ' + escapeHtml(formatHubInstant(new Date())) + '</div></div>',
        buildHubAttendanceLegendHtml(result.enabledAttendanceStatuses),
        '</div>'
      ].join('');
    }

    if (!sessions.length) {
      output.innerHTML = '<div class="hub-empty"><div><i class="bi bi-calendar-x display-6 d-block mb-3"></i><div class="fw-semibold">No active attendance sessions found for this range.</div><div class="text-muted small mt-1">Adjust the date range or choose All Time, then load again.</div></div></div>';
      return;
    }

    const headerCells = sessions.map(function (session) {
      const dateText = String(session.date || '').trim();
      const displayDate = dateText
        ? formatHubDateKey(dateText, { month: 'short', day: 'numeric' })
        : String(session.id || '');
      return '<th class="text-center small">' + escapeHtml(displayDate) + '</th>';
    }).join('');

    const studentHeader = buildHubStudentFilterDropdownHtml(allStudents, visibleIds, visibilityKey);
    const searchMatched = allStudents.filter(function (student) {
      if (!tableSearch) return true;
      return [student.name, student.personId].filter(Boolean).join(' ').toLowerCase().includes(tableSearch);
    });

    const bodyRows = searchMatched.length ? searchMatched.map(function (student) {
      const personId = String(student.personId || '').trim();
      const summary = student.summary || {};
      const present = Number(summary.totalPresentSessions || 0);
      const absent = Number(summary.totalAbsentSessions || 0);
      const percent = summary.performancePercent == null ? '-' : String(summary.performancePercent) + '%';
      const records = Array.isArray(student.records) ? student.records : [];
      const cells = records.map(function (record) {
        const sessionId = String(record.sessionId || '').trim();
        const notesExist = Array.isArray(record.comments) && record.comments.length > 0;
        return [
          '<td class="hub-attendance-cell" data-hub-attendance-cell data-person-id="' + escapeHtml(student.personId || '') + '" data-session-id="' + escapeHtml(sessionId) + '" title="Open this attendance record in the full Attendance page">',
          hubAttendanceStatusIcon(record.status),
          notesExist ? '<div class="small mt-1"><i class="bi bi-chat-dots-fill text-primary"></i></div>' : '',
          '</td>'
        ].join('');
      }).join('');
      return [
        '<tr class="hub-attendance-student-row" data-person-id="' + escapeHtml(personId) + '">',
        '<td class="hub-attendance-rollup text-center small"><div><span class="text-success fw-bold">' + escapeHtml(String(present)) + '</span><span class="text-muted"> / </span><span class="text-danger fw-bold">' + escapeHtml(String(absent)) + '</span></div><div class="text-primary fw-bold">' + escapeHtml(percent) + '</div></td>',
        '<td class="hub-attendance-student"><div class="fw-semibold">' + hubStudentNameHtml(student.name || 'Student', student.studentRecordId) + '</div><div class="text-muted small font-monospace">' + escapeHtml(student.personId || '') + '</div></td>',
        cells,
        '</tr>'
      ].join('');
    }).join('') : '<tr><td colspan="' + escapeHtml(String(sessions.length + 2)) + '" class="text-center text-muted py-5">No matching students in the loaded matrix.</td></tr>';

    output.innerHTML = [
      '<div class="hub-attendance-matrix-wrap" data-hub-attendance-scope="' + escapeHtml(visibilityKey) + '">',
      '<table class="table table-hover align-middle hub-attendance-table">',
      '<thead><tr><th class="hub-attendance-rollup text-center small">Rollup<br><span class="text-muted fw-normal">P / A / %</span></th><th class="hub-attendance-student">' + studentHeader + '</th>' + headerCells + '</tr></thead>',
      '<tbody>' + bodyRows + '</tbody>',
      '</table>',
      '</div>'
    ].join('');

    const scopeRoot = output.querySelector('[data-hub-attendance-scope]');
    bindHubAttendanceStudentVisibility(scopeRoot, visibilityKey, allStudents, function () {
      if (status) {
        const visibleCount = searchMatched.filter(function (student) {
          const id = String(student.personId || '').trim();
          return id && ensureHubAttendanceVisibility(visibilityKey, allStudents).has(id);
        }).length;
        status.innerHTML = [
          '<div class="d-flex justify-content-between align-items-center flex-wrap gap-2">',
          '<div><div class="fw-bold">' + escapeHtml(result.className || 'Class Attendance') + '</div>',
          '<div class="text-muted small">' + escapeHtml(String(visibleCount)) + ' visible students, ' + escapeHtml(String(sessions.length)) + ' sessions. Last loaded: ' + escapeHtml(formatHubInstant(new Date())) + '</div></div>',
          buildHubAttendanceLegendHtml(result.enabledAttendanceStatuses),
          '</div>'
        ].join('');
      }
    });
    applyHubAttendanceStudentVisibility(scopeRoot, visibilityKey, allStudents);

    output.querySelectorAll('[data-hub-attendance-cell]').forEach(function (cell) {
      cell.addEventListener('click', function () {
        const personId = cell.getAttribute('data-person-id') || '';
        const sessionId = cell.getAttribute('data-session-id') || '';
        const url = new URL('/school/attendances', window.location.origin);
        url.searchParams.set('classId', result.classId || '');
        if (startDate) url.searchParams.set('startDate', startDate);
        if (endDate) url.searchParams.set('endDate', endDate);
        if (personId) url.searchParams.set('studentId', personId);
        if (sessionId) url.searchParams.set('sessionId', sessionId);
        window.open(url.pathname + url.search, '_blank', 'noopener');
      });
    });
  }

  function renderHubAttendanceBatch(results) {
    const output = document.getElementById('hubAttendanceResult');
    const status = document.getElementById('hubAttendanceStatus');
    if (!output) return;
    const rows = Array.isArray(results) ? results : [];
    if (!rows.length) {
      if (status) status.innerHTML = '<div class="text-muted small"><i class="bi bi-info-circle me-1"></i>No attendance matrices are loaded.</div>';
      output.innerHTML = '<div class="hub-empty"><div><i class="bi bi-clipboard-check display-6 d-block mb-3"></i><div class="fw-semibold">No attendance loaded.</div></div></div>';
      return;
    }

    const tableSearch = String(document.getElementById('hubAttendanceTableSearch')?.value || '').trim().toLowerCase();
    const successful = rows.filter(function (row) { return row.status === 'success'; });
    const failed = rows.filter(function (row) { return row.status !== 'success'; });
    const totalSessions = successful.reduce(function (sum, row) { return sum + (Array.isArray(row.sessions) ? row.sessions.length : 0); }, 0);
    const totalStudents = successful.reduce(function (sum, row, index) {
      const allStudents = Array.isArray(row.matrix) ? row.matrix : [];
      const visibilityKey = getHubAttendanceBatchClassKey(row, index);
      const visibleIds = ensureHubAttendanceVisibility(visibilityKey, allStudents);
      return sum + allStudents.filter(function (student) {
        const personId = String(student.personId || '').trim();
        if (!personId || !visibleIds.has(personId)) return false;
        if (!tableSearch) return true;
        return [student.name, student.personId].filter(Boolean).join(' ').toLowerCase().includes(tableSearch);
      }).length;
    }, 0);

    if (status) {
      status.innerHTML = '<div class="d-flex justify-content-between align-items-center flex-wrap gap-2"><div><div class="fw-bold">All Active Classes Attendance</div><div class="text-muted small">' + escapeHtml(String(successful.length)) + ' classes loaded, ' + escapeHtml(String(totalStudents)) + ' visible students, ' + escapeHtml(String(totalSessions)) + ' sessions. Last loaded: ' + escapeHtml(formatHubInstant(new Date())) + '</div></div>' + (failed.length ? '<span class="badge text-bg-warning">' + escapeHtml(String(failed.length)) + ' failed</span>' : '') + '</div>';
    }

    function renderBatchClassPanel(row, index) {
      if (row.status !== 'success') {
        return '<div class="card border-danger-subtle shadow-sm mb-3"><div class="card-body"><div class="fw-bold text-danger"><i class="bi bi-exclamation-triangle me-2"></i>' + escapeHtml(row.className || row.classId || 'Class') + '</div><div class="text-muted small mt-1">' + escapeHtml(row.message || 'Unable to load this class.') + '</div></div></div>';
      }
      const sessions = Array.isArray(row.sessions) ? row.sessions : [];
      const allStudents = Array.isArray(row.matrix) ? row.matrix : [];
      const visibilityKey = getHubAttendanceBatchClassKey(row, index);
      const visibleIds = ensureHubAttendanceVisibility(visibilityKey, allStudents);
      const matrix = allStudents.filter(function (student) {
        const personId = String(student.personId || '').trim();
        if (!personId || !visibleIds.has(personId)) return false;
        if (!tableSearch) return true;
        return [student.name, student.personId].filter(Boolean).join(' ').toLowerCase().includes(tableSearch);
      });
      if (!sessions.length) {
        return '<div class="card border-0 shadow-sm mb-3"><div class="card-header bg-white fw-bold">' + escapeHtml(row.className || row.classId || 'Class') + '</div><div class="card-body"><div class="text-muted small"><i class="bi bi-calendar-x me-1"></i>No active attendance sessions found for this range.</div></div></div>';
      }
      const headerCells = sessions.map(function (session) {
        const dateText = String(session.date || '').trim();
        const displayDate = dateText
          ? formatHubDateKey(dateText, { month: 'short', day: 'numeric' })
          : String(session.id || '');
        return '<th class="text-center small">' + escapeHtml(displayDate) + '</th>';
      }).join('');
      const studentHeader = buildHubStudentFilterDropdownHtml(allStudents, visibleIds, visibilityKey);
      const searchMatched = allStudents.filter(function (student) {
        if (!tableSearch) return true;
        return [student.name, student.personId].filter(Boolean).join(' ').toLowerCase().includes(tableSearch);
      });
      const bodyRows = searchMatched.length ? searchMatched.map(function (student) {
        const personId = String(student.personId || '').trim();
        const summary = student.summary || {};
        const present = Number(summary.totalPresentSessions || 0);
        const absent = Number(summary.totalAbsentSessions || 0);
        const percent = summary.performancePercent == null ? '-' : String(summary.performancePercent) + '%';
        const records = Array.isArray(student.records) ? student.records : [];
        const cells = records.map(function (record) {
          const sessionId = String(record.sessionId || '').trim();
          const notesExist = Array.isArray(record.comments) && record.comments.length > 0;
          return '<td class="hub-attendance-cell" data-hub-attendance-cell data-class-id="' + escapeHtml(row.classId || '') + '" data-person-id="' + escapeHtml(student.personId || '') + '" data-session-id="' + escapeHtml(sessionId) + '" title="Open this attendance record in the full Attendance page">' + hubAttendanceStatusIcon(record.status) + (notesExist ? '<div class="small mt-1"><i class="bi bi-chat-dots-fill text-primary"></i></div>' : '') + '</td>';
        }).join('');
        return '<tr class="hub-attendance-student-row" data-person-id="' + escapeHtml(personId) + '"><td class="hub-attendance-rollup text-center small"><div><span class="text-success fw-bold">' + escapeHtml(String(present)) + '</span><span class="text-muted"> / </span><span class="text-danger fw-bold">' + escapeHtml(String(absent)) + '</span></div><div class="text-primary fw-bold">' + escapeHtml(percent) + '</div></td><td class="hub-attendance-student"><div class="fw-semibold">' + hubStudentNameHtml(student.name || 'Student', student.studentRecordId) + '</div><div class="text-muted small font-monospace">' + escapeHtml(student.personId || '') + '</div></td>' + cells + '</tr>';
      }).join('') : '<tr><td colspan="' + escapeHtml(String(sessions.length + 2)) + '" class="text-center text-muted py-5">No matching students in this class matrix.</td></tr>';
      return '<div class="card border-0 shadow-sm mb-4" data-hub-batch-panel="' + escapeHtml(visibilityKey) + '"><div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2"><div><div class="fw-bold">' + escapeHtml(row.className || row.classId || 'Class') + '</div><div class="text-muted small hub-batch-visible-count">' + escapeHtml(String(matrix.length)) + ' visible students, ' + escapeHtml(String(sessions.length)) + ' sessions</div></div><a class="btn btn-outline-primary btn-sm" href="/school/attendances?classId=' + encodeURIComponent(row.classId || '') + '" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right me-1"></i>Open</a></div><div class="card-body p-0"><div class="hub-attendance-matrix-wrap border-0" data-hub-attendance-scope="' + escapeHtml(visibilityKey) + '"><table class="table table-hover align-middle hub-attendance-table mb-0"><thead><tr><th class="hub-attendance-rollup text-center small">Rollup<br><span class="text-muted fw-normal">P / A / %</span></th><th class="hub-attendance-student">' + studentHeader + '</th>' + headerCells + '</tr></thead><tbody>' + bodyRows + '</tbody></table></div></div></div>';
    }

    if (rows.length > 1) {
      const activeKeyExists = rows.some(function (row, index) {
        return getHubAttendanceBatchClassKey(row, index) === hubAttendanceState.activeBatchClassKey;
      });
      if (!hubAttendanceState.activeBatchClassKey || !activeKeyExists) {
        hubAttendanceState.activeBatchClassKey = getHubAttendanceBatchClassKey(rows[0], 0);
      }
      let activeIndex = 0;
      const activeRow = rows.find(function (row, index) {
        const matched = getHubAttendanceBatchClassKey(row, index) === hubAttendanceState.activeBatchClassKey;
        if (matched) activeIndex = index;
        return matched;
      }) || rows[0];
      const tabs = rows.map(function (row, index) {
        const classKey = getHubAttendanceBatchClassKey(row, index);
        const isActive = classKey === hubAttendanceState.activeBatchClassKey;
        const sessionCount = Array.isArray(row.sessions) ? row.sessions.length : 0;
        const studentCount = Array.isArray(row.matrix) ? row.matrix.length : 0;
        const badgeClass = row.status === 'success'
          ? (isActive ? 'text-bg-light' : 'text-bg-primary')
          : 'text-bg-warning';
        const badgeText = row.status === 'success'
          ? String(studentCount) + ' students'
          : 'Needs attention';
        return [
          '<button type="button" class="btn btn-sm ' + (isActive ? 'btn-primary' : 'btn-outline-primary') + ' hub-schedule-person-tab" data-hub-attendance-class-tab="' + escapeHtml(classKey) + '">',
          '<i class="bi bi-easel-fill"></i>',
          '<span>' + escapeHtml(row.className || row.classId || 'Class') + '</span>',
          row.status === 'success' ? '<span class="text-muted small">' + escapeHtml(String(sessionCount)) + ' sessions</span>' : '',
          '<span class="badge ' + badgeClass + '">' + escapeHtml(badgeText) + '</span>',
          '</button>'
        ].join('');
      }).join('');

      output.innerHTML = [
        '<div class="card border-0 shadow-sm">',
        '<div class="hub-schedule-tabs" id="hubAttendanceClassTabs">',
        tabs,
        '</div>',
        '<div class="card-body">',
        '<div id="hubAttendanceClassTabContent">',
        renderBatchClassPanel(activeRow, activeIndex),
        '</div>',
        '</div>',
        '</div>'
      ].join('');

      output.querySelectorAll('[data-hub-attendance-class-tab]').forEach(function (tab) {
        tab.addEventListener('click', function () {
          hubAttendanceState.activeBatchClassKey = tab.getAttribute('data-hub-attendance-class-tab') || hubAttendanceState.activeBatchClassKey;
          renderHubAttendanceBatch(hubAttendanceState.batch);
        });
      });
    } else {
      output.innerHTML = rows.map(function (row, index) {
        return renderBatchClassPanel(row, index);
      }).join('');
    }

    output.querySelectorAll('[data-hub-attendance-scope]').forEach(function (scopeRoot) {
      const visibilityKey = String(scopeRoot.getAttribute('data-hub-attendance-scope') || '').trim();
      const panelRow = rows.find(function (row, index) {
        return getHubAttendanceBatchClassKey(row, index) === visibilityKey;
      });
      const allStudents = Array.isArray(panelRow?.matrix) ? panelRow.matrix : [];
      bindHubAttendanceStudentVisibility(scopeRoot, visibilityKey, allStudents, function () {
        const panel = scopeRoot.closest('[data-hub-batch-panel]');
        const countEl = panel ? panel.querySelector('.hub-batch-visible-count') : null;
        if (countEl) {
          const visibleIds = ensureHubAttendanceVisibility(visibilityKey, allStudents);
          const visibleCount = allStudents.filter(function (student) {
            const personId = String(student.personId || '').trim();
            if (!personId || !visibleIds.has(personId)) return false;
            if (!tableSearch) return true;
            return [student.name, student.personId].filter(Boolean).join(' ').toLowerCase().includes(tableSearch);
          }).length;
          const sessionCount = Array.isArray(panelRow?.sessions) ? panelRow.sessions.length : 0;
          countEl.textContent = String(visibleCount) + ' visible students, ' + String(sessionCount) + ' sessions';
        }
      });
      applyHubAttendanceStudentVisibility(scopeRoot, visibilityKey, allStudents);
    });

    output.querySelectorAll('[data-hub-attendance-cell]').forEach(function (cell) {
      cell.addEventListener('click', function () {
        const classId = cell.getAttribute('data-class-id') || '';
        const personId = cell.getAttribute('data-person-id') || '';
        const sessionId = cell.getAttribute('data-session-id') || '';
        const startDate = String(document.getElementById('hubAttendanceStartDate')?.value || '').trim();
        const endDate = String(document.getElementById('hubAttendanceEndDate')?.value || '').trim();
        const url = new URL('/school/attendances', window.location.origin);
        if (classId) url.searchParams.set('classId', classId);
        if (startDate) url.searchParams.set('startDate', startDate);
        if (endDate) url.searchParams.set('endDate', endDate);
        if (personId) url.searchParams.set('studentId', personId);
        if (sessionId) url.searchParams.set('sessionId', sessionId);
        window.open(url.pathname + url.search, '_blank', 'noopener');
      });
    });
  }

  function reportAssignmentStatusBadgeClass(status) {
    const value = String(status || '').trim().toLowerCase();
    if (value === 'active') return 'text-bg-success';
    if (value === 'draft') return 'text-bg-warning';
    if (value === 'archived' || value === 'inactive') return 'text-bg-secondary';
    return 'text-bg-primary';
  }

  function reportScopeLabel(scope, targetStudentCount) {
    const value = String(scope || '').trim().toLowerCase();
    if (value === 'each_student') return 'Each student';
    if (value === 'selected_students') return 'Selected students (' + String(Number(targetStudentCount || 0)) + ')';
    return 'Whole class';
  }

  function renderReportAssignmentClassChips() {
    const container = document.getElementById('hubReportAssignmentClassChips');
    if (!container) return;
    if (!hubReportAssignmentClassSelections.length) {
      container.innerHTML = '<div class="small text-muted">No class filter selected.</div>';
      return;
    }
    container.innerHTML = hubReportAssignmentClassSelections.map(function (item) {
      return [
        '<span class="badge rounded-pill text-bg-light border d-inline-flex align-items-center gap-1 px-2 py-1 me-1 mb-1">',
        '<span>' + escapeHtml(item.name || item.id) + '</span>',
        '<button type="button" class="btn-close btn-close-sm ms-1" style="font-size:0.62rem;" aria-label="Remove class" data-hub-report-assignment-remove-class="' + escapeHtml(item.id) + '"></button>',
        '</span>'
      ].join('');
    }).join('');
  }

  function syncReportAssignmentFilterInputs() {
    const classIds = hubReportAssignmentClassSelections.map(function (item) { return item.id; }).filter(Boolean);
    const classIdEl = document.getElementById('hubReportAssignmentClassId');
    const classIdsEl = document.getElementById('hubReportAssignmentClassIds');
    const classNameEl = document.getElementById('hubReportAssignmentClassName');
    const teacherIdEl = document.getElementById('hubReportAssignmentTeacherPersonId');
    const teacherNameEl = document.getElementById('hubReportAssignmentTeacherName');
    const scopeEl = document.getElementById('hubReportAssignmentScope');

    if (classIdEl) classIdEl.value = classIds[0] || '';
    if (classIdsEl) classIdsEl.value = classIds.join(',');
    if (classNameEl) classNameEl.value = hubReportAssignmentClassSelections.map(function (item) { return item.name || item.id; }).join(', ');

    if (teacherIdEl) workspaceState.reportAssignmentTeacherPersonId = String(teacherIdEl.value || '').trim();
    if (teacherNameEl) workspaceState.reportAssignmentTeacherName = String(teacherNameEl.value || '').trim();
    if (scopeEl) workspaceState.reportAssignmentScope = String(scopeEl.value || '').trim().toLowerCase();

    renderReportAssignmentClassChips();
  }

  function appendReportAssignmentWorkspaceQuery(requestQuery) {
    const classIds = hubReportAssignmentClassSelections.map(function (item) { return item.id; }).filter(Boolean);
    if (classIds.length) {
      requestQuery.set('classIds', classIds.join(','));
      requestQuery.set('classId', classIds[0]);
    }
    if (workspaceState.reportAssignmentTeacherPersonId) requestQuery.set('teacherPersonId', workspaceState.reportAssignmentTeacherPersonId);
    if (workspaceState.reportAssignmentScope) requestQuery.set('reportScope', workspaceState.reportAssignmentScope);
  }

  function openHubReportAssignmentTeacherPicker() {
    if (!window.GenericPicker || !window.GenericPickerPresets) {
      showHubMessage({ title: 'Teacher Picker', icon: 'warning', message: 'Teacher picker is not available yet.' });
      return;
    }
    window.GenericPicker.open(window.GenericPickerPresets.teacher({
      title: 'Filter by Assigned Teacher',
      context: window.GenericPickerContexts
        ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
        : undefined,
      onSelect: function (itemOrItems) {
        const item = Array.isArray(itemOrItems) ? itemOrItems[0] : itemOrItems;
        const id = resolveHubTeacherId(item);
        if (!id) return;
        const name = formatHubTeacherName(item, id);
        const teacherIdEl = document.getElementById('hubReportAssignmentTeacherPersonId');
        const teacherNameEl = document.getElementById('hubReportAssignmentTeacherName');
        if (teacherIdEl) teacherIdEl.value = id;
        if (teacherNameEl) teacherNameEl.value = name;
        syncReportAssignmentFilterInputs();
        loadWorkspaceSection('report-assignments');
      }
    }));
  }

  function openHubReportAssignmentClassPicker() {
    if (!window.GenericPicker || !window.GenericPickerPresets) {
      showHubMessage({ title: 'Class Picker', icon: 'warning', message: 'Class picker is not available yet.' });
      return;
    }
    window.GenericPicker.open(window.GenericPickerPresets.class({
      title: 'Filter Report Assignments by Classes',
      icon: 'bi-book',
      multiselect: true,
      onSelect: function (items) {
        (Array.isArray(items) ? items : [items]).forEach(function (item) {
          const id = resolveHubClassId(item);
          const name = formatHubClassName(item, id);
          if (id && !hubReportAssignmentClassSelections.some(function (row) { return row.id === id; })) {
            hubReportAssignmentClassSelections.push({ id, name });
          }
        });
        syncReportAssignmentFilterInputs();
        loadWorkspaceSection('report-assignments');
      }
    }));
  }

  function bindReportAssignmentWorkspaceControls() {
    const loadButton = els.workspace.querySelector('[data-hub-load-workspace="report-assignments"]');
    if (loadButton) {
      loadButton.addEventListener('click', function () {
        syncReportAssignmentFilterInputs();
        loadWorkspaceSection('report-assignments');
      });
    }
    const applyBtn = document.getElementById('hubReportAssignmentFilterLoad');
    if (applyBtn) {
      applyBtn.addEventListener('click', function () {
        syncReportAssignmentFilterInputs();
        loadWorkspaceSection('report-assignments');
      });
    }
    const resetBtn = document.getElementById('hubReportAssignmentReset');
    if (resetBtn) {
      resetBtn.addEventListener('click', function () {
        hubReportAssignmentClassSelections = [];
        workspaceState.reportAssignmentTeacherPersonId = '';
        workspaceState.reportAssignmentTeacherName = '';
        workspaceState.reportAssignmentScope = '';
        const teacherIdEl = document.getElementById('hubReportAssignmentTeacherPersonId');
        const teacherNameEl = document.getElementById('hubReportAssignmentTeacherName');
        const scopeEl = document.getElementById('hubReportAssignmentScope');
        if (teacherIdEl) teacherIdEl.value = '';
        if (teacherNameEl) teacherNameEl.value = '';
        if (scopeEl) scopeEl.value = '';
        syncReportAssignmentFilterInputs();
        loadWorkspaceSection('report-assignments');
      });
    }
    const openTeacherBtn = document.getElementById('hubReportAssignmentOpenTeacherPicker');
    if (openTeacherBtn) openTeacherBtn.addEventListener('click', openHubReportAssignmentTeacherPicker);
    const clearTeacherBtn = document.getElementById('hubReportAssignmentClearTeacher');
    if (clearTeacherBtn) {
      clearTeacherBtn.addEventListener('click', function () {
        const teacherIdEl = document.getElementById('hubReportAssignmentTeacherPersonId');
        const teacherNameEl = document.getElementById('hubReportAssignmentTeacherName');
        if (teacherIdEl) teacherIdEl.value = '';
        if (teacherNameEl) teacherNameEl.value = '';
        syncReportAssignmentFilterInputs();
        loadWorkspaceSection('report-assignments');
      });
    }
    const openClassBtn = document.getElementById('hubReportAssignmentOpenClassPicker');
    if (openClassBtn) openClassBtn.addEventListener('click', openHubReportAssignmentClassPicker);
    const clearClassBtn = document.getElementById('hubReportAssignmentClearClass');
    if (clearClassBtn) {
      clearClassBtn.addEventListener('click', function () {
        hubReportAssignmentClassSelections = [];
        syncReportAssignmentFilterInputs();
        loadWorkspaceSection('report-assignments');
      });
    }
    const classChips = document.getElementById('hubReportAssignmentClassChips');
    if (classChips) {
      classChips.addEventListener('click', function (event) {
        const button = event.target && event.target.closest('[data-hub-report-assignment-remove-class]');
        if (!button) return;
        const removeId = button.getAttribute('data-hub-report-assignment-remove-class') || '';
        hubReportAssignmentClassSelections = hubReportAssignmentClassSelections.filter(function (item) { return item.id !== removeId; });
        syncReportAssignmentFilterInputs();
        loadWorkspaceSection('report-assignments');
      });
    }
    const scopeEl = document.getElementById('hubReportAssignmentScope');
    if (scopeEl) {
      scopeEl.addEventListener('change', function () {
        syncReportAssignmentFilterInputs();
        loadWorkspaceSection('report-assignments');
      });
    }
    bindWorkspaceSearchControls('report-assignments');
  }

  function renderReportAssignmentRows(rows) {
    if (!Array.isArray(rows) || !rows.length) {
      return '<div class="hub-empty"><div><i class="bi bi-clipboard2-x display-6 d-block mb-3"></i><div class="fw-semibold">No report assignments found.</div><div class="text-muted small mt-1">Try clearing filters or open the full page for assignment management.</div></div></div>';
    }

    const body = rows.map(function (row) {
      const actions = (Array.isArray(row.actions) ? row.actions : []).map(function (action) {
        return '<a class="btn btn-outline-' + escapeHtml(action.tone || 'secondary') + ' btn-sm" href="' + escapeHtml(action.href || '#') + '" target="_blank" rel="noopener"><i class="' + escapeHtml(action.icon || 'bi bi-box-arrow-up-right') + ' me-1"></i>' + escapeHtml(action.label || 'Open') + '</a>';
      }).join('');
      const cycleSeed = Number(row?.classLifecycle?.cycleNo || 1);
      const cycleNo = Number.isFinite(cycleSeed) && cycleSeed > 0 ? cycleSeed : 1;
      const targetType = String(row.targetType || 'date').toLowerCase() === 'date' ? 'Date target' : 'Session target';
      const searchText = [
        row.id,
        row.classTitle,
        row.templateTitle,
        row.targetDate,
        row.reportScope,
        row.status,
        row.reportStartDate,
        row.reportDueDate,
        Array.isArray(row.teacherIds) ? row.teacherIds.join(' ') : ''
      ].filter(Boolean).join(' ');
      return [
        '<tr data-hub-workspace-row data-search-text="' + escapeHtml(searchText) + '">',
