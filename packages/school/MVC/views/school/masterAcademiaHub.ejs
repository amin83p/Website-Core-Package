  function toHubTitleCase(value) {
    return String(value || '').replace(/_/g, ' ').replace(/\b\w/g, function (ch) { return ch.toUpperCase(); });
  }

  function sessionIssueBadgeClass(value, type) {
    const key = String(value || '').toLowerCase();
    if (type === 'severity') {
      if (key === 'urgent') return 'bg-danger';
      if (key === 'warning') return 'bg-warning text-dark';
      return 'bg-info text-dark';
    }
    if (key === 'resolved') return 'bg-success';
    if (key === 'cancelled') return 'bg-secondary';
    if (key === 'in_progress') return 'bg-primary';
    if (key === 'reopened') return 'bg-warning text-dark';
    return 'bg-dark';
  }

  function formatHubSessionIssueDate(dateValue) {
    const raw = String(dateValue || '').trim();
    if (!raw) return '-';
    try {
      return formatHubDateKey(raw, { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
    } catch (error) {
      return raw;
    }
  }

  function formatHubSessionIssueDateTime(value) {
    const raw = String(value || '').trim();
    if (!raw) return '-';
    return formatHubInstant(raw);
  }

  function resolveHubClassId(item) {
    if (!item || typeof item !== 'object') return '';
    return String(item.id || item.classId || item._id || '').trim();
  }

  function formatHubClassName(item, fallbackId) {
    if (!item || typeof item !== 'object') return String(fallbackId || '').trim();
    const direct = String(item.title || item.name || item.className || item.label || '').trim();
    return direct && direct !== '[object Object]' ? direct : String(fallbackId || item.id || '').trim();
  }

  function renderSessionIssueTeacherChips() {
    const container = document.getElementById('hubSessionIssueTeacherChips');
    if (!container) return;
    if (!hubSessionIssueTeacherSelections.length) {
      container.innerHTML = '<div class="text-muted small">No teacher filter selected.</div>';
      return;
    }
    container.innerHTML = hubSessionIssueTeacherSelections.map(function (item) {
      return '<span class="badge rounded-pill text-bg-light border d-inline-flex align-items-center gap-1 px-2 py-1 me-1 mb-1"><span>' + escapeHtml(item.name || item.id) + '</span><button type="button" class="btn-close btn-close-sm ms-1" style="font-size:0.62rem;" aria-label="Remove ' + escapeHtml(item.name || item.id) + '" data-hub-session-issue-remove-teacher="' + escapeHtml(item.id) + '"></button></span>';
    }).join('');
  }

