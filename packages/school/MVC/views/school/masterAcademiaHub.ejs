      return '<span class="badge rounded-pill text-bg-light border d-inline-flex align-items-center gap-1 px-2 py-1 me-1 mb-1"><span>' + escapeHtml(item.name || item.id) + '</span><button type="button" class="btn-close btn-close-sm ms-1" style="font-size:0.62rem;" aria-label="Remove ' + escapeHtml(item.name || item.id) + '" data-hub-session-issue-remove-student="' + escapeHtml(item.id) + '"></button></span>';
