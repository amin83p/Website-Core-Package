  let hubMakeupOriginalDurationHours = 0;
  let hubMakeupDefaultPercent = 100;

  function hubAddMinutesToClockTime(startTime, minutesToAdd) {
    const start = String(startTime || '').trim();
    if (!/^\d{2}:\d{2}$/.test(start)) return '';
    const parts = start.split(':').map(Number);
    const totalMinutes = (parts[0] * 60) + parts[1] + Number(minutesToAdd || 0);
    if (!Number.isFinite(totalMinutes) || totalMinutes <= 0) return '';
    const endH = Math.floor(totalMinutes / 60) % 24;
    const endM = totalMinutes % 60;
    return String(endH).padStart(2, '0') + ':' + String(endM).padStart(2, '0');
  }

  function hubFormatDurationHoursLabel(hours) {
    const safe = Number(hours);
    if (!Number.isFinite(safe) || safe <= 0) return '0 hr';
    const minutes = Math.round(safe * 60);
    const wholeHours = Math.floor(minutes / 60);
    const remainderMinutes = minutes % 60;
    if (wholeHours && remainderMinutes) return wholeHours + ' hr ' + remainderMinutes + ' min';
    if (wholeHours) return wholeHours + ' hr';
    return remainderMinutes + ' min';
  }

  function hubResolveOriginalDurationHours(row) {
    const start = String(row?.startTime || '').trim();
    const end = String(row?.endTime || '').trim();
    if (start && end && /^\d{2}:\d{2}$/.test(start) && /^\d{2}:\d{2}$/.test(end)) {
      const [sh, sm] = start.split(':').map(Number);
      const [eh, em] = end.split(':').map(Number);
      const minutes = ((eh * 60) + em) - ((sh * 60) + sm);
      if (minutes > 0) return Number((minutes / 60).toFixed(2));
    }
    const fallback = Number(row?.durationHours || 0);
    return Number.isFinite(fallback) && fallback > 0 ? fallback : 0;
  }

  function syncHubMakeupSessionDurationPreview() {
    const modal = document.getElementById('hubSessionMakeupModal');
    if (!modal) return;
    const percentInput = modal.querySelector('#hubMakeupSessionDurationPercent');
    const startInput = modal.querySelector('#hubMakeupSessionStart');
    const endInput = modal.querySelector('#hubMakeupSessionEnd');
    const summary = modal.querySelector('#hubMakeupSessionDurationSummary');
    const percent = Math.max(1, Math.min(100, Number(percentInput?.value || hubMakeupDefaultPercent || 100)));
    if (percentInput) percentInput.value = String(percent);
    const makeupHours = Number((Number(hubMakeupOriginalDurationHours || 0) * (percent / 100)).toFixed(2));
    if (startInput?.value) {
      const computedEnd = hubAddMinutesToClockTime(startInput.value, Math.round(makeupHours * 60));
      if (computedEnd && endInput) endInput.value = computedEnd;
    }
    if (!summary) return;
    summary.innerHTML = '<strong>Original session:</strong> ' + hubFormatDurationHoursLabel(hubMakeupOriginalDurationHours)
      + '<br><strong>Make-up at ' + percent + '%:</strong> ' + hubFormatDurationHoursLabel(makeupHours)
      + '<br><span class="text-muted">Original session payroll uses Timesheet Formula on the full duration. Make-up payroll applies when the make-up session is completed.</span>';
  }

