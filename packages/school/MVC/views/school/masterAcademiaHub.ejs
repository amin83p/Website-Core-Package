  function renderSessionIssueClassChips() {
    const container = document.getElementById('hubSessionIssueClassChips');
    if (!container) return;
    if (!hubSessionIssueClassSelections.length) {
      container.innerHTML = '<div class="text-muted small">No class filter selected.</div>';
