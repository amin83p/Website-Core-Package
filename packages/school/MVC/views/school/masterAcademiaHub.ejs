  function syncSessionIssueInputs() {
    const teacherIdEl = document.getElementById('hubSessionIssueTeacherId');
    const teacherNameEl = document.getElementById('hubSessionIssueTeacherName');
    const studentIdEl = document.getElementById('hubSessionIssueStudentId');
    const studentNameEl = document.getElementById('hubSessionIssueStudentName');
    const classIdEl = document.getElementById('hubSessionIssueClassId');
    const classNameEl = document.getElementById('hubSessionIssueClassName');
    if (teacherIdEl) teacherIdEl.value = hubSessionIssueTeacherSelections.map(function (item) { return item.id; }).filter(Boolean).join(',');
    if (teacherNameEl) teacherNameEl.value = hubSessionIssueTeacherSelections.map(function (item) { return item.name || item.id; }).join(', ');
    if (studentIdEl) studentIdEl.value = hubSessionIssueStudentSelections.map(function (item) { return item.id; }).filter(Boolean).join(',');
    if (studentNameEl) studentNameEl.value = hubSessionIssueStudentSelections.map(function (item) { return item.name || item.id; }).join(', ');
    if (classIdEl) classIdEl.value = hubSessionIssueClassSelections.map(function (item) { return item.id; }).filter(Boolean).join(',');
    if (classNameEl) classNameEl.value = hubSessionIssueClassSelections.map(function (item) { return item.name || item.id; }).join(', ');
    renderSessionIssueTeacherChips();
    renderSessionIssueStudentChips();
    renderSessionIssueClassChips();
  }

  function appendSessionIssueWorkspaceQuery(requestQuery) {
    const values = {
      startDate: hubInputValue('hubSessionIssueStartDate'),
      endDate: hubInputValue('hubSessionIssueEndDate'),
      severity: hubInputValue('hubSessionIssueSeverity'),
      category: hubInputValue('hubSessionIssueCategory'),
      statusGroup: hubInputValue('hubSessionIssueStatusGroup'),
      classId: hubInputValue('hubSessionIssueClassId'),
      teacherPersonId: hubInputValue('hubSessionIssueTeacherId'),
      studentPersonId: hubInputValue('hubSessionIssueStudentId')
    };
    Object.keys(values).forEach(function (key) {
      if (values[key]) requestQuery.set(key, values[key]);
    });
  }

  function setHubSessionIssueDateRange(range) {
    const startEl = document.getElementById('hubSessionIssueStartDate');
    const endEl = document.getElementById('hubSessionIssueEndDate');
    if (!startEl || !endEl) return;
    const today = hubTodayDate();
    let start = new Date(today);
    let end = new Date(today);

    if (range === 'allTime') {
      startEl.value = '';
      endEl.value = '';
      loadWorkspaceSection('session-issues');
      return;
    }
    if (range === 'thisWeek') {
      const day = today.getDay() || 7;
      start.setDate(today.getDate() - (day - 1));
      end = new Date(start);
      end.setDate(start.getDate() + 6);
    } else if (range === 'last7') {
      start.setDate(today.getDate() - 6);
    } else if (range === 'thisMonth') {
      start = new Date(today.getFullYear(), today.getMonth(), 1);
      end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
    }
    startEl.value = hubDateToIso(start);
    endEl.value = hubDateToIso(end);
    loadWorkspaceSection('session-issues');
  }

