  const hubAttendanceState = {
    data: null,
    batch: [],
    activeBatchClassKey: '',
    visibilityByKey: {}
  };

  function resetHubAttendanceVisibility() {
    hubAttendanceState.visibilityByKey = {};
  }

  function ensureHubAttendanceVisibility(key, students) {
    const mapKey = String(key || 'default').trim() || 'default';
    if (!(hubAttendanceState.visibilityByKey[mapKey] instanceof Set)) {
      const next = new Set();
      (Array.isArray(students) ? students : []).forEach(function (student) {
        const id = String(student && student.personId ? student.personId : '').trim();
        if (id) next.add(id);
      });
      hubAttendanceState.visibilityByKey[mapKey] = next;
    }
    return hubAttendanceState.visibilityByKey[mapKey];
  }

  function buildHubStudentFilterDropdownHtml(students, visibleIds, filterId) {
    const rows = Array.isArray(students) ? students : [];
    const visible = visibleIds instanceof Set ? visibleIds : new Set();
    const safeFilterId = String(filterId || 'hubAttFilter').replace(/[^a-zA-Z0-9_-]/g, '_');
    const total = rows.length;
    const shown = rows.reduce(function (count, student) {
      const id = String(student && student.personId ? student.personId : '').trim();
      return count + (id && visible.has(id) ? 1 : 0);
    }, 0);
    const items = rows.map(function (student) {
      const id = String(student && student.personId ? student.personId : '').trim();
      if (!id) return '';
      const name = String(student.name || id).trim() || id;
      const inputId = safeFilterId + '_' + id.replace(/[^a-zA-Z0-9_-]/g, '_');
      return [
        '<li class="px-3 py-1">',
        '<div class="form-check mb-0">',
        '<input class="form-check-input hub-student-visibility-check" type="checkbox" value="' + escapeHtml(id) + '" id="' + escapeHtml(inputId) + '"' + (visible.has(id) ? ' checked' : '') + '>',
        '<label class="form-check-label" for="' + escapeHtml(inputId) + '">' + escapeHtml(name) + '</label>',
        '</div>',
        '</li>'
      ].join('');
    }).join('');
    return [
      '<div class="d-flex flex-column align-items-start gap-1">',
      '<div class="fw-bold">Student</div>',
      '<div class="dropdown hub-student-filter-dropdown" data-hub-visibility-key="' + escapeHtml(String(filterId || '')) + '">',
      '<button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">',
      '<i class="bi bi-people me-1"></i>Students <span class="hub-student-filter-count">' + escapeHtml(String(shown)) + '/' + escapeHtml(String(total)) + '</span>',
      '</button>',
      '<ul class="dropdown-menu shadow-sm p-0 attendance-student-filter-menu">',
      '<li class="px-3 py-2 border-bottom bg-light sticky-top">',
      '<div class="d-flex gap-2">',
