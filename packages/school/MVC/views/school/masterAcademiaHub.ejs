  function bindTimesheetManagementWorkspaceControls() {
    const yearSelect = document.getElementById('hubTimesheetManagementYear');
    const loadButtons = [
      document.getElementById('hubTimesheetManagementLoadRoster'),
      document.getElementById('hubTimesheetManagementLoadRosterAlt')
    ].filter(Boolean);
    const personSearch = document.getElementById('hubTimesheetManagementPersonSearch');
    const statusFilter = document.getElementById('hubTimesheetManagementStatusFilter');
    const clearButton = document.getElementById('hubTimesheetManagementClear');
    const host = document.getElementById('hubTimesheetManagementRosterHost');

    if (yearSelect) {
      yearSelect.addEventListener('change', function () {
        hubTimesheetManagementState.selectedYear = String(yearSelect.value || '');
        hubTimesheetManagementState.rows = [];
        hubTimesheetManagementState.period = null;
        const personSearchInput = document.getElementById('hubTimesheetManagementPersonSearch');
        if (personSearchInput) personSearchInput.value = '';
        renderHubTimesheetManagementPeriodOptions();
        renderTimesheetManagementRows(true);
        updateTimesheetManagementMeta();
      });
    }
    loadButtons.forEach(function (button) {
      button.addEventListener('click', loadHubTimesheetManagementRoster);
    });
    if (personSearch) {
      personSearch.addEventListener('input', function () {
        renderTimesheetManagementRows(false);
      });
    }
    if (statusFilter) {
      statusFilter.addEventListener('change', function () {
        hubTimesheetManagementState.rows = [];
        hubTimesheetManagementState.period = null;
        renderTimesheetManagementRows(true);
        updateTimesheetManagementMeta();
      });
    }
    if (clearButton) {
      clearButton.addEventListener('click', function () {
        hubTimesheetManagementState.rows = [];
        hubTimesheetManagementState.period = null;
        const periodSelect = document.getElementById('hubTimesheetManagementPeriodId');
        if (periodSelect) periodSelect.value = '';
        if (personSearch) personSearch.value = '';
        if (statusFilter) statusFilter.value = '';
        renderTimesheetManagementRows(true);
      });
    }
    if (host) {
      host.addEventListener('click', function (event) {
        const button = event.target && event.target.closest('[data-hub-timesheet-management-summary-person]');
        if (!button) return;
        loadHubTimesheetManagementSummary(
          button.getAttribute('data-hub-timesheet-management-summary-person') || '',
          button.getAttribute('data-person-name') || 'Person'
        );
      });
    }
  }

  async function loadHubTimesheetManagementPeriods(options) {
    const quiet = options && options.quiet === true;
    const params = new URLSearchParams();
    params.set('limit', '1000');
    try {
      if (!quiet && typeof window.showLoading === 'function') window.showLoading('Loading timesheet periods...');
      const result = await fetchHubTimesheetManagementJson('/school/timesheets/manage/api/periods?' + params.toString());
      hubTimesheetManagementState.periods = Array.isArray(result.results)
        ? result.results
        : (Array.isArray(result.data) ? result.data : []);
      refreshHubTimesheetManagementYears();
      renderHubTimesheetManagementPeriodOptions();
      updateTimesheetManagementMeta();
    } catch (error) {
      await showHubMessage({ title: 'Timesheet Period Load Failed', icon: 'error', message: error.message || 'Unable to load timesheet periods.', buttons: [{ text: 'Close', class: 'btn-danger' }] });
    } finally {
      if (!quiet && typeof window.hideLoading === 'function') window.hideLoading({ force: true });
    }
  }

  async function loadHubTimesheetManagementRoster() {
    const periodId = String(document.getElementById('hubTimesheetManagementPeriodId')?.value || '').trim();
    if (!periodId) {
      await showHubMessage({ title: 'Select A Period', icon: 'warning', message: 'Please select a timesheet period before loading the roster.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
      return;
    }
    try {
      if (typeof window.showLoading === 'function') window.showLoading('Loading timesheet roster...');
      const rosterParams = new URLSearchParams({ periodId });
      const requestedStatus = String(document.getElementById('hubTimesheetManagementStatusFilter')?.value || '').trim();
      if (requestedStatus) rosterParams.set('timesheetStatus', requestedStatus);
      const result = await fetchHubTimesheetManagementJson('/school/timesheets/manage/api/roster?' + rosterParams.toString());
      hubTimesheetManagementState.period = result.period || { id: periodId };
      hubTimesheetManagementState.rows = Array.isArray(result.rows) ? result.rows : [];
      renderTimesheetManagementRows(false);
    } catch (error) {
      await showHubMessage({ title: 'Roster Load Failed', icon: 'error', message: error.message || 'Unable to load the timesheet roster.', buttons: [{ text: 'Close', class: 'btn-danger' }] });
    } finally {
      if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
    }
  }

  async function loadHubTimesheetManagementSummary(personId, personName) {
    const periodId = String(hubTimesheetManagementState.period?.id || document.getElementById('hubTimesheetManagementPeriodId')?.value || '').trim();
    if (!periodId || !personId) return;
    const modalEl = document.getElementById('hubTimesheetManagementSummaryModal');
    const subtitle = document.getElementById('hubTimesheetManagementSummarySubtitle');
    const content = document.getElementById('hubTimesheetManagementSummaryContent');
    if (subtitle) subtitle.textContent = String(personName || personId) + ' - ' + String(hubTimesheetManagementState.period?.name || periodId);
    if (content) content.innerHTML = '<div class="text-center text-muted py-4"><span class="spinner-border spinner-border-sm me-2"></span>Loading summary...</div>';
    if (modalEl && typeof bootstrap !== 'undefined') bootstrap.Modal.getOrCreateInstance(modalEl).show();
    try {
      const url = '/school/timesheets/manage/api/department-summary?periodId=' + encodeURIComponent(periodId) + '&personId=' + encodeURIComponent(personId);
      const result = await fetchHubTimesheetManagementJson(url);
      renderHubTimesheetManagementSummary(result);
    } catch (error) {
      if (content) content.innerHTML = '<div class="alert alert-danger mb-0">' + escapeHtml(error.message || 'Unable to load department summary.') + '</div>';
    }
  }

  function renderHubTimesheetManagementSummary(payload) {
    const content = document.getElementById('hubTimesheetManagementSummaryContent');
    if (!content) return;
    const rows = Array.isArray(payload.rows)
      ? payload.rows
      : (Array.isArray(payload.departments) ? payload.departments : []);
    const totals = payload.totals || {};
    const roleTotals = Array.isArray(payload.roleTotals) ? payload.roleTotals : [];
    const warnings = Array.isArray(payload.payrollWarnings) ? payload.payrollWarnings : [];
    if (!rows.length) {
      content.innerHTML = '<div class="hub-empty"><div><i class="bi bi-pie-chart display-6 d-block mb-3"></i><div class="fw-semibold">No department hours found.</div><div class="text-muted small mt-1">This timesheet has no effective hours for department grouping.</div></div></div>';
      return;
    }
    const warningHtml = warnings.length
