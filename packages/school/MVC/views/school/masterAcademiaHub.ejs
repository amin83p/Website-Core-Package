  function resolveHubStudentRecordId(item) {
    return String(item?.id || item?.studentId || '').trim();
  }

  function formatHubStudentRecordName(item, fallbackId) {
    return formatHubSchedulePersonName(item, fallbackId);
  }

  function mergeAcademicLedgerStudents(items) {
    (Array.isArray(items) ? items : [items]).forEach(function (item) {
      const id = resolveHubStudentRecordId(item);
      if (!id) return;
      const name = formatHubStudentRecordName(item, id);
      if (!workspaceState.academicLedgerStudents.some(function (row) { return row.id === id; })) {
        workspaceState.academicLedgerStudents.push({ id: id, name: name });
      }
    });
  }

  function renderAcademicLedgerStudentListHtml() {
    const students = workspaceState.academicLedgerStudents || [];
    if (!students.length) {
      return [
        '<div class="hub-empty">',
        '<div><i class="bi bi-person-lines-fill display-6 d-block mb-3"></i>',
        '<div class="fw-semibold">No students selected</div>',
        '<div class="text-muted small mt-1">Use Select Students to choose one or more students, then open their Academic Ledger overview.</div>',
        '</div></div>'
      ].join('');
    }
    const rows = students.map(function (student) {
      const href = '/school/academic-ledger/student-overview/' + encodeURIComponent(student.id);
      return [
        '<a href="' + escapeHtml(href) + '" target="_blank" rel="noopener noreferrer"',
        ' class="list-group-item list-group-item-action d-flex justify-content-between align-items-center hub-academic-ledger-student">',
        '<div><div class="fw-semibold">' + escapeHtml(student.name) + '</div>',
        '<div class="small text-muted font-monospace">' + escapeHtml(student.id) + '</div></div>',
        '<i class="bi bi-box-arrow-up-right text-primary"></i>',
