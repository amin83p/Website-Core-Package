<%
  // Build dynamic year options
  const yearOptions = availableYears.map(y => String(y));
  if (!yearOptions.includes(selectedYear)) yearOptions.unshift(selectedYear);
%>

<%- include('partials/tablePages-start', {
  title: title, 
  newUrl, 
  newLabel, 
  user,
  tableName,
  btn_export: true,
  print,
  headerManageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>',
    '<a href="/dashboard/section-nav/SCHOOL_ACCOUNTING" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-calculator me-1"></i> Accounting Dashboard</a>'
  ],
  manageBtns: [
  ]
}) %>

<div class="d-flex align-items-end flex-wrap gap-3 mb-4 p-3 bg-light border rounded shadow-sm">
    
    <div>
        <label for="topYearFilter" class="form-label fw-bold small mb-1"><i class="bi bi-calendar me-1"></i> Period Year</label>
        <select id="topYearFilter" class="form-select border-secondary shadow-sm" style="min-width: 120px;" onchange="filterTimesheets()">
            <% yearOptions.forEach(y => { %>
                <option value="<%= y %>" <%= y === String(selectedYear) ? 'selected' : '' %>><%= y %></option>
            <% }); %>
        </select>
    </div>

    <% if (isAdmin) { %>
        <div style="min-width: 300px; max-width: 400px;">
            <label class="form-label fw-bold small mb-1 text-primary"><i class="bi bi-shield-lock me-1"></i> Admin View: Select Teacher</label>
            <div class="input-group shadow-sm">
                <input type="hidden" id="filter_teacherId" value="<%= String(targetTeacherId) === String(currentTeacherId) ? '' : targetTeacherId %>">
                <input type="text" id="filter_teacherName" class="form-control bg-white border-secondary" placeholder="Viewing My Timesheets" value="<%= String(targetTeacherId) === String(currentTeacherId) ? '' : selectedTeacherName %>" readonly>
                
                <% if (String(targetTeacherId) !== String(currentTeacherId)) { %>
                    <button type="button" class="btn btn-outline-danger border-secondary" title="Clear Filter" onclick="clearTeacherFilter()"><i class="bi bi-x-lg"></i></button>
                <% } %>
                
                <button type="button" class="btn btn-primary border-primary" id="btnPickTeacher" title="Select Teacher"><i class="bi bi-person-lines-fill"></i></button>
            </div>
        </div>
    <% } %>
</div>

<% if (isAdmin && String(targetTeacherId) !== String(currentTeacherId) && selectedTeacherName) { %>
    <div class="alert alert-primary d-flex align-items-center shadow-sm mb-4 border-primary">
        <i class="bi bi-person-badge fs-2 me-3 text-primary"></i>
        <div>
            <h6 class="mb-0 fw-bold text-dark">Admin Override Active</h6>
            <span class="small text-dark">You are currently viewing and managing timesheets for: <strong class="fs-6 text-primary"><%= selectedTeacherName %></strong></span>
        </div>
    </div>
<% } %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search periods...',
  fields: [
      { name: 'tsStatus', label: 'Timesheet Status', type: 'select', options: ['not_started', 'draft', 'submitted', 'processed'] }
  ]
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="draggable ps-4" data-column="name">Period Name</th>
        <th class="draggable" data-column="dates">Dates</th>
        <th class="draggable" data-column="deadline">Deadline</th>
        <th class="draggable text-center" data-column="myStatus">Target Status</th>
        <th class="draggable" data-column="totalHours">Total Hours</th>
        <th class="text-end pe-4">Action</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length === 0) { %>
         <tr><td colspan="6" class="text-center py-4 text-muted">No periods available for this filter.</td></tr>
      <% } %>
      
      <% data.forEach(p => { %>
        <tr>
          <td class="ps-4 fw-bold text-dark"><i class="bi bi-calendar-range me-2 text-muted"></i><%= p.name %></td>
          <td class="small text-muted"><%= p.startDate %> <i class="bi bi-arrow-right mx-1"></i> <%= p.endDate %></td>
          <td class="small fw-bold text-danger"><%= p.submissionDeadline %></td>
          <td class="text-center">
             <% 
               let badge = 'bg-secondary';
               if (p.tsStatus === 'draft') badge = 'bg-info text-dark';
               if (p.tsStatus === 'submitted') badge = 'bg-primary';
               if (p.tsStatus === 'processed') badge = 'bg-success';
             %>
             <span class="badge <%= badge %> px-2 py-1"><%= p.tsStatus.replace('_', ' ').toUpperCase() %></span>
          </td>
          <td class="fw-bold text-success"><%= p.totalHours || '0.00' %> Hrs</td>
          <td class="table-actions text-end pe-4">
             <% if (isAdmin && !targetTeacherId) { %>
                <button type="button" class="btn btn-sm btn-filled btn-edit" disabled title="Select a teacher first">
                  Select Teacher
                </button>
             <% } else { %>
                <a href="/school/timesheets/editor/<%= p.id %>?teacherId=<%= isAdmin ? targetTeacherId : '' %>" class="btn btn-sm btn-filled btn-edit">
                   <%= p.tsStatus === 'processed' ? 'View Paystub' : 'Open Timesheet' %>
                </a>
             <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/timesheets/my-timesheets" hidden></span>

<%- include('partials/pagination', { 
    pagination, 
    filters, 
    baseUrlPath: 'school/timesheets/my-timesheets' 
}) %>

<%- include('partials/tablePages-end') %>
<%- include('partials/modal_GenericPicker') %>

<script>
function filterTimesheets() {
    const year = document.getElementById('topYearFilter').value;
    const teacherId = document.getElementById('filter_teacherId') ? document.getElementById('filter_teacherId').value : '';
    
    const urlParams = new URLSearchParams(window.location.search);
    urlParams.set('year', year);
    urlParams.delete('orgId');
    
    if (teacherId) {
        urlParams.set('teacherId', teacherId);
    } else {
        urlParams.delete('teacherId');
    }
    
    urlParams.set('page', '1'); 
    window.location.search = urlParams.toString();
}

function clearTeacherFilter() {
    if(document.getElementById('filter_teacherId')) {
        document.getElementById('filter_teacherId').value = '';
        filterTimesheets();
    }
}

document.addEventListener('DOMContentLoaded', () => {
    const tBtn = document.getElementById('btnPickTeacher');
    if (tBtn) {
        tBtn.addEventListener('click', () => {
            GenericPicker.open(GenericPickerPresets.person({
                title: 'Select Teacher/Staff to View',
                apiEndpoint: '/school/timesheets/api/eligible-persons',
                placeholder: 'Search teacher or staff...',
                onSelect: (item) => {
                    document.getElementById('filter_teacherId').value = item.id;
                    filterTimesheets(); 
                }
            }));
        });
    }
});
</script>
