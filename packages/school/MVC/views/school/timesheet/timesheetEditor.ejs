    } else if (btnReopenTimesheet) {
        btnReopenTimesheet.addEventListener('click', () => executeAdminTimesheetAction('return', {
            title: 'Send Back for Revision',
            message: 'Return this submitted timesheet to Draft for author revision?',
            confirmText: 'Send Back',
            successTitle: 'Timesheet Returned'
        }));
