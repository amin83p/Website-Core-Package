<% 
  const currentTimesheetStatus = String(timesheet.status || 'draft').toLowerCase() === 'approved' ? 'submitted' : String(timesheet.status || 'draft').toLowerCase();
  const reviewerCanEdit = typeof canReviewerEdit !== 'undefined' && canReviewerEdit === true;
  const adminCanApprove = typeof canManagerApprove !== 'undefined' ? canManagerApprove : Boolean(typeof canAdminApprove !== 'undefined' && canAdminApprove);
  const adminCanReopen = typeof canSendBack !== 'undefined' ? canSendBack : Boolean(typeof canAdminReopen !== 'undefined' && canAdminReopen);
  const financeCanProcess = typeof canFinanceProcess !== 'undefined' && canFinanceProcess === true;
  const managerReviewApproved = typeof managerApproved !== 'undefined' ? managerApproved === true : String(timesheet?.managerReview?.status || '').toLowerCase() === 'approved';
  const isReviewerEditing = reviewerCanEdit && currentTimesheetStatus === 'submitted';
  const pageIsReadOnly = currentTimesheetStatus === 'processed' || period.status === 'processed' || (currentTimesheetStatus === 'submitted' && !reviewerCanEdit);
  const isEditorLocked = pageIsReadOnly;
  const isManuallyEdited = timesheet.entries && timesheet.entries.some(e => e.isManual || e.isDeleted);
%>

<%
  const deadlineDate = period && period.submissionDeadline ? String(period.submissionDeadline) : '-';
  const deadlineTime = period && period.submissionDeadlineTime ? String(period.submissionDeadlineTime) : '23:59';
  const deadlineLabel = deadlineDate === '-' ? '-' : `${deadlineDate} ${deadlineTime}`;
  const personDisplayName = typeof personName !== 'undefined' ? String(personName || '').trim() : '';
  const timesheetStatus = currentTimesheetStatus;
  const viewingOther = typeof viewingOtherPerson !== 'undefined' && viewingOtherPerson;
%>

<style>
    /* IMPORTANT:
       Bootstrap applies background on td/th, not tr. So we style tr > * and set BS vars. */

    /* Alternating background per calendar day */
    .bg-day-0 > * { --bs-table-bg: #ffffff !important; --bs-table-accent-bg: #ffffff !important; background-color: #ffffff !important; }
    .bg-day-1 > * { --bs-table-bg: #eef2f7 !important; --bs-table-accent-bg: #eef2f7 !important; background-color: #eef2f7 !important; }

    /* Holiday & weekend (Sat/Sun) — light danger */
    .bg-holiday > * { 
        --bs-table-bg: #f8d7da !important;
        --bs-table-accent-bg: #f8d7da !important;
        background-color: #f8d7da !important;
    }

    .row-hover:hover > * { 
        --bs-table-bg: rgba(0,0,0,0.03) !important;
        --bs-table-accent-bg: rgba(0,0,0,0.03) !important;
        background-color: rgba(0,0,0,0.03) !important;
    }

    .row-prior-adjustment > * {
        --bs-table-bg: #fff3cd !important;
        --bs-table-accent-bg: #fff3cd !important;
        background-color: #fff3cd !important;
    }
    .row-prior-adjustment:hover > * {
        --bs-table-bg: #ffe8a1 !important;
        --bs-table-accent-bg: #ffe8a1 !important;
        background-color: #ffe8a1 !important;
    }

  .incomplete-sessions-table thead th {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .incomplete-sessions-table tbody tr.incomplete-row-day-0 > * { --bs-table-bg: #ffffff; background-color: #ffffff !important; }
  .incomplete-sessions-table tbody tr.incomplete-row-day-1 > * { --bs-table-bg: #eef2f7; background-color: #eef2f7 !important; }
  .incomplete-sessions-table tbody tr.incomplete-row-holiday > * {
    --bs-table-bg: #f8d7da;
    background-color: #f8d7da !important;
  }
  #incompleteSessionsToggle .incomplete-sessions-chevron {
    transition: transform 0.2s ease;
  }
  #incompleteSessionsToggle.collapsed .incomplete-sessions-chevron,
  #incompleteSessionsToggle[aria-expanded="false"] .incomplete-sessions-chevron {
    transform: rotate(-90deg);
  }

  .ts-page-header {
    text-align: left;
  }
  .ts-page-header__main {
    min-width: 0;
    text-align: left;
  }
  .ts-page-header .page-heading {
    text-align: left;
    margin-bottom: 0.25rem;
  }
  .ts-period-name {
    font-size: 1.35rem;
    font-weight: 600;
    line-height: 1.3;
    color: #212529;
  }
  .ts-person-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: #0d6efd;
  }
  .ts-meta-line {
    line-height: 1.5;
  }
  #tsTable thead th {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    border-bottom-width: 2px;
  }
  #tsTable tbody td {
    padding-top: 0.65rem;
    padding-bottom: 0.65rem;
    vertical-align: middle;
  }
  .ts-date-label {
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    color: #212529;
  }
  .ts-day-name {
    font-size: 0.85rem;
    font-weight: 500;
    line-height: 1.25;
    margin-top: 0.1rem;
    color: #6c757d;
  }
  .ts-time-label {
    font-size: 0.95rem;
    font-weight: 500;
  }
  .ts-day-add-row > * {
    border-top: 1px dashed rgba(13, 110, 253, 0.25) !important;
    background-color: rgba(13, 110, 253, 0.03) !important;
  }
  .ts-comment-trigger {
    min-height: 31px;
    white-space: normal;
    word-break: break-word;
  }
  .ts-comment-trigger:hover {
    background-color: #f8f9fa !important;
  }
  #tsDepartmentTotals .table {
    margin-bottom: 0;
  }
</style>

<div class="sections-page">
    <div class="d-flex align-items-start justify-content-between mb-4 ts-page-header">
        <div class="ts-page-header__main">
            <h1 class="page-heading size-md text-start m-0 mb-1"><i class="bi bi-calendar2-week me-2"></i>Timesheet</h1>
            <div class="ts-period-name"><%= period.name %></div>
            <div class="d-flex flex-wrap align-items-center gap-2 mt-2 mb-2">
                <% if (personDisplayName) { %>
                    <span class="ts-person-name"><%= personDisplayName %></span>
                <% } %>
                <span class="badge bg-<%= timesheetStatus === 'submitted' ? 'warning text-dark' : (timesheetStatus === 'processed' ? 'primary' : 'secondary') %> text-uppercase"><%= timesheetStatus %></span>
                <% if (timesheetStatus === 'submitted' && managerReviewApproved) { %>
                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Manager Approved</span>
                <% } %>
                <% if (timesheetStatus === 'draft' && timesheet.returnReason) { %>
                    <span class="badge bg-warning text-dark"><i class="bi bi-reply-fill me-1"></i>Returned for Revision</span>
                <% } %>
                <span id="badge_manualEdit" class="badge bg-warning text-dark shadow-sm <%= isManuallyEdited ? '' : 'd-none' %>">
                    <i class="bi bi-pencil-square me-1"></i> Manually Edited
                </span>
            </div>
            <div class="ts-meta-line text-muted small">
                <strong>Period:</strong> <%= period.startDate %> to <%= period.endDate %>
                <span class="mx-1">|</span>
                <strong>Deadline:</strong> <span class="text-danger fw-bold"><%= deadlineLabel %></span>
                <% if (viewingOther) { %>
                    <span class="mx-1">|</span>
                    <span class="text-info fw-semibold"><i class="bi bi-person-badge me-1"></i>Viewing another person's timesheet</span>
                <% } %>
            </div>
        </div>
        <a href="/school/timesheets/my-timesheets" class="btn btn-outline-secondary btn-sm flex-shrink-0"><i class="bi bi-arrow-left"></i> Back</a>
    </div>

    <% if (pageIsReadOnly) { %>
        <div class="alert alert-success border-success shadow-sm d-flex align-items-center mb-4">
            <i class="bi bi-check-circle-fill fs-3 me-3 text-success"></i>
            <div>
                <h6 class="fw-bold mb-1">Timesheet Locked</h6>
                <div class="small">This timesheet is currently marked as <strong><%= timesheet.status.toUpperCase() %></strong> and cannot be modified.</div>
            </div>
        </div>
    <% } else { %>
        <div class="alert alert-info border-info shadow-sm d-flex justify-content-between align-items-center mb-4">
            <div>
                <strong>Instructions:</strong> Review auto-pulled sessions or add manual entries if required.
                <div class="text-danger fw-bold small mt-1">All auto-pulled sessions must be in a final status before submission.</div>
            </div>
        </div>
    <% } %>

    <% if (timesheetStatus === 'draft' && timesheet.returnReason) { %>
        <div class="alert alert-warning border-warning shadow-sm mb-4">
            <div class="fw-bold mb-1"><i class="bi bi-reply-fill me-1"></i> Returned for Revision</div>
            <div class="small"><%= timesheet.returnReason %></div>
        </div>
    <% } %>

    <% if (typeof payrollWarnings !== 'undefined' && Array.isArray(payrollWarnings) && payrollWarnings.length) { %>
        <div class="alert alert-warning border-warning shadow-sm mb-4">
            <div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle-fill me-1"></i> Payroll setup warnings</div>
            <ul class="small mb-0 ps-3">
                <% payrollWarnings.forEach((warning) => { %>
                    <li><%= warning %></li>
                <% }); %>
            </ul>
        </div>
    <% } %>

    <% const reviewHistoryRows = Array.isArray(reviewHistory) ? reviewHistory : []; %>
    <% if (reviewHistoryRows.length) { %>
        <div class="card border-0 shadow-sm mb-4" id="timesheetReviewHistoryPanel">
            <div class="card-header bg-light border-bottom py-3">
                <div class="fw-bold"><i class="bi bi-clock-history me-2 text-primary"></i>Review History</div>
                <div class="small text-muted">Submission and approval cycles for this timesheet.</div>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">When</th>
                                <th>Event</th>
                                <th>By</th>
                                <th>Status</th>
                                <th class="text-end">Hours</th>
                                <th class="pe-4">Note</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% reviewHistoryRows.slice().reverse().forEach((row) => { %>
                                <tr>
                                    <td class="ps-4 small text-muted"><%= row.at ? (typeof formatOrgDateTime === 'function' ? formatOrgDateTime(row.at) : row.at) : '-' %></td>
                                    <td><span class="badge bg-light text-dark border text-uppercase"><%= row.event || '-' %></span></td>
                                    <td class="small"><%= row.byName || row.by || '-' %></td>
                                    <td class="small text-muted"><%= row.statusBefore ? row.statusBefore + ' → ' + (row.statusAfter || '-') : (row.statusAfter || '-') %></td>
                                    <td class="text-end small fw-semibold"><%= Number(row.totalHours || 0).toFixed(2) %></td>
                                    <td class="pe-4 small"><%= row.note || '-' %></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    <% } %>

    <div id="incompleteSessionsPanel" class="card border-warning shadow-sm mb-4 d-none">
        <button type="button" class="card-header bg-warning-subtle border-warning d-flex align-items-center justify-content-between py-3 w-100 text-start collapsed" data-bs-toggle="collapse" data-bs-target="#incompleteSessionsCollapse" aria-expanded="false" aria-controls="incompleteSessionsCollapse" id="incompleteSessionsToggle">
            <div class="fw-bold text-warning-emphasis">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Incomplete Sessions Detected
                <span class="badge bg-warning text-dark ms-2" id="incompleteSessionsCount">0</span>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="small text-muted d-none d-md-inline">Expand to review class and activity work sessions, then refresh this timesheet.</span>
                <i class="bi bi-chevron-down incomplete-sessions-chevron" aria-hidden="true"></i>
            </div>
        </button>
        <div id="incompleteSessionsCollapse" class="collapse">
            <div class="card-body p-0 border-top border-warning">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle mb-0 incomplete-sessions-table">
                        <thead class="table-warning">
                            <tr>
                                <th class="ps-4" style="width: 140px;">Date</th>
                                <th>Class / Activity</th>
                                <th style="width: 160px;">Time</th>
                                <th style="width: 150px;">Status</th>
                                <th class="text-center pe-4" style="width: 170px;">Action</th>
                            </tr>
                        </thead>
                        <tbody id="incompleteSessionsBody"></tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered align-middle mb-0" id="tsTable">
                    <thead class="table-light border-bottom">
                        <tr>
                            <th class="ps-4" style="width: 140px;">Date</th>
                            <th>Class / Description</th>
                            <th style="width: 160px;">Student Name</th>
                            <th>Time</th>
                            <th style="width: 120px;">Status</th>
                            <th>Comment</th>
                            <th class="text-end" style="width: 90px;">Hours</th>
                            <% if (!isEditorLocked) { %><th class="text-center" style="width: 90px;">Act</th><% } %>
                        </tr>
                    </thead>
                    <tbody id="tsBody">
                    </tbody>
                    <tfoot class="table-light border-top border-3">
                        <tr>
                            <td colspan="6" class="text-end fw-bold text-uppercase">Total Period Hours:</td>
                            <td class="text-end pe-4 fw-bold text-success fs-5" id="lbl_grandTotal">0.00</td>
                            <% if (!isEditorLocked) { %><td></td><% } %>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4" id="tsDepartmentTotals">
        <div class="card-header bg-light border-bottom py-3">
            <div class="fw-bold"><i class="bi bi-diagram-3 me-2 text-primary"></i>Hours by Department</div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Department</th>
                            <th class="text-end pe-4" style="width: 140px;">Hours</th>
                        </tr>
                    </thead>
                    <tbody id="tsDepartmentTotalsBody">
                        <tr>
                            <td colspan="2" class="text-center text-muted py-3">No payable hours yet.</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <% if (!isEditorLocked || adminCanApprove || adminCanReopen || financeCanProcess) { %>
        <div class="d-flex justify-content-end gap-2 border-top pt-3">
            <% if (!isEditorLocked) { %>
                <button class="btn btn-light border fw-bold px-4" id="btnSaveDraft"><%= isReviewerEditing ? 'Save Review Changes' : 'Save Draft' %></button>
                <% if (!isReviewerEditing) { %><button class="btn btn-primary fw-bold px-4" id="btnSubmit">Submit for Payroll</button><% } %>
            <% } %>
            <% if (adminCanApprove) { %>
                <button class="btn btn-success fw-bold px-4" id="btnApproveTimesheet"><i class="bi bi-check-circle me-1"></i> Manager Approve</button>
            <% } %>
            <% if (adminCanReopen) { %>
                <button class="btn btn-warning fw-bold px-4" id="btnReopenTimesheet"><i class="bi bi-reply-fill me-1"></i> Send Back for Revision</button>
            <% } %>
            <% if (financeCanProcess) { %>
                <button class="btn btn-primary fw-bold px-4" id="btnProcessTimesheet"><i class="bi bi-lock-fill me-1"></i> Process Timesheet</button>
            <% } %>
        </div>
    <% } %>
</div>

<div class="modal fade" id="manualEntryModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-light">
        <h5 class="modal-title fw-bold" id="modalTitle"><i class="bi bi-plus-circle me-2 text-primary"></i>Add Manual Entry</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
          <input type="hidden" id="man_date">
          <input type="hidden" id="man_editSessionId">
          
          <div class="mb-3">
              <label class="form-label fw-bold small text-muted">Selected Date</label>
              <div class="d-flex align-items-stretch gap-2">
                  <div id="man_date_display" class="form-control bg-light fw-bold flex-grow-1"></div>
                  <button type="button" class="btn btn-outline-primary text-nowrap" id="btnViewDaySchedule" title="Open schedule for this day in a new tab">
                      <i class="bi bi-calendar-week"></i><span class="d-none d-sm-inline ms-1">View Day</span>
                  </button>
              </div>
          </div>
          
          <div class="mb-3">
              <label class="form-label fw-bold">Activity Type *</label>
              <select id="man_type" class="form-select" onchange="toggleManualType()">
                  <option value="">Class-based entry</option>
                  <% (manualActivities || []).forEach((activity) => { %>
                    <option
                      value="<%= activity.id || '' %>"
                      data-name="<%= activity.name || activity.id || '' %>"
                      data-paid="<%= activity.paid ? 'true' : 'false' %>"
                      data-category="<%= activity.categoryName || '' %>"
                      data-department="<%= activity.departmentName || '' %>">
                      <%= activity.name || activity.id || 'Activity' %>
                    </option>
                  <% }) %>
              </select>
              <div class="form-text">Select an activity definition, or leave blank for class-based entry.</div>
          </div>

          <div class="mb-3 <%= (typeof payrollRoles !== 'undefined' && payrollRoles.length > 1) ? '' : 'd-none' %>" id="div_man_payrollRole">
              <label class="form-label fw-bold">Payroll Role *</label>
              <select id="man_personRole" class="form-select">
                  <% (payrollRoles || []).forEach((role) => { %>
                    <option value="<%= role %>"><%= String(role).charAt(0).toUpperCase() + String(role).slice(1) %></option>
                  <% }) %>
              </select>
              <div class="form-text">Choose whether this work should be paid under your teacher or staff profile.</div>
          </div>

          <div class="mb-3" id="div_man_classPicker">
              <label class="form-label fw-bold">Select Class *</label>
              <div class="input-group">
                  <input type="hidden" id="man_classId">
                  <input type="text" id="man_className" class="form-control bg-white" placeholder="Choose a class..." readonly>
                  <button type="button" class="btn btn-outline-primary" id="btnPickClass"><i class="bi bi-search"></i></button>
              </div>
          </div>
          
          <div class="mb-3" id="div_man_desc">
              <label class="form-label fw-bold">Description *</label>
              <input type="text" id="man_desc" class="form-control" placeholder="e.g. Extra prep, admin work, meeting...">
          </div>

          <div class="row g-2 mb-3" id="div_man_timeRange">
              <div class="col-6">
                  <label class="form-label fw-bold">Start Time *</label>
                  <input type="time" id="man_startTime" class="form-control">
              </div>
              <div class="col-6">
                  <label class="form-label fw-bold">End Time *</label>
                  <input type="time" id="man_endTime" class="form-control">
              </div>
              <div class="col-12">
                  <div class="form-text">For class or activity rows, total hours are calculated from start/end time and applied to the materialized session.</div>
              </div>
          </div>

          <div class="mb-3">
              <label class="form-label fw-bold">Total Hours *</label>
              <input type="number" id="man_hours" class="form-control" step="0.25" min="0" max="<%= maxSessionHours %>" placeholder="e.g. 1.5" required>
              <div class="form-text text-danger" id="man_hours_warning"></div>
          </div>
          
          <div class="mb-3">
              <label class="form-label fw-bold">Notes / Comments</label>
              <input type="text" id="man_comment" class="form-control" placeholder="Reason for manual entry...">
          </div>
      </div>
      <div class="modal-footer bg-light border-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary fw-bold" id="btnSaveManualEntry">Save Entry</button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/modal_GenericPicker') %>

<div class="modal fade" id="reopenTimesheetModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
  <div class="modal-dialog">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-warning-subtle border-0">
        <h5 class="modal-title fw-bold"><i class="bi bi-reply-fill me-2"></i>Send Back for Revision</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="small text-muted mb-3">The timesheet will return to <strong>Draft</strong> so the author can edit and submit it again. The note will be shown to the author.</p>
        <label class="form-label fw-bold" for="reopenTimesheetNote">Revision instructions *</label>
        <textarea id="reopenTimesheetNote" class="form-control" rows="4" maxlength="2000" placeholder="Explain what the person should change before resubmitting..." required></textarea>
        <div class="form-text">This note is stored in the review history.</div>
      </div>
      <div class="modal-footer bg-light border-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-warning fw-bold" id="btnConfirmReopenTimesheet">Send Back to Draft</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="manualRowRejectModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
  <div class="modal-dialog">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-danger-subtle border-0">
        <h5 class="modal-title fw-bold"><i class="bi bi-x-circle me-2"></i>Reject Manual Row</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="manualRowRejectEntryId">
        <label class="form-label fw-bold" for="manualRowRejectNote">Rejection reason *</label>
        <textarea id="manualRowRejectNote" class="form-control" rows="4" maxlength="2000" placeholder="Explain why this paid manual row was rejected..." required></textarea>
      </div>
      <div class="modal-footer bg-light border-0">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger fw-bold" id="btnConfirmManualRowReject">Reject Row</button>
      </div>
    </div>
  </div>
</div>

<div class="modal" id="timesheetCommentModal" tabindex="-1" aria-hidden="true" data-bs-focus="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-light border-0">
        <h5 class="modal-title fw-bold"><i class="bi bi-chat-left-text me-2 text-primary"></i>Session Comment</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="small text-muted mb-2" id="timesheetCommentContext"></div>
        <textarea id="timesheetCommentInput" class="form-control" rows="5" maxlength="2000" placeholder="Add notes for this session row..."></textarea>
        <div class="form-text mb-0">Your comment is saved automatically when you close this window.</div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="priorAdjustmentModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-warning-subtle border-0">
        <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Review Prior Period Adjustments</h5>
      </div>
      <div class="modal-body">
        <p class="mb-2" id="priorAdjustmentIntro">
          Please review your last submitted timesheet before continuing with this period.
        </p>
        <div class="alert alert-light border mb-3 d-none" id="priorAdjustmentSummary"></div>
        <div class="table-responsive" id="priorAdjustmentTableWrap">
          <table class="table table-bordered table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Session Date</th>
                <th>Class / Description</th>
                <th>Change</th>
                <th class="text-end">Paid Hrs</th>
                <th class="text-end">Current Hrs</th>
                <th class="text-end">Adjustment</th>
              </tr>
            </thead>
            <tbody id="priorAdjustmentTableBody"></tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer bg-light border-0">
        <button type="button" class="btn btn-outline-secondary" id="btnPriorAdjustmentLater">Review Later</button>
        <button type="button" class="btn btn-warning fw-bold d-none" id="btnPriorAdjustmentApply">Apply Adjustments</button>
        <button type="button" class="btn btn-primary fw-bold d-none" id="btnPriorAdjustmentContinue">Continue to Timesheet</button>
      </div>
    </div>
  </div>
</div>

<script>
    const P_START = "<%= period.startDate %>";
    const P_END = "<%= period.endDate %>";
    const ORG_TIMEZONE = <%- JSON.stringify(typeof orgTimeZone !== 'undefined' ? orgTimeZone : '') %>;
    const ORG_TODAY = <%- JSON.stringify(typeof orgToday !== 'undefined' ? orgToday : '') %>;
    const LIVE_SESSIONS = <%- JSON.stringify(liveSessions || []) %>;
    const HOLIDAYS = <%- JSON.stringify(holidays || []) %>;
    const TIMESHEET_ENTRIES = <%- JSON.stringify(timesheet.entries || []) %>;
    const SNAPSHOT_ENTRIES = <%- JSON.stringify((timesheet.submissionSnapshot && timesheet.submissionSnapshot.entries) || []) %>;
    const USE_FROZEN_SNAPSHOT = <%= (typeof useFrozenSnapshot !== 'undefined' && useFrozenSnapshot) ? 'true' : 'false' %>;
    const MANUAL_ACTIVITIES = <%- JSON.stringify(manualActivities || []) %>;
    const INCOMPLETE_SESSIONS = <%- JSON.stringify(incompleteSessions || []) %>;
    const SESSION_STATUS_META = <%- JSON.stringify(sessionStatusMeta || []) %>;
    const IS_READONLY = <%= isEditorLocked %>;
    const IS_ADMIN = <%= isAdmin %>;
    const CAN_MANAGER_REVIEW = <%= (typeof canSendBack !== 'undefined' && canSendBack) ? 'true' : 'false' %>;
    const SHOW_PRIOR_ADJUSTMENT_REVIEW = <%= showPriorAdjustmentReview ? 'true' : 'false' %>;
    const PERIOD_ID = "<%= period.id %>";
    const TARGET_TEACHER_ID = "<%= targetTeacherId %>";
    const MAX_DAILY_HOURS = <%= maxDailyHours || 24 %>;
    const MAX_SESSION_HOURS = <%= maxSessionHours || 12 %>;
    const PAYROLL_ROLES = <%- JSON.stringify(typeof payrollRoles !== 'undefined' ? payrollRoles : []) %>;
    const PAYROLL_DEFAULT_ROLE = "<%= typeof payrollDefaultRole !== 'undefined' ? payrollDefaultRole : 'teacher' %>";
    const PAYROLL_WARNINGS = <%- JSON.stringify(typeof payrollWarnings !== 'undefined' ? payrollWarnings : []) %>;
    let actionStateId = '<%= (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '' %>';

    function buildMutationQuery() {
        const params = new URLSearchParams();
        if (TARGET_TEACHER_ID) params.set('teacherId', TARGET_TEACHER_ID);
        if (actionStateId) params.set('actionStateId', actionStateId);
        const query = params.toString();
        return query ? `?${query}` : '';
    }

    function buildManualEntryScheduleUrl(dateStr) {
        const date = String(dateStr || '').trim();
        if (!/^\d{4}-\d{2}-\d{2}$/.test(date)) return '';
        if (IS_ADMIN && TARGET_TEACHER_ID) {
            const params = new URLSearchParams();
            params.set('personId', TARGET_TEACHER_ID);
            params.set('startDate', date);
            params.set('endDate', date);
            return `/school/schedules/viewer?${params.toString()}`;
        }
        const params = new URLSearchParams();
        params.set('anchorDate', date);
        params.set('period', 'day');
        return `/school/schedules/my?${params.toString()}`;
    }
</script>

<script>
function toggleManualType() {
    const type = document.getElementById('man_type').value;
    const classPickerWrap = document.getElementById('div_man_classPicker');
    const classIdInput = document.getElementById('man_classId');
    const classNameInput = document.getElementById('man_className');
    const classButton = document.getElementById('btnPickClass');
    const startInput = document.getElementById('man_startTime');
    const endInput = document.getElementById('man_endTime');
    const hoursInput = document.getElementById('man_hours');
    const usingActivity = Boolean(String(type || '').trim());
    document.getElementById('div_man_desc').classList.remove('d-none');
    classPickerWrap.classList.toggle('opacity-50', usingActivity);
    if (classNameInput) {
        classNameInput.disabled = usingActivity;
        classNameInput.placeholder = usingActivity ? 'Disabled for activity-based entry' : 'Choose a class...';
    }
    if (classButton) classButton.disabled = usingActivity;
    if (startInput) startInput.disabled = false;
    if (endInput) endInput.disabled = false;
    const classId = String(classIdInput?.value || '').trim();
    const usesTimedEntry = usingActivity || Boolean(classId);
    if (hoursInput) {
        hoursInput.readOnly = usesTimedEntry;
        hoursInput.placeholder = usesTimedEntry ? 'Calculated from start/end time' : 'e.g. 1.5';
    }
    if (usingActivity) {
        if (classIdInput) classIdInput.value = '';
        if (classNameInput) classNameInput.value = '';
    }
    if (typeof window.updateManualComputedHoursFromTimes === 'function') {
        window.updateManualComputedHoursFromTimes();
    }
}

document.addEventListener('DOMContentLoaded', () => {

    // Prefer MessageModal; fallback only if modal isn't present
    async function confirmAction({ title, message, confirmText = 'Confirm', cancelText = 'Cancel', icon = 'warning', confirmBtnClass = 'btn-danger' }) {
        if (typeof showMessageModal === 'function') {
            const ans = await showMessageModal({
                title,
                icon,
                message,
                buttons: [
                    { text: cancelText, class: 'btn-secondary' },
                    { text: confirmText, class: confirmBtnClass }
                ]
            });
            return ans === confirmText;
        }
        return confirm(message);
    }

    async function messageBox({ title, message, icon = 'info', okText = 'OK', okClass = 'btn-secondary' }) {
        if (typeof showMessageModal === 'function') {
            await showMessageModal({
                title,
                icon,
                message,
                buttons: [{ text: okText, class: okClass }]
            });
            return;
        }
        alert(message);
    }

    function showTimesheetWaitingModal({
        title = 'Please wait',
        note = 'Processing your request...',
        operation = ''
    } = {}) {
        if (typeof window.showLoading !== 'function') return null;
        return window.showLoading({ title, note, operation });
    }

    function hideTimesheetWaitingModal(token = null) {
        if (typeof window.hideLoading !== 'function') return;
        if (token) {
            window.hideLoading(token);
            return;
        }
        window.hideLoading();
    }

    function setManualSaveBusy(isBusy) {
        const manualSaveBtn = document.getElementById('btnSaveManualEntry');
        if (!manualSaveBtn) return;
        manualSaveBtn.disabled = isBusy === true;
    }

    function resolveManualPersonRole() {
        if (!Array.isArray(PAYROLL_ROLES) || PAYROLL_ROLES.length <= 1) {
            return PAYROLL_DEFAULT_ROLE || 'teacher';
        }
        const selected = String(document.getElementById('man_personRole')?.value || '').trim().toLowerCase();
        return PAYROLL_ROLES.includes(selected) ? selected : '';
    }

    function payrollRoleBadge(personRole) {
        if (!Array.isArray(PAYROLL_ROLES) || PAYROLL_ROLES.length <= 1) return '';
        const role = String(personRole || PAYROLL_DEFAULT_ROLE || 'teacher').trim().toLowerCase();
        const klass = role === 'staff' ? 'bg-success' : 'bg-primary';
        const label = role ? role.charAt(0).toUpperCase() + role.slice(1) : 'Role';
        return `<span class="badge ${klass} ms-1">${label}</span>`;
    }

    const manualActivityMap = new Map((Array.isArray(MANUAL_ACTIVITIES) ? MANUAL_ACTIVITIES : [])
        .map((row) => [String(row?.id || '').trim(), row])
        .filter(([id]) => Boolean(id)));

    function normalizeClock(value) {
        const raw = String(value || '').trim();
        const match = raw.match(/^(\d{1,2}):(\d{2})$/);
        if (!match) return '';
        const h = Number(match[1]);
        const m = Number(match[2]);
        if (!Number.isInteger(h) || !Number.isInteger(m) || h < 0 || h > 23 || m < 0 || m > 59) return '';
        return `${String(h).padStart(2, '0')}:${String(m).padStart(2, '0')}`;
    }

    function calculateHoursFromRange(startTime, endTime) {
        const start = normalizeClock(startTime);
        const end = normalizeClock(endTime);
        if (!start || !end) return 0;
        const [startH, startM] = start.split(':').map(Number);
        const [endH, endM] = end.split(':').map(Number);
        const startMinutes = (startH * 60) + startM;
        const endMinutes = (endH * 60) + endM;
        if (endMinutes <= startMinutes) return 0;
        return Number(((endMinutes - startMinutes) / 60).toFixed(2));
    }

    function hasTimeOverlap(startA, endA, startB, endB) {
        const aStart = normalizeClock(startA);
        const aEnd = normalizeClock(endA);
        const bStart = normalizeClock(startB);
        const bEnd = normalizeClock(endB);
        if (!aStart || !aEnd || !bStart || !bEnd) return false;
        const [ash, asm] = aStart.split(':').map(Number);
        const [aeh, aem] = aEnd.split(':').map(Number);
        const [bsh, bsm] = bStart.split(':').map(Number);
        const [beh, bem] = bEnd.split(':').map(Number);
        const aStartMin = (ash * 60) + asm;
        const aEndMin = (aeh * 60) + aem;
        const bStartMin = (bsh * 60) + bsm;
        const bEndMin = (beh * 60) + bem;
        if (aEndMin <= aStartMin || bEndMin <= bStartMin) return false;
        return aStartMin < bEndMin && aEndMin > bStartMin;
    }

    // Normalize holidays into Map(dateStr -> holidayObj)
    function toYMD(value) {
        if (!value) return null;
        if (typeof value === 'string') {
            if (/^\d{4}-\d{2}-\d{2}$/.test(value)) return value;
            const d = new Date(value);
            if (!isNaN(d)) return d.toISOString().slice(0, 10);
            return null;
        }
        const d = new Date(value);
        if (!isNaN(d)) return d.toISOString().slice(0, 10);
        return null;
    }

    const holidayMap = new Map();
    (HOLIDAYS || []).forEach(h => {
        const dt =
            toYMD(h.date) ||
            toYMD(h.holidayDate) ||
            toYMD(h.startDate) ||
            toYMD(h.day) ||
            toYMD(h.dt) ||
            null;
        if (dt) holidayMap.set(dt, h);
    });

    const normalizeStatusCode = (value) => String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '') || 'scheduled';
    const statusMetaMap = new Map(
        (Array.isArray(SESSION_STATUS_META) ? SESSION_STATUS_META : [])
            .map((row) => [normalizeStatusCode(row?.code), row])
            .filter(([code]) => Boolean(code))
    );
    const resolveStatusMeta = (statusCode) => statusMetaMap.get(normalizeStatusCode(statusCode)) || null;
    const resolveStatusLabel = (statusCode) => {
        const normalized = normalizeStatusCode(statusCode);
        const meta = resolveStatusMeta(normalized);
        if (meta?.label) return String(meta.label);
        return normalized.replace(/_/g, ' ').replace(/\b\w/g, (ch) => ch.toUpperCase());
    };
    const resolveEntryHours = (entry) => {
        if (!entry || entry.isDeleted) return 0;
        const approvalStatus = String(entry.approvalStatus || '').trim().toLowerCase();
        const excluded = entry.excludeFromTotals === true || ['pending_approval', 'rejected', 'unpaid'].includes(approvalStatus);
        if (excluded) return 0;
        if (entry.isManual) return Number(parseFloat(entry.durationHours) || parseFloat(entry.hours) || 0);
        const formulaHours = Number(entry.timesheetHours);
        if (Number.isFinite(formulaHours)) return Number(formulaHours.toFixed(2));
        return Number(parseFloat(entry.durationHours) || parseFloat(entry.hours) || 0);
    };
    const resolveRequestedHours = (entry) => {
        if (!entry || entry.isDeleted) return 0;
        if (entry.isManual) {
            return Number(parseFloat(entry.requestedHours ?? entry.durationHours ?? entry.hours) || 0);
        }
        return resolveEntryHours(entry);
    };
    const isPendingApprovalEntry = (entry) => String(entry?.approvalStatus || '').trim().toLowerCase() === 'pending_approval';
    const isRejectedApprovalEntry = (entry) => String(entry?.approvalStatus || '').trim().toLowerCase() === 'rejected';
    const isUnpaidApprovalEntry = (entry) => String(entry?.approvalStatus || '').trim().toLowerCase() === 'unpaid';
    const isFinalAutoStatus = (entry) => {
        if (!entry || entry.isManual) return true;
        if (entry.isPriorPeriodAdjustment === true) return true;
        if (entry.isReportReflection === true) return true;
        if (entry.isSchoolActivity === true || String(entry?.sessionId || '').startsWith('act-')) return true;
        if (entry.isFinalStatus === true) return true;
        if (entry.isFinalStatus === false) return false;
        return normalizeStatusCode(entry.status) === 'completed';
    };
    const buildStatusBadgeHtml = (entry) => {
        if (entry?.isPriorPeriodAdjustment === true) {
            return `<span class="badge bg-warning text-dark border border-warning"><i class="bi bi-arrow-left-right me-1"></i> Prior Period Adjustment</span>`;
        }
        if (entry?.isManual) {
            if (isPendingApprovalEntry(entry)) {
                return `<span class="badge bg-warning text-dark border border-warning"><i class="bi bi-hourglass-split me-1"></i> Pending Approval</span>`;
            }
            if (isRejectedApprovalEntry(entry)) {
                return `<span class="badge bg-danger border border-danger"><i class="bi bi-x-circle me-1"></i> Rejected</span>`;
            }
            if (String(entry?.approvalStatus || '').toLowerCase() === 'approved' && entry?.activityPaid === true) {
                return `<span class="badge bg-success border border-success"><i class="bi bi-check-circle me-1"></i> Approved Manual Row</span>`;
            }
            if (entry?.activityId && entry?.activityPaid === false) {
                return `<span class="badge bg-secondary border"><i class="bi bi-slash-circle me-1"></i> Unpaid Activity</span>`;
            }
            return `<span class="badge bg-info text-dark border border-info"><i class="bi bi-person-fill me-1"></i> Manual</span>`;
        }
        if (entry?.isReportReflection === true) {
            return `<span class="badge bg-secondary border"><i class="bi bi-file-earmark-text me-1"></i> Report task</span>`;
        }
        const normalized = normalizeStatusCode(entry?.status);
        const statusMeta = resolveStatusMeta(normalized);
        const statusLabel = resolveStatusLabel(normalized);
        const colorBg = statusMeta?.colorBg || '#fff3cd';
        const colorText = statusMeta?.colorText || '#664d03';
        const colorBorder = statusMeta?.colorBorder || '#ffe69c';
        if (!isFinalAutoStatus(entry)) {
            return `<span class="badge border" style="background:${colorBg};color:${colorText};border-color:${colorBorder} !important;"><i class="bi bi-exclamation-triangle-fill me-1"></i>${statusLabel}</span>`;
        }
        return `<span class="badge border" style="background:${colorBg};color:${colorText};border-color:${colorBorder} !important;">${statusLabel}</span>`;
    };

    // Wire up Generic Picker for Classes
    const cBtn = document.getElementById('btnPickClass');
    if (cBtn) {
        cBtn.addEventListener('click', () => {
            GenericPicker.open(GenericPickerPresets.class({
                title: 'Select Class',
                icon: 'bi-journal-bookmark',
                apiEndpoint: '/school/timesheets/api/manual-entry-classes',
                onSelect: (item) => {
                    document.getElementById('man_classId').value = item.id;
                    document.getElementById('man_className').value = item.title || item.name || item.id;
                    toggleManualType();
                }
            }));
        });
    }
    const viewDayScheduleBtn = document.getElementById('btnViewDaySchedule');
    if (viewDayScheduleBtn) {
        viewDayScheduleBtn.addEventListener('click', () => {
            const dateStr = String(document.getElementById('man_date')?.value || '').trim();
            const url = buildManualEntryScheduleUrl(dateStr);
            if (!url) {
                messageBox({ title: 'Missing Date', icon: 'warning', message: 'Select a valid date before opening the schedule.' });
                return;
            }
            window.open(url, '_blank', 'noopener');
        });
    }
    const manualStartInput = document.getElementById('man_startTime');
    const manualEndInput = document.getElementById('man_endTime');
    if (manualStartInput) manualStartInput.addEventListener('change', () => window.updateManualComputedHoursFromTimes());
    if (manualEndInput) manualEndInput.addEventListener('change', () => window.updateManualComputedHoursFromTimes());

    const tbody = document.getElementById('tsBody');
    let grandTotalHours = 0;
    let hasUncompletedSessions = Array.isArray(INCOMPLETE_SESSIONS) && INCOMPLETE_SESSIONS.length > 0;
    let hasPendingApprovals = false;
    
    let activeEntries = []; 
    let deletedAutoSessionIds = [];
    let isEdited = <%= isManuallyEdited %>;

    const savedComments = {};
    TIMESHEET_ENTRIES.forEach(e => {
        if (e.isDeleted) {
            deletedAutoSessionIds.push(e.sessionId);
        } else if (e.isManual || e.isPriorPeriodAdjustment) {
            activeEntries.push(e);
        } else {
            savedComments[e.sessionId] = e.comment;
        }
    });

    if (USE_FROZEN_SNAPSHOT) {
        SNAPSHOT_ENTRIES.forEach(ls => {
            if (ls.isManual === true) return;
            if (!deletedAutoSessionIds.includes(ls.sessionId)) {
                activeEntries.push({
                    ...ls,
                    hours: ls.hours ?? ls.timesheetHours ?? ls.durationHours ?? 0,
                    comment: savedComments[ls.sessionId] || ls.comment || '',
                    isManual: false
                });
            }
        });
    } else {
        LIVE_SESSIONS.forEach(ls => {
            if (!deletedAutoSessionIds.includes(ls.sessionId)) {
                activeEntries.push({ ...ls, comment: savedComments[ls.sessionId] || '', isManual: false });
            }
        });
    }

    function getDatesInRange(startStr, endStr) {
        const dates = [];
        let curr = String(startStr || '').trim();
        const end = String(endStr || '').trim();
        while (curr && end && curr <= end) {
            dates.push(curr);
            const parts = curr.split('-').map((part) => Number(part));
            if (parts.length !== 3 || parts.some((part) => !Number.isFinite(part))) break;
            const next = new Date(parts[0], parts[1] - 1, parts[2] + 1);
            const year = next.getFullYear();
            const month = String(next.getMonth() + 1).padStart(2, '0');
            const day = String(next.getDate()).padStart(2, '0');
            curr = `${year}-${month}-${day}`;
        }
        return dates;
    }

    function formatTimesheetDateLabel(dateStr, options = { weekday: 'short', month: 'short', day: 'numeric' }) {
        const token = String(dateStr || '').trim();
        if (!token) return '';
        if (window.AppOrgDateTime && typeof window.AppOrgDateTime.formatDateKey === 'function') {
            return window.AppOrgDateTime.formatDateKey(token, options);
        }
        return token;
    }

    function dateKeyWeekday(dateStr) {
        const parts = String(dateStr || '').split('-').map((part) => Number(part));
        if (parts.length !== 3 || parts.some((part) => !Number.isFinite(part))) return { dayName: '', dayOfWeek: -1 };
        const date = new Date(parts[0], parts[1] - 1, parts[2]);
        return {
            dayName: formatTimesheetDateLabel(dateStr, { weekday: 'long' }),
            dayOfWeek: date.getDay()
        };
    }

    const dates = getDatesInRange(P_START, P_END);
    const dateDayIndexMap = new Map();
    dates.forEach((dateStr, index) => {
        dateDayIndexMap.set(dateStr, index);
    });

    function isWeekendDay(dayOfWeek) {
        return dayOfWeek === 0 || dayOfWeek === 6;
    }

    function isWeekendDate(dateStr) {
        const d = dateStr ? new Date(`${dateStr}T00:00:00`) : null;
        if (!d || Number.isNaN(d.getTime())) return false;
        return isWeekendDay(d.getDay());
    }

    function resolveDayBgClass(dayIndex) {
        return `bg-day-${Math.abs(Number(dayIndex) || 0) % 2}`;
    }

    function resolveBgClass(isHoliday, isWeekend, dateStr) {
        if (isHoliday || isWeekend) return 'bg-holiday';
        const dayIndex = dateDayIndexMap.get(dateStr) ?? 0;
        return resolveDayBgClass(dayIndex);
    }

    function holidayName(hol) {
        return (hol && (hol.name || hol.title || hol.holidayName || hol.label)) || 'Holiday';
    }

    function escapeHtml(value) {
        return String(value ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    function buildCommentCellHtml(ses) {
        const comment = String(ses?.comment || '').trim();
        if (IS_READONLY || ses?.isPriorPeriodAdjustment === true) {
            return `<span class="text-muted fst-italic">${escapeHtml(comment || '-')}</span>`;
        }
        const label = comment || 'Add comment...';
        const toneClass = comment ? 'text-dark' : 'text-muted fst-italic';
        return `<button type="button" class="btn btn-light btn-sm w-100 text-start ts-comment-trigger border shadow-sm ${toneClass}" data-sesid="${escapeHtml(ses.sessionId)}">${escapeHtml(label)}</button>`;
    }

    let timesheetCommentModal = null;
    let activeCommentSessionId = '';

    function updateCommentTriggerCell(sessionId, commentValue) {
        const trigger = Array.from(tbody.querySelectorAll('.ts-comment-trigger'))
            .find((el) => String(el.dataset.sesid || '') === String(sessionId || ''));
        if (!trigger) return;
        const comment = String(commentValue || '').trim();
        trigger.textContent = comment || 'Add comment...';
        trigger.classList.toggle('text-muted', !comment);
        trigger.classList.toggle('fst-italic', !comment);
        trigger.classList.toggle('text-dark', Boolean(comment));
    }

    function releaseStrayModalShell() {
        if (document.querySelector('.modal.show')) return;
        document.body.classList.remove('modal-open');
        document.body.style.removeProperty('overflow');
        document.body.style.removeProperty('padding-right');
        document.querySelectorAll('body > .modal-backdrop').forEach((el) => el.remove());
    }

    function persistTimesheetCommentModal() {
        if (!activeCommentSessionId) return;
        const nextValue = String(document.getElementById('timesheetCommentInput')?.value || '').trim();
        const entry = activeEntries.find((row) => String(row?.sessionId || '') === activeCommentSessionId);
        if (entry) entry.comment = nextValue;
        updateCommentTriggerCell(activeCommentSessionId, nextValue);
        activeCommentSessionId = '';
    }

    window.openTimesheetCommentModal = function(sessionId) {
        const entry = activeEntries.find((row) => String(row?.sessionId || '') === String(sessionId || ''));
        if (!entry || IS_READONLY || entry.isPriorPeriodAdjustment === true) return;
        const modalEl = document.getElementById('timesheetCommentModal');
        const inputEl = document.getElementById('timesheetCommentInput');
        if (!modalEl || !inputEl) return;
        if (modalEl.classList.contains('show')) return;

        activeCommentSessionId = String(sessionId || '').trim();
        const contextEl = document.getElementById('timesheetCommentContext');
        if (contextEl) {
            const bits = [entry.className, entry.activityName, entry.date].map((value) => String(value || '').trim()).filter(Boolean);
            contextEl.textContent = bits.join(' • ') || activeCommentSessionId;
        }
        inputEl.value = String(entry.comment || '');
        if (!timesheetCommentModal && window.bootstrap) {
            timesheetCommentModal = window.bootstrap.Modal.getOrCreateInstance(modalEl, { backdrop: true, focus: true });
        }
        if (timesheetCommentModal) timesheetCommentModal.show();
        setTimeout(() => inputEl.focus(), 0);
    };

    const TABLE_COL_COUNT = IS_READONLY ? 7 : 8;

    function buildMakeupOriginalSessionLabel(entry) {
        const dateStr = String(entry?.makeupOriginalDate || '').trim();
        const startTime = String(entry?.makeupOriginalStartTime || '').trim();
        const endTime = String(entry?.makeupOriginalEndTime || '').trim();
        const dateLabel = dateStr ? formatTimesheetDateLabel(dateStr) : '';
        const timeLabel = startTime && endTime ? `${startTime} – ${endTime}` : (startTime || endTime || '');
        if (dateLabel && timeLabel) return `For ${dateLabel} · ${timeLabel}`;
        if (dateLabel) return `For ${dateLabel}`;
        if (timeLabel) return `For ${timeLabel}`;
        return 'For original session';
    }

    function buildMakeupSessionStatusHtml(entry) {
        if (!entry?.isMakeupSession) return '';
        const originalSessionId = String(entry?.makeupOriginalSessionId || '').trim();
        const originalClassId = String(entry?.makeupOriginalClassId || '').trim();
        const forLabel = buildMakeupOriginalSessionLabel(entry);
        const badgeHtml = '<span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle"><i class="bi bi-arrow-return-left me-1"></i>Make-up</span>';
        if (!originalSessionId || !originalClassId) {
            return `<div class="d-flex flex-column gap-1 align-items-start">${badgeHtml}<span class="small text-muted">${escapeHtml(forLabel)}</span></div>`;
        }
        const href = `/school/classes/${encodeURIComponent(originalClassId)}/sessions/${encodeURIComponent(originalSessionId)}`;
        const linkHtml = `<a href="${escapeHtml(href)}" class="small text-decoration-none" target="_blank" rel="noopener noreferrer" title="Open original session in Session Manager">${escapeHtml(forLabel)} <i class="bi bi-box-arrow-up-right"></i></a>`;
        return `<div class="d-flex flex-column gap-1 align-items-start">${badgeHtml}${linkHtml}</div>`;
    }

    function buildDayAddRowHtml(dateStr, bgClass) {
        if (IS_READONLY) return '';
        return `<tr class="${bgClass} row-hover ts-day-add-row border-bottom border-2">
            <td colspan="${TABLE_COL_COUNT}" class="p-2">
                <button type="button" class="btn btn-outline-primary w-100 fw-semibold" onclick="openManualModal('${dateStr}')"><i class="bi bi-plus-lg me-1"></i> Add</button>
            </td>
        </tr>`;
    }

    function buildDateCellHtml(dateStr, dayName, isHoliday, hol) {
        const holidayLine = isHoliday
            ? `<div class="ts-holiday-label small text-danger fw-semibold mt-1"><i class="bi bi-balloon-fill me-1"></i>${holidayName(hol)}</div>`
            : '';
        const dayClass = isHoliday ? 'text-danger' : '';
        return `
            <div class="ts-date-label">${formatTimesheetDateLabel(dateStr)}</div>
            <div class="ts-day-name ${dayClass}">${dayName}</div>
            ${holidayLine}`;
    }

    function buildStudentNameCellHtml(ses) {
        const name = String(ses?.singleStudentName || '').trim();
        if (!name) return '<span class="text-muted">—</span>';
        return `<span class="fw-semibold">${name}</span>`;
    }

    function resolveDepartmentLabel(entry) {
        return String(entry?.deliveryDepartmentName || entry?.deliveryDepartmentId || '').trim() || 'No Department';
    }

    function renderDepartmentTotals() {
        const totalsBody = document.getElementById('tsDepartmentTotalsBody');
        if (!totalsBody) return;
        const buckets = new Map();
        activeEntries.forEach((entry) => {
            if (entry?.isDeleted) return;
            const hrs = resolveEntryHours(entry);
            if (!Number.isFinite(hrs) || hrs <= 0) return;
            const dept = resolveDepartmentLabel(entry);
            buckets.set(dept, Number((buckets.get(dept) || 0) + hrs));
        });
        const rows = Array.from(buckets.entries()).sort((a, b) => String(a[0]).localeCompare(String(b[0])));
        if (!rows.length) {
            totalsBody.innerHTML = '<tr><td colspan="2" class="text-center text-muted py-3">No payable hours yet.</td></tr>';
            return;
        }
        let total = 0;
        const html = rows.map(([dept, hrs]) => {
            total += hrs;
            return `<tr><td class="ps-4">${dept}</td><td class="text-end pe-4 fw-semibold">${hrs.toFixed(2)}</td></tr>`;
        }).join('');
        totalsBody.innerHTML = `${html}<tr class="table-light"><td class="ps-4 fw-bold">Total</td><td class="text-end pe-4 fw-bold text-success">${total.toFixed(2)}</td></tr>`;
    }

    function renderTable() {
        tbody.innerHTML = '';
        grandTotalHours = 0;
        hasUncompletedSessions = Array.isArray(INCOMPLETE_SESSIONS) && INCOMPLETE_SESSIONS.length > 0;
        hasPendingApprovals = false;

        dates.forEach((dateStr) => {
            const { dayName, dayOfWeek } = dateKeyWeekday(dateStr);

            const hol = holidayMap.get(dateStr);
            const isHoliday = !!hol;
            const isWeekend = isWeekendDay(dayOfWeek);
            const bgClass = resolveBgClass(isHoliday, isWeekend, dateStr);

            const dayEntries = activeEntries.filter(e => e.date === dateStr);
            const dayRowSpan = Math.max(1, dayEntries.length) + (IS_READONLY ? 0 : 1);

            if (dayEntries.length === 0) {
                const dateCell = buildDateCellHtml(dateStr, dayName, isHoliday, hol);
                if (isHoliday) {
                    tbody.innerHTML += `<tr class="${bgClass} row-hover">
                        <td class="ps-4 align-middle border-end border-2" rowspan="${dayRowSpan}">${dateCell}</td>
                        <td colspan="5" class="align-middle text-danger fw-bold"><i class="bi bi-calendar-x-fill me-1"></i> Holiday: ${holidayName(hol)}</td>
                        <td class="text-end align-middle fw-bold">0.00</td>
                        ${IS_READONLY ? '' : '<td></td>'}
                    </tr>`;
                } else {
                    tbody.innerHTML += `<tr class="${bgClass} row-hover">
                        <td class="ps-4 align-middle border-end border-2" rowspan="${dayRowSpan}">${dateCell}</td>
                        <td colspan="5" class="text-muted fst-italic align-middle">No sessions logged.</td>
                        <td class="text-end align-middle fw-bold">0.00</td>
                        ${IS_READONLY ? '' : '<td></td>'}
                    </tr>`;
                }
                tbody.innerHTML += buildDayAddRowHtml(dateStr, bgClass);
            } else {
                dayEntries.forEach((ses, sIdx) => {
                    const hrs = resolveEntryHours(ses);
                    grandTotalHours += hrs;

                    const statusBadge = buildStatusBadgeHtml(ses);
                    if (!ses.isManual && !ses.isPriorPeriodAdjustment && !isFinalAutoStatus(ses)) {
                        hasUncompletedSessions = true;
                    }
                    if (isPendingApprovalEntry(ses)) {
                        hasPendingApprovals = true;
                    }

                    const isPriorAdj = ses.isPriorPeriodAdjustment === true;
                    const rowClass = isPriorAdj
                        ? `${bgClass} row-hover row-prior-adjustment`
                        : `${bgClass} row-hover`;

                    const commentInput = buildCommentCellHtml(ses);

                    let actBtns = '';
                    if (!IS_READONLY) {
                        if (isPriorAdj && !IS_ADMIN) {
                            actBtns = `<span class="text-muted small"><i class="bi bi-lock-fill"></i></span>`;
                        } else if (ses.isManual) {
                            const reviewBtns = CAN_MANAGER_REVIEW && isPendingApprovalEntry(ses) && ses.activityPaid === true
                                ? `<button class="btn btn-sm btn-outline-success py-0 px-1 me-1" title="Approve paid manual row" onclick="decideManualRow('${ses.sessionId}', 'approved')"><i class="bi bi-check-lg"></i></button>
                                   <button class="btn btn-sm btn-outline-danger py-0 px-1 me-1" title="Reject paid manual row" onclick="decideManualRow('${ses.sessionId}', 'rejected')"><i class="bi bi-x-lg"></i></button>`
                                : '';
                            actBtns = `${reviewBtns}<button class="btn btn-sm btn-outline-secondary py-0 px-1" title="Edit" onclick="openManualModal('${dateStr}', '${ses.sessionId}')"><i class="bi bi-pencil"></i></button>
                                       <button class="btn btn-sm btn-outline-danger py-0 px-1 ms-1" title="Remove" onclick="removeEntry('${ses.sessionId}')"><i class="bi bi-trash"></i></button>`;
                        } else {
                            actBtns = `<button class="btn btn-sm btn-outline-danger py-0 px-1" title="Remove Auto-Pulled Session" onclick="removeEntry('${ses.sessionId}')"><i class="bi bi-trash"></i></button>`;
                        }
                    }

                    const actHtml = IS_READONLY ? '' : `<td class="text-center align-middle text-nowrap">${actBtns}</td>`;
                    const dateCell = sIdx === 0
                        ? `<td class="ps-4 align-top border-end border-2" rowspan="${dayRowSpan}">
                            ${buildDateCellHtml(dateStr, dayName, isHoliday, hol)}
                           </td>`
                        : '';

                    const requestedHours = resolveRequestedHours(ses);
                    const hoursDisplay = isPendingApprovalEntry(ses)
                        ? `<span class="text-muted text-decoration-line-through">${requestedHours.toFixed(2)}</span><br><small class="text-warning fw-semibold">0.00 payable (pending)</small>`
                        : (isRejectedApprovalEntry(ses)
                            ? `<span class="text-muted text-decoration-line-through">${requestedHours.toFixed(2)}</span><br><small class="text-danger fw-semibold">0.00 payable (rejected)</small>`
                            : (isUnpaidApprovalEntry(ses)
                                ? `<span class="text-muted text-decoration-line-through">${requestedHours.toFixed(2)}</span><br><small class="text-secondary fw-semibold">0.00 payable (unpaid)</small>`
                                : (isPriorAdj && hrs < 0 ? hrs.toFixed(2) : hrs.toFixed(2))));
                    const timeLabel = isPriorAdj
                        ? `<div class="ts-time-label text-muted">Prior period correction<div class="small mt-1">Ref: ${(ses.adjustmentMeta?.sourceSessionDate || ses.date || '').toString()}</div></div>`
                        : `<div class="ts-time-label">${ses.startTime ? `<i class="bi bi-clock me-1"></i>${ses.startTime} – ${ses.endTime}` : 'Manual Time'}</div>`;
                    const classMeta = ses.isManual && ses.activityName
                        ? `<div class="small text-muted"><i class="bi bi-list-check me-1"></i>${ses.activityName}${ses.activityPaid ? ' (paid)' : ' (unpaid)'}</div>`
                        : (ses.isManual && ses.deliveryDepartmentName
                            ? `<div class="small text-muted"><i class="bi bi-building me-1"></i>${ses.deliveryDepartmentName}</div>`
                            : '');

                    tbody.innerHTML += `
                        <tr class="${rowClass}">
                            ${dateCell}
                            <td><div class="fw-bold text-primary">${ses.className || ''}${payrollRoleBadge(ses.personRole)}</div>${classMeta}</td>
                            <td>${buildStudentNameCellHtml(ses)}</td>
                            <td>${timeLabel}</td>
                            <td><div class="d-flex flex-column gap-1">${statusBadge}${buildMakeupSessionStatusHtml(ses)}</div></td>
                            <td>${commentInput}</td>
                            <td class="text-end fw-bold align-middle">${hoursDisplay}</td>
                            ${actHtml}
                        </tr>
                    `;
                });
                tbody.innerHTML += buildDayAddRowHtml(dateStr, bgClass);
            }
        });

        document.getElementById('lbl_grandTotal').innerText = grandTotalHours.toFixed(2);
        renderDepartmentTotals();

        const btnSubmit = document.getElementById('btnSubmit');
        if (btnSubmit) {
            if (hasUncompletedSessions) {
                btnSubmit.disabled = true;
                btnSubmit.innerHTML = '<i class="bi bi-lock-fill me-1"></i> Finalize Session Statuses to Submit';
                btnSubmit.classList.replace('btn-primary', 'btn-secondary');
            } else {
                btnSubmit.disabled = false;
                btnSubmit.innerHTML = 'Submit for Payroll';
                btnSubmit.classList.replace('btn-secondary', 'btn-primary');
            }
        }

        const btnManagerApprove = document.getElementById('btnApproveTimesheet');
        if (btnManagerApprove) {
            btnManagerApprove.disabled = hasPendingApprovals;
            btnManagerApprove.title = hasPendingApprovals
                ? 'Approve or reject every pending paid manual row first.'
                : '';
        }

        if (isEdited) document.getElementById('badge_manualEdit').classList.remove('d-none');
    }

    tbody.addEventListener('click', (event) => {
        const trigger = event.target.closest('.ts-comment-trigger');
        if (!trigger) return;
        const sessionId = String(trigger.dataset.sesid || '').trim();
        if (sessionId) openTimesheetCommentModal(sessionId);
    });

    const timesheetCommentModalEl = document.getElementById('timesheetCommentModal');
    if (timesheetCommentModalEl) {
        timesheetCommentModalEl.addEventListener('hide.bs.modal', persistTimesheetCommentModal);
        timesheetCommentModalEl.addEventListener('hidden.bs.modal', releaseStrayModalShell);
    }

    window.updateComment = function(sesId, val) {
        const e = activeEntries.find(x => x.sessionId === sesId);
        if (e) e.comment = val;
    };

    window.updateManualComputedHoursFromTimes = function() {
        const type = String(document.getElementById('man_type')?.value || '').trim();
        const classId = String(document.getElementById('man_classId')?.value || '').trim();
        const usesTimedEntry = Boolean(type) || Boolean(classId);
        if (!usesTimedEntry) return;
        const startTime = document.getElementById('man_startTime')?.value || '';
        const endTime = document.getElementById('man_endTime')?.value || '';
        const hours = calculateHoursFromRange(startTime, endTime);
        const hoursInput = document.getElementById('man_hours');
        if (hoursInput) {
            hoursInput.value = hours > 0 ? hours.toFixed(2) : '';
        }
    };

    window.openManualModal = function(dateStr, editId = null) {
        if (editId) {
            const existing = activeEntries.find(x => x.sessionId === editId);
            if (existing?.isPriorPeriodAdjustment && !IS_ADMIN) {
                messageBox({ title: 'Locked Entry', icon: 'warning', message: 'Prior-period adjustment rows cannot be edited.' });
                return;
            }
        }
        document.getElementById('man_date').value = dateStr;
        document.getElementById('man_editSessionId').value = editId || '';
        document.getElementById('man_date_display').innerText = dateStr;
        
        let existingHoursToIgnore = 0;

        if (editId) {
            document.getElementById('modalTitle').innerHTML = '<i class="bi bi-pencil me-2 text-primary"></i>Edit Manual Entry';
            document.getElementById('btnSaveManualEntry').innerText = 'Update Entry';
            const e = activeEntries.find(x => x.sessionId === editId);
            
            existingHoursToIgnore = resolveRequestedHours(e);

            if (e.activityId && !e.classId) {
                document.getElementById('man_type').value = e.activityId;
                document.getElementById('man_classId').value = '';
                document.getElementById('man_className').value = '';
                document.getElementById('man_desc').value = e.description || e.className || '';
                document.getElementById('man_startTime').value = normalizeClock(e.startTime || '');
                document.getElementById('man_endTime').value = normalizeClock(e.endTime || '');
            } else if (e.classId) {
                document.getElementById('man_type').value = '';
                document.getElementById('man_classId').value = e.classId;
                document.getElementById('man_className').value = e.className;
                document.getElementById('man_desc').value = e.description || '';
                document.getElementById('man_startTime').value = normalizeClock(e.startTime || '');
                document.getElementById('man_endTime').value = normalizeClock(e.endTime || '');
            } else {
                document.getElementById('man_type').value = '';
                document.getElementById('man_classId').value = '';
                document.getElementById('man_className').value = '';
                document.getElementById('man_desc').value = e.className;
                document.getElementById('man_startTime').value = '';
                document.getElementById('man_endTime').value = '';
            }
            document.getElementById('man_hours').value = existingHoursToIgnore ? existingHoursToIgnore.toFixed(2) : '';
            document.getElementById('man_comment').value = e.comment || '';
            const roleSelect = document.getElementById('man_personRole');
            if (roleSelect) roleSelect.value = e.personRole || PAYROLL_DEFAULT_ROLE || 'teacher';
        } else {
            document.getElementById('modalTitle').innerHTML = '<i class="bi bi-plus-circle me-2 text-primary"></i>Add Manual Entry';
            document.getElementById('btnSaveManualEntry').innerText = 'Add Entry';
            document.getElementById('man_type').value = '';
            document.getElementById('man_classId').value = '';
            document.getElementById('man_className').value = '';
            document.getElementById('man_desc').value = '';
            document.getElementById('man_startTime').value = '';
            document.getElementById('man_endTime').value = '';
            document.getElementById('man_hours').value = '';
            document.getElementById('man_comment').value = '';
            const roleSelect = document.getElementById('man_personRole');
            if (roleSelect) roleSelect.value = PAYROLL_DEFAULT_ROLE || 'teacher';
        }
        
        toggleManualType();
        
        const dailyTotalSoFar = activeEntries.filter(e => e.date === dateStr).reduce((sum, e) => sum + resolveRequestedHours(e), 0);
        const actualExisting = dailyTotalSoFar - existingHoursToIgnore;
        
        document.getElementById('man_hours_warning').innerText = `Note: ${actualExisting.toFixed(2)} hours already logged for this day. (Max: ${MAX_DAILY_HOURS} hrs/day)`;

        new bootstrap.Modal(document.getElementById('manualEntryModal')).show();
    };

    window.removeEntry = async function(sesId) {
        const entry = activeEntries.find(x => x.sessionId === sesId);
        if (entry?.isPriorPeriodAdjustment && !IS_ADMIN) {
            await messageBox({ title: 'Locked Entry', icon: 'warning', message: 'Prior-period adjustment rows cannot be removed.' });
            return;
        }
        const ok = await confirmAction({
            title: 'Remove Entry',
            message: 'Remove this entry from the timesheet?',
            confirmText: 'Remove',
            cancelText: 'Cancel',
            icon: 'warning',
            confirmBtnClass: 'btn-danger'
        });
        if (!ok) return;
        
        const entryIdx = activeEntries.findIndex(x => x.sessionId === sesId);
        if (entryIdx > -1) {
            const e = activeEntries[entryIdx];
            if (!e.isManual) deletedAutoSessionIds.push(e.sessionId);
            activeEntries.splice(entryIdx, 1);
            isEdited = true;
            renderTable();
        }
    };

    async function validateManualRowBeforeSave(proposedRow, editId) {
        const loadingToken = showTimesheetWaitingModal({
            title: 'Checking Schedule',
            note: 'Validating this manual entry for conflicts and eligibility...',
            operation: 'Manual entry validation'
        });
        try {
            const response = await fetch(`/school/timesheets/editor/${encodeURIComponent(PERIOD_ID)}/api/validate-manual-row${buildMutationQuery()}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'x-ajax-request': 'true'
                },
                body: JSON.stringify({
                    proposed: proposedRow,
                    editSessionId: editId || '',
                    draftEntries: activeEntries.filter((entry) => entry && entry.isDeleted !== true),
                    timesheetEntries: activeEntries.filter((entry) => entry && entry.isDeleted !== true)
                })
            });
            const result = await response.json().catch(() => ({}));
            const guarded = typeof window.applyGuardedApiResult === 'function'
                ? await window.applyGuardedApiResult(result, { busyTitle: 'Validation In Progress', replayTitle: 'Validation Already Completed' })
                : { stop: false };
            if (guarded.stop) return false;
            if (response.ok && result.status === 'success') return true;
            const conflicts = Array.isArray(result?.conflicts) ? result.conflicts : [];
            const detail = conflicts.length
                ? conflicts.slice(0, 3).map((row) => `${row.conflictLabel || 'Conflict'} (${row.conflictDate || row.date || ''})`).join('; ')
                : (result.message || 'Schedule conflict detected.');
            await messageBox({
                title: 'Schedule Conflict Detected',
                icon: 'error',
                message: detail
            });
            return false;
        } catch (error) {
            await messageBox({ title: 'Validation Failed', icon: 'error', message: error.message || 'Unable to validate manual entry.' });
            return false;
        } finally {
            hideTimesheetWaitingModal(loadingToken);
        }
    }

    // SAVE MANUAL ENTRY LOGIC WITH MODAL ALERTS
    document.getElementById('btnSaveManualEntry').addEventListener('click', async () => {
        const d = document.getElementById('man_date').value;
        const editId = document.getElementById('man_editSessionId').value;
        const type = document.getElementById('man_type').value;
        const typeSelect = document.getElementById('man_type');
        const selectedActivityOption = typeSelect?.selectedOptions?.[0] || null;
        const activityId = String(type || '').trim();
        const activityName = activityId ? String(selectedActivityOption?.dataset?.name || selectedActivityOption?.textContent || activityId).trim() : '';
        const activityPaid = activityId ? String(selectedActivityOption?.dataset?.paid || '').trim().toLowerCase() === 'true' : false;
        const activityMeta = manualActivityMap.get(activityId) || null;
        
        const classId = document.getElementById('man_classId').value;
        const className = document.getElementById('man_className').value;
        const descInput = document.getElementById('man_desc').value.trim();
        const startTimeRaw = document.getElementById('man_startTime').value;
        const endTimeRaw = document.getElementById('man_endTime').value;
        let hrs = parseFloat(document.getElementById('man_hours').value);
        const comment = document.getElementById('man_comment').value.trim();

        let finalClassName = className;
        let finalClassId = classId;
        let finalActivityId = activityId;
        let finalActivityName = activityName;
        let finalActivityPaid = activityPaid;
        let finalApprovalStatus = 'approved';
        let finalExcludeFromTotals = false;
        let finalStartTime = '';
        let finalEndTime = '';
        const finalDepartmentId = String(activityMeta?.departmentId || '').trim();
        const finalDepartmentName = String(activityMeta?.departmentName || '').trim();
        const finalCategoryName = String(activityMeta?.categoryName || '').trim();

        if (activityId) {
            if (!descInput) {
                await messageBox({ title: 'Missing Information', icon: 'warning', message: 'Please provide a short description for the selected activity.' });
                return;
            }
            finalClassName = descInput || finalActivityName;
            finalClassId = null;
            finalStartTime = normalizeClock(startTimeRaw);
            finalEndTime = normalizeClock(endTimeRaw);
            if (!finalStartTime || !finalEndTime) {
                await messageBox({ title: 'Missing Time', icon: 'warning', message: 'Activity-based manual rows require both start time and end time.' });
                return;
            }
            hrs = calculateHoursFromRange(finalStartTime, finalEndTime);
            if (!hrs || hrs <= 0) {
                await messageBox({ title: 'Invalid Time Range', icon: 'warning', message: 'End time must be later than start time for activity-based manual rows.' });
                return;
            }
            document.getElementById('man_hours').value = hrs.toFixed(2);
            if (finalActivityPaid) {
                const proceed = await confirmAction({
                    title: 'Paid Activity Requires Approval',
                    message: 'This paid activity row will be saved as pending approval and excluded from payable totals until authorities approve it. Continue?',
                    confirmText: 'Save as Pending Approval',
                    cancelText: 'Cancel',
                    icon: 'warning',
                    confirmBtnClass: 'btn-warning'
                });
                if (!proceed) return;
                finalApprovalStatus = 'pending_approval';
                finalExcludeFromTotals = true;
            } else {
                await messageBox({
                    title: 'Unpaid Activity',
                    icon: 'warning',
                    message: 'The selected activity is unpaid. It will be recorded as unpaid and will not generate payable hours.'
                });
                finalApprovalStatus = 'unpaid';
                finalExcludeFromTotals = true;
            }
        } else {
            finalActivityId = '';
            finalActivityName = '';
            finalActivityPaid = false;
            finalApprovalStatus = 'approved';
            if (classId) {
                finalStartTime = normalizeClock(startTimeRaw);
                finalEndTime = normalizeClock(endTimeRaw);
                if (!finalStartTime || !finalEndTime) {
                    await messageBox({ title: 'Missing Time', icon: 'warning', message: 'Class-based manual rows require both start time and end time.' });
                    return;
                }
                hrs = calculateHoursFromRange(finalStartTime, finalEndTime);
                if (!hrs || hrs <= 0) {
                    await messageBox({ title: 'Invalid Time Range', icon: 'warning', message: 'End time must be later than start time for class-based manual rows.' });
                    return;
                }
                document.getElementById('man_hours').value = hrs.toFixed(2);
            } else {
                if (!descInput) {
                    await messageBox({ title: 'Missing Information', icon: 'warning', message: 'Please select a class or provide a description for manual work.' });
                    return;
                }
                finalClassName = descInput;
                finalClassId = null;
                finalStartTime = '';
                finalEndTime = '';
            }
        }

        if (isNaN(hrs) || hrs <= 0) {
            await messageBox({ title: 'Invalid Hours', icon: 'warning', message: 'Please provide total hours greater than 0.' });
            return;
        }

        if (hrs > MAX_SESSION_HOURS) {
            await messageBox({ title: 'Limit Exceeded', icon: 'error', message: `A single session cannot exceed ${MAX_SESSION_HOURS} hours.` });
            return;
        }

        const finalPersonRole = resolveManualPersonRole();
        if (Array.isArray(PAYROLL_ROLES) && PAYROLL_ROLES.length > 1 && !finalPersonRole) {
            await messageBox({ title: 'Missing Payroll Role', icon: 'warning', message: 'Please select whether this work belongs to your teacher or staff payroll profile.' });
            return;
        }

        if (!activityId && finalClassId) {
            const proposedRow = {
                sessionId: editId || `MAN_PREVIEW_${Date.now()}`,
                date: d,
                classId: finalClassId,
                className: finalClassName,
                activityId: finalActivityId,
                activityName: finalActivityName,
                startTime: finalStartTime,
                endTime: finalEndTime,
                personRole: finalPersonRole,
                durationHours: hrs,
                requestedHours: hrs,
                isManual: true
            };
            setManualSaveBusy(true);
            let ok = false;
            try {
                ok = await validateManualRowBeforeSave(proposedRow, editId);
            } finally {
                setManualSaveBusy(false);
            }
            if (!ok) return;
        } else if (activityId) {
            const proposedRow = {
                sessionId: editId || `MAN_PREVIEW_${Date.now()}`,
                date: d,
                activityId: finalActivityId,
                activityName: finalActivityName,
                className: finalClassName,
                startTime: finalStartTime,
                endTime: finalEndTime,
                personRole: finalPersonRole,
                durationHours: hrs,
                requestedHours: hrs,
                isManual: true
            };
            setManualSaveBusy(true);
            let ok = false;
            try {
                ok = await validateManualRowBeforeSave(proposedRow, editId);
            } finally {
                setManualSaveBusy(false);
            }
            if (!ok) return;
        }

        // Daily Limit Enforcement Check
        let existingHours = activeEntries.filter(e => e.date === d).reduce((sum, e) => sum + resolveRequestedHours(e), 0);
        if (editId) {
            const oldEntry = activeEntries.find(e => e.sessionId === editId);
            if (oldEntry) existingHours -= resolveRequestedHours(oldEntry);
        }

        if (existingHours + hrs > MAX_DAILY_HOURS) {
            await messageBox({
                title: 'Daily Limit Exceeded',
                icon: 'error',
                message: `Cannot save entry. This would exceed the maximum limit of ${MAX_DAILY_HOURS} hours per day.\nCurrent: ${existingHours.toFixed(2)} hrs\nAttempted: +${hrs.toFixed(2)} hrs`
            });
            return;
        }

        if (editId) {
            const e = activeEntries.find(x => x.sessionId === editId);
            e.className = finalClassName;
            e.classId = finalClassId;
            e.activityId = finalActivityId;
            e.activityName = finalActivityName;
            e.activityPaid = finalActivityPaid;
            e.approvalStatus = finalApprovalStatus;
            e.excludeFromTotals = finalExcludeFromTotals;
            e.startTime = finalStartTime;
            e.endTime = finalEndTime;
            e.deliveryDepartmentId = finalDepartmentId;
            e.deliveryDepartmentName = finalDepartmentName;
            e.categoryName = finalCategoryName;
            e.description = descInput;
            e.personRole = finalPersonRole;
            e.requestedHours = hrs;
            e.durationHours = hrs;
            e.hours = finalExcludeFromTotals ? 0 : hrs;
            e.timesheetHours = finalExcludeFromTotals ? 0 : hrs;
            e.status = finalApprovalStatus === 'pending_approval' ? 'pending_approval' : 'manual';
            e.comment = comment;
        } else {
            activeEntries.push({
                sessionId: 'MAN_' + Date.now() + '_' + Math.floor(Math.random()*1000),
                date: d,
                className: finalClassName,
                classId: finalClassId,
                activityId: finalActivityId,
                activityName: finalActivityName,
                activityPaid: finalActivityPaid,
                approvalStatus: finalApprovalStatus,
                excludeFromTotals: finalExcludeFromTotals,
                startTime: finalStartTime,
                endTime: finalEndTime,
                deliveryDepartmentId: finalDepartmentId,
                deliveryDepartmentName: finalDepartmentName,
                categoryName: finalCategoryName,
                description: descInput,
                personRole: finalPersonRole,
                requestedHours: hrs,
                hours: finalExcludeFromTotals ? 0 : hrs, 
                durationHours: hrs, 
                timesheetHours: finalExcludeFromTotals ? 0 : hrs,
                status: finalApprovalStatus === 'pending_approval' ? 'pending_approval' : 'manual',
                comment: comment,
                isManual: true
            });
        }

        isEdited = true;
        bootstrap.Modal.getInstance(document.getElementById('manualEntryModal')).hide();
        renderTable();
    });

    async function executeSave(statusStr) {
        const btn = statusStr === 'submitted' ? document.getElementById('btnSubmit') : document.getElementById('btnSaveDraft');
        if (btn) btn.disabled = true;
        const loadingToken = showTimesheetWaitingModal({
            title: statusStr === 'submitted' ? 'Submitting Timesheet' : 'Saving Timesheet',
            note: 'Please wait while your entries are saved and validated...',
            operation: statusStr === 'submitted' ? 'Submit' : 'Save draft'
        });

        const payloadEntries = activeEntries.map(e => {
            const row = {
                sessionId: e.sessionId,
                date: e.date,
                className: e.className,
                classId: e.classId || null,
                hours: resolveEntryHours(e),
                requestedHours: resolveRequestedHours(e),
                durationHours: resolveRequestedHours(e),
                status: e.status,
                comment: e.comment,
                isManual: e.isManual
            };
            if (e.startTime) row.startTime = e.startTime;
            if (e.endTime) row.endTime = e.endTime;
            if (e.activityId) row.activityId = e.activityId;
            if (e.activityName) row.activityName = e.activityName;
            if (e.activityPaid !== undefined) row.activityPaid = e.activityPaid === true;
            if (e.approvalStatus) row.approvalStatus = e.approvalStatus;
            if (e.excludeFromTotals === true) row.excludeFromTotals = true;
            if (e.decisionAt) row.decisionAt = e.decisionAt;
            if (e.decisionBy) row.decisionBy = e.decisionBy;
            if (e.decisionByName) row.decisionByName = e.decisionByName;
            if (e.decisionNote) row.decisionNote = e.decisionNote;
            if (e.activityEntryId) row.activityEntryId = e.activityEntryId;
            if (e.materializedAt) row.materializedAt = e.materializedAt;
            if (e.materializedSessionId) row.materializedSessionId = e.materializedSessionId;
            if (e.materializedFromTimesheetId) row.materializedFromTimesheetId = e.materializedFromTimesheetId;
            if (e.materializedFromTimesheetEntryId) row.materializedFromTimesheetEntryId = e.materializedFromTimesheetEntryId;
            if (e.deliveryDepartmentId) row.deliveryDepartmentId = e.deliveryDepartmentId;
            if (e.deliveryDepartmentName) row.deliveryDepartmentName = e.deliveryDepartmentName;
            if (e.categoryName) row.categoryName = e.categoryName;
            if (e.description) row.description = e.description;
            if (e.personRole) row.personRole = e.personRole;
            if (e.isReportReflection === true) row.isReportReflection = true;
            if (e.isPriorPeriodAdjustment === true) {
                row.isPriorPeriodAdjustment = true;
                row.adjustmentMeta = e.adjustmentMeta || {};
            }
            if (e.isMakeupSession === true) {
                row.isMakeupSession = true;
                if (e.makeupOriginalSessionId) row.makeupOriginalSessionId = e.makeupOriginalSessionId;
                if (e.makeupOriginalClassId) row.makeupOriginalClassId = e.makeupOriginalClassId;
                if (e.makeupOriginalDate) row.makeupOriginalDate = e.makeupOriginalDate;
                if (e.makeupOriginalStartTime) row.makeupOriginalStartTime = e.makeupOriginalStartTime;
                if (e.makeupOriginalEndTime) row.makeupOriginalEndTime = e.makeupOriginalEndTime;
            }
            return row;
        });

        deletedAutoSessionIds.forEach(id => {
            payloadEntries.push({ sessionId: id, isDeleted: true });
        });

        const payload = { status: statusStr, totalHours: grandTotalHours, entries: payloadEntries, actionStateId };

        try {
            const res = await fetch(`/school/timesheets/editor/<%= period.id %>/save${buildMutationQuery()}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
                body: JSON.stringify(payload)
            });
            const result = await res.json();
            const guarded = typeof window.applyGuardedApiResult === 'function'
                ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Processed' })
                : { stop: false };
            if (guarded.stop) return;
            if (result.status === 'warning' && result.code === 'MANUAL_ENTRY_SCHEDULE_CONFLICT') {
                const rows = Array.isArray(result?.data?.conflicts) ? result.data.conflicts : [];
                const detailText = rows.length
                    ? rows.slice(0, 6).map((row) => {
                        const eventLabel = row?.conflictLabel || 'Scheduled event';
                        const day = row?.date || row?.conflictDate || '-';
                        const time = `${row?.conflictStartTime || '--:--'} - ${row?.conflictEndTime || '--:--'}`;
                        return `${day}: ${eventLabel} (${time})`;
                    }).join('\n')
                    : '';
                await messageBox({
                    title: 'Schedule Conflict',
                    icon: 'warning',
                    message: `${result.message || 'Manual class entry conflicts with your schedule.'}${detailText ? `\n\n${detailText}` : ''}`
                });
                return;
            }
            
            if (result.status !== 'success') throw new Error(result.message);

            hideTimesheetWaitingModal(loadingToken);
            await messageBox({ title: 'Success', icon: 'success', message: result.message, okText: 'OK', okClass: 'btn-success' });
            window.location.href = '/school/timesheets/my-timesheets';
        } catch (e) {
            await messageBox({ title: 'Error', icon: 'error', message: e.message });
        } finally {
            hideTimesheetWaitingModal(loadingToken);
            if (btn) btn.disabled = false;
        }
    }

    if (document.getElementById('btnSaveDraft')) document.getElementById('btnSaveDraft').addEventListener('click', () => executeSave('draft'));

    if (document.getElementById('btnSubmit')) {
        document.getElementById('btnSubmit').addEventListener('click', async () => {
            if (hasUncompletedSessions) return;
            
            const ok = await confirmAction({
                title: 'Submit Timesheet',
                message: 'Are you sure? Once submitted, you cannot edit this timesheet unless a reviewer sends it back to Draft for revision.',
                confirmText: 'Submit',
                cancelText: 'Cancel',
                icon: 'warning',
                confirmBtnClass: 'btn-primary'
            });

            if (ok) executeSave('submitted');
        });
    }

    async function executeManualRowDecision(entryId, decision, note = '') {
        const loadingToken = showTimesheetWaitingModal({
            title: decision === 'approved' ? 'Approving Manual Row' : 'Rejecting Manual Row',
            note: 'Please wait while the decision and payable total are updated...',
            operation: 'Manual row decision'
        });
        try {
            const res = await fetch(`/school/timesheets/editor/${PERIOD_ID}/manual-entries/${encodeURIComponent(entryId)}/decision${buildMutationQuery()}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
                body: JSON.stringify({ decision, note, actionStateId })
            });
            const result = await res.json();
            const guarded = typeof window.applyGuardedApiResult === 'function'
                ? await window.applyGuardedApiResult(result, { busyTitle: 'Decision In Progress', replayTitle: 'Decision Already Processed' })
                : { stop: false };
            if (guarded.stop) return;
            if (result.status !== 'success') throw new Error(result.message || 'Manual-row decision failed.');
            hideTimesheetWaitingModal(loadingToken);
            await messageBox({ title: 'Manual Row Updated', icon: 'success', message: result.message || 'Decision saved.' });
            window.location.reload();
        } catch (error) {
            await messageBox({ title: 'Error', icon: 'error', message: error.message });
        } finally {
            hideTimesheetWaitingModal(loadingToken);
        }
    }

    window.decideManualRow = async function(entryId, decision) {
        if (decision === 'approved') {
            const ok = await confirmAction({
                title: 'Approve Manual Row',
                message: 'Approve this paid manual row and include its requested hours in the payable total?',
                confirmText: 'Approve Row',
                cancelText: 'Cancel',
                icon: 'warning',
                confirmBtnClass: 'btn-success'
            });
            if (ok) await executeManualRowDecision(entryId, 'approved');
            return;
        }
        const modalEl = document.getElementById('manualRowRejectModal');
        const entryInput = document.getElementById('manualRowRejectEntryId');
        const noteInput = document.getElementById('manualRowRejectNote');
        if (!modalEl || !window.bootstrap?.Modal) return;
        if (entryInput) entryInput.value = entryId;
        if (noteInput) noteInput.value = '';
        window.bootstrap.Modal.getOrCreateInstance(modalEl).show();
    };

    const btnConfirmManualRowReject = document.getElementById('btnConfirmManualRowReject');
    if (btnConfirmManualRowReject) {
        btnConfirmManualRowReject.addEventListener('click', async () => {
            const modalEl = document.getElementById('manualRowRejectModal');
            const entryId = String(document.getElementById('manualRowRejectEntryId')?.value || '').trim();
            const noteInput = document.getElementById('manualRowRejectNote');
            const note = String(noteInput?.value || '').trim();
            if (!note) {
                await messageBox({ title: 'Reason Required', icon: 'warning', message: 'Please explain why this manual row is being rejected.' });
                noteInput?.focus();
                return;
            }
            window.bootstrap?.Modal.getOrCreateInstance(modalEl)?.hide();
            await executeManualRowDecision(entryId, 'rejected', note);
        });
    }

    async function executeAdminTimesheetAction(endpoint, { title, message, confirmText, successTitle, requestBody = null }) {
        if (requestBody === null) {
            const ok = await confirmAction({
                title,
                message,
                confirmText,
                cancelText: 'Cancel',
                icon: 'warning',
                confirmBtnClass: 'btn-primary'
            });
            if (!ok) return;
        }
        const loadingToken = showTimesheetWaitingModal({
            title: successTitle || 'Processing Request',
            note: 'Please wait while this timesheet action completes...',
            operation: endpoint
        });
        try {
            const body = requestBody && typeof requestBody === 'object'
                ? { ...requestBody, actionStateId }
                : { actionStateId };
            const res = await fetch(`/school/timesheets/editor/${PERIOD_ID}/${endpoint}${buildMutationQuery()}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
                body: JSON.stringify(body)
            });
            const result = await res.json();
            const guarded = typeof window.applyGuardedApiResult === 'function'
                ? await window.applyGuardedApiResult(result, { busyTitle: 'Request In Progress', replayTitle: 'Request Already Processed' })
                : { stop: false };
            if (guarded.stop) return;
            if (result.status === 'success') {
                hideTimesheetWaitingModal(loadingToken);
                await messageBox({ title: successTitle, icon: 'success', message: result.message || 'Done.' });
                window.location.reload();
                return;
            }
            throw new Error(result.message || 'Request failed.');
        } catch (error) {
            await messageBox({ title: 'Error', icon: 'error', message: error.message });
        } finally {
            hideTimesheetWaitingModal(loadingToken);
        }
    }

    const btnApproveTimesheet = document.getElementById('btnApproveTimesheet');
    if (btnApproveTimesheet) {
        btnApproveTimesheet.addEventListener('click', () => executeAdminTimesheetAction('approve', {
            title: 'Manager Approve Timesheet',
            message: 'Confirm manager review for this submitted version? Finance processing will still be required.',
            confirmText: 'Manager Approve',
            successTitle: 'Manager Approval Recorded'
        }));
    }

    const btnProcessTimesheet = document.getElementById('btnProcessTimesheet');
    if (btnProcessTimesheet) {
        btnProcessTimesheet.addEventListener('click', () => executeAdminTimesheetAction('process', {
            title: 'Process Timesheet',
            message: 'Process this manager-approved timesheet, materialize approved manual rows, and permanently lock linked sources?',
            confirmText: 'Process and Lock',
            successTitle: 'Timesheet Processed'
        }));
    }

    const btnReopenTimesheet = document.getElementById('btnReopenTimesheet');
    const reopenModalEl = document.getElementById('reopenTimesheetModal');
    const reopenNoteInput = document.getElementById('reopenTimesheetNote');
    const btnConfirmReopenTimesheet = document.getElementById('btnConfirmReopenTimesheet');
    if (btnReopenTimesheet && reopenModalEl && window.bootstrap && window.bootstrap.Modal) {
        const reopenModal = window.bootstrap.Modal.getOrCreateInstance(reopenModalEl);
        btnReopenTimesheet.addEventListener('click', () => {
            if (reopenNoteInput) reopenNoteInput.value = '';
            reopenModal.show();
        });
        if (btnConfirmReopenTimesheet) {
            btnConfirmReopenTimesheet.addEventListener('click', async () => {
                const note = String(reopenNoteInput?.value || '').trim();
                if (!note) {
                    await messageBox({ title: 'Note Required', icon: 'warning', message: 'Please explain what the author should revise.' });
                    reopenNoteInput?.focus();
                    return;
                }
                reopenModal.hide();
                await executeAdminTimesheetAction('return', {
                    successTitle: 'Timesheet Returned',
                    requestBody: { note }
                });
            });
