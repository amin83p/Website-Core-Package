<% 
  const isReadOnly = !isAdmin && (timesheet.status === 'submitted' || timesheet.status === 'approved' || timesheet.status === 'processed' || period.status === 'processed');
  const adminCanApprove = (typeof canAdminApprove !== 'undefined') ? canAdminApprove : (isAdmin && String(timesheet.status || '').toLowerCase() === 'submitted');
  const adminCanReopen = (typeof canAdminReopen !== 'undefined') ? canAdminReopen : (isAdmin && ['approved', 'processed'].includes(String(timesheet.status || '').toLowerCase()));
  const isEditorLocked = isReadOnly || adminCanReopen;
  const isManuallyEdited = timesheet.entries && timesheet.entries.some(e => e.isManual || e.isDeleted);
%>

<%
  const deadlineDate = period && period.submissionDeadline ? String(period.submissionDeadline) : '-';
  const deadlineTime = period && period.submissionDeadlineTime ? String(period.submissionDeadlineTime) : '23:59';
  const deadlineLabel = deadlineDate === '-' ? '-' : `${deadlineDate} ${deadlineTime}`;
%>

<style>
    /* IMPORTANT:
       Bootstrap applies background on td/th, not tr. So we style tr > * and set BS vars. */

    /* Weekday zebra */
    .bg-date-even > * { 
        --bs-table-bg: #ffffff !important;
        --bs-table-accent-bg: #ffffff !important;
        background-color: #ffffff !important;
    }
    .bg-date-odd > *  { 
        --bs-table-bg: #f8f9fa !important;
        --bs-table-accent-bg: #f8f9fa !important;
        background-color: #f8f9fa !important;
    }

    /* Weekend zebra (light red but alternating) */
    .bg-weekend-even > * { 
        --bs-table-bg: #ffe8e8 !important;
        --bs-table-accent-bg: #ffe8e8 !important;
        background-color: #ffe8e8 !important;
    }
    .bg-weekend-odd > *  { 
        --bs-table-bg: #ffdede !important;
        --bs-table-accent-bg: #ffdede !important;
        background-color: #ffdede !important;
    }

    /* Holiday (stronger red) */
    .bg-holiday > * { 
        --bs-table-bg: #ff9a9a !important;
        --bs-table-accent-bg: #ff9a9a !important;
        background-color: #ff9a9a !important;
    }

    .row-hover:hover > * { 
        --bs-table-bg: rgba(0,0,0,0.03) !important;
        --bs-table-accent-bg: rgba(0,0,0,0.03) !important;
        background-color: rgba(0,0,0,0.03) !important;
    }

    .row-prior-adjustment > * {
        --bs-table-bg: #fff3cd !important;
        --bs-table-accent-bg: #fff3cd !important;
        background-color: #fff3cd !important;
    }
    .row-prior-adjustment:hover > * {
        --bs-table-bg: #ffe8a1 !important;
        --bs-table-accent-bg: #ffe8a1 !important;
        background-color: #ffe8a1 !important;
    }

  .incomplete-sessions-table thead th {
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .incomplete-sessions-table tbody tr.incomplete-row-weekday-even > * {
    --bs-table-bg: #ffffff;
    background-color: #ffffff !important;
  }
  .incomplete-sessions-table tbody tr.incomplete-row-weekday-odd > * {
    --bs-table-bg: #f8f9fa;
    background-color: #f8f9fa !important;
  }
  .incomplete-sessions-table tbody tr.incomplete-row-weekend-even > * {
    --bs-table-bg: #ffe8e8;
    background-color: #ffe8e8 !important;
  }
  .incomplete-sessions-table tbody tr.incomplete-row-weekend-odd > * {
    --bs-table-bg: #ffdede;
    background-color: #ffdede !important;
  }
  .incomplete-sessions-table tbody tr.incomplete-row-holiday > * {
    --bs-table-bg: #ff9a9a;
    background-color: #ff9a9a !important;
  }
</style>

<div class="sections-page">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <div class="d-flex align-items-center gap-2">
                <h1 class="page-heading size-md m-0"><i class="bi bi-calendar2-week me-2"></i>Timesheet: <%= period.name %></h1>
                <span id="badge_manualEdit" class="badge bg-warning text-dark shadow-sm <%= isManuallyEdited ? '' : 'd-none' %>">
                    <i class="bi bi-pencil-square me-1"></i> Manually Edited
                </span>
            </div>
            <div class="text-muted small mt-1">
                <strong>Period:</strong> <%= period.startDate %> to <%= period.endDate %> |
                <strong>Deadline:</strong> <span class="text-danger fw-bold"><%= deadlineLabel %></span>
            </div>
        </div>
        <a href="/school/timesheets/my-timesheets" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back</a>
    </div>

    <% if (isReadOnly) { %>
        <div class="alert alert-success border-success shadow-sm d-flex align-items-center mb-4">
            <i class="bi bi-check-circle-fill fs-3 me-3 text-success"></i>
            <div>
                <h6 class="fw-bold mb-1">Timesheet Locked</h6>
                <div class="small">This timesheet is currently marked as <strong><%= timesheet.status.toUpperCase() %></strong> and cannot be modified.</div>
            </div>
        </div>
    <% } else { %>
        <div class="alert alert-info border-info shadow-sm d-flex justify-content-between align-items-center mb-4">
            <div>
                <strong>Instructions:</strong> Review auto-pulled sessions or add manual entries if required.
                <div class="text-danger fw-bold small mt-1">All auto-pulled sessions must be in a final status before submission.</div>
            </div>
        </div>
    <% } %>

    <div id="incompleteSessionsPanel" class="card border-warning shadow-sm mb-4 d-none">
        <div class="card-header bg-warning-subtle border-warning d-flex align-items-center justify-content-between py-3">
            <div class="fw-bold text-warning-emphasis">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                Incomplete Sessions Detected
                <span class="badge bg-warning text-dark ms-2" id="incompleteSessionsCount">0</span>
            </div>
            <div class="small text-muted">Finalize these session statuses before submitting your timesheet.</div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered align-middle mb-0 incomplete-sessions-table">
                    <thead class="table-warning">
                        <tr>
                            <th class="ps-4" style="width: 140px;">Date</th>
                            <th>Class</th>
                            <th style="width: 160px;">Time</th>
                            <th style="width: 150px;">Status</th>
                        </tr>
                    </thead>
                    <tbody id="incompleteSessionsBody"></tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-bordered align-middle mb-0" id="tsTable">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-4" style="width: 140px;">Date</th>
                            <th>Class / Description</th>
                            <th>Time / Session</th>
                            <th style="width: 120px;">Status</th>
                            <th>Comment</th>
                            <th class="text-end" style="width: 90px;">Hours</th>
                            <% if (!isEditorLocked) { %><th class="text-center" style="width: 90px;">Act</th><% } %>
                        </tr>
                    </thead>
                    <tbody id="tsBody">
                    </tbody>
                    <tfoot class="table-light border-top border-3">
                        <tr>
                            <!-- FIX: keep total in Hours column, not Act column -->
                            <td colspan="5" class="text-end fw-bold text-uppercase">Total Period Hours:</td>
                            <td class="text-end pe-4 fw-bold text-success fs-5" id="lbl_grandTotal">0.00</td>
                            <% if (!isEditorLocked) { %><td></td><% } %>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>
    </div>

    <% if (!isEditorLocked || adminCanApprove || adminCanReopen) { %>
        <div class="d-flex justify-content-end gap-2 border-top pt-3">
            <% if (!isEditorLocked) { %>
                <button class="btn btn-light border fw-bold px-4" id="btnSaveDraft">Save Draft</button>
                <button class="btn btn-primary fw-bold px-4" id="btnSubmit">Submit for Payroll</button>
            <% } %>
            <% if (adminCanApprove) { %>
                <button class="btn btn-success fw-bold px-4" id="btnApproveTimesheet"><i class="bi bi-check-circle me-1"></i> Approve Timesheet</button>
            <% } %>
            <% if (adminCanReopen) { %>
                <button class="btn btn-warning fw-bold px-4" id="btnReopenTimesheet"><i class="bi bi-unlock me-1"></i> Reopen Timesheet</button>
            <% } %>
        </div>
    <% } %>
</div>

<div class="modal fade" id="manualEntryModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content border-0 shadow">
      <div class="modal-header bg-light">
        <h5 class="modal-title fw-bold" id="modalTitle"><i class="bi bi-plus-circle me-2 text-primary"></i>Add Manual Entry</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
          <input type="hidden" id="man_date">
          <input type="hidden" id="man_editSessionId">
          
          <div class="mb-3">
              <label class="form-label fw-bold small text-muted">Selected Date</label>
              <div id="man_date_display" class="form-control bg-light fw-bold"></div>
          </div>
          
          <div class="mb-3">
              <label class="form-label fw-bold">Activity Type *</label>
              <select id="man_type" class="form-select" onchange="toggleManualType()">
                  <option value="">Class-based entry</option>
