<%- include('partials/tablePages-start', {
  title,
  newUrl, 
  newLabel,
  user,
  tableName,
  btn_export: true,
  print: true,
  headerManageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>',
    '<a href="/dashboard/section-nav/SCHOOL_ACADEMIA" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-backpack2 me-1"></i> School Academia</a>'
  ],
  manageBtns: [
    `
      <a href="/school/subjects/new-wizard" class="btn btn-filled btn-primary btn-md mb-2">
        <i class="bi bi-signpost-split me-1"></i> Wizard
      </a>
  `]

}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search subjects...',
  fields: []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Title / Code</th>
        <th>Organization</th>
        <th>Department</th>
        <th>Config</th>
        <th class="text-center">Status</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length === 0) { %>
         <tr><td colspan="6" class="text-center py-4 text-muted">No subjects found.</td></tr>
      <% } %>
      
      <% data.forEach(item => { %>
        <tr>
          <td class="ps-4">
             <div class="fw-bold text-dark"><%= item.title %></div>
             <div class="x-small text-muted font-monospace"><%= item.code || 'NO-CODE' %> | <%= item.id %></div>
          </td>
          
          <td>
             <div class="d-flex align-items-center gap-2">
                 <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center text-primary" style="width:32px;height:32px;">
                    <i class="bi bi-building"></i>
                 </div>
                 <div class="fw-bold text-dark small"><%= item.orgName %></div>
             </div>
          </td>

          <td>
             <div class="small fw-bold text-dark"><%= item.academicUnit?.departmentName || 'No Department' %></div>
             <div class="x-small text-muted"><%= item.academicUnit?.departmentCode || 'N/A' %></div>
          </td>

          <td>
             <div class="small">
                <span class="badge bg-light text-secondary border me-1"><%= item.configuration?.credits || 0 %> Credits</span>
                <span class="badge bg-light text-secondary border"><%= item.configuration?.defaultHours || 0 %> Hrs</span>
             </div>
          </td>

          <td class="text-center">
             <% 
               let badge = 'bg-secondary';
               if(item.status === 'active') badge = 'bg-success';
               if(item.status === 'draft') badge = 'bg-warning text-dark';
               if(item.status === 'archived') badge = 'bg-danger';
             %>
             <span class="badge <%= badge %>"><%= (item.status || 'unknown').toUpperCase() %></span>
          </td>

          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= item.id %>"
                title="Subject Actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                <a href="/school/subjects/edit-wizard/<%= item.id %>" class="btn btn-outline-info btn-sm">
                  <i class="bi bi-magic me-2"></i>Wizard
                </a>
                <a href="/school/subjects/edit/<%= item.id %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-pencil-square me-2"></i>Edit
                </a>
                <button class="btn btn-outline-danger btn-sm delete-btn" data-id="<%= item.id %>">
                  <i class="bi bi-archive me-2"></i>Delete
                </button>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/subjects" hidden></span>

<%- include('partials/pagination', { 
    pagination: pagination, 
    filters: filters, 
    baseUrlPath: 'school/subjects' 
}) %>

<%- include('partials/tablePages-end') %>
