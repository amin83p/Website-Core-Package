<%
  const holidayYearRows = Array.isArray(yearHolidayData) ? yearHolidayData : [];
%>

<%- include('partials/tablePages-start', {
  title: 'School Holidays & Off Days',
  newUrl: 'school/holidays', // We will intercept this URL via JS below to open the modal
  newLabel: 'Add Holiday',
  user: user,
  tableName: 'Holidays_List',
  btn_export: true,
  print: true,
  headerManageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>',
    '<a href="/dashboard/section-nav/SCHOOL_ACADEMIA" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-backpack2 me-1"></i> School Academia</a>'
  ],
  manageBtns: [
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search holidays...',
  fields: [
      { name: 'type', label: 'Type', type: 'select', options: ['National Holiday','School Break','Staff Development','Weather Emergency','Other'] }
  ]
}) %>

<div class="bg-light border rounded px-4 py-3 mb-4 d-flex align-items-center justify-content-between gap-3 flex-wrap">
    <div class="d-flex align-items-center gap-3">
      <label class="fw-bold mb-0 text-dark"><i class="bi bi-calendar-range me-2"></i>Select Year:</label>
      <form id="yearForm" action="/school/holidays" method="GET" class="m-0">
          <select name="year" class="form-select form-select-sm border-secondary w-auto fw-bold" onchange="document.getElementById('yearForm').submit();">
              <% const baseYear = new Date().getFullYear() - 1; %>
              <% for(let i = 0; i < 5; i++) { const y = baseYear + i; %>
                  <option value="<%= y %>" <%= currentYear == y ? 'selected' : '' %>><%= y %></option>
              <% } %>
          </select>
      </form>
    </div>
    <button type="button" class="btn btn-outline-danger btn-sm fw-bold" id="btnOpenHolidayYearView">
      <i class="bi bi-calendar3 me-1"></i>Year View
    </button>
</div>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
    <table class="table-responsive size-md" id="first-table">
        <thead>
            <tr>
                <th class="draggable ps-4" data-column="date" style="width: 150px;">Date</th>
                <th class="draggable" data-column="title">Holiday / Event Title</th>
                <th class="draggable" data-column="type" style="width: 200px;">Type</th>
                <th class="draggable" data-column="notes">Notes</th>
                <th class="text-end pe-4" style="width: 150px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (data.length === 0) { %>
                <tr><td colspan="5" class="text-center py-5 text-muted">No holidays recorded for <%= currentYear %>.</td></tr>
            <% } else { %>
                <% data.forEach(item => { 
                    const d = new Date(item.date + 'T00:00:00'); 
                    const displayDate = d.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
                %>
                <tr>
                    <td class="ps-4 fw-bold text-dark" data-sort-value="<%= item.date %>"><%= displayDate %></td>
                    <td class="fw-bold text-primary"><%= item.title %></td>
                    <td>
                        <% 
                           let badgeClass = 'bg-secondary';
                           if(item.type === 'National Holiday') badgeClass = 'bg-primary';
                           if(item.type === 'School Break') badgeClass = 'bg-info text-dark';
                           if(item.type === 'Weather Emergency') badgeClass = 'bg-danger';
                        %>
                        <span class="badge <%= badgeClass %>"><%= item.type %></span>
                    </td>
                    <td class="text-muted small text-truncate" style="max-width: 250px;"><%= item.notes || '-' %></td>
                    <td class="table-actions text-end pe-4">
                        <div class="row-actions-wrap">
                          <button
                            type="button"
                            class="btn btn-secondary btn-sm btn-row-actions-toggle"
                            data-row-actions-id="<%= item.id %>"
                            title="Holiday Actions">
                            <i class="bi bi-three-dots-vertical"></i>
                          </button>
                          <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                            <button class="btn btn-outline-info btn-sm" 
                                onclick="openHolidayModal('<%= item.id %>', '<%= item.date %>', '<%= item.title.replace(/'/g, "\\'") %>', '<%= item.type %>', '<%= (item.notes||'').replace(/'/g, "\\'") %>')">
                                <i class="bi bi-pencil-square me-2"></i>Edit
                            </button>
                            <button class="btn btn-outline-danger btn-sm delete-btn" data-id="<%= item.id %>">
                                <i class="bi bi-trash me-2"></i>Delete
                            </button>
                          </div>
                        </div>
                    </td>
                </tr>
                <% }) %>
            <% } %>
        </tbody>
    </table>
</div>

<%- include('partials/tablePages-end') %>

<div class="modal fade" id="holidayModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="holidayModalTitle">Add Holiday</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="holidayForm">
                    <input type="hidden" id="hol_id">
                    <div class="mb-3">
                        <label class="form-label fw-bold">Date *</label>
                        <input type="date" id="hol_date" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Title *</label>
                        <input type="text" id="hol_title" class="form-control" placeholder="e.g. Thanksgiving Break" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Type</label>
                        <select id="hol_type" class="form-select">
                            <option value="National Holiday">National Holiday</option>
                            <option value="School Break">School Break</option>
                            <option value="Staff Development">Staff Development (No Students)</option>
                            <option value="Weather Emergency">Weather / Emergency</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-bold">Notes</label>
                        <textarea id="hol_notes" class="form-control" rows="2"></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary fw-bold" id="btn_saveHoliday">Save Holiday</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="holidayYearViewModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-danger text-white">
        <h5 class="modal-title fw-bold">
          <i class="bi bi-calendar3-week me-2"></i>Off Days - Year View (<%= currentYear %>)
        </h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="small text-muted mb-3">
          Hover over a red day to see the off day title and description.
        </div>
        <div class="d-flex align-items-center gap-2 mb-3">
          <span class="badge bg-danger">Off Day</span>
          <span class="small text-muted">Highlighted in red</span>
          <span class="badge bg-warning text-dark ms-2">Weekend</span>
          <span class="small text-muted">Saturdays and Sundays</span>
        </div>
        <div id="holidayYearCalendarGrid" class="row g-3"></div>
        <div class="card border-0 shadow-sm mt-3">
          <div class="card-header bg-light fw-bold text-dark py-2">
            <i class="bi bi-clipboard-data me-2"></i>Year Summary
          </div>
          <div class="card-body py-3" id="holidayYearSummaryReport"></div>
        </div>
      </div>
      <div class="modal-footer bg-light">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>

<script>
let modalInstance = null;
let holidayYearModalInstance = null;
const holidayYearData = <%- JSON.stringify(holidayYearRows || []).replace(/</g, '\\u003c') %>;
const selectedHolidayYear = Number('<%= currentYear %>') || new Date().getFullYear();

function monthLabel(year, monthIndex) {
    return new Date(year, monthIndex, 1).toLocaleDateString('en-US', { month: 'long' });
}

function buildHolidayLookup(rows) {
    const map = new Map();
    (Array.isArray(rows) ? rows : []).forEach((row) => {
        const date = String(row?.date || '').trim();
        if (!date) return;
        if (!map.has(date)) map.set(date, []);
        map.get(date).push({
            title: String(row?.title || 'Off Day').trim(),
            notes: String(row?.notes || '').trim()
        });
    });
    return map;
}

function buildHolidayTooltipLabel(items) {
    return (Array.isArray(items) ? items : [])
        .map((item) => {
            const title = String(item?.title || 'Off Day').trim();
            const notes = String(item?.notes || '').trim();
            return notes ? `${title}: ${notes}` : title;
        })
        .filter(Boolean)
        .join(' | ');
}

function toDateKey(dateObj) {
    const y = dateObj.getFullYear();
    const m = String(dateObj.getMonth() + 1).padStart(2, '0');
    const d = String(dateObj.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
}

function computeHolidayYearSummary(holidayLookup) {
    const offDaySet = new Set();
    (holidayLookup instanceof Map ? Array.from(holidayLookup.keys()) : []).forEach((dateKey) => {
        const key = String(dateKey || '').trim();
        if (key.startsWith(`${selectedHolidayYear}-`)) offDaySet.add(key);
    });

    const typeCounts = new Map();
    (Array.isArray(holidayYearData) ? holidayYearData : []).forEach((row) => {
        const dateKey = String(row?.date || '').trim();
        if (!dateKey.startsWith(`${selectedHolidayYear}-`)) return;
        const type = String(row?.type || 'Other').trim() || 'Other';
        typeCounts.set(type, Number(typeCounts.get(type) || 0) + 1);
    });

    let totalDays = 0;
    let totalWeekendDays = 0;
    let totalMonThu = 0;
    let totalFridays = 0;
    let offOnWeekend = 0;
    let offOnMonThu = 0;
    let offOnFriday = 0;

    const start = new Date(selectedHolidayYear, 0, 1);
    const end = new Date(selectedHolidayYear, 11, 31);
    for (let cursor = new Date(start); cursor <= end; cursor.setDate(cursor.getDate() + 1)) {
        totalDays += 1;
        const dayOfWeek = cursor.getDay(); // Sun=0, Mon=1 ... Sat=6
        const dateKey = toDateKey(cursor);
        const isOffDay = offDaySet.has(dateKey);
        const isWeekend = dayOfWeek === 0 || dayOfWeek === 6;

        if (isWeekend) totalWeekendDays += 1;
        if (dayOfWeek >= 1 && dayOfWeek <= 4) totalMonThu += 1;
        if (dayOfWeek === 5) totalFridays += 1;

        if (isOffDay) {
            if (isWeekend) offOnWeekend += 1;
            else if (dayOfWeek >= 1 && dayOfWeek <= 4) offOnMonThu += 1;
            else if (dayOfWeek === 5) offOnFriday += 1;
        }
    }

    const totalSchoolOffDays = offDaySet.size;
    const offExcludingWeekend = Math.max(0, totalSchoolOffDays - offOnWeekend);
    const teacherWorkingDaysMonThu = Math.max(0, totalMonThu - offOnMonThu);
    const totalWeekdays = totalMonThu + totalFridays;
    const offOnWeekdays = offOnMonThu + offOnFriday;
    const weekdaysOpen = Math.max(0, totalWeekdays - offOnWeekdays);

    const topTypes = Array.from(typeCounts.entries())
        .sort((a, b) => b[1] - a[1] || String(a[0]).localeCompare(String(b[0])))
        .slice(0, 3)
        .map(([type, count]) => `${type}: ${count}`)
        .join(' | ');

    return {
        totalDays,
        totalWeekendDays,
        totalMonThu,
        totalFridays,
        totalSchoolOffDays,
        offExcludingWeekend,
        teacherWorkingDaysMonThu,
        offOnWeekend,
        offOnMonThu,
        offOnFriday,
        weekdaysOpen,
        topTypes
    };
}

function renderHolidayYearSummary(holidayLookup) {
    const reportEl = document.getElementById('holidayYearSummaryReport');
    if (!reportEl) return;
    const summary = computeHolidayYearSummary(holidayLookup);

    reportEl.innerHTML = `
      <div class="row g-2 small">
        <div class="col-12 col-md-6"><span class="fw-bold text-dark">Teachers Working Days:</span> Monday to Thursday excluding the off days: <span class="text-primary fw-bold">${summary.teacherWorkingDaysMonThu}</span></div>
        <div class="col-12 col-md-6"><span class="fw-bold text-dark">Total Saturday and Sundays:</span> <span class="fw-bold">${summary.totalWeekendDays}</span></div>
        <div class="col-12 col-md-6"><span class="fw-bold text-dark">Total days school is off:</span> <span class="fw-bold text-danger">${summary.totalSchoolOffDays}</span></div>
        <div class="col-12 col-md-6"><span class="fw-bold text-dark">Total Days school is off excluding saturdays and sundays:</span> <span class="fw-bold text-danger">${summary.offExcludingWeekend}</span></div>
        <div class="col-12 col-md-6"><span class="fw-bold text-dark">Total Fridays:</span> ${summary.totalFridays}</div>
        <div class="col-12 col-md-6"><span class="fw-bold text-dark">Weekdays school is open (Mon-Fri excluding off days):</span> ${summary.weekdaysOpen}</div>
        <div class="col-12 col-md-6"><span class="fw-bold text-dark">Off days on weekends:</span> ${summary.offOnWeekend}</div>
        <div class="col-12 col-md-6"><span class="fw-bold text-dark">Off days on teacher working days (Mon-Thu):</span> ${summary.offOnMonThu}</div>
        <div class="col-12"><span class="fw-bold text-dark">Most common off-day types:</span> ${summary.topTypes || 'N/A'}</div>
      </div>
    `;
}

function renderHolidayYearCalendar() {
    const container = document.getElementById('holidayYearCalendarGrid');
    if (!container) return;
    const holidayLookup = buildHolidayLookup(holidayYearData);

    if (typeof bootstrap !== 'undefined') {
        container.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((el) => {
            const instance = bootstrap.Tooltip.getInstance(el);
            if (instance) instance.dispose();
        });
    }

    container.innerHTML = '';

    for (let monthIndex = 0; monthIndex < 12; monthIndex++) {
        const col = document.createElement('div');
        col.className = 'col-12 col-md-6 col-xl-4';

        const card = document.createElement('div');
        card.className = 'card border-0 shadow-sm h-100';

        const header = document.createElement('div');
        header.className = 'card-header bg-danger-subtle text-danger fw-bold py-2';
        header.textContent = monthLabel(selectedHolidayYear, monthIndex);
        card.appendChild(header);

        const body = document.createElement('div');
        body.className = 'card-body p-2';

        const table = document.createElement('table');
        table.className = 'table table-sm mb-0 align-middle text-center';

        const thead = document.createElement('thead');
        thead.innerHTML = '<tr class="small text-muted"><th>Su</th><th>Mo</th><th>Tu</th><th>We</th><th>Th</th><th>Fr</th><th>Sa</th></tr>';
        table.appendChild(thead);

        const tbody = document.createElement('tbody');
        const firstDayOfMonth = new Date(selectedHolidayYear, monthIndex, 1).getDay();
        const daysInMonth = new Date(selectedHolidayYear, monthIndex + 1, 0).getDate();
        let day = 1;

        for (let week = 0; week < 6; week++) {
            const row = document.createElement('tr');
            let renderedCell = false;

            for (let weekDay = 0; weekDay < 7; weekDay++) {
                const cell = document.createElement('td');
                cell.className = 'py-1 px-0';

                if ((week === 0 && weekDay < firstDayOfMonth) || day > daysInMonth) {
                    cell.innerHTML = '<span class="text-muted"> </span>';
                } else {
                    renderedCell = true;
                    const dateKey = `${selectedHolidayYear}-${String(monthIndex + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
                    const holidayItems = holidayLookup.get(dateKey) || [];

                    const dayEl = document.createElement('span');
                    dayEl.className = 'd-inline-flex align-items-center justify-content-center rounded-circle';
                    dayEl.style.width = '28px';
                    dayEl.style.height = '28px';
                    dayEl.textContent = String(day);

                    if (holidayItems.length) {
                        dayEl.classList.add('bg-danger', 'text-white', 'fw-bold');
                        dayEl.setAttribute('data-bs-toggle', 'tooltip');
                        dayEl.setAttribute('data-bs-placement', 'top');
                        dayEl.setAttribute('title', buildHolidayTooltipLabel(holidayItems));
                        dayEl.style.cursor = 'pointer';
                    } else if (weekDay === 0 || weekDay === 6) {
                        dayEl.classList.add('bg-warning', 'text-dark', 'fw-semibold');
                    } else {
                        dayEl.classList.add('text-dark');
                    }

                    cell.appendChild(dayEl);
                    day += 1;
                }

                row.appendChild(cell);
            }

            if (!renderedCell && day > daysInMonth) break;
            tbody.appendChild(row);
        }

        table.appendChild(tbody);
        body.appendChild(table);
        card.appendChild(body);
        col.appendChild(card);
        container.appendChild(col);
    }

    if (typeof bootstrap !== 'undefined') {
        container.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((el) => {
            new bootstrap.Tooltip(el);
        });
    }

    renderHolidayYearSummary(holidayLookup);
}

document.addEventListener('DOMContentLoaded', () => {
    const actionStateId = '<%= (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '' %>';
    // 1. Initialize Modal
    if (typeof bootstrap !== 'undefined') {
        modalInstance = new bootstrap.Modal(document.getElementById('holidayModal'));
        holidayYearModalInstance = new bootstrap.Modal(document.getElementById('holidayYearViewModal'));
    }

    // 2. Intercept the standard "Add" button from tablePages-start
    const newBtn = document.querySelector('a[href="/school/holidays/new"]');
    if (newBtn) {
        newBtn.addEventListener('click', (e) => {
            e.preventDefault();
            openHolidayModal();
        });
    }

    const openYearViewBtn = document.getElementById('btnOpenHolidayYearView');
    if (openYearViewBtn) {
        openYearViewBtn.addEventListener('click', () => {
            renderHolidayYearCalendar();
            if (holidayYearModalInstance) holidayYearModalInstance.show();
        });
    }

    // 3. Save Logic
    document.getElementById('btn_saveHoliday').addEventListener('click', async () => {
        const form = document.getElementById('holidayForm');
        if (!form.checkValidity()) {
            form.reportValidity();
            return;
        }

        const payload = {
            id: document.getElementById('hol_id').value,
            date: document.getElementById('hol_date').value,
            title: document.getElementById('hol_title').value,
            type: document.getElementById('hol_type').value,
            notes: document.getElementById('hol_notes').value,
            actionStateId
        };

        const submitBtn = document.getElementById('btn_saveHoliday');
        const originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

        try {
            const res = await fetch('/school/holidays/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
                body: JSON.stringify(payload)
            });
            const result = await res.json();
            const guarded = typeof window.applyGuardedApiResult === 'function'
                ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Processed' })
                : { stop: false };
            if (guarded.stop) return;

            if (modalInstance) modalInstance.hide();

            if (typeof showMessageModal === 'function') {
                await showMessageModal({ 
                    title: result.status === 'success' ? 'Success' : 'Error', 
                    icon: result.status === 'success' ? 'success' : 'error', 
                    message: result.message, 
                    buttons: [{ text: 'OK', class: result.status === 'success' ? 'btn-success' : 'btn-danger' }] 
                });
                if (result.status === 'success') window.location.reload();
            } else {
                alert(result.message);
                if (result.status === 'success') window.location.reload();
            }
        } catch (error) {
            console.error(error);
            if (typeof showMessageModal === 'function') {
                await showMessageModal({ title: 'System Error', icon: 'error', message: 'A network error occurred.', buttons: [{ text: 'Close', class: 'btn-secondary' }] });
            } else { alert('A network error occurred.'); }
        } finally {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
        }
    });
});

// --- Helper Functions ---

function openHolidayModal(id = '', date = '', title = '', type = 'National Holiday', notes = '') {
    document.getElementById('holidayModalTitle').innerText = id ? 'Edit Holiday' : 'Add Holiday';
    document.getElementById('hol_id').value = id;
    document.getElementById('hol_date').value = date;
    document.getElementById('hol_title').value = title;
    document.getElementById('hol_type').value = type;
    document.getElementById('hol_notes').value = notes;
    
    if (modalInstance) modalInstance.show();
}

async function deleteHoliday(id, title) {
    // Delete handling is centralized in public/scripts/main.js.
}
</script>
