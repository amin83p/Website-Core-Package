<%- include('partials/tablePages-start', {
  title, newUrl, newLabel, user, tableName, btn_export: true, print,
  headerManageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>',
    '<a href="/dashboard/section-nav/SCHOOL_PEOPLE" class="school-navigator-dashboard btn btn-filled btn-secondary mb-2 btn-md"><i class="bi bi-people me-1"></i> People Dashboard</a>'
  ],
  manageBtns: [
    `<a href="/school/students/archived" class="btn btn-outline-warning btn-md mb-2"><i class="bi bi-arrow-counterclockwise me-1"></i> Recover Archived</a>`,
    '<button type="button" class="btn btn-outline-success btn-md mb-2" id="btnSyncStudentDenormalizedNames"><i class="bi bi-arrow-repeat me-1"></i> Sync All Saved Names</button>'
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search students...',
  fields: [
      { name: 'academicStatus', label: 'Status', type: 'select', options: ['Active', 'Probation', 'Graduated', 'Withdrawn'] },
      { name: 'feeCategory', label: 'Fee Category', type: 'select', options: feeCategories || [] }
  ]
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Student Info</th>
        <th>Contact</th>
        <th>Fee Category</th>
        <th class="text-center">Status</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length === 0) { %>
         <tr><td colspan="5" class="text-center py-4 text-muted">No students found.</td></tr>
      <% } %>
      <% data.forEach(item => { %>
        <tr>
          <td class="ps-4">
              <div class="fw-bold text-primary">
                <%- include('../partials/studentNameLink', { name: `${item.firstName} ${item.lastName}`.trim(), studentRecordId: item.id, canOpenStudentProfile: typeof canOpenStudentProfile !== 'undefined' ? canOpenStudentProfile : false, linkClass: 'text-decoration-none' }) %>
              </div>
              <div class="small text-muted font-monospace"><i class="bi bi-person-badge me-1"></i><%= item.customStudentId || item.id %></div>
          </td>
          <td class="small text-muted">
              <div><i class="bi bi-envelope me-1"></i><%= item.email %></div>
              <div><i class="bi bi-telephone me-1"></i><%= item.phone %></div>
          </td>
          <td class="fw-bold text-dark"><%= item.feeCategory %></td>
          <td class="text-center">
             <% 
               let badge = 'bg-secondary';
               if(item.academicStatus === 'Active') badge = 'bg-success';
               if(item.academicStatus === 'Probation') badge = 'bg-warning text-dark';
               if(item.academicStatus === 'Graduated') badge = 'bg-primary';
               if(item.academicStatus === 'Withdrawn') badge = 'bg-danger';
               if(item.academicStatus === 'Archived') badge = 'bg-secondary';
             %>
             <span class="badge <%= badge %>"><%= item.academicStatus.toUpperCase() %></span>
          </td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= item.id %>"
                title="Student Actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                <a href="/school/students/edit/<%= item.id %>" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil-square me-2"></i>Edit</a>
                <% if (canChangeStudentSystemId) { %>
                <button type="button" class="btn btn-outline-warning btn-sm change-system-id-btn" data-id="<%= item.id %>" data-name="<%= item.name || ((item.firstName || '') + ' ' + (item.lastName || '')).trim() %>"><i class="bi bi-arrow-repeat me-2"></i>Change System Record ID</button>
                <% } %>
                <button class="btn btn-outline-secondary btn-sm archive-btn" data-id="<%= item.id %>"><i class="bi bi-archive me-2"></i>Archive</button>
                <button class="btn btn-outline-danger btn-sm delete-btn" data-id="<%= item.id %>"><i class="bi bi-trash me-2"></i>Delete</button>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="modal fade" id="changeStudentSystemIdModal" tabindex="-1" aria-labelledby="changeStudentSystemIdModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="changeStudentSystemIdModalLabel"><i class="bi bi-arrow-repeat me-2"></i>Change Student System Record ID</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-warning"><strong>High-impact migration:</strong> this updates the student key in all linked School records. Custom Student ID is not changed.</div>
        <div id="changeSystemIdAlert" class="alert alert-danger d-none"></div>
        <div class="mb-3"><div class="small text-muted">Student</div><div class="fw-bold" id="changeSystemIdStudentName"></div></div>
        <div class="row g-3">
          <div class="col-md-6"><label class="form-label fw-bold">Current System Record ID</label><input id="changeSystemIdCurrent" class="form-control font-monospace" readonly></div>
          <div class="col-md-6"><label class="form-label fw-bold">Replacement System Record ID</label><div class="input-group"><input id="changeSystemIdNew" class="form-control font-monospace" maxlength="40" pattern="[A-Za-z0-9_-]+"><button type="button" class="btn btn-outline-primary" id="changeSystemIdGenerate">Generate ID</button></div></div>
        </div>
        <div class="mt-4"><h6 class="fw-bold">Affected records</h6><div id="changeSystemIdImpact" class="text-muted">Loading impact preview...</div></div>
        <div class="mt-3"><label class="form-label fw-bold">Confirm replacement ID</label><input id="changeSystemIdConfirmation" class="form-control font-monospace" placeholder="Type the replacement ID exactly"><div class="form-text">This must exactly match the replacement ID.</div></div>
      </div>
      <div class="modal-footer"><button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button><button type="button" class="btn btn-warning" id="changeSystemIdSubmit">Change System Record ID</button></div>
    </div>
  </div>
</div>

<span id="urlRef" data-id="school/students" hidden></span>
<%- include('partials/pagination', { pagination, filters, baseUrlPath: 'school/students' }) %>
<%- include('partials/tablePages-end') %>
<%- include('school/partials/syncDenormalizedNamesManage', {
  syncDenormalizedLinkType: 'student',
  syncDenormalizedSectionLabel: 'Students',
  syncDenormalizedButtonId: 'btnSyncStudentDenormalizedNames',
  actionStateId
}) %>

<script>
function initializeChangeStudentSystemIdModal() {
  const modalEl = document.getElementById('changeStudentSystemIdModal');
  if (!modalEl) return;
  // Keep the modal outside page containers that establish their own stacking
  // context, otherwise Bootstrap's body-level backdrop can cover the dialog.
  if (modalEl.parentElement !== document.body) document.body.appendChild(modalEl);
  const modalApi = window.bootstrap && window.bootstrap.Modal;
  if (!modalApi) {
    console.error('[Students] Bootstrap Modal is unavailable; the Change System Record ID modal cannot be initialized.');
    return;
  }
  const modal = modalApi.getOrCreateInstance(modalEl);
  const alertEl = document.getElementById('changeSystemIdAlert');
  const currentEl = document.getElementById('changeSystemIdCurrent');
  const newEl = document.getElementById('changeSystemIdNew');
  const confirmationEl = document.getElementById('changeSystemIdConfirmation');
  const impactEl = document.getElementById('changeSystemIdImpact');
  const submitBtn = document.getElementById('changeSystemIdSubmit');
  let actionStateId = <%- JSON.stringify(actionStateId || '').replace(/</g, '\u003c') %>;

  function formatMessageMarkup(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/&lt;b&gt;/gi, '<b>')
      .replace(/&lt;\/b&gt;/gi, '</b>')
      .replace(/&lt;br\s*\/?&gt;/gi, '<br>');
  }
  function isSecurityMessage(message) {
    return /security violation|session validation failed|action state token/i.test(String(message || ''));
  }
  async function showError(message, { useMessageModal = false } = {}) {
    alertEl.innerHTML = formatMessageMarkup(message || 'Unable to change the System Record ID.');
    alertEl.classList.remove('d-none');
    if (!useMessageModal || typeof window.showMessageModal !== 'function') return;
    const shouldRestore = modalEl.classList.contains('show');
    if (shouldRestore) {
      await new Promise((resolve) => {
        modalEl.addEventListener('hidden.bs.modal', resolve, { once: true });
        modal.hide();
      });
    }
    await window.showMessageModal({
      title: isSecurityMessage(message) ? 'Security Validation Failed' : 'Operation Failed',
      icon: 'error',
      message: formatMessageMarkup(message || 'Unable to change the System Record ID.'),
      buttons: [{ text: 'OK', class: 'btn-danger', value: true }]
    });
    if (shouldRestore) modal.show();
  }
  function clearError() { alertEl.classList.add('d-none'); alertEl.textContent = ''; }
  async function readJson(response) {
    const result = await response.json().catch(() => ({}));
    if (!response.ok || result.status === 'error') {
      const error = new Error(result.message || 'Request failed.');
      error.migrationId = result.migrationId || '';
      error.rollbackStatus = result.rollbackStatus || '';
      throw error;
    }
    return result;
  }
  function renderImpact(data) {
    const rows = Array.isArray(data?.collections) ? data.collections.filter((row) => Number(row.count) > 0) : [];
    impactEl.innerHTML = rows.length
      ? '<div class="list-group">' + rows.map((row) => '<div class="list-group-item d-flex justify-content-between"><span>' + String(row.label || row.key) + '</span><span class="badge bg-primary">' + Number(row.count || 0) + '</span></div>').join('') + '</div><div class="mt-2 fw-bold">Total references: ' + Number(data.totalUpdates || 0) + '</div>'
      : '<div class="text-muted">Only the student record will be updated.</div>';
  }
  const originalRenderImpact = renderImpact;
  renderImpact = function renderImpactWithMode(data) {
    originalRenderImpact(data);
    if (data?.transactionMode === 'compensating') {
      const notice = document.createElement('div');
      notice.className = 'alert alert-info py-2 mb-2';
      notice.textContent = 'Standalone MongoDB detected. The migration will use protected rollback mode.';
      impactEl.prepend(notice);
    }
  };
  document.querySelectorAll('.change-system-id-btn').forEach((button) => {
    button.addEventListener('click', async () => {
      clearError();
      currentEl.value = button.dataset.id || '';
      newEl.value = '';
      confirmationEl.value = '';
      document.getElementById('changeSystemIdStudentName').textContent = button.dataset.name || button.dataset.id || 'Student';
      impactEl.textContent = 'Loading impact preview...';
      submitBtn.disabled = true;
      modal.show();
      try {
        const result = await readJson(await fetch('/school/students/' + encodeURIComponent(currentEl.value) + '/system-id-impact', { headers: { Accept: 'application/json', 'X-Ajax-Request': 'true' } }));
        if (result.actionStateId) actionStateId = result.actionStateId;
        renderImpact(result.data);
        submitBtn.disabled = false;
      } catch (error) { await showError(error.message, { useMessageModal: true }); impactEl.textContent = 'Impact preview unavailable.'; }
    });
  });
  document.getElementById('changeSystemIdGenerate').addEventListener('click', async () => {
    clearError();
    try {
      const result = await readJson(await fetch('/school/students/' + encodeURIComponent(currentEl.value) + '/system-id-generate', { headers: { Accept: 'application/json', 'X-Ajax-Request': 'true' } }));
      if (result.actionStateId) actionStateId = result.actionStateId;
      newEl.value = result.data?.id || '';
      confirmationEl.value = '';
      newEl.focus();
    } catch (error) { await showError(error.message, { useMessageModal: true }); }
  });
  submitBtn.addEventListener('click', async () => {
    clearError();
    const newId = newEl.value.trim();
    const confirmationId = confirmationEl.value.trim();
    if (!newId || !/^[A-Za-z0-9_-]{1,40}$/.test(newId)) return showError('Enter a valid 1-40 character System Record ID using letters, numbers, underscores, or hyphens.');
    if (confirmationId !== newId) return showError('Confirmation must exactly match the replacement System Record ID.');
    submitBtn.disabled = true;
    const waitingToken = typeof window.showLoading === 'function'
      ? window.showLoading({ title: 'Changing Student System Record ID', message: 'Updating references and verifying the migration. Please wait...' })
      : null;
    try {
      const result = await readJson(await fetch('/school/students/' + encodeURIComponent(currentEl.value) + '/change-system-id', {
        method: 'POST', headers: { 'Content-Type': 'application/json', Accept: 'application/json', 'X-Ajax-Request': 'true' },
        body: JSON.stringify({ newId, confirmationId, actionStateId })
      }));
      window.location.href = result.redirectTo || result.data?.redirectTo || '/school/students';
    } catch (error) {
      await showError(error.message, { useMessageModal: true });
      submitBtn.disabled = false;
    } finally {
      if (waitingToken && typeof window.hideLoading === 'function') window.hideLoading(waitingToken);
    }
  });
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initializeChangeStudentSystemIdModal, { once: true });
} else {
  initializeChangeStudentSystemIdModal();
}
</script>
