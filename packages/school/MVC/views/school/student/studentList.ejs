<%- include('partials/tablePages-start', {
  title, newUrl, newLabel, user, tableName, btn_export: true, print,
  headerManageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>',
    '<a href="/dashboard/section-nav/SCHOOL_PEOPLE" class="school-navigator-dashboard btn btn-filled btn-secondary mb-2 btn-md"><i class="bi bi-people me-1"></i> People Dashboard</a>'
  ],
  manageBtns: [
    `<a href="/school/students/archived" class="btn btn-outline-warning btn-md mb-2"><i class="bi bi-arrow-counterclockwise me-1"></i> Recover Archived</a>`,
    '<button type="button" class="btn btn-outline-success btn-md mb-2" id="btnSyncStudentDenormalizedNames"><i class="bi bi-arrow-repeat me-1"></i> Sync Saved Names</button>'
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search students...',
  fields: [
      { name: 'academicStatus', label: 'Status', type: 'select', options: ['Active', 'Probation', 'Graduated', 'Withdrawn'] },
      { name: 'feeCategory', label: 'Fee Category', type: 'select', options: feeCategories || [] }
  ]
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Student Info</th>
        <th>Contact</th>
        <th>Fee Category</th>
        <th class="text-center">Status</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length === 0) { %>
         <tr><td colspan="5" class="text-center py-4 text-muted">No students found.</td></tr>
      <% } %>
      <% data.forEach(item => { %>
        <tr>
          <td class="ps-4">
              <div class="fw-bold text-primary">
                <%- include('../partials/studentNameLink', { name: `${item.firstName} ${item.lastName}`.trim(), studentRecordId: item.id, canOpenStudentProfile: typeof canOpenStudentProfile !== 'undefined' ? canOpenStudentProfile : false, linkClass: 'text-decoration-none' }) %>
              </div>
              <div class="small text-muted font-monospace"><i class="bi bi-person-badge me-1"></i><%= item.customStudentId || item.id %></div>
          </td>
          <td class="small text-muted">
              <div><i class="bi bi-envelope me-1"></i><%= item.email %></div>
              <div><i class="bi bi-telephone me-1"></i><%= item.phone %></div>
          </td>
          <td class="fw-bold text-dark"><%= item.feeCategory %></td>
          <td class="text-center">
             <% 
               let badge = 'bg-secondary';
               if(item.academicStatus === 'Active') badge = 'bg-success';
               if(item.academicStatus === 'Probation') badge = 'bg-warning text-dark';
               if(item.academicStatus === 'Graduated') badge = 'bg-primary';
               if(item.academicStatus === 'Withdrawn') badge = 'bg-danger';
               if(item.academicStatus === 'Archived') badge = 'bg-secondary';
             %>
             <span class="badge <%= badge %>"><%= item.academicStatus.toUpperCase() %></span>
          </td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= item.id %>"
                title="Student Actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                <a href="/school/students/edit/<%= item.id %>" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil-square me-2"></i>Edit</a>
                <button class="btn btn-outline-secondary btn-sm archive-btn" data-id="<%= item.id %>"><i class="bi bi-archive me-2"></i>Archive</button>
                <button class="btn btn-outline-danger btn-sm delete-btn" data-id="<%= item.id %>"><i class="bi bi-trash me-2"></i>Delete</button>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/students" hidden></span>
<%- include('partials/pagination', { pagination, filters, baseUrlPath: 'school/students' }) %>
<%- include('partials/tablePages-end') %>
<%- include('../partials/syncDenormalizedNamesManage', {
  syncDenormalizedLinkType: 'student',
  syncDenormalizedSectionLabel: 'Students',
  syncDenormalizedButtonId: 'btnSyncStudentDenormalizedNames',
  actionStateId
}) %>
