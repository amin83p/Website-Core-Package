      document.getElementById('inp_newPersonFirstName'),
      document.getElementById('inp_newPersonLastName'),
      document.getElementById('inp_newPersonGender'),
      document.getElementById('inp_newPersonDateOfBirth')
    ].filter(Boolean);

    if (selectedMode === 'new') {
      if (existingBlock) existingBlock.classList.add('d-none');
      if (newBlock) newBlock.classList.remove('d-none');
      if (personIdInput) personIdInput.required = false;
      if (personNameInput) personNameInput.required = false;
      newPersonRequiredFields.forEach((el) => { el.required = true; });
      return;
    }

    if (existingBlock) existingBlock.classList.remove('d-none');
    if (newBlock) newBlock.classList.add('d-none');
    if (personIdInput) personIdInput.required = true;
    if (personNameInput) personNameInput.required = true;
