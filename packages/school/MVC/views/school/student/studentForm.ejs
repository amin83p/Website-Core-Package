<%
  const s = student || {};
  const isEdit = !!s.id;
  const routeId = (s.id || s.personId || '');

  // actionStateId is injected by actionState middleware/controller (anti-tamper token)
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';

  // safe JSON for embedding into <script>
  const initAttachmentsJson = JSON.stringify(s.attachments || []).replace(/</g, '\\u003c');
  const initClbLevelHistoryJson = JSON.stringify(s.clbLevelHistory || []).replace(/</g, '\\u003c');
  const routeIdJson = JSON.stringify(routeId).replace(/</g, '\\u003c');
  const initPersonOrganizationsJson = JSON.stringify(typeof personOrganizations !== 'undefined' ? (personOrganizations || []) : []).replace(/</g, '\\u003c');
  const initOrganizationLookupJson = JSON.stringify(typeof organizationLookup !== 'undefined' ? (organizationLookup || {}) : {}).replace(/</g, '\\u003c');
  const entityDisplayName = String(typeof personName !== 'undefined' ? personName : '').trim() || 'Student';
  const entityRecordId = String(routeId || s.personId || '').trim();
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
      <h1 class="page-heading size-md m-0"><i class="bi bi-person-vcard me-2"></i><% if (isEdit) { %>Edit Student: <%= entityDisplayName %> <small class="text-muted fw-normal">(<%= entityRecordId %>)</small><% } else { %>Admit New Student<% } %></h1>
      <a href="/school/students" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back to List</a>
  </div>

  <div class="form-container wide" style="max-width: 1400px;">
    <form
      id="studentForm"
      action="<%= (isEdit ? '/school/students/edit/'+routeId : '/school/students/new') + (asid ? ('?actionStateId=' + encodeURIComponent(asid)) : '') %>"
      method="POST"
      enctype="multipart/form-data"
    >

      <!-- Existing attachments JSON (updated live when comments or deletions happen) -->
      <input type="hidden" name="attachments" id="hid_attachments" value="[]">
      <input type="hidden" name="clbLevelHistory" id="hid_clbLevelHistory" value="[]">

      <!-- ActionState anti-tamper token (required for edit/update when middleware is enabled) -->
      <input type="hidden" name="actionStateId" id="hid_actionStateId" value="<%= asid %>">
      <input type="hidden" name="newPersonEmails" id="hid_newPersonEmails" value="[]">
      <input type="hidden" name="newPersonPhones" id="hid_newPersonPhones" value="[]">
      <input type="hidden" name="newPersonAddresses" id="hid_newPersonAddresses" value="[]">
      <script type="application/json" id="init_personOrganizations"><%- initPersonOrganizationsJson %></script>
      <script type="application/json" id="init_organizationLookup"><%- initOrganizationLookupJson %></script>

      <ul class="nav nav-tabs mb-4" id="studentTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active fw-bold" data-bs-toggle="tab" data-bs-target="#tab-general" type="button">Step 1: Person</button></li>
        <li class="nav-item"><button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-financial" type="button">Step 2: Student</button></li>
        <li class="nav-item"><button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-documents" type="button">Step 3: Documents</button></li>
      </ul>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 tab-content">

           <div class="tab-pane fade show active" id="tab-general">
               <% if (!isEdit) { %>
                 <div class="alert alert-light border shadow-sm mb-4">
                   <div class="fw-bold mb-2"><i class="bi bi-person-plus me-2"></i>Person Source</div>
                   <div class="d-flex flex-wrap gap-4">
                     <div class="form-check">
                       <input class="form-check-input" type="radio" name="personMode" id="personModeExisting" value="existing" checked>
                       <label class="form-check-label fw-bold" for="personModeExisting">Use Existing Person</label>
                     </div>
                     <div class="form-check">
                       <input class="form-check-input" type="radio" name="personMode" id="personModeNew" value="new">
                       <label class="form-check-label fw-bold" for="personModeNew">Create New Person</label>
                     </div>
                   </div>
                 </div>
               <% } else { %>
                 <input type="hidden" name="personMode" value="existing">
               <% } %>

               <div id="existingPersonBlock">
               <div class="row">
                  <div class="col-md-8 mb-3">
                     <label class="form-label fw-bold">Select Person *</label>
                     <div class="input-group">
                        <input type="hidden" name="personId" id="inp_personId" value="<%= s.personId || '' %>" required>
                        <input type="text" id="inp_personName" class="form-control size-md bg-white border-primary fw-bold" placeholder="Search Person Directory..." value="<%= personName || '' %>" readonly required>
                        <button type="button" class="btn btn-primary" id="btnPickPerson" <%= isEdit ? 'disabled' : '' %>><i class="bi bi-search"></i></button>
                        <% if (canEditLinkedPerson) { %>
                        <button type="button" class="btn btn-outline-primary" id="btnEditPersonProfile" data-link-type="<%= linkedPersonLinkType || 'student' %>" data-link-id="<%= linkedPersonLinkId || '' %>" title="Edit person profile"><i class="bi bi-pencil-square"></i></button>
                        <% } %>
                     </div>
                     <div class="form-text small">Links this student profile to a global user identity.</div>
                  </div>
               </div>
               <div class="card border shadow-sm bg-light-subtle mb-3">
                 <div class="card-header bg-light fw-bold">
                   <i class="bi bi-diagram-3 me-2"></i>Current Person Role Composition
                 </div>
                 <div class="card-body" id="personRoleSummary"></div>
               </div>
               </div>

               <% if (!isEdit) { %>
               <div id="newPersonBlock" class="d-none">
                 <div class="card shadow-sm border-0 mb-3">
                   <div class="card-body">
                     <h6 class="fw-bold text-uppercase text-muted mb-3"><i class="bi bi-person-bounding-box me-2"></i>Profile & Identity</h6>
                     <div class="row g-3 mb-3">
                       <div class="col-md-4">
                         <label class="form-label fw-bold">First Name *</label>
                         <input type="text" name="newPersonFirstName" id="inp_newPersonFirstName" class="form-control size-md" placeholder="First name">
                       </div>
                       <div class="col-md-4">
                         <label class="form-label fw-bold">Middle Name</label>
                         <input type="text" name="newPersonMiddleName" id="inp_newPersonMiddleName" class="form-control size-md" placeholder="Middle name (optional)">
                       </div>
                       <div class="col-md-4">
                         <label class="form-label fw-bold">Last Name *</label>
                         <input type="text" name="newPersonLastName" id="inp_newPersonLastName" class="form-control size-md" placeholder="Last name">
                       </div>
                     </div>
                     <div class="row g-3 mb-3">
                       <div class="col-md-6">
                         <label class="form-label fw-bold">Preferred Name</label>
                         <input type="text" name="newPersonPreferredName" id="inp_newPersonPreferredName" class="form-control size-md" placeholder="Optional preferred name">
                       </div>
                       <div class="col-md-6">
                         <div class="form-check form-switch mt-4 pt-1">
                           <input class="form-check-input" type="checkbox" id="inp_newPersonActive" name="newPersonActive" checked>
                           <label class="form-check-label fw-bold" for="inp_newPersonActive">Active Person Profile</label>
                         </div>
                       </div>
                     </div>
                     <div class="row g-3">
                       <div class="col-md-6">
                         <label class="form-label fw-bold">Gender *</label>
                         <select name="newPersonGender" id="inp_newPersonGender" class="form-select size-md">
                           <option value="">-- Select Gender --</option>
                           <option value="male">Male</option>
                           <option value="female">Female</option>
                           <option value="nonbinary">Non-binary</option>
                           <option value="other">Other</option>
                         </select>
                       </div>
                       <div class="col-md-6">
                         <label class="form-label fw-bold">Date of Birth *</label>
                         <input type="date" name="newPersonDateOfBirth" id="inp_newPersonDateOfBirth" class="form-control size-md">
                       </div>
                     </div>
                   </div>
                 </div>

                 <div class="row g-3 mb-3">
                   <div class="col-lg-6">
                     <div class="card shadow-sm border-0 h-100">
                       <div class="card-header bg-light fw-bold text-uppercase small text-muted">
                         <i class="bi bi-envelope-paper me-2"></i>Communication
                       </div>
                       <div class="card-body">
                         <div class="d-flex justify-content-between align-items-center mb-2">
                           <label class="form-label mb-0 fw-bold">Email Addresses *</label>
                           <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddNewPersonEmail"><i class="bi bi-plus-lg"></i> Add</button>
                         </div>
                         <div id="newPersonEmailsList" class="mb-4"></div>

                         <hr class="text-muted opacity-25">

                         <div class="d-flex justify-content-between align-items-center mb-2">
                           <label class="form-label mb-0 fw-bold">Phone Numbers</label>
                           <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddNewPersonPhone"><i class="bi bi-plus-lg"></i> Add</button>
                         </div>
                         <div id="newPersonPhonesList"></div>
                       </div>
                     </div>
                   </div>
                   <div class="col-lg-6">
                     <div class="card shadow-sm border-0 h-100">
                       <div class="card-header bg-light fw-bold text-uppercase small text-muted">
                         <i class="bi bi-geo-alt me-2"></i>Addresses
                       </div>
                       <div class="card-body bg-light-subtle">
                         <div class="mb-3 position-relative">
                           <label class="form-label small fw-bold text-primary">
                             <i class="bi bi-search me-1"></i>Find Address (Canada)
                           </label>
                           <div class="input-group">
                             <input type="text" id="newPersonAddressSearchInput" class="form-control size-md" placeholder="Type street name..." autocomplete="off">
                             <button class="btn btn-outline-secondary" type="button" id="btnAddNewPersonAddressManual">Manual</button>
                           </div>
                           <div id="newPersonAddressSuggestions" class="list-group position-absolute w-100 shadow-lg" style="z-index: 1000; top: 100%; display: none;"></div>
                         </div>
                         <div id="newPersonAddressesList"></div>
                       </div>
                     </div>
                   </div>
                 </div>

                 <div class="row">
                   <div class="col-md-12 mb-3">
                     <label class="form-label fw-bold">Person Notes</label>
                     <textarea name="newPersonNotes" id="inp_newPersonNotes" class="form-control size-md" rows="2" placeholder="Optional internal notes for person profile..."></textarea>
                   </div>
                 </div>
               </div>
               <% } %>

               <div class="row">
                  <div class="col-md-4 mb-3">
                     <label class="form-label fw-bold">Custom Student ID</label>
                     <input type="text" name="studentId" class="form-control size-md font-monospace" placeholder="Auto-generated if blank" value="<%= s.id || '' %>" <%= isEdit ? 'readonly' : '' %>>
                  </div>
               </div>

               <div class="row">
                   <div class="col-md-6 mb-3">
                     <label class="form-label fw-bold">Local / National ID</label>
                     <input type="text" name="localId" class="form-control size-md" placeholder="e.g. SSN, Passport Number" value="<%= s.localId || '' %>">
                  </div>
                  <div class="col-md-6 mb-3">
                     <label class="form-label fw-bold">Country of Origin</label>
                     <select name="countryOfOrigin" class="form-select size-md">
                         <option value="">-- Select Country --</option>
                         <% countries.forEach(c => { %>
                             <option value="<%= c %>" <%= s.countryOfOrigin === c ? 'selected' : '' %>><%= c %></option>
                         <% }); %>
                     </select>
                  </div>
               </div>

               <div class="row">
                  <div class="col-md-6 mb-3">
                     <label class="form-label fw-bold">Admission Date *</label>
                     <input type="date" name="enrollmentDate" class="form-control size-md" value="<%= s.enrollmentDate || new Date().toISOString().split('T')[0] %>" required>
                  </div>
                  <div class="col-md-6 mb-3">
                     <label class="form-label fw-bold">Global Academic Status</label>
                     <select name="academicStatus" class="form-select size-md">
                        <% (academicStatuses || []).forEach(status => { %>
                          <option value="<%= status %>" <%= (s.academicStatus || 'Active') === status ? 'selected' : '' %>><%= status %></option>
                        <% }); %>
                     </select>
                  </div>
               </div>

               <div class="row mt-2">
                   <div class="col-12 mb-3">
                     <label class="form-label fw-bold">Admissions Notes</label>
                     <textarea name="notes" class="form-control size-md" rows="2" placeholder="Internal notes..."><%= s.notes || '' %></textarea>
                  </div>
               </div>

               <div class="card border-secondary shadow-sm mb-3">
                 <div class="card-header bg-light d-flex justify-content-between align-items-center">
                   <span class="fw-bold"><i class="bi bi-bar-chart-steps me-2"></i>CLB Levels</span>
                   <button type="button" class="btn btn-sm btn-outline-primary fw-bold" id="btnAddClbEntry">
                     <i class="bi bi-plus-lg me-1"></i>Add CLB Entry
                   </button>
                 </div>
                 <div class="card-body">
                   <p class="small text-muted mb-3">Track CLB goals and current levels over time. Each entry includes a goal row and a current-level row across Listening, Speaking, Reading, and Writing.</p>
                   <div id="clbHistoryEmpty" class="text-muted small text-center py-3 border rounded bg-light">No CLB entries yet. Click <strong>Add CLB Entry</strong> to record the first assessment.</div>
                   <div id="clbHistoryWrap" class="d-none">
                     <div class="table-responsive">
                       <table class="table table-sm table-bordered align-middle mb-0" id="clbHistoryTable">
                         <thead class="table-light">
                           <tr>
                             <th style="width: 12%;">Date</th>
                             <th style="width: 14%;">Row</th>
                             <th>Listening</th>
                             <th>Speaking</th>
                             <th>Reading</th>
                             <th>Writing</th>
                             <th style="width: 8%;" class="text-end">Actions</th>
                           </tr>
                         </thead>
                         <tbody id="clbHistoryTbody"></tbody>
                       </table>
                     </div>
                   </div>

                   <div id="clbEntryEditor" class="border rounded p-3 mt-3 bg-light d-none">
                     <div class="d-flex justify-content-between align-items-center mb-3">
                       <h6 class="fw-bold mb-0">New CLB Entry</h6>
                       <button type="button" class="btn btn-sm btn-outline-secondary" id="btnCancelClbEntry">Cancel</button>
                     </div>
                     <div class="row g-3 mb-3">
                       <div class="col-md-4">
                         <label class="form-label fw-bold small" for="inp_clbRecordedAt">Recorded Date *</label>
                         <input type="date" class="form-control form-control-sm" id="inp_clbRecordedAt">
                       </div>
                     </div>
                     <div class="table-responsive">
                       <table class="table table-sm table-bordered align-middle mb-3">
                         <thead class="table-light">
                           <tr>
                             <th style="width: 18%;">Row</th>
                             <th>Listening</th>
                             <th>Speaking</th>
                             <th>Reading</th>
                             <th>Writing</th>
                           </tr>
                         </thead>
                         <tbody>
                           <tr>
                             <td class="fw-bold small">CLB Goal</td>
                             <td><input type="text" class="form-control form-control-sm clb-editor-input" id="inp_clb_goal_listening" placeholder="e.g. 7-8" maxlength="20"></td>
                             <td><input type="text" class="form-control form-control-sm clb-editor-input" id="inp_clb_goal_speaking" placeholder="e.g. 7-8" maxlength="20"></td>
                             <td><input type="text" class="form-control form-control-sm clb-editor-input" id="inp_clb_goal_reading" placeholder="e.g. 6" maxlength="20"></td>
                             <td><input type="text" class="form-control form-control-sm clb-editor-input" id="inp_clb_goal_writing" placeholder="e.g. 6" maxlength="20"></td>
                           </tr>
                           <tr>
                             <td class="fw-bold small">Current CLB Level</td>
                             <td><input type="text" class="form-control form-control-sm clb-editor-input" id="inp_clb_current_listening" placeholder="e.g. 7+" maxlength="20"></td>
                             <td><input type="text" class="form-control form-control-sm clb-editor-input" id="inp_clb_current_speaking" placeholder="e.g. 7+" maxlength="20"></td>
                             <td><input type="text" class="form-control form-control-sm clb-editor-input" id="inp_clb_current_reading" placeholder="e.g. 6-" maxlength="20"></td>
                             <td><input type="text" class="form-control form-control-sm clb-editor-input" id="inp_clb_current_writing" placeholder="e.g. 5+" maxlength="20"></td>
                           </tr>
                         </tbody>
                       </table>
                     </div>
                     <button type="button" class="btn btn-sm btn-primary fw-bold" id="btnSaveClbEntry">Save CLB Entry</button>
                   </div>
                 </div>
               </div>
           </div>

           <div class="tab-pane fade" id="tab-financial">
               <div class="alert alert-info border-info shadow-sm mb-4">
                   <i class="bi bi-info-circle me-2"></i> These serve as the default settings for this student when enrolling in specific programs and classes.
               </div>
               <div class="row">
                  <div class="col-md-4 mb-3">
                     <label class="form-label fw-bold text-success"><i class="bi bi-cash-coin me-1"></i> Default Fee Category *</label>
                     <select name="feeCategory" class="form-select size-md border-success fw-bold" required>
                         <option value="" disabled <%= !s.feeCategory ? 'selected' : '' %>>-- Select Category --</option>
                         <% feeCategories.forEach(cat => { %>
                             <option value="<%= cat %>" <%= s.feeCategory === cat ? 'selected' : '' %>><%= cat %></option>
                         <% }); %>
                     </select>
                  </div>
               </div>
               <div class="row g-3 mb-1">
                  <div class="col-lg-4">
                     <div class="card border-success shadow-sm h-100" id="selfFundSection">
                        <div class="card-header bg-success-subtle text-success fw-bold text-uppercase small">
                           <i class="bi bi-person-check me-1"></i>Self-funded Student
                        </div>
                        <div class="card-body">
                           <div class="form-check form-switch">
                              <input class="form-check-input" type="checkbox" id="chk_selfFund" name="selfFund" value="true" <%= s.selfFund ? 'checked' : '' %>>
                              <label class="form-check-label fw-bold" for="chk_selfFund">This student is self-funded</label>
                           </div>
                           <div class="form-text small mt-2">Use this when the student pays directly and no external funder account should be linked.</div>
                        </div>
                     </div>
                  </div>
                  <div class="col-lg-8">
                     <div class="card border-primary shadow-sm h-100" id="fundedStudentSection">
                        <div class="card-header bg-primary-subtle text-primary fw-bold text-uppercase small">
                           <i class="bi bi-building me-1"></i>Funded Student
                        </div>
                        <div class="card-body">
                           <div class="mb-3">
                              <label class="form-label fw-bold">Funder Account</label>
                              <div class="input-group">
                                 <input type="hidden" name="funderAccountId" id="inp_funderAccountId" value="<%= s.funderAccountId || '' %>">
                                 <input type="text" id="inp_funderAccountName" class="form-control size-md bg-white border-primary fw-bold" value="<%= funderAccountName || '' %>" placeholder="Select account..." readonly>
                                 <button type="button" class="btn btn-primary" id="btnPickFunder"><i class="bi bi-search"></i></button>
                                 <button type="button" class="btn btn-outline-secondary" id="btnClearFunder">Clear</button>
                              </div>
                              <div class="form-text small">Pick the default funder account used for this student.</div>
                           </div>
                           <div class="mb-0">
                              <label class="form-label fw-bold">Student ID at Funder</label>
                              <input type="text" name="studentIdAtFunder" id="inp_studentIdAtFunder" class="form-control size-md" placeholder="External ID used by funder" value="<%= s.studentIdAtFunder || '' %>">
                              <div class="form-text small">Enabled only when a funder account is selected.</div>
                           </div>
                        </div>
                     </div>
                  </div>
               </div>
               <div class="row">
                  <div class="col-md-12 mb-3">
                     <label class="form-label fw-bold">Note</label>
                     <textarea name="funderNote" class="form-control size-md" rows="3" placeholder="Funding-related notes..."><%= s.funderNote || '' %></textarea>
                  </div>
               </div>
           </div>

           <div class="tab-pane fade" id="tab-documents">
               <div class="alert alert-light border shadow-sm">
                   <h6 class="fw-bold mb-2"><i class="bi bi-paperclip me-2"></i>Attached Documents</h6>
                   <p class="small text-muted mb-3">
                     Upload scans of Passports, Visas, Transcripts, or Letters here.
                     <span class="fw-bold">Max 5 files.</span> Add a short comment per file to find it faster later.
                   </p>

                   <!-- Existing Attachments (edit mode only) -->
                   <div id="existingAttachmentsWrap" class="mt-2 d-none">
                     <div class="fw-bold mb-2">Existing Attachments</div>
                     <div class="table-responsive">
                       <table class="table table-sm align-middle">
                         <thead>
                           <tr>
                             <th style="width: 30%;">File</th>
                             <th style="width: 45%;">Comment</th>
                             <th style="width: 25%;" class="text-end">Actions</th>
                           </tr>
                         </thead>
                         <tbody id="existingAttachmentsTbody"></tbody>
                       </table>
                     </div>
                   </div>

                   <!-- Upload box -->
                   <div
                     id="fileUploadBox"
                     class="p-4 border border-primary border-2 border-dashed rounded text-center bg-light mt-3"
                     style="cursor: pointer;"
                   >
                       <i class="bi bi-cloud-arrow-up fs-2 text-primary mb-2"></i>
                       <p class="mb-1 fw-bold">Click to Browse or Drag files here</p>
                       <p class="small text-muted mb-0" id="fileCountText">No files selected</p>
                   </div>

                   <!-- IMPORTANT: field name MUST match Multer route: .array('files', 5) -->
                   <input type="file" id="fileInput" name="files" multiple class="d-none">

                   <!-- New Uploads + comments -->
                   <div id="newFilesWrap" class="mt-3 d-none">
                     <div class="fw-bold mb-2">New Uploads (add a comment per file)</div>
                     <div class="table-responsive">
                       <table class="table table-sm align-middle">
                         <thead>
                           <tr>
                             <th style="width: 35%;">File</th>
                             <th style="width: 55%;">Comment</th>
                             <th style="width: 10%;" class="text-end"></th>
                           </tr>
                         </thead>
                         <tbody id="newFilesTbody"></tbody>
                       </table>
                     </div>
                   </div>

               </div>
           </div>

        </div>
      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="button" class="btn btn-outline-primary btn-md" id="btnWizardPrev">Back</button>
        <button type="button" class="btn btn-filled btn-primary btn-md fw-bold px-4" id="btnWizardNext">Next</button>
        <button type="submit" class="btn btn-filled btn-success btn-md fw-bold px-4 d-none" id="btnWizardSubmit">Save Profile</button>
        <a href="/school/students" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction" data-return-url="/school/students">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/modal_GenericPicker') %>
<%- include('../partials/personProfileEditModal') %>

<script>
  window.__INIT_STUDENT_ATTACHMENTS__ = <%- initAttachmentsJson %>;
  window.__INIT_CLB_LEVEL_HISTORY__ = <%- initClbLevelHistoryJson %>;
  window.__STUDENT_ROUTE_ID__ = <%- routeIdJson %>;
</script>

<script>
(function () {
  const MAX_FILES = 5;

  const form = document.getElementById('studentForm');
  const fileInput = document.getElementById('fileInput');
  const uploadBox = document.getElementById('fileUploadBox');
  const fileCountText = document.getElementById('fileCountText');

  const hidAttachments = document.getElementById('hid_attachments');
  const existingWrap = document.getElementById('existingAttachmentsWrap');
  const existingTbody = document.getElementById('existingAttachmentsTbody');

  const newWrap = document.getElementById('newFilesWrap');
  const newTbody = document.getElementById('newFilesTbody');
  const wizardTabTargets = ['#tab-general', '#tab-financial', '#tab-documents'];
