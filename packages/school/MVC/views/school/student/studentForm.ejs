  function getActiveTabTarget() {
    const activeBtn = document.querySelector('#studentTabs .nav-link.active');
    return activeBtn ? activeBtn.getAttribute('data-bs-target') : wizardTabTargets[0];
  }

  function validateCurrentWizardStep() {
    const currentTarget = wizardTabTargets[currentWizardStep];
    const currentPane = document.querySelector(currentTarget);
    if (!currentPane) return true;

    const controls = currentPane.querySelectorAll('input, select, textarea');
    for (const control of controls) {
      if (!control || control.disabled) continue;
      if (control.type === 'hidden') continue;
      if (!control.checkValidity()) {
        control.reportValidity();
        return false;
      }
    }

    if (currentTarget === '#tab-general') {
      const personMode = document.querySelector('input[name="personMode"]:checked')?.value || 'existing';
      if (personMode === 'new') {
        const validEmails = (newPersonEmails || []).filter((x) => String(x?.email || '').trim());
        if (!validEmails.length) {
          showMsg({
            title: 'Validation',
            icon: 'warning',
            message: 'At least one email is required for the new person.',
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
          return false;
        }
      }
    }

    return true;
  }

  function showWizardStep(index) {
    const safeIndex = Math.min(Math.max(index, 0), wizardTabTargets.length - 1);
    currentWizardStep = safeIndex;
    const target = wizardTabTargets[safeIndex];
    const btn = document.querySelector('#studentTabs [data-bs-target="' + target + '"]');
    if (btn) {
      const tab = new bootstrap.Tab(btn);
      tab.show();
    }
    updateWizardButtons();
  }

  function updateWizardButtons() {
    if (btnWizardPrev) btnWizardPrev.classList.toggle('d-none', currentWizardStep === 0);
    if (btnWizardNext) btnWizardNext.classList.toggle('d-none', currentWizardStep === wizardTabTargets.length - 1);
    if (btnWizardSubmit) btnWizardSubmit.classList.toggle('d-none', currentWizardStep !== wizardTabTargets.length - 1);
  }

  function syncHiddenAttachments() {
    hidAttachments.value = JSON.stringify(existingAttachments || []);
  }

  function sortClbHistory(entries) {
    return [...(Array.isArray(entries) ? entries : [])].sort((a, b) => {
      const dateCmp = String(b?.recordedAt || '').localeCompare(String(a?.recordedAt || ''));
      if (dateCmp !== 0) return dateCmp;
      return String(b?.id || '').localeCompare(String(a?.id || ''));
    });
  }

  function syncClbHiddenField() {
    if (hidClbLevelHistory) {
      hidClbLevelHistory.value = JSON.stringify(sortClbHistory(clbLevelHistory));
    }
  }

  function renderClbCell(value) {
    const text = String(value || '').trim();
    return text ? safeHtml(text) : '<span class="text-muted">—</span>';
  }

  function renderClbHistoryTable() {
    clbLevelHistory = sortClbHistory(clbLevelHistory);
    if (!clbHistoryTbody || !clbHistoryEmpty || !clbHistoryWrap) return;

    if (!clbLevelHistory.length) {
      clbHistoryEmpty.classList.remove('d-none');
      clbHistoryWrap.classList.add('d-none');
      clbHistoryTbody.innerHTML = '';
      syncClbHiddenField();
      return;
    }

    clbHistoryEmpty.classList.add('d-none');
    clbHistoryWrap.classList.remove('d-none');
    clbHistoryTbody.innerHTML = '';

    clbLevelHistory.forEach((entry) => {
      const entryId = String(entry?.id || '');
      const goalCells = CLB_SKILLS.map((skill) => `<td>${renderClbCell(entry?.goal?.[skill])}</td>`).join('');
      const currentCells = CLB_SKILLS.map((skill) => `<td>${renderClbCell(entry?.current?.[skill])}</td>`).join('');
      clbHistoryTbody.innerHTML += `
        <tr>
          <td rowspan="2" class="align-middle fw-semibold">${safeHtml(entry?.recordedAt || '')}</td>
          <td class="fw-bold small">CLB Goal</td>
          ${goalCells}
          <td rowspan="2" class="text-end align-middle">
            <button type="button" class="btn btn-sm btn-outline-danger btn-remove-clb-entry" data-entry-id="${safeHtml(entryId)}" title="Remove entry">
              <i class="bi bi-trash"></i>
            </button>
          </td>
        </tr>
        <tr>
          <td class="fw-bold small">Current CLB Level</td>
          ${currentCells}
        </tr>
      `;
    });

    clbHistoryTbody.querySelectorAll('.btn-remove-clb-entry').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const entryId = btn.getAttribute('data-entry-id') || '';
        const confirmed = await confirmDelete('Remove this CLB entry from the student profile?');
        if (!confirmed) return;
        clbLevelHistory = clbLevelHistory.filter((row) => String(row?.id || '') !== entryId);
        renderClbHistoryTable();
      });
    });

    syncClbHiddenField();
  }

  function clearClbEditor() {
    if (inpClbRecordedAt) inpClbRecordedAt.value = new Date().toISOString().slice(0, 10);
    CLB_SKILLS.forEach((skill) => {
      const goalInput = document.getElementById(`inp_clb_goal_${skill}`);
      const currentInput = document.getElementById(`inp_clb_current_${skill}`);
      if (goalInput) goalInput.value = '';
      if (currentInput) currentInput.value = '';
    });
  }

  function showClbEditor() {
    clearClbEditor();
    if (clbEntryEditor) clbEntryEditor.classList.remove('d-none');
  }

  function hideClbEditor() {
    if (clbEntryEditor) clbEntryEditor.classList.add('d-none');
  }

  function collectClbEditorEntry() {
    const recordedAt = String(inpClbRecordedAt?.value || '').trim();
    if (!recordedAt) throw new Error('Recorded date is required for a CLB entry.');
    const goal = {};
    const current = {};
    CLB_SKILLS.forEach((skill) => {
      goal[skill] = String(document.getElementById(`inp_clb_goal_${skill}`)?.value || '').trim();
      current[skill] = String(document.getElementById(`inp_clb_current_${skill}`)?.value || '').trim();
    });
    const hasAnyValue = CLB_SKILLS.some((skill) => goal[skill] || current[skill]);
    if (!hasAnyValue) throw new Error('Enter at least one CLB goal or current level value.');
    return {
      id: `clb_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`,
      recordedAt,
      goal,
      current
    };
  }

  function saveClbEntryFromEditor() {
    const entry = collectClbEditorEntry();
    clbLevelHistory.push(entry);
    renderClbHistoryTable();
    hideClbEditor();
  }

  function wireClbLevelHistoryUi() {
    if (btnAddClbEntry) btnAddClbEntry.addEventListener('click', showClbEditor);
    if (btnCancelClbEntry) btnCancelClbEntry.addEventListener('click', hideClbEditor);
    if (btnSaveClbEntry) {
      btnSaveClbEntry.addEventListener('click', () => {
        try {
          saveClbEntryFromEditor();
        } catch (err) {
          showMsg({
            title: 'CLB Entry',
            icon: 'warning',
            message: err.message || 'Unable to save CLB entry.',
            buttons: [{ text: 'OK', class: 'btn-primary' }]
          });
        }
      });
    }
    renderClbHistoryTable();
  }

  // Robust confirm helper that works with showMessageModal if present.
  // We do NOT rely on the modal's return value (different implementations return different shapes).
  async function confirmDelete(htmlMessage) {
    if (typeof showMessageModal !== 'function') {
      // fall back to native confirm (plain text)
      const plain = String(htmlMessage || '').replace(/<[^>]*>/g, '');
      return confirm(plain);
    }

    return await new Promise((resolve) => {
      let resolved = false;
      try {
        showMessageModal({
          title: 'Confirm',
          icon: 'warning',
          message: htmlMessage,
          buttons: [
            { text: 'Cancel', class: 'btn-secondary', onClick: () => { if (!resolved) { resolved = true; resolve(false); } } },
            { text: 'Delete', class: 'btn-danger', onClick: () => { if (!resolved) { resolved = true; resolve(true); } } }
          ]
        });
      } catch (e) {
        // As a last resort, don't block the UI.
        resolve(false);
      }
    });
  }

  async function deleteAttachment(attKey) {
    const actionStateId = document.getElementById('hid_actionStateId')?.value || '';
    const url = `/school/students/${encodeURIComponent(studentRouteId)}/attachments/${encodeURIComponent(attKey)}?actionStateId=${encodeURIComponent(actionStateId)}`;

    const resp = await fetch(url, {
      method: 'DELETE',
      headers: { 'X-AJAX-Request': 'true' }
    });

    const result = await resp.json().catch(() => null);
    if (!resp.ok || !result || result.status !== 'success') {
      throw new Error(result?.message || `Delete failed (HTTP ${resp.status})`);
    }

    existingAttachments = Array.isArray(result.attachments) ? result.attachments : [];
    syncHiddenAttachments();
    renderExisting();
  }

  function renderExisting() {
    if (!studentRouteId || !existingAttachments || existingAttachments.length === 0) {
      existingWrap.classList.add('d-none');
      existingTbody.innerHTML = '';
      syncHiddenAttachments();
      return;
    }

    existingWrap.classList.remove('d-none');

    existingTbody.innerHTML = existingAttachments.map((a, idx) => {
      const key = a.id || idx; // can be string id or numeric index
      const fileLabel = safeHtml(a.originalName || a.filename || '(file)');
      const comment = safeHtml(a.comment || '');
      const sizeText = safeHtml(formatBytes(a.size));

      const dl = `/school/students/${encodeURIComponent(studentRouteId)}/attachments/${encodeURIComponent(key)}/download`;

      return `
        <tr>
          <td>
            <div class="fw-bold">${fileLabel}</div>
            <div class="text-muted small">${sizeText}</div>
          </td>
          <td>
            <input
              type="text"
              class="form-control form-control-sm"
              value="${comment}"
              placeholder="e.g. Passport scan, Visa, Transcript..."
              data-existing-index="${idx}"
            >
          </td>
          <td class="text-end">
            <div class="d-flex gap-2 justify-content-end">
              <a class="btn btn-outline-primary btn-sm" href="${dl}">
                <i class="bi bi-download me-1"></i>Download
              </a>
              <button type="button" class="btn btn-outline-danger btn-sm" data-delete-att="${key}">
                <i class="bi bi-trash me-1"></i>Delete
              </button>
            </div>
          </td>
        </tr>
      `;
    }).join('');

    // Update comment edits => saved on next Save
    existingTbody.querySelectorAll('input[data-existing-index]').forEach(inp => {
      inp.addEventListener('input', (e) => {
        const i = Number(e.target.getAttribute('data-existing-index'));
        if (!Number.isNaN(i) && existingAttachments[i]) {
          existingAttachments[i].comment = e.target.value || '';
          syncHiddenAttachments();
        }
      });
    });

    // Delete buttons
    existingTbody.querySelectorAll('button[data-delete-att]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const key = btn.getAttribute('data-delete-att');

        // Key can be either an attachment id or an index; find best-effort label for the confirm dialog
        const a = existingAttachments.find(x => String(x?.id) === String(key)) || null;
        const label = a?.originalName || a?.filename || 'this file';

        const ok = await confirmDelete(
          `Delete <b>"${safeHtml(label)}"</b>?<br>` +
          `This will remove it from the student record and delete the file from disk.<br>` +
          `<b>No undo will be available for this operation.</b>`
        );
        if (!ok) return;

        btn.disabled = true;
        try {
          await deleteAttachment(key);
          await showMsg({
            title: 'Deleted',
            icon: 'success',
            message: 'Attachment deleted.',
            buttons: [{ text: 'OK', class: 'btn-success' }]
          });
        } catch (err) {
          btn.disabled = false;
          await showMsg({
            title: 'Error',
            icon: 'error',
            message: err.message || 'Failed to delete attachment.',
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        }
      });
    });

    syncHiddenAttachments();
  }

  function enforceMaxFiles() {
    const files = Array.from(fileInput.files || []);
    if (files.length <= MAX_FILES) return;

    const dt = new DataTransfer();
    files.slice(0, MAX_FILES).forEach(f => dt.items.add(f));
    fileInput.files = dt.files;

    showMsg({
      title: 'Too many files',
      icon: 'warning',
      message: `You can upload up to ${MAX_FILES} files. Extra files were ignored.`,
      buttons: [{ text: 'OK', class: 'btn-warning' }]
    });
  }

  function renderNewFiles() {
    const files = Array.from(fileInput.files || []);
    clearNewFileObjectUrls();
    if (files.length === 0) {
      newWrap.classList.add('d-none');
      newTbody.innerHTML = '';
      fileCountText.innerText = 'No files selected';
      uploadBox.classList.remove('bg-success', 'bg-opacity-10', 'border-success');
      return;
    }

    newWrap.classList.remove('d-none');
    fileCountText.innerHTML = `<span class="text-success fw-bold">${files.length} file(s) selected ready for upload.</span>`;
    uploadBox.classList.add('bg-success', 'bg-opacity-10', 'border-success');

    newTbody.innerHTML = files.map((f, idx) => `
      <tr>
        <td>
          <div class="fw-bold">${safeHtml(f.name)}</div>
          <div class="text-muted small">${safeHtml(formatBytes(f.size))}</div>
        </td>
        <td>
          <input
            type="text"
            class="form-control form-control-sm"
            name="newFileComments"
            placeholder="Comment for this file..."
            data-new-index="${idx}"
          >
        </td>
        <td class="text-end">
          <div class="d-inline-flex gap-1">
            ${(() => {
              let downloadUrl = '';
              try {
                downloadUrl = window.URL.createObjectURL(f);
              } catch (_) {
                downloadUrl = '';
              }
              if (downloadUrl) newFileObjectUrls.push(downloadUrl);
              if (!downloadUrl) return '';
              return `
                <a href="${safeHtml(downloadUrl)}" download="${safeHtml(f.name)}" class="btn btn-outline-primary btn-sm" title="Download">
                  <i class="bi bi-download"></i>
                </a>
              `;
            })()}
            <button type="button" class="btn btn-outline-danger btn-sm" data-remove-new="${idx}">
              <i class="bi bi-x-lg"></i>
            </button>
          </div>
        </td>
      </tr>
    `).join('');

    newTbody.querySelectorAll('button[data-remove-new]').forEach(btn => {
      btn.addEventListener('click', () => {
        const idx = Number(btn.getAttribute('data-remove-new'));
        const filesArr = Array.from(fileInput.files || []);
        if (Number.isNaN(idx) || idx < 0 || idx >= filesArr.length) return;

        const dt = new DataTransfer();
        filesArr.forEach((f, i) => { if (i !== idx) dt.items.add(f); });
        fileInput.files = dt.files;
        renderNewFiles();
      });
    });
  }

  function handleFilesChanged() {
    enforceMaxFiles();
    renderNewFiles();
  }

  // Click to browse
  uploadBox.addEventListener('click', () => fileInput.click());

  // Drag & drop
  uploadBox.addEventListener('dragover', (e) => {
    e.preventDefault();
    uploadBox.classList.add('border-success');
  });
  uploadBox.addEventListener('dragleave', () => uploadBox.classList.remove('border-success'));
  uploadBox.addEventListener('drop', (e) => {
    e.preventDefault();
    uploadBox.classList.remove('border-success');

    const dt = new DataTransfer();
    const dropped = Array.from(e.dataTransfer.files || []);
    dropped.slice(0, MAX_FILES).forEach(f => dt.items.add(f));
    fileInput.files = dt.files;

    handleFilesChanged();
  });

  fileInput.addEventListener('change', handleFilesChanged);
  window.addEventListener('beforeunload', clearNewFileObjectUrls);

  document.addEventListener('DOMContentLoaded', () => {
    // Wire up Person Picker
    const pBtn = document.getElementById('btnPickPerson');
    if (pBtn && !pBtn.disabled) {
      pBtn.addEventListener('click', () => {
        GenericPicker.open(GenericPickerPresets.person({
          title: 'Select Person',
          apiEndpoint: '/school/students/api/eligible-persons',
          placeholder: 'Search by name or email...',
          onSelect: (item) => {
            if (item?.alreadyHasSchoolAccount) {
              const linked = item.linkedSchoolAccount || {};
              const targetUrl = linked.archived ? linked.recoveryUrl : linked.editUrl;
              showMsg({
                title: 'Student Already Exists',
                icon: 'warning',
                message: `This person already has a Student account in the active organization.${targetUrl ? `<br><br><a href="${targetUrl}" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">Open existing Student record</a>` : ''}`,
                buttons: [{ text: 'Close', class: 'btn-secondary' }]
              });
              return;
            }
            document.getElementById('inp_personId').value = item.id;
            document.getElementById('inp_personName').value = `${item.name?.first || ''} ${item.name?.last || ''}`.trim() || item.id;
            selectedPersonOrganizations = Array.isArray(item.organizations) ? item.organizations : [];
            renderPersonRoleSummary();
            refreshEditPersonButton();
            const modeExisting = document.getElementById('personModeExisting');
            if (modeExisting) {
              modeExisting.checked = true;
              syncPersonModeUI();
            }
          }
        }));
      });
    }

    const modeExisting = document.getElementById('personModeExisting');
    const modeNew = document.getElementById('personModeNew');
    if (modeExisting) modeExisting.addEventListener('change', () => { syncPersonModeUI(); refreshEditPersonButton(); });
    if (modeNew) modeNew.addEventListener('change', () => { syncPersonModeUI(); refreshEditPersonButton(); });

    function refreshEditPersonButton() {
      const btnEditPerson = document.getElementById('btnEditPersonProfile');
      if (!btnEditPerson || !window.SchoolPersonProfileModal) return;
      const personId = document.getElementById('inp_personId')?.value?.trim();
      const personModeExisting = !modeExisting || modeExisting.checked;
      window.SchoolPersonProfileModal.updateEditButtonState(btnEditPerson, { personId, personModeExisting });
    }

    const btnEditPerson = document.getElementById('btnEditPersonProfile');
    if (btnEditPerson && window.SchoolPersonProfileModal) {
      btnEditPerson.addEventListener('click', () => {
        const personId = document.getElementById('inp_personId')?.value?.trim();
        if (!personId) return;
        window.SchoolPersonProfileModal.open({
          personId,
          linkType: btnEditPerson.dataset.linkType || 'student',
          linkId: btnEditPerson.dataset.linkId || '',
          organizationLookup,
          onSaved: ({ displayName, organizations: nextOrganizations }) => {
            if (displayName) document.getElementById('inp_personName').value = displayName;
            selectedPersonOrganizations = Array.isArray(nextOrganizations) ? nextOrganizations : [];
            renderPersonRoleSummary();
          }
        });
      });
    }

    const selfFundToggle = document.getElementById('chk_selfFund');
    if (selfFundToggle) selfFundToggle.addEventListener('change', syncFunderDependentFields);

    const funderBtn = document.getElementById('btnPickFunder');
    const funderClearBtn = document.getElementById('btnClearFunder');
    if (funderBtn) {
      funderBtn.addEventListener('click', () => {
        GenericPicker.open(GenericPickerPresets.account({
          title: 'Select Funder Account',
          icon: 'bi-diagram-2',
          placeholder: 'Search by account code or name...',
          onSelect: (item) => {
            document.getElementById('inp_funderAccountId').value = item.id || '';
            const code = String(item.code || '').trim();
            const name = String(item.name || '').trim();
            document.getElementById('inp_funderAccountName').value = (code && name) ? `${code} - ${name}` : (name || code || item.id || '');
            syncFunderDependentFields();
          }
        }));
      });
    }
    if (funderClearBtn) {
      funderClearBtn.addEventListener('click', () => {
        document.getElementById('inp_funderAccountId').value = '';
        document.getElementById('inp_funderAccountName').value = '';
        syncFunderDependentFields();
      });
    }

    if (btnAddNewPersonEmail) {
      btnAddNewPersonEmail.addEventListener('click', () => {
        newPersonEmails.push({ type: 'work', email: '', isPrimary: false });
        renderNewPersonEmails();
      });
    }
    if (btnAddNewPersonPhone) {
      btnAddNewPersonPhone.addEventListener('click', () => {
        newPersonPhones.push({ type: 'mobile', number: '' });
        renderNewPersonPhones();
      });
    }
    if (btnAddNewPersonAddressManual) {
      btnAddNewPersonAddressManual.addEventListener('click', () => {
        newPersonAddresses.push({ type: 'home', line1: '', city: '', province: '', postalCode: '' });
        renderNewPersonAddresses();
      });
    }
    if (newPersonAddressSearchInput && newPersonAddressSuggestions) {
      newPersonAddressSearchInput.addEventListener('input', () => {
        const query = newPersonAddressSearchInput.value.trim();
        clearTimeout(newPersonAddressDebounceTimer);
        if (query.length < 3) {
          newPersonAddressSuggestions.style.display = 'none';
          return;
        }

        newPersonAddressDebounceTimer = setTimeout(async () => {
          try {
            newPersonAddressSuggestions.innerHTML = '<div class="list-group-item text-muted"><span class="spinner-border spinner-border-sm me-2"></span>Searching...</div>';
            newPersonAddressSuggestions.style.display = 'block';

            const url = 'https://nominatim.openstreetmap.org/search?format=json&q=' + encodeURIComponent(query) + '&countrycodes=ca&addressdetails=1&limit=5';
            const res = await fetch(url);
            const data = await res.json();

            newPersonAddressSuggestions.innerHTML = '';
            if (!Array.isArray(data) || !data.length) {
              newPersonAddressSuggestions.innerHTML = '<div class="list-group-item text-muted">No results found.</div>';
              return;
            }

            data.forEach((item) => {
              const addr = item.address || {};
              const display = item.display_name || '';
              const btn = document.createElement('button');
              btn.type = 'button';
              btn.className = 'list-group-item list-group-item-action text-start small';
              btn.innerHTML = '<i class="bi bi-geo-alt me-2 text-primary"></i>' + safeHtml(display);
              btn.addEventListener('click', () => {
                newPersonAddresses.push({
                  type: 'home',
                  line1: ((addr.house_number || '') + ' ' + (addr.road || '')).trim() || String(display).split(',')[0] || '',
                  city: addr.city || addr.town || addr.village || '',
                  province: addr.state || '',
                  postalCode: addr.postcode || ''
                });
                renderNewPersonAddresses();
                newPersonAddressSearchInput.value = '';
                newPersonAddressSuggestions.style.display = 'none';
              });
              newPersonAddressSuggestions.appendChild(btn);
            });
          } catch (error) {
            newPersonAddressSuggestions.style.display = 'none';
          }
        }, 500);
      });

      document.addEventListener('click', (e) => {
        if (!newPersonAddressSearchInput.contains(e.target) && !newPersonAddressSuggestions.contains(e.target)) {
          newPersonAddressSuggestions.style.display = 'none';
        }
      });
    }

    const activeTarget = getActiveTabTarget();
    currentWizardStep = Math.max(0, wizardTabTargets.indexOf(activeTarget));
    updateWizardButtons();

    document.querySelectorAll('#studentTabs .nav-link').forEach((tabBtn) => {
      tabBtn.addEventListener('shown.bs.tab', () => {
        const shownTarget = getActiveTabTarget();
        currentWizardStep = Math.max(0, wizardTabTargets.indexOf(shownTarget));
        updateWizardButtons();
      });
    });

    if (btnWizardPrev) {
      btnWizardPrev.addEventListener('click', () => {
        showWizardStep(currentWizardStep - 1);
      });
    }
    if (btnWizardNext) {
      btnWizardNext.addEventListener('click', () => {
        if (!validateCurrentWizardStep()) return;
        showWizardStep(currentWizardStep + 1);
      });
    }

    // SMART TAB VALIDATION SWITCHER
    form.addEventListener('invalid', function(e) {
      const invalidField = e.target;
      const tabPane = invalidField.closest('.tab-pane');
      if (tabPane) {
        const tabId = tabPane.id;
        const tabButton = document.querySelector(`[data-bs-target="#${tabId}"]`);
        if (tabButton) {
          const tab = new bootstrap.Tab(tabButton);
          tab.show();
          currentWizardStep = Math.max(0, wizardTabTargets.indexOf('#' + tabId));
          updateWizardButtons();
          setTimeout(() => invalidField.focus(), 200);
        }
      }
    }, true);

    // Submit with real multipart FormData (files work)
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

      try {
        if (currentWizardStep !== wizardTabTargets.length - 1) {
          if (!validateCurrentWizardStep()) {
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;
            return;
          }
          showWizardStep(currentWizardStep + 1);
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
          return;
        }

        if (!validateCurrentWizardStep()) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
          return;
        }

        const personMode = document.querySelector('input[name="personMode"]:checked')?.value || 'existing';
        if (personMode === 'existing') {
          const personId = document.getElementById('inp_personId').value?.trim();
          if (!personId) throw new Error('Please select a Person before saving.');
        } else {
          const firstName = document.getElementById('inp_newPersonFirstName')?.value?.trim();
          const lastName = document.getElementById('inp_newPersonLastName')?.value?.trim();
          const gender = document.getElementById('inp_newPersonGender')?.value?.trim();
          const dob = document.getElementById('inp_newPersonDateOfBirth')?.value?.trim();
          const emails = (newPersonEmails || []).filter((x) => String(x?.email || '').trim());
          if (!firstName || !lastName || !gender || !dob) {
            throw new Error('Please complete all required New Person fields.');
          }
          if (!emails.length) {
            throw new Error('At least one email is required for the new person.');
          }
        }

        syncHiddenAttachments();
        syncClbHiddenField();
        syncNewPersonHiddenState();

        // Build FormData manually so fields go first, files last
        const fd = new FormData();
        const elements = Array.from(form.elements);

        for (const el of elements) {
          if (!el || !el.name || el.disabled) continue;
          if (el.type === 'file') continue;
          if ((el.type === 'checkbox' || el.type === 'radio') && !el.checked) continue;
          fd.append(el.name, el.value ?? '');
        }

        const files = Array.from(fileInput.files || []);
        files.forEach(f => fd.append('files', f));

        const submitUrl = (() => {
          const token = document.getElementById('hid_actionStateId')?.value || '';
          if (!token) return form.action;
          const hasToken = /[?&]actionStateId=/.test(String(form.action || ''));
          if (hasToken) return form.action;
          return String(form.action || '') + (String(form.action || '').includes('?') ? '&' : '?') + 'actionStateId=' + encodeURIComponent(token);
        })();

        const response = await fetch(submitUrl, {
          method: 'POST',
          headers: { 'X-AJAX-Request': 'true' },
          body: fd
        });

        const contentType = response.headers.get('content-type') || '';
        if (!contentType.includes('application/json')) {
          throw new Error(`Server returned non-JSON response (Status ${response.status})`);
        }

        const result = await response.json();
        const guarded = typeof window.applyGuardedApiResult === 'function'
          ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Processed' })
          : { stop: false };
        if (guarded.stop) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
          return;
        }

        await showMsg({
          title: result.status === 'success' ? 'Success' : 'Error',
          icon: result.status === 'success' ? 'success' : 'error',
          message: result.message || 'Operation completed.',
          buttons: [{ text: 'OK', class: result.status === 'success' ? 'btn-success' : 'btn-danger' }]
        });

        if (result.status === 'success') {
          const autoAcc = result?.autoCreatedAccount || null;
          if (autoAcc && autoAcc.id) {
            const studentName = safeHtml(autoAcc.studentName || 'the student');
            const accountCode = safeHtml(autoAcc.code || '-');
            const accountName = safeHtml(autoAcc.name || '-');
            const accountRole = safeHtml(autoAcc.partyRole || 'student');
            const accountType = safeHtml(autoAcc.type || '-');
            const accountLevel = safeHtml(autoAcc.level || '-');

            const recheck = await askYesNo({
              title: 'Student Account Created',
              message:
                `The account was saved as follows:<br>` +
                `<b>Code:</b> ${accountCode}<br>` +
                `<b>Name:</b> ${accountName}<br>` +
                `<b>Role:</b> ${accountRole}<br>` +
                `<b>Type:</b> ${accountType}<br>` +
                `<b>Level:</b> ${accountLevel}<br><br>` +
                `Do you want to recheck the account we created for ${studentName}?`,
              yesText: 'Yes, open account',
              noText: 'No'
            });

            if (recheck) {
              window.location.href = autoAcc.editUrl || `/school/accounts/edit/${encodeURIComponent(String(autoAcc.id))}`;
              return;
            }
          }
          window.location.href = '/school/students';
        } else {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
        }
      } catch (error) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;

        await showMsg({
          title: 'System Error',
          icon: 'error',
          message: error.message || 'An unexpected network error occurred.',
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
      }
    });

    // Init
    newPersonEmails = readJsonSafe(hidNewPersonEmails?.value, [{ type: 'primary', email: '', isPrimary: true }]);
    newPersonPhones = readJsonSafe(hidNewPersonPhones?.value, []);
    newPersonAddresses = readJsonSafe(hidNewPersonAddresses?.value, []);
    if (!Array.isArray(newPersonEmails) || !newPersonEmails.length) {
      newPersonEmails = [{ type: 'primary', email: '', isPrimary: true }];
    }
    if (!Array.isArray(newPersonPhones)) newPersonPhones = [];
    if (!Array.isArray(newPersonAddresses)) newPersonAddresses = [];

    renderNewPersonEmails();
    renderNewPersonPhones();
    renderNewPersonAddresses();
    renderExisting();
    renderNewFiles();
    renderPersonRoleSummary();
    syncFunderDependentFields();
    syncPersonModeUI();
    syncNewPersonHiddenState();
    wireClbLevelHistoryUi();
    refreshEditPersonButton();
  });
})();
</script>
