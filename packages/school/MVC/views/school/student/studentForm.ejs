    if (!funderIdInput || !funderStudentIdInput) return;

    const isSelfFund = Boolean(selfFundCheckbox?.checked);
    if (isSelfFund) {
      funderIdInput.value = '';
      if (funderNameInput) funderNameInput.value = '';
      funderStudentIdInput.value = '';
    }

    const hasFunder = Boolean(funderIdInput.value?.trim());
    funderStudentIdInput.disabled = isSelfFund || !hasFunder;
    if (funderPickBtn) funderPickBtn.disabled = isSelfFund;
    if (funderClearBtn) funderClearBtn.disabled = isSelfFund;
    if (fundedSection) fundedSection.classList.toggle('opacity-50', isSelfFund);
    if (!hasFunder) funderStudentIdInput.value = '';
