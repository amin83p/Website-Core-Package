  function safeHtml(s) {
    return String(s ?? '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
  }

  function formatBytes(bytes) {
    if (bytes === undefined || bytes === null) return '';
    const units = ['B','KB','MB','GB'];
    let i = 0;
    let n = bytes;
    while (n >= 1024 && i < units.length - 1) { n /= 1024; i++; }
    return `${n.toFixed(i === 0 ? 0 : 1)} ${units[i]}`;
  }

  function clearNewFileObjectUrls() {
    if (!newFileObjectUrls.length) return;
    newFileObjectUrls.forEach((url) => {
      try {
        window.URL.revokeObjectURL(url);
      } catch (_) {}
    });
    newFileObjectUrls = [];
  }

  function showMsg(opts) {
    if (typeof showMessageModal === 'function') return showMessageModal(opts);
    alert(opts?.message || 'Done');
    return Promise.resolve();
  }

  async function askYesNo(opts = {}) {
    const title = String(opts.title || 'Confirm');
    const message = String(opts.message || 'Are you sure?');
    const yesText = String(opts.yesText || 'Yes');
    const noText = String(opts.noText || 'No');

    if (typeof showMessageModal !== 'function') {
      const plain = message.replace(/<br\s*\/?>/gi, '\n').replace(/<[^>]+>/g, '');
      return Promise.resolve(confirm(plain));
    }

    return new Promise((resolve) => {
      try {
        showMessageModal({
          title,
          icon: 'question',
          message,
          buttons: [
            { text: noText, class: 'btn-secondary' },
            { text: yesText, class: 'btn-primary' }
          ]
        }).then((result) => resolve(result === yesText)).catch(() => resolve(false));
      } catch (_) {
        resolve(false);
      }
    });
  }

  function readJsonSafe(rawValue, fallback) {
    if (!rawValue) return fallback;
    try {
      const parsed = JSON.parse(rawValue);
      return parsed;
    } catch {
      return fallback;
    }
  }

  function syncNewPersonHiddenState() {
    if (hidNewPersonEmails) hidNewPersonEmails.value = JSON.stringify(newPersonEmails);
    if (hidNewPersonPhones) hidNewPersonPhones.value = JSON.stringify(newPersonPhones);
    if (hidNewPersonAddresses) hidNewPersonAddresses.value = JSON.stringify(newPersonAddresses);
  }

  function formatRoleLabel(roleValue) {
    return String(roleValue || '')
      .split('_')
      .map((part) => part ? part[0].toUpperCase() + part.slice(1) : '')
      .join(' ');
  }

  function normalizePersonRoles(org) {
    if (window.SchoolRoleDisplay && typeof window.SchoolRoleDisplay.filterSchoolPackageOrgRoles === 'function') {
      return window.SchoolRoleDisplay.filterSchoolPackageOrgRoles(org);
    }
    const rawRoles = Array.isArray(org?.roles) && org.roles.length
      ? org.roles
      : (org?.role ? [org.role] : []);
    return Array.from(new Set(rawRoles.map((role) => String(role || '').trim()).filter(Boolean)))
      .filter((role) => /^school_(student|teacher|staff)$/i.test(String(role || '').trim()));
  }

  function getOrganizationDisplayName(org) {
    const direct = String(org?.orgName || org?.name || org?.organizationName || '').trim();
    if (direct) return direct;
    const id = String(org?.orgId || '').trim();
    if (id && organizationLookup && Object.prototype.hasOwnProperty.call(organizationLookup, id)) {
      return String(organizationLookup[id] || '').trim() || id;
    }
    return id || 'Unknown Organization';
  }

  function renderPersonRoleSummary() {
    if (!personRoleSummary) return;

    const orgs = Array.isArray(selectedPersonOrganizations) ? selectedPersonOrganizations : [];
    if (!orgs.length) {
      personRoleSummary.innerHTML = '<div class="text-muted small">No organization role assignments are available for the selected person yet.</div>';
      return;
    }

    personRoleSummary.innerHTML = orgs.map((org) => {
      const orgLabel = safeHtml(getOrganizationDisplayName(org));
      const roles = normalizePersonRoles(org);
      const roleBadges = roles.length
        ? roles.map((role) => `<span class="badge text-bg-primary-subtle text-primary-emphasis border me-1 mb-1">${safeHtml(formatRoleLabel(role))}</span>`).join('')
        : '<span class="text-muted small">No school roles assigned</span>';

      return (
        '<div class="border rounded p-3 mb-2 bg-white">' +
          `<div class="fw-bold">${orgLabel}</div>` +
          `<div class="small text-muted mb-2">Org ID: ${safeHtml(org?.orgId || '-')}</div>` +
          `<div>${roleBadges}</div>` +
        '</div>'
      );
    }).join('');
  }

