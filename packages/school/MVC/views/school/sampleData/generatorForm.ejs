  async function loadOrgWorkspaceResetPreview() {
    if (!workspaceResetPreviewModalContentEl) return null;
    workspaceResetPreviewModalContentEl.innerHTML = '<div class="py-4 text-center text-muted"><span class="spinner-border spinner-border-sm me-2"></span>Loading preview...</div>';
    const params = new URLSearchParams();
    params.set('actionStateId', String(actionStateInput?.value || '').trim());
    appendWorkspaceResetPreviewParams(params);
    const response = await fetch(`/school/sample-data/clear-transactional-preview?${params.toString()}`, {
      method: 'GET',
      headers: { 'X-AJAX-Request': 'true' }
    });
    const result = await response.json();
    if (result.status !== 'success') {
      throw new Error(result.message || 'Failed to load org workspace reset preview.');
    }
    renderOrgWorkspaceResetPreview(result.preview || null);
    return result.preview || null;
  }

  function getPeopleDeleteModalApi() {
    if (peopleDeleteModalApi) return peopleDeleteModalApi;
    if (peopleDeleteModalEl && window.bootstrap && window.bootstrap.Modal) {
      peopleDeleteModalApi = window.bootstrap.Modal.getOrCreateInstance(peopleDeleteModalEl);
      return peopleDeleteModalApi;
    }
    return null;
  }

  function showPeopleDeleteModal() {
    const api = getPeopleDeleteModalApi();
    if (api) {
      api.show();
      return;
    }
    if (!peopleDeleteModalEl) return;
    peopleDeleteModalEl.style.display = 'block';
    peopleDeleteModalEl.classList.add('show');
    peopleDeleteModalEl.removeAttribute('aria-hidden');
    peopleDeleteModalEl.setAttribute('aria-modal', 'true');
    peopleDeleteModalEl.setAttribute('role', 'dialog');
    document.body.classList.add('modal-open');
  }

  function hidePeopleDeleteModal() {
    const api = getPeopleDeleteModalApi();
    if (api) {
      api.hide();
      return;
    }
    if (!peopleDeleteModalEl) return;
    peopleDeleteModalEl.classList.remove('show');
    peopleDeleteModalEl.style.display = 'none';
    peopleDeleteModalEl.setAttribute('aria-hidden', 'true');
    peopleDeleteModalEl.removeAttribute('aria-modal');
    document.body.classList.remove('modal-open');
  }

