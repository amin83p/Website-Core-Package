  function renderOrgWorkspaceResetPreview(preview) {
    sampleWorkspaceResetPreview = preview || null;
    if (!workspaceResetPreviewModalContentEl) return;
    if (!preview) {
      workspaceResetPreviewModalContentEl.innerHTML = '';
      if (workspaceResetPreviewSummaryTextEl) workspaceResetPreviewSummaryTextEl.textContent = '';
      return;
    }

    const transactionalGroups = preview?.transactional?.groups || [];
    const masterGroups = preview?.masters?.groups || [];
    const protectedGroups = preview?.masters?.protected || [];
    const summary = preview?.summary || {};

    workspaceResetPreviewModalContentEl.innerHTML = `
      <div class="mb-4">
        <h6 class="fw-bold mb-3">Transactional / runtime impact (always cleared)</h6>
        ${buildPreviewGroupTableHtml(transactionalGroups, 'No transactional records found for this organization.')}
      </div>
      ${masterGroups.length ? `
        <div class="mb-4">
          <h6 class="fw-bold mb-3">Optional master definition purge</h6>
          ${buildPreviewGroupTableHtml(masterGroups, 'No master definitions selected.')}
        </div>
      ` : `
        <div class="alert alert-secondary border-secondary mb-4">
          No optional master definitions are selected. Master rows will be preserved.
        </div>
      `}
      ${protectedGroups.length ? `
        <div class="mb-2">
          <h6 class="fw-bold mb-3">Protected items</h6>
          ${buildPreviewGroupTableHtml(protectedGroups, 'No protected items.')}
        </div>
      ` : ''}
    `;

