  function renderPeopleDeleteResult(payload) {
    if (!payload || !payload.summary) {
      peopleDeleteResultEl.innerHTML = '';
      return;
    }
    const requested = payload.summary.requested || {};
    const succeeded = payload.summary.succeeded || {};
    const failed = payload.summary.failed || {};
    const skipped = payload.summary.skipped || {};
    const rows = Array.isArray(payload.results) ? payload.results : [];
    const failures = rows.filter((row) => String(row?.status || '').toLowerCase() === 'error');
    const skippedItems = rows.filter((row) => String(row?.status || '').toLowerCase() === 'skipped');
    const badge = String(payload.status || '').toLowerCase();
    const titleBadge = badge === 'success'
      ? '<span class="badge bg-success">Success</span>'
      : (badge === 'partial'
        ? '<span class="badge bg-warning text-dark">Partial</span>'
        : '<span class="badge bg-danger">Error</span>');

    peopleDeleteResultEl.innerHTML = `
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
          <h5 class="m-0 fw-bold"><i class="bi bi-trash3 me-2"></i>Sample People Cleanup Result</h5>
          ${titleBadge}
        </div>
        <div class="card-body p-4">
          <p class="mb-3">${safeHtml(payload.message || '')}</p>
          <div class="row g-3 mb-3">
            <div class="col-md-3"><div class="border rounded-3 p-3"><div class="small text-muted">Requested</div><div class="fs-4 fw-bold">${Number(requested.total || 0)}</div></div></div>
            <div class="col-md-3"><div class="border rounded-3 p-3"><div class="small text-muted">Succeeded</div><div class="fs-4 fw-bold text-success">${Number(succeeded.total || 0)}</div></div></div>
            <div class="col-md-3"><div class="border rounded-3 p-3"><div class="small text-muted">Skipped</div><div class="fs-4 fw-bold text-warning">${Number(skipped.total || 0)}</div></div></div>
            <div class="col-md-3"><div class="border rounded-3 p-3"><div class="small text-muted">Failed</div><div class="fs-4 fw-bold text-danger">${Number(failed.total || 0)}</div></div></div>
          </div>
          <div class="small text-muted mb-3">
            Students: ${Number(succeeded.students || 0)}/${Number(requested.students || 0)} |
            Teachers: ${Number(succeeded.teachers || 0)}/${Number(requested.teachers || 0)} |
            Staff: ${Number(succeeded.staff || 0)}/${Number(requested.staff || 0)} |
            Persons: ${Number(succeeded.persons || 0)}/${Number(requested.persons || 0)} |
            Accounts: ${Number(succeeded.accounts || 0)}/${Number(requested.accounts || 0)}
          </div>
          ${skippedItems.length ? `
            <div class="alert alert-info border-info mb-3">
              <div class="fw-bold mb-2">Retained / Skipped</div>
              <ul class="mb-0 small">
                ${skippedItems.slice(0, 20).map((row) => `<li>[${safeHtml(row.group || 'item')}] ${safeHtml(row.id || '')}: ${safeHtml(row.message || '')}</li>`).join('')}
              </ul>
              ${skippedItems.length > 20 ? `<div class="small mt-2 text-muted">+${skippedItems.length - 20} more skipped item(s)</div>` : ''}
            </div>
          ` : ''}
          ${failures.length ? `
            <div class="alert alert-warning border-warning mb-0">
              <div class="fw-bold mb-2">Items Needing Attention</div>
              <ul class="mb-0 small">
                ${failures.slice(0, 30).map((row) => `<li>[${safeHtml(row.group || 'item')}] ${safeHtml(row.id || '')}: ${safeHtml(row.message || '')}</li>`).join('')}
              </ul>
              ${failures.length > 30 ? `<div class="small mt-2 text-muted">+${failures.length - 30} more item(s)</div>` : ''}
            </div>
          ` : ''}
        </div>
      </div>
    `;
  }

  async function loadPeopleDeletePreview() {
    if (!peopleDeleteModalContentEl) return null;
    peopleDeleteModalContentEl.innerHTML = '<div class="py-4 text-center text-muted"><span class="spinner-border spinner-border-sm me-2"></span>Loading preview...</div>';
    const params = new URLSearchParams();
    params.set('actionStateId', String(actionStateInput?.value || '').trim());
    const response = await fetch(`/school/sample-data/people-delete-preview?${params.toString()}`, {
      method: 'GET',
      headers: { 'X-AJAX-Request': 'true' }
    });
    const result = await response.json();
    if (result.status !== 'success') {
      throw new Error(result.message || 'Failed to load sample people preview.');
    }
    renderPeopleDeleteModal(result.preview || null);
    return result.preview || null;
  }

  function setAllPeopleSelection(checked) {
    if (!peopleDeleteModalContentEl) return;
    peopleDeleteModalContentEl.querySelectorAll('.js-sample-people-row').forEach((el) => {
      if (el.disabled) return;
      el.checked = checked;
    });
    updatePeopleDeleteSelectionSummary();
  }

  function setGroupPeopleSelection(group, checked) {
    if (!peopleDeleteModalContentEl) return;
    peopleDeleteModalContentEl.querySelectorAll(`.js-sample-people-row[data-group="${group}"]`).forEach((el) => {
      if (el.disabled) return;
      el.checked = checked;
    });
    updatePeopleDeleteSelectionSummary();
  }

  document.addEventListener('DOMContentLoaded', function () {
    if (window.__LAST_SAMPLE_GENERATOR_RESULT__) {
      renderResult(window.__LAST_SAMPLE_GENERATOR_RESULT__);
    }
    if (window.__LAST_SAMPLE_RESET_RESULT__) {
      renderResetResult(window.__LAST_SAMPLE_RESET_RESULT__);
    }
  });

  form.addEventListener('submit', async function (e) {
    e.preventDefault();
    const originalText = submitBtn.innerHTML;
    try {
      await ensureAdminVerification();

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Generating...';
      const formData = new FormData(form);
      const totalRequested =
        Number(formData.get('studentCount') || 0)
        + Number(formData.get('teacherCount') || 0)
        + Number(formData.get('staffCount') || 0);
      showOperationModal({
        title: 'Generating sample school data',
        subtitle: `Creating ${Number.isFinite(totalRequested) ? totalRequested : 0} sample role record(s) for the active organization.`,
        stages: [
          'Checking the active organization and request details...',
          'Creating person profiles and school role records...',
          'Linking school accounts when matching accounts are available...',
          'Validating generated records...',
          'Preparing the generation summary...'
        ]
      });

      const response = await fetch(form.action, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'X-AJAX-Request': 'true'
        },
        body: new URLSearchParams(formData).toString()
      });

      const result = await readJsonResponse(response, 'Admin approval is required before generating sample data.');
      if (result?.idempotency?.state) hideOperationModal();
      const guarded = typeof window.applyGuardedApiResult === 'function'
        ? await window.applyGuardedApiResult(result, { busyTitle: 'Generation In Progress', replayTitle: 'Generation Already Processed' })
        : { stop: false };
      if (guarded.stop) return;
      if (result.status !== 'success') {
        throw new Error(result.message || 'Generation failed.');
      }
      if (!result?.idempotency?.state) {
        await completeOperationModal('Generation completed. Preparing the result...');
      }

      renderResult(result.result);
      await showMsg({
        title: 'Completed',
        icon: 'success',
        message: result.message || 'Sample data generation completed.',
        buttons: [{ text: 'OK', class: 'btn-success' }]
      });
    } catch (error) {
      hideOperationModal();
      if (isAdminVerificationCancel(error)) return;
      await showMsg({
        title: isAdminRequiredError(error) ? 'Admin Verification Required' : 'System Error',
        icon: isAdminRequiredError(error) ? 'warning' : 'error',
        message: error.message || 'Failed to generate sample data.',
        buttons: [{ text: 'Close', class: 'btn-secondary' }]
      });
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });

  if (clearBtn) {
    clearBtn.addEventListener('click', async function () {
    const originalText = clearBtn.innerHTML;
    try {
      let confirmed = false;
      if (typeof window.showMessageModal === 'function') {
        const result = await window.showMessageModal({
          title: 'Clear Transactions, Registrations & Withdrawals?',
          icon: 'warning',
          message: 'This will clear academic/accounting transactions, program & term registrations, prior subject credits, withdrawals, class enrollments, enrollment periods, class workspace files, report runs (not templates), timesheets (not periods), subject storage folders, attendance matrix policy for this org, official final grades on classes, optional snapshots, and rebuild class-related schedule indexes. Master definitions will remain unchanged.',
          buttons: [
            { text: 'Cancel', class: 'btn-secondary' },
            { text: 'Clear Data', class: 'btn-danger' }
          ]
        });
        confirmed = result === 'Clear Data';
      } else {
        confirmed = window.confirm('Clear transactions, registrations, prior credits, withdrawals, enrollments, workspaces, report runs, timesheets, attendance policy, official final grades, snapshots (if enabled), and rebuild indexes? Master definitions will remain unchanged.');
      }
      if (!confirmed) return;

      await ensureAdminVerification();

      clearBtn.disabled = true;
      clearBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Clearing...';
      showOperationModal({
        title: 'Clearing sample transactional data',
        subtitle: 'Removing generated transactional records and rebuilding related school indexes.',
        stages: [
          'Checking the active organization and cleanup options...',
          'Clearing ledgers, journals, registrations, and withdrawals...',
          'Removing class workspace data and report runs...',
          'Resetting attendance and final grade workflow state...',
          'Rebuilding indexes and preparing the cleanup summary...'
        ]
      });

      const params = new URLSearchParams();
      params.set('actionStateId', String(actionStateInput?.value || '').trim());
      params.set('includeAcademicSnapshots', includeSnapshotsCheckbox?.checked ? 'true' : 'false');

      const response = await fetch('/school/sample-data/clear-transactional', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded',
          'X-AJAX-Request': 'true'
        },
        body: params.toString()
      });

      const result = await readJsonResponse(response, 'Admin approval is required before clearing sample transactional data.');
      if (result?.idempotency?.state) hideOperationModal();
      const guarded = typeof window.applyGuardedApiResult === 'function'
        ? await window.applyGuardedApiResult(result, { busyTitle: 'Clear In Progress', replayTitle: 'Clear Already Processed' })
        : { stop: false };
      if (guarded.stop) return;
      if (result.status !== 'success') {
        throw new Error(result.message || 'Failed to clear transactional data.');
      }
      if (!result?.idempotency?.state) {
        await completeOperationModal('Cleanup completed. Preparing the result...');
      }

      renderResetResult(result.result);
      await showMsg({
        title: 'Completed',
        icon: 'success',
        message: result.message || 'Transactional data cleared successfully.',
        buttons: [{ text: 'OK', class: 'btn-success' }]
      });
    } catch (error) {
      hideOperationModal();
      if (isAdminVerificationCancel(error)) return;
      await showMsg({
        title: isAdminRequiredError(error) ? 'Admin Verification Required' : 'System Error',
        icon: isAdminRequiredError(error) ? 'warning' : 'error',
        message: error.message || 'Failed to clear transactional data.',
        buttons: [{ text: 'Close', class: 'btn-secondary' }]
      });
    } finally {
      clearBtn.disabled = false;
      clearBtn.innerHTML = originalText;
    }
    });
  }

  if (peopleDeleteModalContentEl) {
    peopleDeleteModalContentEl.addEventListener('change', function (event) {
      if (event.target && event.target.classList.contains('js-sample-people-row')) {
        updatePeopleDeleteSelectionSummary();
      }
    });
    peopleDeleteModalContentEl.addEventListener('click', function (event) {
      const btn = event.target.closest('.js-group-toggle');
      if (!btn) return;
      const group = String(btn.getAttribute('data-group') || '').trim();
      const value = String(btn.getAttribute('data-value') || '').trim() === 'true';
      if (!getGroupKeys().includes(group)) return;
      setGroupPeopleSelection(group, value);
    });
  }

  if (peopleDeleteModalEl) {
    peopleDeleteModalEl.addEventListener('click', function (event) {
      const dismissBtn = event.target.closest('[data-bs-dismiss="modal"]');
      if (dismissBtn) {
        hidePeopleDeleteModal();
        return;
      }
      if (event.target === peopleDeleteModalEl) {
        hidePeopleDeleteModal();
      }
    });
  }

  if (selectAllPeopleBtn) {
    selectAllPeopleBtn.addEventListener('click', function () {
      setAllPeopleSelection(true);
    });
  }
  if (unselectAllPeopleBtn) {
    unselectAllPeopleBtn.addEventListener('click', function () {
      setAllPeopleSelection(false);
    });
  }

  if (openPeopleDeleteBtn) {
    openPeopleDeleteBtn.addEventListener('click', async function () {
      const originalText = openPeopleDeleteBtn.innerHTML;
      openPeopleDeleteBtn.disabled = true;
      openPeopleDeleteBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Loading...';
      try {
        await loadPeopleDeletePreview();
        showPeopleDeleteModal();
      } catch (error) {
        await showMsg({
          title: 'System Error',
          icon: 'error',
          message: error.message || 'Failed to load sample people preview.',
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
      } finally {
        openPeopleDeleteBtn.disabled = false;
        openPeopleDeleteBtn.innerHTML = originalText;
      }
    });
  }

  if (confirmPeopleDeleteBtn) {
    confirmPeopleDeleteBtn.addEventListener('click', async function () {
      if (peopleDeleteSubmissionActive) return;
      peopleDeleteSubmissionActive = true;
      const originalText = confirmPeopleDeleteBtn.innerHTML;
      const selection = collectModalSelection();
      const totalSelected = selection.students.length + selection.teachers.length + selection.staff.length + selection.persons.length;
      try {
        if (totalSelected <= 0) {
          peopleDeleteSubmissionActive = false;
          await showMsg({
            title: 'No Selection',
            icon: 'warning',
            message: 'Please select at least one row to delete.',
            buttons: [{ text: 'OK', class: 'btn-secondary' }]
          });
          return;
        }

        let confirmed = false;
        if (typeof window.showMessageModal === 'function') {
          const confirmResult = await window.showMessageModal({
            title: 'Delete Selected Sample Records?',
            icon: 'warning',
            message: `This is permanent. Selected now: ${selection.students.length} Students, ${selection.teachers.length} Teachers, ${selection.staff.length} Staff, ${selection.persons.length} Persons.`,
            buttons: [
              { text: 'Cancel', class: 'btn-secondary' },
              { text: 'Delete Permanently', class: 'btn-danger' }
            ]
          });
          confirmed = confirmResult === 'Delete Permanently';
        } else {
          confirmed = window.confirm('Delete selected sample records permanently?');
        }
        if (!confirmed) return;

        confirmPeopleDeleteBtn.disabled = true;
        confirmPeopleDeleteBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Verifying...';

        await ensureAdminVerification();

        confirmPeopleDeleteBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Deleting...';
        hidePeopleDeleteModal();
        showOperationModal({
          title: 'Deleting selected sample records',
          subtitle: `Processing ${totalSelected} selected row(s) and checking linked school records.`,
          stages: [
            'Validating the selected records...',
            'Deleting selected student, teacher, and staff rows...',
            'Cleaning school role memberships from person profiles...',
            'Checking linked accounts and safety references...',
            'Preparing the cleanup report...'
          ]
        });

        const params = new URLSearchParams();
        params.set('actionStateId', String(actionStateInput?.value || '').trim());
        selection.students.forEach((id) => params.append('studentIds', id));
        selection.teachers.forEach((id) => params.append('teacherIds', id));
        selection.staff.forEach((id) => params.append('staffIds', id));
        selection.persons.forEach((id) => params.append('personIds', id));

        const response = await fetch('/school/sample-data/people-delete', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-AJAX-Request': 'true'
          },
          body: params.toString()
        });
        const result = await readJsonResponse(response, 'Admin approval is required before deleting sample people.');
        if (result?.idempotency?.state) hideOperationModal();
        const guarded = typeof window.applyGuardedApiResult === 'function'
          ? await window.applyGuardedApiResult(result, { busyTitle: 'Deletion In Progress', replayTitle: 'Deletion Already Processed' })
          : { stop: false };
        if (guarded.stop) return;
        if (String(result.status || '').toLowerCase() === 'error') {
          throw new Error(result.message || 'Deletion failed.');
        }
        if (!result?.idempotency?.state) {
          await completeOperationModal('Deletion completed. Preparing the report...');
        }

        renderPeopleDeleteResult(result);
        hidePeopleDeleteModal();
        await showMsg({
          title: String(result.status || '').toLowerCase() === 'partial' ? 'Completed with Warnings' : 'Completed',
          icon: String(result.status || '').toLowerCase() === 'partial' ? 'warning' : 'success',
          message: result.message || 'Sample people cleanup completed.',
          buttons: [{ text: 'OK', class: 'btn-success' }]
        });
      } catch (error) {
        hideOperationModal();
        if (isAdminVerificationCancel(error)) return;
        await showMsg({
          title: isAdminRequiredError(error) ? 'Admin Verification Required' : 'System Error',
          icon: isAdminRequiredError(error) ? 'warning' : 'error',
          message: error.message || 'Failed to delete selected sample records.',
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
      } finally {
        peopleDeleteSubmissionActive = false;
        confirmPeopleDeleteBtn.disabled = false;
        confirmPeopleDeleteBtn.innerHTML = originalText;
      }
    });
  }
})();
</script>
