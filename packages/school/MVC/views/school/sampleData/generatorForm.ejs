    const totalSelected = selectedCounts.students + selectedCounts.teachers + selectedCounts.staff + selectedCounts.persons;
    if (peopleDeleteSelectionSummaryTextEl) {
      peopleDeleteSelectionSummaryTextEl.textContent = `Selected: ${selectedCounts.students} Students, ${selectedCounts.teachers} Teachers, ${selectedCounts.staff} Staff, ${selectedCounts.persons} Persons (Total ${totalSelected})`;
