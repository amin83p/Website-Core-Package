      workspaceResetPreviewSummaryTextEl.innerHTML = `
        Transactional records: <b>${Number(summary.transactionalRecords || 0)}</b>
        | Master records: <b>${Number(summary.masterRecords || 0)}</b>
        | Protected: <b>${Number(summary.protectedRecords || 0)}</b>
      `;
