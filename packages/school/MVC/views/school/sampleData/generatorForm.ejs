  function badgeClassForStatus(statusKey) {
    const key = String(statusKey || '').trim().toLowerCase();
    if (key === 'archived') return 'bg-secondary-subtle text-secondary border border-secondary-subtle';
    if (key === 'active') return 'bg-success-subtle text-success border border-success-subtle';
    if (key === 'inactive' || key === 'on leave' || key === 'on_leave') return 'bg-warning-subtle text-warning border border-warning-subtle';
    if (key === 'missing') return 'bg-danger-subtle text-danger border border-danger-subtle';
    return 'bg-light text-dark border';
  }

  function getGroupKeys() {
    return ['students', 'teachers', 'staff', 'persons'];
  }

  function collectModalSelection() {
    const selected = { students: [], teachers: [], staff: [], persons: [] };
    const checkboxes = peopleDeleteModalContentEl
      ? peopleDeleteModalContentEl.querySelectorAll('.js-sample-people-row')
      : [];
    checkboxes.forEach((checkbox) => {
      if (checkbox.disabled) return;
      const group = String(checkbox.getAttribute('data-group') || '').trim();
      const id = String(checkbox.getAttribute('data-id') || '').trim();
      if (!checkbox.checked || !id || !Object.prototype.hasOwnProperty.call(selected, group)) return;
      selected[group].push(id);
    });
    return selected;
  }

  function renderAccountImpactPreview(preview, selection) {
    const accounts = Array.isArray(preview?.linkedAccounts) ? preview.linkedAccounts : [];
    const selectedRoleSets = {
      students: new Set(selection.students || []),
      teachers: new Set(selection.teachers || []),
      staff: new Set(selection.staff || [])
    };
    const impacted = accounts
      .map((account) => {
        const owners = Array.isArray(account?.owners) ? account.owners : [];
        const selectedOwners = owners.filter((owner) => selectedRoleSets[owner.group]?.has(String(owner.roleId || '').trim()));
        if (!selectedOwners.length) return null;
        return {
          id: String(account?.id || '').trim(),
          name: String(account?.name || '').trim() || '(Unnamed Account)',
          status: String(account?.status || '').trim().toLowerCase() || 'unknown',
          ownerCount: owners.length,
          selectedOwnerCount: selectedOwners.length,
          eligible: selectedOwners.length === owners.length
        };
      })
      .filter(Boolean);

    const eligibleCount = impacted.filter((row) => row.eligible).length;
    const sharedCount = impacted.length - eligibleCount;

    if (peopleDeleteImpactTextEl) {
      peopleDeleteImpactTextEl.innerHTML = impacted.length
        ? `Linked account impact: <b>${eligibleCount}</b> eligible, <b>${sharedCount}</b> shared/likely skipped.`
        : 'Linked account impact: none from current selection.';
    }

    const target = document.getElementById('samplePeopleLinkedAccountImpactTable');
    if (!target) return;
    if (!impacted.length) {
      target.innerHTML = '<div class="small text-muted">No linked school accounts are affected by the current selection.</div>';
      return;
    }

    target.innerHTML = `
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead>
            <tr>
              <th>Account</th>
              <th>Status</th>
              <th>Owners Selected</th>
              <th>Impact</th>
            </tr>
          </thead>
          <tbody>
            ${impacted.map((row) => `
              <tr>
                <td>
                  <div class="fw-semibold">${safeHtml(row.name)}</div>
                  <div class="small text-muted font-monospace">${safeHtml(row.id)}</div>
                </td>
                <td><span class="badge ${badgeClassForStatus(row.status)}">${safeHtml(row.status || 'unknown')}</span></td>
                <td>${Number(row.selectedOwnerCount)} / ${Number(row.ownerCount)}</td>
                <td>
                  ${row.eligible
                    ? '<span class="badge bg-success-subtle text-success border border-success-subtle">Will Attempt Delete</span>'
                    : '<span class="badge bg-warning-subtle text-warning border border-warning-subtle">Shared / Likely Skipped</span>'}
                </td>
              </tr>
            `).join('')}
          </tbody>
        </table>
      </div>
    `;
  }

  function updatePeopleDeleteSelectionSummary() {
    const selection = collectModalSelection();
    const selectedCounts = {
      students: selection.students.length,
      teachers: selection.teachers.length,
      staff: selection.staff.length,
      persons: selection.persons.length
    };
    const totalSelected = selectedCounts.students + selectedCounts.teachers + selectedCounts.staff + selectedCounts.persons;
    if (peopleDeleteSelectionSummaryTextEl) {
      peopleDeleteSelectionSummaryTextEl.textContent = `Selected: ${selectedCounts.students} Students, ${selectedCounts.teachers} Teachers, ${selectedCounts.staff} Staff, ${selectedCounts.persons} Persons (Total ${totalSelected})`;
    }
    renderAccountImpactPreview(samplePeoplePreview, selection);
  }

  function buildPeopleRowsHtml(groupKey, rows) {
    const groupTitleMap = {
      students: 'Students',
      teachers: 'Teachers',
      staff: 'Staff',
      persons: 'Persons'
    };
    const title = groupTitleMap[groupKey] || groupKey;

    const tableRows = (Array.isArray(rows) ? rows : []).map((row) => {
      if (groupKey === 'persons') {
        const associations = Array.isArray(row?.associations) ? row.associations : [];
        const assocText = associations.length
          ? associations.map((item) => `${item.role || ''}:${item.roleId || ''}`).join(', ')
          : 'No linked sample role row';
        const schoolRoles = Array.isArray(row?.schoolRoles) ? row.schoolRoles : [];
        const otherRoles = Array.isArray(row?.otherRoles) ? row.otherRoles : [];
        const schoolRoleText = schoolRoles.length ? schoolRoles.join(', ') : 'member';
        const otherRoleText = otherRoles.length
          ? otherRoles.map((token) => `<span class="badge bg-warning-subtle text-warning border border-warning-subtle me-1 mb-1">${safeHtml(token)}</span>`).join('')
          : '<span class="small text-muted">None</span>';
        const isMissing = String(row?.status || '').trim().toLowerCase() === 'missing';
        return `
          <tr>
            <td class="text-center">
              <input type="checkbox" class="form-check-input js-sample-people-row" data-group="persons" data-id="${safeHtml(row.id)}" ${isMissing ? 'disabled' : 'checked'}>
            </td>
            <td>
              <div class="fw-semibold">${safeHtml(row.personName)}</div>
              <div class="small text-muted font-monospace">${safeHtml(row.id)}</div>
              ${isMissing ? '<div class="small text-muted">Person row is already absent; linked school rows can still be cleaned.</div>' : ''}
            </td>
            <td>${row.personEmail ? `<span class="small">${safeHtml(row.personEmail)}</span>` : '<span class="small text-muted">-</span>'}</td>
            <td><span class="badge ${badgeClassForStatus(row.status)}">${safeHtml(row.status)}</span></td>
            <td><span class="small">${safeHtml(assocText)}</span></td>
            <td><span class="small">${safeHtml(schoolRoleText)}</span></td>
            <td>${otherRoleText}</td>
          </tr>
        `;
      }

      const accountText = row.linkedAccountId
        ? `${safeHtml(row.linkedAccountName || '(Unnamed Account)')} (${safeHtml(row.linkedAccountId)})`
        : '-';
      return `
        <tr>
          <td class="text-center">
            <input type="checkbox" class="form-check-input js-sample-people-row" data-group="${safeHtml(groupKey)}" data-id="${safeHtml(row.id)}" checked>
          </td>
          <td>
            <div class="fw-semibold">${safeHtml(row.personName)}</div>
            <div class="small text-muted font-monospace">${safeHtml(row.id)}</div>
          </td>
          <td><span class="badge ${badgeClassForStatus(row.statusKey)}">${safeHtml(row.status)}</span></td>
          <td>${row.sampleCode ? `<span class="small font-monospace">${safeHtml(row.sampleCode)}</span>` : '<span class="small text-muted">-</span>'}</td>
          <td><span class="small">${accountText}</span></td>
        </tr>
      `;
    }).join('');

    const columns = groupKey === 'persons'
      ? '<th>Name</th><th>Email</th><th>Status</th><th>Associations</th><th>School Roles</th><th>Other Roles</th>'
      : '<th>Name</th><th>Status</th><th>Sample Marker</th><th>Linked Account</th>';

    return `
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white py-2 d-flex justify-content-between align-items-center">
          <div class="fw-semibold">${title} <span class="badge bg-light text-dark border ms-2">${Number((rows || []).length)}</span></div>
          <div class="d-flex gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm js-group-toggle" data-group="${safeHtml(groupKey)}" data-value="true">Select All</button>
            <button type="button" class="btn btn-outline-secondary btn-sm js-group-toggle" data-group="${safeHtml(groupKey)}" data-value="false">Unselect All</button>
          </div>
        </div>
        <div class="card-body p-0">
          ${rows.length
            ? `<div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                  <thead>
                    <tr>
                      <th class="text-center" style="width:44px;">#</th>
                      ${columns}
                    </tr>
                  </thead>
                  <tbody>${tableRows}</tbody>
                </table>
              </div>`
            : '<div class="p-3 small text-muted">No sample records found in this group.</div>'}
        </div>
      </div>
    `;
  }

