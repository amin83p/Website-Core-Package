<%- include('partials/tablePages-start', {
  title,
  newUrl, 
  newLabel,
  user,
  tableName,
  btn_export: true,
  print,
  headerManageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>',
    '<a href="/dashboard/section-nav/SCHOOL_ACADEMIA" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-backpack2 me-1"></i> School Academia</a>'
  ],
  manageBtns: [
    `<a href="/school/departments/help" class="btn btn-primary btn-filled btn-md mb-2">
      <i class="bi bi-journal-text me-1"></i> Help
    </a>`,
    `<a href="/school/departments/new-wizard" class="btn btn-filled btn-primary btn-md mb-2">
      <i class="bi bi-signpost-split me-1"></i> Wizard
    </a>`
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search departments...',
  fields: []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Code</th>
        <th>Department Name</th>
        <th class="text-center">Status</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length === 0) { %>
         <tr><td colspan="4" class="text-center py-4 text-muted">No departments found.</td></tr>
      <% } %>
      
      <% data.forEach(item => { %>
        <tr>
          <td class="ps-4 fw-bold text-primary"><%= item.code %></td>
          <td class="fw-bold text-dark"><%= item.name %></td>
          <td class="text-center">
             <% let badge = item.status === 'active' ? 'bg-success' : 'bg-secondary'; %>
             <span class="badge <%= badge %>"><%= (item.status || 'unknown').toUpperCase() %></span>
          </td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= item.id %>"
                title="Department Actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                <a href="/school/departments/edit-wizard/<%= item.id %>" class="btn btn-outline-info btn-sm">
                  <i class="bi bi-magic me-2"></i>Wizard
                </a>
                <a href="/school/departments/edit/<%= item.id %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-pencil-square me-2"></i>Edit
                </a>
                <button class="btn btn-outline-danger btn-sm delete-btn" data-id="<%= item.id %>">
                  <i class="bi bi-archive me-2"></i>Delete
                </button>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/departments" hidden></span>

<%- include('partials/pagination', { 
    pagination: pagination, 
    filters: filters, 
    baseUrlPath: 'school/departments' 
}) %>

<%- include('partials/tablePages-end') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const actionStateId = '<%= (typeof actionStateId !== "undefined" && actionStateId) ? actionStateId : "" %>';
  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      e.stopPropagation();
      const id = btn.getAttribute('data-id');
      if (!id) return;

      let approved = false;
      if (typeof showMessageModal === 'function') {
        const res = await showMessageModal({
          title: 'Confirm Deletion',
          icon: 'warning',
          message: 'Are you sure you want to delete this department?',
          buttons: [
            { text: 'Cancel', class: 'btn-secondary', value: false },
            { text: 'Delete', class: 'btn-danger', value: true }
          ]
        });
        approved = (res === true || res === 'Delete' || (res && res.value === true));
      } else {
        approved = confirm('Are you sure you want to delete this department?');
      }
      if (!approved) return;

      try {
        const response = await fetch(`/school/departments/delete/${encodeURIComponent(id)}?actionStateId=${encodeURIComponent(actionStateId)}`, {
          method: 'DELETE',
          headers: { 'X-AJAX-Request': 'true' }
        });
        const result = await response.json();
        const guarded = typeof window.applyGuardedApiResult === 'function'
          ? await window.applyGuardedApiResult(result, { busyTitle: 'Delete In Progress', replayTitle: 'Delete Already Processed' })
          : { stop: false };
        if (guarded.stop) return;
        if (result.status !== 'success') throw new Error(result.message || 'Delete failed.');
        window.location.reload();
      } catch (err) {
        if (typeof showMessageModal === 'function') {
          await showMessageModal({ title: 'Error', icon: 'error', message: err.message, buttons: [{ text: 'OK', class: 'btn-danger' }] });
        } else {
          alert(err.message);
        }
      }
    });
  });
});
</script>
