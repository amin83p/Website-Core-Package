<%- include('partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print,
  headerManageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>',
    '<a href="/dashboard/section-nav/SCHOOL_ACCOUNTING" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-calculator me-1"></i> Accounting Dashboard</a>'
  ],
  manageBtns: [
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search teacher/staff profiles...',
  fields: []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Person</th>
        <th>Role</th>
        <th>Compensation Entries</th>
        <th>Departments</th>
        <th>Status</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || data.length === 0) { %>
        <tr><td colspan="6" class="text-center py-4 text-muted">No teacher/staff profiles found.</td></tr>
      <% } %>

      <% (data || []).forEach((item) => { %>
        <tr>
          <td class="ps-4 fw-bold text-dark"><i class="bi bi-person me-1 text-muted"></i> <%= item.personName || item.personId %></td>
          <td><span class="badge bg-light text-dark border text-uppercase"><%= item.profileRole || '-' %></span></td>
          <td><span class="badge bg-primary-subtle text-primary border"><%= Number(item.compensationCount || 0) %></span></td>
          <td class="small text-primary fw-bold"><%= item.departments || '-' %></td>
          <td><span class="badge bg-light text-dark border"><%= item.status || '-' %></span></td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= item.ownerId %>"
                title="Pay Rate Actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.ownerId %>">
                <a href="/<%= newUrl %>/edit/<%= item.ownerId %>?ownerType=<%= encodeURIComponent(item.ownerType || '') %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-gear me-2"></i>Manage Rates
                </a>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/payrates" hidden></span>

<%- include('partials/pagination', {
  pagination,
  filters,
  baseUrlPath: newUrl
}) %>

<%- include('partials/tablePages-end') %>
