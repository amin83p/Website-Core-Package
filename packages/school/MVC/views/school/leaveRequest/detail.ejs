<% const row = request || {}; %>
<% const status = String(row.status || '').toLowerCase(); %>
<% const reasonLabel = (reasons || {})[row.reason] || row.reason || '-'; %>
<% const asid = actionStateId || ''; %>
<%
  const lifecycleEvents = Array.isArray(row.lifecycle) ? row.lifecycle.slice().reverse() : [];
  const lifecycleMeta = {
    submitted: { icon: 'bi-send-check', tone: 'primary', label: 'Submitted' },
    request_modified: { icon: 'bi-pencil-square', tone: 'info', label: 'Modified' },
    approved_request_modified: { icon: 'bi-arrow-repeat', tone: 'warning', label: 'Reapproval Needed' },
    approved: { icon: 'bi-check2-circle', tone: 'success', label: 'Approved' },
    rejected: { icon: 'bi-x-circle', tone: 'danger', label: 'Rejected' },
    cancelled: { icon: 'bi-slash-circle', tone: 'secondary', label: 'Cancelled' }
  };
  function formatLifecycleAction(action) {
    const token = String(action || '').trim();
    if (!token) return 'Update';
    return token.replace(/_/g, ' ').replace(/\b\w/g, (ch) => ch.toUpperCase());
  }
  function lifecycleStatusLabel(value) {
    const token = String(value || '').trim();
    return token ? token.replace(/_/g, ' ').toUpperCase() : 'NONE';
  }
  function formatFriendlyDate(value) {
    const token = String(value || '').trim();
    if (!/^\d{4}-\d{2}-\d{2}$/.test(token)) return token || '-';
    const date = new Date(token + 'T12:00:00');
    if (Number.isNaN(date.getTime())) return token;
    return date.toLocaleDateString(undefined, { weekday: 'short', month: 'short', day: 'numeric', year: 'numeric' });
  }
  function formatDateTime(value) {
    const token = String(value || '').trim();
    if (!token) return '-';
    const date = new Date(token);
    if (Number.isNaN(date.getTime())) return token;
    return date.toLocaleString(undefined, {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
      hour: 'numeric',
      minute: '2-digit'
    });
  }
  function countInclusiveDays(startDate, endDate) {
    const start = String(startDate || '').trim();
    const end = String(endDate || startDate || '').trim();
    if (!/^\d{4}-\d{2}-\d{2}$/.test(start) || !/^\d{4}-\d{2}-\d{2}$/.test(end)) return 0;
    const startMs = new Date(start + 'T00:00:00').getTime();
    const endMs = new Date(end + 'T00:00:00').getTime();
    if (Number.isNaN(startMs) || Number.isNaN(endMs) || endMs < startMs) return 0;
    return Math.floor((endMs - startMs) / 86400000) + 1;
  }
  function capitalizeToken(value) {
    const token = String(value || '').trim();
    if (!token) return '-';
    return token.charAt(0).toUpperCase() + token.slice(1);
  }
  function statusBadgeClass(value) {
    const token = String(value || '').trim().toLowerCase();
    if (token === 'approved') return 'bg-success';
    if (token === 'submitted' || token === 'pending_reapproval') return 'bg-warning text-dark';
    if (token === 'rejected' || token === 'cancelled') return 'bg-danger';
    return 'bg-secondary';
  }
  function addDaysIso(value, days) {
    const token = String(value || '').trim();
    if (!/^\d{4}-\d{2}-\d{2}$/.test(token)) return '';
    const date = new Date(token + 'T00:00:00Z');
    if (Number.isNaN(date.getTime())) return '';
    date.setUTCDate(date.getUTCDate() + Number(days || 0));
    return date.toISOString().slice(0, 10);
  }
  const leaveScheduleStartDate = addDaysIso(row.startDate, -3);
  const leaveScheduleEndDate = addDaysIso(row.endDate || row.startDate, 3);
  const leaveScheduleParams = new URLSearchParams();
  if (row.requesterPersonId) leaveScheduleParams.set('personId', row.requesterPersonId);
  if (row.requesterName) leaveScheduleParams.set('personName', row.requesterName);
  if (leaveScheduleStartDate) leaveScheduleParams.set('startDate', leaveScheduleStartDate);
  if (leaveScheduleEndDate) leaveScheduleParams.set('endDate', leaveScheduleEndDate);
  if (row.requesterRole) leaveScheduleParams.set('role', row.requesterRole);
  const leaveScheduleUrl = `/school/schedules${leaveScheduleParams.toString() ? '?' + leaveScheduleParams.toString() : ''}`;
  const leaveDayCount = countInclusiveDays(row.startDate, row.endDate || row.startDate);
  const leaveDayLabel = leaveDayCount === 1 ? '1 day' : `${leaveDayCount} days`;
  const isSingleDay = !row.endDate || row.endDate === row.startDate;
  const approval = row.approval && typeof row.approval === 'object' ? row.approval : {};
  const needsSessionResolution = ['teacher', 'staff', 'admin'].includes(String(row.requesterRole || '').toLowerCase())
    && ['submitted', 'pending_reapproval'].includes(status);
%>

<style>
  .leave-lifecycle-timeline {
    position: relative;
    display: grid;
    gap: 1rem;
    margin: 0;
    padding: .25rem 0 .25rem 0;
  }
  .leave-lifecycle-item {
    position: relative;
    display: grid;
    grid-template-columns: 48px minmax(0, 1fr);
    gap: .85rem;
  }
  .leave-lifecycle-item:not(:last-child)::before {
    content: "";
    position: absolute;
    left: 23px;
    top: 48px;
    bottom: -1rem;
    width: 2px;
    background: linear-gradient(180deg, rgba(13, 110, 253, .22), rgba(108, 117, 125, .08));
  }
  .leave-lifecycle-marker {
    position: relative;
    z-index: 1;
    width: 48px;
    height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: #fff;
    border: 1px solid rgba(33, 37, 41, .1);
    box-shadow: 0 10px 22px rgba(15, 23, 42, .08);
  }
  .leave-lifecycle-card {
    min-width: 0;
    border: 1px solid rgba(33, 37, 41, .08);
    border-radius: 10px;
    background: linear-gradient(180deg, #fff, #fbfcfe);
    padding: .9rem 1rem;
  }
  .leave-lifecycle-card header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: .75rem;
  }
  .leave-lifecycle-note {
    margin-top: .65rem;
    padding: .65rem .75rem;
    border-radius: 8px;
    background: rgba(248, 249, 250, .95);
    border: 1px solid rgba(33, 37, 41, .06);
    color: #495057;
  }
  .leave-lifecycle-status-chain {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: .4rem;
    margin-top: .55rem;
    font-size: .78rem;
  }
  .leave-lifecycle-status-pill {
    display: inline-flex;
    align-items: center;
    border-radius: 999px;
    padding: .2rem .55rem;
    background: #f8f9fa;
    border: 1px solid rgba(33, 37, 41, .08);
    color: #495057;
    font-weight: 600;
  }
  .leave-detail-meta {
    display: flex;
    flex-wrap: wrap;
    gap: .65rem;
    margin-bottom: 1rem;
  }
  .leave-detail-meta-item {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    padding: .45rem .7rem;
    border-radius: 999px;
    background: #f8f9fa;
    border: 1px solid rgba(33, 37, 41, .08);
    color: #495057;
    font-size: .82rem;
    font-weight: 600;
  }
  .leave-detail-panel {
    border: 1px solid rgba(33, 37, 41, .08);
    border-radius: 10px;
    background: linear-gradient(180deg, #fff, #fbfcfe);
    padding: .9rem 1rem;
    height: 100%;
  }
  .leave-detail-panel-label {
    font-size: .72rem;
    font-weight: 700;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: #6c757d;
    margin-bottom: .35rem;
  }
  .leave-detail-window-range {
    font-size: 1.05rem;
    font-weight: 700;
    color: #123047;
    line-height: 1.35;
  }
  .leave-detail-subtle {
    color: #6c757d;
    font-size: .88rem;
  }
  .leave-detail-details-copy {
    white-space: pre-wrap;
    word-break: break-word;
    margin-bottom: 0;
    color: #212529;
  }
  .leave-detail-empty {
    color: #adb5bd;
    font-style: italic;
  }
  .leave-detail-review-box {
    border-left: 4px solid rgba(13, 110, 253, .35);
    background: rgba(248, 249, 250, .95);
    border-radius: 8px;
    padding: .75rem .9rem;
  }
  @media (max-width: 575.98px) {
    .leave-lifecycle-item {
      grid-template-columns: 40px minmax(0, 1fr);
      gap: .7rem;
    }
    .leave-lifecycle-marker {
      width: 40px;
      height: 40px;
      border-radius: 12px;
    }
    .leave-lifecycle-item:not(:last-child)::before {
      left: 19px;
      top: 40px;
    }
    .leave-lifecycle-card header {
      display: block;
    }
  }
</style>

<div class="container-fluid py-3">
  <input type="hidden" id="leaveRequestActionStateId" value="<%= asid %>">

  <div class="d-flex flex-wrap justify-content-between align-items-start gap-2 mb-3">
    <div>
      <div class="d-flex align-items-center flex-wrap gap-2 mb-1">
        <h1 class="h3 mb-0">Leave Request</h1>
        <span class="badge <%= statusBadgeClass(status) %>"><%= status.replace(/_/g, ' ').toUpperCase() || 'UNKNOWN' %></span>
      </div>
      <div class="text-muted"><span class="font-monospace"><%= row.id %></span></div>
      <div class="mt-1">
        <span class="fw-semibold text-dark"><%= row.requesterName || row.requesterPersonId || '-' %></span>
        <span class="text-muted"> &middot; </span>
        <span><%= formatFriendlyDate(row.startDate) %><%= isSingleDay ? '' : ' to ' + formatFriendlyDate(row.endDate) %></span>
        <% if (leaveDayCount > 0) { %>
          <span class="badge bg-light text-dark border ms-1"><%= leaveDayLabel %></span>
        <% } %>
      </div>
    </div>
      <div class="d-flex flex-wrap gap-2">
      <a href="<%= schoolSectionDashboardHref %>" class="btn btn-filled btn-secondary"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>
      <a href="/dashboard/section-nav/SCHOOL_ACADEMIA" class="btn btn-filled btn-secondary"><i class="bi bi-journal-bookmark me-1"></i> School Academia</a>
      <a href="/school/leave-requests" class="btn btn-outline-secondary"><i class="bi bi-list-ul me-1"></i> Leave Requests</a>
      <% if (!['rejected', 'cancelled'].includes(status)) { %>
        <a href="/school/leave-requests/edit/<%= row.id %>" class="btn btn-primary"><i class="bi bi-pencil-square me-1"></i> Edit</a>
      <% } %>
    </div>
  </div>

  <div id="leaveSessionConflictBanner" class="alert alert-warning border shadow-sm d-none mb-3" role="alert">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
      <div>
        <div class="fw-semibold"><i class="bi bi-exclamation-triangle me-1"></i><span id="leaveSessionConflictSummary">Overlapping class sessions require substitute instructors before approval.</span></div>
        <div class="small mt-1" id="leaveSessionConflictDetail"></div>
      </div>
      <a href="/school/leave-requests/resolve-sessions/<%= row.id %>" class="btn btn-warning btn-sm fw-bold" id="leaveResolveSessionsLink"><i class="bi bi-calendar2-week me-1"></i>Resolve sessions</a>
    </div>
  </div>

  <div class="d-flex justify-content-end mb-3">
    <button class="btn btn-outline-secondary btn-sm" type="button" data-bs-toggle="collapse" data-bs-target="#approvalSnapshotPanel" aria-expanded="<%= status === 'approved' ? 'true' : 'false' %>" aria-controls="approvalSnapshotPanel">
      <i class="bi bi-shield-check me-1"></i> Approval Snapshot
    </button>
  </div>

  <div id="approvalSnapshotPanel" class="collapse <%= status === 'approved' ? 'show' : '' %> mb-3">
    <div class="card shadow-sm border-0">
      <div class="card-header bg-white d-flex justify-content-between align-items-center gap-2">
        <h2 class="h5 mb-0">Approval Snapshot</h2>
        <button class="btn btn-sm btn-outline-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#approvalSnapshotPanel" aria-expanded="<%= status === 'approved' ? 'true' : 'false' %>" aria-controls="approvalSnapshotPanel">
          <i class="bi bi-chevron-up me-1"></i> Hide
        </button>
      </div>
      <div class="card-body">
        <% if (row.lastApprovedSnapshot && row.lastApprovedSnapshot.active !== false) { %>
          <div class="leave-detail-panel">
            <div class="leave-detail-panel-label">Active Approved Window</div>
            <div class="leave-detail-window-range">
              <%= formatFriendlyDate(row.lastApprovedSnapshot.startDate) %><%= row.lastApprovedSnapshot.endDate && row.lastApprovedSnapshot.endDate !== row.lastApprovedSnapshot.startDate ? ' to ' + formatFriendlyDate(row.lastApprovedSnapshot.endDate) : '' %>
            </div>
            <div class="leave-detail-subtle mt-1">
              <% if (row.lastApprovedSnapshot.allDay === false) { %>
                <i class="bi bi-clock me-1"></i><%= row.lastApprovedSnapshot.startTime || '--:--' %> - <%= row.lastApprovedSnapshot.endTime || '--:--' %>
              <% } else { %>
                <i class="bi bi-calendar-day me-1"></i>All day
              <% } %>
            </div>
          </div>
        <% } else if (status === 'approved') { %>
          <div class="small text-muted">This approved request is the active schedule-blocking source.</div>
        <% } else { %>
          <div class="small text-muted">No active approved snapshot.</div>
        <% } %>
      </div>
    </div>
  </div>

  <div class="row g-3">
    <div class="col-12">
      <div class="card shadow-sm border-0 mb-3">
        <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
          <h2 class="h5 mb-0">Request Details</h2>
          <div class="d-flex flex-wrap align-items-center justify-content-end gap-2">
            <% if (row.requesterPersonId && leaveScheduleStartDate && leaveScheduleEndDate) { %>
              <a href="<%= leaveScheduleUrl %>" class="btn btn-outline-info btn-sm" target="_blank" rel="noopener"><i class="bi bi-calendar-week me-1"></i> View Schedule +/- 3 Days</a>
            <% } %>
            <span class="badge <%= statusBadgeClass(status) %>"><%= status.replace(/_/g, ' ').toUpperCase() || 'UNKNOWN' %></span>
          </div>
        </div>
        <div class="card-body">
          <div class="leave-detail-meta">
            <span class="leave-detail-meta-item"><i class="bi bi-calendar-plus"></i> Requested <%= formatFriendlyDate(row.requestDate) %></span>
            <span class="leave-detail-meta-item"><i class="bi bi-arrow-repeat"></i> Revision <%= row.revisionNo || 1 %></span>
            <% if (row.audit?.lastUpdateDateTime) { %>
              <span class="leave-detail-meta-item"><i class="bi bi-clock-history"></i> Updated <%= formatDateTime(row.audit.lastUpdateDateTime) %></span>
            <% } %>
          </div>
          <dl class="row mb-0">
            <dt class="col-sm-4">Requester</dt>
            <dd class="col-sm-8">
              <div class="leave-detail-panel">
                <div class="fw-bold fs-5"><%= row.requesterName || '-' %></div>
                <div class="d-flex flex-wrap align-items-center gap-2 mt-2">
                  <span class="badge bg-light text-dark border"><%= capitalizeToken(row.requesterRole) %></span>
                  <span class="small text-muted font-monospace"><%= row.requesterPersonId || '-' %></span>
                </div>
              </div>
            </dd>
            <dt class="col-sm-4">Leave Window</dt>
            <dd class="col-sm-8">
              <div class="leave-detail-panel">
                <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
                  <span class="badge bg-primary-subtle text-primary border border-primary-subtle"><%= leaveDayLabel %></span>
                  <% if (row.allDay === false) { %>
                    <span class="badge bg-light text-dark border"><i class="bi bi-clock me-1"></i>Partial day</span>
                  <% } else { %>
                    <span class="badge bg-light text-dark border"><i class="bi bi-calendar-day me-1"></i>All day</span>
                  <% } %>
                </div>
                <div class="leave-detail-window-range">
                  <%= formatFriendlyDate(row.startDate) %><%= isSingleDay ? '' : ' to ' + formatFriendlyDate(row.endDate) %>
                </div>
                <div class="leave-detail-subtle mt-1">
                  <span class="font-monospace"><%= row.startDate || '-' %><%= isSingleDay ? '' : ' to ' + (row.endDate || '-') %></span>
                </div>
                <% if (row.allDay === false) { %>
                  <div class="leave-detail-subtle mt-2"><i class="bi bi-clock me-1"></i><%= row.startTime || '--:--' %> - <%= row.endTime || '--:--' %></div>
                <% } %>
              </div>
            </dd>
            <dt class="col-sm-4">Reason</dt>
            <dd class="col-sm-8">
              <div class="leave-detail-panel">
                <div class="fw-semibold"><%= reasonLabel %></div>
                <% if (row.reason && row.reason !== reasonLabel) { %>
                  <div class="leave-detail-subtle font-monospace mt-1"><%= row.reason %></div>
                <% } %>
              </div>
            </dd>
            <dt class="col-sm-4">Details</dt>
            <dd class="col-sm-8">
              <div class="leave-detail-panel">
                <% if (row.details) { %>
                  <p class="leave-detail-details-copy"><%= row.details %></p>
                <% } else { %>
                  <div class="leave-detail-empty">No additional details provided.</div>
                <% } %>
              </div>
            </dd>
            <% if (approval.approvedAt || approval.rejectedAt || approval.cancelledAt) { %>
              <dt class="col-sm-4">Review</dt>
              <dd class="col-sm-8">
                <div class="leave-detail-review-box">
                  <% if (approval.approvedAt) { %>
                    <div class="fw-semibold text-success"><i class="bi bi-check2-circle me-1"></i>Approved</div>
                    <div class="leave-detail-subtle">By <%= approval.approvedByName || approval.approvedBy || 'System' %> on <%= formatDateTime(approval.approvedAt) %></div>
                    <% if (approval.note) { %><div class="mt-2 small"><%= approval.note %></div><% } %>
                  <% } %>
                  <% if (approval.rejectedAt) { %>
                    <div class="fw-semibold text-danger"><i class="bi bi-x-circle me-1"></i>Rejected</div>
                    <div class="leave-detail-subtle">By <%= approval.rejectedByName || approval.rejectedBy || 'System' %> on <%= formatDateTime(approval.rejectedAt) %></div>
                    <% if (approval.note) { %><div class="mt-2 small"><%= approval.note %></div><% } %>
                  <% } %>
                  <% if (approval.cancelledAt) { %>
                    <div class="fw-semibold text-secondary"><i class="bi bi-slash-circle me-1"></i>Cancelled</div>
                    <div class="leave-detail-subtle">By <%= approval.cancelledByName || approval.cancelledBy || 'System' %> on <%= formatDateTime(approval.cancelledAt) %></div>
                  <% } %>
                </div>
              </dd>
            <% } %>
            <% if (row.adminNote) { %>
              <dt class="col-sm-4">Admin Note</dt>
              <dd class="col-sm-8">
                <div class="leave-detail-panel">
                  <p class="leave-detail-details-copy mb-0"><%= row.adminNote %></p>
                </div>
              </dd>
            <% } %>
          </dl>
        </div>
        <% if (canApprove || !['rejected', 'cancelled'].includes(status)) { %>
          <div class="card-footer bg-white d-flex flex-wrap justify-content-end gap-2">
            <% if (canApprove && ['submitted', 'pending_reapproval'].includes(status)) { %>
              <button class="btn btn-success leave-request-action" id="leaveApproveBtn" data-action="approve" data-id="<%= row.id %>" data-requester-role="<%= row.requesterRole || '' %>" <%= needsSessionResolution ? 'disabled' : '' %>><i class="bi bi-check2-circle me-1"></i> Approve</button>
              <button class="btn btn-outline-danger leave-request-action" data-action="reject" data-id="<%= row.id %>"><i class="bi bi-x-circle me-1"></i> Reject</button>
            <% } %>
      <% if (!['rejected', 'cancelled'].includes(status)) { %>
        <button class="btn btn-outline-danger leave-request-action" data-action="cancel" data-id="<%= row.id %>"><i class="bi bi-slash-circle me-1"></i> Cancel</button>
      <% } %>
      <% if (canApprove) { %>
        <button type="button" class="btn btn-outline-primary" id="createLeaveTaskFooterBtn" data-id="<%= row.id %>"><i class="bi bi-list-task me-1"></i> Create School Task</button>
        <button class="btn btn-outline-danger leave-request-action" data-action="delete" data-id="<%= row.id %>"><i class="bi bi-trash3 me-1"></i> Delete</button>
      <% } %>
        </div>
      <% } %>
      </div>

      <div class="card shadow-sm border-0">
        <div class="card-header bg-white d-flex flex-wrap justify-content-between align-items-center gap-2">
          <div>
            <h2 class="h5 mb-0">Action Timeline</h2>
            <div class="small text-muted">Most recent activity appears first.</div>
          </div>
          <span class="badge bg-light text-dark border"><%= lifecycleEvents.length %> event<%= lifecycleEvents.length === 1 ? '' : 's' %></span>
        </div>
        <div class="card-body">
          <% if (lifecycleEvents.length === 0) { %>
            <div class="text-muted">No lifecycle entries recorded.</div>
          <% } %>
          <div class="leave-lifecycle-timeline">
            <% lifecycleEvents.forEach((event, index) => { %>
              <%
                const actionKey = String(event.action || '').trim().toLowerCase();
                const meta = lifecycleMeta[actionKey] || { icon: 'bi-clock-history', tone: 'secondary', label: formatLifecycleAction(event.action) };
              %>
              <article class="leave-lifecycle-item">
                <div class="leave-lifecycle-marker text-<%= meta.tone %>">
                  <i class="bi <%= meta.icon %> fs-5"></i>
                </div>
                <div class="leave-lifecycle-card">
                  <header>
                    <div>
                      <div class="d-flex align-items-center flex-wrap gap-2">
                        <span class="badge bg-<%= meta.tone %><%= meta.tone === 'warning' ? ' text-dark' : '' %>"><%= meta.label %></span>
                        <% if (index === 0) { %><span class="badge bg-light text-dark border">Latest</span><% } %>
                      </div>
                      <div class="fw-bold mt-2"><%= formatLifecycleAction(event.action) %></div>
                      <div class="small text-muted">
                        <i class="bi bi-person-circle me-1"></i><%= event.actorName || event.actorId || 'System' %>
                      </div>
                    </div>
                    <div class="text-lg-end small text-muted mt-2 mt-lg-0">
                      <i class="bi bi-calendar3 me-1"></i><%= formatDateTime(event.at) %>
                    </div>
                  </header>
                  <div class="leave-lifecycle-status-chain">
                    <span class="leave-lifecycle-status-pill"><%= lifecycleStatusLabel(event.oldStatus) %></span>
                    <i class="bi bi-arrow-right text-muted"></i>
                    <span class="leave-lifecycle-status-pill"><%= lifecycleStatusLabel(event.newStatus) %></span>
                  </div>
                  <% if (event.note) { %>
                    <div class="leave-lifecycle-note small">
                      <i class="bi bi-chat-left-text me-1"></i><%= event.note %>
                    </div>
                  <% } %>
                </div>
              </article>
            <% }) %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<% if (canApprove) { %>
  <div class="modal fade" id="leaveTaskCreateModal" tabindex="-1" aria-labelledby="leaveTaskCreateModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
      <div class="modal-content">
        <div class="modal-header">
          <h2 class="modal-title h5" id="leaveTaskCreateModalLabel"><i class="bi bi-list-task me-2"></i>Create School Task</h2>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <form id="leaveTaskCreateForm">
          <div class="modal-body">
            <input type="hidden" id="leaveTaskAssignedPersonId" name="assignedPersonId">
            <input type="hidden" id="leaveTaskAssignedPersonName" name="assignedPersonName">
            <div class="row g-3">
              <div class="col-md-8">
                <label class="form-label" for="leaveTaskAssigneeLabel">Assignee <span class="text-danger">*</span></label>
                <div class="input-group">
                  <input class="form-control bg-white" id="leaveTaskAssigneeLabel" placeholder="Select a person" readonly required>
                  <button type="button" class="btn btn-outline-primary" id="leaveTaskPickPersonBtn"><i class="bi bi-person-search me-1"></i>Select</button>
                </div>
              </div>
              <div class="col-md-4">
                <label class="form-label" for="leaveTaskDueDate">Due Date</label>
                <input class="form-control" type="date" id="leaveTaskDueDate" name="dueDate">
              </div>
              <div class="col-md-8">
                <label class="form-label" for="leaveTaskTitle">Task Title <span class="text-danger">*</span></label>
                <input class="form-control" id="leaveTaskTitle" name="title" maxlength="220" value="Review leave request for <%= row.requesterName || row.requesterPersonId || 'requester' %>" required>
              </div>
              <div class="col-md-4">
                <label class="form-label" for="leaveTaskSeverity">Severity</label>
                <select class="form-select" id="leaveTaskSeverity" name="severity">
                  <option value="info">Info</option>
                  <option value="warning" selected>Warning</option>
                  <option value="urgent">Urgent</option>
                  <option value="error">Error</option>
                </select>
              </div>
              <div class="col-12">
                <label class="form-label" for="leaveTaskDescription">Task Details <span class="text-danger">*</span></label>
                <textarea class="form-control" id="leaveTaskDescription" name="description" rows="4" maxlength="2000" required>Review leave request <%= row.id %> for <%= row.requesterName || row.requesterPersonId || 'requester' %>.</textarea>
              </div>
              <div class="col-12">
                <label class="form-label" for="leaveTaskNote">Internal Note</label>
                <textarea class="form-control" id="leaveTaskNote" name="note" rows="2" maxlength="1000"></textarea>
              </div>
            </div>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary"><i class="bi bi-plus-circle me-1"></i>Create School Task</button>
          </div>
        </form>
      </div>
    </div>
  </div>
  <%- include('partials/modal_GenericPicker', { user }) %>
<% } %>

<script>
  (function () {
    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, (ch) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
      }[ch]));
    }

    async function showLeaveRequestMessage({ title, message, icon = 'info', buttons, size = 'md' } = {}) {
      if (typeof window.showMessageModal === 'function') {
        return window.showMessageModal({
          title: title || 'Leave Request',
          icon,
          message: message || '',
          size,
          buttons: buttons && buttons.length ? buttons : [{ text: 'OK', class: 'btn-primary' }]
        });
      }
      console.warn(`${title || 'Leave Request'}: ${message || ''}`);
      return buttons?.[0]?.text || 'OK';
    }

    function showLeaveRequestWaitingModal({
      title = 'Please wait',
      note = 'Processing your request...',
      operation = ''
    } = {}) {
      if (typeof window.showLoading !== 'function') return null;
      return window.showLoading({ title, note, operation });
    }

    function hideLeaveRequestWaitingModal(token = null) {
      if (typeof window.hideLoading !== 'function') return;
      if (token) {
        window.hideLoading(token);
        return;
      }
      window.hideLoading();
    }

    function runAfterPageLoad(callback) {
      if (document.readyState === 'complete') {
        setTimeout(callback, 0);
      } else {
        window.addEventListener('load', () => setTimeout(callback, 0), { once: true });
      }
    }

    function displayNameForPickerItem(item) {
      const firstName = String(item?.firstName || item?.name?.first || '').trim();
      const lastName = String(item?.lastName || item?.name?.last || '').trim();
      const preferredName = String(item?.preferredName || item?.name?.preferred || '').trim();
      const directName = String(item?.label || item?.displayName || item?.fullName || item?.name || '').trim();
      const name = preferredName || [firstName, lastName].filter(Boolean).join(' ').trim() || directName;
      const id = String(item?.personId || item?.id || '').trim();
      return id ? `${name || id} (${id})` : (name || 'Selected person');
    }

    function openLeaveTaskModal() {
      const modalEl = document.getElementById('leaveTaskCreateModal');
      if (!modalEl || !window.bootstrap) return;
      bootstrap.Modal.getOrCreateInstance(modalEl).show();
    }

    async function pickLeaveTaskPerson() {
      if (!window.GenericPicker || !window.GenericPickerPresets) {
        await showLeaveRequestMessage({
          title: 'Person Picker',
          icon: 'warning',
          message: 'The person picker is not available on this page. Please refresh and try again.'
        });
        return;
      }
      const context = (window.GenericPickerContexts && typeof window.GenericPickerContexts.activeOrganizationScope === 'function')
        ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
        : undefined;
      const config = GenericPickerPresets.person({
        title: 'Select Task Assignee',
        apiEndpoint: '/school/tasks/api/eligible-persons?allowedRoles=teacher,staff',
        searchFields: 'id,firstName,lastName,name.first,name.last,name.preferred,preferredName,email,personId',
        context
      });
      config.multiselect = false;
      config.onSelect = (selected) => {
        const item = Array.isArray(selected) ? selected[0] : selected;
        if (!item) return;
        const personId = String(item?.personId || item?.id || '').trim();
        const label = displayNameForPickerItem(item);
        const personIdEl = document.getElementById('leaveTaskAssignedPersonId');
        const personNameEl = document.getElementById('leaveTaskAssignedPersonName');
        const labelEl = document.getElementById('leaveTaskAssigneeLabel');
        if (personIdEl) personIdEl.value = personId;
        if (personNameEl) personNameEl.value = label;
        if (labelEl) labelEl.value = label;
      };
      GenericPicker.open(config);
    }

    async function createLeaveTask(event) {
      event.preventDefault();
      const form = event.currentTarget;
      const leaveId = document.getElementById('createLeaveTaskBtn')?.dataset.id
        || document.getElementById('createLeaveTaskFooterBtn')?.dataset.id
        || '';
      const data = new FormData(form);
      const payload = {
        assignedPersonId: String(data.get('assignedPersonId') || '').trim(),
        assignedPersonName: String(data.get('assignedPersonName') || '').trim(),
        title: String(data.get('title') || '').trim(),
        description: String(data.get('description') || '').trim(),
        dueDate: String(data.get('dueDate') || '').trim(),
        severity: String(data.get('severity') || 'warning').trim(),
        note: String(data.get('note') || '').trim()
      };
      if (!payload.assignedPersonId || !payload.title || !payload.description) {
        await showLeaveRequestMessage({
          title: 'Create School Task',
          icon: 'warning',
          message: 'Please select an assignee and enter a task title and details.'
        });
        return;
      }
      if (typeof window.showLoading === 'function') window.showLoading('Creating School Task...');
      try {
        const response = await fetch(`/school/leave-requests/api/${encodeURIComponent(leaveId)}/create-task`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Ajax-Request': 'true'
          },
          credentials: 'same-origin',
          body: JSON.stringify(payload)
        });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || result.status === 'error') throw new Error(result.message || 'The School Task could not be created.');
        const taskId = result.task && result.task.id ? result.task.id : '';
        const taskUrl = taskId ? `/school/tasks/detail/${encodeURIComponent(taskId)}` : '/school/tasks';
        const modalEl = document.getElementById('leaveTaskCreateModal');
        if (modalEl && window.bootstrap) bootstrap.Modal.getOrCreateInstance(modalEl).hide();
        await showLeaveRequestMessage({
          title: 'School Task Created',
          icon: 'success',
          message: 'School Task created successfully.<br><a class="fw-bold" href="' + escapeHtml(taskUrl) + '" target="_blank" rel="noopener">Open School Task</a>'
        });
      } catch (error) {
        await showLeaveRequestMessage({
          title: 'Create School Task',
          icon: 'error',
          message: escapeHtml(error.message || 'The School Task could not be created.'),
          buttons: [{ text: 'OK', class: 'btn-danger' }]
        });
      } finally {
        if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
      }
    }

    async function requestReviewNote(action) {
      const isApprove = action === 'approve';
      const confirmText = isApprove ? 'Approve' : 'Reject';
      const noteId = `leaveReviewNote_${Date.now()}`;
      const result = await showLeaveRequestMessage({
        title: `${confirmText} Leave Request`,
        icon: isApprove ? 'success' : 'warning',
        size: 'lg',
        message: `
          <label class="form-label" for="${noteId}">Optional review note</label>
          <textarea class="form-control" id="${noteId}" rows="4" maxlength="2000" placeholder="Add a note for the request lifecycle"></textarea>
        `,
        buttons: [
          { text: 'Cancel', class: 'btn-secondary' },
          { text: confirmText, class: isApprove ? 'btn-success' : 'btn-danger' }
        ]
      });
      if (result !== confirmText) return null;
      return document.getElementById(noteId)?.value || '';
    }

    async function confirmCancel() {
      const result = await showLeaveRequestMessage({
        title: 'Cancel Leave Request',
        icon: 'warning',
        message: 'Cancel this leave request?',
        buttons: [
          { text: 'Keep Request', class: 'btn-secondary' },
          { text: 'Cancel Request', class: 'btn-danger' }
        ]
      });
      return result === 'Cancel Request';
    }

    async function confirmDelete() {
      const result = await showLeaveRequestMessage({
        title: 'Delete Leave Request',
        icon: 'warning',
        message: 'Delete this leave request permanently? Related tasks will also be removed.',
        buttons: [
          { text: 'Keep Request', class: 'btn-secondary' },
          { text: 'Delete Request', class: 'btn-danger' }
        ]
      });
      return result === 'Delete Request';
    }

    async function fetchLeaveSessionConflictState(requestId) {
      const response = await fetch(`/school/leave-requests/api/${encodeURIComponent(requestId)}/session-conflicts`, {
        headers: { 'X-Ajax-Request': 'true', Accept: 'application/json' },
        credentials: 'same-origin'
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok || payload.status === 'error') {
        throw new Error(payload.message || 'Could not verify session conflicts.');
      }
      return payload.data || {};
    }

    async function promptResolveSessionsBeforeApproval(requestId, state) {
      const unresolved = Number(state?.unresolvedCount || 0);
      const total = Number(state?.totalCount || 0);
      const resolveUrl = state?.resolveSessionsUrl || `/school/leave-requests/resolve-sessions/${encodeURIComponent(requestId)}`;
      const detailHtml = total > 0
        ? `<div class="mt-2">${unresolved} of ${total} overlapping class session(s) still assign the leave requester.</div>`
        : '';
      const result = await showLeaveRequestMessage({
        title: 'Resolve Sessions Before Approval',
        icon: 'warning',
        size: 'lg',
        message: `This leave request cannot be approved until substitute instructors are assigned for every overlapping class session.${detailHtml}`,
        buttons: [
          { text: 'Cancel', class: 'btn-secondary' },
          { text: 'Resolve Sessions', class: 'btn-warning' }
        ]
      });
      if (result === 'Resolve Sessions') {
        window.location.href = resolveUrl;
      }
      return false;
    }

    async function ensureReadyToApprove(requestId, requesterRole) {
      const teacherStaffRoles = ['teacher', 'staff', 'admin'];
      const role = String(requesterRole || '').trim().toLowerCase();
      if (!teacherStaffRoles.includes(role)) return true;
      const state = await fetchLeaveSessionConflictState(requestId);
      if (!state.requiresResolution || state.readyForApproval) return true;
      await promptResolveSessionsBeforeApproval(requestId, state);
      return false;
    }

    async function postAction(action, id, note = '') {
      if (action === 'delete') {
        const confirmed = await confirmDelete();
        if (!confirmed) return;
      }
      const response = await fetch(`/school/leave-requests/api/${encodeURIComponent(id)}/${encodeURIComponent(action)}`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Ajax-Request': 'true'
        },
        body: JSON.stringify({ note })
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok || payload.status === 'error') {
        if (payload.code === 'LEAVE_SESSIONS_UNRESOLVED') {
          await promptResolveSessionsBeforeApproval(id, payload.data || {});
          return;
        }
        await showLeaveRequestMessage({
          title: 'Leave Request',
          icon: 'error',
          message: payload.message || 'The leave request could not be updated.',
          buttons: [{ text: 'OK', class: 'btn-danger' }]
        });
        return;
      }
      window.location.reload();
    }

    document.querySelectorAll('.leave-request-action').forEach((button) => {
      button.addEventListener('click', async () => {
        const action = button.dataset.action || '';
        const id = button.dataset.id || '';
        if (!action || !id) return;
        if (action === 'cancel') {
          const confirmed = await confirmCancel();
          if (!confirmed) return;
          await postAction(action, id);
          return;
        }
        const note = ['approve', 'reject'].includes(action) ? await requestReviewNote(action) : '';
        if (note === null) return;
        if (action === 'approve') {
          const approveBtn = document.getElementById('leaveApproveBtn');
          const requesterRole = approveBtn?.dataset?.requesterRole || <%- JSON.stringify(String(row.requesterRole || '')) %>;
          const ready = await ensureReadyToApprove(id, requesterRole);
          if (!ready) return;
        }
        await postAction(action, id, note);
      });
    });
    document.getElementById('createLeaveTaskBtn')?.addEventListener('click', openLeaveTaskModal);
    document.getElementById('createLeaveTaskFooterBtn')?.addEventListener('click', openLeaveTaskModal);
    document.getElementById('leaveTaskPickPersonBtn')?.addEventListener('click', pickLeaveTaskPerson);
    document.getElementById('leaveTaskCreateForm')?.addEventListener('submit', createLeaveTask);

    async function syncLeaveSessionConflictState() {
      const requestId = <%- JSON.stringify(row.id || '') %>;
      const requesterRole = <%- JSON.stringify(String(row.requesterRole || '').toLowerCase()) %>;
      const requestStatus = <%- JSON.stringify(status) %>;
      const canApprove = <%- JSON.stringify(Boolean(canApprove)) %>;
      const teacherStaffRoles = ['teacher', 'staff'];
      const reviewableStatuses = ['submitted', 'pending_reapproval'];
      if (!canApprove || !teacherStaffRoles.includes(requesterRole) || !reviewableStatuses.includes(requestStatus)) return;

      const banner = document.getElementById('leaveSessionConflictBanner');
      const summary = document.getElementById('leaveSessionConflictSummary');
      const detail = document.getElementById('leaveSessionConflictDetail');
      const approveBtn = document.getElementById('leaveApproveBtn');
      const resolveLink = document.getElementById('leaveResolveSessionsLink');
      let loadingToken = null;

      try {
        loadingToken = showLeaveRequestWaitingModal({
          title: 'Please wait',
          note: 'Checking for overlapping class sessions...',
          operation: 'Leave request conflict review'
        });

        const response = await fetch(`/school/leave-requests/api/${encodeURIComponent(requestId)}/session-conflicts`, {
          headers: { 'X-Ajax-Request': 'true', Accept: 'application/json' },
          credentials: 'same-origin'
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload.status === 'error') return;
        const state = payload.data || {};
        const total = Number(state.totalCount || 0);
        const unresolved = Number(state.unresolvedCount || 0);

        if (total === 0) {
          banner?.classList.add('d-none');
          if (approveBtn) {
            approveBtn.disabled = false;
            approveBtn.title = '';
          }
          return;
        }

        banner?.classList.remove('d-none');
        if (summary) {
          summary.textContent = unresolved > 0
            ? `${unresolved} of ${total} overlapping class session(s) still need substitute instructors.`
            : `All ${total} overlapping session(s) have substitutes assigned.`;
        }
        if (detail) {
          detail.textContent = unresolved > 0
            ? 'Open Resolve sessions to assign substitutes before approval.'
            : 'You can approve this leave request now.';
        }
        if (approveBtn) {
          approveBtn.disabled = unresolved > 0;
          approveBtn.title = unresolved > 0 ? 'Resolve all overlapping sessions before approving.' : '';
        }
        if (resolveLink && unresolved === 0) {
          resolveLink.classList.remove('btn-warning');
          resolveLink.classList.add('btn-outline-success');
          resolveLink.innerHTML = '<i class="bi bi-check2-circle me-1"></i>View resolutions';
        }
      } catch (_) { /* ignore banner failures */ }
      finally {
        hideLeaveRequestWaitingModal(loadingToken);
      }
    }

    runAfterPageLoad(() => {
      syncLeaveSessionConflictState();
    });
  })();
</script>
