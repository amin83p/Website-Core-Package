<%
  const s = staff || {};
  const isEdit = !!s.id;
  const routeId = (s.id || '');
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-heading size-md m-0"><i class="bi bi-people-fill me-2"></i><%= title %></h1>
    <a href="/school/staff" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back to List</a>
  </div>

  <div class="form-container wide" style="max-width: 1300px;">
    <form id="staffForm" action="<%= isEdit ? '/school/staff/edit/' + routeId : '/school/staff/new' %>" method="POST">
      <input type="hidden" name="actionStateId" id="hid_actionStateId" value="<%= asid %>">
      <input type="hidden" name="newPersonEmails" id="hid_newPersonEmails" value="[]">
      <input type="hidden" name="newPersonPhones" id="hid_newPersonPhones" value="[]">
      <input type="hidden" name="newPersonAddresses" id="hid_newPersonAddresses" value="[]">
      <input type="hidden" name="compensationProfiles" id="hid_compensationProfiles" value="[]">
      <script type="application/json" id="init_personOrganizations"><%- JSON.stringify(typeof personOrganizations !== 'undefined' ? (personOrganizations || []) : []).replace(/</g, '\\u003c') %></script>
      <script type="application/json" id="init_organizationLookup"><%- JSON.stringify(typeof organizationLookup !== 'undefined' ? (organizationLookup || {}) : {}).replace(/</g, '\\u003c') %></script>
      <script type="application/json" id="init_compensationProfiles"><%- JSON.stringify(s.compensationProfiles || []) %></script>
      <script type="application/json" id="comp_departments"><%- JSON.stringify(departments || []) %></script>
      <script type="application/json" id="comp_methods"><%- JSON.stringify(compensationMethods || []) %></script>

      <ul class="nav nav-tabs mb-4" role="tablist">
        <li class="nav-item"><button class="nav-link active fw-bold" data-bs-toggle="tab" data-bs-target="#tab-person" type="button">Step 1: Person</button></li>
        <li class="nav-item"><button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-profile" type="button">Step 2: Profile</button></li>
        <li class="nav-item"><button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-admin" type="button">Step 3: Admin</button></li>
      </ul>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 tab-content">
          <div class="tab-pane fade show active" id="tab-person">
            <% if (!isEdit) { %>
              <div class="alert alert-light border shadow-sm mb-4">
                <div class="fw-bold mb-2"><i class="bi bi-person-plus me-2"></i>Person Source</div>
                <div class="d-flex flex-wrap gap-4">
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="personMode" id="personModeExisting" value="existing" checked>
                    <label class="form-check-label fw-bold" for="personModeExisting">Use Existing Person</label>
                  </div>
                  <div class="form-check">
                    <input class="form-check-input" type="radio" name="personMode" id="personModeNew" value="new">
                    <label class="form-check-label fw-bold" for="personModeNew">Create New Person</label>
                  </div>
                </div>
              </div>
            <% } else { %>
              <input type="hidden" name="personMode" value="existing">
            <% } %>

            <div id="existingPersonBlock">
              <div class="row">
                <div class="col-md-8 mb-3">
                  <label class="form-label fw-bold">Select Person *</label>
                  <div class="input-group">
                    <input type="hidden" name="personId" id="inp_personId" value="<%= s.personId || '' %>" required>
                    <input type="text" id="inp_personName" class="form-control size-md bg-white border-primary fw-bold" placeholder="Search Person Directory..." value="<%= personName || '' %>" readonly required>
                    <button type="button" class="btn btn-primary" id="btnPickPerson" <%= isEdit ? 'disabled' : '' %>><i class="bi bi-search"></i></button>
                  </div>
                </div>
                <div class="col-md-4 mb-3">
                  <label class="form-label fw-bold">Staff ID</label>
                  <input type="text" name="staffId" class="form-control size-md font-monospace" value="<%= s.id || '' %>" placeholder="Auto-generated if blank" <%= isEdit ? 'readonly' : '' %>>
                </div>
              </div>
              <div class="card border shadow-sm bg-light-subtle mb-3">
                <div class="card-header bg-light fw-bold">
                  <i class="bi bi-diagram-3 me-2"></i>Current Person Role Composition
                </div>
                <div class="card-body" id="personRoleSummary"></div>
              </div>
            </div>

            <% if (!isEdit) { %>
              <div id="newPersonBlock" class="d-none">
                <div class="card shadow-sm border-0 mb-3">
                  <div class="card-body">
                    <h6 class="fw-bold text-uppercase text-muted mb-3"><i class="bi bi-person-bounding-box me-2"></i>Profile & Identity</h6>
                    <div class="row g-3 mb-3">
                      <div class="col-md-4">
                        <label class="form-label fw-bold">First Name *</label>
                        <input type="text" name="newPersonFirstName" id="inp_newPersonFirstName" class="form-control size-md" placeholder="First name">
                      </div>
                      <div class="col-md-4">
                        <label class="form-label fw-bold">Middle Name</label>
                        <input type="text" name="newPersonMiddleName" class="form-control size-md" placeholder="Middle name (optional)">
                      </div>
                      <div class="col-md-4">
                        <label class="form-label fw-bold">Last Name *</label>
                        <input type="text" name="newPersonLastName" id="inp_newPersonLastName" class="form-control size-md" placeholder="Last name">
                      </div>
                    </div>
                    <div class="row g-3 mb-3">
                      <div class="col-md-6">
                        <label class="form-label fw-bold">Preferred Name</label>
                        <input type="text" name="newPersonPreferredName" class="form-control size-md" placeholder="Optional preferred name">
                      </div>
                      <div class="col-md-6">
                        <div class="form-check form-switch mt-4 pt-1">
                          <input class="form-check-input" type="checkbox" id="inp_newPersonActive" name="newPersonActive" checked>
                          <label class="form-check-label fw-bold" for="inp_newPersonActive">Active Person Profile</label>
                        </div>
                      </div>
                    </div>
                    <div class="row g-3">
                      <div class="col-md-6">
                        <label class="form-label fw-bold">Gender *</label>
                        <select name="newPersonGender" id="inp_newPersonGender" class="form-select size-md">
                          <option value="">-- Select Gender --</option>
                          <option value="male">Male</option>
                          <option value="female">Female</option>
                          <option value="nonbinary">Non-binary</option>
                          <option value="other">Other</option>
                        </select>
                      </div>
                      <div class="col-md-6">
                        <label class="form-label fw-bold">Date of Birth *</label>
                        <input type="date" name="newPersonDateOfBirth" id="inp_newPersonDateOfBirth" class="form-control size-md">
                      </div>
                    </div>
                  </div>
                </div>

                <div class="row g-3 mb-3">
                  <div class="col-lg-6">
                    <div class="card shadow-sm border-0 h-100">
                      <div class="card-header bg-light fw-bold text-uppercase small text-muted">
                        <i class="bi bi-envelope-paper me-2"></i>Communication
                      </div>
                      <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                          <label class="form-label mb-0 fw-bold">Email Addresses *</label>
                          <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddNewPersonEmail"><i class="bi bi-plus-lg"></i> Add</button>
                        </div>
                        <div id="newPersonEmailsList" class="mb-4"></div>

                        <hr class="text-muted opacity-25">

                        <div class="d-flex justify-content-between align-items-center mb-2">
                          <label class="form-label mb-0 fw-bold">Phone Numbers</label>
                          <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddNewPersonPhone"><i class="bi bi-plus-lg"></i> Add</button>
                        </div>
                        <div id="newPersonPhonesList"></div>
                      </div>
                    </div>
                  </div>
                  <div class="col-lg-6">
                    <div class="card shadow-sm border-0 h-100">
                      <div class="card-header bg-light fw-bold text-uppercase small text-muted">
                        <i class="bi bi-geo-alt me-2"></i>Addresses
                      </div>
                      <div class="card-body bg-light-subtle">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                          <label class="form-label mb-0 fw-bold">Address Records</label>
                          <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddNewPersonAddressManual"><i class="bi bi-plus-lg"></i> Add</button>
                        </div>
                        <div id="newPersonAddressesList"></div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="row">
                  <div class="col-md-12">
                    <label class="form-label fw-bold">Person Notes</label>
                    <textarea name="newPersonNotes" class="form-control size-md" rows="2" placeholder="Optional notes..."></textarea>
                  </div>
                </div>
              </div>
            <% } %>
          </div>

          <div class="tab-pane fade" id="tab-profile">
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label fw-bold">Employee Number</label>
                <input type="text" name="employeeNumber" class="form-control size-md" value="<%= s.employeeNumber || '' %>" placeholder="Internal HR number">
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Job Title</label>
                <input type="text" name="jobTitle" class="form-control size-md" value="<%= s.jobTitle || '' %>" placeholder="e.g. Registrar Assistant">
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Department</label>
                <select name="departmentId" class="form-select size-md">
                  <option value="">-- Select Department --</option>
                  <% (departments || []).forEach(d => { %>
                    <option value="<%= d.id %>" <%= String(s.departmentId || '') === String(d.id) ? 'selected' : '' %>><%= d.code || d.id %> - <%= d.name || '' %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Employment Type *</label>
                <select name="employmentType" class="form-select size-md" required>
                  <% (employmentTypes || []).forEach(et => { %>
                    <option value="<%= et %>" <%= (s.employmentType || 'Full-Time') === et ? 'selected' : '' %>><%= et %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Status *</label>
                <select name="status" class="form-select size-md" required>
                  <% (statuses || []).forEach(st => { %>
                    <option value="<%= st %>" <%= (s.status || 'Active') === st ? 'selected' : '' %>><%= st %></option>
                  <% }); %>
                </select>
              </div>
              <div class="col-md-12 mt-3">
                <div class="card border shadow-sm">
                  <div class="card-header bg-light d-flex justify-content-between align-items-center">
                    <span class="fw-bold"><i class="bi bi-cash-stack me-2"></i>Compensation Profiles</span>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddCompensation"><i class="bi bi-plus-lg"></i> Add Compensation</button>
                  </div>
                  <div class="card-body">
                    <div id="compensationProfilesList"></div>
                    <div class="form-text small">Each entry includes Department, payment method, amount/rate, date range, and contract reference. Overlapping dates in the same department are blocked.</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="tab-pane fade" id="tab-admin">
            <div class="row g-3">
              <div class="col-md-4">
                <label class="form-label fw-bold">Hire Date *</label>
                <input type="date" name="hireDate" class="form-control size-md" value="<%= s.hireDate || '' %>" required>
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Contract End Date</label>
                <input type="date" name="contractEndDate" class="form-control size-md" value="<%= s.contractEndDate || '' %>">
              </div>
              <div class="col-md-4">
                <label class="form-label fw-bold">Work Location</label>
                <input type="text" name="workLocation" class="form-control size-md" value="<%= s.workLocation || '' %>" placeholder="Campus / office location">
              </div>
              <div class="col-md-12">
                <label class="form-label fw-bold">Responsibilities</label>
                <textarea name="responsibilities" class="form-control size-md" rows="3" placeholder="Main responsibilities and operational scope..."><%= s.responsibilities || '' %></textarea>
              </div>
              <div class="col-md-12">
                <label class="form-label fw-bold">Internal Notes</label>
                <textarea name="notes" class="form-control size-md" rows="4" placeholder="Admin notes, compliance remarks, internal context..."><%= s.notes || '' %></textarea>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md fw-bold px-4">Save Staff</button>
        <a href="/school/staff" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction" data-return-url="/school/staff">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/modal_GenericPicker') %>

<script>
(function () {
  const form = document.getElementById('staffForm');
  const hidNewPersonEmails = document.getElementById('hid_newPersonEmails');
  const hidNewPersonPhones = document.getElementById('hid_newPersonPhones');
  const hidNewPersonAddresses = document.getElementById('hid_newPersonAddresses');
  const newPersonEmailsList = document.getElementById('newPersonEmailsList');
  const newPersonPhonesList = document.getElementById('newPersonPhonesList');
  const newPersonAddressesList = document.getElementById('newPersonAddressesList');
  const btnAddNewPersonEmail = document.getElementById('btnAddNewPersonEmail');
  const btnAddNewPersonPhone = document.getElementById('btnAddNewPersonPhone');
  const btnAddNewPersonAddressManual = document.getElementById('btnAddNewPersonAddressManual');
  const hidCompensationProfiles = document.getElementById('hid_compensationProfiles');
  const compensationProfilesList = document.getElementById('compensationProfilesList');
  const btnAddCompensation = document.getElementById('btnAddCompensation');
  const personRoleSummary = document.getElementById('personRoleSummary');

  let newPersonEmails = [{ type: 'primary', email: '', isPrimary: true }];
  let newPersonPhones = [];
  let newPersonAddresses = [];
  let selectedPersonOrganizations = readJsonSafe(document.getElementById('init_personOrganizations')?.textContent, []);
  const organizationLookup = readJsonSafe(document.getElementById('init_organizationLookup')?.textContent, {});
  const departmentOptions = readJsonSafe(document.getElementById('comp_departments')?.textContent, []);
  const compensationMethods = readJsonSafe(document.getElementById('comp_methods')?.textContent, ['hourly']);
  let compensationProfiles = readJsonSafe(document.getElementById('init_compensationProfiles')?.textContent, []);

  function showMsg(opts) {
    if (typeof showMessageModal === 'function') return showMessageModal(opts);
    alert(opts?.message || 'Done');
    return Promise.resolve();
  }

  async function askYesNo(opts = {}) {
    const title = String(opts.title || 'Confirm');
    const message = String(opts.message || 'Are you sure?');
    const yesText = String(opts.yesText || 'Yes');
    const noText = String(opts.noText || 'No');

    if (typeof showMessageModal !== 'function') {
      const plain = message.replace(/<br\s*\/?>/gi, '\n').replace(/<[^>]+>/g, '');
      return Promise.resolve(confirm(plain));
    }

    return new Promise((resolve) => {
      showMessageModal({
        title,
        icon: 'question',
        message,
        buttons: [
          { text: noText, class: 'btn-secondary' },
          { text: yesText, class: 'btn-primary' }
        ]
      }).then((result) => resolve(result === yesText)).catch(() => resolve(false));
    });
  }

  function readJsonSafe(rawValue, fallback) {
    if (!rawValue) return fallback;
    try {
      return JSON.parse(rawValue);
    } catch {
      return fallback;
    }
  }

  function syncNewPersonHiddenState() {
    if (hidNewPersonEmails) hidNewPersonEmails.value = JSON.stringify(newPersonEmails);
    if (hidNewPersonPhones) hidNewPersonPhones.value = JSON.stringify(newPersonPhones);
    if (hidNewPersonAddresses) hidNewPersonAddresses.value = JSON.stringify(newPersonAddresses);
  }

  function syncCompensationHiddenState() {
    if (hidCompensationProfiles) hidCompensationProfiles.value = JSON.stringify(compensationProfiles);
  }

  function toLabelCase(v) {
    return String(v || '')
      .replace(/([a-z0-9])([A-Z])/g, '$1_$2')
      .split('_')
      .map((x) => x ? x[0].toUpperCase() + x.slice(1) : '')
      .join(' ');
  }

  function safeHtml(value) {
    return String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function normalizePersonRoles(org) {
    const rawRoles = Array.isArray(org?.roles) && org.roles.length
      ? org.roles
      : (org?.role ? [org.role] : []);
    return Array.from(new Set(rawRoles.map((role) => String(role || '').trim()).filter(Boolean)));
  }

  function getOrganizationDisplayName(org) {
    const direct = String(org?.orgName || org?.name || org?.organizationName || '').trim();
    if (direct) return direct;
    const id = String(org?.orgId || '').trim();
    if (id && organizationLookup && Object.prototype.hasOwnProperty.call(organizationLookup, id)) {
      return String(organizationLookup[id] || '').trim() || id;
    }
    return id || 'Unknown Organization';
  }

  function renderPersonRoleSummary() {
    if (!personRoleSummary) return;

    const orgs = Array.isArray(selectedPersonOrganizations) ? selectedPersonOrganizations : [];
    if (!orgs.length) {
      personRoleSummary.innerHTML = '<div class="text-muted small">No organization role assignments are available for the selected person yet.</div>';
      return;
    }

    personRoleSummary.innerHTML = orgs.map((org) => {
      const roles = normalizePersonRoles(org);
      const roleBadges = roles.length
        ? roles.map((role) => `<span class="badge text-bg-primary-subtle text-primary-emphasis border me-1 mb-1">${safeHtml(toLabelCase(role))}</span>`).join('')
        : '<span class="text-muted small">No roles assigned</span>';

      return (
        '<div class="border rounded p-3 mb-2 bg-white">' +
          `<div class="fw-bold">${safeHtml(getOrganizationDisplayName(org))}</div>` +
          `<div class="small text-muted mb-2">Org ID: ${safeHtml(org?.orgId || '-')}</div>` +
          `<div>${roleBadges}</div>` +
        '</div>'
      );
    }).join('');
  }

  function renderCompensationProfiles() {
    if (!compensationProfilesList) return;
    compensationProfilesList.innerHTML = '';
    if (!Array.isArray(compensationProfiles)) compensationProfiles = [];

    if (!compensationProfiles.length) {
      compensationProfilesList.innerHTML = '<div class="text-muted small">No compensation entries yet.</div>';
      syncCompensationHiddenState();
      return;
    }

    compensationProfiles.forEach((row, idx) => {
      const deptOptions = ['<option value="">-- Department --</option>']
        .concat((departmentOptions || []).map((d) => {
          const id = String(d?.id || '');
          const selected = String(row.departmentId || '') === id ? 'selected' : '';
          const label = `${d?.code || d?.id || ''} - ${d?.name || ''}`.trim();
          return `<option value="${id}" ${selected}>${label}</option>`;
        }))
        .join('');

      const methodOptions = (compensationMethods || []).map((m) => {
        const selected = String(row.paymentMethod || 'hourly') === String(m) ? 'selected' : '';
        return `<option value="${m}" ${selected}>${toLabelCase(m)}</option>`;
      }).join('');

      const wrap = document.createElement('div');
      wrap.className = 'border rounded p-3 mb-3 bg-white';
      wrap.innerHTML =
        `<div class="d-flex justify-content-between align-items-center mb-2">
          <div class="fw-bold small text-muted">Compensation #${idx + 1}</div>
          <button type="button" class="btn btn-sm btn-outline-danger comp-remove"><i class="bi bi-trash"></i></button>
        </div>
        <div class="row g-2">
          <div class="col-md-3"><label class="form-label fw-bold small">Department *</label><select class="form-select size-md comp-dept">${deptOptions}</select></div>
          <div class="col-md-3"><label class="form-label fw-bold small">Payment Method *</label><select class="form-select size-md comp-method">${methodOptions}</select></div>
          <div class="col-md-2"><label class="form-label fw-bold small">Hourly Rate</label><input type="number" step="0.01" min="0" class="form-control size-md comp-hourly" value="${row.hourlyRate ?? ''}"></div>
          <div class="col-md-2"><label class="form-label fw-bold small">Payment Amount</label><input type="number" step="0.01" min="0" class="form-control size-md comp-amount" value="${row.paymentAmount ?? ''}"></div>
          <div class="col-md-2"><label class="form-label fw-bold small">Contract #</label><input type="text" class="form-control size-md comp-contract" value="${String(row.contractId || '').replace(/\"/g, '&quot;')}"></div>
          <div class="col-md-3"><label class="form-label fw-bold small">Effective From</label><input type="date" class="form-control size-md comp-from" value="${row.effectiveFrom || ''}"></div>
          <div class="col-md-3"><label class="form-label fw-bold small">Effective To</label><input type="date" class="form-control size-md comp-to" value="${row.effectiveTo || ''}"></div>
          <div class="col-md-6"><label class="form-label fw-bold small">Notes</label><input type="text" class="form-control size-md comp-notes" value="${String(row.notes || '').replace(/\"/g, '&quot;')}"></div>
        </div>`;

      const setValue = (key, value) => { compensationProfiles[idx][key] = value; syncCompensationHiddenState(); };
      wrap.querySelector('.comp-dept').addEventListener('change', (e) => setValue('departmentId', e.target.value));
      wrap.querySelector('.comp-method').addEventListener('change', (e) => setValue('paymentMethod', e.target.value));
      wrap.querySelector('.comp-hourly').addEventListener('input', (e) => setValue('hourlyRate', e.target.value));
      wrap.querySelector('.comp-amount').addEventListener('input', (e) => setValue('paymentAmount', e.target.value));
      wrap.querySelector('.comp-contract').addEventListener('input', (e) => setValue('contractId', e.target.value));
      wrap.querySelector('.comp-from').addEventListener('change', (e) => setValue('effectiveFrom', e.target.value));
      wrap.querySelector('.comp-to').addEventListener('change', (e) => setValue('effectiveTo', e.target.value));
      wrap.querySelector('.comp-notes').addEventListener('input', (e) => setValue('notes', e.target.value));
      wrap.querySelector('.comp-remove').addEventListener('click', () => {
        compensationProfiles.splice(idx, 1);
        renderCompensationProfiles();
      });

      compensationProfilesList.appendChild(wrap);
    });
    syncCompensationHiddenState();
  }

  function syncPersonModeUI() {
    const modeExisting = document.getElementById('personModeExisting');
    const modeNew = document.getElementById('personModeNew');
    if (!modeExisting && !modeNew) return;

    const selectedMode = modeNew && modeNew.checked ? 'new' : 'existing';
    const existingBlock = document.getElementById('existingPersonBlock');
    const newBlock = document.getElementById('newPersonBlock');
    const personIdInput = document.getElementById('inp_personId');
    const personNameInput = document.getElementById('inp_personName');

    const newPersonRequiredFields = [
      document.getElementById('inp_newPersonFirstName'),
      document.getElementById('inp_newPersonLastName'),
      document.getElementById('inp_newPersonGender'),
      document.getElementById('inp_newPersonDateOfBirth')
    ].filter(Boolean);

    if (selectedMode === 'new') {
      if (existingBlock) existingBlock.classList.add('d-none');
      if (newBlock) newBlock.classList.remove('d-none');
      if (personIdInput) personIdInput.required = false;
      if (personNameInput) personNameInput.required = false;
      newPersonRequiredFields.forEach((el) => { el.required = true; });
      return;
    }

    if (existingBlock) existingBlock.classList.remove('d-none');
    if (newBlock) newBlock.classList.add('d-none');
    if (personIdInput) personIdInput.required = true;
    if (personNameInput) personNameInput.required = true;
    newPersonRequiredFields.forEach((el) => { el.required = false; });
  }

  function renderNewPersonEmails() {
    if (!newPersonEmailsList) return;
    newPersonEmailsList.innerHTML = '';

    if (!newPersonEmails.length) {
      newPersonEmails = [{ type: 'primary', email: '', isPrimary: true }];
    }

    newPersonEmails.forEach((row, index) => {
      const wrap = document.createElement('div');
      wrap.className = 'input-group mb-2';
      wrap.innerHTML =
        '<select class="form-select size-md bg-light border-end-0" style="max-width: 130px;">' +
          '<option value="primary">Primary</option>' +
          '<option value="work">Work</option>' +
          '<option value="personal">Personal</option>' +
        '</select>' +
        '<input type="email" class="form-control size-md" placeholder="email@example.com">' +
        '<button type="button" class="btn btn-outline-danger"><i class="bi bi-x-lg"></i></button>';

      const typeSelect = wrap.querySelector('select');
      const emailInput = wrap.querySelector('input');
      const removeBtn = wrap.querySelector('button');

      typeSelect.value = String(row.type || 'work');
      emailInput.value = String(row.email || '');

      typeSelect.addEventListener('change', () => {
        newPersonEmails[index].type = typeSelect.value;
        syncNewPersonHiddenState();
      });
      emailInput.addEventListener('input', () => {
        newPersonEmails[index].email = emailInput.value;
        syncNewPersonHiddenState();
      });
      removeBtn.addEventListener('click', () => {
        newPersonEmails.splice(index, 1);
        renderNewPersonEmails();
      });

      newPersonEmailsList.appendChild(wrap);
    });

    syncNewPersonHiddenState();
  }

  function renderNewPersonPhones() {
    if (!newPersonPhonesList) return;
    newPersonPhonesList.innerHTML = '';

    newPersonPhones.forEach((row, index) => {
      const wrap = document.createElement('div');
      wrap.className = 'input-group mb-2';
      wrap.innerHTML =
        '<select class="form-select size-md bg-light border-end-0" style="max-width: 130px;">' +
          '<option value="mobile">Mobile</option>' +
          '<option value="work">Work</option>' +
          '<option value="home">Home</option>' +
        '</select>' +
        '<input type="text" class="form-control size-md" placeholder="(555) 123-4567">' +
        '<button type="button" class="btn btn-outline-danger"><i class="bi bi-x-lg"></i></button>';

      const typeSelect = wrap.querySelector('select');
      const numberInput = wrap.querySelector('input');
      const removeBtn = wrap.querySelector('button');

      typeSelect.value = String(row.type || 'mobile');
      numberInput.value = String(row.number || '');

      typeSelect.addEventListener('change', () => {
        newPersonPhones[index].type = typeSelect.value;
        syncNewPersonHiddenState();
      });
      numberInput.addEventListener('input', () => {
        newPersonPhones[index].number = numberInput.value;
        syncNewPersonHiddenState();
      });
      removeBtn.addEventListener('click', () => {
        newPersonPhones.splice(index, 1);
        renderNewPersonPhones();
      });

      newPersonPhonesList.appendChild(wrap);
    });

    syncNewPersonHiddenState();
  }

  function renderNewPersonAddresses() {
    if (!newPersonAddressesList) return;
    newPersonAddressesList.innerHTML = '';

    newPersonAddresses.forEach((row, index) => {
      const card = document.createElement('div');
      card.className = 'card mb-3 border shadow-sm';
      card.innerHTML =
        '<div class="card-body p-3 bg-white rounded">' +
          '<div class="d-flex justify-content-between mb-2">' +
            '<select class="form-select form-select-sm border-0 bg-light fw-bold text-uppercase px-2 addr-type" style="width:auto;">' +
              '<option value="home">HOME</option>' +
              '<option value="work">WORK</option>' +
              '<option value="other">OTHER</option>' +
            '</select>' +
            '<button class="btn btn-sm text-danger addr-remove" type="button"><i class="bi bi-trash"></i></button>' +
          '</div>' +
          '<input class="form-control size-md mb-2 addr-line1" placeholder="Street Address">' +
          '<div class="row g-2">' +
            '<div class="col-6"><input class="form-control size-md addr-city" placeholder="City"></div>' +
            '<div class="col-3"><input class="form-control size-md addr-prov" placeholder="Prov"></div>' +
            '<div class="col-3"><input class="form-control size-md addr-post" placeholder="Postal"></div>' +
          '</div>' +
        '</div>';

      const typeEl = card.querySelector('.addr-type');
      const line1El = card.querySelector('.addr-line1');
      const cityEl = card.querySelector('.addr-city');
      const provEl = card.querySelector('.addr-prov');
      const postEl = card.querySelector('.addr-post');

      typeEl.value = String(row.type || 'home');
      line1El.value = String(row.line1 || '');
      cityEl.value = String(row.city || '');
      provEl.value = String(row.province || '');
      postEl.value = String(row.postalCode || '');

      typeEl.addEventListener('change', () => { newPersonAddresses[index].type = typeEl.value; syncNewPersonHiddenState(); });
      line1El.addEventListener('input', () => { newPersonAddresses[index].line1 = line1El.value; syncNewPersonHiddenState(); });
      cityEl.addEventListener('input', () => { newPersonAddresses[index].city = cityEl.value; syncNewPersonHiddenState(); });
      provEl.addEventListener('input', () => { newPersonAddresses[index].province = provEl.value; syncNewPersonHiddenState(); });
      postEl.addEventListener('input', () => { newPersonAddresses[index].postalCode = postEl.value; syncNewPersonHiddenState(); });

      card.querySelector('.addr-remove').addEventListener('click', () => {
        newPersonAddresses.splice(index, 1);
        renderNewPersonAddresses();
      });

      newPersonAddressesList.appendChild(card);
    });

    syncNewPersonHiddenState();
  }

  document.addEventListener('DOMContentLoaded', function () {
    const pBtn = document.getElementById('btnPickPerson');
    if (pBtn && !pBtn.disabled) {
      pBtn.addEventListener('click', () => {
        GenericPicker.open(GenericPickerPresets.person({
          title: 'Select Person',
          apiEndpoint: '/school/staff/api/eligible-persons',
          placeholder: 'Search by name or email...',
          onSelect: (item) => {
            if (item?.alreadyHasSchoolAccount) {
              const linked = item.linkedSchoolAccount || {};
              const targetUrl = linked.archived ? linked.recoveryUrl : linked.editUrl;
              showMsg({
                title: 'Staff Already Exists',
                icon: 'warning',
                message: `This person already has a Staff account in the active organization.${targetUrl ? `<br><br><a href="${targetUrl}" target="_blank" rel="noopener" class="btn btn-sm btn-outline-primary">Open existing Staff record</a>` : ''}`,
                buttons: [{ text: 'Close', class: 'btn-secondary' }]
              });
              return;
            }
            document.getElementById('inp_personId').value = item.id || '';
            document.getElementById('inp_personName').value = `${item.name?.first || ''} ${item.name?.last || ''}`.trim() || item.id;
            selectedPersonOrganizations = Array.isArray(item.organizations) ? item.organizations : [];
            renderPersonRoleSummary();
            const modeExisting = document.getElementById('personModeExisting');
            if (modeExisting) {
              modeExisting.checked = true;
              syncPersonModeUI();
            }
          }
        }));
      });
    }

    const modeExisting = document.getElementById('personModeExisting');
    const modeNew = document.getElementById('personModeNew');
    if (modeExisting) modeExisting.addEventListener('change', syncPersonModeUI);
    if (modeNew) modeNew.addEventListener('change', syncPersonModeUI);

    if (btnAddNewPersonEmail) {
      btnAddNewPersonEmail.addEventListener('click', () => {
        newPersonEmails.push({ type: 'work', email: '', isPrimary: false });
        renderNewPersonEmails();
      });
    }
    if (btnAddNewPersonPhone) {
      btnAddNewPersonPhone.addEventListener('click', () => {
        newPersonPhones.push({ type: 'mobile', number: '' });
        renderNewPersonPhones();
      });
    }
    if (btnAddNewPersonAddressManual) {
      btnAddNewPersonAddressManual.addEventListener('click', () => {
        newPersonAddresses.push({ type: 'home', line1: '', city: '', province: '', postalCode: '' });
        renderNewPersonAddresses();
      });
    }
    if (btnAddCompensation) {
      btnAddCompensation.addEventListener('click', () => {
        compensationProfiles.push({
          id: `CMP_${Date.now()}_${Math.floor(Math.random() * 1000)}`,
          departmentId: String(document.querySelector('select[name="departmentId"]')?.value || ''),
          paymentMethod: 'hourly',
          hourlyRate: '',
          paymentAmount: '',
          effectiveFrom: '',
          effectiveTo: '',
          contractId: '',
          notes: ''
        });
        renderCompensationProfiles();
      });
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

      try {
        const personMode = document.querySelector('input[name="personMode"]:checked')?.value || 'existing';
        if (personMode === 'existing') {
          const personId = document.getElementById('inp_personId')?.value?.trim();
          if (!personId) throw new Error('Please select a Person before saving.');
        } else {
          const firstName = document.getElementById('inp_newPersonFirstName')?.value?.trim();
          const lastName = document.getElementById('inp_newPersonLastName')?.value?.trim();
          const gender = document.getElementById('inp_newPersonGender')?.value?.trim();
          const dob = document.getElementById('inp_newPersonDateOfBirth')?.value?.trim();
          const emails = (newPersonEmails || []).filter((x) => String(x?.email || '').trim());
          if (!firstName || !lastName || !gender || !dob) {
            throw new Error('Please complete all required New Person fields.');
          }
          if (!emails.length) {
            throw new Error('At least one email is required for the new person.');
          }
        }

        syncNewPersonHiddenState();
        syncCompensationHiddenState();

        const data = new URLSearchParams(new FormData(form));
        const response = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-AJAX-Request': 'true' },
          body: data.toString()
        });

        const contentType = response.headers.get('content-type') || '';
        if (!contentType.includes('application/json')) {
          throw new Error('Server returned non-JSON response (Status ' + response.status + ')');
        }

        const result = await response.json();
        const guarded = typeof window.applyGuardedApiResult === 'function'
          ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Processed' })
          : { stop: false };
        if (guarded.stop) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
          return;
        }
        await showMsg({
          title: result.status === 'success' ? 'Success' : 'Error',
          icon: result.status === 'success' ? 'success' : 'error',
          message: result.message || 'Operation completed.',
          buttons: [{ text: 'OK', class: result.status === 'success' ? 'btn-success' : 'btn-danger' }]
        });

        if (result.status === 'success') {
          const autoAcc = result?.autoCreatedAccount || null;
          if (autoAcc && autoAcc.id) {
            const staffName = String(autoAcc.staffName || 'the staff')
              .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            const accountCode = String(autoAcc.code || '-').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            const accountName = String(autoAcc.name || '-').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            const accountRole = String(autoAcc.partyRole || 'staff').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            const accountType = String(autoAcc.type || '-').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
            const accountLevel = String(autoAcc.level || '-').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

            const recheck = await askYesNo({
              title: 'Staff Account Created',
              message:
                `The account was saved as follows:<br>` +
                `<b>Code:</b> ${accountCode}<br>` +
                `<b>Name:</b> ${accountName}<br>` +
                `<b>Role:</b> ${accountRole}<br>` +
                `<b>Type:</b> ${accountType}<br>` +
                `<b>Level:</b> ${accountLevel}<br><br>` +
                `Do you want to recheck the account we created for ${staffName}?`,
              yesText: 'Yes, open account',
              noText: 'No'
            });

            if (recheck) {
              window.location.href = autoAcc.editUrl || `/school/accounts/edit/${encodeURIComponent(String(autoAcc.id))}`;
              return;
            }
          }
          window.location.href = '/school/staff';
        } else {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
        }
      } catch (error) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
        await showMsg({
          title: 'System Error',
          icon: 'error',
          message: error.message || 'An unexpected network error occurred.',
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
      }
    });

    newPersonEmails = readJsonSafe(hidNewPersonEmails?.value, [{ type: 'primary', email: '', isPrimary: true }]);
    newPersonPhones = readJsonSafe(hidNewPersonPhones?.value, []);
    newPersonAddresses = readJsonSafe(hidNewPersonAddresses?.value, []);
    if (!Array.isArray(newPersonEmails) || !newPersonEmails.length) {
      newPersonEmails = [{ type: 'primary', email: '', isPrimary: true }];
    }
    if (!Array.isArray(newPersonPhones)) newPersonPhones = [];
    if (!Array.isArray(newPersonAddresses)) newPersonAddresses = [];

    renderNewPersonEmails();
    renderNewPersonPhones();
    renderNewPersonAddresses();
    renderCompensationProfiles();
    renderPersonRoleSummary();
    syncPersonModeUI();
    syncNewPersonHiddenState();
    syncCompensationHiddenState();
  });
})();
</script>
