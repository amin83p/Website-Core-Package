<%- include('partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print,
  manageBtns: [
      '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>',
      '<a href="/school/accounts/archived" class="btn btn-warning btn-filled btn-md mb-2"><i class="bi bi-arrow-counterclockwise me-1"></i> Archived</a>',
      '<a href="/school/accounts/help" class="btn btn-primary btn-filled btn-md mb-2"><i class="bi bi-journal-text me-1"></i> Help</a>',
      '<a href="/school/accounts/new-wizard" class="btn btn-filled btn-info btn-md mb-2"><i class="bi bi-signpost-split me-1"></i> Wizard</a>',
      '<button type="button" class="btn btn-outline-success btn-md mb-2" id="btnSyncOwnerNames"><i class="bi bi-arrow-repeat me-1"></i> Sync Owner Names</button>'
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search accounts...',
  fields: [
    { name: 'type', label: 'Type', type: 'select', options: ['asset', 'liability', 'equity', 'income', 'expense'] },
    { name: 'status', label: 'Status', type: 'select', options: ['active', 'inactive'] },
    { name: 'level', label: 'Level', type: 'select', options: ['1', '2', '3', '4', '5', '6'] },
    { name: 'partyRole', label: 'Role', type: 'select', options: ['none', 'student', 'teacher', 'staff', 'parent', 'vendor', 'organization', 'other'] },
    { name: 'headCategory', label: 'Head For', type: 'select', options: accountHeadCategories || ['none', 'students', 'student_all', 'student_domestic', 'student_international', 'student_corporate', 'student_scholarship', 'student_government_funded', 'student_linc_alberta', 'student_wcb_alberta', 'student_other', 'teachers', 'staff', 'parents', 'vendors', 'organizations', 'other'] }
  ]
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Code / Name</th>
        <th>Type</th>
        <th>Level</th>
        <th>Parent</th>
        <th>Role</th>
        <th>Head For</th>
        <th>Postable</th>
        <th class="text-center">Status</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length === 0) { %>
         <tr><td colspan="9" class="text-center py-4 text-muted">No accounts found.</td></tr>
      <% } %>

      <% data.forEach(item => { %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-primary"><%= item.code %></div>
            <div class="small text-dark"><%= item.name %></div>
            <div class="x-small text-muted font-monospace"><%= item.id %></div>
          </td>
          <td><span class="badge bg-light text-dark border"><%= (item.type || '').toUpperCase() %></span></td>
          <td><span class="badge bg-secondary-subtle text-dark border">L<%= item.level %></span></td>
          <td class="small text-muted"><%= item.parentName || '-' %></td>
          <td>
            <% if ((item.partyRole || 'none') !== 'none') { %>
              <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle"><%= String(item.partyRole || '').toUpperCase() %></span>
            <% } else { %>
              <span class="text-muted">-</span>
            <% } %>
          </td>
          <td>
            <% if ((item.headCategory || 'none') !== 'none') { %>
              <span class="badge bg-primary-subtle text-primary-emphasis border border-primary-subtle"><%= String(item.headCategory || '').toUpperCase() %></span>
            <% } else { %>
              <span class="text-muted">-</span>
            <% } %>
          </td>
          <td>
            <% if (item.allowPost) { %>
              <span class="badge bg-success">Yes</span>
            <% } else { %>
              <span class="badge bg-secondary">No</span>
            <% } %>
          </td>
          <td class="text-center">
            <% let badge = 'bg-secondary'; if (item.status === 'active') badge = 'bg-success'; if (item.status === 'inactive') badge = 'bg-warning text-dark'; %>
            <span class="badge <%= badge %>"><%= (item.status || 'unknown').toUpperCase() %></span>
          </td>
          <td class="table-actions text-end pe-4">
            <a href="/school/accounts/edit-wizard/<%= item.id %>" class="btn btn-sm btn-outline-info me-1">Wizard</a>
            <a href="/school/accounts/edit/<%= item.id %>" class="btn btn-sm btn-filled btn-edit">Edit</a>
            <button class="btn btn-sm btn-filled btn-delete delete-btn" data-id="<%= item.id %>">Archive</button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/accounts" hidden></span>
<%- include('partials/pagination', { pagination, filters, baseUrlPath: 'school/accounts' }) %>
<%- include('partials/tablePages-end') %>

<script>
  (function () {
    const btn = document.getElementById('btnSyncOwnerNames');
    const actionStateId = String('<%= String(actionStateId || "") %>');

    function escapeHtml(v) {
      return String(v || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#039;');
    }

    if (!btn) return;
    btn.addEventListener('click', async function () {
      const confirmMsg = 'Sync linked student/teacher/staff sub-account names from the Persons directory for the active org?';
      let confirmed = false;
      if (typeof window.showMessageModal === 'function') {
        const r = await window.showMessageModal({
          title: 'Sync owner names?',
          icon: 'warning',
          message: escapeHtml(confirmMsg) + '<br><br>This updates the <b>School Accounts</b> names that were auto-created for Students / Teachers / Staff when the person name has changed.',
          buttons: [
            { text: 'Cancel', class: 'btn-secondary btn-md' },
            { text: 'Sync Names', class: 'btn-success btn-md' }
          ]
        });
        confirmed = r === 'Sync Names';
      } else {
        confirmed = window.confirm(confirmMsg);
      }
      if (!confirmed) return;

      btn.disabled = true;
      const original = btn.innerHTML;
      btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Syncing...';

      try {
        if (typeof window.showMessageModal === 'function') {
          window.showMessageModal({
            title: 'Syncing owner names…',
            icon: 'info',
            message: `
              <div class="mb-2">Updating linked <b>School Accounts</b> names from the <b>Persons</b> directory.</div>
              <div class="progress" role="progressbar" aria-label="Sync progress" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100">
                <div class="progress-bar progress-bar-striped progress-bar-animated" style="width: 100%"></div>
              </div>
              <div class="small text-muted mt-2">This may take a moment depending on the number of linked accounts.</div>
            `,
            buttons: []
          });
        }

        const res = await fetch('/school/accounts/api/sync-owner-names', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-AJAX-Request': 'true',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ actionStateId })
        });
        const payload = await res.json();
        const guarded = typeof window.applyGuardedApiResult === 'function'
          ? await window.applyGuardedApiResult(payload, { busyTitle: 'Sync In Progress', replayTitle: 'Sync Already Completed' })
          : { stop: false };
        if (guarded.stop) return;
        if (payload.status !== 'success') throw new Error(payload.message || 'Sync failed');

        const r = payload.result || {};
        const scanned = r.scanned || {};
        const updated = r.updated || {};
        const skipped = r.skipped || {};

        const summaryHtml = `
          <div class="mb-2"><b>Done.</b> Owner-linked account names were synced from Persons.</div>
          <div class="small">
            Scanned: Students <b>${Number(scanned.students || 0)}</b>, Teachers <b>${Number(scanned.teachers || 0)}</b>, Staff <b>${Number(scanned.staff || 0)}</b><br>
            Linked Accounts: <b>${Number(scanned.linkedAccounts || 0)}</b><br>
            Updated: Total <b>${Number(updated.total || 0)}</b> (Students <b>${Number(updated.students || 0)}</b>, Teachers <b>${Number(updated.teachers || 0)}</b>, Staff <b>${Number(updated.staff || 0)}</b>)<br>
            Skipped: Unchanged <b>${Number(skipped.unchanged || 0)}</b>, Missing account <b>${Number(skipped.missingAccount || 0)}</b>, Errors <b>${Number(skipped.errors || 0)}</b>
          </div>
        `;

        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: 'Sync completed',
            icon: 'success',
            message: summaryHtml,
            buttons: [{ text: 'OK', class: 'btn-success btn-md' }]
          });
        } else {
          alert('Sync completed.');
        }
      } catch (err) {
        if (typeof window.showMessageModal === 'function') {
          await window.showMessageModal({
            title: 'Sync failed',
            icon: 'error',
            message: escapeHtml(err?.message || String(err)),
            buttons: [{ text: 'Close', class: 'btn-secondary btn-md' }]
          });
        } else {
          alert(err?.message || String(err));
        }
      } finally {
        btn.disabled = false;
        btn.innerHTML = original;
      }
    });
  })();
</script>
