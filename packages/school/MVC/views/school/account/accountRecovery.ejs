<%- include('../../partials/tablePages-start', {
  title,
  newUrl: 'school/accounts/archived',
  newLabel: 'Recover Account',
  user,
  tableName,
  btn_export: true,
  print,
  manageBtns: [
    `<a href="/school/accounts" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-arrow-left me-1"></i> Accounts List</a>`
  ]
}) %>

<%- include('../../partials/tablePages-search', {
  placeholder: 'Search archived accounts...',
  fields: [
    { name: 'type', label: 'Type', type: 'select', options: ['asset', 'liability', 'equity', 'income', 'expense'] },
    { name: 'level', label: 'Level', type: 'select', options: ['1', '2', '3', '4', '5', '6'] },
    { name: 'partyRole', label: 'Role', type: 'select', options: ['none', 'student', 'teacher', 'staff', 'parent', 'vendor', 'organization', 'other'] }
  ]
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Code / Name</th>
        <th>Type</th>
        <th>Level</th>
        <th>Role</th>
        <th>Owner Link</th>
        <th class="text-center">Status</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length === 0) { %>
         <tr><td colspan="7" class="text-center py-4 text-muted">No archived accounts found.</td></tr>
      <% } %>

      <% data.forEach(item => { %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-primary"><%= item.code %></div>
            <div class="small text-dark"><%= item.name %></div>
            <div class="x-small text-muted font-monospace"><%= item.id %></div>
          </td>
          <td><span class="badge bg-light text-dark border"><%= (item.type || '').toUpperCase() %></span></td>
          <td><span class="badge bg-secondary-subtle text-dark border">L<%= item.level %></span></td>
          <td>
            <% if ((item.partyRole || 'none') !== 'none') { %>
              <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle"><%= String(item.partyRole || '').toUpperCase() %></span>
            <% } else { %>
              <span class="text-muted">-</span>
            <% } %>
          </td>
          <td>
            <% if (item.ownerLinked) { %>
              <span class="badge bg-warning text-dark" title="<%= item.ownerSummary || '' %>">Linked</span>
              <div class="x-small text-muted mt-1"><%= item.ownerSummary || '' %></div>
            <% } else { %>
              <span class="badge bg-success">No Owner</span>
            <% } %>
          </td>
          <td class="text-center">
            <span class="badge bg-secondary">ARCHIVED</span>
          </td>
          <td class="table-actions text-end pe-4">
            <button class="btn btn-sm btn-filled btn-edit recover-btn" data-id="<%= item.id %>" <%= item.ownerLinked ? 'disabled' : '' %>>
              <i class="bi bi-arrow-counterclockwise me-1"></i>Recover
            </button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/accounts/archived" hidden></span>
<span id="actionStateRef" data-id="<%= actionStateId || '' %>" hidden></span>
<%- include('../../partials/pagination', { pagination, filters, baseUrlPath: 'school/accounts/archived' }) %>
<%- include('../../partials/tablePages-end') %>

<script>
(function () {
  function showMsg(opts) {
    if (typeof showMessageModal === 'function') return showMessageModal(opts);
    alert(opts?.message || 'Done');
    return Promise.resolve('OK');
  }

  function askConfirm(message) {
    if (typeof showMessageModal !== 'function') return Promise.resolve(confirm(message.replace(/<[^>]+>/g, '')));
    return showMessageModal({
      title: 'Recover Account',
      icon: 'question',
      message,
      buttons: [
        { text: 'Cancel', class: 'btn-secondary' },
        { text: 'Recover', class: 'btn-success' }
      ]
    }).then(v => v === 'Recover');
  }

  document.addEventListener('DOMContentLoaded', function () {
    const token = document.getElementById('actionStateRef')?.dataset?.id || '';
    const buttons = document.querySelectorAll('.recover-btn');
    buttons.forEach((btn) => {
      btn.addEventListener('click', async function () {
        if (btn.disabled) return;
        const id = btn.dataset.id;
        if (!id) return;

        const ok = await askConfirm('Recover this archived account?');
        if (!ok) return;

        const original = btn.innerHTML;
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Recovering...';

        try {
          const response = await fetch(`/school/accounts/recover/${encodeURIComponent(id)}?actionStateId=${encodeURIComponent(token)}`, {
            method: 'POST',
            headers: { 'X-AJAX-Request': 'true' }
          });
          const result = await response.json().catch(() => null);
          const guarded = (result && typeof window.applyGuardedApiResult === 'function')
            ? await window.applyGuardedApiResult(result, { busyTitle: 'Recovery In Progress', replayTitle: 'Recovery Already Processed' })
            : { stop: false };
          if (guarded.stop) {
            btn.disabled = false;
            btn.innerHTML = original;
            return;
          }
          if (!response.ok || !result || result.status !== 'success') {
            throw new Error(result?.message || 'Recovery failed.');
          }

          await showMsg({
            title: 'Recovered',
            icon: 'success',
            message: result.message || 'Account recovered successfully.',
            buttons: [{ text: 'OK', class: 'btn-success' }]
          });
          window.location.reload();
        } catch (err) {
          btn.disabled = false;
          btn.innerHTML = original;
          await showMsg({
            title: 'Error',
            icon: 'error',
            message: err.message || 'Failed to recover account.',
            buttons: [{ text: 'OK', class: 'btn-danger' }]
          });
        }
      });
    });
  });
})();
</script>
