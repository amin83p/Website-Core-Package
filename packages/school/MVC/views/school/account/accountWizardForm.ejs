<%- include('./accountForm') %>

<style>
  #accountWizardGuide {
    font-size: 1rem;
  }
  #accountWizardGuide .small {
    font-size: 1rem !important;
  }
  .wizard-step-rail {
    display: flex;
    gap: 0.5rem;
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 0.25rem;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .wizard-step-rail::-webkit-scrollbar {
    display: none;
  }
  #accountWizardGuide .wizard-step-pill {
    flex: 0 0 auto;
    white-space: nowrap;
    border: 1px solid #c8d1dc;
    background: #f8fafc;
    color: #17324d;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 999px;
    padding: 0.35rem 0.8rem;
    transition: all 0.2s ease;
  }
  #accountWizardGuide .wizard-step-pill.active {
    background: #17324d;
    color: #fff;
    border-color: #17324d;
  }
  #accountWizardGuide .wizard-step-pill.completed {
    background: #e8f5ee;
    border-color: #95d5b2;
    color: #1b6f4a;
  }
  #accountWizardGuide .wizard-progress {
    height: 0.35rem;
    background: #e8edf3;
    border-radius: 999px;
    overflow: hidden;
  }
  #accountWizardGuide .wizard-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, #17324d 0%, #2f5d8a 100%);
    width: 0;
    transition: width 0.25s ease;
  }
  .account-wizard-controls {
    background: #f8fafc;
    border: 1px solid #d5dee8;
    border-radius: 0.75rem;
    font-size: 1rem;
    padding: 0.75rem 1rem;
  }
  .account-wizard-controls .wizard-step-label {
    color: #17324d;
    font-weight: 600;
  }
  .account-wizard-controls .btn.btn-sm {
    font-size: 1rem;
    padding: 0.45rem 0.85rem;
  }
  #accountForm .account-wizard-hidden {
    display: none !important;
  }
</style>

<script src="/scripts/wizardStepRail.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const form = document.getElementById('accountForm');
  if (!form) return;

  const firstCard = form.querySelector('.card');
  const buttonRow = form.querySelector('.button-row');
  if (!firstCard || !buttonRow) return;

  function parseNumberSafe(value) {
    const num = Number(value);
    return Number.isFinite(num) ? num : NaN;
  }

  const stepConfig = [
    {
      title: 'Identity',
      focusSelector: 'input[name="code"]',
      visibleSelectors: [
        'input[name="accountId"]',
        'input[name="name"]'
      ],
      helper: [
        'Define account identity, status, and primary classification.',
        'Keep account code stable because it is used across reports and posting logic.',
        'Type is foundational and should match your chart of accounts design.'
      ],
      impacts: [
        'Code and name are shown in ledgers, picker lists, and reconciliation tools.',
        'Status controls whether this account is active for operations.',
        'Type influences reporting grouping and account hierarchy behavior.'
      ],
      required: [
        { selector: 'input[name="code"]', label: 'Code' },
        { selector: 'input[name="name"]', label: 'Name' },
        { selector: 'select[name="status"]', label: 'Status' },
        { selector: 'select[name="type"]', label: 'Type' }
      ]
    },
    {
      title: 'Structure & Posting',
      focusSelector: 'input[name="level"]',
      visibleSelectors: [
        'input[name="level"]',
        '#isControl',
        'select[name="headCategory"]'
      ],
      helper: [
        'Set hierarchy level, parent account, posting controls, and role labels.',
        'Use parent only when the account must live under an existing branch.',
        'Head category marks this account as a section parent for auto-created owner accounts.'
      ],
      impacts: [
        'Level and parent define chart tree structure used throughout accounting screens.',
        'Allow Posting controls whether transactions can post directly to this account.',
        'Party role/head category support dynamic account resolution for school operations.'
      ],
      required: [
        { selector: 'input[name="level"]', label: 'Level' },
        { selector: 'select[name="normalBalance"]', label: 'Normal Balance' }
      ],
      customCheck: function () {
        const levelField = form.querySelector('input[name="level"]');
        const parentField = form.querySelector('select[name="parentId"]');
        const typeField = form.querySelector('select[name="type"]');
        const level = parseNumberSafe(levelField?.value);
        if (!Number.isFinite(level) || level < 1 || level > 6) {
          return 'Level must be between 1 and 6.';
        }
        if (!parentField || !parentField.value) return '';

        const selectedParent = parentField.options[parentField.selectedIndex];
        if (!selectedParent) return '';

        const parentLevel = parseNumberSafe(selectedParent.getAttribute('data-level'));
        const parentType = String(selectedParent.getAttribute('data-type') || '').trim().toLowerCase();
        const selectedType = String(typeField?.value || '').trim().toLowerCase();

        if (Number.isFinite(parentLevel) && level !== Math.min(parentLevel + 1, 6)) {
          return 'When parent is selected, level must be parent level + 1.';
        }
        if (parentType && selectedType && parentType !== selectedType) {
          return 'Account type must match selected parent type.';
        }
        return '';
      }
    },
    {
      title: 'Review & Save',
      focusSelector: 'button[type="submit"]',
      visibleSelectors: [
        'input[name="accountId"]',
        'input[name="name"]',
        'input[name="level"]',
        '#isControl',
        'select[name="headCategory"]'
      ],
      helper: [
        'Review the complete account configuration before saving.',
        'Confirm hierarchy, posting flags, and role/head tagging are correct.',
        'Save only after validating the account fits your chart strategy.'
      ],
      impacts: [
        'Saved settings become available to transactions and setup modules immediately.',
        'Incorrect hierarchy can require downstream cleanup and re-linking.',
        'Owner-linked accounts may lock some critical fields after linkage.'
      ],
      required: []
    }
  ];

  const guide = document.createElement('div');
  guide.id = 'accountWizardGuide';
  guide.className = 'card border-0 shadow-sm mb-3';
  guide.innerHTML = [
    '<div class="card-body">',
      '<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">',
        '<div>',
          '<div class="fw-bold text-primary">School Account Wizard</div>',
          '<div class="text-muted">Create and structure accounts with controlled, step-by-step setup.</div>',
        '</div>',
        '<div class="d-flex align-items-center gap-2">',
          '<span class="badge bg-light text-dark border" id="accountWizardStepBadge">Step 1 of ' + stepConfig.length + '</span>',
          '<span class="badge bg-primary-subtle text-primary border border-primary-subtle" id="accountWizardProgressPct">0%</span>',
        '</div>',
      '</div>',
      '<div class="wizard-progress mb-3"><div class="wizard-progress-bar" id="accountWizardProgressBar"></div></div>',
      '<div class="wizard-step-rail mb-3" id="accountWizardStepPills"></div>',
      '<div class="row g-3">',
        '<div class="col-lg-6">',
          '<div class="border rounded p-3 h-100 bg-light-subtle">',
            '<div class="fw-bold mb-2">Active Step Help</div>',
            '<div id="accountWizardStepHelp"></div>',
          '</div>',
        '</div>',
        '<div class="col-lg-6">',
          '<div class="border rounded p-3 h-100 bg-light">',
            '<div class="fw-bold mb-2">Operational Impact</div>',
            '<div id="accountWizardStepImpacts"></div>',
          '</div>',
        '</div>',
      '</div>',
    '</div>'
  ].join('');
  form.insertBefore(guide, firstCard);

  const controls = document.createElement('div');
  controls.className = 'account-wizard-controls d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3';
  controls.innerHTML = [
    '<div class="wizard-step-label" id="accountWizardCurrentLabel"></div>',
    '<div class="d-flex gap-2">',
      '<button type="button" class="btn btn-outline-secondary btn-sm" id="accountWizardPrevBtn"><i class="bi bi-arrow-left me-1"></i>Previous</button>',
      '<button type="button" class="btn btn-primary btn-sm" id="accountWizardNextBtn">Next<i class="bi bi-arrow-right ms-1"></i></button>',
    '</div>'
  ].join('');
  buttonRow.parentNode.insertBefore(controls, buttonRow);

  const stepPills = document.getElementById('accountWizardStepPills');
  const stepHelp = document.getElementById('accountWizardStepHelp');
  const stepImpacts = document.getElementById('accountWizardStepImpacts');
  const stepBadge = document.getElementById('accountWizardStepBadge');
  const progressPct = document.getElementById('accountWizardProgressPct');
  const stepLabel = document.getElementById('accountWizardCurrentLabel');
  const progressBar = document.getElementById('accountWizardProgressBar');
  const btnPrev = document.getElementById('accountWizardPrevBtn');
  const btnNext = document.getElementById('accountWizardNextBtn');
  const cardBody = firstCard.querySelector('.card-body');
  const formBlocks = cardBody ? Array.from(cardBody.children).filter(function (el) { return el && el.nodeType === 1; }) : [];
  const stepBlocksCache = new Map();
  let currentIndex = 0;

  function escapeHtml(input) {
    return String(input || '').replace(/[&<>\"']/g, function (m) {
      return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[m];
    });
  }

  function renderList(items) {
    const safe = Array.isArray(items) ? items : [];
    if (!safe.length) return '<div class="text-muted">No additional notes for this step.</div>';
    return '<ul class="mb-0 ps-3">' + safe.map(function (line) {
      return '<li>' + escapeHtml(line) + '</li>';
    }).join('') + '</ul>';
  }

  function focusStep(step) {
    const selector = String(step?.focusSelector || '').trim();
    if (!selector) return;
    const el = form.querySelector(selector);
    if (!el) return;
    try {
      el.scrollIntoView({ behavior: 'smooth', block: 'center' });
      el.focus();
    } catch (_) {}
  }

  function findMissingRequired(step) {
    const missing = [];
    (step.required || []).forEach(function (rule) {
      const el = form.querySelector(rule.selector);
      const value = String(el?.value || '').trim();
      if (!el || !value) missing.push({ label: rule.label, selector: rule.selector });
    });
    if (typeof step.customCheck === 'function') {
      const customError = String(step.customCheck() || '').trim();
      if (customError) missing.push({ label: customError, selector: '' });
    }
    return missing;
  }

  async function showWarning(message) {
    if (typeof showMessageModal === 'function') {
      await showMessageModal({
        title: 'Step Incomplete',
        icon: 'warning',
        message,
        buttons: [{ text: 'OK', class: 'btn-warning' }]
      });
      return;
    }
    alert(message);
  }

  function findBlockForElement(el) {
    if (!el) return null;
    let current = el;
    while (current && current !== cardBody) {
      if (current.parentElement === cardBody) return current;
      current = current.parentElement;
    }
    return null;
  }

  function getStepBlocks(stepIndex) {
    if (stepBlocksCache.has(stepIndex)) return stepBlocksCache.get(stepIndex);
    const step = stepConfig[stepIndex] || {};
    const selectors = Array.isArray(step.visibleSelectors) ? step.visibleSelectors : [];
    const blocks = [];
    selectors.forEach(function (selector) {
      const target = form.querySelector(selector);
      const block = findBlockForElement(target);
      if (block && !blocks.includes(block)) blocks.push(block);
    });
    stepBlocksCache.set(stepIndex, blocks);
    return blocks;
  }

  function applyStepVisibility(stepIndex) {
    const visible = new Set(getStepBlocks(stepIndex));
    formBlocks.forEach(function (block) {
      if (visible.has(block)) block.classList.remove('account-wizard-hidden');
      else block.classList.add('account-wizard-hidden');
    });
  }

  function buildMissingMessage(missing) {
    return 'Complete required checks before moving on:<br>' +
      missing.map(function (item) { return '- ' + escapeHtml(item.label); }).join('<br>');
  }

  function focusFirstMissing(missing) {
    const first = (Array.isArray(missing) ? missing : []).find(function (item) { return item.selector; });
    if (!first?.selector) return;
    const el = form.querySelector(first.selector);
    if (!el) return;
    try { el.focus(); } catch (_) {}
  }

  async function tryGoToStep(targetIndex) {
    const boundedTarget = Math.max(0, Math.min(stepConfig.length - 1, Number(targetIndex)));
    if (boundedTarget <= currentIndex) {
      showStep(boundedTarget);
      return;
    }

    for (let idx = currentIndex; idx < boundedTarget; idx += 1) {
      const missing = findMissingRequired(stepConfig[idx]);
      if (missing.length) {
        showStep(idx);
        await showWarning(buildMissingMessage(missing));
        focusFirstMissing(missing);
        return;
      }
    }

    showStep(boundedTarget);
  }

  function showStep(index, shouldFocus) {
    const bounded = Math.max(0, Math.min(stepConfig.length - 1, Number(index)));
    currentIndex = bounded;
    applyStepVisibility(currentIndex);
    renderWizardUi();
    if (shouldFocus !== false) focusStep(stepConfig[currentIndex]);
  }

  function renderWizardUi() {
    const step = stepConfig[currentIndex];
    const progress = ((currentIndex + 1) / stepConfig.length) * 100;

    stepBadge.textContent = 'Step ' + (currentIndex + 1) + ' of ' + stepConfig.length;
    progressPct.textContent = Math.round(progress) + '%';
    stepLabel.textContent = step.title;
    progressBar.style.width = progress.toFixed(2) + '%';
    stepHelp.innerHTML = renderList(step.helper);
    stepImpacts.innerHTML = renderList(step.impacts);

    stepPills.innerHTML = stepConfig.map(function (item, idx) {
      const cls = idx === currentIndex ? 'active' : (idx < currentIndex ? 'completed' : '');
      return '<button type="button" class="wizard-step-pill ' + cls + '" data-step-index="' + idx + '">' + (idx + 1) + '. ' + escapeHtml(item.title) + '</button>';
    }).join('');

    stepPills.querySelectorAll('[data-step-index]').forEach(function (btn) {
      btn.addEventListener('click', async function () {
        await tryGoToStep(Number(btn.getAttribute('data-step-index')));
      });
    });

    if (window.WizardStepRail) window.WizardStepRail.sync(stepPills);
    btnPrev.disabled = currentIndex <= 0;
    btnNext.innerHTML = currentIndex >= stepConfig.length - 1
      ? 'Review Save<i class="bi bi-check2-circle ms-1"></i>'
      : 'Next<i class="bi bi-arrow-right ms-1"></i>';
  }

  btnPrev?.addEventListener('click', function () {
    showStep(currentIndex - 1);
  });

  btnNext?.addEventListener('click', async function () {
    if (currentIndex < stepConfig.length - 1) {
      await tryGoToStep(currentIndex + 1);
      return;
    }
    buttonRow.scrollIntoView({ behavior: 'smooth', block: 'center' });
    const saveBtn = form.querySelector('button[type="submit"]');
    if (saveBtn) {
      saveBtn.classList.add('shadow');
      setTimeout(function () { saveBtn.classList.remove('shadow'); }, 1200);
    }
  });

  showStep(0, false);
});
</script>


