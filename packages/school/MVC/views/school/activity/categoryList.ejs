<%
  const stateFilters = (filters && typeof filters === 'object') ? filters : {};
  const activeStatus = String(stateFilters.status || '').trim().toLowerCase();
  const activeDefaultPaid = String(stateFilters.defaultPaid || '').trim().toLowerCase();
  const totalMatchedRows = Number(pagination?.totalItems ?? pagination?.total ?? (Array.isArray(data) ? data.length : 0));
  const hasCategoryFiltersApplied = Boolean(
    String(stateFilters.q || '').trim()
    || activeStatus
    || activeDefaultPaid
  );
%>

<%- include('partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print,
  headerManageBtns: [
    '<a href="/school/activities" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-calendar-event me-1"></i> School Activities</a>',
    '<a href="/dashboard/section-nav/SCHOOL_ACADEMIA" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-mortarboard me-1"></i> School Academia</a>'
  ],
  manageBtns: []
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
    <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter Categories</div>
    <button
      id="schoolActivityCategoryFilterToggleBtn"
      type="button"
      class="btn btn-outline-secondary btn-sm px-2"
      data-bs-toggle="collapse"
      data-bs-target="#schoolActivityCategoryFilterCollapse"
      aria-expanded="<%= hasCategoryFiltersApplied ? 'true' : 'false' %>"
      aria-controls="schoolActivityCategoryFilterCollapse"
      aria-label="<%= hasCategoryFiltersApplied ? 'Close filters' : 'Open filters' %>">
      <i id="schoolActivityCategoryFilterToggleIcon" class="bi <%= hasCategoryFiltersApplied ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
    </button>
  </div>
  <div class="collapse<%= hasCategoryFiltersApplied ? ' show' : '' %>" id="schoolActivityCategoryFilterCollapse">
    <form method="GET" action="/school/activities/categories" id="schoolActivityCategoryFilterForm" class="card-body p-3">
      <div class="row g-3 align-items-end">
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Status</label>
          <select name="status" class="form-select size-md">
            <option value="">All Statuses</option>
            <option value="active" <%= activeStatus === 'active' ? 'selected' : '' %>>Active</option>
            <option value="inactive" <%= activeStatus === 'inactive' ? 'selected' : '' %>>Inactive</option>
          </select>
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Default</label>
          <select name="defaultPaid" class="form-select size-md">
            <option value="">All Defaults</option>
            <option value="true" <%= activeDefaultPaid === 'true' ? 'selected' : '' %>>Payable</option>
            <option value="false" <%= activeDefaultPaid === 'false' ? 'selected' : '' %>>Unpaid</option>
          </select>
        </div>
        <div class="col-md-6 col-xl-3">
          <label class="form-label">Search</label>
          <input type="search" name="q" class="form-control size-md" value="<%= stateFilters.q || '' %>" placeholder="Search categories by code, name, description, or status...">
        </div>
        <div class="col-md-6 col-xl-3 d-flex justify-content-xl-end gap-2 pt-xl-4">
          <a href="/school/activities/categories" class="btn btn-outline-secondary btn-md">Reset</a>
          <button type="submit" class="btn btn-filled btn-primary btn-md">
            <i class="bi bi-funnel me-1"></i> Apply
          </button>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div class="small text-muted">
      Matched rows: <span class="fw-bold text-dark"><%= totalMatchedRows.toLocaleString() %></span>
    </div>
    <div class="small text-muted">
      Showing page: <span class="fw-bold text-dark"><%= Number(pagination?.currentPage || pagination?.page || 1) %> / <%= Number(pagination?.totalPages || 1) %></span>
    </div>
  </div>
</div>

<%- include('partials/tablePages-search', {
  placeholder: 'Search categories by code, name, description, or status...',
  fields: []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4 draggable" data-column="name">Category<span class="sort-icon"></span></th>
        <th class="draggable" data-column="code">Code<span class="sort-icon"></span></th>
        <th class="draggable" data-column="defaultPaid">Default<span class="sort-icon"></span></th>
        <th class="draggable" data-column="active">Status<span class="sort-icon"></span></th>
        <th class="text-end pe-4">Action</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || !data.length) { %>
        <tr>
          <td colspan="5" class="text-center py-4 text-muted">No activity categories found.</td>
        </tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-dark"><%= item.name || item.code || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= item.id || '-' %></div>
            <% if (item.description) { %>
              <div class="x-small text-muted mt-1"><%= item.description %></div>
            <% } %>
          </td>
          <td>
            <span class="badge bg-light text-dark border"><%= item.code || '-' %></span>
          </td>
          <td>
            <div class="small text-dark"><%= item.defaultPaid ? 'Payable' : 'Unpaid' %></div>
          </td>
          <td>
            <span class="badge <%= item.active === false ? 'bg-secondary' : 'bg-success' %>"><%= item.active === false ? 'Inactive' : 'Active' %></span>
          </td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button type="button" class="btn btn-secondary btn-sm btn-row-actions-toggle" data-row-actions-id="<%= item.id %>" title="Row actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= item.id %>">
                <a href="/school/activities/categories/edit/<%= item.id %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-pencil-square me-2"></i>Edit
                </a>
                <button type="button" class="btn btn-outline-danger btn-sm js-delete-category" data-id="<%= item.id %>">
                  <i class="bi bi-trash me-2"></i>Delete
                </button>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/pagination', { pagination, filters, baseUrlPath: newUrl }) %>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const collapse = document.getElementById('schoolActivityCategoryFilterCollapse');
  const icon = document.getElementById('schoolActivityCategoryFilterToggleIcon');
  if (collapse && icon) {
    collapse.addEventListener('show.bs.collapse', function () {
      icon.classList.remove('bi-chevron-down');
      icon.classList.add('bi-chevron-up');
    });
    collapse.addEventListener('hide.bs.collapse', function () {
      icon.classList.remove('bi-chevron-up');
      icon.classList.add('bi-chevron-down');
    });
  }

  document.querySelectorAll('.js-delete-category').forEach(function (button) {
    button.addEventListener('click', async function () {
      const id = button.getAttribute('data-id');
      const confirmed = await showMessageModal({
        title: 'Delete Category',
        icon: 'warning',
        message: 'Delete this category?',
        buttons: [
          { text: 'Cancel', class: 'btn-secondary', value: false },
          { text: 'Delete', class: 'btn-danger', value: true }
        ]
      });
      if (!confirmed) return;
      const response = await fetch('/school/activities/categories/delete/' + encodeURIComponent(id), {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
        body: JSON.stringify({ actionStateId: '<%= actionStateId || "" %>' })
      });
      const payload = await response.json().catch(function () { return { status: 'error', message: 'Delete failed.' }; });
      await showMessageModal({ title: payload.status === 'success' ? 'Deleted' : 'Error', icon: payload.status === 'success' ? 'success' : 'error', message: payload.message || 'Operation completed.' });
      if (payload.status === 'success') window.location.reload();
    });
  });
});
</script>

<%- include('partials/tablePages-end') %>

