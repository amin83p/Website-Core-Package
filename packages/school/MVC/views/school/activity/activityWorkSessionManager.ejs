<div class="sections-page activity-work-session-page">
  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <h1 class="page-heading size-md m-0 text-start"><i class="bi bi-journal-check me-2 text-primary"></i>Manage Work Session</h1>
    <a href="<%= dashboardHref %>" class="btn btn-filled btn-secondary btn-md">
      <i class="bi bi-speedometer2 me-1"></i>Dashboard
    </a>
  </div>

  <div class="session-manager-quick-nav">
    <div class="session-manager-class-nav">
      <button
        type="button"
        class="session-manager-class-nav-toggle"
        id="btnToggleWorkSessionNav"
        data-bs-toggle="collapse"
        data-bs-target="#workSessionNavCollapse"
        aria-expanded="false"
        aria-controls="workSessionNavCollapse">
        <span class="session-manager-class-nav-icon" aria-hidden="true"><i class="bi bi-box-arrow-up-right"></i></span>
        <span class="session-manager-class-nav-copy">
          <span class="session-manager-class-nav-title">Activity navigation</span>
          <span class="session-manager-class-nav-sub">Manage and browse</span>
        </span>
        <i class="bi bi-chevron-down session-class-nav-chevron" aria-hidden="true"></i>
      </button>
      <div class="collapse" id="workSessionNavCollapse">
        <div class="session-manager-class-nav-links">
          <a href="/school/activities" class="session-manager-class-nav-link"><i class="bi bi-list-ul"></i>All Activities</a>
          <a href="<%= overviewManageUrl %>" class="session-manager-class-nav-link"><i class="bi bi-kanban"></i>All work sessions</a>
          <a href="/school/activities/edit/<%= encodeURIComponent(activityRow.id) %>" class="session-manager-class-nav-link"><i class="bi bi-pencil-square"></i>Edit Activity</a>
        </div>
      </div>
    </div>
  </div>

  <div class="session-manager-toolbar-row">
    <div class="btn-group shadow-sm">
      <% if (prevSession && prevSession.manageUrl) { %>
        <a href="<%= prevSession.manageUrl %>" class="btn btn-outline-primary bg-grey btn-md" title="Previous work session"><i class="bi bi-chevron-left"></i></a>
      <% } else { %>
        <button type="button" class="btn btn-outline-secondary bg-light btn-md" disabled><i class="bi bi-chevron-left"></i></button>
      <% } %>
      <% if (nextSession && nextSession.manageUrl) { %>
        <a href="<%= nextSession.manageUrl %>" class="btn btn-outline-primary bg-grey btn-md" title="Next work session"><i class="bi bi-chevron-right"></i></a>
      <% } else { %>
        <button type="button" class="btn btn-outline-secondary bg-light btn-md" disabled><i class="bi bi-chevron-right"></i></button>
      <% } %>
    </div>
    <% if (editableAssigneeRows.length) { %>
      <button type="button" class="btn btn-primary btn-md btn-filled btn-save-session shadow-md" id="btnSaveWorkSession">
        <i class="bi bi-save me-1"></i>Save session
      </button>
    <% } %>
    <button type="button" class="btn btn-warning btn-md btn-filled btn-close-session" id="btnCloseWorkSessionManager"><i class="bi bi-x-lg me-1"></i>Close</button>
  </div>

  <div class="card session-manager-info-card shadow-sm mb-3">
    <div class="session-info-header">
      <div
        class="session-info-details-toggle"
        id="btnToggleWorkSessionInfoDetails"
        role="button"
        tabindex="0"
        data-bs-toggle="collapse"
        data-bs-target="#workSessionInfoDetailsCollapse"
        aria-expanded="false"
        aria-controls="workSessionInfoDetailsCollapse">
        <div class="session-info-summary">
          <span class="session-info-summary-class text-truncate" title="<%= activityRow.title || 'Activity' %>"><%= activityRow.title || 'Activity' %></span>
          <span class="session-info-summary-sep" aria-hidden="true">·</span>
          <span class="session-info-summary-chip" id="workSessionInfoSummaryDate"><i class="bi bi-calendar3 me-1" aria-hidden="true"></i><%= entryRow.date || '-' %></span>
          <span class="session-info-summary-chip" id="workSessionInfoSummaryTime"><i class="bi bi-clock me-1" aria-hidden="true"></i><%= entryRow.startTime || '-' %>–<%= entryRow.endTime || '-' %></span>
          <span class="session-info-summary-chip session-info-summary-chip--location<%= workSessionLocationLabel ? '' : ' is-muted' %>" id="workSessionInfoSummaryLocation" title="Location"><% if (workSessionLocationLabel) { %><i class="bi bi-geo-alt me-1" aria-hidden="true"></i><%= workSessionLocationLabel %><% } %></span>
          <span class="session-info-summary-chip d-none d-lg-inline-flex" title="Evaluation"><i class="bi bi-ui-checks me-1" aria-hidden="true"></i><%= evaluationTypeLabel %></span>
        </div>
        <span class="session-info-expand-meta">
          <span class="session-info-expand-label">Details</span>
          <i class="bi bi-chevron-down session-info-expand-chevron" aria-hidden="true"></i>
        </span>
      </div>
      <div class="session-info-status-slot<%= workSessionStatusActionRequired ? '' : ' is-complete' %>" id="workSessionStatusSlot">
        <div class="session-info-status-slot-label">
          <span>Session status</span>
          <% if (workSessionStatusActionRequired) { %>
            <span class="badge bg-warning text-dark session-status-required-badge">Required</span>
          <% } %>
        </div>
        <button
          type="button"
          id="workSessionStatusButton"
          class="btn session-status-button<%= workSessionStatusActionRequired ? ' session-status-button--action-required' : '' %>"
          <%= (isCompletion && workSessionStatusActionRequired && editableAssigneeRows.length) ? '' : 'disabled' %>
          style="<%= !workSessionStatusActionRequired ? 'background-color:#d1e7dd;color:#0f5132;border-color:#badbcc;' : '' %>">
          <span id="workSessionStatusButtonLabel"><%= workSessionStatusLabel %></span>
          <i class="bi bi-pencil-square" aria-hidden="true"></i>
        </button>
      </div>
    </div>
    <div class="collapse" id="workSessionInfoDetailsCollapse">
      <div class="session-info-details-body">
        <div class="session-info-grid">
          <div class="session-info-tile session-info-tile--accent">
            <div class="session-info-tile-label">Activity</div>
            <div class="session-info-tile-value text-truncate" title="<%= activityRow.title || '-' %>"><%= activityRow.title || '-' %></div>
          </div>
          <div class="session-info-tile">
            <div class="session-info-tile-label">Session title</div>
            <div class="session-info-tile-value"><%= entryRow.title || '-' %></div>
          </div>
          <div class="session-info-tile">
            <div class="session-info-tile-label">Date</div>
            <div class="session-info-tile-value"><%= entryRow.date || '-' %></div>
          </div>
          <div class="session-info-tile">
            <div class="session-info-tile-label">Time</div>
            <div class="session-info-tile-value text-nowrap"><%= entryRow.startTime || '-' %> – <%= entryRow.endTime || '-' %></div>
          </div>
          <div class="session-info-tile">
            <div class="session-info-tile-label">Duration</div>
            <div class="session-info-tile-value"><%= Number(entryRow.durationHours || 0).toFixed(2) %> h</div>
          </div>
          <div class="session-info-tile">
            <div class="session-info-tile-label">Category</div>
            <div class="session-info-tile-value"><%= activityRow.categoryName || '-' %></div>
          </div>
          <div class="session-info-tile">
            <div class="session-info-tile-label">Department</div>
            <div class="session-info-tile-value"><%= activityRow.departmentName || '-' %></div>
          </div>
        </div>
        <div class="session-info-meta-grid">
          <div class="session-info-tile">
            <div class="session-info-tile-label">Evaluation</div>
            <div class="session-info-tile-value session-info-tile-value-sm"><%= evaluationTypeLabel %></div>
          </div>
          <div class="session-info-tile">
            <div class="session-info-tile-label">Assignees</div>
            <div class="session-info-tile-value session-info-tile-value-sm"><%= assigneeRows.length %> total · <%= readyCount %> ready for timesheet</div>
          </div>
          <div class="session-info-tile">
            <div class="session-info-tile-label">Payable</div>
            <div class="session-info-tile-value session-info-tile-value-sm"><%= activityRow.paid ? 'Yes' : 'No' %></div>
          </div>
        </div>
        <% if (entryRow.notes || activityRow.notes) { %>
          <div class="session-info-tile mt-2">
            <div class="session-info-tile-label">Notes</div>
            <div class="session-info-tile-value session-info-tile-value-sm"><%= entryRow.notes || activityRow.notes %></div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <form method="POST" action="<%= manageUrl %>/complete" id="frmCompleteWorkSessionStatus" class="d-none">
    <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
    <input type="hidden" name="personId" id="completeWorkSessionPersonId" value="">
    <input type="hidden" name="status" id="completeWorkSessionStatus" value="attended">
    <input type="hidden" name="paidHours" id="completeWorkSessionPaidHours" value="<%= Number(entryRow.durationHours || 0).toFixed(2) %>">
    <input type="hidden" name="notes" id="completeWorkSessionNotes" value="">
  </form>

  <div class="session-manager-shell" id="workSessionManagerShell">
    <aside class="session-manager-sidebar" id="workSessionManagerSidebar" aria-label="Work session sections">
      <div class="session-manager-sidebar-head w-100">
        <span class="session-manager-nav-label small fw-bold text-secondary text-uppercase" style="letter-spacing:0.06em;">Sections</span>
        <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" id="btnToggleWorkSessionSidebar" title="Collapse sidebar" aria-expanded="true" aria-controls="workSessionManagerSidebar">
          <i class="bi bi-layout-sidebar-inset" id="workSessionSidebarToggleIcon"></i>
        </button>
      </div>
      <nav class="session-manager-sidebar-nav" role="tablist">
        <button type="button" class="session-manager-nav-item active" data-work-panel="session-detail" role="tab" aria-selected="true">
          <i class="bi bi-journal-text fs-5"></i><span class="session-manager-nav-label">Session Detail</span>
        </button>
      </nav>
    </aside>

    <main class="session-manager-main">
      <div class="session-panel active" id="work-panel-session-detail" role="tabpanel">
        <div class="row g-2 mb-3">
          <div class="col-6 col-md">
            <div class="session-summary-card h-100">
              <div class="session-summary-label">Assignees</div>
              <div class="session-summary-value"><%= visibleRows.length %></div>
            </div>
          </div>
          <div class="col-6 col-md">
            <div class="session-summary-card h-100">
              <div class="session-summary-label">Ready for timesheet</div>
              <div class="session-summary-value text-success"><%= readyCount %></div>
            </div>
          </div>
          <div class="col-6 col-md">
            <div class="session-summary-card h-100">
              <div class="session-summary-label"><%= isCompletion ? 'Completed' : 'Attended' %></div>
              <div class="session-summary-value <%= isCompletion ? 'text-primary' : 'text-success' %>"><%= isCompletion ? completionDoneCount : attendanceAttendedCount %></div>
            </div>
          </div>
          <% if (lockedCount > 0) { %>
            <div class="col-6 col-md">
              <div class="session-summary-card h-100">
                <div class="session-summary-label">Locked</div>
                <div class="session-summary-value text-secondary"><%= lockedCount %></div>
              </div>
            </div>
          <% } %>
        </div>

        <% if (evaluationTypeLocked) { %>
          <div class="alert alert-warning border-warning shadow-sm mb-3">
            <div class="fw-semibold"><i class="bi bi-exclamation-triangle-fill me-2"></i>Evaluation type is locked</div>
            <div class="small mt-1">One or more assignee rows are tied to approved timesheets.</div>
          </div>
        <% } %>

        <% if (isCompletion) { %>
          <div class="alert alert-info border-info shadow-sm mb-3">
            <div class="fw-semibold"><i class="bi bi-check2-circle me-2"></i>Completion workflow</div>
            <div class="small mt-1">Use <strong>Session status</strong> in the header to mark completion, then <strong>Save session</strong> for assignee details.</div>
          </div>
        <% } else { %>
          <div class="alert alert-info border-info shadow-sm mb-3">
            <div class="fw-semibold"><i class="bi bi-person-check me-2"></i>Attendance workflow</div>
            <div class="small mt-1">Set attendance per assignee below, then use <strong>Save session</strong> in the toolbar.</div>
          </div>
        <% } %>

        <div class="work-session-assignee-forms">
          <% assigneeRows.forEach((assignee, idx) => {
            const rowVisible = canManageAll || assignee.isSelf;
            if (!rowVisible && !canManageAll) return;
            const rowEditable = assignee.editable && (canManageAll || assignee.isSelf);
            const statusClass = assignee.locked ? 'secondary' : (assignee.readyForTimesheet ? 'success' : 'warning');
            const rowKey = String(assignee.personId || ('row_' + idx)).replace(/[^A-Za-z0-9_-]/g, '_') + '_' + String(idx);
          %>
            <div class="card border-0 shadow-sm work-session-assignee-form<%= assignee.locked ? ' is-locked' : '' %>" data-person-id="<%= assignee.personId %>">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
                  <div>
                    <h6 class="fw-bold mb-1"><%= assignee.personName || assignee.personId %></h6>
                    <div class="small text-muted"><%= assignee.role || 'participant' %></div>
                    <% if (assignee.locked) { %><span class="badge bg-secondary mt-2">Timesheet locked</span><% } %>
                  </div>
                  <div class="text-end">
                    <span class="badge bg-<%= statusClass %>"><%= assignee.completionLabel %></span>
                    <% if (isCompletion && String(assignee.completionStatus || '').toLowerCase() === 'completed' && assignee.completedAt) { %>
                      <div class="small text-muted mt-1"><%= assignee.completedAt.slice(0, 10) %></div>
                    <% } %>
                  </div>
                </div>

                <% if (!isCompletion) { %>
                  <div class="mb-3">
                    <label class="form-label">Attendance</label>
                    <% if (rowEditable) { %>
                      <div class="btn-group btn-group-sm flex-wrap" role="group" aria-label="Attendance status for <%= assignee.personName || assignee.personId %>">
                        <input type="radio" class="btn-check ws-att-radio" data-person-id="<%= assignee.personId %>" name="att_<%= rowKey %>" id="attended_<%= rowKey %>" value="attended" <%= String(assignee.status || 'attended') === 'attended' ? 'checked' : '' %>>
                        <label class="btn att-label" for="attended_<%= rowKey %>" title="Attended"><i class="bi bi-check-lg me-1"></i>Attended</label>
                        <input type="radio" class="btn-check ws-att-radio" data-person-id="<%= assignee.personId %>" name="att_<%= rowKey %>" id="excused_<%= rowKey %>" value="excused" <%= String(assignee.status || '') === 'excused' ? 'checked' : '' %>>
                        <label class="btn att-label" for="excused_<%= rowKey %>" title="Excused"><i class="bi bi-envelope-paper me-1"></i>Excused</label>
                        <input type="radio" class="btn-check ws-att-radio" data-person-id="<%= assignee.personId %>" name="att_<%= rowKey %>" id="absent_<%= rowKey %>" value="absent" <%= String(assignee.status || '') === 'absent' ? 'checked' : '' %>>
                        <label class="btn att-label" for="absent_<%= rowKey %>" title="Absent"><i class="bi bi-x-lg me-1"></i>Absent</label>
                      </div>
                    <% } else { %>
                      <div class="form-control-plaintext"><span class="badge bg-light text-dark border"><%= assignee.status || 'pending' %></span></div>
                    <% } %>
                  </div>
                <% } %>

                <% if (activityRow.paid) { %>
                  <div class="mb-3">
                    <label class="form-label" for="paidHours_<%= rowKey %>">Paid hours</label>
                    <% if (rowEditable) { %>
                      <input type="number" step="0.25" min="0" max="24" class="form-control ws-paid-hours-input" id="paidHours_<%= rowKey %>" data-person-id="<%= assignee.personId %>" value="<%= Number(assignee.paidHours || entryRow.durationHours || 0).toFixed(2) %>">
                    <% } else { %>
                      <div class="form-control-plaintext fw-semibold"><%= Number(assignee.paidHours || 0).toFixed(2) %></div>
                    <% } %>
                  </div>
                <% } %>

                <div class="mb-3">
                  <label class="form-label" for="notes_<%= rowKey %>">Notes</label>
                  <% if (rowEditable) { %>
                    <textarea class="form-control ws-notes-input" id="notes_<%= rowKey %>" data-person-id="<%= assignee.personId %>" rows="3" maxlength="500" placeholder="Add notes for this assignee"><%= assignee.notes || '' %></textarea>
                  <% } else { %>
                    <div class="form-control-plaintext"><%= assignee.notes || '-' %></div>
                  <% } %>
                </div>

                <% if (isCompletion && rowEditable) { %>
                  <div class="form-check">
                    <input type="radio" class="form-check-input ws-complete-target" name="ws_complete_target" id="completeTarget_<%= rowKey %>" value="<%= assignee.personId %>" data-person-id="<%= assignee.personId %>">
                    <label class="form-check-label" for="completeTarget_<%= rowKey %>">Use this assignee when marking session completed</label>
                  </div>
                <% } %>

                <% if (rowEditable) { %>
                  <form method="POST" action="<%= manageUrl %>/save" class="d-none ws-assignee-save-form" data-person-id="<%= assignee.personId %>">
                    <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
                    <input type="hidden" name="personId" value="<%= assignee.personId %>">
                    <input type="hidden" name="status" value="<%= assignee.status || 'attended' %>" class="ws-status-<%= assignee.personId %>">
                    <input type="hidden" name="paidHours" value="<%= Number(assignee.paidHours || entryRow.durationHours || 0).toFixed(2) %>" class="ws-paid-hours-<%= assignee.personId %>">
                    <input type="hidden" name="notes" value="<%= assignee.notes || '' %>" class="ws-notes-<%= assignee.personId %>">
                  </form>
                <% } %>
              </div>
            </div>
          <% }) %>
          <% if (!assigneeRows.length) { %>
            <div class="text-center text-muted py-4 border rounded bg-light">No assignees on this work session.</div>
          <% } %>
        </div>
      </div>
    </main>
  </div>

  <% if (!canManageAll && assigneeRows.every((row) => !row.isSelf)) { %>
    <div class="alert alert-warning mt-3 border-warning shadow-sm">
      <div class="fw-semibold"><i class="bi bi-exclamation-circle me-1"></i>Not assigned</div>
      <div class="small mt-1">You are not assigned to this work session.</div>
    </div>
  <% } %>
</div>

<%- include('partials/modal') %>

<script>
  (function () {
    const fallbackCloseHref = "<%= overviewManageUrl %>";
    const isCompletionMode = <%= isCompletion ? 'true' : 'false' %>;

    function resolveMessageModalFn() {
      if (typeof showMessageModal === 'function') return showMessageModal;
      if (typeof window !== 'undefined' && typeof window.showMessageModal === 'function') return window.showMessageModal;
      return null;
    }

    function resolveMessageBoxFn() {
      if (typeof messageBox === 'function') return messageBox;
      if (typeof window !== 'undefined' && typeof window.messageBox === 'function') return window.messageBox;
      return null;
    }

    async function showUiMessage(options) {
      try {
        const showMessageModalFn = resolveMessageModalFn();
        if (showMessageModalFn) return await showMessageModalFn(options || {});
        const messageBoxFn = resolveMessageBoxFn();
        if (messageBoxFn) return await messageBoxFn(options || {});
      } catch (error) { /* ignore and fall back */ }
      window.alert((options && options.message) ? options.message : 'Done');
      return false;
    }

    async function showUiConfirm(options) {
      const opts = { showCancel: true, ...(options || {}) };
      try {
        const showMessageModalFn = resolveMessageModalFn();
        if (showMessageModalFn) {
          const okText = String(opts.okText || 'Yes').trim() || 'Yes';
          const cancelText = String(opts.cancelText || 'No').trim() || 'No';
          const modalPayload = {
            title: opts.title || 'Confirm',
            message: opts.message || 'Are you sure?',
            type: opts.type || 'confirm',
            okText: okText,
            cancelText: cancelText,
            icon: opts.icon || 'warning',
            buttons: [
              { text: okText, class: 'btn-primary' },
              { text: cancelText, class: 'btn-secondary' }
            ]
          };
          const modalResult = await showMessageModalFn(modalPayload);
          const normalizedResult = typeof modalResult === 'string'
            ? modalResult.trim().toLowerCase()
            : modalResult;
          return normalizedResult === true || normalizedResult === okText.toLowerCase();
        }
        const messageBoxFn = resolveMessageBoxFn();
        if (messageBoxFn) return !!(await messageBoxFn(opts));
      } catch (error) { /* ignore and fall back */ }
      return window.confirm((opts && opts.message) ? opts.message : 'Are you sure?');
    }

    function syncRowFields(personId) {
      const status = document.querySelector('input.ws-att-radio[data-person-id="' + personId + '"]:checked');
      const paidHours = document.querySelector('.ws-paid-hours-input[data-person-id="' + personId + '"]');
      const notes = document.querySelector('.ws-notes-input[data-person-id="' + personId + '"]');
      document.querySelectorAll('.ws-status-' + personId).forEach((input) => {
        if (status) input.value = status.value;
        else if (isCompletionMode) input.value = input.value || 'attended';
      });
      document.querySelectorAll('.ws-paid-hours-' + personId).forEach((input) => {
        if (paidHours) input.value = paidHours.value;
      });
      document.querySelectorAll('.ws-notes-' + personId).forEach((input) => {
        if (notes) input.value = notes.value;
      });
    }

    function syncCompleteWorkSessionForm(personId) {
      syncRowFields(personId);
      const statusSource = document.querySelector('.ws-status-' + personId);
      const paidSource = document.querySelector('.ws-paid-hours-' + personId);
      const notesSource = document.querySelector('.ws-notes-' + personId);
      const personInput = document.getElementById('completeWorkSessionPersonId');
      const statusInput = document.getElementById('completeWorkSessionStatus');
      const paidInput = document.getElementById('completeWorkSessionPaidHours');
      const notesInput = document.getElementById('completeWorkSessionNotes');
      if (personInput) personInput.value = personId || '';
      if (statusInput) statusInput.value = statusSource ? statusSource.value : 'attended';
      if (paidInput) paidInput.value = paidSource ? paidSource.value : '';
      if (notesInput) notesInput.value = notesSource ? notesSource.value : '';
    }

    function resolveCompletionTargetPersonId() {
      const selected = document.querySelector('input.ws-complete-target:checked');
      if (selected) return selected.getAttribute('data-person-id') || selected.value || '';
      const editableTargets = Array.from(document.querySelectorAll('input.ws-complete-target'));
      if (editableTargets.length === 1) {
        return editableTargets[0].getAttribute('data-person-id') || editableTargets[0].value || '';
      }
      const saveForms = Array.from(document.querySelectorAll('.ws-assignee-save-form[data-person-id]'));
      if (saveForms.length === 1) return saveForms[0].getAttribute('data-person-id') || '';
      return '';
    }

    const saveSessionBtn = document.getElementById('btnSaveWorkSession');
    if (saveSessionBtn) {
      saveSessionBtn.addEventListener('click', async function () {
        const saveForms = Array.from(document.querySelectorAll('.ws-assignee-save-form[data-person-id]'));
        if (!saveForms.length) return;
        if (typeof window.showLoading === 'function') window.showLoading('Saving session…');
        try {
          for (const form of saveForms) {
            const personId = form.getAttribute('data-person-id');
            if (personId) syncRowFields(personId);
            const response = await fetch(form.action, {
              method: 'POST',
              body: new FormData(form),
              headers: { 'X-Requested-With': 'XMLHttpRequest' }
            });
            const payload = await response.json().catch(() => ({}));
            if (!response.ok || payload.status === 'error') {
              throw new Error(payload.message || 'Save failed.');
            }
          }
          window.location.reload();
        } catch (error) {
          if (typeof window.hideLoading === 'function') window.hideLoading();
          const message = error && error.message ? error.message : 'Save failed.';
          await showUiMessage({ title: 'Save failed', icon: 'error', message: message });
        }
      });
    }
    const completeForm = document.getElementById('frmCompleteWorkSessionStatus');
    const statusButton = document.getElementById('workSessionStatusButton');
    if (statusButton && completeForm && isCompletionMode) {
      statusButton.addEventListener('click', async function () {
        if (statusButton.disabled) return;
        const personId = resolveCompletionTargetPersonId();
        if (!personId) {
          const message = 'Select an assignee below before marking this work session completed.';
          await showUiMessage({ title: 'Select assignee', icon: 'warning', message: message });
          return;
        }
        const confirmed = await showUiConfirm({
          title: 'Mark completed',
          icon: 'warning',
          message: 'Mark this work session as completed for the selected assignee?'
        });
        if (!confirmed) return;
        syncCompleteWorkSessionForm(personId);
        if (typeof window.showLoading === 'function') window.showLoading('Completing…');
        completeForm.submit();
      });
    }

    function setActiveWorkPanel(panelId) {
      document.querySelectorAll('.session-manager-nav-item[data-work-panel]').forEach((btn) => {
        const isActive = btn.getAttribute('data-work-panel') === panelId;
        btn.classList.toggle('active', isActive);
        btn.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      document.querySelectorAll('.session-panel[id^="work-panel-"]').forEach((panel) => {
        panel.classList.toggle('active', panel.id === 'work-panel-' + panelId);
      });
    }

    document.querySelectorAll('.session-manager-nav-item[data-work-panel]').forEach((btn) => {
      btn.addEventListener('click', function () {
        const panelId = btn.getAttribute('data-work-panel');
        if (!panelId) return;
        setActiveWorkPanel(panelId);
      });
    });

    const sidebarEl = document.getElementById('workSessionManagerSidebar');
    const btnToggleSidebar = document.getElementById('btnToggleWorkSessionSidebar');
    const sidebarIcon = document.getElementById('workSessionSidebarToggleIcon');
    const SIDEBAR_KEY = 'workSessionManagerSidebarCollapsed';
    if (sidebarEl && btnToggleSidebar) {
      try {
        if (localStorage.getItem(SIDEBAR_KEY) === '1') {
          sidebarEl.classList.add('collapsed');
          btnToggleSidebar.setAttribute('aria-expanded', 'false');
          if (sidebarIcon) sidebarIcon.className = 'bi bi-layout-sidebar';
        }
      } catch (e) { /* ignore */ }
      btnToggleSidebar.addEventListener('click', function () {
        sidebarEl.classList.toggle('collapsed');
        const collapsed = sidebarEl.classList.contains('collapsed');
        btnToggleSidebar.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
        if (sidebarIcon) sidebarIcon.className = collapsed ? 'bi bi-layout-sidebar' : 'bi bi-layout-sidebar-inset';
        try { localStorage.setItem(SIDEBAR_KEY, collapsed ? '1' : '0'); } catch (e) { /* ignore */ }
      });
    }

    const closeBtn = document.getElementById('btnCloseWorkSessionManager');
    if (closeBtn) {
      closeBtn.addEventListener('click', function () {
        if (window.history.length > 1) window.history.back();
        else window.location.href = fallbackCloseHref;
      });
    }
  })();
</script>
