<%
  const activityRow = activity || {};
  const entryRow = entry || {};
  const assigneeRows = Array.isArray(entryRow.assignees) ? entryRow.assignees : [];
  const sessionSwitcher = Array.isArray(siblingSessions) ? siblingSessions : [];
  const hasMultipleSessions = sessionSwitcher.length > 1;
  const isCompletion = evaluationType === 'completion';
  const manageUrl = `/school/activities/${encodeURIComponent(activityRow.id)}/work-sessions/${encodeURIComponent(entryRow.entryId)}`;
  const overviewManageUrl = overviewUrl || ('/school/activities/' + encodeURIComponent(activityRow.id) + '/work-sessions/manage');
  const dashboardHref = (typeof schoolSectionDashboardHref !== 'undefined' && schoolSectionDashboardHref)
    ? schoolSectionDashboardHref
    : '/school/activities';
  const visibleRows = assigneeRows.filter((row) => canManageAll || row.isSelf);
  const lockedCount = visibleRows.filter((row) => row.locked).length;
  const readyCount = visibleRows.filter((row) => row.readyForTimesheet).length;
  const completionDoneCount = visibleRows.filter((row) => String(row.completionStatus || '').toLowerCase() === 'completed').length;
  const completionPendingCount = visibleRows.filter((row) => String(row.completionStatus || '').toLowerCase() !== 'completed').length;
  const attendanceAttendedCount = visibleRows.filter((row) => String(row.status || '').toLowerCase() === 'attended').length;
  const allAssigneesCompleted = isCompletion && visibleRows.length > 0 && completionPendingCount === 0;
  const allAttendanceRecorded = !isCompletion && visibleRows.length > 0 && attendanceAttendedCount === visibleRows.length;
  const workSessionStatusLabel = isCompletion
    ? (allAssigneesCompleted ? 'Completed' : 'Pending completion')
    : (allAttendanceRecorded ? 'Attendance recorded' : 'Pending attendance');
  const workSessionStatusActionRequired = isCompletion ? !allAssigneesCompleted : !allAttendanceRecorded;
  const workSessionLocationLabel = String(entryRow.location || activityRow.location || '').trim();
  const editableAssigneeRows = visibleRows.filter((row) => row.editable && !row.locked);
  const currentSessionIndex = sessionSwitcher.findIndex((row) => row && row.isCurrent === true);
  const prevSession = currentSessionIndex > 0 ? sessionSwitcher[currentSessionIndex - 1] : null;
  const nextSession = currentSessionIndex >= 0 && currentSessionIndex < (sessionSwitcher.length - 1)
    ? sessionSwitcher[currentSessionIndex + 1]
    : null;
%>

