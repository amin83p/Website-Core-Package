<%
  const activityRow = activity || {};
  const entryRow = entry || {};
  const assigneeRows = Array.isArray(entryRow.assignees) ? entryRow.assignees : [];
  const sessionSwitcher = Array.isArray(siblingSessions) ? siblingSessions : [];
  const hasMultipleSessions = sessionSwitcher.length > 1;
  const isCompletion = evaluationType === 'completion';
  const manageUrl = `/school/activities/${encodeURIComponent(activityRow.id)}/work-sessions/${encodeURIComponent(entryRow.entryId)}`;
  const entryTitle = entryRow.title || '';
  const entrySubtitleParts = [entryTitle, entryRow.date || ''].filter(Boolean);
  const overviewManageUrl = overviewUrl || ('/school/activities/' + encodeURIComponent(activityRow.id) + '/work-sessions/manage');
%>

<div class="sections-page activity-work-session-page">
  <% if (hasMultipleSessions) { %>
    <div class="mb-2">
      <a href="<%= overviewManageUrl %>" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i>All work sessions
      </a>
    </div>
  <% } %>
  <div class="activity-work-session-header mb-3">
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
      <h1 class="page-heading size-md m-0 text-start"><i class="bi bi-kanban me-2"></i>Manage Work Session</h1>
      <a href="/school/activities" class="btn btn-outline-secondary btn-sm ms-auto"><i class="bi bi-list-ul me-1"></i>All Activities</a>
    </div>
    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mt-2">
      <div class="text-start mb-0">
        <div class="fw-semibold text-dark"><%= activityRow.title || '' %></div>
        <% if (entrySubtitleParts.length) { %>
          <div class="small text-muted"><%= entrySubtitleParts.join(' — ') %></div>
        <% } %>
      </div>
      <a href="/school/activities/edit/<%= encodeURIComponent(activityRow.id) %>" class="btn btn-outline-secondary btn-sm ms-auto"><i class="bi bi-pencil-square me-1"></i>Edit Activity</a>
    </div>
  </div>

  <div class="d-flex flex-wrap gap-2 mb-3">
    <span class="badge bg-<%= isCompletion ? 'primary' : 'info' %>"><%= evaluationTypeLabel %></span>
    <% if (activityRow.paid) { %><span class="badge bg-success">Payable</span><% } %>
    <% if (activityRow.categoryName) { %><span class="badge bg-light text-dark border"><%= activityRow.categoryName %></span><% } %>
    <% if (activityRow.departmentName) { %><span class="badge bg-light text-dark border"><%= activityRow.departmentName %></span><% } %>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body p-4">
      <div class="row g-3">
        <div class="col-md-3">
          <div class="text-muted small text-uppercase">Date</div>
          <div class="fw-bold"><%= entryRow.date || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="text-muted small text-uppercase">Time</div>
          <div class="fw-bold"><%= entryRow.startTime || '-' %> – <%= entryRow.endTime || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="text-muted small text-uppercase">Duration</div>
          <div class="fw-bold"><%= Number(entryRow.durationHours || 0).toFixed(2) %> h</div>
        </div>
        <div class="col-md-3">
          <div class="text-muted small text-uppercase">Location</div>
          <div class="fw-bold"><%= entryRow.location || activityRow.location || '-' %></div>
        </div>
        <% if (entryRow.notes || activityRow.notes) { %>
          <div class="col-12">
            <div class="text-muted small text-uppercase">Notes</div>
            <div><%= entryRow.notes || activityRow.notes %></div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <% if (isCompletion) { %>
    <div class="alert alert-light border mb-4">
      <i class="bi bi-check2-circle me-2"></i>
      Assignees must explicitly mark their assignment <strong>complete</strong>. Paid rows also require <strong>attended</strong> status.
    </div>
  <% } else { %>
    <div class="alert alert-light border mb-4">
      <i class="bi bi-person-check me-2"></i>
      Record attendance for each assignee. Paid timesheet rows require <strong>attended</strong> status.
    </div>
  <% } %>

  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Person</th>
              <th>Role</th>
              <% if (!isCompletion) { %><th>Attendance</th><% } %>
              <% if (activityRow.paid) { %><th>Paid hours</th><% } %>
              <th>Notes</th>
              <th>Status</th>
              <% if (isCompletion) { %><th class="text-end">Actions</th><% } else { %><th class="text-end">Save</th><% } %>
            </tr>
          </thead>
          <tbody>
            <% const tableColSpan = 5 + (isCompletion ? 0 : 1) + (activityRow.paid ? 1 : 0); %>
            <% assigneeRows.forEach((assignee) => {
              const rowVisible = canManageAll || assignee.isSelf;
              const rowEditable = assignee.editable && (canManageAll || assignee.isSelf);
              const statusClass = assignee.locked ? 'secondary' : (assignee.readyForTimesheet ? 'success' : 'warning');
            %>
              <tr class="<%= assignee.locked ? 'table-secondary' : '' %>">
                <td>
                  <div class="fw-semibold"><%= assignee.personName || assignee.personId %></div>
                  <% if (assignee.locked) { %><span class="badge bg-secondary">Timesheet locked</span><% } %>
                </td>
                <td><%= assignee.role || 'participant' %></td>
                <% if (!isCompletion) { %>
                <td>
                  <% if (rowEditable) { %>
                    <select class="form-select form-select-sm ws-status-input" data-person-id="<%= assignee.personId %>" style="min-width: 8rem;">
                      <% ['attended', 'absent', 'excused'].forEach((status) => { %>
                        <option value="<%= status %>" <%= String(assignee.status || 'attended') === status ? 'selected' : '' %>><%= status %></option>
                      <% }) %>
                    </select>
                  <% } else { %>
                    <span class="badge bg-light text-dark border"><%= assignee.status || 'pending' %></span>
                  <% } %>
                </td>
                <% } %>
                <% if (activityRow.paid) { %>
                  <td>
                    <% if (rowEditable) { %>
                      <input type="number" step="0.25" min="0" max="24" class="form-control form-control-sm ws-paid-hours-input" data-person-id="<%= assignee.personId %>" style="max-width: 6rem;" value="<%= Number(assignee.paidHours || entryRow.durationHours || 0).toFixed(2) %>">
                    <% } else { %>
                      <%= Number(assignee.paidHours || 0).toFixed(2) %>
                    <% } %>
                  </td>
                <% } %>
                <td>
                  <% if (rowEditable) { %>
                    <input type="text" class="form-control form-control-sm ws-notes-input" data-person-id="<%= assignee.personId %>" value="<%= assignee.notes || '' %>" maxlength="500">
                  <% } else { %>
                    <%= assignee.notes || '-' %>
                  <% } %>
                </td>
                <td>
                  <span class="badge bg-<%= statusClass %>"><%= assignee.completionLabel %></span>
                  <% if (isCompletion && String(assignee.completionStatus || '').toLowerCase() === 'completed' && assignee.completedAt) { %>
                    <div class="small text-muted"><%= assignee.completedAt.slice(0, 10) %></div>
                  <% } %>
                </td>
                <td class="text-end">
                  <% if (rowEditable) { %>
                    <% if (isCompletion) { %>
                      <div class="d-inline-flex gap-2 flex-wrap justify-content-end">
                        <form method="POST" action="<%= manageUrl %>/save" class="d-inline">
                          <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
                          <input type="hidden" name="personId" value="<%= assignee.personId %>">
                          <input type="hidden" name="status" value="<%= assignee.status || 'attended' %>" class="ws-status-<%= assignee.personId %>">
                          <input type="hidden" name="paidHours" value="<%= Number(assignee.paidHours || entryRow.durationHours || 0).toFixed(2) %>" class="ws-paid-hours-<%= assignee.personId %>">
                          <input type="hidden" name="notes" value="<%= assignee.notes || '' %>" class="ws-notes-<%= assignee.personId %>">
                          <button type="submit" class="btn btn-outline-secondary btn-sm btn-ws-save" data-person-id="<%= assignee.personId %>"><i class="bi bi-save me-1"></i>Save</button>
                        </form>
                        <form method="POST" action="<%= manageUrl %>/complete" class="d-inline">
                          <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
                          <input type="hidden" name="personId" value="<%= assignee.personId %>">
                          <input type="hidden" name="status" value="<%= assignee.status || 'attended' %>" class="ws-status-<%= assignee.personId %>">
                          <input type="hidden" name="paidHours" value="<%= Number(assignee.paidHours || entryRow.durationHours || 0).toFixed(2) %>" class="ws-paid-hours-<%= assignee.personId %>">
                          <input type="hidden" name="notes" value="<%= assignee.notes || '' %>" class="ws-notes-<%= assignee.personId %>">
                          <button type="submit" class="btn btn-primary btn-sm btn-ws-complete" data-person-id="<%= assignee.personId %>" onclick="return confirm('Mark this assignment complete?');">
                            <i class="bi bi-check2-circle me-1"></i>Complete
                          </button>
                        </form>
                      </div>
                    <% } else { %>
                      <form method="POST" action="<%= manageUrl %>/save" class="d-inline">
                        <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
                        <input type="hidden" name="personId" value="<%= assignee.personId %>">
                        <input type="hidden" name="status" value="<%= assignee.status || 'attended' %>" class="ws-status-<%= assignee.personId %>">
                        <input type="hidden" name="paidHours" value="<%= Number(assignee.paidHours || entryRow.durationHours || 0).toFixed(2) %>" class="ws-paid-hours-<%= assignee.personId %>">
                        <input type="hidden" name="notes" value="<%= assignee.notes || '' %>" class="ws-notes-<%= assignee.personId %>">
                        <button type="submit" class="btn btn-primary btn-sm btn-ws-save" data-person-id="<%= assignee.personId %>"><i class="bi bi-save me-1"></i>Save attendance</button>
                      </form>
                    <% } %>
                  <% } else if (!rowVisible && canManageAll === false) { %>
                    <span class="text-muted small">Hidden</span>
                  <% } else { %>
                    <span class="text-muted small">Read only</span>
                  <% } %>
                </td>
              </tr>
            <% }) %>
            <% if (!assigneeRows.length) { %>
              <tr><td colspan="<%= tableColSpan %>" class="text-center text-muted py-4">No assignees on this work session.</td></tr>
            <% } %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <% if (!canManageAll && assigneeRows.every((row) => !row.isSelf)) { %>
    <div class="alert alert-warning mt-4">You are not assigned to this work session.</div>
  <% } %>
</div>

<script>
  (function () {
    function syncRowFields(personId) {
      const status = document.querySelector('.ws-status-input[data-person-id="' + personId + '"]');
      const paidHours = document.querySelector('.ws-paid-hours-input[data-person-id="' + personId + '"]');
      const notes = document.querySelector('.ws-notes-input[data-person-id="' + personId + '"]');
      document.querySelectorAll('.ws-status-' + personId).forEach((input) => {
        if (status) input.value = status.value;
      });
      document.querySelectorAll('.ws-paid-hours-' + personId).forEach((input) => {
        if (paidHours) input.value = paidHours.value;
      });
      document.querySelectorAll('.ws-notes-' + personId).forEach((input) => {
        if (notes) input.value = notes.value;
      });
    }
    document.querySelectorAll('.btn-ws-save, .btn-ws-complete').forEach((button) => {
      button.addEventListener('click', function () {
        const personId = button.getAttribute('data-person-id');
        if (personId) syncRowFields(personId);
        if (typeof window.showLoading === 'function') window.showLoading('Saving…');
      });
    });
  })();
</script>
