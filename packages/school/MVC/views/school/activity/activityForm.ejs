      '<div class="col-md-3"><label class="form-label fw-bold">Location</label><input type="text" class="form-control form-control-sm js-entry-field" data-field="location" value="' + escapeHtml(entry.location || '') + '"></div>',
      '<div class="col-md-3"><label class="form-label fw-bold">Date *</label><input type="date" class="form-control form-control-sm js-entry-field" data-field="date" value="' + escapeHtml(entry.date || '') + '"></div>',
      '<div class="col-md-3"><label class="form-label fw-bold">Start *</label><input type="time" class="form-control form-control-sm js-entry-field" data-field="startTime" value="' + escapeHtml(entry.startTime || '') + '"></div>',
      '<div class="col-md-3"><label class="form-label fw-bold">End *</label><input type="time" class="form-control form-control-sm js-entry-field" data-field="endTime" value="' + escapeHtml(entry.endTime || '') + '"></div>',
      '<div class="col-md-3"><label class="form-label fw-bold">Hours *</label><input type="number" min="0" max="24" step="0.01" class="form-control form-control-sm js-entry-field" data-field="durationHours" value="' + escapeHtml(entry.durationHours || '') + '"></div>',
      '<div class="col-12"><label class="form-label fw-bold">Session Notes</label><textarea rows="2" class="form-control form-control-sm js-entry-field" data-field="notes" placeholder="Optional notes for this session...">' + escapeHtml(entry.notes || '') + '</textarea></div>',
