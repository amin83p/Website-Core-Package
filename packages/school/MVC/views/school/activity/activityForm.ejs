<%
  const row = activity || {};
  const legacyAttendees = Array.isArray(row.attendees) ? row.attendees : [];
  const normalizePersonIdListServer = (source) => {
    if (!Array.isArray(source)) return [];
    const seen = new Set();
    return source
      .map((item) => String(typeof item === 'string' ? item : (item?.personId || item?.id || '')).trim())
      .filter((personId) => {
        if (!personId || seen.has(personId)) return false;
        seen.add(personId);
        return true;
      });
  };
  const rawVisibilityScope = String(row.visibilityScope || 'school').trim().toLowerCase().replace(/[\s-]+/g, '_');
  const visibilityScope = ['individual', 'private', 'personal', 'assigned', 'assigned_only', 'attendee', 'attendees', 'attendees_only'].includes(rawVisibilityScope)
    ? 'individual'
    : 'school';
  const rawEvaluationType = String(row.evaluationType || 'attendance').trim().toLowerCase();
  const evaluationType = rawEvaluationType === 'completion' ? 'completion' : 'attendance';
  const evaluationTypeLocked = (() => {
    const entries = Array.isArray(row.entries) ? row.entries : [];
    for (const entry of entries) {
      const assignees = Array.isArray(entry.assignees) ? entry.assignees : [];
      if (assignees.some((assignee) => (assignee.locked === true || String(assignee.locked) === 'true') && String(assignee.lockReason || '') === 'timesheet_approved')) return true;
      if ((entry.locked === true || String(entry.locked) === 'true') && String(entry.lockReason || '') === 'timesheet_approved') return true;
    }
    return (row.locked === true || String(row.locked) === 'true') && String(row.lockReason || '') === 'timesheet_approved';
  })();
  const initialAllowedPersonIds = normalizePersonIdListServer(row.allowedPersonIds || []);
  const initialExcludedPersonIds = normalizePersonIdListServer(row.excludedPersonIds || []);
  const initialEntries = Array.isArray(row.entries) && row.entries.length
    ? row.entries
    : [{
        entryId: 'ENTRY-1',
        title: '',
        date: row.date || '',
        startTime: row.startTime || '',
        endTime: row.endTime || '',
        durationHours: row.durationHours || '',
        location: row.location || '',
        notes: '',
        status: 'posted',
        excludedPersonIds: [],
        assignees: legacyAttendees
      }];
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-heading size-md m-0"><i class="bi bi-calendar-event me-2"></i><%= title %></h1>
    <% if (isEdit) { %><span class="badge bg-primary border font-monospace"><%= row.id %></span><% } %>
  </div>

  <% const activityTimesheetLocked = (row.locked === true || String(row.locked) === 'true') && String(row.lockReason || '') === 'timesheet_approved'
    || (Array.isArray(row.entries) ? row.entries : []).some((entry) => (entry.locked === true || String(entry.locked) === 'true') && String(entry.lockReason || '') === 'timesheet_approved'); %>
  <% if (activityTimesheetLocked) { %>
    <div class="alert alert-warning border-warning shadow-sm mb-4">
      <i class="bi bi-lock-fill me-2"></i>
      <strong>Timesheet locked.</strong> One or more work sessions on this activity are locked by an approved timesheet. Reopen the timesheet before making structural changes.
    </div>
  <% } %>

  <div class="form-container wide" style="max-width: 1180px;">
    <form id="schoolActivityForm" method="POST" action="<%= isEdit ? '/school/activities/edit/' + row.id : '/school/activities/new' %>">
      <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
      <input type="hidden" name="entries" id="activityEntriesInput" value="[]">
      <input type="hidden" name="attendees" id="activityAttendeesInput" value="[]">
      <input type="hidden" name="allowedPersonIds" id="activityAllowedPersonIdsInput" value="[]">
      <input type="hidden" name="excludedPersonIds" id="activityExcludedPersonIdsInput" value="[]">
      <input type="hidden" name="date" id="activityLegacyDate" value="<%= row.date || '' %>">
      <input type="hidden" name="startTime" id="activityLegacyStartTime" value="<%= row.startTime || '' %>">
      <input type="hidden" name="endTime" id="activityLegacyEndTime" value="<%= row.endTime || '' %>">
      <input type="hidden" name="durationHours" id="activityLegacyDurationHours" value="<%= row.durationHours || '' %>">

      <script type="application/json" id="activityInitialEntries"><%- JSON.stringify(initialEntries) %></script>
      <script type="application/json" id="activityInitialAttendees"><%- JSON.stringify(legacyAttendees) %></script>
      <script type="application/json" id="activityInitialAllowedPersonIds"><%- JSON.stringify(initialAllowedPersonIds) %></script>
      <script type="application/json" id="activityInitialExcludedPersonIds"><%- JSON.stringify(initialExcludedPersonIds) %></script>
      <script type="application/json" id="activityCategoriesData"><%- JSON.stringify(categories || []) %></script>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
          <div class="row g-3">
            <div class="col-md-8">
              <label class="form-label fw-bold">Title *</label>
              <input type="text" name="title" id="activityTitle" class="form-control size-md" value="<%= row.title || '' %>" required>
              <div class="form-text small">Use this as the parent work plan, such as content preparation or web development.</div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Status *</label>
              <select name="status" class="form-select size-md">
                <% ['draft', 'posted', 'cancelled'].forEach((status) => { %>
                  <option value="<%= status %>" <%= String(row.status || 'draft') === status ? 'selected' : '' %>><%= status[0].toUpperCase() + status.slice(1) %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Calendar Scope *</label>
              <select name="visibilityScope" id="activityVisibilityScope" class="form-select size-md" required>
                <option value="school" <%= visibilityScope === 'school' ? 'selected' : '' %>>School / Public</option>
                <option value="individual" <%= visibilityScope === 'individual' ? 'selected' : '' %>>Individual / Assigned people only</option>
              </select>
              <div class="form-text small">Public activities appear on the School Calendar; individual activities only appear in assigned schedules.</div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Category *</label>
              <select name="categoryId" id="activityCategoryId" class="form-select size-md" required>
                <option value="">Select category</option>
                <% (categories || []).forEach((cat) => { %>
                  <option value="<%= cat.id %>" <%= String(row.categoryId || '') === String(cat.id) ? 'selected' : '' %> data-paid="<%= cat.defaultPaid ? 'true' : 'false' %>"><%= cat.name || cat.code || cat.id %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Department *</label>
              <select name="departmentId" class="form-select size-md" required>
                <option value="">Select department</option>
                <% (departments || []).forEach((dep) => { %>
                  <option value="<%= dep.id %>" <%= String(row.departmentId || '') === String(dep.id) ? 'selected' : '' %>><%= (dep.code ? dep.code + ' - ' : '') + (dep.name || dep.id) %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Default Location</label>
              <input type="text" name="location" id="activityLocation" class="form-control size-md" value="<%= row.location || '' %>">
            </div>
            <div class="col-md-4">
              <div class="form-check form-switch mt-4">
                <input class="form-check-input" type="checkbox" name="paid" id="activityPaid" <%= row.paid ? 'checked' : '' %>>
                <label class="form-check-label fw-bold" for="activityPaid">Payable activity</label>
              </div>
              <div class="form-text small">Assignees can still be marked unpaid per work session.</div>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Evaluation type *</label>
              <select name="evaluationType" id="activityEvaluationType" class="form-select size-md" required <%= evaluationTypeLocked ? 'disabled' : '' %>>
                <option value="attendance" <%= evaluationType === 'attendance' ? 'selected' : '' %>>Attendance — presence/absence is the criterion</option>
                <option value="completion" <%= evaluationType === 'completion' ? 'selected' : '' %>>Completion — assignees must mark complete</option>
              </select>
              <% if (evaluationTypeLocked) { %>
                <input type="hidden" name="evaluationType" value="<%= evaluationType %>">
                <div class="form-text small text-warning">Cannot change evaluation type while timesheet-locked assignee rows exist.</div>
              <% } else { %>
                <div class="form-text small">Attendance activities use attendance recording on the manage page; completion activities require an explicit complete action.</div>
              <% } %>
            </div>
            <div class="col-12">
              <label class="form-label fw-bold">Parent Notes</label>
              <textarea name="notes" rows="3" class="form-control size-md"><%= row.notes || '' %></textarea>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
          <div class="d-flex align-items-start justify-content-between flex-wrap gap-2 mb-3">
            <div>
              <h5 class="m-0 fw-bold"><i class="bi bi-person-check me-2"></i>Scope Person Controls</h5>
              <div class="small text-muted">Configure who can be assigned to this activity by scope, with optional exclusions.</div>
            </div>
          </div>

          <div class="row g-3">
            <div class="col-12 d-none" id="activityAllowedPersonsGroup">
              <div class="border rounded p-3 bg-light">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                  <div>
                    <div class="fw-bold">Allowed persons (Individual scope)</div>
                    <div class="small text-muted">Only selected people can be assigned when scope is individual.</div>
                  </div>
                  <button type="button" class="btn btn-outline-primary btn-sm" id="activityAllowedPersonsSelectBtn"><i class="bi bi-person-plus me-1"></i>Select allowed persons</button>
                </div>
                <div id="activityAllowedPersonsChips" class="d-flex flex-wrap gap-2"></div>
                <div class="small text-muted mt-2" id="activityAllowedPersonsEmptyHint">No allowed persons selected yet.</div>
              </div>
            </div>

            <div class="col-12" id="activityExcludedPersonsGroup">
              <div class="border rounded p-3 bg-light">
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
                  <div>
                    <div class="fw-bold">Excluded persons</div>
                    <div class="small text-muted">Excluded people cannot be assigned, shown in schedule, or extracted to timesheets for this activity.</div>
                  </div>
                  <button type="button" class="btn btn-outline-primary btn-sm" id="activityExcludedPersonsSelectBtn"><i class="bi bi-person-dash me-1"></i>Select exclusions</button>
                </div>
                <div id="activityExcludedPersonsChips" class="d-flex flex-wrap gap-2"></div>
                <div class="small text-muted mt-2" id="activityExcludedPersonsEmptyHint">No excluded persons configured.</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
          <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-3">
            <div>
              <h5 class="m-0 fw-bold"><i class="bi bi-list-check me-2"></i>Sessions / Work Items</h5>
              <div class="small text-muted">Each session can have its own date, time, assignees, and payable hours.</div>
            </div>
            <button type="button" class="btn btn-outline-primary btn-sm" id="addActivityEntry"><i class="bi bi-plus-circle me-1"></i>Add Work Session</button>
          </div>
          <div class="table-responsive table-scroll-wrapper border rounded bg-white" data-floating-row-actions="true" style="max-height: 460px; overflow-y: auto;">
            <table class="table table-hover table-sm mb-0 align-middle" id="activityEntriesTable">
              <thead class="table-light text-nowrap position-sticky top-0" style="z-index: 1;">
                <tr>
                  <th style="width: 150px;">Date</th>
                  <th style="width: 150px;">Time</th>
                  <th style="width: 80px;">Hrs</th>
                  <th>Work Session</th>
                  <th style="width: 170px;">Assigned</th>
                  <th style="width: 120px;">Status</th>
                  <th style="width: 150px;">Location</th>
                  <th style="width: 64px;" class="text-end pe-3">Action</th>
                </tr>
              </thead>
              <tbody id="activityEntriesTbody"></tbody>
            </table>
            <div id="activityNoEntriesMsg" class="text-center py-4 text-muted small d-none">No work sessions added yet.</div>
          </div>
        </div>
      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md">Save Activity</button>
        <a href="/school/activities" class="btn btn-filled btn-secondary btn-md">Cancel</a>
      </div>
    </form>
  </div>
</div>

<div class="modal fade" id="activityBatchModal" tabindex="-1" aria-labelledby="activityBatchModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-light">
        <div>
          <h5 class="modal-title fw-bold" id="activityBatchModalLabel"><i class="bi bi-magic me-2"></i>Generate Work Sessions</h5>
          <div class="small text-muted">Create one or more activity work sessions using dates, weekdays, time, and copied assignees.</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-light border small mb-3">
          Enter a session count, an end date, or both. If both are provided, generation starts from the start date, follows selected weekdays, and stops when the first limit is reached.
        </div>
        <div class="row g-3">
          <div class="col-md-3">
            <label class="form-label fw-bold">Number of Sessions</label>
            <input type="number" max="500" step="1" id="activityBatchCount" class="form-control form-control-sm" placeholder="e.g. 10">
            <div class="form-text small">Leave blank to generate through the end date.</div>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold">Start Date *</label>
            <input type="date" id="activityBatchStartDate" class="form-control form-control-sm">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold">End Date</label>
            <input type="date" id="activityBatchEndDate" class="form-control form-control-sm">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold">Status</label>
            <select id="activityBatchStatus" class="form-select form-select-sm">
              <option value="posted" selected>Posted</option>
              <option value="draft">Draft</option>
              <option value="cancelled">Cancelled</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold">Start Time *</label>
            <input type="time" id="activityBatchStartTime" class="form-control form-control-sm">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold">End Time *</label>
            <input type="time" id="activityBatchEndTime" class="form-control form-control-sm">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold">Location</label>
            <input type="text" id="activityBatchLocation" class="form-control form-control-sm" placeholder="Optional location">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold">Title Prefix</label>
            <input type="text" id="activityBatchTitlePrefix" class="form-control form-control-sm" placeholder="Work Session">
          </div>
          <div class="col-12">
            <label class="form-label fw-bold">Days</label>
            <div class="d-flex flex-wrap gap-2">
              <input type="checkbox" class="btn-check activity-batch-day" id="activityBatchDayMon" value="1"><label class="btn btn-sm btn-outline-primary" for="activityBatchDayMon">Mon</label>
              <input type="checkbox" class="btn-check activity-batch-day" id="activityBatchDayTue" value="2"><label class="btn btn-sm btn-outline-primary" for="activityBatchDayTue">Tue</label>
              <input type="checkbox" class="btn-check activity-batch-day" id="activityBatchDayWed" value="3"><label class="btn btn-sm btn-outline-primary" for="activityBatchDayWed">Wed</label>
              <input type="checkbox" class="btn-check activity-batch-day" id="activityBatchDayThu" value="4"><label class="btn btn-sm btn-outline-primary" for="activityBatchDayThu">Thu</label>
              <input type="checkbox" class="btn-check activity-batch-day" id="activityBatchDayFri" value="5"><label class="btn btn-sm btn-outline-primary" for="activityBatchDayFri">Fri</label>
              <input type="checkbox" class="btn-check activity-batch-day" id="activityBatchDaySat" value="6"><label class="btn btn-sm btn-outline-primary" for="activityBatchDaySat">Sat</label>
              <input type="checkbox" class="btn-check activity-batch-day" id="activityBatchDaySun" value="0"><label class="btn btn-sm btn-outline-primary" for="activityBatchDaySun">Sun</label>
            </div>
            <div class="form-text small">If no day is selected, the weekday of the start date will be used.</div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold">Exception Dates</label>
            <input type="text" id="activityBatchExceptions" class="form-control form-control-sm" placeholder="2026-07-01, 2026-07-08">
            <div class="form-text small">Comma-separated dates to skip.</div>
          </div>
          <div class="col-md-6">
            <label class="form-label fw-bold">Holiday Handling</label>
            <div class="form-check form-switch border rounded bg-light px-3 py-2">
              <input class="form-check-input ms-0 me-2" type="checkbox" role="switch" id="activityBatchSkipHolidays">
              <label class="form-check-label fw-bold" for="activityBatchSkipHolidays">Skip school holidays</label>
              <div class="small text-muted mt-1" id="activityBatchHolidayHint">Uses the school holiday range endpoint when enabled.</div>
            </div>
          </div>
          <div class="col-12">
            <label class="form-label fw-bold">Notes</label>
            <textarea id="activityBatchNotes" rows="2" class="form-control form-control-sm" placeholder="Optional notes copied into each generated session..."></textarea>
          </div>
          <div class="col-12">
            <div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2">
              <div>
                <div class="fw-bold small"><i class="bi bi-people me-1"></i>Assignees to Copy</div>
                <div class="small text-muted">Selected people will be copied into every generated work session.</div>
              </div>
              <div class="d-flex gap-2">
                <button type="button" class="btn btn-outline-primary btn-sm" id="activityBatchAddAssignees"><i class="bi bi-person-plus me-1"></i>Add People</button>
                <button type="button" class="btn btn-outline-secondary btn-sm" id="activityBatchClearAssignees"><i class="bi bi-x-lg me-1"></i>Clear</button>
              </div>
            </div>
            <div id="activityBatchAssignees" class="border rounded bg-light p-3 small text-muted">No people selected yet.</div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-filled btn-secondary btn-md" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-filled btn-primary btn-md" id="generateActivityEntries"><i class="bi bi-magic me-1"></i>Generate Sessions</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="activityEntryModal" tabindex="-1" aria-labelledby="activityEntryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-light">
        <div>
          <h5 class="modal-title fw-bold" id="activityEntryModalLabel"><i class="bi bi-pencil-square me-2"></i>Edit Work Session</h5>
          <div class="small text-muted">Update date, time, notes, status, assignees, and payable hours.</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="activityEntryModalBody"></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-filled btn-secondary btn-md" data-bs-dismiss="modal">Done</button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/modal_GenericPicker') %>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const form = document.getElementById('schoolActivityForm');
  const entriesInput = document.getElementById('activityEntriesInput');
  const attendeesInput = document.getElementById('activityAttendeesInput');
  const allowedPersonIdsInput = document.getElementById('activityAllowedPersonIdsInput');
  const excludedPersonIdsInput = document.getElementById('activityExcludedPersonIdsInput');
  const entriesTbody = document.getElementById('activityEntriesTbody');
  const noEntriesMsg = document.getElementById('activityNoEntriesMsg');
  const batchModalEl = document.getElementById('activityBatchModal');
  const entryModalEl = document.getElementById('activityEntryModal');
  const entryModalBody = document.getElementById('activityEntryModalBody');
  const paidInput = document.getElementById('activityPaid');
  const categorySelect = document.getElementById('activityCategoryId');
  const visibilityScopeSelect = document.getElementById('activityVisibilityScope');
  const activityTitleInput = document.getElementById('activityTitle');
  const activityLocationInput = document.getElementById('activityLocation');
  const allowedPersonsGroup = document.getElementById('activityAllowedPersonsGroup');
  const allowedPersonsChips = document.getElementById('activityAllowedPersonsChips');
  const allowedPersonsEmptyHint = document.getElementById('activityAllowedPersonsEmptyHint');
  const excludedPersonsGroup = document.getElementById('activityExcludedPersonsGroup');
  const excludedPersonsChips = document.getElementById('activityExcludedPersonsChips');
  const excludedPersonsEmptyHint = document.getElementById('activityExcludedPersonsEmptyHint');
  const legacyDateInput = document.getElementById('activityLegacyDate');
  const legacyStartInput = document.getElementById('activityLegacyStartTime');
  const legacyEndInput = document.getElementById('activityLegacyEndTime');
  const legacyDurationInput = document.getElementById('activityLegacyDurationHours');

  function parseInitialJson(id, fallback) {
    try {
      const node = document.getElementById(id);
      const parsed = JSON.parse(node?.textContent || '[]');
      return Array.isArray(parsed) ? parsed : fallback;
    } catch (_error) {
      return fallback;
    }
  }

  const initialAttendees = parseInitialJson('activityInitialAttendees', []);
  const initialAllowedPersonIds = parseInitialJson('activityInitialAllowedPersonIds', []);
  const initialExcludedPersonIds = parseInitialJson('activityInitialExcludedPersonIds', []);
  let entries = parseInitialJson('activityInitialEntries', []);
  let activityAllowedPersonIds = Array.isArray(initialAllowedPersonIds) ? initialAllowedPersonIds.map(function (id) { return String(id || '').trim(); }).filter(Boolean) : [];
  let activityExcludedPersonIds = Array.isArray(initialExcludedPersonIds) ? initialExcludedPersonIds.map(function (id) { return String(id || '').trim(); }).filter(Boolean) : [];
  let selectedEntryIndex = null;
  let batchModalInstance = null;
  let batchAssignees = [];
  let entryModalInstance = null;
  const eligiblePersonMap = new Map();
  let eligiblePersonsLoaded = false;

  function escapeHtml(value) {
    return String(value ?? '').replace(/[&<>"']/g, function (character) {
      return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[character];
    });
  }

  async function safeShowMessage(options) {
    if (typeof window.showMessageModal === 'function') return window.showMessageModal(options);
    console.error('Message modal is not available on this page.', options);
    return false;
  }

  function normalizeRole(value) {
    return String(value || '').trim().toLowerCase().replace(/^school_/, '');
  }

  function normalizeRoleList(value) {
    const source = Array.isArray(value) ? value : String(value || '').split(',');
    const roles = [];
    source.forEach(function (item) {
      const role = normalizeRole(typeof item === 'string' ? item : (item?.key || item?.role || item?.name || item?.label));
      if (role && !roles.includes(role)) roles.push(role);
    });
    return roles;
  }

  function roleLabel(role) {
    const normalized = normalizeRole(role);
    if (normalized === 'teacher') return 'Teacher';
    if (normalized === 'staff') return 'Staff';
    if (normalized === 'student') return 'Student';
    return normalized ? normalized.charAt(0).toUpperCase() + normalized.slice(1) : 'Participant';
  }

  function pickDefaultRole(roles, preferred) {
    const normalizedRoles = normalizeRoleList(roles);
    const preferredRole = normalizeRole(preferred);
    if (preferredRole && normalizedRoles.includes(preferredRole)) return preferredRole;
    if (normalizedRoles.includes('teacher')) return 'teacher';
    if (normalizedRoles.includes('staff')) return 'staff';
    if (normalizedRoles.includes('student')) return 'student';
    return normalizedRoles[0] || preferredRole || 'participant';
  }

  function buildPersonDisplayName(item, fallback) {
    const preferred = String(item?.preferredName || item?.name?.preferred || '').trim();
    if (preferred) return preferred;
    const firstName = String(item?.firstName || item?.name?.first || '').trim();
    const lastName = String(item?.lastName || item?.name?.last || '').trim();
    const fullName = [firstName, lastName].filter(Boolean).join(' ');
    if (fullName) return fullName;
    return String(item?.personName || item?.displayName || fallback || '').trim();
  }

  function normalizeBoolean(value, fallback) {
    if (value === undefined || value === null || value === '') return Boolean(fallback);
    return value === true || value === 'true' || value === 'on' || value === 1 || value === '1';
  }

  function normalizePersonIdList(value) {
    const source = Array.isArray(value) ? value : [];
    const seen = new Set();
    return source.map(function (item) {
      return String(typeof item === 'string' ? item : (item?.personId || item?.id || item?.value || '')).trim();
    }).filter(function (personId) {
      if (!personId || seen.has(personId)) return false;
      seen.add(personId);
      return true;
    });
  }

  function getVisibilityScopeValue() {
    const token = String(visibilityScopeSelect?.value || 'school').trim().toLowerCase();
    return token === 'individual' ? 'individual' : 'school';
  }

  function getActivityScopeAssigneeFallbackSet() {
    const fallback = [];
    entries.forEach(function (entry) {
      (Array.isArray(entry?.assignees) ? entry.assignees : []).forEach(function (assignee) {
        const personId = String(assignee?.personId || '').trim();
        if (personId) fallback.push(personId);
      });
    });
    return new Set(fallback);
  }

  function getActivityLevelEffectiveAllowedSet() {
    const excludedSet = new Set(normalizePersonIdList(activityExcludedPersonIds));
    if (getVisibilityScopeValue() === 'individual') {
      const allowedSource = normalizePersonIdList(activityAllowedPersonIds);
      const fallbackIds = allowedSource.length ? [] : Array.from(getActivityScopeAssigneeFallbackSet());
      return new Set([].concat(allowedSource, fallbackIds).filter(function (personId) {
        return personId && !excludedSet.has(personId);
      }));
    }
    const schoolAllowed = [];
    if (eligiblePersonMap.size) {
      eligiblePersonMap.forEach(function (_person, personId) {
        if (personId && !excludedSet.has(personId)) schoolAllowed.push(personId);
      });
    } else {
      const referencedIds = new Set([
        ...normalizePersonIdList(activityAllowedPersonIds),
        ...Array.from(getActivityScopeAssigneeFallbackSet()),
        ...entries.flatMap(function (entry) { return normalizePersonIdList(entry?.excludedPersonIds || []); })
      ]);
      referencedIds.forEach(function (personId) {
        if (personId && !excludedSet.has(personId)) schoolAllowed.push(personId);
      });
    }
    return new Set(schoolAllowed);
  }

  function syncActivityScopePersonControlInputs() {
    activityAllowedPersonIds = normalizePersonIdList(activityAllowedPersonIds).filter(function (personId) {
      return !activityExcludedPersonIds.includes(personId);
    });
    activityExcludedPersonIds = normalizePersonIdList(activityExcludedPersonIds);
    if (allowedPersonIdsInput) allowedPersonIdsInput.value = JSON.stringify(activityAllowedPersonIds);
    if (excludedPersonIdsInput) excludedPersonIdsInput.value = JSON.stringify(activityExcludedPersonIds);
  }

  function ensurePersonRecord(item) {
    const personId = String(item?.personId || item?.id || '').trim();
    if (!personId) return null;
    const normalized = {
      id: personId,
      personId,
      displayName: buildPersonDisplayName(item, personId),
      firstName: String(item?.firstName || item?.name?.first || '').trim(),
      lastName: String(item?.lastName || item?.name?.last || '').trim(),
      preferredName: String(item?.preferredName || item?.name?.preferred || '').trim(),
      roles: normalizeRoleList(item?.roles || item?.availableRoles || item?.matchedRole || item?.role),
      matchedRole: normalizeRole(item?.matchedRole || item?.role || '')
    };
    eligiblePersonMap.set(personId, normalized);
    return normalized;
  }

  async function ensureEligiblePersonsLoaded() {
    if (eligiblePersonsLoaded) return Array.from(eligiblePersonMap.values());
    const response = await fetch('/school/activities/api/eligible-persons?q=', {
      headers: { 'X-AJAX-Request': 'true', Accept: 'application/json' },
      credentials: 'same-origin'
    });
    const payload = await response.json().catch(function () {
      return { status: 'error', message: 'Unable to read eligible persons.' };
    });
    if (!response.ok || payload.status !== 'success') {
      throw new Error(payload.message || 'Unable to load eligible persons.');
    }
    const rows = Array.isArray(payload.data) ? payload.data : [];
    rows.forEach(function (row) {
      ensurePersonRecord(row);
    });
    eligiblePersonsLoaded = true;
    return Array.from(eligiblePersonMap.values());
  }

  function personChipLabel(personId) {
    const person = eligiblePersonMap.get(String(personId || '').trim());
    if (!person) return String(personId || '').trim();
    return person.displayName || person.personId;
  }

  function renderPersonControlChips(targetNode, emptyNode, rows, type) {
    if (!targetNode) return;
    const normalizedRows = normalizePersonIdList(rows);
    targetNode.innerHTML = normalizedRows.map(function (personId, index) {
      return [
        '<span class="badge text-bg-light border d-inline-flex align-items-center gap-2 py-2 px-2" data-chip-type="' + escapeHtml(type) + '" data-chip-index="' + index + '">',
        '<span>' + escapeHtml(personChipLabel(personId)) + '</span>',
        '<button type="button" class="btn btn-sm btn-outline-danger py-0 px-1 js-remove-scope-chip" title="Remove"><i class="bi bi-x"></i></button>',
        '</span>'
      ].join('');
    }).join('');
    if (emptyNode) {
      emptyNode.classList.toggle('d-none', normalizedRows.length > 0);
    }
    targetNode.querySelectorAll('[data-chip-index]').forEach(function (chipEl) {
      const chipIndex = Number(chipEl.getAttribute('data-chip-index'));
      const chipType = String(chipEl.getAttribute('data-chip-type') || '').trim();
      chipEl.querySelector('.js-remove-scope-chip')?.addEventListener('click', function () {
        if (chipType === 'allowed') {
          activityAllowedPersonIds.splice(chipIndex, 1);
        } else {
          activityExcludedPersonIds.splice(chipIndex, 1);
        }
        syncActivityScopePersonControlInputs();
        renderScopePersonControls();
        if (selectedEntryIndex !== null && entryModalEl?.classList.contains('show')) renderEntryModal();
      });
    });
  }

  function renderScopePersonControls() {
    syncActivityScopePersonControlInputs();
    const scope = getVisibilityScopeValue();
    if (allowedPersonsGroup) allowedPersonsGroup.classList.toggle('d-none', scope !== 'individual');
    if (excludedPersonsGroup) excludedPersonsGroup.classList.remove('d-none');
    renderPersonControlChips(allowedPersonsChips, allowedPersonsEmptyHint, activityAllowedPersonIds, 'allowed');
    renderPersonControlChips(excludedPersonsChips, excludedPersonsEmptyHint, activityExcludedPersonIds, 'excluded');
  }

  async function openScopePersonPicker(type) {
    if (!window.GenericPicker || !window.GenericPickerPresets) {
      await safeShowMessage({ title: 'Picker Unavailable', icon: 'error', message: 'Person picker is not available on this page.' });
      return;
    }
    try {
      await ensureEligiblePersonsLoaded();
    } catch (error) {
      await safeShowMessage({ title: 'Load Failed', icon: 'error', message: error.message || 'Unable to load eligible persons.' });
      return;
    }
    const context = window.GenericPickerContexts && typeof window.GenericPickerContexts.activeOrganizationScope === 'function'
      ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization Scope' })
      : null;
    window.GenericPicker.open(window.GenericPickerPresets.person({
      title: type === 'allowed' ? 'Select Allowed Persons' : 'Select Excluded Persons',
      apiEndpoint: '/school/activities/api/eligible-persons',
      placeholder: 'Search students, teachers, or staff...',
      multiselect: true,
      context,
      onSelect: function (items) {
        const selectedRows = Array.isArray(items) ? items : [items];
        selectedRows.forEach(function (item) {
          const person = ensurePersonRecord(item);
          if (!person || !person.personId) return;
          if (type === 'allowed') {
            if (!activityAllowedPersonIds.includes(person.personId)) activityAllowedPersonIds.push(person.personId);
            activityExcludedPersonIds = activityExcludedPersonIds.filter(function (personId) { return personId !== person.personId; });
          } else {
            if (!activityExcludedPersonIds.includes(person.personId)) activityExcludedPersonIds.push(person.personId);
            activityAllowedPersonIds = activityAllowedPersonIds.filter(function (personId) { return personId !== person.personId; });
            entries.forEach(function (entry) {
              entry.assignees = (Array.isArray(entry.assignees) ? entry.assignees : []).filter(function (assignee) {
                return String(assignee?.personId || '').trim() !== person.personId;
              });
              entry.excludedPersonIds = normalizePersonIdList(entry.excludedPersonIds).filter(function (entryPersonId) {
                return entryPersonId !== person.personId;
              });
            });
          }
        });
        syncEntries();
        renderScopePersonControls();
        renderEntries();
        if (selectedEntryIndex !== null && entryModalEl?.classList.contains('show')) renderEntryModal();
      }
    }));
  }

  function isPersonAllowedByScope(personId, entryIndex) {
    const token = String(personId || '').trim();
    if (!token) return false;
    if (activityExcludedPersonIds.includes(token)) return false;
    if (getVisibilityScopeValue() === 'individual') {
      const allowedSet = getActivityLevelEffectiveAllowedSet();
      if (!allowedSet.has(token)) return false;
    }
    const entry = Number.isInteger(entryIndex) ? entries[entryIndex] : null;
    const entryExcluded = new Set(normalizePersonIdList(entry?.excludedPersonIds || []));
    return !entryExcluded.has(token);
  }

  function calculateDurationHours(startTime, endTime) {
    if (!startTime || !endTime) return 0;
    const startParts = String(startTime).split(':').map(Number);
    const endParts = String(endTime).split(':').map(Number);
    if (startParts.length < 2 || endParts.length < 2 || !startParts.every(Number.isFinite) || !endParts.every(Number.isFinite)) return 0;
    const minutes = ((endParts[0] * 60) + endParts[1]) - ((startParts[0] * 60) + startParts[1]);
    return minutes > 0 ? Number((minutes / 60).toFixed(2)) : 0;
  }

  function parseLocalDateToken(token) {
    const parts = String(token || '').split('-').map(Number);
    if (parts.length !== 3 || !parts.every(Number.isFinite)) return null;
    return new Date(parts[0], parts[1] - 1, parts[2]);
  }

  function formatLocalDateToken(date) {
    if (!(date instanceof Date) || Number.isNaN(date.getTime())) return '';
    const year = date.getFullYear();
    const month = String(date.getMonth() + 1).padStart(2, '0');
    const day = String(date.getDate()).padStart(2, '0');
    return year + '-' + month + '-' + day;
  }

  function addLocalDays(date, days) {
    const next = new Date(date.getFullYear(), date.getMonth(), date.getDate());
    next.setDate(next.getDate() + days);
    return next;
  }

  function generateEntryId() {
    return 'ENTRY-' + Date.now() + '-' + Math.floor(Math.random() * 10000);
  }

  function normalizeAttendee(item, entryDuration) {
    const personId = String(item?.personId || item?.id || '').trim();
    if (!personId) return null;
    const roles = normalizeRoleList(item?.roles || item?.availableRoles || item?.role || item?.matchedRole);
    const selectedRole = pickDefaultRole(roles, item?.role || item?.matchedRole);
    return {
      personId,
      personName: buildPersonDisplayName(item, personId),
      roles: roles.length ? roles : [selectedRole],
      role: selectedRole,
      status: item?.status || 'attended',
      paid: item?.paid === undefined ? paidInput.checked : normalizeBoolean(item.paid, paidInput.checked),
      paidHours: item?.paidHours ?? entryDuration ?? '',
      notes: item?.notes || ''
    };
  }

  function getDefaultEntry(overrides) {
    const values = overrides || {};
    return {
      entryId: values.entryId || generateEntryId(),
      title: values.title || '',
      date: values.date || '',
      startTime: values.startTime || '',
      endTime: values.endTime || '',
      durationHours: values.durationHours ?? '',
      location: values.location ?? activityLocationInput.value ?? '',
      notes: values.notes || '',
      status: values.status || 'posted',
      excludedPersonIds: normalizePersonIdList(values.excludedPersonIds || values.excludedPersons || []),
      assignees: Array.isArray(values.assignees) ? values.assignees : []
    };
  }

  function normalizeEntry(item, index) {
    const sourceAssignees = Array.isArray(item?.assignees)
      ? item.assignees
      : (Array.isArray(item?.attendees) ? item.attendees : []);
    const durationHours = item?.durationHours ?? '';
    return {
      entryId: String(item?.entryId || item?.id || 'ENTRY-' + (index + 1)).trim(),
      title: String(item?.title || '').trim(),
      date: String(item?.date || '').trim(),
      startTime: String(item?.startTime || '').trim(),
      endTime: String(item?.endTime || '').trim(),
      durationHours,
      location: String(item?.location || activityLocationInput.value || '').trim(),
      notes: String(item?.notes || '').trim(),
      status: String(item?.status || 'posted').trim().toLowerCase(),
      excludedPersonIds: normalizePersonIdList(item?.excludedPersonIds || item?.excludedPersons || []),
      assignees: sourceAssignees.map(function (itemRow) {
        return normalizeAttendee(itemRow, durationHours);
      }).filter(Boolean)
    };
  }

  function mergeAssigneesForLegacy() {
    const byPersonId = new Map();
    entries.forEach(function (entry) {
      (Array.isArray(entry.assignees) ? entry.assignees : []).forEach(function (assignee) {
        const personId = String(assignee.personId || '').trim();
        if (!personId) return;
        const existing = byPersonId.get(personId);
        if (!existing) {
          byPersonId.set(personId, { ...assignee });
          return;
        }
        const roles = Array.from(new Set([...(existing.roles || []), ...(assignee.roles || [])].filter(Boolean)));
        existing.roles = roles.length ? roles : existing.roles;
        existing.role = existing.role || assignee.role;
        existing.personName = existing.personName || assignee.personName || personId;
        existing.paid = existing.paid !== false || assignee.paid !== false;
        existing.paidHours = Number(((Number(existing.paidHours) || 0) + (Number(assignee.paidHours) || 0)).toFixed(2));
      });
    });
    return Array.from(byPersonId.values());
  }

  function syncEntries() {
    entries = (Array.isArray(entries) ? entries : []).map(normalizeEntry);
    if (!entries.length) entries.push(getDefaultEntry());
    entries.forEach(function (entry, entryIndex) {
      const excludedSet = new Set(normalizePersonIdList(entry.excludedPersonIds || []));
      entry.assignees = (Array.isArray(entry.assignees) ? entry.assignees : []).filter(function (assignee) {
        const personId = String(assignee?.personId || '').trim();
        if (!personId || excludedSet.has(personId)) return false;
        return isPersonAllowedByScope(personId, entryIndex);
      });
    });
    entriesInput.value = JSON.stringify(entries);
    attendeesInput.value = JSON.stringify(mergeAssigneesForLegacy());
    syncActivityScopePersonControlInputs();
    const firstEntry = entries[0] || {};
    legacyDateInput.value = firstEntry.date || '';
    legacyStartInput.value = firstEntry.startTime || '';
    legacyEndInput.value = firstEntry.endTime || '';
    legacyDurationInput.value = firstEntry.durationHours || '';
  }

  function renderRoleSelect(item, entryIndex, assigneeIndex) {
    const roles = normalizeRoleList(item.roles || item.role);
    const selectedRole = pickDefaultRole(roles, item.role);
    entries[entryIndex].assignees[assigneeIndex].role = selectedRole;
    entries[entryIndex].assignees[assigneeIndex].roles = roles.length ? roles : [selectedRole];
    const options = entries[entryIndex].assignees[assigneeIndex].roles.map(function (role) {
      return '<option value="' + escapeHtml(role) + '" ' + (role === selectedRole ? 'selected' : '') + '>' + escapeHtml(roleLabel(role)) + '</option>';
    }).join('');
    return '<select class="form-select form-select-sm js-assignee-role">' + options + '</select>';
  }

  function renderAssigneeRows(entry, entryIndex) {
    const assignees = Array.isArray(entry.assignees) ? entry.assignees : [];
    if (!assignees.length) {
      return '<div class="text-muted small border rounded p-3 bg-light">No people assigned to this work session yet.</div>';
    }
    return assignees.map(function (assignee, assigneeIndex) {
      const status = assignee.status || 'attended';
      const paid = assignee.paid !== false;
      return [
        '<div class="border rounded p-3 mb-2 bg-white" data-assignee-index="' + assigneeIndex + '">',
        '<div class="row g-2 align-items-end">',
        '<div class="col-md-3"><div class="fw-bold">' + escapeHtml(assignee.personName || assignee.personId) + '</div><div class="small text-muted">' + escapeHtml(assignee.personId || '') + '</div></div>',
        '<div class="col-md-2"><label class="form-label fw-bold small">Role</label>' + renderRoleSelect(assignee, entryIndex, assigneeIndex) + '</div>',
        '<div class="col-md-2"><label class="form-label fw-bold small">Status</label><select class="form-select form-select-sm js-assignee-status"><option value="attended" ' + (status === 'attended' ? 'selected' : '') + '>Attended</option><option value="absent" ' + (status === 'absent' ? 'selected' : '') + '>Absent</option><option value="excused" ' + (status === 'excused' ? 'selected' : '') + '>Excused</option></select></div>',
        '<div class="col-md-2"><label class="form-label fw-bold small">Paid Hours</label><input type="number" min="0" max="24" step="0.01" class="form-control form-control-sm js-assignee-hours" value="' + escapeHtml(assignee.paidHours ?? entry.durationHours ?? '') + '"></div>',
        '<div class="col-md-2"><div class="form-check form-switch"><input class="form-check-input js-assignee-paid" type="checkbox" ' + (paid ? 'checked' : '') + '><label class="form-check-label small fw-bold">Payable</label></div></div>',
        '<div class="col-md-1 text-end"><button type="button" class="btn btn-outline-danger btn-sm js-assignee-remove"><i class="bi bi-trash"></i></button></div>',
        '</div>',
        '<div class="mt-2"><label class="form-label fw-bold small">Assignee Notes</label><input type="text" class="form-control form-control-sm js-assignee-notes" value="' + escapeHtml(assignee.notes || '') + '" placeholder="Optional notes for this person..."></div>',
        '</div>'
      ].join('');
    }).join('');
  }

  function renderEntryExcludedRows(entry) {
    const excludedPersonIds = normalizePersonIdList(entry?.excludedPersonIds || []);
    if (!excludedPersonIds.length) {
      return '<div class="text-muted small border rounded p-3 bg-light">No session-level exclusions set.</div>';
    }
    return excludedPersonIds.map(function (personId, idx) {
      return [
        '<div class="d-flex align-items-center justify-content-between gap-2 border rounded p-2 mb-2 bg-white" data-entry-excluded-index="' + idx + '">',
        '<div><div class="fw-semibold">' + escapeHtml(personChipLabel(personId)) + '</div><div class="small text-muted font-monospace">' + escapeHtml(personId) + '</div></div>',
        '<button type="button" class="btn btn-outline-danger btn-sm js-entry-excluded-remove"><i class="bi bi-x-lg"></i></button>',
        '</div>'
      ].join('');
    }).join('');
  }

  function isBlankActivityEntry(entry) {
    if (!entry) return true;
    const hasCoreDetails = Boolean(entry.date || entry.startTime || entry.endTime || entry.durationHours || entry.title || entry.notes);
    const hasPeople = Array.isArray(entry.assignees) && entry.assignees.length > 0;
    return !hasCoreDetails && !hasPeople;
  }

  function renderBatchAssignees() {
    const target = document.getElementById('activityBatchAssignees');
    if (!target) return;
    if (!batchAssignees.length) {
      target.classList.add('text-muted');
      target.innerHTML = 'No people selected yet.';
      return;
    }
    target.classList.remove('text-muted');
    target.innerHTML = batchAssignees.map(function (assignee, index) {
      return [
        '<div class="d-flex align-items-center justify-content-between gap-2 border rounded bg-white p-2 mb-2" data-batch-assignee-index="' + index + '">',
        '<div><div class="fw-bold text-dark">' + escapeHtml(assignee.personName || assignee.personId) + '</div><div class="x-small text-muted">' + escapeHtml(roleLabel(assignee.role)) + ' · ' + escapeHtml(assignee.personId || '') + '</div></div>',
        '<button type="button" class="btn btn-outline-danger btn-sm js-batch-assignee-remove"><i class="bi bi-trash"></i></button>',
        '</div>'
      ].join('');
    }).join('');
    target.querySelectorAll('[data-batch-assignee-index]').forEach(function (row) {
      const index = Number(row.getAttribute('data-batch-assignee-index'));
      row.querySelector('.js-batch-assignee-remove')?.addEventListener('click', function () {
        batchAssignees.splice(index, 1);
        renderBatchAssignees();
      });
    });
  }

  function buildEntryRowsHtml() {
    return entries.map(function (entry, entryIndex) {
      const status = String(entry.status || 'posted').toLowerCase();
      const statusClass = status === 'posted' ? 'bg-success' : (status === 'cancelled' ? 'bg-secondary' : 'bg-info text-dark');
      const assignees = Array.isArray(entry.assignees) ? entry.assignees : [];
      const assigneeNames = assignees.slice(0, 2).map(function (assignee) {
        return assignee.personName || assignee.personId || '';
      }).filter(Boolean);
      const extraAssignees = assignees.length > assigneeNames.length ? ' +' + (assignees.length - assigneeNames.length) : '';
      const rowClass = selectedEntryIndex === entryIndex ? 'table-primary' : '';
      const rowActionId = 'activity-entry-' + escapeHtml(entry.entryId || entryIndex);
      return [
        '<tr class="' + rowClass + '" data-entry-index="' + entryIndex + '">',
        '<td><div class="fw-bold text-dark">' + escapeHtml(entry.date || '-') + '</div></td>',
        '<td><div class="small text-dark">' + escapeHtml(entry.startTime || '-') + ' - ' + escapeHtml(entry.endTime || '-') + '</div></td>',
        '<td><span class="badge bg-light text-dark border">' + escapeHtml(Number(entry.durationHours || 0).toFixed(2)) + '</span></td>',
        '<td><div class="fw-bold text-dark">' + escapeHtml(entry.title || 'Work Session ' + (entryIndex + 1)) + '</div><div class="x-small text-muted">' + escapeHtml(entry.notes || 'No notes') + '</div></td>',
        '<td><div class="small text-dark">' + escapeHtml(assigneeNames.join(', ') || 'No people') + escapeHtml(extraAssignees) + '</div><div class="x-small text-muted">' + assignees.length + ' assigned</div></td>',
        '<td><span class="badge ' + statusClass + ' text-capitalize">' + escapeHtml(status) + '</span></td>',
        '<td><div class="small text-muted">' + escapeHtml(entry.location || '-') + '</div></td>',
        '<td class="table-actions text-end pe-3">',
        '<div class="row-actions-wrap">',
        '<button type="button" class="btn btn-secondary btn-sm btn-row-actions-toggle" data-row-actions-id="' + rowActionId + '" title="Work session actions"><i class="bi bi-three-dots-vertical"></i></button>',
        '<div class="row-actions-menu d-none" data-row-actions-id="' + rowActionId + '">',
        '<button type="button" class="btn btn-outline-primary btn-sm js-entry-edit" data-index="' + entryIndex + '"><i class="bi bi-pencil-square me-2"></i>Edit details</button>',
        '<button type="button" class="btn btn-outline-primary btn-sm js-entry-add-person" data-index="' + entryIndex + '"><i class="bi bi-person-plus me-2"></i>Add person</button>',
        '<button type="button" class="btn btn-outline-secondary btn-sm js-entry-duplicate" data-index="' + entryIndex + '"><i class="bi bi-files me-2"></i>Duplicate</button>',
        '<button type="button" class="btn btn-outline-danger btn-sm js-entry-remove" data-index="' + entryIndex + '" ' + (entries.length <= 1 ? 'disabled' : '') + '><i class="bi bi-trash me-2"></i>Remove</button>',
        '</div>',
        '</div>',
        '</td>',
        '</tr>'
      ].join('');
    }).join('');
  }

  function renderEntries() {
    syncEntries();
    if (selectedEntryIndex !== null && (!entries[selectedEntryIndex] || selectedEntryIndex < 0)) selectedEntryIndex = null;
    if (!entries.length) {
      entriesTbody.innerHTML = '';
      noEntriesMsg.classList.remove('d-none');
      return;
    }
    noEntriesMsg.classList.add('d-none');
    entriesTbody.innerHTML = buildEntryRowsHtml();
  }

  function getEntryModalInstance() {
    if (!entryModalEl || !window.bootstrap || !window.bootstrap.Modal) return null;
    if (!entryModalInstance) entryModalInstance = window.bootstrap.Modal.getOrCreateInstance(entryModalEl);
    return entryModalInstance;
  }

  function openEntryModal(entryIndex) {
    if (!Number.isInteger(entryIndex) || !entries[entryIndex]) return;
    selectedEntryIndex = entryIndex;
    renderEntryRowsOnly();
    renderEntryModal();
    const modal = getEntryModalInstance();
    if (modal) modal.show();
  }

  function renderEntryModal() {
    if (selectedEntryIndex === null || !entries[selectedEntryIndex] || !entryModalBody) return;
    const entry = entries[selectedEntryIndex];
    const label = document.getElementById('activityEntryModalLabel');
