      '<div class="d-flex align-items-center justify-content-between flex-wrap gap-2 mb-2"><div class="fw-bold small"><i class="bi bi-person-dash me-1"></i>Exclude from This Session</div><button type="button" class="btn btn-outline-secondary btn-sm" id="excludePersonFromSelectedEntry"><i class="bi bi-person-dash me-1"></i>Add Exclusion</button></div>',
      '<div class="js-entry-excluded">' + renderEntryExcludedRows(entry) + '</div>',
