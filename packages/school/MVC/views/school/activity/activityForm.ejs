  function bindEntryModal() {
    const entryIndex = selectedEntryIndex;
    if (entryIndex === null || !entries[entryIndex]) return;
    entryModalBody.querySelector('#addPersonToSelectedEntry')?.addEventListener('click', function () {
      openPersonPicker(entryIndex);
    });
    entryModalBody.querySelector('#excludePersonFromSelectedEntry')?.addEventListener('click', function () {
      openEntryExcludedPersonPicker(entryIndex);
    });
    entryModalBody.querySelectorAll('.js-entry-field').forEach(function (field) {
      const updateEntryField = function () {
        const fieldName = field.getAttribute('data-field');
        entries[entryIndex][fieldName] = field.value;
        if (fieldName === 'startTime' || fieldName === 'endTime') {
          const calculatedHours = calculateDurationHours(entries[entryIndex].startTime, entries[entryIndex].endTime);
          if (calculatedHours > 0) {
            entries[entryIndex].durationHours = calculatedHours.toFixed(2);
            const durationField = entryModalBody.querySelector('[data-field="durationHours"]');
            if (durationField) durationField.value = entries[entryIndex].durationHours;
          }
        }
        syncEntries();
        renderEntryRowsOnly();
      };
      field.addEventListener('input', updateEntryField);
      field.addEventListener('change', updateEntryField);
    });
    entryModalBody.querySelectorAll('[data-assignee-index]').forEach(function (assigneeRow) {
      const assigneeIndex = Number(assigneeRow.getAttribute('data-assignee-index'));
      assigneeRow.querySelector('.js-assignee-role')?.addEventListener('change', function (event) {
        entries[entryIndex].assignees[assigneeIndex].role = event.target.value;
        syncEntries();
        renderEntryRowsOnly();
      });
      assigneeRow.querySelector('.js-assignee-status')?.addEventListener('change', function (event) {
        entries[entryIndex].assignees[assigneeIndex].status = event.target.value;
        syncEntries();
      });
      assigneeRow.querySelector('.js-assignee-hours')?.addEventListener('input', function (event) {
        entries[entryIndex].assignees[assigneeIndex].paidHours = event.target.value;
        syncEntries();
      });
      assigneeRow.querySelector('.js-assignee-paid')?.addEventListener('change', function (event) {
        entries[entryIndex].assignees[assigneeIndex].paid = event.target.checked;
        syncEntries();
      });
      assigneeRow.querySelector('.js-assignee-notes')?.addEventListener('input', function (event) {
        entries[entryIndex].assignees[assigneeIndex].notes = event.target.value;
        syncEntries();
      });
      assigneeRow.querySelector('.js-assignee-remove')?.addEventListener('click', function () {
        entries[entryIndex].assignees.splice(assigneeIndex, 1);
        syncEntries();
        renderEntryRowsOnly();
        renderEntryModal();
      });
    });
    entryModalBody.querySelectorAll('[data-entry-excluded-index]').forEach(function (rowEl) {
      const excludedIndex = Number(rowEl.getAttribute('data-entry-excluded-index'));
      rowEl.querySelector('.js-entry-excluded-remove')?.addEventListener('click', function () {
        const list = normalizePersonIdList(entries[entryIndex].excludedPersonIds || []);
        list.splice(excludedIndex, 1);
        entries[entryIndex].excludedPersonIds = list;
        syncEntries();
        renderEntryRowsOnly();
        renderEntryModal();
      });
    });
  }

  function renderEntryRowsOnly() {
    syncEntries();
    entriesTbody.innerHTML = buildEntryRowsHtml();
  }

  function getBatchModalInstance() {
    if (!batchModalEl || !window.bootstrap || !window.bootstrap.Modal) return null;
    if (!batchModalInstance) batchModalInstance = window.bootstrap.Modal.getOrCreateInstance(batchModalEl);
    return batchModalInstance;
  }

  function getBatchFieldValue(id) {
    return String(document.getElementById(id)?.value || '').trim();
  }

  function setBatchFieldValue(id, value) {
    const field = document.getElementById(id);
    if (field) field.value = value || '';
  }

  function getSelectedBatchWeekdays(startDateToken) {
    const selectedDays = Array.from(document.querySelectorAll('.activity-batch-day:checked'))
      .map(function (checkbox) { return Number(checkbox.value); })
      .filter(Number.isFinite);
    if (selectedDays.length) return selectedDays;
    const startDate = parseLocalDateToken(startDateToken);
    return startDate ? [startDate.getDay()] : [];
  }

  function parseExceptionDates(value) {
    return new Set(String(value || '').split(',').map(function (item) {
      return item.trim();
    }).filter(Boolean));
  }

  async function getHolidayDatesForBatch(startToken, endToken) {
    const skipHolidays = document.getElementById('activityBatchSkipHolidays')?.checked;
    const hint = document.getElementById('activityBatchHolidayHint');
    if (!skipHolidays || !startToken || !endToken) return new Set();
    try {
      if (hint) hint.textContent = 'Loading holidays...';
      const response = await fetch('/school/holidays/api/range?start=' + encodeURIComponent(startToken) + '&end=' + encodeURIComponent(endToken), {
        headers: { 'X-AJAX-Request': 'true' }
      });
      const payload = await response.json().catch(function () {
        return { status: 'error', message: 'Holiday endpoint returned a non-JSON response.' };
      });
      if (!response.ok || payload.status !== 'success') {
        throw new Error(payload.message || 'Unable to load school holidays.');
      }
      const holidays = Array.isArray(payload.holidays) ? payload.holidays : [];
      if (hint) hint.textContent = 'Holidays in range: ' + holidays.length;
      return new Set(holidays.map(function (holiday) {
        return String(holiday?.date || '').trim();
      }).filter(Boolean));
    } catch (error) {
      if (hint) hint.textContent = 'Holiday lookup failed; generation will continue without holiday skipping.';
      await safeShowMessage({
        title: 'Holiday Lookup Failed',
        icon: 'warning',
        message: error.message || 'Unable to load holidays. Generation will continue without skipping holidays.',
        buttons: [{ text: 'OK', class: 'btn-warning' }]
      });
      return new Set();
    }
  }

  function buildBatchDateTokens({ startDateToken, endDateToken, sessionCount, weekdays, exceptions, holidays }) {
    const startDate = parseLocalDateToken(startDateToken);
    const explicitEndDate = parseLocalDateToken(endDateToken);
    if (!startDate) return [];
    const hasCountLimit = Number(sessionCount) > 0;
    const maxLoopDays = hasCountLimit
      ? Math.max(Number(sessionCount) * 14, 366)
      : 3660;
    const safetyEndDate = explicitEndDate || addLocalDays(startDate, maxLoopDays);
    const generated = [];
    let cursor = new Date(startDate.getFullYear(), startDate.getMonth(), startDate.getDate());
    let guard = 0;
    while (cursor <= safetyEndDate && guard <= maxLoopDays) {
      const token = formatLocalDateToken(cursor);
      if (weekdays.includes(cursor.getDay()) && !exceptions.has(token) && !holidays.has(token)) {
        generated.push(token);
        if (hasCountLimit && generated.length >= Number(sessionCount)) break;
      }
      cursor.setDate(cursor.getDate() + 1);
      guard += 1;
    }
    return generated;
  }

  function openActivityBatchModal() {
    const previousEntry = entries[entries.length - 1] || {};
    setBatchFieldValue('activityBatchStartDate', previousEntry.date || '');
    setBatchFieldValue('activityBatchEndDate', '');
    setBatchFieldValue('activityBatchStartTime', previousEntry.startTime || '');
    setBatchFieldValue('activityBatchEndTime', previousEntry.endTime || '');
    setBatchFieldValue('activityBatchLocation', previousEntry.location || activityLocationInput.value || '');
    setBatchFieldValue('activityBatchTitlePrefix', activityTitleInput.value || 'Work Session');
    setBatchFieldValue('activityBatchStatus', 'posted');
    setBatchFieldValue('activityBatchNotes', '');
    setBatchFieldValue('activityBatchExceptions', '');
    const skipHolidays = document.getElementById('activityBatchSkipHolidays');
    if (skipHolidays) skipHolidays.checked = false;
    document.querySelectorAll('.activity-batch-day').forEach(function (checkbox) { checkbox.checked = false; });
    batchAssignees = [];
    renderBatchAssignees();
    const modal = getBatchModalInstance();
    if (modal) modal.show();
  }

  function buildWorkSessionAssigneeLocalItems() {
    const allowedSet = getActivityLevelEffectiveAllowedSet();
    return Array.from(allowedSet).map(function (personId) {
      const person = eligiblePersonMap.get(personId) || { personId, id: personId };
      const displayName = personChipLabel(personId);
      return {
        id: personId,
        personId,
        displayName,
        firstName: String(person?.firstName || '').trim(),
        lastName: String(person?.lastName || '').trim(),
        preferredName: String(person?.preferredName || '').trim(),
        roles: normalizeRoleList(person?.roles || person?.matchedRole || person?.role),
        matchedRole: normalizeRole(person?.matchedRole || person?.role || ''),
        title: displayName
      };
    }).sort(function (a, b) {
      return String(a.displayName || a.personId).localeCompare(String(b.displayName || b.personId));
    });
  }

  async function openWorkSessionAssigneePicker(options) {
    const title = options?.title || 'Select Assigned People';
    const onSelect = options?.onSelect;
    if (!window.GenericPicker || !window.GenericPickerPresets) {
      await safeShowMessage({ title: 'Picker Unavailable', icon: 'error', message: 'Assignee picker is not available on this page.' });
      return;
    }
    try {
      await ensureEligiblePersonsLoaded();
    } catch (error) {
      await safeShowMessage({ title: 'Load Failed', icon: 'error', message: error.message || 'Unable to load eligible persons.' });
      return;
    }
    const pickerConfig = {
      title,
      placeholder: 'Search students, teachers, or staff...',
      multiselect: true,
      onSelect
    };
    if (getVisibilityScopeValue() === 'individual') {
      const localItems = buildWorkSessionAssigneeLocalItems();
      if (!localItems.length) {
        await safeShowMessage({
          title: 'No Allowed Persons',
          icon: 'warning',
          message: 'Add allowed persons at the activity level before assigning people to work sessions.',
          buttons: [{ text: 'OK', class: 'btn-warning' }]
        });
        return;
      }
      pickerConfig.sourceMode = 'local';
      pickerConfig.localItems = localItems;
      pickerConfig.searchFields = 'id,personId,displayName,firstName,lastName,preferredName,title';
      pickerConfig.limit = 5000;
    } else {
      const contexts = window.GenericPickerContexts || {};
      pickerConfig.apiEndpoint = '/school/activities/api/eligible-persons';
      pickerConfig.context = (typeof contexts.activeOrganizationScope === 'function')
        ? contexts.activeOrganizationScope({ label: 'Active Organization Scope' })
        : null;
    }
    window.GenericPicker.open(window.GenericPickerPresets.person(pickerConfig));
  }

  function openBatchAssigneePicker() {
    const entryDuration = calculateDurationHours(getBatchFieldValue('activityBatchStartTime'), getBatchFieldValue('activityBatchEndTime')) || '';
    openWorkSessionAssigneePicker({
      title: 'Select People for Generated Sessions',
      onSelect: function (items) {
        const selectedRows = Array.isArray(items) ? items : [items];
        let blockedCount = 0;
        selectedRows.forEach(function (item) {
          const person = ensurePersonRecord(item);
          const personId = String(person?.personId || '').trim();
          if (!personId || !isPersonAllowedByScope(personId)) {
            blockedCount += 1;
            return;
          }
          const attendee = normalizeAttendee(item, entryDuration);
          if (!attendee) return;
          const existing = batchAssignees.find(function (row) {
            return String(row.personId) === String(attendee.personId);
          });
          if (existing) {
            existing.roles = attendee.roles;
            existing.role = pickDefaultRole(attendee.roles, existing.role || attendee.role);
            existing.personName = attendee.personName || existing.personName;
            return;
          }
          batchAssignees.push(attendee);
        });
        renderBatchAssignees();
        if (blockedCount > 0) {
          safeShowMessage({
            title: 'Scope Restriction',
            icon: 'warning',
            message: blockedCount + ' selected person(s) were skipped because of activity scope or exclusion rules.',
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
        }
      }
    });
  }

  async function generateActivityBatchEntries() {
    const countRaw = getBatchFieldValue('activityBatchCount');
    const sessionCount = countRaw ? Number(countRaw) : 0;
    const startDateToken = getBatchFieldValue('activityBatchStartDate');
    const endDateToken = getBatchFieldValue('activityBatchEndDate');
    const startTime = getBatchFieldValue('activityBatchStartTime');
    const endTime = getBatchFieldValue('activityBatchEndTime');
    const durationHours = calculateDurationHours(startTime, endTime);
    if (countRaw && (!Number.isInteger(sessionCount) || sessionCount < 1)) {
      await safeShowMessage({ title: 'Check Session Count', icon: 'warning', message: 'Number of sessions must be a whole number greater than zero.', buttons: [{ text: 'OK', class: 'btn-warning' }] });
      return;
    }
    if (!sessionCount && !endDateToken) {
      await safeShowMessage({ title: 'Add a Limit', icon: 'warning', message: 'Enter a number of sessions or an end date before generating.', buttons: [{ text: 'OK', class: 'btn-warning' }] });
      return;
    }
    if (!startDateToken || !startTime || !endTime) {
      await safeShowMessage({ title: 'Complete Batch Details', icon: 'warning', message: 'Start date, start time, and end time are required.', buttons: [{ text: 'OK', class: 'btn-warning' }] });
      return;
    }
    if (endDateToken && endDateToken < startDateToken) {
      await safeShowMessage({ title: 'Check Date Range', icon: 'warning', message: 'End date cannot be before the start date.', buttons: [{ text: 'OK', class: 'btn-warning' }] });
      return;
    }
    if (!(durationHours > 0)) {
      await safeShowMessage({ title: 'Check Time Range', icon: 'warning', message: 'End time must be after start time.', buttons: [{ text: 'OK', class: 'btn-warning' }] });
      return;
    }

    const weekdays = getSelectedBatchWeekdays(startDateToken);
    const exceptions = parseExceptionDates(getBatchFieldValue('activityBatchExceptions'));
    const lookupEndToken = endDateToken || formatLocalDateToken(addLocalDays(parseLocalDateToken(startDateToken), Math.max((sessionCount || 1) * 14, 30)));
    const holidays = await getHolidayDatesForBatch(startDateToken, lookupEndToken);
    const dateTokens = buildBatchDateTokens({ startDateToken, endDateToken, sessionCount, weekdays, exceptions, holidays });
    if (!dateTokens.length) {
      await safeShowMessage({ title: 'No Sessions Generated', icon: 'warning', message: 'No matching dates were found for the selected weekdays and limits.', buttons: [{ text: 'OK', class: 'btn-warning' }] });
      return;
    }
    if (sessionCount > 1 && dateTokens.length < sessionCount) {
      await safeShowMessage({
        title: 'End Date Too Early',
        icon: 'warning',
        message: 'Only ' + dateTokens.length + ' matching date(s) were found before the end date on the selected weekdays. Extend the end date, adjust weekdays, or reduce the session count.',
        buttons: [{ text: 'OK', class: 'btn-warning' }]
      });
      return;
    }

    const titlePrefix = getBatchFieldValue('activityBatchTitlePrefix') || activityTitleInput.value || 'Work Session';
    const location = getBatchFieldValue('activityBatchLocation') || activityLocationInput.value || '';
    const status = getBatchFieldValue('activityBatchStatus') || 'posted';
    const notes = getBatchFieldValue('activityBatchNotes');
    if (entries.length === 1 && isBlankActivityEntry(entries[0])) entries = [];
    dateTokens.forEach(function (dateToken, index) {
      const assignees = batchAssignees.map(function (assignee) {
        return {
          ...assignee,
          roles: Array.isArray(assignee.roles) ? [...assignee.roles] : normalizeRoleList(assignee.roles || assignee.role),
          paidHours: assignee.paidHours || durationHours
        };
      });
      entries.push(getDefaultEntry({
        title: titlePrefix + ' ' + (index + 1),
        date: dateToken,
        startTime,
        endTime,
        durationHours: durationHours.toFixed(2),
        location,
        notes,
        status,
        assignees
      }));
    });
    renderEntries();
    const modal = getBatchModalInstance();
    if (modal) modal.hide();
  }

  document.addEventListener('click', function (event) {
    const actionButton = event.target.closest('.js-entry-edit, .js-entry-add-person, .js-entry-duplicate, .js-entry-remove');
    if (!actionButton) return;
    const actionMenu = actionButton.closest('.row-actions-menu');
    if (!actionMenu || !String(actionMenu.dataset.rowActionsId || '').startsWith('activity-entry-')) return;
    const entryIndex = Number(actionButton.getAttribute('data-index'));
    if (!Number.isInteger(entryIndex) || !entries[entryIndex]) return;

    if (actionButton.classList.contains('js-entry-edit')) {
      openEntryModal(entryIndex);
      return;
    }

    if (actionButton.classList.contains('js-entry-add-person')) {
      openEntryModal(entryIndex);
      openPersonPicker(entryIndex);
      return;
    }

    if (actionButton.classList.contains('js-entry-duplicate')) {
      const clonedEntry = JSON.parse(JSON.stringify(entries[entryIndex] || getDefaultEntry()));
      clonedEntry.entryId = generateEntryId();
      entries.splice(entryIndex + 1, 0, clonedEntry);
      renderEntries();
      openEntryModal(entryIndex + 1);
      return;
    }

    if (actionButton.classList.contains('js-entry-remove')) {
      if (entries.length <= 1) return;
      entries.splice(entryIndex, 1);
      selectedEntryIndex = entries.length ? Math.min(entryIndex, entries.length - 1) : null;
      renderEntries();
      if (selectedEntryIndex !== null && entryModalEl?.classList.contains('show')) {
        renderEntryModal();
      }
    }
  });

  entryModalEl?.addEventListener('hidden.bs.modal', function () {
    selectedEntryIndex = null;
    renderEntryRowsOnly();
  });

  function openPersonPicker(entryIndex) {
    openWorkSessionAssigneePicker({
      title: 'Select Assigned People',
      onSelect: function (items) {
        const selectedRows = Array.isArray(items) ? items : [items];
        let blockedCount = 0;
        selectedRows.forEach(function (item) {
          const person = ensurePersonRecord(item);
          const personId = String(person?.personId || '').trim();
          if (!personId || !isPersonAllowedByScope(personId, entryIndex)) {
            blockedCount += 1;
            return;
          }
          const attendee = normalizeAttendee(item, entries[entryIndex]?.durationHours || '');
          if (!attendee) return;
          entries[entryIndex].excludedPersonIds = normalizePersonIdList(entries[entryIndex].excludedPersonIds || []).filter(function (entryPersonId) {
            return entryPersonId !== personId;
          });
          const existing = entries[entryIndex].assignees.find(function (row) {
            return String(row.personId) === String(attendee.personId);
          });
          if (existing) {
            existing.roles = attendee.roles;
            existing.role = pickDefaultRole(attendee.roles, existing.role || attendee.role);
            existing.personName = attendee.personName || existing.personName;
            return;
          }
          entries[entryIndex].assignees.push(attendee);
        });
        renderEntries();
        if (selectedEntryIndex === entryIndex && entryModalEl?.classList.contains('show')) {
          renderEntryModal();
        }
        if (blockedCount > 0) {
          safeShowMessage({
            title: 'Scope Restriction',
            icon: 'warning',
            message: blockedCount + ' selected person(s) were skipped because of activity scope or exclusion rules.',
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
        }
      }
    });
  }

  function openEntryExcludedPersonPicker(entryIndex) {
    if (!window.GenericPicker || !window.GenericPickerPresets) {
      safeShowMessage({ title: 'Picker Unavailable', icon: 'error', message: 'Requester picker is not available on this page.' });
      return;
    }
    ensureEligiblePersonsLoaded().catch(function () {
      return null;
    });
    const contexts = window.GenericPickerContexts || {};
    const context = (typeof contexts.activeOrganizationScope === 'function')
      ? contexts.activeOrganizationScope({ label: 'Active Organization Scope' })
      : null;
    window.GenericPicker.open(window.GenericPickerPresets.person({
      title: 'Exclude People for This Session',
      apiEndpoint: '/school/activities/api/eligible-persons',
      placeholder: 'Search students, teachers, or staff...',
      multiselect: true,
      context,
      onSelect: function (items) {
        const selectedRows = Array.isArray(items) ? items : [items];
        const scope = getVisibilityScopeValue();
        const allowedSet = getActivityLevelEffectiveAllowedSet();
        let skippedCount = 0;
        selectedRows.forEach(function (item) {
          const person = ensurePersonRecord(item);
          const personId = String(person?.personId || '').trim();
          const blockedByScope = scope === 'individual' && !allowedSet.has(personId);
          const blockedByActivityExclusion = activityExcludedPersonIds.includes(personId);
          if (!personId || blockedByScope || blockedByActivityExclusion) {
            skippedCount += 1;
            return;
          }
          const nextExcluded = normalizePersonIdList(entries[entryIndex].excludedPersonIds || []);
          if (!nextExcluded.includes(personId)) nextExcluded.push(personId);
          entries[entryIndex].excludedPersonIds = nextExcluded;
          entries[entryIndex].assignees = (Array.isArray(entries[entryIndex].assignees) ? entries[entryIndex].assignees : []).filter(function (assignee) {
            return String(assignee?.personId || '').trim() !== personId;
          });
        });
        syncEntries();
        renderEntries();
        if (selectedEntryIndex === entryIndex && entryModalEl?.classList.contains('show')) {
          renderEntryModal();
        }
        if (skippedCount > 0) {
          safeShowMessage({
            title: 'Subset Rule',
            icon: 'warning',
            message: skippedCount + ' selected person(s) were skipped because they are not in activity-level eligible people.',
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
        }
      }
    }));
  }

  function validateEntriesBeforeSubmit() {
    syncEntries();
    if (!entries.length) return 'Please add at least one work session.';
    const scope = getVisibilityScopeValue();
    const activityAllowedSet = getActivityLevelEffectiveAllowedSet();
    if (scope === 'individual' && !activityAllowedSet.size) {
      return 'Individual scope requires at least one allowed person.';
    }
    for (let entryIndex = 0; entryIndex < entries.length; entryIndex += 1) {
      const entry = entries[entryIndex];
      if (!entry.date) return 'Please enter a date for every work session.';
      if (!entry.startTime || !entry.endTime) return 'Please enter start and end times for every work session.';
      if (!(Number(entry.durationHours) > 0)) return 'Please enter hours greater than zero for every work session.';
      const entryExcluded = normalizePersonIdList(entry.excludedPersonIds || []);
      const nonSubsetExclusions = entryExcluded.filter(function (personId) { return !activityAllowedSet.has(personId); });
      if (nonSubsetExclusions.length) return 'Session exclusions must be selected from activity-level eligible people.';
      const blockedAssignee = (Array.isArray(entry.assignees) ? entry.assignees : []).find(function (assignee) {
        return !isPersonAllowedByScope(assignee?.personId, entryIndex);
      });
      if (blockedAssignee) {
        return 'Assigned people must match the selected scope and exclusion rules.';
      }
    }
    return '';
  }

  categorySelect?.addEventListener('change', function () {
    const selected = categorySelect.options[categorySelect.selectedIndex];
    if (selected && selected.getAttribute('data-paid') === 'true' && !paidInput.checked) paidInput.checked = true;
  });

  visibilityScopeSelect?.addEventListener('change', function () {
    if (getVisibilityScopeValue() === 'school') {
      activityAllowedPersonIds = [];
    }
    entries.forEach(function (entry, entryIndex) {
      entry.assignees = (Array.isArray(entry.assignees) ? entry.assignees : []).filter(function (assignee) {
        return isPersonAllowedByScope(assignee?.personId, entryIndex);
      });
      entry.excludedPersonIds = normalizePersonIdList(entry.excludedPersonIds || []).filter(function (personId) {
        return getActivityLevelEffectiveAllowedSet().has(personId);
      });
    });
    syncEntries();
    renderScopePersonControls();
    renderEntries();
    if (selectedEntryIndex !== null && entryModalEl?.classList.contains('show')) renderEntryModal();
  });

  activityLocationInput?.addEventListener('input', function () {
    entries.forEach(function (entry) {
      if (!entry.location) entry.location = activityLocationInput.value;
    });
    syncEntries();
  });

  document.getElementById('activityAllowedPersonsSelectBtn')?.addEventListener('click', function () {
    openScopePersonPicker('allowed');
  });
  document.getElementById('activityExcludedPersonsSelectBtn')?.addEventListener('click', function () {
    openScopePersonPicker('excluded');
  });

  document.getElementById('addActivityEntry')?.addEventListener('click', function () {
    openActivityBatchModal();
  });
  document.getElementById('activityBatchAddAssignees')?.addEventListener('click', openBatchAssigneePicker);
  document.getElementById('activityBatchClearAssignees')?.addEventListener('click', function () {
    batchAssignees = [];
    renderBatchAssignees();
  });
  document.getElementById('generateActivityEntries')?.addEventListener('click', generateActivityBatchEntries);

  form.addEventListener('submit', async function (event) {
    event.preventDefault();
    const validationMessage = validateEntriesBeforeSubmit();
    if (validationMessage) {
      await safeShowMessage({
        title: 'Complete Work Sessions',
        icon: 'warning',
        message: validationMessage,
        buttons: [{ text: 'OK', class: 'btn-warning' }]
      });
      return;
    }

    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn ? submitBtn.innerHTML : '';
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
    }

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-AJAX-Request': 'true' },
        body: new URLSearchParams(new FormData(form)).toString()
      });
      const payload = await response.json().catch(function () {
        return { status: 'error', message: response.ok ? 'Save completed, but the response could not be read.' : 'Save failed.' };
      });
      const isSuccess = response.ok && payload.status === 'success';

      await safeShowMessage({
        title: isSuccess ? 'School Activity Saved' : 'School Activity Not Saved',
        icon: isSuccess ? 'success' : 'error',
        message: payload.message || (isSuccess ? 'School activity saved successfully.' : 'Please review the form and try again.'),
        buttons: [{ text: 'OK', class: isSuccess ? 'btn-success' : 'btn-danger' }]
      });

      if (isSuccess) {
        window.location.href = '/school/activities';
        return;
      }
    } catch (error) {
      await safeShowMessage({
        title: 'System Error',
        icon: 'error',
        message: error.message || 'Unexpected error while saving the school activity.',
        buttons: [{ text: 'Close', class: 'btn-secondary' }]
      });
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
      }
    }
  });

  entries = entries.length
    ? entries.map(normalizeEntry)
    : [getDefaultEntry({ assignees: initialAttendees })];
  entries.forEach(function (entry) {
    (Array.isArray(entry?.assignees) ? entry.assignees : []).forEach(function (assignee) {
      ensurePersonRecord(assignee);
    });
  });
  syncActivityScopePersonControlInputs();
  renderScopePersonControls();
  renderEntries();
});
</script>
