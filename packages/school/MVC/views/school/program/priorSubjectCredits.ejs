<%
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
  const priorHeaderManageBtns = [
    `<a href="${typeof schoolSectionDashboardHref !== 'undefined' ? String(schoolSectionDashboardHref || '').trim() : '#'}" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>`
  ];
  const priorManageBtns = [
    '<a href="/school/programs/registrations" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-card-list me-1"></i> Program registrations</a>',
    '<a href="/school/programs" class="btn btn-filled btn-primary btn-md mb-2"><i class="bi bi-journal-bookmark me-1"></i> Programs</a>'
  ];
  const priorOptionalBtnsBeforePrint = [
    '<button type="button" id="btn_openAddPriorModal" class="btn btn-filled btn-add btn-md me-2 mb-2"><i class="bi bi-plus-circle me-1"></i> Add credit</button>'
  ];
%>

<%- include('../../partials/tablePages-start', {
  title: 'Prior Subject Credits',
  newUrl: 'school/programs/prior-subject-credits',
  newLabel: null,
  user,
  tableName: typeof tableName !== 'undefined' ? tableName : 'Prior_Subject_Credits',
  btn_export: typeof btn_export !== 'undefined' ? btn_export : true,
  print: typeof print !== 'undefined' ? print : true,
  headerManageBtns: priorHeaderManageBtns,
  manageBtns: priorManageBtns,
  optionalBtnsBeforePrint: priorOptionalBtnsBeforePrint
}) %>

<%- include('../../partials/tablePages-search', {
  placeholder: 'Search credits (student, program, subject, id)…',
  fields: [
    { name: 'status', label: 'Status', type: 'select', options: ['', 'active', 'revoked'] }
  ]
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Student</th>
        <th>Program</th>
        <th>Subject</th>
        <th>Source</th>
        <th class="text-center">Status</th>
        <th>Evidence</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || data.length === 0) { %>
        <tr><td colspan="7" class="text-center py-4 text-muted">No prior subject credits found.</td></tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <tr data-record-id="<%= item.id %>">
          <td class="ps-4">
            <div class="fw-bold text-dark"><%= item.studentLabel || item.studentId %></div>
            <div class="x-small text-muted font-monospace"><%= item.studentId %></div>
          </td>
          <td>
            <div class="fw-semibold small"><%= item.programLabel || item.programId %></div>
            <div class="x-small text-muted font-monospace"><%= item.programId %></div>
          </td>
          <td>
            <div class="fw-semibold small"><%= item.subjectLabel || item.subjectId %></div>
            <div class="x-small text-muted font-monospace"><%= item.subjectId %></div>
          </td>
          <td><span class="badge bg-light text-dark border"><%= String(item.source || '').replace(/_/g, ' ') %></span></td>
          <td class="text-center">
            <% const st = String(item.status || '').toLowerCase(); %>
            <% const stBadge = st === 'active' ? 'bg-success' : 'bg-secondary'; %>
            <span class="badge <%= stBadge %>"><%= (item.status || '-').toUpperCase() %></span>
          </td>
          <td class="small text-muted" style="max-width: 14rem;">
            <div class="text-truncate" title="<%= (item.evidenceNote || '').replace(/"/g, '&quot;') %>"><%= item.evidenceNote || '—' %></div>
          </td>
          <td class="table-actions text-end pe-4">
            <% if (st === 'active') { %>
              <button type="button" class="btn btn-sm btn-outline-warning me-1 btn-prior-revoke" data-id="<%= item.id %>">Revoke</button>
            <% } %>
            <button type="button" class="btn btn-sm btn-filled btn-delete delete-btn" data-id="<%= item.id %>">Delete</button>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/programs/prior-subject-credits" hidden></span>
<input type="hidden" id="hid_actionStateId" value="<%= asid %>">

<%- include('../../partials/pagination', {
  pagination,
  filters,
  baseUrlPath: 'school/programs/prior-subject-credits'
}) %>

<%- include('../../partials/tablePages-end') %>

<div class="modal fade" id="addPriorCreditModal" tabindex="-1" aria-labelledby="addPriorCreditModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="addPriorCreditModalLabel"><i class="bi bi-mortarboard me-1"></i>Add prior subject credits</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="prior_inp_studentId">
        <div class="mb-3">
          <label class="form-label fw-bold">Student *</label>
          <div class="input-group">
            <input type="text" id="prior_inp_studentLabel" class="form-control bg-white" placeholder="Select student…" readonly>
            <button type="button" class="btn btn-outline-primary" id="prior_btn_pickStudent" title="Pick student"><i class="bi bi-person-vcard"></i></button>
          </div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold" for="prior_sel_program">Program *</label>
          <select id="prior_sel_program" class="form-select" disabled>
            <option value="">— Select a student first —</option>
          </select>
          <div class="form-text small text-muted" id="prior_program_hint">Programs listed here are those the student is <b>registered</b> in (approved program registration).</div>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold d-block">Subjects *</label>
          <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <button type="button" class="btn btn-outline-primary btn-sm" id="prior_btn_pickSubjects" title="Pick subjects">
              <i class="bi bi-journal-bookmark me-1"></i>Add subjects…
            </button>
            <span class="form-text small text-muted mb-0">Multiselect picker (same pattern as program definition).</span>
          </div>
          <ul class="list-group list-group-flush border rounded small" id="prior_subject_list" style="max-height: 12rem; overflow-y: auto;">
            <li class="list-group-item text-muted py-2">No subjects added yet.</li>
          </ul>
        </div>
        <div class="mb-3">
          <label class="form-label fw-bold" for="prior_sel_source">Source</label>
          <select id="prior_sel_source" class="form-select">
            <% (priorSources || []).forEach(function (src) { %>
              <option value="<%= src %>"><%= String(src).replace(/_/g, ' ') %></option>
            <% }); %>
          </select>
        </div>
        <div class="mb-0">
          <label class="form-label fw-bold" for="prior_txt_evidence">Evidence / notes</label>
          <textarea id="prior_txt_evidence" class="form-control" rows="3" placeholder="Transcript reference, placement exam, waiver…"></textarea>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-filled btn-primary btn-sm" id="prior_btn_save">
          <i class="bi bi-check2-circle me-1"></i>Save credits
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/modal_GenericPicker') %>

<script>
(function () {
  const actionStateId = <%- JSON.stringify(String(asid || '')) %>;

  /** @type {{ id: string, label: string }[]} */
  let priorSelectedSubjects = [];

  const qs = (id) => document.getElementById(id);
  const addModalEl = qs('addPriorCreditModal');
  const bootstrapApi = window.bootstrap || (typeof bootstrap !== 'undefined' ? bootstrap : null);
  let addModal = null;
  if (addModalEl && bootstrapApi && typeof bootstrapApi.Modal === 'function') {
    addModal = bootstrapApi.Modal.getOrCreateInstance
      ? bootstrapApi.Modal.getOrCreateInstance(addModalEl)
      : new bootstrapApi.Modal(addModalEl);
  }

  function escHtml(s) {
    return String(s == null ? '' : s)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/"/g, '&quot;');
  }

  function subjectRowFromPickerItem(item) {
    const id = String(item && item.id != null ? item.id : '').trim();
    if (!id) return null;
    const code = String(item.code || '').trim();
    const name = String(item.name || item.title || '').trim();
    const label = [code, name].filter(Boolean).join(' — ') || id;
    return { id: id, label: label };
  }

  function renderPriorSubjectList() {
    const ul = qs('prior_subject_list');
    if (!ul) return;
    if (!priorSelectedSubjects.length) {
      ul.innerHTML = '<li class="list-group-item text-muted py-2">No subjects added yet. Use <strong>Add subjects</strong> to pick courses.</li>';
      return;
    }
    ul.innerHTML = priorSelectedSubjects.map(function (row) {
      const slab = escHtml(row.label);
      const sidVis = escHtml(row.id);
      const sidAttr = encodeURIComponent(row.id);
      return '<li class="list-group-item d-flex justify-content-between align-items-center gap-2 py-2">'
        + '<div class="min-w-0"><div class="fw-semibold text-truncate" title="' + slab + '">' + slab + '</div>'
        + '<div class="x-small text-muted font-monospace text-truncate">' + sidVis + '</div></div>'
        + '<button type="button" class="btn btn-sm btn-outline-danger flex-shrink-0 prior_btn_remove_subject" data-subject-id="' + sidAttr + '" title="Remove">&times;</button>'
        + '</li>';
    }).join('');
  }

  function modalMessageHtml(text) {
    return String(text == null ? '' : text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/\n/g, '<br>');
  }

  async function showMsg(title, icon, message) {
    if (typeof window.showMessageModal !== 'function') {
      console.error('showMessageModal is not available.');
      return;
    }
    await window.showMessageModal({
      title: title,
      icon: icon || 'info',
      message: modalMessageHtml(message),
      buttons: [{ text: 'OK', class: 'btn-primary' }]
    });
  }

  function apiHeaders(isMutating) {
    const h = { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' };
    if (isMutating && actionStateId) h['X-Action-State-Id'] = actionStateId;
    return h;
  }

  function selectedSubjectIds() {
    return priorSelectedSubjects.map(function (r) { return r.id; }).filter(Boolean);
  }

  function resetProgramSelect(placeholderText, disabled) {
    const sel = qs('prior_sel_program');
    if (!sel) return;
    sel.innerHTML = '<option value="">' + String(placeholderText || '— Select program —').replace(/</g, '&lt;') + '</option>';
    sel.value = '';
    sel.disabled = !!disabled;
  }

  async function loadProgramsForStudent(studentId) {
    const sel = qs('prior_sel_program');
    if (!sel) return;
    sel.disabled = true;
    sel.innerHTML = '<option value="">Loading programs…</option>';
    try {
      let url = '/school/programs/prior-subject-credits/api/student-programs?studentId=' + encodeURIComponent(studentId);
      if (actionStateId) url += '&actionStateId=' + encodeURIComponent(actionStateId);
      const res = await fetch(url, { headers: { 'X-AJAX-Request': 'true' } });
      const data = await res.json();
      if (data.status === 'error') throw new Error(data.message || 'Failed to load programs.');
      const programs = Array.isArray(data.programs) ? data.programs : [];
      if (!programs.length) {
        sel.innerHTML = '<option value="">No approved program registrations</option>';
        sel.disabled = true;
        return;
      }
      const opts = ['<option value="">— Select program —</option>'].concat(programs.map(function (p) {
        const id = String(p.id || '').replace(/"/g, '&quot;');
        const lab = String(p.label || p.id || '').replace(/</g, '&lt;').replace(/"/g, '&quot;');
        return '<option value="' + id + '">' + lab + '</option>';
      }));
      sel.innerHTML = opts.join('');
      sel.disabled = false;
    } catch (e) {
      sel.innerHTML = '<option value="">Could not load programs</option>';
      sel.disabled = true;
      showMsg('Programs', 'error', e.message || 'Failed to load programs.');
    }
  }

  function clearAddForm() {
    if (qs('prior_inp_studentId')) qs('prior_inp_studentId').value = '';
    if (qs('prior_inp_studentLabel')) qs('prior_inp_studentLabel').value = '';
    resetProgramSelect('— Select a student first —', true);
    priorSelectedSubjects = [];
    renderPriorSubjectList();
    if (qs('prior_sel_source')) qs('prior_sel_source').selectedIndex = 0;
    if (qs('prior_txt_evidence')) qs('prior_txt_evidence').value = '';
  }

  function openAddModal() {
    clearAddForm();
    if (addModal) addModal.show();
    else if (addModalEl) { addModalEl.classList.add('show'); addModalEl.style.display = 'block'; }
  }

  qs('btn_openAddPriorModal')?.addEventListener('click', openAddModal);

  function pickStudent() {
    if (!window.GenericPicker || !window.GenericPickerPresets) {
      showMsg('Picker unavailable', 'warning', 'Student picker is not loaded on this page.');
      return;
    }
    window.GenericPicker.open(window.GenericPickerPresets.student({
      title: 'Select Student',
      multiselect: false,
      searchFields: 'id,firstName,lastName,name.first,name.last,studentNumber,personId',
      context: (window.GenericPickerContexts && typeof window.GenericPickerContexts.activeOrganizationScope === 'function')
        ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
        : undefined,
      onSelect: function (selected) {
        const item = Array.isArray(selected) ? selected[0] : selected;
        if (!item) return;
        const id = String(item.id || '').trim();
        const firstName = String(item.firstName || (item.name && item.name.first) || '').trim();
        const lastName = String(item.lastName || (item.name && item.name.last) || '').trim();
        const personName = [firstName, lastName].filter(Boolean).join(' ').trim();
        const studentNum = String(item.studentNumber || '').trim();
        qs('prior_inp_studentId').value = id;
        qs('prior_inp_studentLabel').value = studentNum ? (personName + ' (' + studentNum + ')') : (personName || id);
        loadProgramsForStudent(id);
      }
    }));
  }
  qs('prior_btn_pickStudent')?.addEventListener('click', pickStudent);

  qs('prior_subject_list')?.addEventListener('click', function (ev) {
    const btn = ev.target && ev.target.closest && ev.target.closest('.prior_btn_remove_subject');
    if (!btn) return;
    const enc = btn.getAttribute('data-subject-id');
    if (enc == null || enc === '') return;
    let id;
    try {
      id = decodeURIComponent(enc);
    } catch (e) {
      id = enc;
    }
    priorSelectedSubjects = priorSelectedSubjects.filter(function (r) { return r.id !== id; });
    renderPriorSubjectList();
  });

  function pickPriorSubjects() {
    if (!window.GenericPicker || !window.GenericPickerPresets) {
      showMsg('Picker unavailable', 'warning', 'Subject picker is not loaded on this page.');
      return;
    }
    window.GenericPicker.open(window.GenericPickerPresets.subject({
      title: 'Select Subject',
      icon: 'bi-journal-bookmark',
      multiselect: true,
      placeholder: 'Search subjects, select multiple, then Add Selected…',
      context: (window.GenericPickerContexts && typeof window.GenericPickerContexts.activeOrganizationScope === 'function')
        ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
        : undefined,
      onSelect: function (items) {
        const rows = Array.isArray(items) ? items : [items];
        rows.forEach(function (item) {
          const row = subjectRowFromPickerItem(item);
          if (!row) return;
          if (priorSelectedSubjects.some(function (s) { return s.id === row.id; })) return;
          priorSelectedSubjects.push(row);
        });
        renderPriorSubjectList();
      }
    }));
  }
  qs('prior_btn_pickSubjects')?.addEventListener('click', pickPriorSubjects);

  qs('prior_btn_save')?.addEventListener('click', async function () {
    const studentId = String(qs('prior_inp_studentId')?.value || '').trim();
    const programId = String(qs('prior_sel_program')?.value || '').trim();
    const subjectIds = selectedSubjectIds();
    if (!studentId || !programId) {
      await showMsg('Missing fields', 'warning', 'Select a student and program.');
      return;
    }
    if (!subjectIds.length) {
      await showMsg('Missing subjects', 'warning', 'Add one or more subjects using Add subjects…');
      return;
    }
    const body = {
      studentId: studentId,
      programId: programId,
      subjectIds: subjectIds,
      source: String(qs('prior_sel_source')?.value || 'manual_waiver'),
      evidenceNote: String(qs('prior_txt_evidence')?.value || '')
    };
    if (actionStateId) body.actionStateId = actionStateId;
    const btn = qs('prior_btn_save');
    const prev = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving…';
    try {
      const res = await fetch('/school/programs/prior-subject-credits/api/batch', {
        method: 'POST',
        headers: apiHeaders(true),
        body: JSON.stringify(body)
      });
      const data = await res.json();
      const guarded = typeof window.applyGuardedApiResult === 'function'
        ? await window.applyGuardedApiResult(data, { busyTitle: 'Save in progress', replayTitle: 'Already saved' })
        : { stop: false };
      if (guarded.stop) return;
      if (data.status === 'error') throw new Error(data.message || 'Save failed.');
      const skipN = Number(data.skippedDuplicateCount || 0) || 0;
      let msg = 'Saved ' + (data.createdCount || 0) + ' credit(s).';
      if (skipN > 0) {
        msg += ' Skipped ' + skipN + ' subject(s) that already have an active prior credit for this program.';
      }
      if (Array.isArray(data.errors) && data.errors.length) {
        msg += '\n\n' + data.errors.map(function (e) { return (e.subjectId || '') + ': ' + (e.message || ''); }).join('\n');
      }
      const hasErr = Array.isArray(data.errors) && data.errors.length;
      const createdN = Number(data.createdCount || 0) || 0;
      const warn = hasErr || (createdN === 0 && skipN > 0);
      await showMsg('Result', warn ? 'warning' : 'success', msg);
      if (addModal) addModal.hide();
      window.location.reload();
    } catch (e) {
      await showMsg('Error', 'error', e.message || 'Save failed.');
    } finally {
      btn.disabled = false;
      btn.innerHTML = prev;
    }
  });

  async function postRecordAction(url, recordId) {
    const body = { recordId: recordId };
    if (actionStateId) body.actionStateId = actionStateId;
    const res = await fetch(url, {
      method: 'POST',
      headers: apiHeaders(true),
      body: JSON.stringify(body)
    });
    const data = await res.json();
    const guarded = typeof window.applyGuardedApiResult === 'function'
      ? await window.applyGuardedApiResult(data, { busyTitle: 'Working…', replayTitle: 'Already processed' })
      : { stop: false };
    if (guarded.stop) return null;
    if (data.status === 'error') throw new Error(data.message || 'Request failed.');
    return data;
  }

  document.getElementById('first-table')?.addEventListener('click', async function (ev) {
    const t = ev.target;
    if (!t || !t.classList) return;
    if (!t.classList.contains('btn-prior-revoke')) return;
    const id = String(t.getAttribute('data-id') || '').trim();
    if (!id) return;
    try {
      if (typeof window.showMessageModal !== 'function') {
        console.error('showMessageModal is not available.');
        return;
      }
      const choice = await window.showMessageModal({
        title: 'Confirm revoke',
        icon: 'warning',
        message: 'Revoke this credit? It will no longer satisfy prerequisites.',
        size: 'md',
        buttons: [
          { text: 'Cancel', class: 'btn-secondary btn-md' },
          { text: 'Revoke', class: 'btn-warning btn-md' }
        ]
      });
      if (choice !== 'Revoke') return;
      await postRecordAction('/school/programs/prior-subject-credits/api/revoke', id);
      window.location.reload();
    } catch (err) {
      await showMsg('Error', 'error', err.message || 'Request failed.');
    }
  });
})();
</script>
