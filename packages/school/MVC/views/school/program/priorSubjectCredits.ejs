<%
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
  const priorHeaderManageBtns = [
    `<a href="${typeof schoolSectionDashboardHref !== 'undefined' ? String(schoolSectionDashboardHref || '').trim() : '#'}" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>`,
    '<a href="/dashboard/section-nav/SCHOOL_ACADEMIA" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-backpack2 me-1"></i> School Academia</a>'
  ];
  const priorManageBtns = [
    '<a href="/school/programs/registrations" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-card-list me-1"></i> Program registrations</a>',
    '<a href="/school/programs" class="btn btn-filled btn-primary btn-md mb-2"><i class="bi bi-journal-bookmark me-1"></i> Programs</a>'
  ];
%>

<%- include('partials/tablePages-start', {
  title: 'Prior Subject Credits',
  newUrl: 'school/programs/prior-subject-credits',
  newHref: '/school/programs/prior-subject-credits/new',
  newLabel: 'Add Credit',
  user,
  tableName: typeof tableName !== 'undefined' ? tableName : 'Prior_Subject_Credits',
  btn_export: typeof btn_export !== 'undefined' ? btn_export : true,
  print: typeof print !== 'undefined' ? print : true,
  headerManageBtns: priorHeaderManageBtns,
  manageBtns: priorManageBtns
}) %>

<% if (typeof filters !== 'undefined' && (filters.created || filters.skipped || filters.warnings)) { %>
  <div class="alert alert-success py-2 mb-3">
    Saved <strong><%= Number(filters.created || 0) || 0 %></strong> credit(s).
    <% if (Number(filters.skipped || 0) > 0) { %>
      <span class="ms-2">Skipped <strong><%= Number(filters.skipped || 0) %></strong> duplicate subject(s).</span>
    <% } %>
    <% if (Number(filters.warnings || 0) > 0) { %>
      <span class="ms-2 text-warning">Completed with <strong><%= Number(filters.warnings || 0) %></strong> warning(s).</span>
    <% } %>
  </div>
<% } %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search credits (student, program, subject, id)...',
  fields: [
    { name: 'status', label: 'Status', type: 'select', options: ['', 'active', 'revoked'] }
  ]
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Student</th>
        <th>Program</th>
        <th>Subject</th>
        <th>Source</th>
        <th class="text-center">Status</th>
        <th>Evidence</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || data.length === 0) { %>
        <tr><td colspan="7" class="text-center py-4 text-muted">No prior subject credits found.</td></tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <tr data-record-id="<%= item.id %>">
          <td class="ps-4">
            <div class="fw-bold text-dark"><%= item.studentLabel || item.studentId %></div>
            <div class="x-small text-muted font-monospace"><%= item.studentId %></div>
          </td>
          <td>
            <div class="fw-semibold small"><%= item.programLabel || item.programId %></div>
            <div class="x-small text-muted font-monospace"><%= item.programId %></div>
          </td>
          <td>
            <div class="fw-semibold small"><%= item.subjectLabel || item.subjectId %></div>
            <div class="x-small text-muted font-monospace"><%= item.subjectId %></div>
          </td>
          <td><span class="badge bg-light text-dark border"><%= String(item.source || '').replace(/_/g, ' ') %></span></td>
          <td class="text-center">
            <% const st = String(item.status || '').toLowerCase(); %>
            <% const stBadge = st === 'active' ? 'bg-success' : 'bg-secondary'; %>
            <span class="badge <%= stBadge %>"><%= (item.status || '-').toUpperCase() %></span>
          </td>
          <td class="small text-muted" style="max-width: 14rem;">
            <div class="text-truncate" title="<%= (item.evidenceNote || '').replace(/"/g, '&quot;') %>"><%= item.evidenceNote || '-' %></div>
          </td>
          <td class="table-actions text-end pe-4">
            <% if (st === 'active') { %>
              <button type="button" class="btn btn-sm btn-outline-warning me-1 btn-prior-revoke" data-id="<%= item.id %>">Revoke</button>
            <% } %>
            <button type="button" class="btn btn-sm btn-filled btn-delete delete-btn" data-id="<%= item.id %>">Delete</button>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/programs/prior-subject-credits" hidden></span>
<input type="hidden" id="hid_actionStateId" value="<%= asid %>">

<%- include('partials/pagination', {
  pagination,
  filters,
  baseUrlPath: 'school/programs/prior-subject-credits'
}) %>

<%- include('partials/tablePages-end') %>

<script>
(function () {
  const actionStateId = <%- JSON.stringify(String(asid || '')) %>;

  function modalMessageHtml(text) {
    return String(text == null ? '' : text)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/\n/g, '<br>');
  }

  async function showMsg(title, icon, message) {
    if (typeof window.showMessageModal !== 'function') {
      console.error('showMessageModal is not available.');
      return;
    }
    await window.showMessageModal({
      title: title,
      icon: icon || 'info',
      message: modalMessageHtml(message),
      buttons: [{ text: 'OK', class: 'btn-primary' }]
    });
  }

  function apiHeaders(isMutating) {
    const h = { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' };
    if (isMutating && actionStateId) h['X-Action-State-Id'] = actionStateId;
    return h;
  }

  async function postRecordAction(url, recordId) {
    const body = { recordId: recordId };
    if (actionStateId) body.actionStateId = actionStateId;
    const res = await fetch(url, {
      method: 'POST',
      headers: apiHeaders(true),
      body: JSON.stringify(body)
    });
    const data = await res.json();
    const guarded = typeof window.applyGuardedApiResult === 'function'
      ? await window.applyGuardedApiResult(data, { busyTitle: 'Working...', replayTitle: 'Already processed' })
      : { stop: false };
    if (guarded.stop) return null;
    if (data.status === 'error') throw new Error(data.message || 'Request failed.');
    return data;
  }

  document.getElementById('first-table')?.addEventListener('click', async function (ev) {
    const t = ev.target;
    if (!t || !t.classList) return;
    if (!t.classList.contains('btn-prior-revoke')) return;
    const id = String(t.getAttribute('data-id') || '').trim();
    if (!id) return;
    try {
      if (typeof window.showMessageModal !== 'function') {
        console.error('showMessageModal is not available.');
        return;
      }
      const choice = await window.showMessageModal({
        title: 'Confirm revoke',
        icon: 'warning',
        message: 'Revoke this credit? It will no longer satisfy prerequisites.',
        size: 'md',
        buttons: [
          { text: 'Cancel', class: 'btn-secondary btn-md' },
          { text: 'Revoke', class: 'btn-warning btn-md' }
        ]
      });
      if (choice !== 'Revoke') return;
      await postRecordAction('/school/programs/prior-subject-credits/api/revoke', id);
      window.location.reload();
    } catch (err) {
      await showMsg('Error', 'error', err.message || 'Request failed.');
    }
  });
})();
</script>
