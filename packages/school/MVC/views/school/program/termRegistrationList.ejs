<%- include('../../partials/tablePages-start', {
  title, newUrl, newLabel, newHref: '/school/programs/register-terms', user, tableName, btn_export: true, print,
  manageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>',
    `<a href="/school/programs/register-terms-wizard" class="btn btn-filled btn-primary btn-md mb-2"><i class="bi bi-signpost-split me-1"></i> Wizard</a>`,
    `<a href="/school/programs/register-terms-batch-wizard" class="btn btn-filled btn-primary btn-md mb-2"><i class="bi bi-diagram-3 me-1"></i> Batch Wizard</a>`,
  ]
}) %>

<%- include('../../partials/tablePages-search', {
  placeholder: 'Search term registrations...',
  fields: [
    { name: 'status', label: 'Record Status', type: 'select', options: ['draft', 'registered', 'rolled_back', 'error', 'withdrawn', 'cancelled', 'completed'] },
    { name: 'verificationStatus', label: 'Verification', type: 'select', options: ['verified', 'partial', 'rolled_back', 'failed', 'pending'] }
  ]
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
      <div class="fw-bold text-primary mb-1">Need to register many students into a term?</div>
      <div class="small text-muted">Use the Batch Wizard to set effective date, choose program/term, validate eligible students/classes, then save draft registrations in one flow.</div>
    </div>
    <div class="d-flex gap-2">
      <a href="/school/programs/register-terms-batch-wizard" class="btn btn-primary btn-sm">
        <i class="bi bi-diagram-3 me-1"></i> Open Batch Wizard
      </a>
      <a href="/school/programs/register-terms-wizard" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-signpost-split me-1"></i> Single Wizard
      </a>
    </div>
  </div>
</div>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Registration</th>
        <th>Student</th>
        <th>Program / Term</th>
        <th>Credits / Classes</th>
        <th>Finance</th>
        <th>Academic</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length === 0) { %>
        <tr><td colspan="7" class="text-center py-4 text-muted">No term registrations found.</td></tr>
      <% } %>
      <% data.forEach(item => { %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-primary"><a href="/school/programs/term-registrations/<%= encodeURIComponent(item.id) %>"><%= item.id %></a></div>
            <div class="small text-muted"><%= item.registrationDate || '-' %></div>
            <div class="x-small text-muted">Record: <%= String(item.status || '').toLowerCase() === 'rolled_back' ? 'Moved back to draft' : item.status %></div>
          </td>
          <td>
            <div class="fw-bold"><%= item.studentName || item.studentId %></div>
            <div class="small text-muted font-monospace"><%= item.studentId || '-' %></div>
            <div class="x-small text-muted"><%= item.feeCategorySnapshot || '-' %></div>
          </td>
          <td>
            <div class="fw-bold"><%= item.programLabel || item.programId %></div>
            <div class="small text-muted"><%= item.termLabel || item.termId %></div>
            <div class="x-small text-muted"><span class="badge <%= item.statusBadgeClass %>"><%= String(item.verificationStatus || '').toLowerCase() === 'rolled_back' ? 'Moved back to draft' : item.verificationStatus %></span></div>
          </td>
          <td class="small">
            <div>Credits: <span class="fw-bold"><%= Number(item.selectedCredits || 0).toFixed(2) %></span></div>
            <div>Classes: <span class="fw-bold"><%= item.classCount || 0 %></span></div>
          </td>
          <td class="small">
            <div>Posted: <span class="fw-bold"><%= item.finance.posted %></span> / <%= item.finance.expected %></div>
            <div>Amount: <span class="fw-bold"><%= Number(item.finance.totalAmount || 0).toFixed(2) %></span></div>
          </td>
          <td class="small">
            <div>Posted: <span class="fw-bold"><%= item.academic.posted %></span> / <%= item.academic.expected %></div>
            <div>Voided: <span class="fw-bold"><%= item.academic.voided %></span></div>
          </td>
          <td class="table-actions text-end pe-4">
            <a href="/school/programs/term-registrations/<%= encodeURIComponent(item.id) %>" class="btn btn-sm btn-outline-secondary"><%= String(item.status || '').toLowerCase() === 'draft' ? 'Review Draft' : 'Details' %></a>
            <% if (canManageRegistrations && item.canApprove) { %>
              <button type="button" class="btn btn-sm btn-outline-success approve-btn" data-id="<%= item.id %>" data-name="<%= item.studentName || item.studentId %>">
                Approve & Post
              </button>
            <% } %>
            <% if (canManageRegistrations && item.canRollback) { %>
              <button type="button" class="btn btn-sm btn-filled btn-delete rollback-btn" data-id="<%= item.id %>" data-name="<%= item.studentName || item.studentId %>" data-status="<%= String(item.status || '').toLowerCase() %>"><%= String(item.status || '').toLowerCase() === 'draft' ? 'Cancel Draft' : 'Move Back to Draft' %></button>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/programs/term-registrations" hidden></span>
<%- include('../../partials/pagination', { pagination, filters, baseUrlPath: 'school/programs/term-registrations' }) %>
<%- include('../../partials/tablePages-end') %>

<script>
(function () {
  function showMsg(opts) {
    if (typeof showMessageModal === 'function') return showMessageModal(opts);
    alert(opts?.message || 'Done');
    return Promise.resolve();
  }

  const approveButtons = Array.from(document.querySelectorAll('.approve-btn'));
  const rollbackButtons = Array.from(document.querySelectorAll('.rollback-btn'));
  const actionButtons = approveButtons.concat(rollbackButtons);
  let actionInProgress = false;

  function setActionLock(isLocked, activeButton, loadingLabel) {
    actionButtons.forEach(function (button) {
      if (!button) return;
      if (!button.dataset.originalHtml) button.dataset.originalHtml = button.innerHTML;
      button.disabled = isLocked;
    });

    if (activeButton) {
      if (!activeButton.dataset.originalHtml) activeButton.dataset.originalHtml = activeButton.innerHTML;
      if (isLocked) {
        activeButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + String(loadingLabel || 'Processing...');
      } else if (activeButton.dataset.originalHtml) {
        activeButton.innerHTML = activeButton.dataset.originalHtml;
      }
    }

    if (typeof showLoading === 'function') {
      if (isLocked) showLoading();
      else if (typeof hideLoading === 'function') hideLoading();
    }
  }

  document.querySelectorAll('.rollback-btn').forEach(function (btn) {
    btn.addEventListener('click', async function () {
      if (actionInProgress) return;
      const id = String(btn.getAttribute('data-id') || '').trim();
      const name = String(btn.getAttribute('data-name') || id).trim();
      const status = String(btn.getAttribute('data-status') || '').toLowerCase();
      const isDraft = status === 'draft';
      if (!id) return;
      const confirmed = typeof window.showMessageModal === 'function'
        ? (await window.showMessageModal({
            title: isDraft ? 'Cancel Draft Term Registration?' : 'Move Term Registration Back to Draft?',
            icon: 'warning',
            message: (isDraft ? 'Cancel draft registration for <b>' : 'Move registration for <b>') + String(name || '').replace(/[&<>"']/g, function (m) { return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[m]; }) + (isDraft ? '</b>?' : '</b> back to draft?'),
            buttons: [
              { text: 'Cancel', class: 'btn-secondary' },
              { text: isDraft ? 'Cancel Draft' : 'Move Back to Draft', class: 'btn-danger' }
            ]
          })) === (isDraft ? 'Cancel Draft' : 'Move Back to Draft')
        : window.confirm((isDraft ? 'Cancel draft registration for ' : 'Move registration for ') + name + (isDraft ? '?' : ' back to draft?'));
      if (!confirmed) return;

      const body = new URLSearchParams({ note: isDraft ? 'Draft cancelled from Term Registrations list' : 'Manual rollback from Term Registrations list' });

      try {
        actionInProgress = true;
        setActionLock(true, btn, isDraft ? 'Cancelling...' : 'Moving back...');
        const response = await fetch('/school/programs/register-terms/rollback/' + encodeURIComponent(id), {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-AJAX-Request': 'true'
          },
          body: body.toString()
        });
        const result = await response.json();
        const guarded = typeof window.applyGuardedApiResult === 'function'
          ? await window.applyGuardedApiResult(result, { busyTitle: 'Move Back to Draft In Progress', replayTitle: 'Move Back to Draft Already Processed' })
          : { stop: false };
        if (guarded.stop) return;
        if (result.status === 'error') throw new Error(result.message || 'Move back to draft failed.');
        actionInProgress = false;
        setActionLock(false, btn);
        await showMsg({
          title: 'Move Back to Draft Result',
          icon: result.status === 'warning' ? 'warning' : 'success',
          message: result.message || 'Moved back to draft.',
          buttons: [{ text: 'OK', class: result.status === 'warning' ? 'btn-warning' : 'btn-success' }]
        });
        window.location.reload();
      } catch (error) {
        actionInProgress = false;
        setActionLock(false, btn);
        await showMsg({
          title: 'Move Back to Draft Error',
          icon: 'error',
          message: error.message || 'Move back to draft failed.',
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
      }
    });
  });

  document.querySelectorAll('.approve-btn').forEach(function (btn) {
    btn.addEventListener('click', async function () {
      if (actionInProgress) return;
      const id = String(btn.getAttribute('data-id') || '').trim();
      const name = String(btn.getAttribute('data-name') || id).trim();
      if (!id) return;

      const confirmed = typeof window.showMessageModal === 'function'
        ? (await window.showMessageModal({
            title: 'Approve Draft?',
            icon: 'warning',
            message: 'Approve and post draft term registration for <b>' + String(name || '').replace(/[&<>"']/g, function (m) { return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[m]; }) + '</b>?',
            buttons: [
              { text: 'Cancel', class: 'btn-secondary' },
              { text: 'Approve & Post', class: 'btn-success' }
            ]
          })) === 'Approve & Post'
        : window.confirm('Approve and post draft term registration for ' + name + '?');
      if (!confirmed) return;

      const body = new URLSearchParams({ note: 'Approved from Term Registrations list' });

      try {
        actionInProgress = true;
        setActionLock(true, btn, 'Posting...');
        const response = await fetch('/school/programs/register-terms/approve/' + encodeURIComponent(id), {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-AJAX-Request': 'true'
          },
          body: body.toString()
        });
        const result = await response.json();
        const guarded = typeof window.applyGuardedApiResult === 'function'
          ? await window.applyGuardedApiResult(result, { busyTitle: 'Approval In Progress', replayTitle: 'Approval Already Processed' })
          : { stop: false };
        if (guarded.stop) return;
        if (result.status === 'error') throw new Error(result.message || 'Approval failed.');
        actionInProgress = false;
        setActionLock(false, btn);
        await showMsg({
          title: 'Approval Result',
          icon: result.status === 'warning' ? 'warning' : 'success',
          message: result.message || 'Draft approved.',
          buttons: [{ text: 'OK', class: result.status === 'warning' ? 'btn-warning' : 'btn-success' }]
        });
        window.location.reload();
      } catch (error) {
        actionInProgress = false;
        setActionLock(false, btn);
        await showMsg({
          title: 'Approval Error',
          icon: 'error',
          message: error.message || 'Approval failed.',
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
      }
    });
  });
})();
</script>
