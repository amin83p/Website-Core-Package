      syncTransactionDefinitionSelectionUi();
    });

    document.getElementById('btnPickTermTransactionDefinition').addEventListener('click', function () {
      GenericPicker.open(GenericPickerPresets.transactionDefinition({
        context: GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' }),
        onSelect: function (item) {
          document.getElementById('sel_termTransactionDefinition').value = String(item.id || '');
          syncTermTransactionDefinitionSelectionUi();
        }
      }));
    });

    document.getElementById('btnClearTermTransactionDefinition').addEventListener('click', function () {
      document.getElementById('sel_termTransactionDefinition').value = '';
      syncTermTransactionDefinitionSelectionUi();
    });

    document.getElementById('btnPickAdmin').addEventListener('click', function () {
      GenericPicker.open(GenericPickerPresets.person({
        title: 'Select Program Administrator',
        apiEndpoint: adminPickerEndpoint,
        placeholder: 'Search teachers/staff by name or email...',
        onSelect: function (item) {
          setAdministrator(item.id, getPersonDisplayName(item) || item.id);
        }
      }));
    });

    document.getElementById('btnPickProgramDepartment').addEventListener('click', function () {
      GenericPicker.open(GenericPickerPresets.department({
        title: 'Select Program Department',
        context: GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' }),
        onSelect: function (item) {
          setProgramDepartment(item);
        }
      }));
    });

    document.getElementById('btnClearProgramDepartment').addEventListener('click', function () {
      showMsg({
        title: 'Required Field',
        icon: 'warning',
        message: 'Department is required and cannot be cleared. Please select another department instead.',
        buttons: [{ text: 'OK', class: 'btn-warning' }]
      });
    });

    document.getElementById('btnCopyFromProgram').addEventListener('click', function () {
      GenericPicker.open(GenericPickerPresets.program({
        title: 'Copy From Program',
        placeholder: 'Search programs to copy...',
        onSelect: async function (item) {
          if (!item || (String(item.id || '') && String(item.id || '') === String(<%- JSON.stringify(routeId || '') %>))) return;
          applyProgramTemplate(item);
          await showMsg({
            title: 'Template Applied',
            icon: 'success',
            message: 'Program fields were copied. Review and edit the values before saving.',
            buttons: [{ text: 'OK', class: 'btn-success' }]
          });
        }
      }));
    });

    document.getElementById('btnPickProgramPostingPolicyDefinition').addEventListener('click', function () {
      GenericPicker.open(GenericPickerPresets.transactionDefinition({
        context: GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' }),
        onSelect: function (item) {
          document.getElementById('sel_programPostingPolicyDefinition').value = String(item.id || '');
          syncProgramPostingPolicySelectionUi();
        }
      }));
    });

    document.getElementById('btnClearProgramPostingPolicyDefinition').addEventListener('click', function () {
      document.getElementById('sel_programPostingPolicyDefinition').value = '';
      syncProgramPostingPolicySelectionUi();
    });

    document.getElementById('btnAddProgramPostingPolicy').addEventListener('click', async function () {
      try {
        const category = document.getElementById('programPostingPolicyCategory').value;
        const categoryKey = category || ALL_FEE_CATEGORY_KEY;
        const transactionDefinitionId = document.getElementById('sel_programPostingPolicyDefinition').value;
        const selectedDefinition = transactionDefinitionId ? transactionDefMap.get(String(transactionDefinitionId)) : null;
        const notes = document.getElementById('inp_programPostingPolicyNotes').value.trim();

        if (!transactionDefinitionId) throw new Error('Transaction template is required.');
        if (postingPolicies.some(function (row) { return String(row.feeCategory || '').trim() === categoryKey; })) {
          throw new Error('This fee category already has a Posting Policy.');
        }

        postingPolicies.push({
          feeCategory: categoryKey,
          transactionDefinitionId: transactionDefinitionId || '',
          transactionDefinitionCode: String(selectedDefinition?.code || ''),
          transactionDefinitionName: String(selectedDefinition?.name || ''),
          notes: notes,
          active: true
        });

        document.getElementById('programPostingPolicyCategory').value = '';
        document.getElementById('sel_programPostingPolicyDefinition').value = '';
        document.getElementById('inp_programPostingPolicyNotes').value = '';
        syncProgramPostingPolicySelectionUi();
        renderPostingPolicies();
        syncHiddenState();
      } catch (err) {
        await showMsg({
          title: 'Validation',
          icon: 'warning',
          message: err.message || 'Invalid Posting Policy.',
          buttons: [{ text: 'OK', class: 'btn-warning' }]
        });
      }
    });

    document.getElementById('btnAddTerm').addEventListener('click', function () {
      GenericPicker.open(GenericPickerPresets.term({
        title: 'Select Program Term',
        icon: 'bi-calendar3-range',
        multiselect: true,
        placeholder: 'Search terms, select multiple, then Add Selected...',
        context: GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' }),
        onSelect: function (items) {
          const rows = Array.isArray(items) ? items : [items];
          rows.forEach(function (item) {
            const termId = String(item.id || '').trim();
            if (!termId) return;
            if (terms.some(function (t) { return t.termId === termId; })) return;
            terms.push({
              termId: termId,
              order: terms.length + 1,
              isRequired: true,
              notes: '',
              ...buildTermSnapshot(item, { termId: termId }),
              startDate: String(item.startDate || '').trim(),
              endDate: String(item.endDate || '').trim(),
              termAcademicRules: {
                minimumPassingAverage: null,
                minimumPassingScore: null,
                totalAllowedCredits: null,
                minimumRequiredCredits: null,
                allowOverload: false,
                mustCompleteRequiredSubjects: true,
                notes: ''
              },
              termRegistrationFeeGroups: ensureCategoryFeeKeys({})
            });
          });
          normalizeTerms();
          renderTerms();
        }
      }));
    });

    document.getElementById('btnAddFeeLine').addEventListener('click', async function () {
      try {
        const category = document.getElementById('sel_feeCategory').value;
        const categoryKey = category || ALL_FEE_CATEGORY_KEY;
        const transactionDefinitionId = document.getElementById('sel_transactionDefinition').value;
        const selectedDefinition = transactionDefinitionId ? transactionDefMap.get(String(transactionDefinitionId)) : null;
        const notes = document.getElementById('inp_feeNotes').value.trim();

        if (!transactionDefinitionId) throw new Error('Transaction template is required.');
        if (selectedDefinition && isExpiredDefinition(selectedDefinition)) {
          throw new Error('Expired transaction templates cannot be added to Program Enrollment Fees.');
        }

        const txDefaultAmount = (selectedDefinition && Array.isArray(selectedDefinition.entries) && selectedDefinition.entries.length)
          ? selectedDefinition.entries.reduce(function (sum, entry) {
              const amount = Number(entry && entry.amount);
              return Number.isFinite(amount) ? (sum + amount) : sum;
            }, 0)
          : null;
        const normalizedAmount = (txDefaultAmount === null || txDefaultAmount === undefined || txDefaultAmount === '')
          ? null
          : Number(Number(txDefaultAmount).toFixed(2));

        if (normalizedAmount !== null && (!Number.isFinite(normalizedAmount) || normalizedAmount < 0)) {
          throw new Error('Valid fee amount is required.');
        }
        if (transactionDefinitionId && normalizedAmount === null) {
          throw new Error('Selected transaction template does not contain a usable amount.');
        }

        const finalCode = String(selectedDefinition?.code || '').trim().toUpperCase();
        const finalLabel = String(selectedDefinition?.name || '').trim();
        const finalCurrency = String(selectedDefinition?.currency || '').trim().toUpperCase();
        const finalFrequency = String(selectedDefinition?.frequency || 'one_time').trim().toLowerCase() || 'one_time';
        const finalIsOptional = Boolean(selectedDefinition?.isOptional);

        feeGroups[categoryKey].push({
          transactionDefinitionId: transactionDefinitionId || '',
          transactionDefinitionCode: String(selectedDefinition?.code || ''),
          transactionDefinitionName: String(selectedDefinition?.name || ''),
          code: finalCode,
          label: finalLabel,
          amount: normalizedAmount,
          currency: finalCurrency,
          frequency: finalFrequency,
          validFrom: String(selectedDefinition?.validFrom || ''),
          validTo: String(selectedDefinition?.validTo || ''),
          notes: notes,
          isOptional: finalIsOptional
        });

        document.getElementById('sel_transactionDefinition').value = '';
        syncTransactionDefinitionSelectionUi();
        document.getElementById('inp_feeNotes').value = '';

        renderFeeLines();
      } catch (err) {
        await showMsg({
          title: 'Validation',
          icon: 'warning',
          message: err.message || 'Invalid fee line.',
          buttons: [{ text: 'OK', class: 'btn-warning' }]
        });
      }
    });

    document.getElementById('btnAddTermFeeLine').addEventListener('click', async function () {
      try {
        const category = document.getElementById('sel_termFeeCategory').value;
        const categoryKey = category || ALL_FEE_CATEGORY_KEY;
        const transactionDefinitionId = document.getElementById('sel_termTransactionDefinition').value;
        const selectedDefinition = transactionDefinitionId ? transactionDefMap.get(String(transactionDefinitionId)) : null;
        const notes = document.getElementById('inp_termFeeNotes').value.trim();

        if (editingTermFeeIndex === null || editingTermFeeIndex < 0 || editingTermFeeIndex >= terms.length) {
          throw new Error('Select a program term first.');
        }
        if (!transactionDefinitionId) throw new Error('Transaction template is required.');
        assertNoTermFeeDateConflict(category, transactionDefinitionId);

        const totalAmount = (selectedDefinition && Array.isArray(selectedDefinition.entries) && selectedDefinition.entries.length)
          ? selectedDefinition.entries.reduce(function (sum, entry) {
              const amount = Number(entry && entry.amount);
              return Number.isFinite(amount) ? (sum + amount) : sum;
            }, 0)
          : null;
        const normalizedAmount = (totalAmount === null || totalAmount === undefined || totalAmount === '')
          ? null
          : Number(Number(totalAmount).toFixed(2));

        if (normalizedAmount === null) {
          throw new Error('Selected transaction template does not contain a usable amount.');
        }

        const groups = getEditingTermFeeGroups();
        groups[categoryKey].push({
          transactionDefinitionId: transactionDefinitionId || '',
          transactionDefinitionCode: String(selectedDefinition?.code || ''),
          transactionDefinitionName: String(selectedDefinition?.name || ''),
          code: String(selectedDefinition?.code || '').trim().toUpperCase(),
          label: String(selectedDefinition?.name || '').trim(),
          amount: normalizedAmount,
          currency: String(selectedDefinition?.currency || '').trim().toUpperCase(),
          frequency: String(selectedDefinition?.frequency || 'one_time').trim().toLowerCase() || 'one_time',
          validFrom: String(selectedDefinition?.validFrom || ''),
          validTo: String(selectedDefinition?.validTo || ''),
          notes: notes,
          isOptional: Boolean(selectedDefinition?.isOptional)
        });

        document.getElementById('sel_termTransactionDefinition').value = '';
        syncTermTransactionDefinitionSelectionUi();
        document.getElementById('inp_termFeeNotes').value = '';
        renderTermFeeLines();
        renderTerms();
      } catch (err) {
        await showMsg({
          title: 'Validation',
          icon: 'warning',
          message: err.message || 'Invalid term registration fee.',
          buttons: [{ text: 'OK', class: 'btn-warning' }]
        });
      }
    });

    document.getElementById('chk_termDetailsRequired').addEventListener('change', function () {
      if (editingTermDetailsIndex === null || editingTermDetailsIndex < 0 || editingTermDetailsIndex >= terms.length) return;
      terms[editingTermDetailsIndex].isRequired = this.checked;
      renderTerms();
      syncHiddenState();
    });

    document.getElementById('inp_termDetailsNotes').addEventListener('input', function () {
      if (editingTermDetailsIndex === null || editingTermDetailsIndex < 0 || editingTermDetailsIndex >= terms.length) return;
      terms[editingTermDetailsIndex].notes = this.value.trim();
      syncHiddenState();
    });

    document.getElementById('btnTermDetailsCalendar').addEventListener('click', function () {
      const index = editingTermDetailsIndex;
      if (index === null || index < 0 || index >= terms.length) return;
      closeTermDetailsThen(function () {
        openTermSnapshotModal(index);
      });
    });

    document.getElementById('btnTermDetailsRules').addEventListener('click', function () {
      const index = editingTermDetailsIndex;
      if (index === null || index < 0 || index >= terms.length) return;
      closeTermDetailsThen(function () {
        openTermRuleModal(index);
      });
    });

    document.getElementById('btnTermDetailsFees').addEventListener('click', function () {
      const index = editingTermDetailsIndex;
      if (index === null || index < 0 || index >= terms.length) return;
      closeTermDetailsThen(function () {
        openTermFeeModal(index);
      });
    });

    document.getElementById('btnTermDetailsRemove').addEventListener('click', function () {
      const index = editingTermDetailsIndex;
      if (index === null || index < 0 || index >= terms.length) return;
      terms.splice(index, 1);
      normalizeTerms();
      renderTerms();
      if (termDetailsModal) termDetailsModal.hide();
    });

    document.getElementById('termDetailsModal').addEventListener('hidden.bs.modal', function () {
      editingTermDetailsIndex = null;
    });

    document.getElementById('btnAddSubject').addEventListener('click', function () {
      GenericPicker.open(GenericPickerPresets.subject({
        title: 'Select Subject',
        icon: 'bi-journal-bookmark',
        multiselect: true,
        placeholder: 'Search subjects, select multiple, then Add Selected...',
        onSelect: function (items) {
          const rows = Array.isArray(items) ? items : [items];
          rows.forEach(function (item) {
            const sid = String(item.id || '').trim();
            if (!sid) return;
            if (subjects.some(function (s) { return s.subjectId === sid; })) return;
            const defaultRules = getSubjectDefaultScoreRules(sid);
            subjects.push({
              subjectId: sid,
              order: subjects.length + 1,
              isRequired: true,
              subjectType: 'main',
              programCredits: item?.configuration && item.configuration.credits !== undefined && item.configuration.credits !== null
                ? Number(item.configuration.credits)
                : 0,
              minPassingScore: defaultRules.minPassingScore,
              minPassingAverage: defaultRules.minPassingAverage,
              mustPass: defaultRules.mustPass,
              allowCompensation: defaultRules.allowCompensation,
              prerequisites: [],
              notes: defaultRules.notes || '',
              subjectCode: String(item.code || ''),
              subjectTitle: String(item.title || item.name || sid),
              subjectStatus: String(item.status || '').trim().toLowerCase()
            });
          });
          normalizeSubjects();
          renderSubjects();
        }
      }));
    });

    document.getElementById('btnSavePrereq').addEventListener('click', function () {
      if (editingPrereqFor === null || editingPrereqFor < 0 || editingPrereqFor >= subjects.length) return;
      const selected = Array.from(document.querySelectorAll('#preReqOptions input[type="checkbox"]:checked')).map(function (el) { return el.value; });
      subjects[editingPrereqFor].prerequisites = selected;
      renderSubjects();
      const modalEl = document.getElementById('preReqModal');
      const modal = bootstrap.Modal.getInstance(modalEl);
      if (modal) modal.hide();
    });

    document.getElementById('btnSaveSubjectRules').addEventListener('click', function () {
      if (editingSubjectRuleFor === null || editingSubjectRuleFor < 0 || editingSubjectRuleFor >= subjects.length) return;
      const minScoreRaw = document.getElementById('inp_subjectRuleMinScore').value.trim();
      const minAverageRaw = document.getElementById('inp_subjectRuleMinAverage').value.trim();
      const minScore = minScoreRaw === '' ? null : Number(minScoreRaw);
      const minAverage = minAverageRaw === '' ? null : Number(minAverageRaw);
      if (minScore !== null && (!Number.isFinite(minScore) || minScore < 0 || minScore > 100)) {
        showMsg({
          title: 'Validation',
          icon: 'warning',
          message: 'Minimum Passing Score must be between 0 and 100.',
          buttons: [{ text: 'OK', class: 'btn-warning' }]
        });
        return;
      }
      if (minAverage !== null && (!Number.isFinite(minAverage) || minAverage < 0 || minAverage > 100)) {
        showMsg({
          title: 'Validation',
          icon: 'warning',
          message: 'Minimum Passing Average must be between 0 and 100.',
          buttons: [{ text: 'OK', class: 'btn-warning' }]
        });
        return;
      }

      subjects[editingSubjectRuleFor].minPassingScore = minScore;
      subjects[editingSubjectRuleFor].minPassingAverage = minAverage;
      subjects[editingSubjectRuleFor].mustPass = document.getElementById('chk_subjectRuleMustPass').checked;
      subjects[editingSubjectRuleFor].allowCompensation = document.getElementById('chk_subjectRuleAllowCompensation').checked;
      subjects[editingSubjectRuleFor].notes = document.getElementById('inp_subjectRuleNotes').value.trim();
      renderSubjects();

      const modalEl = document.getElementById('subjectRuleModal');
      const modal = bootstrap.Modal.getInstance(modalEl);
      if (modal) modal.hide();
    });

    document.getElementById('btnSaveTermRules').addEventListener('click', async function () {
      if (editingTermRuleIndex === null || editingTermRuleIndex < 0 || editingTermRuleIndex >= terms.length) return;
      const minimumPassingAverageRaw = document.getElementById('inp_termMinimumPassingAverage').value.trim();
      const minimumPassingScoreRaw = document.getElementById('inp_termMinimumPassingScore').value.trim();
      const totalAllowedCreditsRaw = document.getElementById('inp_termTotalAllowedCredits').value.trim();
      const minimumRequiredCreditsRaw = document.getElementById('inp_termMinimumRequiredCredits').value.trim();

      const minimumPassingAverage = minimumPassingAverageRaw === '' ? null : Number(minimumPassingAverageRaw);
      const minimumPassingScore = minimumPassingScoreRaw === '' ? null : Number(minimumPassingScoreRaw);
      const totalAllowedCredits = totalAllowedCreditsRaw === '' ? null : Number(totalAllowedCreditsRaw);
      const minimumRequiredCredits = minimumRequiredCreditsRaw === '' ? null : Number(minimumRequiredCreditsRaw);

      function validPercent(v) { return v === null || (Number.isFinite(v) && v >= 0 && v <= 100); }
      function validCredits(v) { return v === null || (Number.isFinite(v) && v >= 0); }

      if (!validPercent(minimumPassingAverage)) {
        await showMsg({ title: 'Validation', icon: 'warning', message: 'Minimum Passing Average must be between 0 and 100.', buttons: [{ text: 'OK', class: 'btn-warning' }] });
        return;
      }
      if (!validPercent(minimumPassingScore)) {
        await showMsg({ title: 'Validation', icon: 'warning', message: 'Minimum Passing Score must be between 0 and 100.', buttons: [{ text: 'OK', class: 'btn-warning' }] });
        return;
      }
      if (!validCredits(totalAllowedCredits) || !validCredits(minimumRequiredCredits)) {
        await showMsg({ title: 'Validation', icon: 'warning', message: 'Credit values must be non-negative numbers.', buttons: [{ text: 'OK', class: 'btn-warning' }] });
        return;
      }
      if (totalAllowedCredits !== null && minimumRequiredCredits !== null && minimumRequiredCredits > totalAllowedCredits) {
        await showMsg({ title: 'Validation', icon: 'warning', message: 'Minimum Required Credits cannot exceed Total Allowed Credits.', buttons: [{ text: 'OK', class: 'btn-warning' }] });
        return;
      }

      terms[editingTermRuleIndex].termAcademicRules = {
        minimumPassingAverage: minimumPassingAverage,
        minimumPassingScore: minimumPassingScore,
        totalAllowedCredits: totalAllowedCredits,
        minimumRequiredCredits: minimumRequiredCredits,
        allowOverload: document.getElementById('chk_termAllowOverload').checked,
        mustCompleteRequiredSubjects: document.getElementById('chk_termMustCompleteRequiredSubjects').checked,
        notes: document.getElementById('inp_termRuleNotes').value.trim()
      };

      renderTerms();
      const modalEl = document.getElementById('termRuleModal');
      const modal = bootstrap.Modal.getInstance(modalEl);
      if (modal) modal.hide();
    });

    document.getElementById('btnSaveTermSnapshot').addEventListener('click', async function () {
      if (editingTermSnapshotIndex === null || editingTermSnapshotIndex < 0 || editingTermSnapshotIndex >= terms.length) return;
      try {
        const snapshot = {
          termCode: document.getElementById('inp_termSnapshotCode').value.trim().toUpperCase(),
          termName: document.getElementById('inp_termSnapshotName').value.trim(),
          status: document.getElementById('inp_termSnapshotStatus').value.trim().toLowerCase(),
          termDescription: document.getElementById('inp_termSnapshotDescription').value.trim(),
          registrationOpenDate: document.getElementById('inp_termSnapshotRegistrationOpenDate').value.trim(),
          registrationCloseDate: document.getElementById('inp_termSnapshotRegistrationCloseDate').value.trim(),
          lateRegistrationDeadline: document.getElementById('inp_termSnapshotLateRegistrationDeadline').value.trim(),
          paymentDueDate: document.getElementById('inp_termSnapshotPaymentDueDate').value.trim(),
          classesStartDate: document.getElementById('inp_termSnapshotClassesStartDate').value.trim(),
          classesEndDate: document.getElementById('inp_termSnapshotClassesEndDate').value.trim(),
          addDropDeadline: document.getElementById('inp_termSnapshotAddDropDeadline').value.trim(),
          swapDeadline: document.getElementById('inp_termSnapshotSwapDeadline').value.trim(),
          withdrawWithoutPenaltyDeadline: document.getElementById('inp_termSnapshotWithdrawWithoutPenaltyDeadline').value.trim(),
          withdrawDeadline: document.getElementById('inp_termSnapshotWithdrawDeadline').value.trim(),
          censusDate: document.getElementById('inp_termSnapshotCensusDate').value.trim(),
          finalExamStartDate: document.getElementById('inp_termSnapshotFinalExamStartDate').value.trim(),
          finalExamEndDate: document.getElementById('inp_termSnapshotFinalExamEndDate').value.trim(),
          gradeSubmissionDeadline: document.getElementById('inp_termSnapshotGradeSubmissionDeadline').value.trim(),
          termResultReleaseDate: document.getElementById('inp_termSnapshotResultReleaseDate').value.trim()
        };
        validateTermSnapshot(snapshot);
        terms[editingTermSnapshotIndex] = {
          ...terms[editingTermSnapshotIndex],
          ...snapshot
        };
        renderTerms();
        const modalEl = document.getElementById('termSnapshotModal');
        const modal = bootstrap.Modal.getInstance(modalEl);
        if (modal) modal.hide();
      } catch (err) {
        await showMsg({
          title: 'Validation',
          icon: 'warning',
          message: err.message || 'Invalid term snapshot.',
          buttons: [{ text: 'OK', class: 'btn-warning' }]
        });
      }
    });

    form.addEventListener('invalid', function (e) {
      const invalidField = e.target;
      activateTabForElement(invalidField);
      setTimeout(function () { invalidField.focus(); }, 200);
    }, true);

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

      try {
        if (!form.checkValidity()) {
          const firstInvalid = form.querySelector(':invalid');
          activateTabForElement(firstInvalid);
          form.reportValidity();
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
          return;
        }

        const adminId = document.getElementById('inp_adminPersonId').value.trim();
        if (!adminId) throw new Error('Please select Program Administrator.');

        const years = Number(document.getElementById('inp_durationYears').value || 0);
        const months = Number(document.getElementById('inp_durationMonths').value || 0);
        const days = Number(document.getElementById('inp_durationDays').value || 0);
        if ((years + months + days) <= 0) throw new Error('Duration must have at least one non-zero value.');

        normalizeTerms();
        normalizeSubjects();
        assertAcademicRulesValid();
        const totalProgramCredits = Number(form.querySelector('input[name="credits"]').value || 0);
        const minimumRequiredCredits =
          Number(academicRules.requiredMainCredits || 0) +
          Number(academicRules.requiredEssentialCredits || 0) +
          Number(academicRules.requiredOptionalCredits || 0);
        if (totalProgramCredits < minimumRequiredCredits) {
          throw new Error('Program credits cannot be lower than the total required credits defined in Academic Rules.');
        }
        ensureFeeKeys();
        syncHiddenState();

        const formData = new FormData(form);
        const data = new URLSearchParams(formData);

        const response = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-AJAX-Request': 'true' },
          body: data.toString()
        });

        const contentType = response.headers.get('content-type') || '';
        if (!contentType.includes('application/json')) {
          throw new Error('Server returned non-JSON response (Status ' + response.status + ')');
        }

        const result = await response.json();
        const guarded = typeof window.applyGuardedApiResult === 'function'
          ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Processed' })
          : { stop: false };
        if (guarded.stop) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
          return;
        }
        await showMsg({
          title: result.status === 'success' ? 'Success' : 'Error',
          icon: result.status === 'success' ? 'success' : 'error',
          message: result.message || 'Operation completed.',
          buttons: [{ text: 'OK', class: result.status === 'success' ? 'btn-success' : 'btn-danger' }]
        });

        if (result.status === 'success') {
          window.location.href = '/school/programs';
        } else {
          activateTabForErrorMessage(result.message);
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
        }
      } catch (error) {
        activateTabForErrorMessage(error.message);
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
        await showMsg({
          title: 'System Error',
          icon: 'error',
          message: error.message || 'An unexpected network error occurred.',
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
      }
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    ensureFeeKeys();
    normalizePostingPolicies();
    normalizeTerms();
    normalizeSubjects();
    normalizeDurationUI();
    normalizeAcademicRulesUI();
    syncTransactionDefinitionSelectionUi();
    syncProgramPostingPolicySelectionUi();
    renderFeeLines();
    renderPostingPolicies();
    renderTerms();
    renderSubjects();
    bindEvents();
    syncHiddenState();
  });
})();
</script>
