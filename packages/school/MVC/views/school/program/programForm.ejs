<%
  const p = program || {};
  const isEdit = !!p.id;
  const routeId = (p.id || '');
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';

  const initDuration = JSON.stringify(p.duration || { years: 0, months: 0, days: 0 }).replace(/</g, '\\u003c');
  const initAcademicRules = JSON.stringify(p.academicRules || {}).replace(/</g, '\\u003c');
  const initFeeGroups = JSON.stringify(p.feeGroups || {}).replace(/</g, '\\u003c');
  const initPostingPolicies = JSON.stringify(p.postingPolicies || []).replace(/</g, '\\u003c');
  const initTerms = JSON.stringify(p.terms || []).replace(/</g, '\\u003c');
  const initSubjects = JSON.stringify(p.subjects || []).replace(/</g, '\\u003c');
  const initTransactionDefinitions = JSON.stringify(transactionDefinitions || []).replace(/</g, '\\u003c');
  const initSubjectCatalog = JSON.stringify(subjectCatalog || []).replace(/</g, '\\u003c');
  const initTermCatalog = JSON.stringify(termCatalog || []).replace(/</g, '\\u003c');
  const initDepartments = JSON.stringify(departments || []).replace(/</g, '\\u003c');
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-heading size-md m-0"><i class="bi bi-journal-text me-2"></i><%= title %></h1>
    <div class="d-flex align-items-center gap-2">
      <button type="button" class="btn btn-outline-primary btn-md" id="btnCopyFromProgram">
        <i class="bi bi-copy me-1"></i> Copy From Program
      </button>
      <a href="/school/programs" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back to List</a>
    </div>
  </div>

  <div class="form-container wide" style="max-width: 1400px;">
    <form id="programForm" action="<%= isEdit ? '/school/programs/edit/'+routeId : '/school/programs/new' %>" method="POST">
      <input type="hidden" name="actionStateId" id="hid_actionStateId" value="<%= asid %>">
      <input type="hidden" name="feeGroups" id="hid_feeGroups" value="{}">
      <input type="hidden" name="postingPolicies" id="hid_postingPolicies" value="[]">
      <input type="hidden" name="terms" id="hid_terms" value="[]">
      <input type="hidden" name="subjects" id="hid_subjects" value="[]">
      <input type="hidden" name="academicRules" id="hid_academicRules" value="{}">
      <input type="hidden" name="duration" id="hid_duration" value="{}">

      <ul class="nav nav-tabs mb-4" id="programTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active fw-bold" data-bs-toggle="tab" data-bs-target="#tab-general" type="button">General Identity</button></li>
        <li class="nav-item"><button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-rules" type="button">Academic Rules</button></li>
        <li class="nav-item"><button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-terms" type="button">Terms</button></li>
        <li class="nav-item"><button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-fees" type="button">Program Enrollment Fees</button></li>
        <li class="nav-item"><button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-posting-policy" type="button">Posting Policies</button></li>
        <li class="nav-item"><button class="nav-link fw-bold" data-bs-toggle="tab" data-bs-target="#tab-curriculum" type="button">Subjects & Prerequisites</button></li>
      </ul>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4 tab-content">
          <div class="tab-pane fade show active" id="tab-general">
            <div class="row">
              <div class="col-md-8 mb-3">
                <label class="form-label fw-bold">Program Name *</label>
                <input type="text" name="name" class="form-control size-md" value="<%= p.name || '' %>" placeholder="e.g. Diploma in Software Engineering" required>
              </div>
              <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Program ID</label>
                <input type="text" name="programId" class="form-control size-md font-monospace" value="<%= p.id || '' %>" placeholder="Auto-generated if blank" <%= isEdit ? 'readonly' : '' %>>
              </div>
            </div>

            <div class="row">
              <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Program Code</label>
                <input type="text" name="code" class="form-control size-md font-monospace" value="<%= p.code || '' %>" placeholder="e.g. PRG-SE-01">
              </div>
              <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Status</label>
                <select name="status" class="form-select size-md" required>
                  <% (programStatuses || []).forEach(st => { %>
                    <option value="<%= st %>" <%= (p.status || 'active') === st ? 'selected' : '' %>><%= st %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Program Administrator *</label>
                <div class="input-group">
                  <input type="hidden" name="programAdministratorPersonId" id="inp_adminPersonId" value="<%= p.programAdministratorPersonId || '' %>" required>
                  <input type="text" id="inp_adminPersonName" class="form-control size-md bg-white border-primary fw-bold" value="<%= administratorName || '' %>" placeholder="Select from persons..." readonly required>
                  <button type="button" class="btn btn-primary" id="btnPickAdmin"><i class="bi bi-search"></i></button>
                </div>
              </div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold">Department *</label>
              <div class="input-group">
                <input type="hidden" name="departmentId" id="inp_programDepartmentId" value="<%= p.departmentId || '' %>">
                <input type="hidden" name="departmentCode" id="inp_programDepartmentCode" value="<%= p.departmentCode || '' %>">
                <input type="text" name="departmentName" id="inp_programDepartmentName" class="form-control size-md bg-white" value="<%= p.departmentName || '' %>" placeholder="Select Department..." readonly required>
                <button type="button" class="btn btn-outline-primary" id="btnPickProgramDepartment"><i class="bi bi-search"></i></button>
                <button type="button" class="btn btn-outline-secondary" id="btnClearProgramDepartment" disabled title="Department is required"><i class="bi bi-x-lg"></i></button>
              </div>
              <div class="small text-muted mt-1">Used for inherited Posting Policies when a class does not define its own policy.</div>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold">Program Description</label>
              <textarea name="description" class="form-control size-md" rows="3" placeholder="Program overview..."><%= p.description || '' %></textarea>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold">Notes</label>
              <textarea name="notes" class="form-control size-md" rows="2" placeholder="Internal notes..."><%= p.notes || '' %></textarea>
            </div>
          </div>

          <div class="tab-pane fade" id="tab-rules">
            <div class="alert alert-info border-info shadow-sm mb-4">
              <i class="bi bi-info-circle me-2"></i> These rules are validated at program level and can be overridden later only where explicitly allowed.
            </div>
            <div class="row">
              <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Duration (Years)</label>
                <input type="number" id="inp_durationYears" class="form-control size-md" min="0" step="1">
              </div>
              <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Duration (Months)</label>
                <input type="number" id="inp_durationMonths" class="form-control size-md" min="0" step="1">
              </div>
              <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Duration (Days)</label>
                <input type="number" id="inp_durationDays" class="form-control size-md" min="0" step="1">
              </div>
            </div>
            <div class="small text-muted mb-3">At least one of Years, Months, or Days is required.</div>

            <div class="row">
              <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Credits *</label>
                <input type="number" name="credits" class="form-control size-md" value="<%= p.credits ?? '' %>" min="0" step="0.01" required>
              </div>
              <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Minimum Passing Score *</label>
                <input type="number" name="minimumPassingScore" class="form-control size-md" value="<%= p.minimumPassingScore ?? '' %>" min="0" max="100" step="0.01" required>
              </div>
              <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Minimum Passing Average *</label>
                <input type="number" name="minimumPassingAverage" class="form-control size-md" value="<%= p.minimumPassingAverage ?? '' %>" min="0" max="100" step="0.01" required>
              </div>
            </div>

            <div class="card border shadow-sm mt-3">
              <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                  <div class="fw-bold">Curriculum Credit Rules</div>
                  <div class="small text-muted">Main subjects are mandatory. Essential and Optional credits are controlled here.</div>
                </div>
                <div class="row g-3 mb-3">
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Available Main Credits</label>
                    <input type="text" id="txt_totalMainCredits" class="form-control size-md bg-light" readonly>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Available Essential Credits</label>
                    <input type="text" id="txt_totalEssentialCredits" class="form-control size-md bg-light" readonly>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Available Optional Credits</label>
                    <input type="text" id="txt_totalOptionalCredits" class="form-control size-md bg-light" readonly>
                  </div>
                </div>
                <div class="row g-3">
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Required Main Credits</label>
                    <input type="number" id="inp_requiredMainCredits" class="form-control size-md bg-light" min="0" step="0.01" readonly>
                    <div class="small text-muted mt-1">Auto-derived from all Main subjects.</div>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Required Essential Credits</label>
                    <input type="number" id="inp_requiredEssentialCredits" class="form-control size-md" min="0" step="0.01">
                  </div>
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Required Optional Credits</label>
                    <input type="number" id="inp_requiredOptionalCredits" class="form-control size-md" min="0" step="0.01">
                  </div>
                </div>
                <div class="form-check mt-3">
                  <input type="checkbox" class="form-check-input" id="chk_allowEssentialCreditsTowardOptional">
                  <label class="form-check-label fw-bold" for="chk_allowEssentialCreditsTowardOptional">Allow unused Essential credits to count toward Optional requirement</label>
                </div>
              </div>
            </div>
          </div>

          <div class="tab-pane fade" id="tab-terms">
            <div class="alert alert-light border shadow-sm mb-3">
              <i class="bi bi-calendar3-range me-2"></i>Assign the academic terms/semesters in which this program is offered. Classes can later reference these program-term combinations.
            </div>
            <div class="mb-3">
              <button type="button" class="btn btn-filled btn-primary btn-sm" id="btnAddTerm"><i class="bi bi-plus-circle me-1"></i>Add Term</button>
            </div>

            <div class="table-responsive">
              <table class="table table-sm align-middle">
                <thead>
                  <tr>
                    <th style="width: 16%;">Order</th>
                    <th>Term</th>
                    <th style="width: 10%;">Required</th>
                    <th style="width: 10%;" class="text-end">More</th>
                  </tr>
                </thead>
                <tbody id="termsTbody"></tbody>
              </table>
            </div>
          </div>

          <div class="tab-pane fade" id="tab-fees">
            <div class="alert alert-warning border-warning shadow-sm mb-3">
              <i class="bi bi-tools me-2"></i>Define one-time program enrollment fees. These fees are charged when a student is registered into the program. If no category is selected, the fee applies to all categories.
            </div>

            <div class="row align-items-end">
              <div class="col-md-3 mb-3">
                <label class="form-label fw-bold">Fee Category</label>
                <select id="sel_feeCategory" class="form-select size-md">
                  <option value=""><%= allFeeCategoryLabel || 'All Categories' %></option>
                  <% (feeCategories || []).forEach(cat => { %>
                    <option value="<%= cat %>"><%= cat %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Transaction Template (optional)</label>
                <div class="small text-muted mb-1">Select a template. Program transactions can only be added from Transaction Templates.</div>
                <div class="input-group">
                  <input type="hidden" id="sel_transactionDefinition" value="">
                  <input type="text" id="inp_transactionDefinitionLabel" class="form-control size-md bg-white" value="" placeholder="Select Transaction Template" readonly>
                  <button type="button" class="btn btn-outline-primary" id="btnPickTransactionDefinition"><i class="bi bi-search"></i></button>
                  <button type="button" class="btn btn-outline-secondary" id="btnClearTransactionDefinition"><i class="bi bi-x-lg"></i></button>
                  <a href="#" class="btn btn-outline-info d-none" id="btnViewTransactionDefinition" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right"></i></a>
                </div>
              </div>
              <div class="col-12">
                <div class="alert alert-light border shadow-sm mb-3" id="selectedTransactionDefinitionNotice">
                  <div class="fw-bold mb-1">Transaction Template Driven</div>
                  <div class="small text-muted">Code, label, amount, currency, and validity period are taken directly from the linked Transaction Template. Only the row note can be added here.</div>
                </div>
              </div>
            </div>

            <div class="row align-items-end">
              <div class="col-md-12 mb-3">
                <label class="form-label fw-bold">Notes</label>
                <input type="text" id="inp_feeNotes" class="form-control size-md" placeholder="Optional note">
              </div>
            </div>

            <div class="mb-3">
              <button type="button" class="btn btn-filled btn-primary btn-sm" id="btnAddFeeLine"><i class="bi bi-plus-circle me-1"></i>Add Fee Line</button>
            </div>

            <div class="table-responsive">
              <table class="table table-sm align-middle">
                <thead>
                  <tr>
                    <th>Transaction</th>
                    <th>Code / Label</th>
                    <th>Amount</th>
                    <th>Currency</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody id="feeLinesTbody"></tbody>
              </table>
            </div>
          </div>

          <div class="tab-pane fade" id="tab-posting-policy">
            <div class="alert alert-warning border-warning shadow-sm mb-3">
              <i class="bi bi-cash-stack me-2"></i>Program Posting Policies are used for term-registration class charges when the class itself does not define a policy. Class-level policies override these rows, and these rows override Department policies.
            </div>

            <div class="row align-items-end">
              <div class="col-md-3 mb-3">
                <label class="form-label fw-bold">Fee Category</label>
                <select id="programPostingPolicyCategory" class="form-select size-md">
                  <option value=""><%= allFeeCategoryLabel || 'All Categories' %></option>
                  <% (feeCategories || []).forEach(cat => { %>
                    <option value="<%= cat %>"><%= cat %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Transaction Template</label>
                <div class="small text-muted mb-1">Choose the default template the program should use for class posting.</div>
                <div class="input-group">
                  <input type="hidden" id="sel_programPostingPolicyDefinition" value="">
                  <input type="text" id="inp_programPostingPolicyDefinitionLabel" class="form-control size-md bg-white" value="" placeholder="Select Transaction Template" readonly>
                  <button type="button" class="btn btn-outline-primary" id="btnPickProgramPostingPolicyDefinition"><i class="bi bi-search"></i></button>
                  <button type="button" class="btn btn-outline-secondary" id="btnClearProgramPostingPolicyDefinition"><i class="bi bi-x-lg"></i></button>
                  <a href="#" class="btn btn-outline-info d-none" id="btnViewProgramPostingPolicyDefinition" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right"></i></a>
                </div>
              </div>
              <div class="col-md-3 mb-3">
                <label class="form-label fw-bold">Notes</label>
                <input type="text" id="inp_programPostingPolicyNotes" class="form-control size-md" placeholder="Optional note">
              </div>
            </div>

            <div class="mb-3">
              <button type="button" class="btn btn-filled btn-primary btn-sm" id="btnAddProgramPostingPolicy"><i class="bi bi-plus-circle me-1"></i>Add Posting Policy</button>
            </div>

            <div class="table-responsive">
              <table class="table table-sm align-middle">
                <thead>
                  <tr>
                    <th>Fee Category</th>
                    <th>Posting Policy</th>
                    <th>Template Code</th>
                    <th>Notes</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody id="programPostingPolicyTbody"></tbody>
              </table>
            </div>
          </div>

          <div class="tab-pane fade" id="tab-curriculum">
            <div class="alert alert-light border shadow-sm mb-3">
              <i class="bi bi-journal-check me-2"></i>Add subjects via Generic Picker, then define program-specific type, credits, and one or more prerequisites.
            </div>
            <div class="mb-3">
              <button type="button" class="btn btn-filled btn-primary btn-sm" id="btnAddSubject"><i class="bi bi-plus-circle me-1"></i>Add Subject</button>
            </div>

            <div class="table-responsive">
              <table class="table table-sm align-middle">
                <thead>
                  <tr>
                    <th style="width: 8%;">Order</th>
                    <th style="width: 28%;">Subject</th>
                    <th style="width: 16%;">Type</th>
                    <th style="width: 14%;">Program Credits</th>
                    <th style="width: 18%;">Prerequisites</th>
                    <th style="width: 16%;">Rule Summary</th>
                    <th style="width: 20%;" class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody id="subjectsTbody"></tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md fw-bold px-4">Save Program</button>
        <a href="/school/programs" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction" data-return-url="/school/programs">Cancel</a>
      </div>
    </form>
  </div>
</div>

<div class="modal fade" id="preReqModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Set Prerequisites</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="small text-muted mb-2">Select one or more prerequisite subjects.</div>
        <div id="preReqOptions" class="d-grid gap-2"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary btn-sm" id="btnSavePrereq">Save</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="termDetailsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <div>
          <h5 class="modal-title fw-bold" id="termDetailsModalTitle">Program Term Details</h5>
          <div class="small text-muted" id="termDetailsModalMeta"></div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <div class="form-check mt-1">
              <input type="checkbox" class="form-check-input" id="chk_termDetailsRequired">
              <label class="form-check-label fw-bold" for="chk_termDetailsRequired">Term is required in this program</label>
            </div>
          </div>
          <div class="col-md-6 text-md-end">
            <div class="small text-muted" id="termDetailsModalSubmeta"></div>
          </div>
        </div>

        <div class="row g-3 mb-3">
          <div class="col-md-6">
            <div class="border rounded p-3 h-100">
              <div class="small text-uppercase text-muted fw-bold mb-1">Academic Rules</div>
              <div class="fw-bold" id="termDetailsRuleLabel">Default</div>
              <div class="small text-muted mt-1" id="termDetailsRuleDetails">No term-specific academic rules.</div>
            </div>
          </div>
          <div class="col-md-6">
            <div class="border rounded p-3 h-100">
              <div class="small text-uppercase text-muted fw-bold mb-1">Registration Fees</div>
              <div class="fw-bold" id="termDetailsFeeLabel">No fees</div>
              <div class="small text-muted mt-1" id="termDetailsFeeDetails">None configured.</div>
            </div>
          </div>
        </div>

        <div class="mb-3">
          <label class="form-label fw-bold" for="inp_termDetailsNotes">Notes</label>
          <textarea class="form-control size-md" id="inp_termDetailsNotes" rows="4" placeholder="Optional note for this term"></textarea>
        </div>

        <div class="mb-2">
          <div class="small text-uppercase text-muted fw-bold mb-2">Calendar Snapshot</div>
          <div class="row g-2" id="termDetailsSnapshotList"></div>
        </div>
      </div>
      <div class="modal-footer justify-content-between">
        <div class="d-flex flex-wrap gap-2">
          <button type="button" class="btn btn-secondary btn-sm" id="btnTermDetailsCalendar"><i class="bi bi-calendar-event me-1"></i>Calendar</button>
          <button type="button" class="btn btn-secondary btn-sm" id="btnTermDetailsRules"><i class="bi bi-sliders2 me-1"></i>Rules</button>
          <button type="button" class="btn btn-secondary btn-sm" id="btnTermDetailsFees"><i class="bi bi-receipt-cutoff me-1"></i>Fees</button>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <button type="button" class="btn btn-danger btn-sm" id="btnTermDetailsRemove">Remove</button>
          <button type="button" class="btn btn-dark btn-sm" data-bs-dismiss="modal">Close</button>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="termRuleModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold">Term Academic Rules</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <div class="fw-bold" id="termRuleModalTermName">Selected Term</div>
          <div class="small text-muted" id="termRuleModalTermMeta"></div>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Minimum Passing Average</label>
            <input type="number" class="form-control size-md" id="inp_termMinimumPassingAverage" min="0" max="100" step="0.01" placeholder="Leave blank if not required">
          </div>
          <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Minimum Passing Score</label>
            <input type="number" class="form-control size-md" id="inp_termMinimumPassingScore" min="0" max="100" step="0.01" placeholder="Leave blank if not required">
          </div>
        </div>
        <div class="row">
          <div class="col-md-6 mb-3">
            <label class="form-label fw-bold">Total Allowed Credits</label>
            <input type="number" class="form-control size-md" id="inp_termTotalAllowedCredits" min="0" step="0.01" placeholder="Optional limit">
          </div>
