      { label: 'Add / Drop Deadline', value: String(term?.addDropDeadline || '').trim() },
      { label: 'Swap Deadline', value: String(term?.swapDeadline || '').trim() },
      { label: 'Withdraw Without Penalty', value: String(term?.withdrawWithoutPenaltyDeadline || '').trim() },
      { label: 'Final Withdraw Deadline', value: String(term?.withdrawDeadline || '').trim() },
