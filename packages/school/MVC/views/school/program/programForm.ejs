<script>
  window.__INIT_PROGRAM_DURATION__ = <%- initDuration %>;
  window.__INIT_PROGRAM_ACADEMIC_RULES__ = <%- initAcademicRules %>;
  window.__INIT_PROGRAM_FEES__ = <%- initFeeGroups %>;
  window.__INIT_PROGRAM_POSTING_POLICIES__ = <%- initPostingPolicies %>;
  window.__INIT_PROGRAM_TERMS__ = <%- initTerms %>;
  window.__INIT_PROGRAM_SUBJECTS__ = <%- initSubjects %>;
  window.__INIT_TRANSACTION_DEFINITIONS__ = <%- initTransactionDefinitions %>;
  window.__INIT_SUBJECT_CATALOG__ = <%- initSubjectCatalog %>;
  window.__INIT_TERM_CATALOG__ = <%- initTermCatalog %>;
  window.__INIT_DEPARTMENTS__ = <%- initDepartments %>;
</script>

<script>
(function () {
  const form = document.getElementById('programForm');
  const tabsRoot = document.getElementById('programTabs');
  const hidFeeGroups = document.getElementById('hid_feeGroups');
  const hidPostingPolicies = document.getElementById('hid_postingPolicies');
  const hidTerms = document.getElementById('hid_terms');
  const hidSubjects = document.getElementById('hid_subjects');
  const hidAcademicRules = document.getElementById('hid_academicRules');
  const hidDuration = document.getElementById('hid_duration');
  const feeLinesTbody = document.getElementById('feeLinesTbody');
  const termsTbody = document.getElementById('termsTbody');
  const subjectsTbody = document.getElementById('subjectsTbody');
  const feeCategories = <%- JSON.stringify(feeCategories || []) %>;
  const allFeeCategoryKey = <%- JSON.stringify(allFeeCategoryKey || '__ALL__') %>;
  const allFeeCategoryLabel = <%- JSON.stringify(allFeeCategoryLabel || 'All Categories') %>;
  const subjectTypes = <%- JSON.stringify(subjectTypes || ['main', 'essential', 'optional']) %>;
  const ALL_FEE_CATEGORY_KEY = allFeeCategoryKey;
  const programOrgId = <%- JSON.stringify(programOrgId || '') %>;
  const adminPickerEndpoint = '/school/programs/api/eligible-administrators?orgId=' + encodeURIComponent(programOrgId);
  const transactionDefinitions = Array.isArray(window.__INIT_TRANSACTION_DEFINITIONS__) ? window.__INIT_TRANSACTION_DEFINITIONS__ : [];
  const transactionDefMap = new Map(transactionDefinitions.map(function (t) { return [String(t.id), t]; }));
  const departments = Array.isArray(window.__INIT_DEPARTMENTS__) ? window.__INIT_DEPARTMENTS__ : [];
  const departmentMap = new Map(departments.map(function (d) { return [String(d.id || ''), d]; }));
  const subjectCatalog = Array.isArray(window.__INIT_SUBJECT_CATALOG__) ? window.__INIT_SUBJECT_CATALOG__ : [];
  const subjectCatalogMap = new Map(subjectCatalog.map(function (s) { return [String(s.id || ''), s]; }));
  const termCatalog = Array.isArray(window.__INIT_TERM_CATALOG__) ? window.__INIT_TERM_CATALOG__ : [];
  const termCatalogMap = new Map(termCatalog.map(function (t) { return [String(t.id || ''), t]; }));
  const termSnapshotFields = [
    'registrationOpenDate',
    'registrationCloseDate',
    'lateRegistrationDeadline',
    'paymentDueDate',
    'classesStartDate',
    'classesEndDate',
    'addDropDeadline',
    'swapDeadline',
    'withdrawWithoutPenaltyDeadline',
    'withdrawDeadline',
    'censusDate',
    'finalExamStartDate',
    'finalExamEndDate',
    'gradeSubmissionDeadline',
    'termResultReleaseDate'
  ];

  let academicRules = (window.__INIT_PROGRAM_ACADEMIC_RULES__ && typeof window.__INIT_PROGRAM_ACADEMIC_RULES__ === 'object') ? window.__INIT_PROGRAM_ACADEMIC_RULES__ : {};
  let feeGroups = (window.__INIT_PROGRAM_FEES__ && typeof window.__INIT_PROGRAM_FEES__ === 'object') ? window.__INIT_PROGRAM_FEES__ : {};
  let postingPolicies = Array.isArray(window.__INIT_PROGRAM_POSTING_POLICIES__) ? window.__INIT_PROGRAM_POSTING_POLICIES__ : [];
  let terms = Array.isArray(window.__INIT_PROGRAM_TERMS__) ? window.__INIT_PROGRAM_TERMS__ : [];
  let subjects = Array.isArray(window.__INIT_PROGRAM_SUBJECTS__) ? window.__INIT_PROGRAM_SUBJECTS__ : [];
  let editingPrereqFor = null;
  let editingSubjectRuleFor = null;
  let editingTermDetailsIndex = null;
  let editingTermRuleIndex = null;
  let editingTermFeeIndex = null;
  let editingTermSnapshotIndex = null;
  let termDetailsModal = null;
  let termFeeModal = null;
  let termRuleModal = null;
  let termSnapshotModal = null;
  let subjectRuleModal = null;

  function activateTab(targetSelector) {
    if (!targetSelector) return;
    const trigger = tabsRoot ? tabsRoot.querySelector(`[data-bs-target="${targetSelector}"]`) : null;
    if (!trigger) return;
    if (window.bootstrap && typeof window.bootstrap.Tab === 'function') {
      window.bootstrap.Tab.getOrCreateInstance(trigger).show();
      return;
    }
    trigger.click();
  }

  function activateTabForElement(element) {
    if (!element) return;
    const pane = element.closest('.tab-pane');
    if (pane && pane.id) activateTab(`#${pane.id}`);
  }

  function getTermMaster(termId) {
    return termCatalogMap.get(String(termId || '').trim()) || null;
  }

  function buildTermSnapshot(master, existing) {
    const source = (master && typeof master === 'object') ? master : {};
    const prior = (existing && typeof existing === 'object') ? existing : {};
    const snapshot = {
      termCode: String(prior.termCode || source.code || '').trim().toUpperCase(),
      termName: String(prior.termName || source.name || source.title || prior.termId || '').trim(),
      status: String(prior.status || source.status || '').trim().toLowerCase(),
      termDescription: String(prior.termDescription || source.description || '').trim()
    };
    termSnapshotFields.forEach(function (field) {
      snapshot[field] = String(prior[field] || source[field] || '').trim();
    });
    return snapshot;
  }

  function getTermLiveDates(termObj) {
    const master = getTermMaster(termObj.termId);
    return {
      startDate: String((master && master.startDate) || termObj.startDate || '').trim(),
      endDate: String((master && master.endDate) || termObj.endDate || '').trim()
    };
  }

  function validateTermSnapshot(snapshot) {
    const s = snapshot || {};
    function fail(message) { throw new Error(message); }
    if (s.registrationOpenDate && s.registrationCloseDate && s.registrationCloseDate < s.registrationOpenDate) fail('Program term registration close date cannot be earlier than registration open date.');
    if (s.classesStartDate && s.classesEndDate && s.classesEndDate < s.classesStartDate) fail('Program term classes end date cannot be earlier than classes start date.');
    if (s.finalExamStartDate && s.finalExamEndDate && s.finalExamEndDate < s.finalExamStartDate) fail('Program term final exam end date cannot be earlier than final exam start date.');
    if (s.withdrawWithoutPenaltyDeadline && s.withdrawDeadline && s.withdrawDeadline < s.withdrawWithoutPenaltyDeadline) fail('Program term withdraw deadline cannot be earlier than withdraw without penalty deadline.');
    if (s.classesStartDate && s.addDropDeadline && s.addDropDeadline < s.classesStartDate) fail('Program term add/drop deadline cannot be earlier than classes start date.');
    if (s.classesStartDate && s.swapDeadline && s.swapDeadline < s.classesStartDate) fail('Program term swap deadline cannot be earlier than classes start date.');
    if (s.classesStartDate && s.classesEndDate && s.censusDate && (s.censusDate < s.classesStartDate || s.censusDate > s.classesEndDate)) {
      fail('Program term census date must fall within the class period.');
    }
  }

  function activateTabForErrorMessage(message) {
    const msg = String(message || '').toLowerCase();
    if (!msg) return;
    if (msg.includes('program administrator') || msg.includes('program name') || msg.includes('program code') || msg.includes('status') || msg.includes('description') || msg.includes('department')) return activateTab('#tab-general');
    if (msg.includes('duration') || msg.includes('academic rules') || msg.includes('program credits') || msg.includes('passing score') || msg.includes('passing average') || msg.includes('required credits')) return activateTab('#tab-rules');
    if (msg.includes('term') || msg.includes('semester') || msg.includes('overload')) return activateTab('#tab-terms');
    if (msg.includes('fee') || msg.includes('transaction definition') || msg.includes('transaction template') || msg.includes('category')) return activateTab('#tab-fees');
    if (msg.includes('posting policy')) return activateTab('#tab-posting-policy');
    if (msg.includes('subject') || msg.includes('prerequisite') || msg.includes('curriculum') || msg.includes('compensation')) return activateTab('#tab-curriculum');
  }

  function getPersonDisplayName(item) {
    const first = String(item?.name?.first || item?.firstName || '').trim();
    const last = String(item?.name?.last || item?.lastName || '').trim();
    return `${first} ${last}`.trim() || String(item?.displayName || item?.id || '').trim();
  }

  function showMsg(opts) {
    if (typeof showMessageModal === 'function') return showMessageModal(opts);
    alert(opts?.message || 'Done');
    return Promise.resolve();
  }

  function safeHtml(s) {
    return String(s ?? '').replace(/[&<>"']/g, function (m) {
      return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[m];
    });
  }

  function normalizeDurationUI() {
    const d = window.__INIT_PROGRAM_DURATION__ || {};
    document.getElementById('inp_durationYears').value = Number(d.years || 0);
    document.getElementById('inp_durationMonths').value = Number(d.months || 0);
    document.getElementById('inp_durationDays').value = Number(d.days || 0);
  }

  function normalizeAcademicRulesUI() {
    const rules = academicRules && typeof academicRules === 'object' ? academicRules : {};
    document.getElementById('inp_requiredEssentialCredits').value =
      (rules.requiredEssentialCredits === null || rules.requiredEssentialCredits === undefined || rules.requiredEssentialCredits === '') ? '' : Number(rules.requiredEssentialCredits);
    document.getElementById('inp_requiredOptionalCredits').value =
      (rules.requiredOptionalCredits === null || rules.requiredOptionalCredits === undefined || rules.requiredOptionalCredits === '') ? '' : Number(rules.requiredOptionalCredits);
    document.getElementById('chk_allowEssentialCreditsTowardOptional').checked =
      rules.allowEssentialCreditsTowardOptional !== false && String(rules.allowEssentialCreditsTowardOptional) !== 'false';
  }

  function ensureFeeKeys() {
    feeGroups = ensureCategoryFeeKeys(feeGroups);
  }

  function ensureCategoryFeeKeys(groups) {
    const next = (groups && typeof groups === 'object' && !Array.isArray(groups)) ? groups : {};
    feeCategories.forEach(function (cat) {
      if (!Array.isArray(next[cat])) next[cat] = [];
    });
    if (!Array.isArray(next[ALL_FEE_CATEGORY_KEY])) next[ALL_FEE_CATEGORY_KEY] = [];
    Object.keys(next).forEach(function (k) {
      if (!feeCategories.includes(k) && k !== ALL_FEE_CATEGORY_KEY) delete next[k];
    });
    return next;
  }

  function getCategoryLabel(cat) {
    return cat ? String(cat) : allFeeCategoryLabel;
  }

  function setAdministrator(personId, personName) {
    document.getElementById('inp_adminPersonId').value = String(personId || '').trim();
    document.getElementById('inp_adminPersonName').value = String(personName || '').trim();
  }

  function setProgramDepartment(item) {
    const department = item && typeof item === 'object' ? item : null;
    document.getElementById('inp_programDepartmentId').value = String(department?.id || '').trim();
    document.getElementById('inp_programDepartmentCode').value = String(department?.code || '').trim().toUpperCase();
    document.getElementById('inp_programDepartmentName').value = String(department?.name || '').trim();
  }

  function applyProgramTemplate(item) {
    if (!item || typeof item !== 'object') return;
    form.querySelector('input[name="name"]').value = item.name || '';
    form.querySelector('input[name="code"]').value = item.code || '';
    form.querySelector('select[name="status"]').value = item.status || 'active';
    form.querySelector('textarea[name="description"]').value = item.description || '';
    form.querySelector('textarea[name="notes"]').value = item.notes || '';
    form.querySelector('input[name="credits"]').value = item.credits ?? '';
    form.querySelector('input[name="minimumPassingScore"]').value = item.minimumPassingScore ?? '';
    form.querySelector('input[name="minimumPassingAverage"]').value = item.minimumPassingAverage ?? '';

    const duration = (item.duration && typeof item.duration === 'object') ? item.duration : {};
    window.__INIT_PROGRAM_DURATION__ = {
      years: Number(duration.years || 0),
      months: Number(duration.months || 0),
      days: Number(duration.days || 0)
    };
    normalizeDurationUI();

    academicRules = (item.academicRules && typeof item.academicRules === 'object')
      ? JSON.parse(JSON.stringify(item.academicRules))
      : {};
    normalizeAcademicRulesUI();

    feeGroups = (item.feeGroups && typeof item.feeGroups === 'object')
      ? JSON.parse(JSON.stringify(item.feeGroups))
      : {};
    ensureFeeKeys();
    renderFeeLines();

    terms = Array.isArray(item.terms) ? JSON.parse(JSON.stringify(item.terms)) : [];
    normalizeTerms();
    renderTerms();

    subjects = Array.isArray(item.subjects) ? JSON.parse(JSON.stringify(item.subjects)) : [];
    normalizeSubjects();
    renderSubjects();

    const adminName = String(item.programAdministratorPersonName || item.administratorName || '').trim();
    setAdministrator(item.programAdministratorPersonId || '', adminName);
    setProgramDepartment({
      id: item.departmentId || '',
      code: item.departmentCode || '',
      name: item.departmentName || ''
    });
    postingPolicies = Array.isArray(item.postingPolicies) ? JSON.parse(JSON.stringify(item.postingPolicies)) : [];
    normalizePostingPolicies();
    renderPostingPolicies();
    syncHiddenState();
    activateTab('#tab-general');
  }

  function resolveSubjectMaster(subjectId) {
    return subjectCatalogMap.get(String(subjectId || '').trim()) || null;
  }

  function getSubjectDisplay(subject) {
    const master = resolveSubjectMaster(subject && subject.subjectId);
    return {
      title: String(
        master?.title ||
        subject?.subjectTitle ||
        subject?.title ||
        subject?.name ||
        subject?.subjectId ||
        ''
      ).trim(),
      code: String(
        master?.code ||
        subject?.subjectCode ||
        subject?.code ||
        subject?.subjectId ||
        ''
      ).trim(),
      status: String(master?.status || '').trim().toLowerCase(),
      defaultCredits: master && master.configuration ? Number(master.configuration.credits) : null
    };
  }

  function getSubjectDefaultScoreRules(subjectId) {
    const master = resolveSubjectMaster(subjectId);
    const rules = (master && master.defaultScoreRules && typeof master.defaultScoreRules === 'object')
      ? master.defaultScoreRules
      : {};
    return {
      minPassingScore: rules.minPassingScore === null || rules.minPassingScore === undefined || rules.minPassingScore === '' ? null : Number(rules.minPassingScore),
      minPassingAverage: rules.minPassingAverage === null || rules.minPassingAverage === undefined || rules.minPassingAverage === '' ? null : Number(rules.minPassingAverage),
      mustPass: rules.mustPass === true || String(rules.mustPass) === 'true',
      allowCompensation: rules.allowCompensation === true || String(rules.allowCompensation) === 'true',
      notes: String(rules.notes || '')
    };
  }

  function formatCredit(value) {
    const n = Number(value);
    return Number.isFinite(n) ? n.toFixed(2).replace(/\.00$/, '') : '0';
  }

  function calculateSubjectTypeTotals() {
    return subjects.reduce(function (acc, s) {
      const type = subjectTypes.includes(String(s.subjectType || '')) ? String(s.subjectType) : 'main';
      const credits = Number(s.programCredits);
      if (Number.isFinite(credits)) acc[type] += credits;
      return acc;
    }, { main: 0, essential: 0, optional: 0 });
  }

  function getPrerequisiteLabels(subject) {
    return (Array.isArray(subject.prerequisites) ? subject.prerequisites : []).map(function (preId) {
      const preSubject = subjects.find(function (candidate) { return candidate.subjectId === preId; });
      const display = getSubjectDisplay(preSubject || { subjectId: preId });
      return display.code || display.title || preId;
    });
  }

  function syncAcademicRules() {
    const totals = calculateSubjectTypeTotals();
    const requiredEssentialCredits = Number(document.getElementById('inp_requiredEssentialCredits').value || 0);
    const requiredOptionalCredits = Number(document.getElementById('inp_requiredOptionalCredits').value || 0);
    const allowEssentialCreditsTowardOptional = document.getElementById('chk_allowEssentialCreditsTowardOptional').checked;

    document.getElementById('txt_totalMainCredits').value = formatCredit(totals.main);
    document.getElementById('txt_totalEssentialCredits').value = formatCredit(totals.essential);
    document.getElementById('txt_totalOptionalCredits').value = formatCredit(totals.optional);
    document.getElementById('inp_requiredMainCredits').value = formatCredit(totals.main);

    academicRules = {
      requiredMainCredits: Number(totals.main.toFixed(2)),
      requiredEssentialCredits: Number((Number.isFinite(requiredEssentialCredits) ? requiredEssentialCredits : 0).toFixed(2)),
      requiredOptionalCredits: Number((Number.isFinite(requiredOptionalCredits) ? requiredOptionalCredits : 0).toFixed(2)),
      allowEssentialCreditsTowardOptional: allowEssentialCreditsTowardOptional
    };
  }

  function assertAcademicRulesValid() {
    const totals = calculateSubjectTypeTotals();
    const requiredEssentialCredits = Number(academicRules.requiredEssentialCredits || 0);
    const requiredOptionalCredits = Number(academicRules.requiredOptionalCredits || 0);
    if (requiredEssentialCredits > totals.essential) {
      throw new Error('Required essential credits cannot exceed the total available essential credits.');
    }
    const optionalCapacity = academicRules.allowEssentialCreditsTowardOptional
      ? totals.optional + Math.max(0, totals.essential - requiredEssentialCredits)
      : totals.optional;
    if (requiredOptionalCredits > optionalCapacity) {
      throw new Error('Required optional credits exceed the available optional credit capacity under the current academic rule.');
    }
  }

  function getSelectedTransactionDefinition() {
    const txId = String(document.getElementById('sel_transactionDefinition').value || '').trim();
    return txId ? (transactionDefMap.get(txId) || null) : null;
  }

  function syncTransactionDefinitionSelectionUi() {
    const txIdField = document.getElementById('sel_transactionDefinition');
    const labelField = document.getElementById('inp_transactionDefinitionLabel');
    const viewBtn = document.getElementById('btnViewTransactionDefinition');
    const tx = getSelectedTransactionDefinition();
    if (!tx) {
      txIdField.value = '';
      labelField.value = '';
      viewBtn.classList.add('d-none');
      viewBtn.setAttribute('href', '#');
      return;
    }
    txIdField.value = String(tx.id || '');
    labelField.value = [String(tx.code || tx.id || '').trim(), String(tx.name || '').trim()].filter(Boolean).join(' - ');
    viewBtn.classList.remove('d-none');
    viewBtn.setAttribute('href', '/school/transactionTemplates/edit/' + encodeURIComponent(String(tx.id || '')));
  }

  function getTodayIso() {
    return (window.AppOrgDateTime && AppOrgDateTime.today) ? String(AppOrgDateTime.today) : '';
  }

  function isExpiredDefinition(definitionLike) {
    const validTo = String((definitionLike && definitionLike.validTo) || '').trim();
    return !!validTo && validTo < getTodayIso();
  }

  function normalizeSubjects() {
    subjects = subjects.map(function (s, idx) {
      const master = resolveSubjectMaster(s.subjectId || s.id || '');
      const defaultRules = getSubjectDefaultScoreRules(s.subjectId || s.id || '');
      const subjectType = String(s.subjectType || (s.isRequired === false ? 'essential' : 'main')).trim().toLowerCase() || 'main';
      const defaultCredits = master && master.configuration ? Number(master.configuration.credits) : null;
      const programCreditsRaw = (s.programCredits === null || s.programCredits === undefined || s.programCredits === '')
        ? defaultCredits
        : s.programCredits;
      return {
        subjectId: String(s.subjectId || '').trim(),
        order: Number(s.order || (idx + 1)),
        isRequired: subjectType === 'main',
        subjectType: subjectTypes.includes(subjectType) ? subjectType : 'main',
        programCredits: (programCreditsRaw === null || programCreditsRaw === undefined || programCreditsRaw === '') ? 0 : Number(programCreditsRaw),
        minPassingScore: (s.minPassingScore === null || s.minPassingScore === undefined || s.minPassingScore === '')
          ? defaultRules.minPassingScore
          : Number(s.minPassingScore),
        minPassingAverage: (s.minPassingAverage === null || s.minPassingAverage === undefined || s.minPassingAverage === '')
          ? defaultRules.minPassingAverage
          : Number(s.minPassingAverage),
        mustPass: s.mustPass === undefined
          ? (defaultRules.mustPass || subjectType === 'main')
          : (s.mustPass === true || String(s.mustPass) === 'true'),
        allowCompensation: s.allowCompensation === undefined
          ? defaultRules.allowCompensation
          : (s.allowCompensation === true || String(s.allowCompensation) === 'true'),
        prerequisites: Array.isArray(s.prerequisites) ? s.prerequisites.map(function (x) { return String(x); }) : [],
        notes: String(s.notes || defaultRules.notes || ''),
        subjectCode: String(master?.code || s.subjectCode || s.code || ''),
        subjectTitle: String(master?.title || s.subjectTitle || s.title || s.name || s.subjectId || ''),
        subjectStatus: String(master?.status || s.subjectStatus || '').trim().toLowerCase()
      };
    }).filter(function (s) { return !!s.subjectId; });

    subjects.sort(function (a, b) { return a.order - b.order; });
    subjects.forEach(function (s, i) { s.order = i + 1; });
  }

  function normalizeTerms() {
    terms = terms.map(function (t, idx) {
      const termId = String(t.termId || t.id || '').trim();
      const snapshot = buildTermSnapshot(getTermMaster(termId), t);
      const liveDates = getTermLiveDates({ termId: termId, startDate: t.startDate, endDate: t.endDate });
      return {
        termId: termId,
        order: Number(t.order || (idx + 1)),
        isRequired: t.isRequired !== false,
        notes: String(t.notes || '').trim(),
        termCode: snapshot.termCode,
        termName: snapshot.termName,
        status: snapshot.status,
        termDescription: snapshot.termDescription,
        startDate: liveDates.startDate,
        endDate: liveDates.endDate,
        registrationOpenDate: snapshot.registrationOpenDate,
        registrationCloseDate: snapshot.registrationCloseDate,
        lateRegistrationDeadline: snapshot.lateRegistrationDeadline,
        paymentDueDate: snapshot.paymentDueDate,
        classesStartDate: snapshot.classesStartDate,
        classesEndDate: snapshot.classesEndDate,
        addDropDeadline: snapshot.addDropDeadline,
        swapDeadline: snapshot.swapDeadline,
        withdrawWithoutPenaltyDeadline: snapshot.withdrawWithoutPenaltyDeadline,
        withdrawDeadline: snapshot.withdrawDeadline,
        censusDate: snapshot.censusDate,
        finalExamStartDate: snapshot.finalExamStartDate,
        finalExamEndDate: snapshot.finalExamEndDate,
        gradeSubmissionDeadline: snapshot.gradeSubmissionDeadline,
        termResultReleaseDate: snapshot.termResultReleaseDate,
        termAcademicRules: {
          minimumPassingAverage: (t.termAcademicRules && t.termAcademicRules.minimumPassingAverage !== undefined && t.termAcademicRules.minimumPassingAverage !== null && t.termAcademicRules.minimumPassingAverage !== '') ? Number(t.termAcademicRules.minimumPassingAverage) : null,
          minimumPassingScore: (t.termAcademicRules && t.termAcademicRules.minimumPassingScore !== undefined && t.termAcademicRules.minimumPassingScore !== null && t.termAcademicRules.minimumPassingScore !== '') ? Number(t.termAcademicRules.minimumPassingScore) : null,
          totalAllowedCredits: (t.termAcademicRules && t.termAcademicRules.totalAllowedCredits !== undefined && t.termAcademicRules.totalAllowedCredits !== null && t.termAcademicRules.totalAllowedCredits !== '') ? Number(t.termAcademicRules.totalAllowedCredits) : null,
          minimumRequiredCredits: (t.termAcademicRules && t.termAcademicRules.minimumRequiredCredits !== undefined && t.termAcademicRules.minimumRequiredCredits !== null && t.termAcademicRules.minimumRequiredCredits !== '') ? Number(t.termAcademicRules.minimumRequiredCredits) : null,
          allowOverload: Boolean(t.termAcademicRules && t.termAcademicRules.allowOverload),
          mustCompleteRequiredSubjects: !(t.termAcademicRules && t.termAcademicRules.mustCompleteRequiredSubjects === false),
          notes: String((t.termAcademicRules && t.termAcademicRules.notes) || '').trim()
        },
        termRegistrationFeeGroups: ensureCategoryFeeKeys(t.termRegistrationFeeGroups || t.registrationFeeGroups)
      };
    }).filter(function (t) { return !!t.termId; });

    terms.sort(function (a, b) { return a.order - b.order; });
    terms.forEach(function (t, i) { t.order = i + 1; });
  }

  function normalizePostingPolicies() {
    const seen = new Set();
    postingPolicies = (Array.isArray(postingPolicies) ? postingPolicies : []).map(function (row) {
      return {
        feeCategory: String(row?.feeCategory || ALL_FEE_CATEGORY_KEY).trim() || ALL_FEE_CATEGORY_KEY,
        transactionDefinitionId: String(row?.transactionDefinitionId || '').trim(),
        transactionDefinitionCode: String(row?.transactionDefinitionCode || '').trim().toUpperCase(),
        transactionDefinitionName: String(row?.transactionDefinitionName || '').trim(),
        notes: String(row?.notes || '').trim(),
        active: row?.active !== false && String(row?.active) !== 'false'
      };
    }).filter(function (row) {
      if (!row.transactionDefinitionId) return false;
      if (seen.has(row.feeCategory)) return false;
      seen.add(row.feeCategory);
      return true;
    });
  }

  function formatPostingPolicyLabel(row) {
    return [row.transactionDefinitionCode || '', row.transactionDefinitionName || ''].filter(Boolean).join(' - ') || row.transactionDefinitionId || '-';
  }

  function syncProgramPostingPolicySelectionUi() {
    const idField = document.getElementById('sel_programPostingPolicyDefinition');
    const labelField = document.getElementById('inp_programPostingPolicyDefinitionLabel');
    const viewBtn = document.getElementById('btnViewProgramPostingPolicyDefinition');
    const txId = String(idField?.value || '').trim();
    if (!txId) {
      labelField.value = '';
      viewBtn.classList.add('d-none');
      viewBtn.setAttribute('href', '#');
      return;
    }
    const tx = transactionDefMap.get(txId) || null;
    labelField.value = tx ? [String(tx.code || '').trim(), String(tx.name || '').trim()].filter(Boolean).join(' - ') : '';
    viewBtn.classList.remove('d-none');
    viewBtn.setAttribute('href', '/school/transactionTemplates/edit/' + encodeURIComponent(txId));
  }

  function renderPostingPolicies() {
    normalizePostingPolicies();
    const tbody = document.getElementById('programPostingPolicyTbody');
    if (!tbody) return;
    if (!postingPolicies.length) {
      tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No Posting Policies added yet.</td></tr>';
      return;
    }
    tbody.innerHTML = postingPolicies.map(function (row, index) {
      return '<tr>' +
        '<td><span class="fw-bold">' + safeHtml(getCategoryLabel(row.feeCategory === ALL_FEE_CATEGORY_KEY ? '' : row.feeCategory)) + '</span></td>' +
        '<td><div class="fw-bold">' + safeHtml(formatPostingPolicyLabel(row)) + '</div></td>' +
        '<td><span class="font-monospace">' + safeHtml(row.transactionDefinitionCode || row.transactionDefinitionId || '-') + '</span></td>' +
        '<td><span class="small text-muted">' + safeHtml(row.notes || '') + '</span></td>' +
        '<td class="text-end"><button type="button" class="btn btn-outline-danger btn-sm" data-del-program-policy="' + index + '"><i class="bi bi-trash"></i></button></td>' +
      '</tr>';
    }).join('');
    tbody.querySelectorAll('button[data-del-program-policy]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const index = Number(btn.getAttribute('data-del-program-policy'));
        if (!Number.isInteger(index) || !postingPolicies[index]) return;
        postingPolicies.splice(index, 1);
        renderPostingPolicies();
        syncHiddenState();
      });
    });
  }

  function syncHiddenState() {
    const duration = {
      years: Number(document.getElementById('inp_durationYears').value || 0),
      months: Number(document.getElementById('inp_durationMonths').value || 0),
      days: Number(document.getElementById('inp_durationDays').value || 0)
    };
    hidDuration.value = JSON.stringify(duration);
    syncAcademicRules();
    hidFeeGroups.value = JSON.stringify(feeGroups);
    normalizePostingPolicies();
    hidPostingPolicies.value = JSON.stringify(postingPolicies);
    hidTerms.value = JSON.stringify(terms.map(function (t) {
      return {
        termId: t.termId,
        order: t.order,
        isRequired: t.isRequired,
        notes: t.notes,
        termCode: t.termCode,
        termName: t.termName,
        status: t.status,
        termDescription: t.termDescription,
        registrationOpenDate: t.registrationOpenDate,
        registrationCloseDate: t.registrationCloseDate,
        lateRegistrationDeadline: t.lateRegistrationDeadline,
        paymentDueDate: t.paymentDueDate,
        classesStartDate: t.classesStartDate,
        classesEndDate: t.classesEndDate,
        addDropDeadline: t.addDropDeadline,
        swapDeadline: t.swapDeadline,
        withdrawWithoutPenaltyDeadline: t.withdrawWithoutPenaltyDeadline,
        withdrawDeadline: t.withdrawDeadline,
        censusDate: t.censusDate,
        finalExamStartDate: t.finalExamStartDate,
        finalExamEndDate: t.finalExamEndDate,
        gradeSubmissionDeadline: t.gradeSubmissionDeadline,
        termResultReleaseDate: t.termResultReleaseDate,
        termAcademicRules: t.termAcademicRules,
        termRegistrationFeeGroups: t.termRegistrationFeeGroups
      };
    }));
    hidSubjects.value = JSON.stringify(subjects.map(function (s) {
      return {
        subjectId: s.subjectId,
        order: s.order,
        isRequired: s.isRequired,
        subjectType: s.subjectType,
        programCredits: s.programCredits,
        minPassingScore: s.minPassingScore,
        minPassingAverage: s.minPassingAverage,
        mustPass: s.mustPass,
        allowCompensation: s.allowCompensation,
        prerequisites: s.prerequisites,
        notes: s.notes
      };
    }));
    hidAcademicRules.value = JSON.stringify(academicRules || {});
  }

  function renderFeeLines() {
    const groupedRows = [ALL_FEE_CATEGORY_KEY].concat(feeCategories).map(function (cat) {
      return {
        category: cat,
        rows: (feeGroups[cat] || []).map(function (line, idx) {
          return {
            category: cat,
            index: idx,
            transactionDefinitionId: String(line.transactionDefinitionId || ''),
            transactionDefinitionCode: String(line.transactionDefinitionCode || ''),
            transactionDefinitionName: String(line.transactionDefinitionName || ''),
            code: String(line.code || ''),
            label: String(line.label || ''),
            amount: (line.amount === null || line.amount === undefined || line.amount === '') ? null : Number(line.amount),
            currency: String(line.currency || ''),
            validFrom: String(line.validFrom || ''),
            validTo: String(line.validTo || '')
          };
        })
      };
    }).filter(function (group) { return group.rows.length > 0; });

    if (!groupedRows.length) {
      feeLinesTbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No fee lines added yet.</td></tr>';
      syncHiddenState();
      return;
    }

    feeLinesTbody.innerHTML = groupedRows.map(function (group) {
      const header = '<tr class="table-light">' +
        '<td colspan="5"><span class="fw-bold">' + safeHtml(getCategoryLabel(group.category === ALL_FEE_CATEGORY_KEY ? '' : group.category)) + '</span></td>' +
      '</tr>';
      const rowsHtml = group.rows.map(function (r) {
        const txLabel = r.transactionDefinitionId
          ? (r.transactionDefinitionCode || r.transactionDefinitionId) + (r.transactionDefinitionName ? ' - ' + r.transactionDefinitionName : '')
          : 'Manual row';
        const validityLabel = r.validFrom || r.validTo
          ? ('Valid: ' + safeHtml(r.validFrom || 'Open') + ' to ' + safeHtml(r.validTo || 'Open'))
          : 'Unlimited validity';
        const expiredBadge = isExpiredDefinition(r)
          ? '<span class="badge bg-warning text-dark border ms-2">Expired</span>'
          : '';
        const detailBtn = r.transactionDefinitionId
          ? '<a href="/school/transactionTemplates/edit/' + encodeURIComponent(r.transactionDefinitionId) + '" class="btn btn-outline-info btn-sm" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right me-1"></i>View</a>'
          : '';
        return '<tr>' +
          '<td><span class="small text-dark">' + safeHtml(txLabel) + expiredBadge + '<div class="x-small text-muted">' + validityLabel + '</div></span></td>' +
          '<td><div class="fw-bold">' + safeHtml(r.code || '(no-code)') + '</div><div class="small text-muted">' + safeHtml(r.label || '') + '</div></td>' +
          '<td class="fw-bold">' + safeHtml(r.amount === null || Number.isNaN(r.amount) ? '-' : r.amount.toFixed(2)) + '</td>' +
          '<td>' + safeHtml(r.currency || '-') + '</td>' +
          '<td class="text-end"><div class="d-flex gap-2 justify-content-end">' + detailBtn + '<button type="button" class="btn btn-outline-danger btn-sm" data-del-cat="' + safeHtml(r.category) + '" data-del-idx="' + r.index + '"><i class="bi bi-trash me-1"></i>Delete</button></div></td>' +
        '</tr>';
      }).join('');
      return header + rowsHtml;
    }).join('');

    feeLinesTbody.querySelectorAll('button[data-del-cat]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const cat = btn.getAttribute('data-del-cat');
        const idx = Number(btn.getAttribute('data-del-idx'));
        if (!feeGroups[cat] || Number.isNaN(idx) || idx < 0 || idx >= feeGroups[cat].length) return;
        feeGroups[cat].splice(idx, 1);
        renderFeeLines();
      });
    });

    syncHiddenState();
  }

  function renderTerms() {
    if (!terms.length) {
      termsTbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-3">No terms added yet.</td></tr>';
      syncHiddenState();
      return;
    }

    termsTbody.innerHTML = terms.map(function (t, idx) {
      const metaParts = [];
      if (t.status) metaParts.push(t.status);
      if (t.startDate || t.endDate) metaParts.push([t.startDate || '?', t.endDate || '?'].join(' to '));
      if (t.classesStartDate || t.classesEndDate) metaParts.push('Classes ' + [t.classesStartDate || '?', t.classesEndDate || '?'].join(' to '));
      const snapshotSummary = [];
      if (t.registrationOpenDate || t.registrationCloseDate) snapshotSummary.push('Reg ' + [t.registrationOpenDate || '?', t.registrationCloseDate || '?'].join(' to '));
      if (t.addDropDeadline) snapshotSummary.push('Add/Drop ' + t.addDropDeadline);
      if (t.paymentDueDate) snapshotSummary.push('Payment ' + t.paymentDueDate);
      return '<tr>' +
        '<td>' +
          '<div class="d-flex align-items-center gap-2">' +
            '<span class="badge bg-primary">' + t.order + '</span>' +
            '<div class="btn-group btn-group-sm" role="group" aria-label="Reorder term">' +
              '<button type="button" class="btn btn-outline-secondary btn-sm" data-term-up="' + idx + '"' + (idx <= 0 ? ' disabled' : '') + '><i class="bi bi-arrow-up"></i></button>' +
              '<button type="button" class="btn btn-outline-secondary btn-sm" data-term-down="' + idx + '"' + (idx >= terms.length - 1 ? ' disabled' : '') + '><i class="bi bi-arrow-down"></i></button>' +
            '</div>' +
          '</div>' +
        '</td>' +
        '<td><div class="fw-bold">' + safeHtml(t.termName || t.termId) + '</div><div class="x-small text-muted font-monospace">' + safeHtml(t.termCode || t.termId) + (metaParts.length ? ' | ' + safeHtml(metaParts.join(' | ')) : '') + '</div>' + (snapshotSummary.length ? '<div class="x-small text-muted mt-1">' + safeHtml(snapshotSummary.join(' | ')) + '</div>' : '') + '</td>' +
        '<td><div class="form-check"><input class="form-check-input" type="checkbox" data-term-required="' + idx + '" ' + (t.isRequired ? 'checked' : '') + '></div></td>' +
        '<td class="text-end">' +
          '<button type="button" class="btn btn-outline-secondary btn-sm" data-term-details="' + idx + '" aria-label="Open term details">' +
            '<i class="bi bi-three-dots"></i>' +
          '</button>' +
        '</td>' +
      '</tr>';
    }).join('');

    termsTbody.querySelectorAll('input[data-term-required]').forEach(function (input) {
      input.addEventListener('change', function () {
        const i = Number(input.getAttribute('data-term-required'));
        if (Number.isNaN(i) || i < 0 || i >= terms.length) return;
        terms[i].isRequired = input.checked;
        if (editingTermDetailsIndex === i) {
          document.getElementById('chk_termDetailsRequired').checked = input.checked;
        }
        syncHiddenState();
      });
    });

    termsTbody.querySelectorAll('button[data-term-details]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const i = Number(btn.getAttribute('data-term-details'));
        if (Number.isNaN(i) || i < 0 || i >= terms.length) return;
        openTermDetailsModal(i);
      });
    });

    termsTbody.querySelectorAll('button[data-term-up]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const i = Number(btn.getAttribute('data-term-up'));
        if (i <= 0) return;
        const prev = terms[i - 1];
        const curr = terms[i];
        terms[i - 1] = curr;
        terms[i] = prev;
        const tmpOrder = Number(prev.order);
        prev.order = Number(curr.order);
        curr.order = tmpOrder;
        normalizeTerms();
        renderTerms();
      });
    });

    termsTbody.querySelectorAll('button[data-term-down]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const i = Number(btn.getAttribute('data-term-down'));
        if (i >= terms.length - 1) return;
        const curr = terms[i];
        const next = terms[i + 1];
        terms[i] = next;
        terms[i + 1] = curr;
        const tmpOrder = Number(curr.order);
        curr.order = Number(next.order);
        next.order = tmpOrder;
        normalizeTerms();
        renderTerms();
      });
    });

    syncHiddenState();
  }

  function summarizeFeeGroups(groups) {
    const normalized = ensureCategoryFeeKeys(groups);
    let count = 0;
    let total = 0;
    Object.keys(normalized).forEach(function (cat) {
      (normalized[cat] || []).forEach(function (row) {
        count += 1;
        const amount = Number(row && row.amount);
        if (Number.isFinite(amount)) total += amount;
      });
    });
    if (!count) return { label: 'No fees', details: 'None configured' };
    return { label: count + ' fee' + (count === 1 ? '' : 's'), details: total.toFixed(2) + ' total' };
  }

  function summarizeTermAcademicRules(rules) {
    const r = (rules && typeof rules === 'object') ? rules : {};
    const parts = [];
    if (r.minimumPassingAverage !== null && r.minimumPassingAverage !== undefined && r.minimumPassingAverage !== '') {
      parts.push('Avg >= ' + formatCredit(r.minimumPassingAverage));
    }
    if (r.totalAllowedCredits !== null && r.totalAllowedCredits !== undefined && r.totalAllowedCredits !== '') {
      parts.push('Credits <= ' + formatCredit(r.totalAllowedCredits));
    }
    if (r.minimumRequiredCredits !== null && r.minimumRequiredCredits !== undefined && r.minimumRequiredCredits !== '') {
      parts.push('Min credits ' + formatCredit(r.minimumRequiredCredits));
    }
    if (r.mustCompleteRequiredSubjects) parts.push('Required subjects enforced');
    return {
      label: parts.length ? 'Configured' : 'Default',
      details: parts.length ? parts.join(' | ') : 'No term-specific academic rules'
    };
  }

