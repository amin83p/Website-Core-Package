  function assertNoTermFeeDateConflict(categoryKey, transactionDefinitionId) {
    const tx = transactionDefinitionId ? transactionDefMap.get(String(transactionDefinitionId)) : null;
    if (!tx || !tx.validFrom || !tx.validTo) return;
    const targetCategory = categoryKey || ALL_FEE_CATEGORY_KEY;
    const rows = Array.isArray(getEditingTermFeeGroups()[targetCategory]) ? getEditingTermFeeGroups()[targetCategory] : [];
    rows.forEach(function (row) {
      const existingTxId = String(row.transactionDefinitionId || '').trim();
      if (!existingTxId) return;
      const existingStart = String(row.validFrom || '').trim();
      const existingEnd = String(row.validTo || '').trim();
      if (rangesOverlap(String(tx.validFrom || ''), String(tx.validTo || ''), existingStart, existingEnd)) {
        const categoryLabel = getCategoryLabel(targetCategory === ALL_FEE_CATEGORY_KEY ? '' : targetCategory);
        throw new Error('Date conflict detected with existing transaction template "' +
          String(row.transactionDefinitionCode || row.code || existingTxId) +
          '" in ' + categoryLabel + '.');
      }
    });
  }

  function renderTermFeeLines() {
    const tbody = document.getElementById('termFeeLinesTbody');
    const groups = getEditingTermFeeGroups();
    const groupedRows = [ALL_FEE_CATEGORY_KEY].concat(feeCategories).map(function (cat) {
      return {
        category: cat,
        rows: (groups[cat] || []).map(function (line, idx) {
          return {
            category: cat,
            index: idx,
            transactionDefinitionId: String(line.transactionDefinitionId || ''),
            transactionDefinitionCode: String(line.transactionDefinitionCode || ''),
            transactionDefinitionName: String(line.transactionDefinitionName || ''),
            code: String(line.code || ''),
            label: String(line.label || ''),
            amount: (line.amount === null || line.amount === undefined || line.amount === '') ? null : Number(line.amount),
            currency: String(line.currency || ''),
            validFrom: String(line.validFrom || ''),
            validTo: String(line.validTo || '')
          };
        })
      };
    }).filter(function (group) { return group.rows.length > 0; });

    if (!groupedRows.length) {
      tbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No term registration fees added yet.</td></tr>';
      syncHiddenState();
      return;
    }

    tbody.innerHTML = groupedRows.map(function (group) {
      const header = '<tr class="table-light"><td colspan="5"><span class="fw-bold">' + safeHtml(getCategoryLabel(group.category === ALL_FEE_CATEGORY_KEY ? '' : group.category)) + '</span></td></tr>';
      const rowsHtml = group.rows.map(function (r) {
        const txLabel = (r.transactionDefinitionCode || r.transactionDefinitionId) + (r.transactionDefinitionName ? ' - ' + r.transactionDefinitionName : '');
        const validityLabel = r.validFrom || r.validTo
          ? ('Valid: ' + safeHtml(r.validFrom || '?') + ' to ' + safeHtml(r.validTo || '?'))
          : 'No definition validity';
        return '<tr>' +
          '<td><span class="small text-dark">' + safeHtml(txLabel) + '<div class="x-small text-muted">' + validityLabel + '</div></span></td>' +
          '<td><div class="fw-bold">' + safeHtml(r.code || '(no-code)') + '</div><div class="small text-muted">' + safeHtml(r.label || '') + '</div></td>' +
          '<td class="fw-bold">' + safeHtml(r.amount === null || Number.isNaN(r.amount) ? '-' : r.amount.toFixed(2)) + '</td>' +
          '<td>' + safeHtml(r.currency || '-') + '</td>' +
          '<td class="text-end"><div class="d-flex gap-2 justify-content-end"><a href="/school/transactionTemplates/edit/' + encodeURIComponent(r.transactionDefinitionId) + '" class="btn btn-outline-info btn-sm" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right me-1"></i>View</a><button type="button" class="btn btn-outline-danger btn-sm" data-termfee-del-cat="' + safeHtml(r.category) + '" data-termfee-del-idx="' + r.index + '"><i class="bi bi-trash me-1"></i>Delete</button></div></td>' +
        '</tr>';
      }).join('');
      return header + rowsHtml;
    }).join('');

    tbody.querySelectorAll('button[data-termfee-del-cat]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const cat = btn.getAttribute('data-termfee-del-cat');
        const idx = Number(btn.getAttribute('data-termfee-del-idx'));
        if (!groups[cat] || Number.isNaN(idx) || idx < 0 || idx >= groups[cat].length) return;
        groups[cat].splice(idx, 1);
        renderTermFeeLines();
        renderTerms();
      });
    });

    syncHiddenState();
  }

