  function renderSubjects() {
    if (!subjects.length) {
      subjectsTbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">No subjects added yet.</td></tr>';
      syncHiddenState();
      return;
    }

    subjectsTbody.innerHTML = subjects.map(function (s, idx) {
      const pre = getPrerequisiteLabels(s).join(', ');
      const display = getSubjectDisplay(s);
      const statusBadge = display.status && display.status !== 'active'
        ? '<div class="x-small text-warning fw-bold mt-1">Status: ' + safeHtml(display.status) + '</div>'
        : '';
      const typeOptions = subjectTypes.map(function (type) {
        return '<option value="' + safeHtml(type) + '" ' + (String(s.subjectType || 'main') === type ? 'selected' : '') + '>' +
          safeHtml(type.charAt(0).toUpperCase() + type.slice(1)) + '</option>';
      }).join('');
      const ruleSummary = [
        s.minPassingScore !== null && s.minPassingScore !== undefined ? ('Min score: ' + safeHtml(formatCredit(s.minPassingScore))) : '',
        s.minPassingAverage !== null && s.minPassingAverage !== undefined ? ('Min average: ' + safeHtml(formatCredit(s.minPassingAverage))) : '',
        s.mustPass ? 'Must pass' : '',
        s.allowCompensation ? 'Compensation allowed' : ''
      ].filter(Boolean).join(' | ');
      return '<tr>' +
        '<td><span class="badge bg-primary">' + s.order + '</span></td>' +
        '<td><div class="fw-bold">' + safeHtml(display.title || s.subjectId) + '</div><div class="x-small text-muted font-monospace">' + safeHtml(display.code || s.subjectId) + '</div>' + statusBadge + '</td>' +
        '<td><select class="form-select form-select-sm" data-subject-type="' + idx + '">' + typeOptions + '</select></td>' +
        '<td><input type="number" class="form-control form-control-sm" data-subject-credits="' + idx + '" min="0" step="0.01" value="' + safeHtml(formatCredit(s.programCredits)) + '"></td>' +
        '<td><span class="small text-muted">' + safeHtml(pre || 'None') + '</span></td>' +
        '<td><span class="small text-muted">' + safeHtml(ruleSummary || 'Default program rules') + '</span></td>' +
        '<td class="text-end">' +
          '<div class="d-flex gap-2 justify-content-end">' +
            '<button type="button" class="btn btn-outline-secondary btn-sm" data-up="' + idx + '"><i class="bi bi-arrow-up"></i></button>' +
            '<button type="button" class="btn btn-outline-secondary btn-sm" data-down="' + idx + '"><i class="bi bi-arrow-down"></i></button>' +
            '<button type="button" class="btn btn-outline-info btn-sm" data-rules="' + idx + '">Rules</button>' +
            '<button type="button" class="btn btn-outline-primary btn-sm" data-pre="' + idx + '">Prerequisites</button>' +
            '<button type="button" class="btn btn-outline-danger btn-sm" data-del-sub="' + idx + '">Remove</button>' +
          '</div>' +
        '</td>' +
      '</tr>';
    }).join('');

    subjectsTbody.querySelectorAll('button[data-up]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const i = Number(btn.getAttribute('data-up'));
        if (i <= 0) return;
        const prev = subjects[i - 1];
        const curr = subjects[i];
        subjects[i - 1] = curr;
        subjects[i] = prev;
        const tmpOrder = Number(prev.order);
        prev.order = Number(curr.order);
        curr.order = tmpOrder;
        normalizeSubjects();
        renderSubjects();
      });
    });

    subjectsTbody.querySelectorAll('button[data-down]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const i = Number(btn.getAttribute('data-down'));
        if (i >= subjects.length - 1) return;
        const curr = subjects[i];
        const next = subjects[i + 1];
        subjects[i] = next;
        subjects[i + 1] = curr;
        const tmpOrder = Number(curr.order);
        curr.order = Number(next.order);
        next.order = tmpOrder;
        normalizeSubjects();
        renderSubjects();
      });
    });

    subjectsTbody.querySelectorAll('button[data-del-sub]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const i = Number(btn.getAttribute('data-del-sub'));
        if (Number.isNaN(i) || i < 0 || i >= subjects.length) return;
        const removedId = subjects[i].subjectId;
        subjects.splice(i, 1);
        subjects.forEach(function (s) {
          s.prerequisites = (s.prerequisites || []).filter(function (pid) { return pid !== removedId; });
        });
        normalizeSubjects();
        renderSubjects();
      });
    });

    subjectsTbody.querySelectorAll('button[data-pre]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const i = Number(btn.getAttribute('data-pre'));
        if (Number.isNaN(i) || i < 0 || i >= subjects.length) return;
        openPrereqModal(i);
      });
    });

    subjectsTbody.querySelectorAll('button[data-rules]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const i = Number(btn.getAttribute('data-rules'));
        if (Number.isNaN(i) || i < 0 || i >= subjects.length) return;
        openSubjectRuleModal(i);
      });
    });

    subjectsTbody.querySelectorAll('select[data-subject-type]').forEach(function (select) {
      select.addEventListener('change', function () {
        const i = Number(select.getAttribute('data-subject-type'));
        if (Number.isNaN(i) || i < 0 || i >= subjects.length) return;
        subjects[i].subjectType = select.value;
        subjects[i].isRequired = select.value === 'main';
        syncHiddenState();
      });
    });

    subjectsTbody.querySelectorAll('input[data-subject-credits]').forEach(function (input) {
      input.addEventListener('input', function () {
        const i = Number(input.getAttribute('data-subject-credits'));
        if (Number.isNaN(i) || i < 0 || i >= subjects.length) return;
        const nextValue = input.value === '' ? 0 : Number(input.value);
        subjects[i].programCredits = Number.isFinite(nextValue) ? nextValue : 0;
        syncHiddenState();
      });
    });

    syncHiddenState();
  }

