<%
  const d = transactionDefinition || {};
  const isEdit = !!d.id;
  const routeId = (d.id || '');
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
  const metadataText = JSON.stringify(d.metadata || {}, null, 2);
  const initEntries = JSON.stringify(Array.isArray(d.entries) ? d.entries : []).replace(/</g, '\\u003c');
  const initMemoCommonPlaceholders = JSON.stringify(memoCommonPlaceholders || []).replace(/</g, '\\u003c');
  const initMemoPlaceholdersByRole = JSON.stringify(memoPlaceholdersByRole || {}).replace(/</g, '\\u003c');
  const initPostingAccounts = JSON.stringify(postingAccounts || []).replace(/</g, '\\u003c');
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-heading size-md m-0"><i class="bi bi-receipt-cutoff me-2"></i><%= title %></h1>
    <div class="d-flex align-items-center gap-2">
      <button type="button" class="btn btn-outline-primary btn-md" id="btnCopyFromDefinition">
        <i class="bi bi-copy me-1"></i> Copy From Template
      </button>
      <a href="/school/transactionTemplates" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back to List</a>
    </div>
  </div>

  <div class="form-container wide" style="max-width: 1300px;">
    <form id="transactionDefinitionForm" action="<%= isEdit ? '/school/transactionTemplates/edit/'+routeId : '/school/transactionTemplates/new' %>" method="POST">
      <input type="hidden" name="actionStateId" id="hid_actionStateId" value="<%= asid %>">
      <input type="hidden" name="entries" id="hid_entries" value="[]">

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
          <div class="row">
            <div class="col-md-3 mb-3">
              <label class="form-label fw-bold">Template ID</label>
              <input type="text" name="transactionDefinitionId" class="form-control size-md font-monospace" value="<%= d.id || '' %>" placeholder="Auto-generated if blank" <%= isEdit ? 'readonly' : '' %>>
            </div>
            <div class="col-md-3 mb-3">
              <label class="form-label fw-bold">Code *</label>
              <input type="text" name="code" class="form-control size-md font-monospace" value="<%= d.code || '' %>" placeholder="e.g. TUITION-CHARGE" required>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label fw-bold">Name *</label>
              <input type="text" name="name" class="form-control size-md" value="<%= d.name || '' %>" placeholder="e.g. Tuition Posting Template" required>
            </div>
          </div>

          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">Status *</label>
              <select name="status" class="form-select size-md" required>
                <% (definitionStatuses || []).forEach(st => { %>
                  <option value="<%= st %>" <%= (d.status || 'active') === st ? 'selected' : '' %>><%= st %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-8 mb-3">
              <label class="form-label fw-bold">Description</label>
              <input type="text" name="description" class="form-control size-md" value="<%= d.description || '' %>" placeholder="Describe when this transaction template is used.">
            </div>
          </div>

          <div class="row">
            <div class="col-md-3 mb-3">
              <label class="form-label fw-bold">Valid From</label>
              <input type="date" name="validFrom" class="form-control size-md" value="<%= d.validFrom || '' %>">
            </div>
            <div class="col-md-3 mb-3">
              <label class="form-label fw-bold">Valid To</label>
              <input type="date" name="validTo" class="form-control size-md" value="<%= d.validTo || '' %>">
            </div>
            <div class="col-md-6 mb-3">
              <div class="small text-muted pt-4 mt-2">Leave both dates blank for unlimited validity. You can also set only one side for open-ended validity.</div>
            </div>
          </div>

          <div class="alert alert-info border-info shadow-sm mb-3">
            <i class="bi bi-arrow-left-right me-2"></i>Define one or more double-entry rows. You can reference fixed accounts or role placeholders.
          </div>
          <div class="alert alert-warning border-warning shadow-sm mb-3">
            <div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle me-2"></i>Runtime Amount Template Rule</div>
            <div class="small">
              For runtime templates, set each entry <strong>Amount = 0</strong> and use <strong>Percentage</strong> to distribute the final applied amount across rows.
              Runtime entry percentages must total <strong>100%</strong>. If you enter non-zero amounts, the template will use those fixed amounts and percentages will be derived automatically.
            </div>
          </div>

          <div class="row g-3 mb-1">
            <div class="col-12">
              <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                <div class="d-flex align-items-center gap-2 mb-3">
                  <span class="badge bg-success">Debit</span>
                  <div class="small text-muted">Choose how the debit side should resolve.</div>
                </div>
                <div class="row align-items-start">
                  <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Debit Type *</label>
                    <select id="inp_debitRefType" class="form-select size-md">
                      <option value="ACCOUNT">Account</option>
                      <option value="ROLE">Role</option>
                    </select>
                  </div>
                  <div class="col-md-8 mb-3">
                    <label class="form-label fw-bold" id="lbl_debitReference">Debit Account *</label>
                    <div id="debitAccountPickerWrap">
                      <div class="input-group">
                        <input type="hidden" id="inp_debitAccountRef">
                        <input type="text" id="inp_debitAccountLabel" class="form-control size-md bg-white" placeholder="Search account by code or name..." readonly>
                        <button type="button" class="btn btn-outline-primary" id="btnPickDebitAccount"><i class="bi bi-search"></i></button>
                        <button type="button" class="btn btn-outline-secondary" id="btnClearDebitAccount"><i class="bi bi-x-lg"></i></button>
                      </div>
                    </div>
                    <div id="debitRoleWrap" class="d-none">
                      <select id="inp_debitRoleRef" class="form-select size-md">
                        <option value="">-- Select Role --</option>
                        <% (partyRoleOptions || []).forEach(role => { %>
                          <option value="ROLE:<%= role %>"><%= role %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="form-text small" id="debitReferenceHint">Pick a fixed posting account for the debit side.</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-3 mb-1">
            <div class="col-12">
              <div class="border rounded-3 p-3 h-100 bg-light-subtle">
                <div class="d-flex align-items-center gap-2 mb-3">
                  <span class="badge bg-danger">Credit</span>
                  <div class="small text-muted">Choose how the credit side should resolve.</div>
                </div>
                <div class="row align-items-start">
                  <div class="col-md-4 mb-3">
                    <label class="form-label fw-bold">Credit Type *</label>
                    <select id="inp_creditRefType" class="form-select size-md">
                      <option value="ACCOUNT">Account</option>
                      <option value="ROLE">Role</option>
                    </select>
                  </div>
                  <div class="col-md-8 mb-3">
                    <label class="form-label fw-bold" id="lbl_creditReference">Credit Account *</label>
                    <div id="creditAccountPickerWrap">
                      <div class="input-group">
                        <input type="hidden" id="inp_creditAccountRef">
                        <input type="text" id="inp_creditAccountLabel" class="form-control size-md bg-white" placeholder="Search account by code or name..." readonly>
                        <button type="button" class="btn btn-outline-primary" id="btnPickCreditAccount"><i class="bi bi-search"></i></button>
                        <button type="button" class="btn btn-outline-secondary" id="btnClearCreditAccount"><i class="bi bi-x-lg"></i></button>
                      </div>
                    </div>
                    <div id="creditRoleWrap" class="d-none">
                      <select id="inp_creditRoleRef" class="form-select size-md">
                        <option value="">-- Select Role --</option>
                        <% (partyRoleOptions || []).forEach(role => { %>
                          <option value="ROLE:<%= role %>"><%= role %></option>
                        <% }) %>
                      </select>
                    </div>
                    <div class="form-text small" id="creditReferenceHint">Pick a fixed posting account for the credit side.</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-3 mt-2">
            <div class="col-md-3 mb-3">
              <label class="form-label fw-bold">Amount *</label>
              <input type="number" id="inp_amount" class="form-control size-md" min="0" step="0.01">
              <div class="form-text small">Use <strong>0</strong> for runtime templates such as class fee posting templates.</div>
            </div>
            <div class="col-md-2 mb-3">
              <label class="form-label fw-bold">Percentage</label>
              <div class="input-group">
                <input type="number" id="inp_percentage" class="form-control size-md" min="0" max="100" step="0.01" placeholder="0-100">
                <span class="input-group-text">%</span>
              </div>
              <div class="form-text small">Required for multi-row runtime templates. Total runtime percentage must be 100%.</div>
            </div>
            <div class="col-md-2 mb-3">
              <label class="form-label fw-bold">Currency *</label>
              <input type="text" id="inp_currency" class="form-control size-md font-monospace" maxlength="3" value="CAD">
              <div class="form-text small">Used for fixed rows or as the fallback currency for runtime rows.</div>
            </div>
            <div class="col-md-2 mb-3">
              <label class="form-label fw-bold">Memo Role</label>
              <select id="inp_memoRole" class="form-select size-md">
                <option value="">-- Select Role --</option>
                <% (partyRoleOptions || []).forEach(role => { %>
                  <option value="<%= role %>"><%= role %></option>
                <% }) %>
              </select>
              <div class="form-text small">Optional role context for memo placeholders.</div>
            </div>
            <div class="col-md-3 mb-3">
              <label class="form-label fw-bold">Entry Notes</label>
              <input type="text" id="inp_entryNotes" class="form-control size-md" placeholder="Optional">
              <div class="form-text small">Internal note for this template row.</div>
            </div>
          </div>

          <div class="row align-items-end">
            <div class="col-md-9 mb-3">
              <label class="form-label fw-bold">Memo Template</label>
              <input type="text" id="inp_memoTemplate" class="form-control size-md" placeholder="e.g. Tuition charge for {{studentId}}">
            </div>
            <div class="col-md-3 mb-3">
              <button type="button" class="btn btn-filled btn-primary btn-sm w-100" id="btnAddEntry"><i class="bi bi-plus-circle me-1"></i>Add Entry</button>
            </div>
          </div>

          <div class="row">
            <div class="col-12 mb-3">
              <div id="memoPlaceholderPanel" class="alert alert-light border py-2 d-none mb-0">
                <div class="small fw-bold mb-1">Memo Placeholders</div>
                <div id="memoPlaceholderHint" class="small text-muted mb-2"></div>
                <div id="memoPlaceholderList" class="d-flex flex-wrap gap-2"></div>
              </div>
            </div>
          </div>

          <div class="table-responsive">
            <table class="table table-sm align-middle">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Debit</th>
                  <th>Credit</th>
                  <th>Posting Details</th>
                  <th>Memo / Notes</th>
                  <th class="text-end">Actions</th>
                </tr>
              </thead>
              <tbody id="entriesTbody"></tbody>
            </table>
          </div>
          <div id="entryTemplateSummary" class="small mt-2 text-muted"></div>

          <div class="row mt-3">
            <div class="col-md-8 mb-3">
              <label class="form-label fw-bold">Notes</label>
              <textarea name="notes" class="form-control size-md" rows="3" placeholder="Internal notes..."><%= d.notes || '' %></textarea>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">Metadata (JSON)</label>
              <textarea name="metadata" id="metadataField" class="form-control size-md font-monospace" rows="3"><%= metadataText %></textarea>
            </div>
          </div>
        </div>
      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md fw-bold px-4">Save Template</button>
        <a href="/school/transactionTemplates" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction" data-return-url="/school/transactionTemplates">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('../../partials/modal_GenericPicker') %>

<script>
  window.__INIT_TRANSACTION_DEF_ENTRIES__ = <%- initEntries %>;
  window.__TXD_MEMO_COMMON__ = <%- initMemoCommonPlaceholders %>;
  window.__TXD_MEMO_BY_ROLE__ = <%- initMemoPlaceholdersByRole %>;
  window.__TXD_POSTING_ACCOUNTS__ = <%- initPostingAccounts %>;
</script>

<script>
(function () {
  const form = document.getElementById('transactionDefinitionForm');
  const currentDefinitionId = <%- JSON.stringify(routeId || '') %>;
  const entriesTbody = document.getElementById('entriesTbody');
  const hidEntries = document.getElementById('hid_entries');
  const metadataField = document.getElementById('metadataField');
  const debitRefTypeField = document.getElementById('inp_debitRefType');
  const creditRefTypeField = document.getElementById('inp_creditRefType');
  const debitAccountRefField = document.getElementById('inp_debitAccountRef');
  const creditAccountRefField = document.getElementById('inp_creditAccountRef');
  const debitAccountLabelField = document.getElementById('inp_debitAccountLabel');
  const creditAccountLabelField = document.getElementById('inp_creditAccountLabel');
  const debitRoleField = document.getElementById('inp_debitRoleRef');
  const creditRoleField = document.getElementById('inp_creditRoleRef');
  const debitReferenceLabel = document.getElementById('lbl_debitReference');
  const creditReferenceLabel = document.getElementById('lbl_creditReference');
  const debitReferenceHint = document.getElementById('debitReferenceHint');
  const creditReferenceHint = document.getElementById('creditReferenceHint');
  const amountField = document.getElementById('inp_amount');
  const percentageField = document.getElementById('inp_percentage');
  const memoTemplateField = document.getElementById('inp_memoTemplate');
  const memoRoleField = document.getElementById('inp_memoRole');
  const memoPlaceholderPanel = document.getElementById('memoPlaceholderPanel');
  const memoPlaceholderHint = document.getElementById('memoPlaceholderHint');
  const memoPlaceholderList = document.getElementById('memoPlaceholderList');
  const entryTemplateSummary = document.getElementById('entryTemplateSummary');
  const memoCommonPlaceholders = Array.isArray(window.__TXD_MEMO_COMMON__) ? window.__TXD_MEMO_COMMON__ : [];
  const memoPlaceholdersByRole = window.__TXD_MEMO_BY_ROLE__ && typeof window.__TXD_MEMO_BY_ROLE__ === 'object'
    ? window.__TXD_MEMO_BY_ROLE__
    : {};
  const postingAccounts = Array.isArray(window.__TXD_POSTING_ACCOUNTS__) ? window.__TXD_POSTING_ACCOUNTS__ : [];
  const postingAccountMap = new Map(postingAccounts.map(function (acc) { return [String(acc.id || ''), acc]; }));
  let entries = [];

  function showMsg(opts) {
    if (typeof showMessageModal === 'function') return showMessageModal(opts);
    alert(opts?.message || 'Done');
    return Promise.resolve();
  }

  function safeHtml(s) {
    return String(s ?? '').replace(/[&<>"']/g, function (m) {
      return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[m];
    });
  }

  function roundToTwo(value) {
    const num = Number(value || 0);
    if (!Number.isFinite(num)) return 0;
    return Number(num.toFixed(2));
  }

  function normalizePercentageValue(value) {
    if (value === '' || value === null || value === undefined) return 0;
    const num = Number(value);
    if (!Number.isFinite(num) || num < 0) return 0;
    return roundToTwo(Math.min(num, 100));
  }

  function normalizeEntry(entry, index) {
    return {
      entryId: String(entry?.entryId || ('ENTRY_' + (index + 1))).trim() || ('ENTRY_' + (index + 1)),
      debitRef: String(entry?.debitRef || '').trim(),
      creditRef: String(entry?.creditRef || '').trim(),
      amount: roundToTwo(entry?.amount),
      percentage: normalizePercentageValue(entry?.percentage),
      currency: String(entry?.currency || 'CAD').trim().toUpperCase() || 'CAD',
      memoTemplate: String(entry?.memoTemplate || '').trim(),
      notes: String(entry?.notes || '').trim()
    };
  }

  function hasFixedAmounts(entryRows) {
    return (Array.isArray(entryRows) ? entryRows : []).some(function (entry) {
      return Number(entry?.amount || 0) > 0;
    });
  }

  function hasRuntimeRows(entryRows) {
    return (Array.isArray(entryRows) ? entryRows : []).some(function (entry) {
      return !(Number(entry?.amount || 0) > 0);
    });
  }

  function getRuntimePercentageTotal(entryRows) {
    return roundToTwo((Array.isArray(entryRows) ? entryRows : []).reduce(function (sum, entry) {
      if (Number(entry?.amount || 0) > 0) return sum;
      return sum + Number(entry?.percentage || 0);
    }, 0));
  }

  function syncEntryModeInputs(preferredSource) {
    if (!amountField || !percentageField) return;
    const amountValue = Number(amountField.value);
    const percentageValue = Number(percentageField.value);
    const hasAmount = Number.isFinite(amountValue) && amountValue > 0;
    const hasPercentage = Number.isFinite(percentageValue) && percentageValue > 0;

    if (preferredSource === 'amount' && hasAmount) {
      percentageField.value = '';
    }
    if (preferredSource === 'percentage' && hasPercentage) {
      amountField.value = '0';
    }

    const finalAmountValue = Number(amountField.value);
    const finalPercentageValue = Number(percentageField.value);
    const finalHasAmount = Number.isFinite(finalAmountValue) && finalAmountValue > 0;
    const finalHasPercentage = Number.isFinite(finalPercentageValue) && finalPercentageValue > 0;

    amountField.disabled = finalHasPercentage;
    percentageField.disabled = finalHasAmount;
  }

  function syncHidden() {
    entries = (Array.isArray(entries) ? entries : []).map(normalizeEntry);
    hidEntries.value = JSON.stringify(entries);
  }

  function applyDefinitionTemplate(item) {
    if (!item || typeof item !== 'object') return;
    form.querySelector('input[name="code"]').value = item.code || '';
    form.querySelector('input[name="name"]').value = item.name || '';
    form.querySelector('select[name="status"]').value = item.status || 'active';
    form.querySelector('input[name="description"]').value = item.description || '';
    form.querySelector('input[name="validFrom"]').value = item.validFrom || '';
    form.querySelector('input[name="validTo"]').value = item.validTo || '';
    form.querySelector('textarea[name="notes"]').value = item.notes || '';
    metadataField.value = JSON.stringify((item.metadata && typeof item.metadata === 'object' && !Array.isArray(item.metadata)) ? item.metadata : {}, null, 2);
    entries = Array.isArray(item.entries)
      ? item.entries.map(normalizeEntry)
      : [];
    renderEntries();
  }

  function formatAccountLabel(account) {
    if (!account) return '';
    const code = String(account.code || '').trim();
    const name = String(account.name || '').trim();
    const id = String(account.id || '').trim();
    return (code && name) ? (code + ' - ' + name) : (name || code || id);
  }

  function isAccountActivePostable(account) {
    const status = String(account?.status || '').trim().toLowerCase();
    return Boolean(account?.allowPost) && status === 'active';
  }

  function assertAccountReferencePostable(ref, sideLabel) {
    const parsed = parseEntryReference(ref);
    if (parsed.kind !== 'ACCOUNT') return;
    const account = postingAccountMap.get(String(parsed.value || '')) || null;
    if (!account) {
      throw new Error(`${sideLabel} account is not available in the active account list.`);
    }
    if (!isAccountActivePostable(account)) {
      const code = String(account.code || account.id || '').trim();
      const status = String(account.status || 'unknown').trim();
      const postableText = account.allowPost ? 'true' : 'false';
      throw new Error(
        `${sideLabel} account "${code}" is not valid for posting. ` +
        `It must be Active + Postable (status="${status}", allowPost="${postableText}").`
      );
    }
  }

  function parseEntryReference(ref) {
    const raw = String(ref || '').trim();
    const separatorIndex = raw.indexOf(':');
    if (separatorIndex === -1) {
      return {
        kind: 'UNKNOWN',
        value: raw
      };
    }
    return {
      kind: raw.slice(0, separatorIndex).trim().toUpperCase(),
      value: raw.slice(separatorIndex + 1).trim()
    };
  }

  function formatEntryReferenceCell(ref, side) {
    const parsed = parseEntryReference(ref);
    const badgeClass = side === 'debit' ? 'bg-success-subtle text-success' : 'bg-danger-subtle text-danger';

    if (parsed.kind === 'ACCOUNT') {
      const account = postingAccountMap.get(String(parsed.value || '')) || null;
      const accountCode = String(account?.code || '').trim();
      const accountName = String(account?.name || '').trim();
      const accountId = String(account?.id || parsed.value || '').trim();
      const accountRole = String(account?.partyRole || 'none').trim().toLowerCase();
      const accountOrg = String(account?.orgId || '').trim();
      const accountStatus = String(account?.status || '').trim().toLowerCase();
      const isActivePostable = Boolean(account && isAccountActivePostable(account));
      return '' +
        '<div class="d-flex flex-column gap-1">' +
          '<div class="d-flex align-items-center gap-2 flex-wrap">' +
            '<span class="badge ' + badgeClass + '">Account</span>' +
            '<span class="fw-bold">' + safeHtml(accountName || accountCode || accountId) + '</span>' +
          '</div>' +
          '<div class="small text-muted">' +
            (accountCode ? ('Code/Number: <span class="font-monospace">' + safeHtml(accountCode) + '</span>') : 'Code/Number: -') +
          '</div>' +
          '<div class="small text-muted">' +
            'ID: <span class="font-monospace">' + safeHtml(accountId || '-') + '</span>' +
            (accountRole && accountRole !== 'none' ? (' | Role: ' + safeHtml(accountRole)) : '') +
            (accountOrg ? (' | Org: ' + safeHtml(accountOrg)) : '') +
          '</div>' +
          '<div class="small ' + (isActivePostable ? 'text-success' : 'text-danger') + '">' +
            'Posting State: ' + (isActivePostable ? 'Active + Postable' : ('status=' + safeHtml(accountStatus || 'unknown') + ', allowPost=' + safeHtml(String(Boolean(account?.allowPost)))) ) +
          '</div>' +
        '</div>';
    }

    if (parsed.kind === 'ROLE') {
      return '' +
        '<div class="d-flex flex-column gap-1">' +
          '<div class="d-flex align-items-center gap-2 flex-wrap">' +
            '<span class="badge ' + badgeClass + '">Role</span>' +
            '<span class="fw-bold text-capitalize">' + safeHtml(parsed.value || '-') + '</span>' +
          '</div>' +
          '<div class="small text-muted">This resolves dynamically to the active posting account for that role.</div>' +
          '<div class="small text-muted font-monospace">Ref: ' + safeHtml(ref || '-') + '</div>' +
        '</div>';
    }

    return '' +
      '<div class="d-flex flex-column gap-1">' +
        '<div class="d-flex align-items-center gap-2 flex-wrap">' +
          '<span class="badge ' + badgeClass + '">' + safeHtml(parsed.kind || 'Ref') + '</span>' +
          '<span class="fw-bold">' + safeHtml(parsed.value || ref || '-') + '</span>' +
        '</div>' +
        '<div class="small text-muted font-monospace">' + safeHtml(ref || '-') + '</div>' +
      '</div>';
  }

  function applyAccountSelection(side, account) {
    const refField = side === 'debit' ? debitAccountRefField : creditAccountRefField;
    const labelField = side === 'debit' ? debitAccountLabelField : creditAccountLabelField;
    refField.value = account ? `ACCOUNT:${account.id}` : '';
    labelField.value = account ? formatAccountLabel(account) : '';
    autoSelectMemoRoleFromReferences();
  }

  function clearAccountSelection(side) {
    applyAccountSelection(side, null);
  }

  function getReferenceValue(side) {
    const typeField = side === 'debit' ? debitRefTypeField : creditRefTypeField;
    const roleField = side === 'debit' ? debitRoleField : creditRoleField;
    const accountRefField = side === 'debit' ? debitAccountRefField : creditAccountRefField;
    const type = String(typeField ? typeField.value : 'ACCOUNT').trim().toUpperCase();
    return type === 'ROLE'
      ? String(roleField ? roleField.value : '').trim()
      : String(accountRefField ? accountRefField.value : '').trim();
  }

  function syncReferenceUi(side) {
    const typeField = side === 'debit' ? debitRefTypeField : creditRefTypeField;
    const roleWrap = document.getElementById(side + 'RoleWrap');
    const accountWrap = document.getElementById(side + 'AccountPickerWrap');
    const labelField = side === 'debit' ? debitReferenceLabel : creditReferenceLabel;
    const hintField = side === 'debit' ? debitReferenceHint : creditReferenceHint;
    const type = String(typeField ? typeField.value : 'ACCOUNT').trim().toUpperCase();
    if (type === 'ROLE') {
      if (roleWrap) roleWrap.classList.remove('d-none');
      if (accountWrap) accountWrap.classList.add('d-none');
      if (labelField) labelField.textContent = (side === 'debit' ? 'Debit Role *' : 'Credit Role *');
      if (hintField) hintField.textContent = 'Choose the posting role placeholder that will resolve during application.';
    } else {
      if (roleWrap) roleWrap.classList.add('d-none');
      if (accountWrap) accountWrap.classList.remove('d-none');
      if (labelField) labelField.textContent = (side === 'debit' ? 'Debit Account *' : 'Credit Account *');
      if (hintField) hintField.textContent = 'Pick a fixed posting account for this side.';
    }
    autoSelectMemoRoleFromReferences();
  }

  function extractRoleFromRef(ref) {
    const raw = String(ref || '').trim();
    if (!raw.toUpperCase().startsWith('ROLE:')) return '';
    const role = raw.slice(5).trim().toLowerCase();
    return role;
  }

  function setMemoHint(message) {
    if (!memoPlaceholderHint) return;
    memoPlaceholderHint.textContent = message || '';
  }

  function insertTokenAtCursor(token) {
    if (!memoTemplateField) return;
    const current = String(memoTemplateField.value || '');
    const start = Number.isInteger(memoTemplateField.selectionStart) ? memoTemplateField.selectionStart : current.length;
    const end = Number.isInteger(memoTemplateField.selectionEnd) ? memoTemplateField.selectionEnd : current.length;
    memoTemplateField.value = current.slice(0, start) + token + current.slice(end);
    const cursor = start + token.length;
    memoTemplateField.focus();
    memoTemplateField.setSelectionRange(cursor, cursor);
  }

  async function copyToken(token) {
    try {
      if (navigator.clipboard && typeof navigator.clipboard.writeText === 'function') {
        await navigator.clipboard.writeText(token);
      } else {
        const helper = document.createElement('textarea');
        helper.value = token;
        helper.setAttribute('readonly', 'readonly');
        helper.style.position = 'absolute';
        helper.style.left = '-9999px';
        document.body.appendChild(helper);
        helper.select();
        document.execCommand('copy');
        document.body.removeChild(helper);
      }
      setMemoHint('Copied: ' + token);
    } catch {
      setMemoHint('Copy failed. Please copy manually.');
    }
  }

  function renderMemoPlaceholders() {
    if (!memoRoleField || !memoPlaceholderPanel || !memoPlaceholderList) return;

    const selectedRole = String(memoRoleField.value || '').trim().toLowerCase();
    if (!selectedRole) {
      memoPlaceholderPanel.classList.add('d-none');
      memoPlaceholderList.innerHTML = '';
      setMemoHint('');
      return;
    }

    const rolePlaceholders = Array.isArray(memoPlaceholdersByRole[selectedRole]) ? memoPlaceholdersByRole[selectedRole] : [];
    const placeholders = memoCommonPlaceholders
      .concat(rolePlaceholders)
      .filter((p) => p && p.key)
      .map((p) => ({
        key: String(p.key || '').trim(),
        label: String(p.label || p.key || '').trim()
      }))
      .filter((p) => !!p.key);

    if (!placeholders.length) {
      memoPlaceholderPanel.classList.add('d-none');
      memoPlaceholderList.innerHTML = '';
      setMemoHint('');
      return;
    }

    memoPlaceholderPanel.classList.remove('d-none');
    setMemoHint('Click a token to insert it. Use the clipboard button to copy.');
    memoPlaceholderList.innerHTML = placeholders.map((p) => {
      const token = '{{' + p.key + '}}';
      return (
        '<div class="btn-group btn-group-sm" role="group">' +
          '<button type="button" class="btn btn-outline-primary font-monospace" data-insert-token="' + safeHtml(token) + '" title="' + safeHtml(p.label) + '">' + safeHtml(token) + '</button>' +
          '<button type="button" class="btn btn-outline-secondary" data-copy-token="' + safeHtml(token) + '" title="Copy ' + safeHtml(token) + '"><i class="bi bi-clipboard"></i></button>' +
        '</div>'
      );
    }).join('');

    memoPlaceholderList.querySelectorAll('button[data-insert-token]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const token = String(btn.getAttribute('data-insert-token') || '').trim();
        if (!token) return;
        insertTokenAtCursor(token);
      });
    });

    memoPlaceholderList.querySelectorAll('button[data-copy-token]').forEach(function (btn) {
      btn.addEventListener('click', async function () {
        const token = String(btn.getAttribute('data-copy-token') || '').trim();
        if (!token) return;
        await copyToken(token);
      });
    });
  }

  function autoSelectMemoRoleFromReferences() {
    if (!memoRoleField) return;
    if (String(memoRoleField.value || '').trim()) return;
    const roleFromDebit = extractRoleFromRef(getReferenceValue('debit'));
    const roleFromCredit = extractRoleFromRef(getReferenceValue('credit'));
    const resolvedRole = roleFromDebit || roleFromCredit;
    if (!resolvedRole) return;

    const canUseRole = Array.from(memoRoleField.options || []).some((opt) =>
      String(opt.value || '').trim().toLowerCase() === resolvedRole
    );
    if (!canUseRole) return;

    memoRoleField.value = resolvedRole;
    renderMemoPlaceholders();
  }

  function renderEntries() {
    entries = (Array.isArray(entries) ? entries : []).map(normalizeEntry);
    const hasAnyFixedAmounts = hasFixedAmounts(entries);
    const hasAnyRuntimeRows = hasRuntimeRows(entries);
    const runtimePercentageTotal = getRuntimePercentageTotal(entries);

    if (!entries.length) {
      entriesTbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-3">No entries added yet.</td></tr>';
      if (entryTemplateSummary) {
        entryTemplateSummary.className = 'small mt-2 text-muted';
        entryTemplateSummary.textContent = 'Add at least one posting row to build this transaction template.';
      }
      syncHidden();
      return;
    }

    entriesTbody.innerHTML = entries.map(function (e, idx) {
      const rowHasFixedAmount = Number(e.amount || 0) > 0;
      const percentageInput = rowHasFixedAmount
        ? '<div class="small text-muted">Share: ' + safeHtml(Number(e.percentage || 0).toFixed(2)) + '% (derived from fixed amount)</div>'
        : '<label class="small text-muted d-block mb-1">Runtime share</label>' +
          '<div class="input-group input-group-sm" style="max-width: 160px;">' +
            '<input type="number" class="form-control" min="0" max="100" step="0.01" value="' + safeHtml(Number(e.percentage || 0).toFixed(2)) + '" data-percentage="' + idx + '">' +
            '<span class="input-group-text">%</span>' +
          '</div>';
      return '<tr>' +
        '<td>' + (idx + 1) + '</td>' +
        '<td>' + formatEntryReferenceCell(e.debitRef, 'debit') + '</td>' +
        '<td>' + formatEntryReferenceCell(e.creditRef, 'credit') + '</td>' +
        '<td>' +
          '<div class="fw-bold">' + safeHtml(Number(e.amount || 0).toFixed(2)) + ' ' + safeHtml(e.currency || 'CAD') + '</div>' +
          percentageInput +
          '<div class="small text-muted">Entry ID: <span class="font-monospace">' + safeHtml(e.entryId || ('ENTRY_' + (idx + 1))) + '</span></div>' +
        '</td>' +
        '<td>' +
          '<div class="small">' + safeHtml(e.memoTemplate || '-') + '</div>' +
          '<div class="small text-muted mt-1">' + safeHtml(e.notes || 'No notes') + '</div>' +
        '</td>' +
        '<td class="text-end"><button type="button" class="btn btn-outline-danger btn-sm" data-del="' + idx + '">Delete</button></td>' +
      '</tr>';
    }).join('');

    entriesTbody.querySelectorAll('button[data-del]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        const i = Number(btn.getAttribute('data-del'));
        if (!Number.isNaN(i) && i >= 0 && i < entries.length) {
          entries.splice(i, 1);
          renderEntries();
        }
      });
    });

    entriesTbody.querySelectorAll('input[data-percentage]').forEach(function (input) {
      input.addEventListener('change', function () {
        const index = Number(input.getAttribute('data-percentage'));
        if (!Number.isInteger(index) || !entries[index]) return;
        entries[index].percentage = normalizePercentageValue(input.value);
        renderEntries();
      });
    });

    if (entryTemplateSummary) {
      const fixedTotal = roundToTwo(entries.reduce(function (sum, entry) {
        return sum + (Number(entry?.amount || 0) > 0 ? Number(entry.amount || 0) : 0);
      }, 0));
      const currency = String(entries[0]?.currency || 'CAD');

      if (hasAnyFixedAmounts && !hasAnyRuntimeRows) {
        entryTemplateSummary.className = 'small mt-2 text-muted';
        entryTemplateSummary.textContent = 'Fixed-amount template total: ' + fixedTotal.toFixed(2) + ' ' + currency + '. Percentages are derived automatically.';
      } else if (hasAnyRuntimeRows) {
        const isValid = Math.abs(runtimePercentageTotal - 100) <= 0.01;
        entryTemplateSummary.className = 'small mt-2 ' + (isValid ? 'text-success' : 'text-danger');
        entryTemplateSummary.textContent = (hasAnyFixedAmounts
          ? ('Fixed rows: ' + fixedTotal.toFixed(2) + ' ' + currency + '. ')
          : '') + 'Runtime percentage total: ' + runtimePercentageTotal.toFixed(2) + '%. This must equal 100%.';
      } else {
        entryTemplateSummary.className = 'small mt-2 text-muted';
        entryTemplateSummary.textContent = 'Add at least one fixed or runtime row.';
      }
    }

    syncHidden();
  }

  document.addEventListener('DOMContentLoaded', function () {
    const copyBtn = document.getElementById('btnCopyFromDefinition');
    if (memoRoleField) memoRoleField.addEventListener('change', renderMemoPlaceholders);
    if (debitRefTypeField) debitRefTypeField.addEventListener('change', function () { syncReferenceUi('debit'); });
    if (creditRefTypeField) creditRefTypeField.addEventListener('change', function () { syncReferenceUi('credit'); });
    if (debitRoleField) debitRoleField.addEventListener('change', autoSelectMemoRoleFromReferences);
    if (creditRoleField) creditRoleField.addEventListener('change', autoSelectMemoRoleFromReferences);

    const openAccountPicker = function (side) {
      GenericPicker.open(GenericPickerPresets.account({
        title: side === 'debit' ? 'Select Debit Account' : 'Select Credit Account',
        icon: 'bi-wallet2',
        placeholder: 'Search by account code, number, or name...',
        apiEndpoint: '/school/accounts?allowPost=true&status=active',
        onSelect: function (item) {
          if (!item || !isAccountActivePostable(item)) {
            showMsg({
              title: 'Invalid Account',
              icon: 'warning',
              message: 'Only Active + Postable accounts can be used in transaction template entries.',
              buttons: [{ text: 'OK', class: 'btn-warning' }]
            });
            return;
          }
          applyAccountSelection(side, item);
        }
      }));
    };

    const debitPickBtn = document.getElementById('btnPickDebitAccount');
    const creditPickBtn = document.getElementById('btnPickCreditAccount');
    const debitClearBtn = document.getElementById('btnClearDebitAccount');
    const creditClearBtn = document.getElementById('btnClearCreditAccount');
    if (debitPickBtn) debitPickBtn.addEventListener('click', function () { openAccountPicker('debit'); });
    if (creditPickBtn) creditPickBtn.addEventListener('click', function () { openAccountPicker('credit'); });
    if (debitClearBtn) debitClearBtn.addEventListener('click', function () { clearAccountSelection('debit'); });
    if (creditClearBtn) creditClearBtn.addEventListener('click', function () { clearAccountSelection('credit'); });

    if (copyBtn) {
      copyBtn.addEventListener('click', function () {
        GenericPicker.open(GenericPickerPresets.transactionDefinition({
          title: 'Copy From Transaction Template',
          placeholder: 'Search transaction templates...',
          onSelect: async function (item) {
            if (!item || (currentDefinitionId && String(item.id || '') === String(currentDefinitionId))) return;
            applyDefinitionTemplate(item);
            await showMsg({
              title: 'Template Applied',
              icon: 'success',
              message: 'Transaction template fields were copied. Review and edit the values before saving.',
              buttons: [{ text: 'OK', class: 'btn-success' }]
            });
          }
        }));
      });
    }

    syncReferenceUi('debit');
    syncReferenceUi('credit');
    autoSelectMemoRoleFromReferences();
    renderMemoPlaceholders();
    entries = Array.isArray(window.__INIT_TRANSACTION_DEF_ENTRIES__) ? window.__INIT_TRANSACTION_DEF_ENTRIES__.map(normalizeEntry) : [];
    syncEntryModeInputs();
    if (amountField) {
      amountField.addEventListener('input', function () {
        syncEntryModeInputs('amount');
      });
    }
    if (percentageField) {
      percentageField.addEventListener('input', function () {
        syncEntryModeInputs('percentage');
      });
    }

    document.getElementById('btnAddEntry').addEventListener('click', async function () {
      try {
        const debitRef = getReferenceValue('debit');
        const creditRef = getReferenceValue('credit');
        const amount = Number(amountField ? amountField.value : 0);
        const percentageRaw = String(percentageField ? percentageField.value : '').trim();
        const percentage = percentageRaw ? Number(percentageRaw) : 0;
        const currency = String(document.getElementById('inp_currency').value || '').trim().toUpperCase() || 'CAD';
        const memoTemplate = String(memoTemplateField ? memoTemplateField.value : '').trim();
        const notes = String(document.getElementById('inp_entryNotes').value || '').trim();

        if (!debitRef || !creditRef) throw new Error('Both debit and credit references are required.');
        if (debitRef === creditRef) throw new Error('Debit and credit references must be different.');
        assertAccountReferencePostable(debitRef, 'Debit');
        assertAccountReferencePostable(creditRef, 'Credit');
        if (!Number.isFinite(amount) || amount < 0) throw new Error('Amount must be zero or greater.');
        if (percentageRaw && (!Number.isFinite(percentage) || percentage < 0 || percentage > 100)) {
          throw new Error('Percentage must be between 0 and 100.');
        }
        if (amount > 0 && percentage > 0) throw new Error('Use either a fixed amount or a runtime percentage for a row, not both.');
        if (!/^[A-Z]{3}$/.test(currency)) throw new Error('Currency must be ISO code (e.g. CAD).');

        entries.push({
          entryId: 'ENTRY_' + (entries.length + 1),
          debitRef,
          creditRef,
          amount,
          percentage,
          currency,
          memoTemplate,
          notes
        });

        if (debitRefTypeField) debitRefTypeField.value = 'ACCOUNT';
        if (creditRefTypeField) creditRefTypeField.value = 'ACCOUNT';
        if (debitRoleField) debitRoleField.value = '';
        if (creditRoleField) creditRoleField.value = '';
        clearAccountSelection('debit');
        clearAccountSelection('credit');
        if (amountField) amountField.value = '';
        if (percentageField) percentageField.value = '';
        document.getElementById('inp_currency').value = 'CAD';
        if (memoTemplateField) memoTemplateField.value = '';
        if (memoRoleField) memoRoleField.value = '';
        document.getElementById('inp_entryNotes').value = '';
        syncEntryModeInputs();
        syncReferenceUi('debit');
        syncReferenceUi('credit');
        renderMemoPlaceholders();
        renderEntries();
      } catch (err) {
        await showMsg({
          title: 'Validation',
          icon: 'warning',
          message: err.message || 'Invalid entry.',
          buttons: [{ text: 'OK', class: 'btn-warning' }]
        });
      }
    });

    form.addEventListener('submit', async function (e) {
      e.preventDefault();

      const submitBtn = form.querySelector('button[type="submit"]');
      const originalText = submitBtn.innerHTML;
      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

      try {
        if (!entries.length) throw new Error('Please add at least one posting entry.');
        entries = entries.map(normalizeEntry);
        entries.forEach(function (entry, idx) {
          assertAccountReferencePostable(entry?.debitRef, `Debit (row ${idx + 1})`);
          assertAccountReferencePostable(entry?.creditRef, `Credit (row ${idx + 1})`);
        });
        const validFromField = form.querySelector('input[name="validFrom"]');
        const validToField = form.querySelector('input[name="validTo"]');
        const validFrom = String(validFromField ? validFromField.value : '').trim();
        const validTo = String(validToField ? validToField.value : '').trim();
        if (validFrom && validTo && validFrom > validTo) {
          throw new Error('Valid To cannot be earlier than Valid From.');
        }
        if (hasRuntimeRows(entries)) {
          const runtimePercentageTotal = getRuntimePercentageTotal(entries);
          if (Math.abs(runtimePercentageTotal - 100) > 0.01) {
            throw new Error('Runtime template percentages must total 100 before saving.');
          }
        }
        const metadataRaw = String(metadataField.value || '').trim();
        if (metadataRaw) {
          try { JSON.parse(metadataRaw); } catch { throw new Error('Metadata must be valid JSON.'); }
        } else {
          metadataField.value = '{}';
        }

        syncHidden();
        const formData = new FormData(form);
        const data = new URLSearchParams(formData);

        const response = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-AJAX-Request': 'true' },
          body: data.toString()
        });

        const contentType = response.headers.get('content-type') || '';
        if (!contentType.includes('application/json')) {
          throw new Error('Server returned non-JSON response (Status ' + response.status + ')');
        }

        const result = await response.json();
        const guarded = typeof window.applyGuardedApiResult === 'function'
          ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Processed' })
          : { stop: false };
        if (guarded.stop) {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
          return;
        }
        await showMsg({
          title: result.status === 'success' ? 'Success' : 'Error',
          icon: result.status === 'success' ? 'success' : 'error',
          message: result.message || 'Operation completed.',
          buttons: [{ text: 'OK', class: result.status === 'success' ? 'btn-success' : 'btn-danger' }]
        });

        if (result.status === 'success') {
          window.location.href = '/school/transactionTemplates';
        } else {
          submitBtn.disabled = false;
          submitBtn.innerHTML = originalText;
        }
      } catch (error) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
        await showMsg({
          title: 'System Error',
          icon: 'error',
          message: error.message || 'An unexpected network error occurred.',
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
      }
    });

    renderEntries();
  });
})();
</script>
