<%- include('partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print: true,
  manageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>'
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search session status definitions...',
  fields: [
    { name: 'active', label: 'Active', type: 'select', options: ['true', 'false'] },
    { name: 'isFinal', label: 'Final', type: 'select', options: ['true', 'false'] },
    { name: 'makeUpRequired', label: 'Make-up', type: 'select', options: ['true', 'false'] }
  ]
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="draggable ps-4" data-column="code">Code</th>
        <th class="draggable" data-column="label">Label</th>
        <th class="draggable" data-column="timesheetFormula">Timesheet Formula</th>
        <th class="draggable" data-column="isFinal">Final</th>
        <th class="draggable" data-column="makeUpRequired">Make-up</th>
        <th class="draggable" data-column="active">Active</th>
        <th class="draggable" data-column="sortOrder">Order</th>
        <th class="draggable" data-column="colors">Colors</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || data.length === 0) { %>
        <tr><td colspan="9" class="text-center py-5 text-muted">No session statuses found.</td></tr>
      <% } %>
      <% (data || []).forEach((item) => { %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold font-monospace text-dark"><%= item.code %></div>
            <div class="x-small text-muted"><%= item.id %></div>
          </td>
          <td>
            <div class="fw-bold text-dark"><%= item.label %></div>
            <div class="small text-muted"><%= item.description || '-' %></div>
          </td>
          <td>
            <code><%= item.timesheetFormula || 'duration' %></code>
          </td>
          <td>
            <span class="badge <%= item.isFinal ? 'bg-success' : 'bg-secondary' %>"><%= item.isFinal ? 'Yes' : 'No' %></span>
          </td>
          <td>
            <span class="badge <%= item.makeUpRequired ? 'bg-warning text-dark' : 'bg-light text-dark border' %>"><%= item.makeUpRequired ? 'Required' : 'No' %></span>
          </td>
          <td>
            <span class="badge <%= item.active ? 'bg-primary' : 'bg-danger' %>"><%= item.active ? 'Active' : 'Inactive' %></span>
          </td>
          <td><%= Number(item.sortOrder || 0) %></td>
          <td>
            <div class="d-flex align-items-center gap-1">
              <span class="d-inline-block border rounded" style="width: 16px; height: 16px; background:<%= item.colorBg || '#e2e3e5' %>; border-color:<%= item.colorBorder || '#c6c8ca' %> !important;" title="Background"></span>
              <span class="badge border" style="background:<%= item.colorBg || '#e2e3e5' %>; color:<%= item.colorText || '#41464b' %>; border-color:<%= item.colorBorder || '#c6c8ca' %> !important;">
                A
              </span>
            </div>
          </td>
          <td class="table-actions">
            <a href="/school/session-statuses/edit/<%= item.id %>" class="btn btn-sm btn-filled btn-edit">Edit</a>
            <button class="btn btn-sm btn-filled btn-delete delete-btn" data-id="<%= item.id %>">Delete</button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/session-statuses" hidden></span>

<%- include('partials/pagination', {
  pagination,
  filters,
  baseUrlPath: newUrl
}) %>

<%- include('partials/tablePages-end') %>
