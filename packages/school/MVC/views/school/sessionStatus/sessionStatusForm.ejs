<%
  const item = statusItem || {};
  const isEdit = !!item.id;
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-2 flex-wrap">
      <h1 class="page-heading size-md m-0"><i class="bi bi-sliders me-2"></i><%= isEdit ? 'Edit Session Status' : 'New Session Status' %></h1>
      <% if (isEdit) { %>
        <span class="badge bg-primary border font-monospace">ID: <%= item.id %></span>
      <% } %>
    </div>
    <div class="d-flex gap-2">
      <button type="button" class="btn btn-outline-primary btn-sm" id="btnCopyFromSessionStatus">
        <i class="bi bi-copy me-1"></i> Copy From Existing
      </button>
    </div>
  </div>

  <div class="form-container wide" style="max-width: 1400px;">
    <form id="sessionStatusForm" action="<%= isEdit ? '/school/session-statuses/edit/' + item.id : '/school/session-statuses/new' %>" method="POST">
      <input type="hidden" name="actionStateId" value="<%= asid %>">

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label fw-bold">Code *</label>
              <input type="text" name="code" class="form-control size-md font-monospace" value="<%= item.code || '' %>" placeholder="e.g. completed" required>
              <div class="form-text small">Use lowercase/underscore. Example: <code>missed_informed24</code></div>
            </div>
            <div class="col-md-5">
              <label class="form-label fw-bold">Label *</label>
              <input type="text" name="label" class="form-control size-md" value="<%= item.label || '' %>" placeholder="e.g. Missed (Informed-24)" required>
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">Sort Order</label>
              <input type="number" name="sortOrder" class="form-control size-md" value="<%= Number(item.sortOrder || 0) %>" min="0" max="9999">
            </div>
            <div class="col-12">
              <label class="form-label fw-bold">Description</label>
              <textarea name="description" class="form-control" rows="2" placeholder="Explain the workflow meaning of this status..."><%= item.description || '' %></textarea>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom">
          <h6 class="fw-bold m-0 text-primary"><i class="bi bi-calculator me-2"></i>Timesheet Formula</h6>
        </div>
        <div class="card-body p-4">
          <div class="row g-3 align-items-end">
            <div class="col-md-8">
              <label class="form-label fw-bold">Formula *</label>
              <input type="text" id="inp_formula" name="timesheetFormula" class="form-control size-md font-monospace" value="<%= item.timesheetFormula || 'duration' %>" required>
              <div class="form-text small">
                Allowed variables: <code>duration</code>, <code>hours</code>. Operators: <code>+ - * / ( )</code><br>
                Examples: <code>duration</code>, <code>duration * 0.5</code>, <code>0</code>
              </div>
            </div>
            <div class="col-md-2">
              <label class="form-label fw-bold">Sample Duration</label>
              <input type="number" id="inp_previewDuration" class="form-control size-md" value="2" min="0" step="0.25">
            </div>
            <div class="col-md-2">
              <button type="button" class="btn btn-outline-primary w-100" id="btnPreviewFormula">
                <i class="bi bi-play-fill me-1"></i>Preview
              </button>
            </div>
            <div class="col-12">
              <div class="alert alert-light border mb-0 py-2">
                Preview Result: <strong id="lbl_formulaPreview">-</strong>
              </div>
            </div>
          </div>
        </div>
      </div>

      <style>
        .session-status-rule-group + .session-status-rule-group {
          margin-top: 1.5rem;
          padding-top: 1.5rem;
          border-top: 1px solid var(--bs-border-color);
        }
        .session-status-rule-tile {
          height: 100%;
        }
        .session-status-rule-tile .form-check {
          margin-bottom: 0;
        }
        .session-status-rule-tile .rule-tile-header {
          display: flex;
          align-items: flex-start;
          justify-content: space-between;
          gap: 0.75rem;
        }
        .session-status-rule-tile .rule-tile-label {
          font-weight: 600;
          margin-bottom: 0;
        }
        .makeup-policy-panel {
          border-left: 3px solid var(--bs-warning);
        }
      </style>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom">
          <h6 class="fw-bold m-0 text-primary"><i class="bi bi-diagram-3 me-2"></i>Behavior Rules</h6>
          <div class="small text-muted mt-1">These rules control payroll, attendance, schedules, and make-up behavior for sessions with this status.</div>
        </div>
        <div class="card-body p-4">

          <div class="session-status-rule-group">
            <div class="text-uppercase text-muted small fw-bold mb-3">Session Lifecycle</div>
            <div class="row g-3">
              <div class="col-lg-6">
                <div class="session-status-rule-tile border rounded p-3 bg-light-subtle">
                  <div class="rule-tile-header">
                    <label class="rule-tile-label" for="isFinal">Final Status</label>
                    <div class="form-check form-switch">
                      <input class="form-check-input" type="checkbox" role="switch" id="isFinal" name="isFinal" value="true" <%= item.isFinal ? 'checked' : '' %>>
                    </div>
                  </div>
                  <div class="form-text small mt-2 mb-0">Allows timesheet submission when a session has this status.</div>
                </div>
              </div>
              <div class="col-lg-6">
                <div class="session-status-rule-tile border rounded p-3 bg-light-subtle">
                  <div class="rule-tile-header">
                    <label class="rule-tile-label" for="active">Active</label>
                    <div class="form-check form-switch">
                      <input class="form-check-input" type="checkbox" role="switch" id="active" name="active" value="true" <%= (item.active === false ? '' : 'checked') %>>
                    </div>
                  </div>
                  <div class="form-text small mt-2 mb-0">Inactive statuses cannot be selected for new session operations.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="session-status-rule-group">
            <div class="text-uppercase text-muted small fw-bold mb-3">Make-up Policy</div>
            <div class="session-status-rule-tile border rounded p-3 bg-light-subtle">
              <div class="rule-tile-header">
                <label class="rule-tile-label" for="makeUpRequired">Make-up Required</label>
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" role="switch" id="makeUpRequired" name="makeUpRequired" value="true" <%= item.makeUpRequired ? 'checked' : '' %>>
                </div>
              </div>
              <div class="form-text small mt-2 mb-0">Use for missed sessions that must be replaced with a make-up session later.</div>

              <div class="makeup-policy-panel border rounded p-3 bg-white mt-3" id="makeupPolicyPanel">
                <div class="fw-semibold small text-uppercase text-muted mb-3">Make-up Session Defaults</div>
                <div class="row g-3">
                  <div class="col-12">
                    <label class="form-label fw-bold" for="makeupDurationPercent">Make-up Duration %</label>
                    <input type="number" class="form-control size-md" id="makeupDurationPercent" name="makeupDurationPercent" min="1" max="100" step="1" value="<%= Number(item.makeupDurationPercent || 100) %>">
                    <div class="form-text small">Default share of the original session length for the make-up session.</div>
                  </div>
                </div>
                <div class="alert alert-light border small mb-0 mt-3 py-2">
                  Original session payroll is controlled by <strong>Timesheet Formula</strong> above (on the full session duration).
                  The make-up session is paid when completed, using normal timesheet rules on the make-up session duration.
                  Example: a 3 hr session at 50% creates a 1.5 hr make-up session.
                </div>
              </div>
            </div>
          </div>

          <div class="session-status-rule-group">
            <div class="text-uppercase text-muted small fw-bold mb-3">Attendance</div>
            <div class="row g-3">
              <div class="col-lg-6">
                <div class="session-status-rule-tile border rounded p-3 bg-light-subtle">
                  <div class="rule-tile-header">
                    <label class="rule-tile-label" for="excludeFromAttendance">Exclude Attendance</label>
                    <div class="form-check form-switch">
                      <input class="form-check-input" type="checkbox" role="switch" id="excludeFromAttendance" name="excludeFromAttendance" value="true" <%= item.excludeFromAttendance ? 'checked' : '' %>>
                    </div>
                  </div>
                  <div class="form-text small mt-2 mb-0">Hide this status from attendance matrix and report rollups.</div>
                </div>
              </div>
            </div>
          </div>

          <div class="session-status-rule-group">
            <div class="text-uppercase text-muted small fw-bold mb-3">Schedule Indexes</div>
            <div class="row g-3">
              <div class="col-lg-6">
                <div class="session-status-rule-tile border rounded p-3 bg-light-subtle">
                  <div class="rule-tile-header">
                    <label class="rule-tile-label" for="excludeFromTeacherIndex">Exclude from Teacher Schedule Index</label>
                    <div class="form-check form-switch">
                      <input class="form-check-input" type="checkbox" role="switch" id="excludeFromTeacherIndex" name="excludeFromTeacherIndex" value="true" <%= item.excludeFromTeacherIndex ? 'checked' : '' %>>
                    </div>
                  </div>
                  <div class="form-text small mt-2 mb-0">Remove sessions with this status from teacher schedule views and conflict checks.</div>
                </div>
              </div>
              <div class="col-lg-6">
                <div class="session-status-rule-tile border rounded p-3 bg-light-subtle">
                  <div class="rule-tile-header">
                    <label class="rule-tile-label" for="excludeFromStudentIndex">Exclude from Student Schedule Index</label>
                    <div class="form-check form-switch">
                      <input class="form-check-input" type="checkbox" role="switch" id="excludeFromStudentIndex" name="excludeFromStudentIndex" value="true" <%= item.excludeFromStudentIndex ? 'checked' : '' %>>
                    </div>
                  </div>
                  <div class="form-text small mt-2 mb-0">Remove sessions with this status from student schedule views and leave-window checks.</div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom">
          <h6 class="fw-bold m-0 text-primary"><i class="bi bi-palette me-2"></i>Display Colors</h6>
        </div>
        <div class="card-body p-4">
          <div class="row g-3 align-items-end">
            <div class="col-md-3">
              <label class="form-label fw-bold">Background</label>
              <input type="color" name="colorBg" id="colorBg" class="form-control form-control-color w-100" value="<%= item.colorBg || '#E2E3E5' %>">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">Text</label>
              <input type="color" name="colorText" id="colorText" class="form-control form-control-color w-100" value="<%= item.colorText || '#41464B' %>">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">Border</label>
              <input type="color" name="colorBorder" id="colorBorder" class="form-control form-control-color w-100" value="<%= item.colorBorder || '#C6C8CA' %>">
            </div>
            <div class="col-md-3">
              <div class="border rounded p-2 text-center" id="statusColorPreview" style="background:<%= item.colorBg || '#E2E3E5' %>; color:<%= item.colorText || '#41464B' %>; border:1px solid <%= item.colorBorder || '#C6C8CA' %>;">
                <span class="fw-bold"><%= item.label || 'Preview' %></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md"><%= isEdit ? 'Save Changes' : 'Create Status' %></button>
        <a href="/school/session-statuses" class="btn btn-filled btn-secondary btn-md">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/modal_GenericPicker') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const form = document.getElementById('sessionStatusForm');
  const currentStatusId = '<%= item.id || '' %>';
  const formulaInput = document.getElementById('inp_formula');
  const durationInput = document.getElementById('inp_previewDuration');
  const previewLabel = document.getElementById('lbl_formulaPreview');

  function setInputValue(selector, value, fallbackValue) {
    const field = document.querySelector(selector);
    if (!field) return;
    if (value !== undefined && value !== null) field.value = String(value);
    else if (fallbackValue !== undefined) field.value = String(fallbackValue);
  }

  function setCheckboxValue(selector, value, fallbackValue) {
    const field = document.querySelector(selector);
    if (!field) return;
    if (value !== undefined && value !== null) field.checked = Boolean(value);
    else if (fallbackValue !== undefined) field.checked = Boolean(fallbackValue);
  }

  async function showFormMessage(title, icon, message, buttonClass) {
    if (typeof showMessageModal === 'function') {
      await showMessageModal({
        title,
        icon,
        message,
        buttons: [{ text: 'OK', class: buttonClass || 'btn-secondary' }]
      });
      return;
    }
    alert(message);
  }

  function applyStatusTemplate(source) {
    setInputValue('input[name="code"]', source.code || '');
    setInputValue('input[name="label"]', source.label || '');
    setInputValue('input[name="sortOrder"]', Number(source.sortOrder || 0));
    setInputValue('textarea[name="description"]', source.description || '');
    setInputValue('input[name="timesheetFormula"]', source.timesheetFormula || 'duration');
    setCheckboxValue('#isFinal', source.isFinal, false);
    setCheckboxValue('#makeUpRequired', source.makeUpRequired, false);
    setInputValue('#makeupDurationPercent', Number(source.makeupDurationPercent || 100));
    syncMakeupPolicyFields();
    setCheckboxValue('#excludeFromAttendance', source.excludeFromAttendance, false);
    setCheckboxValue('#excludeFromTeacherIndex', source.excludeFromTeacherIndex, false);
    setCheckboxValue('#excludeFromStudentIndex', source.excludeFromStudentIndex, false);
    setCheckboxValue('#active', source.active, true);
    setInputValue('#colorBg', source.colorBg || '#E2E3E5');
    setInputValue('#colorText', source.colorText || '#41464B');
    setInputValue('#colorBorder', source.colorBorder || '#C6C8CA');
    previewLabel.textContent = '-';
    previewLabel.className = '';
    updateColorPreview();
  }

  function evaluatePreviewFormula(expression, duration) {
    const expr = String(expression || '').trim();
    if (!expr) throw new Error('Formula is empty.');
    if (!/^[A-Za-z0-9_+\-*/().\s]+$/.test(expr)) {
      throw new Error('Unsupported characters in formula.');
    }
    const safeDuration = Number(duration);
    if (!Number.isFinite(safeDuration) || safeDuration < 0) throw new Error('Invalid sample duration.');
    const normalizedExpr = expr
      .replace(/\bhours\b/gi, 'duration')
      .replace(/\bduration\b/gi, `(${safeDuration})`);
    const raw = Function(`"use strict"; return (${normalizedExpr});`)();
    const num = Number(raw);
    if (!Number.isFinite(num)) throw new Error('Formula result is invalid.');
    return Math.max(0, Number(num.toFixed(2)));
  }

  function updateColorPreview() {
    const bg = document.getElementById('colorBg').value || '#E2E3E5';
    const text = document.getElementById('colorText').value || '#41464B';
    const border = document.getElementById('colorBorder').value || '#C6C8CA';
    const label = document.querySelector('input[name="label"]').value || 'Preview';
    const el = document.getElementById('statusColorPreview');
    if (!el) return;
    el.style.background = bg;
    el.style.color = text;
    el.style.border = `1px solid ${border}`;
    el.innerHTML = `<span class="fw-bold">${label}</span>`;
  }

  document.getElementById('btnPreviewFormula')?.addEventListener('click', async () => {
    try {
      const result = evaluatePreviewFormula(formulaInput?.value || 'duration', durationInput?.value || 0);
      previewLabel.textContent = `${result.toFixed(2)} hours`;
      previewLabel.className = 'text-success';
    } catch (error) {
      previewLabel.textContent = error.message;
      previewLabel.className = 'text-danger';
    }
  });

  ['colorBg', 'colorText', 'colorBorder'].forEach((id) => {
    document.getElementById(id)?.addEventListener('input', updateColorPreview);
  });
  document.querySelector('input[name="label"]')?.addEventListener('input', updateColorPreview);

  document.getElementById('btnCopyFromSessionStatus')?.addEventListener('click', () => {
    if (!window.GenericPicker) {
      showFormMessage('Unavailable', 'warning', 'Session status picker is not available.', 'btn-warning');
      return;
    }

    const onSelect = async (selectedItem) => {
      const sourceId = String(selectedItem?.id || '').trim();
      if (!sourceId) return;
      if (currentStatusId && sourceId === String(currentStatusId)) {
        await showFormMessage('Invalid Selection', 'warning', 'Select a different session status to copy from.', 'btn-warning');
        return;
      }

      applyStatusTemplate(selectedItem);
      await showFormMessage(
        'Template Applied',
        'success',
        'Session status fields were copied. Review and update the code/label before saving if needed.',
        'btn-success'
      );
    };

    const pickerConfig = typeof window.GenericPickerPresets?.sessionStatus === 'function'
      ? window.GenericPickerPresets.sessionStatus({
          title: 'Copy From Session Status',
          placeholder: 'Search session statuses to copy...',
          onSelect
        })
      : {
          title: 'Copy From Session Status',
          icon: 'bi-sliders',
          apiEndpoint: '/school/session-statuses',
          placeholder: 'Search session statuses to copy...',
          context: typeof window.GenericPickerContexts?.activeOrganizationScope === 'function'
            ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
            : null,
          onSelect
        };

    GenericPicker.open(pickerConfig);
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const submitBtn = form.querySelector('button[type="submit"]');
    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-AJAX-Request': 'true' },
        body: new URLSearchParams(new FormData(form)).toString()
      });
      const result = await response.json();
      const guarded = typeof window.applyGuardedApiResult === 'function'
        ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Processed' })
        : { stop: false };
      if (guarded.stop) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = originalText;
        return;
      }
      if (result.status !== 'success') throw new Error(result.message || 'Save failed.');

      if (typeof showMessageModal === 'function') {
        await showMessageModal({
          title: 'Success',
          icon: 'success',
          message: result.message || 'Session status saved.',
          buttons: [{ text: 'OK', class: 'btn-success' }]
        });
      } else {
        alert(result.message || 'Session status saved.');
      }
      window.location.href = '/school/session-statuses';
    } catch (error) {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
      if (typeof showMessageModal === 'function') {
        await showMessageModal({
          title: 'Error',
          icon: 'error',
          message: error.message || 'Save failed.',
          buttons: [{ text: 'Close', class: 'btn-danger' }]
        });
      } else {
        alert(error.message || 'Save failed.');
      }
    }
  });

  function syncMakeupPolicyFields() {
    const enabled = Boolean(document.getElementById('makeUpRequired')?.checked);
    const panel = document.getElementById('makeupPolicyPanel');
    if (panel) panel.style.display = enabled ? '' : 'none';
    const percentInput = document.getElementById('makeupDurationPercent');
    if (percentInput) percentInput.required = enabled;
  }

  document.getElementById('makeUpRequired')?.addEventListener('change', syncMakeupPolicyFields);
  syncMakeupPolicyFields();
  updateColorPreview();
});
</script>
