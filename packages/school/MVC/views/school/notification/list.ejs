<%
  const currentPersonIdValue = String(currentPersonId || '').trim();
  const notificationStateFilters = (filters && typeof filters === 'object') ? filters : {};
  const hasNotificationFiltersApplied = Boolean(
    String(notificationStateFilters?.status || '').trim()
    || String(notificationStateFilters?.severity || '').trim()
    || String(notificationStateFilters?.sourceType || '').trim()
    || String(notificationStateFilters?.assignment || '').trim()
  );
  const headerButtons = [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>',
    '<a href="/dashboard/section-nav/SCHOOL_ACADEMIA" class="school-navigator-dashboard btn btn-filled btn-secondary mb-2 btn-md"><i class="bi bi-journal-bookmark me-1"></i> School Academia</a>'
  ];
  if (canManageRouting) {
    headerButtons.push('<a href="/school/notifications/routing" class="school-navigator-dashboard btn btn-outline-primary mb-2 btn-md"><i class="bi bi-diagram-3 me-1"></i> Routing Rules</a>');
  }
%>
<%- include('partials/tablePages-start', {
  title,
  newUrl: null,
  newLabel: null,
  user,
  tableName: 'school_notifications',
  btn_export: true,
  print: false,
  headerManageBtns: headerButtons
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
    <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filters</div>
    <button
      id="notificationFilterToggleBtn"
      type="button"
      class="btn btn-outline-secondary btn-sm px-2"
      data-bs-toggle="collapse"
      data-bs-target="#notificationFilterCollapse"
      aria-expanded="<%= hasNotificationFiltersApplied ? 'true' : 'false' %>"
      aria-controls="notificationFilterCollapse"
      aria-label="<%= hasNotificationFiltersApplied ? 'Close filters' : 'Open filters' %>">
      Filters
      <i id="notificationFilterToggleIcon" class="bi <%= hasNotificationFiltersApplied ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
    </button>
  </div>
  <div class="collapse<%= hasNotificationFiltersApplied ? ' show' : '' %>" id="notificationFilterCollapse">
    <form class="card-body p-3" method="get" action="/school/notifications">
      <div class="row g-2 align-items-end">
        <div class="col-md-3">
          <label class="form-label" for="notificationAssignmentFilter">Assignment</label>
          <select class="form-select" id="notificationAssignmentFilter" name="assignment">
            <option value="" <%= !notificationStateFilters?.assignment ? 'selected' : '' %>>All assignments</option>
            <option value="mine" <%= notificationStateFilters?.assignment === 'mine' ? 'selected' : '' %>>Assigned to me</option>
            <option value="unassigned" <%= notificationStateFilters?.assignment === 'unassigned' ? 'selected' : '' %>>Unassigned</option>
          </select>
        </div>
        <div class="col-md-3">
          <label class="form-label" for="notificationStatusFilter">Status</label>
          <select class="form-select" id="notificationStatusFilter" name="status">
            <option value="" <%= !notificationStateFilters?.status ? 'selected' : '' %>>All statuses</option>
            <% (statuses || []).forEach((value) => { %>
              <option value="<%= value %>" <%= notificationStateFilters?.status === value ? 'selected' : '' %>><%= String(value).replace(/_/g, ' ').toUpperCase() %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label" for="notificationSeverityFilter">Severity</label>
          <select class="form-select" id="notificationSeverityFilter" name="severity">
            <option value="" <%= !notificationStateFilters?.severity ? 'selected' : '' %>>All</option>
            <% (severities || []).forEach((value) => { %>
              <option value="<%= value %>" <%= notificationStateFilters?.severity === value ? 'selected' : '' %>><%= String(value).toUpperCase() %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2">
          <label class="form-label" for="notificationSourceFilter">Source</label>
          <select class="form-select" id="notificationSourceFilter" name="sourceType">
            <option value="" <%= !notificationStateFilters?.sourceType ? 'selected' : '' %>>All</option>
            <% (sourceTypes || []).forEach((value) => { %>
              <option value="<%= value %>" <%= notificationStateFilters?.sourceType === value ? 'selected' : '' %>><%= String(value).replace(/_/g, ' ') %></option>
            <% }) %>
          </select>
        </div>
        <div class="col-md-2 d-flex gap-2">
          <button type="submit" class="btn btn-primary flex-fill"><i class="bi bi-funnel me-1"></i> Filter</button>
          <a href="/school/notifications" class="btn btn-outline-secondary"><i class="bi bi-x-circle"></i></a>
        </div>
      </div>
    </form>
  </div>
</div>

<%- include('partials/tablePages-search', {
  placeholder: 'Search notifications...',
  fields: [
    { name: 'status', label: 'Status', type: 'select', options: statuses || [] },
    { name: 'severity', label: 'Severity', type: 'select', options: severities || [] },
    { name: 'sourceType', label: 'Source', type: 'select', options: sourceTypes || [] },
    { name: 'assignment', label: 'Assignment', type: 'select', options: assignmentFilters || [] }
  ]
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Notification</th>
        <th>Source</th>
        <th>Assigned</th>
        <th>Severity</th>
        <th>Status</th>
        <th>Updated</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!notifications || notifications.length === 0) { %>
        <tr><td colspan="7" class="text-center py-4 text-muted">No notifications found.</td></tr>
      <% } %>
      <% (notifications || []).forEach((row) => { %>
        <% const status = String(row.status || '').toLowerCase(); %>
        <% const severity = String(row.severity || 'info').toLowerCase(); %>
        <% const sourceLabel = String(row.sourceType || 'manual').replace(/_/g, ' '); %>
        <% let statusBadge = 'bg-secondary'; %>
        <% if (status === 'open') statusBadge = 'bg-warning text-dark'; %>
        <% if (status === 'in_progress') statusBadge = 'bg-primary'; %>
        <% if (status === 'resolved') statusBadge = 'bg-success'; %>
        <% if (status === 'dismissed') statusBadge = 'bg-secondary'; %>
        <% let severityBadge = 'bg-info text-dark'; %>
        <% if (severity === 'warning') severityBadge = 'bg-warning text-dark'; %>
        <% if (severity === 'urgent') severityBadge = 'bg-danger'; %>
        <% if (severity === 'error') severityBadge = 'bg-dark'; %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-primary"><a href="/school/notifications/detail/<%= row.id %>"><%= row.title || row.id %></a></div>
            <div class="small text-muted"><%= row.message || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= row.id %></div>
          </td>
          <td class="small">
            <div class="text-capitalize"><%= sourceLabel %></div>
            <% if (row.sourceUrl) { %>
              <a href="<%= row.sourceUrl %>"><%= row.sourceId || 'Open source' %></a>
            <% } else { %>
              <span class="text-muted"><%= row.sourceId || '-' %></span>
            <% } %>
          </td>
          <td class="small">
            <div><%= row.assignedPersonName || row.assignedPersonId || 'Unassigned' %></div>
            <% if (row.assignedRole) { %><div class="text-muted"><%= row.assignedRole %></div><% } %>
          </td>
          <td><span class="badge <%= severityBadge %>"><%= severity.toUpperCase() %></span></td>
          <td><span class="badge <%= statusBadge %>"><%= status.replace(/_/g, ' ').toUpperCase() || 'UNKNOWN' %></span></td>
          <td class="small text-muted"><%= row.audit?.lastUpdateDateTime || row.createdAt || '-' %></td>
          <td class="table-actions text-end pe-4">
            <div class="row-actions-wrap">
              <button type="button" class="btn btn-secondary btn-sm btn-row-actions-toggle" data-row-actions-id="<%= row.id %>" title="Notification Actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= row.id %>">
                <% const rowIsAssignedToCurrent = currentPersonIdValue && currentPersonIdValue === String(row.assignedPersonId || '').trim(); %>
                <% const canManageRow = canManageAll || rowIsAssignedToCurrent; %>
                <a href="/school/notifications/detail/<%= row.id %>" class="btn btn-outline-secondary btn-sm"><i class="bi bi-eye me-2"></i>Details</a>
                <% if (canManageRow) { %>
                  <% if (status === 'open') { %>
                    <button class="btn btn-outline-primary btn-sm notification-status-action" data-status="in_progress" data-id="<%= row.id %>"><i class="bi bi-play-circle me-2"></i>Start</button>
                  <% } %>
                  <% if (status === 'open' || status === 'in_progress') { %>
                    <button class="btn btn-outline-success btn-sm notification-status-action" data-status="resolved" data-id="<%= row.id %>"><i class="bi bi-check2-circle me-2"></i>Resolve</button>
                    <button class="btn btn-outline-secondary btn-sm notification-status-action" data-status="dismissed" data-id="<%= row.id %>"><i class="bi bi-archive me-2"></i>Dismiss</button>
                  <% } else { %>
                    <button class="btn btn-outline-warning btn-sm notification-status-action" data-status="open" data-id="<%= row.id %>"><i class="bi bi-arrow-counterclockwise me-2"></i>Reopen</button>
                  <% } %>
                  <% if (canManageAll) { %>
                    <button class="btn btn-outline-danger btn-sm notification-delete-action" data-id="<%= row.id %>"><i class="bi bi-trash3 me-2"></i>Delete</button>
                  <% } %>
                <% } %>
              </div>
            </div>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="row align-items-center mt-3 bg-white p-3 border rounded shadow-sm g-0">
  <div class="col-md-12 text-center text-md-start">
    <span class="text-muted small" style="font-weight: 500;">
      Showing <span class="text-dark"><%= (notifications || []).length %></span> notification(s)
    </span>
  </div>
</div>

<span id="urlRef" data-id="school/notifications" hidden></span>
<%- include('partials/tablePages-end') %>

<script>
  (function () {
    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, (ch) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
      }[ch]));
    }

    async function showNotificationMessage({ title, message, icon = 'info', buttons, size = 'md' } = {}) {
      if (typeof window.showMessageModal === 'function') {
        return window.showMessageModal({
          title: title || 'School Notifications',
          icon,
          message: message || '',
          size,
          buttons: buttons && buttons.length ? buttons : [{ text: 'OK', class: 'btn-primary' }]
        });
      }
      console.warn(`${title || 'School Notifications'}: ${message || ''}`);
      return buttons?.[0]?.text || 'OK';
    }

    async function requestNote(status) {
      const label = String(status || '').replace(/_/g, ' ');
      const confirmText = status === 'resolved' ? 'Resolve' : (status === 'dismissed' ? 'Dismiss' : 'Update');
      const noteId = `notificationNote_${Date.now()}`;
      const result = await showNotificationMessage({
        title: `${confirmText} Notification`,
        icon: status === 'resolved' ? 'success' : 'warning',
        size: 'lg',
        message: `
          <p class="mb-2">Set this notification to <b>${escapeHtml(label)}</b>.</p>
          <label class="form-label" for="${noteId}">Optional note</label>
          <textarea class="form-control" id="${noteId}" rows="4" maxlength="1000"></textarea>
        `,
        buttons: [
          { text: 'Cancel', class: 'btn-secondary' },
          { text: confirmText, class: status === 'resolved' ? 'btn-success' : 'btn-warning' }
        ]
      });
      if (result !== confirmText) return null;
      return document.getElementById(noteId)?.value || '';
    }

    async function postStatus(id, status, note) {
      const response = await fetch(`/school/notifications/api/${encodeURIComponent(id)}/status`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Ajax-Request': 'true'
        },
        body: JSON.stringify({ status, note })
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok || payload.status === 'error') {
        await showNotificationMessage({
          title: 'School Notifications',
          icon: 'error',
          message: escapeHtml(payload.message || 'The notification could not be updated.'),
          buttons: [{ text: 'OK', class: 'btn-danger' }]
        });
        return;
      }
      window.location.reload();
    }

    async function confirmDelete() {
      const result = await showNotificationMessage({
        title: 'Delete Notification',
        icon: 'warning',
        message: 'Delete this notification permanently?',
        buttons: [
          { text: 'Keep Notification', class: 'btn-secondary' },
          { text: 'Delete Notification', class: 'btn-danger' }
        ]
      });
      return result === 'Delete Notification';
    }

    async function postDelete(id) {
      const confirmed = await confirmDelete();
      if (!confirmed) return;
      const response = await fetch(`/school/notifications/api/${encodeURIComponent(id)}/delete`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Ajax-Request': 'true'
        },
        body: JSON.stringify({})
      });
      const payload = await response.json().catch(() => ({}));
      if (!response.ok || payload.status === 'error') {
        await showNotificationMessage({
          title: 'School Notifications',
          icon: 'error',
          message: payload.message || 'The notification could not be deleted.',
          buttons: [{ text: 'OK', class: 'btn-danger' }]
        });
        return;
      }
      window.location.reload();
    }

    function initCollapseToggleIcon(options = {}) {
      const collapseEl = document.getElementById(String(options.collapseId || ''));
      const buttonEl = document.getElementById(String(options.buttonId || ''));
      const iconEl = document.getElementById(String(options.iconId || ''));
      if (!collapseEl || !buttonEl || !iconEl) return;

      const openIcon = String(options.openIcon || 'bi-chevron-down');
      const closeIcon = String(options.closeIcon || 'bi-chevron-up');
      const openLabel = String(options.openLabel || 'Open filters');
      const closeLabel = String(options.closeLabel || 'Close filters');

      const setState = (expanded) => {
        iconEl.classList.remove(openIcon, closeIcon);
        iconEl.classList.add(expanded ? closeIcon : openIcon);
        buttonEl.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        buttonEl.setAttribute('aria-label', expanded ? closeLabel : openLabel);
      };

      setState(collapseEl.classList.contains('show'));
      collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
      collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
    }

    document.querySelectorAll('.notification-status-action').forEach((button) => {
      button.addEventListener('click', async () => {
        const id = button.dataset.id || '';
        const status = button.dataset.status || '';
        if (!id || !status) return;
        const note = await requestNote(status);
        if (note === null) return;
        await postStatus(id, status, note);
      });
    });

    document.querySelectorAll('.notification-delete-action').forEach((button) => {
      button.addEventListener('click', async () => {
        const id = button.dataset.id || '';
        if (!id) return;
        await postDelete(id);
      });
    });

    initCollapseToggleIcon({
      collapseId: 'notificationFilterCollapse',
      buttonId: 'notificationFilterToggleBtn',
      iconId: 'notificationFilterToggleIcon',
      openIcon: 'bi-chevron-down',
      closeIcon: 'bi-chevron-up',
      openLabel: 'Open filters',
      closeLabel: 'Close filters'
    });
  })();
</script>
