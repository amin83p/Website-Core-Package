<div class="schedule-shell">
    <p class="text-muted small mb-3">View and manage class attendance across sessions. Pick a class, set a date range, then apply to load the matrix.</p>

    <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
            <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter Attendance Matrix</div>
            <button
                id="attFilterToggleBtn"
                type="button"
                class="btn btn-outline-secondary btn-sm px-2"
                data-bs-toggle="collapse"
                data-bs-target="#attFilterCollapse"
                aria-expanded="true"
                aria-controls="attFilterCollapse"
                aria-label="Close filters">
                <i id="attFilterToggleIcon" class="bi bi-chevron-up"></i>
            </button>
        </div>
        <div class="collapse show" id="attFilterCollapse">
            <div class="card-body filter-panel p-3" id="attFilterForm">
