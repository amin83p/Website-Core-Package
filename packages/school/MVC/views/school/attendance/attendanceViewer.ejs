  </style>
</head>
<body>
  <div class="screen-actions no-print">
    <button type="button" onclick="window.print()">Print</button>
    <button type="button" onclick="window.close()">Close</button>
  </div>
  <div class="sheet">
    <header class="doc-header">
      ${orgName ? `<div class="org-name">${attPrintEscapeHtml(orgName)}</div>` : ''}
      <h1>Attendance Matrix</h1>
      <div class="meta-row">
        <span><strong>Class:</strong> ${attPrintEscapeHtml(className)}</span>
        <span><strong>Range:</strong> ${attPrintEscapeHtml(rangeLabel)}</span>
        <span><strong>Printed:</strong> ${attPrintEscapeHtml(printedAtLabel)}</span>
      </div>
    </header>

    <div class="summary">
      <span class="stat"><b>${summary.studentCount}</b> students</span>
      <span class="stat"><b>${summary.sessionCount}</b> sessions</span>
      <span class="stat">P <b>${c.present}</b></span>
      <span class="stat">L <b>${c.late}</b></span>
      <span class="stat">E <b>${c.excused}</b></span>
      <span class="stat">A <b>${c.absent}</b></span>
      <span class="stat">N/A <b>${c.not_applicable}</b></span>
      <span class="stat">Avg rollup <b>${attPrintEscapeHtml(avgPctLabel)}</b></span>
    </div>
    <div class="legend">Legend: P Present · L Late · E Excused · A Absent · — N/A · minutes as late'/early' (e.g. L 12', L /5', or L 12'/5')</div>

    <table class="matrix">
      <thead>
        <tr>
          <th class="num-col">#</th>
          <th class="name-col">Student</th>
          <th class="rollup-col">P/A/%</th>
          ${headerCells}
        </tr>
      </thead>
      <tbody>
        ${bodyRows || emptyRow}
      </tbody>
    </table>

    ${footnotesHtml}

    <footer class="doc-footer">
      <span>Generated from Attendance Matrix</span>
      <span>${attPrintEscapeHtml(className)} · ${attPrintEscapeHtml(rangeLabel)}</span>
    </footer>
  </div>
</body>
</html>`;
    }

    function openAttendancePrint() {
        if (!window.currentMatrixData || window.currentMatrixData.status !== 'success') {
            showAttendanceMatrixMessage({
                title: 'Nothing to print',
                icon: 'warning',
                message: 'Load an attendance matrix for a class first.',
                buttons: [{ text: 'Close', class: 'btn-secondary' }]
            });
            return;
        }

        const orgName = String(document.getElementById('activeOrgNameRef')?.getAttribute('data-name') || '').trim();
        const startDate = document.getElementById('filter_startDate')?.value || '';
        const endDate = document.getElementById('filter_endDate')?.value || '';
        const html = buildAttendancePrintDocument(window.currentMatrixData, {
            orgName,
            startDate,
            endDate,
            className: window.currentMatrixData.className,
            printedAt: new Date()
        });

        // Do not pass noopener/noreferrer in features: browsers return null and we cannot write the print HTML.
        const printWindow = window.open('', '_blank', 'height=720,width=1100');
        if (!printWindow) {
            showAttendanceMatrixMessage({
                title: 'Popup blocked',
                icon: 'warning',
                message: 'Allow pop-ups for this site to open the print page.',
                buttons: [{ text: 'Close', class: 'btn-secondary' }]
            });
            return;
        }

        try {
            printWindow.opener = null;
        } catch (_) { /* ignore */ }

        try {
            const byLabel = String(document.getElementById('activeOrgIdRef')?.getAttribute('data-id') || '').trim();
            const qsParts = ['print=1', 'view=attendance-matrix'];
            if (byLabel) qsParts.push(`org=${encodeURIComponent(byLabel)}`);
            printWindow.history.replaceState({}, '', `${location.pathname}?${qsParts.join('&')}`);
        } catch (_) { /* ignore */ }

        printWindow.document.open();
        printWindow.document.write(html);
        printWindow.document.close();
        printWindow.focus();
        setTimeout(() => {
            try { printWindow.print(); } catch (_) { /* ignore */ }
        }, 250);
    }

    document.getElementById('btn_printAttendanceMatrix')?.addEventListener('click', () => openAttendancePrint());

    // --- 4. Interactive Note Saving Logic ---
    document.getElementById('btn_saveComment').addEventListener('click', async () => {
        const classId = document.getElementById('modal_classId').value;
        const sessionId = document.getElementById('modal_sessionId').value;
        const personId = document.getElementById('modal_personId').value;
        const text = document.getElementById('inp_newComment').value;

        if (!text.trim()) return;

        const btn = document.getElementById('btn_saveComment');
        const origBtn = btn.innerHTML;
        btn.innerHTML = 'Saving...'; btn.disabled = true;
        showAttendanceMatrixBusy({
            title: 'Saving Comment',
            note: 'Please wait while the attendance note is saved and the matrix refreshes.',
            operation: 'Attendance Matrix'
        });

        try {
            const payload = {
                classId: classId,
                sessionId: sessionId,
                studentPersonId: personId,
                text: text,
                mentions: currentMentions,
                attachment: await uploadAttendanceFile(document.getElementById('inp_newCommentFile'), 'comment', classId, sessionId, personId),
                actionStateId
            };

            const res = await fetch('/school/attendances/api/comment', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
                body: JSON.stringify(payload)
            });
            const result = await res.json();
            const guarded = typeof window.applyGuardedApiResult === 'function'
                ? await window.applyGuardedApiResult(result, { busyTitle: 'Save Comment In Progress', replayTitle: 'Comment Already Saved' })
                : { stop: false };
            if (guarded.stop) return;

            if (result.status !== 'success') throw new Error(result.message);
            
            document.getElementById('inp_newComment').value = '';
            const savedCommentFileInput = document.getElementById('inp_newCommentFile');
            if (savedCommentFileInput) savedCommentFileInput.value = '';
            currentMentions = [];
            renderMentions();
            
            await loadAttendanceMatrixData({
                skipButtonBusy: true,
                loadingTitle: 'Refreshing Attendance Matrix',
                loadingNote: 'Refreshing the attendance matrix after saving the note...'
            });

            const thread = document.getElementById('det_commentsThread');
            let mentionHtml = '';
            result.comment.mentions.forEach(m => mentionHtml += `<span class="mention-badge me-1">@${m.name}</span>`);
            const attachmentHtml = result.comment.attachment ? `<div class="small mt-1">${renderAttendanceAttachmentLink(result.comment.attachment)}</div>` : '';
            thread.innerHTML += `
                <div class="comment-bubble">
                    <span class="comment-time">${formatSchoolInstant(result.comment.timestamp)}</span>
                    <div class="comment-author">${result.comment.authorName}</div>
                    <div class="mt-1">${mentionHtml} ${result.comment.text}</div>
                    ${attachmentHtml}
                </div>
            `;
            thread.scrollTop = thread.scrollHeight;

        } catch (err) {
            hideAttendanceMatrixBusy(true);
            showAttendanceMatrixMessage({
                title: 'Error',
                icon: 'error',
                message: err.message,
                buttons: [{ text: 'Close', class: 'btn-secondary' }]
            });
        } finally {
            hideAttendanceMatrixBusy();
            btn.innerHTML = origBtn; btn.disabled = false;
        }
    });

    const btnSaveAttendance = document.getElementById('btn_saveAttendance');
    if (btnSaveAttendance) {
        btnSaveAttendance.addEventListener('click', async () => {
            const classId = document.getElementById('modal_classId').value;
            const sessionId = document.getElementById('modal_sessionId').value;
            const personId = document.getElementById('modal_personId').value;
            const attendance = document.querySelector('input[name="modal_cell_attendance"]:checked')?.value;
            if (!attendance) {
                if (typeof showMessageModal === 'function') {
                    showMessageModal({ title: 'Attendance', icon: 'warning', message: 'Select a status (Present, Late, Excused, Absent, or N/A).', buttons: [{ text: 'OK', class: 'btn-primary' }] });
                } else { alert('Select an attendance status.'); }
                return;
            }

            const btn = btnSaveAttendance;
            const origBtn = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
            btn.disabled = true;
            if (detailsModalInstance) detailsModalInstance.hide();
            showAttendanceMatrixBusy({
                title: 'Saving Attendance',
                note: 'Please wait while attendance changes are applied and the matrix refreshes.',
                operation: 'Attendance Matrix'
            });

            try {
                const payload = {
                    classId,
                    sessionId,
                    studentPersonId: personId,
                    attendance,
                    lateMinutes: document.getElementById('inp_cellLateMins').value,
                    earlyLeaveMinutes: document.getElementById('inp_cellLeaveMins').value,
                    excuseRef: document.getElementById('inp_cellExcuseRef').value,
                    excuseAttachment: await uploadAttendanceFile(document.getElementById('inp_cellExcuseFile'), 'excuse', classId, sessionId, personId) || window.currentAttendanceExcuseAttachment || null,
                    notes: document.getElementById('inp_rosterStudentNote').value,
                    actionStateId
                };
                const res = await fetch('/school/attendances/api/update-roster-cell', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
                    body: JSON.stringify(payload)
                });
                const result = await res.json();
                const guarded = typeof window.applyGuardedApiResult === 'function'
                    ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Completed' })
                    : { stop: false };
                if (guarded.stop) return;
                if (result.status !== 'success') throw new Error(result.message);

                await loadAttendanceMatrixData({
                    skipButtonBusy: true,
                    loadingTitle: 'Refreshing Attendance Matrix',
                    loadingNote: 'Refreshing the attendance matrix after saving attendance...'
                });
            } catch (err) {
                hideAttendanceMatrixBusy(true);
                showAttendanceMatrixMessage({
                    title: 'Error',
                    icon: 'error',
                    message: err.message,
                    buttons: [{ text: 'Close', class: 'btn-secondary' }]
                });
            } finally {
                hideAttendanceMatrixBusy();
                btn.innerHTML = origBtn;
                btn.disabled = false;
            }
        });
    }

    // --- 5. Query / server initial state: class, date range, deep link ---
    const init = window.ATTENDANCE_PAGE_INITIAL || {};
    const urlParams = new URLSearchParams(window.location.search);
    const qClassId = (urlParams.get('classId') || init.classId || '').trim();
    const qClassName = (urlParams.get('className') || init.className || '').trim();
    let qStart = (urlParams.get('startDate') || init.startDate || '').trim();
    let qEnd = (urlParams.get('endDate') || init.endDate || '').trim();
    const qStudentId = (urlParams.get('studentId') || init.studentId || '').trim();
    const qSessionId = (urlParams.get('sessionId') || init.sessionId || '').trim();
    const qRange = (urlParams.get('range') || init.range || '').trim().toLowerCase();
    const wantsAllTimeRange = qRange === 'alltime' || qRange === 'all_time';

    if (qStart && !qEnd) qEnd = qStart;

    if (qClassId) {
        document.getElementById('filter_classId').value = qClassId;
        document.getElementById('filter_className').value = qClassName || 'Loading Class Data...';
    }
    if (qStart) document.getElementById('filter_startDate').value = qStart;
    if (qEnd) document.getElementById('filter_endDate').value = qEnd;

    if (!qClassId) {
        document.querySelector('.btn-range[data-range="thisWeek"]').click();
    } else if (qStart && qEnd) {
        document.getElementById('btn_loadData').click();
    } else if (wantsAllTimeRange) {
        document.querySelector('.btn-range[data-range="allTime"]').click();
    } else if (qStudentId && qSessionId && !qStart) {
        document.querySelector('.btn-range[data-range="allTime"]').click();
    } else {
        document.querySelector('.btn-range[data-range="thisWeek"]').click();
    }
});

// --- NEW: Global Function to handle Header Clicks ---
window.confirmOpenSession = async function(classId, sessionId) {
    if (typeof showMessageModal === 'function') {
        const res = await showMessageModal({
            title: 'Open Session Manager',
            icon: 'question',
            message: 'Do you want to open the Session Manager for this specific date in a new tab?',
            buttons: [
                { text: 'Cancel', class: 'btn-secondary', value: false },
                { text: 'Open Session', class: 'btn-primary', value: true }
            ]
        });
        if (res === true || (res && res.value === true) || res === 'Open Session') {
            window.open(`/school/classes/${classId}/sessions/${sessionId}`, '_blank');
        }
    } else {
        if (confirm("Do you want to open the Session Manager for this date in a new tab?")) {
            window.open(`/school/classes/${classId}/sessions/${sessionId}`, '_blank');
        }
    }
};

// Global Function to handle Cell Clicks
window.openInteractiveModal = function(studentPersonId, sessionId) {
    if (!window.currentMatrixData) return;
    const matrix = window.currentMatrixData.matrix;
    const student = matrix.find(s => s.personId === studentPersonId);
    if (!student) return;
    const record = student.records.find(r => r.sessionId === sessionId);
    if (!record) return;

    document.getElementById('modal_classId').value = window.currentMatrixData.classId;
    document.getElementById('modal_sessionId').value = sessionId;
    document.getElementById('modal_personId').value = studentPersonId;
    const studentNameEl = document.getElementById('det_studentName');
    if (studentNameEl) {
        if (typeof schoolRenderStudentNameHtml === 'function') {
            studentNameEl.innerHTML = schoolRenderStudentNameHtml(student.name, record.studentRecordId || student.studentRecordId, { className: 'text-decoration-none fw-bold' });
        } else {
            studentNameEl.innerText = student.name;
        }
    }
    document.getElementById('det_date').innerText = `Session Date: ${record.date}`;

    const allowed = ['present', 'late', 'excused', 'absent', 'not_applicable'];
    const effStatus = allowed.includes(record.status) ? record.status : 'absent';
    document.querySelectorAll('input[name="modal_cell_attendance"]').forEach((el) => {
        el.checked = el.value === effStatus;
    });
    document.getElementById('inp_cellLateMins').value = record.lateMinutes != null && record.lateMinutes !== '' ? record.lateMinutes : '';
    document.getElementById('inp_cellLeaveMins').value = record.earlyLeaveMinutes != null && record.earlyLeaveMinutes !== '' ? record.earlyLeaveMinutes : '';
    document.getElementById('inp_cellExcuseRef').value = record.excuseRef || '';
    window.currentAttendanceExcuseAttachment = record.excuseAttachment || null;
    const excuseFileInput = document.getElementById('inp_cellExcuseFile');
    if (excuseFileInput) excuseFileInput.value = '';
    const excusePreview = document.getElementById('inp_cellExcuseAttachmentPreview');
    if (excusePreview) excusePreview.innerHTML = renderAttendanceAttachmentLink(record.excuseAttachment, '<span class="text-muted">No file attached.</span>');
    document.getElementById('inp_rosterStudentNote').value = record.rosterStudentNotes != null ? record.rosterStudentNotes : '';

    const sessionNote = record.sessionLevelNote || '';
    const snWrap = document.getElementById('det_sessionLevelNote_wrap');
    if (sessionNote) {
        snWrap.classList.remove('d-none');
        document.getElementById('det_sessionLevelNote').textContent = sessionNote;
    } else {
        snWrap.classList.add('d-none');
    }

    const locked = record.sessionLocked === true;
    const makeupRequired = record.applicability === 'makeup_required';
    const outsideEnrollmentWindow = record.withinEnrollmentWindow === false;
    const canEdit = window.CAN_EDIT_ATTENDANCE_ROSTER === true;
    const canOverride = window.CAN_OVERRIDE_SESSION_LOCK === true;
    const allowEdit = canEdit && !outsideEnrollmentWindow && !makeupRequired && (!locked || canOverride);
    const fs = document.getElementById('fieldset_cell_attendance');
    if (fs) fs.disabled = !allowEdit;
    const lockNotice = document.getElementById('cell_modal_lock_notice');
    const makeupNotice = document.getElementById('cell_modal_makeup_notice');
    const enrollmentNotice = document.getElementById('cell_modal_enrollment_notice');
    if (enrollmentNotice) {
        if (outsideEnrollmentWindow) enrollmentNotice.classList.remove('d-none');
        else enrollmentNotice.classList.add('d-none');
    }
    if (makeupNotice) {
        if (makeupRequired && canEdit) makeupNotice.classList.remove('d-none');
        else makeupNotice.classList.add('d-none');
    }
    if (locked && !canOverride && canEdit && !makeupRequired) lockNotice.classList.remove('d-none');
    else lockNotice.classList.add('d-none');
    const saveAttBtn = document.getElementById('btn_saveAttendance');
    if (saveAttBtn) {
        saveAttBtn.disabled = !allowEdit;
    }
    ['inp_newComment', 'inp_newCommentFile', 'btn_saveComment', 'btn_mentionUser'].forEach((id) => {
        const el = document.getElementById(id);
        if (el) el.disabled = !allowEdit;
    });

    const thread = document.getElementById('det_commentsThread');
    thread.innerHTML = '';
    if (record.comments && record.comments.length > 0) {
        record.comments.forEach(c => {
            let mentionHtml = '';
            (c.mentions || []).forEach(m => mentionHtml += `<span class="mention-badge me-1">@${m.name}</span>`);
            const attachmentHtml = c.attachment ? `<div class="small mt-1">${renderAttendanceAttachmentLink(c.attachment)}</div>` : '';
            
            thread.innerHTML += `
                <div class="comment-bubble">
                    <span class="comment-time">${formatSchoolInstant(c.timestamp)}</span>
                    <div class="comment-author">${c.authorName}</div>
                    <div class="mt-1">${mentionHtml} ${c.text}</div>
                    ${attachmentHtml}
                </div>
            `;
        });
    } else {
        thread.innerHTML = '<div class="text-muted small text-center py-2">No administrative notes yet. Be the first to comment.</div>';
    }

            document.getElementById('inp_newComment').value = '';
            const commentFileInput = document.getElementById('inp_newCommentFile');
            if (commentFileInput) commentFileInput.value = '';
            currentMentions = [];
    document.getElementById('pendingMentionsArea').innerHTML = '';

    if (detailsModalInstance) detailsModalInstance.show();
};
</script>
