                    <div class="col-lg-4 col-md-6">
                        <label class="form-label" for="filter_className">Class</label>
                        <div class="input-group">
                            <input type="hidden" id="filter_classId">
                            <input type="text" id="filter_className" class="form-control bg-white" placeholder="Select class..." readonly>
                            <button type="button" class="btn btn-outline-primary" id="btn_openClassPicker" title="Select class">
                                <i class="bi bi-book"></i>
                            </button>
                            <button type="button" class="btn btn-outline-secondary" id="btn_clearClass" title="Clear class">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-3">
                        <label class="form-label" for="filter_startDate">Start Date</label>
                        <input type="date" id="filter_startDate" class="form-control size-md">
                    </div>
                    <div class="col-lg-2 col-md-3">
                        <label class="form-label" for="filter_endDate">End Date</label>
                        <input type="date" id="filter_endDate" class="form-control size-md">
                    </div>
                    <div class="col-12 col-lg-4 d-flex justify-content-lg-end gap-2 pt-lg-2">
                        <button type="button" id="btn_reset" class="btn btn-outline-secondary btn-md">Reset</button>
                        <button type="button" id="btn_loadData" class="btn btn-filled btn-primary btn-md">
                            <i class="bi bi-funnel me-1"></i> Apply
                        </button>
                    </div>
                </div>
                <div class="border rounded-3 bg-white bg-opacity-75 p-2 mt-3">
                    <div class="small fw-bold text-uppercase text-muted mb-2">Quick Ranges</div>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button" class="btn btn-outline-secondary btn-sm btn-range range-chip" data-range="today">Today</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm btn-range range-chip" data-range="twoWeeks">Two Weeks</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm btn-range range-chip" data-range="thisWeek">This Week</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm btn-range range-chip" data-range="prevWeek">Prev Week</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm btn-range range-chip" data-range="thisMonth">This Month</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm btn-range range-chip" data-range="prevMonth">Prev Month</button>
                        <button type="button" class="btn btn-outline-secondary btn-sm btn-range range-chip" data-range="allTime">Whole Class (All Time)</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm d-none" id="resultsContainer">
        <div class="card-header bg-white border-bottom py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
            <h5 class="m-0 fw-bold text-primary" id="lbl_displayClassName">Class Name</h5>
            <div class="small text-muted text-md-end">
                <span class="me-3"><i class="bi bi-check-circle-fill text-success"></i> Present</span>
                <span class="me-3"><i class="bi bi-clock-fill text-warning"></i> Late</span>
                <span class="me-3"><i class="bi bi-envelope-paper-fill text-info"></i> Excused</span>
                <span class="me-3"><i class="bi bi-x-circle-fill text-danger"></i> Absent</span>
                <span class="me-3"><i class="bi bi-percent text-secondary"></i> Rollup % = time-based credit (see column header)</span>
