                    <p class="text-secondary small mb-0 mt-2 d-none" id="cell_modal_enrollment_notice">This student was not enrolled for this session date. Attendance and roster details are read-only.</p>
                </div>

                <fieldset id="fieldset_cell_attendance" class="border-0 p-0 m-0 mb-4">
                    <legend class="fw-bold small text-secondary mb-2">Attendance</legend>
                    <div class="btn-group btn-group-sm flex-wrap mb-3" role="group" aria-label="Attendance status">
