<%
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
  const orgLabel = String(activeOrgId || '').trim();
  const orgName = String(activeOrgName || orgLabel).trim();
  const backend = String(backendMode || 'json').trim().toLowerCase();
  const groups = Array.isArray(catalogGroups) ? catalogGroups : [];
%>

<style>
  .data-maintenance-page .collection-nav .list-group-item.active {
    background: rgba(13, 110, 253, 0.08);
    border-color: rgba(13, 110, 253, 0.25);
    color: #0d6efd;
    font-weight: 600;
  }
  .data-maintenance-page .collection-count {
    min-width: 2.25rem;
    text-align: right;
  }
  .data-maintenance-page .table td,
  .data-maintenance-page .table th {
    vertical-align: middle;
  }
</style>

<div class="sections-page data-maintenance-page" data-action-state-id="<%= asid %>">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
      <h1 class="page-heading size-md m-0 text-start"><i class="bi bi-database-gear me-2"></i>School Data Maintenance</h1>
      <div class="text-muted mt-1">Browse real rows in school collections for the active organization and hard-delete selected records without dependency checks.</div>
      <div class="small text-muted mt-1">Org: <strong><%= orgName %></strong> <span class="font-monospace">(<%= orgLabel %>)</span></div>
      <div class="small text-muted">Backend: <span class="badge bg-secondary text-uppercase"><%= backend %></span></div>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <a href="/school/sample-data" class="btn btn-outline-secondary btn-sm"><i class="bi bi-database-fill me-1"></i>Sample Data</a>
      <a href="/school/classes/storage-integrity" class="btn btn-outline-secondary btn-sm"><i class="bi bi-hdd-network me-1"></i>Storage Integrity</a>
      <button type="button" class="btn btn-outline-primary btn-sm" id="btnRefreshSummary"><i class="bi bi-arrow-clockwise me-1"></i>Refresh</button>
    </div>
  </div>

  <div class="alert border border-warning mb-4" style="background:rgba(255,193,7,0.08)">
    <div class="fw-semibold"><i class="bi bi-exclamation-triangle me-1"></i>Maintenance delete factory</div>
    <div class="small mb-0">Deletes are permanent and bypass deletion guards. Use for test cleanup only. Head school accounts are protected.</div>
  </div>

  <div class="row g-4">
    <div class="col-lg-3">
      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-bold">Collections</div>
        <div class="card-body p-0 collection-nav" id="collectionNav">
          <div class="text-muted small p-3">Loading collections...</div>
        </div>
      </div>
    </div>

    <div class="col-lg-9">
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
          <div>
            <div class="fw-bold" id="activeCollectionLabel">Select a collection</div>
            <div class="small text-muted font-monospace" id="activeCollectionMeta"></div>
          </div>
          <div class="d-flex flex-wrap gap-2">
            <input type="search" class="form-control form-control-sm" id="rowSearchInput" placeholder="Search id or label" style="min-width: 12rem;" disabled>
            <button type="button" class="btn btn-outline-danger btn-sm" id="btnClearAll" disabled hidden>Clear All (Org)</button>
            <button type="button" class="btn btn-danger btn-sm" id="btnDeleteSelected" disabled><i class="bi bi-trash me-1"></i>Delete Selected</button>
          </div>
        </div>
        <div class="card-body p-0">
          <div id="rowsPlaceholder" class="text-muted small p-4">Select a collection from the sidebar to view records.</div>
          <div class="table-responsive" id="rowsTableWrap" hidden>
            <table class="table table-sm table-hover mb-0">
              <thead class="table-light">
                <tr>
                  <th class="ps-3" style="width:2.5rem;"><input type="checkbox" id="chkSelectAllRows" title="Select all on page"></th>
                  <th>ID</th>
                  <th>Label</th>
                  <th>Status</th>
                  <th class="pe-3">Updated</th>
                </tr>
              </thead>
              <tbody id="rowsTableBody"></tbody>
            </table>
          </div>
        </div>
        <div class="card-footer bg-white d-flex justify-content-between align-items-center flex-wrap gap-2" id="rowsPager" hidden>
          <div class="small text-muted" id="rowsPagerSummary"></div>
          <div class="btn-group btn-group-sm">
            <button type="button" class="btn btn-outline-secondary" id="btnPrevPage">Previous</button>
            <button type="button" class="btn btn-outline-secondary" id="btnNextPage">Next</button>
          </div>
        </div>
      </div>

      <div id="operationResult" class="alert border" hidden role="status"></div>
    </div>
  </div>
</div>

<div class="modal fade" id="deleteConfirmModal" tabindex="-1" aria-labelledby="deleteConfirmModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="deleteConfirmModalLabel">Confirm Hard Delete</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-danger small">This permanently removes selected rows from the active data backend. Type <strong>DELETE</strong> to confirm.</div>
        <div id="deletePreviewSummary" class="mb-3 small"></div>
        <ul class="list-group list-group-flush small mb-3" id="deletePreviewList"></ul>
        <input type="text" class="form-control" id="deleteConfirmInput" placeholder="Type DELETE" autocomplete="off">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" id="btnConfirmDelete" disabled>Delete Selected</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="clearAllConfirmModal" tabindex="-1" aria-labelledby="clearAllConfirmModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="clearAllConfirmModalLabel">Clear Entire Collection</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-danger small">This removes <strong>all</strong> rows for the active organization in this collection. Type <strong>CLEAR ALL</strong> to confirm.</div>
        <div class="small mb-3" id="clearAllSummary"></div>
        <input type="text" class="form-control" id="clearAllConfirmInput" placeholder="Type CLEAR ALL" autocomplete="off">
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger" id="btnConfirmClearAll" disabled>Clear All</button>
      </div>
    </div>
  </div>
</div>

<script>
(() => {
  const pageEl = document.querySelector('.data-maintenance-page');
  const actionStateId = String(pageEl?.dataset?.actionStateId || '').trim();
  const collectionNavEl = document.getElementById('collectionNav');
  const activeCollectionLabelEl = document.getElementById('activeCollectionLabel');
  const activeCollectionMetaEl = document.getElementById('activeCollectionMeta');
  const rowsPlaceholderEl = document.getElementById('rowsPlaceholder');
  const rowsTableWrapEl = document.getElementById('rowsTableWrap');
  const rowsTableBodyEl = document.getElementById('rowsTableBody');
  const rowsPagerEl = document.getElementById('rowsPager');
  const rowsPagerSummaryEl = document.getElementById('rowsPagerSummary');
  const rowSearchInputEl = document.getElementById('rowSearchInput');
  const btnDeleteSelectedEl = document.getElementById('btnDeleteSelected');
  const btnClearAllEl = document.getElementById('btnClearAll');
  const btnRefreshSummaryEl = document.getElementById('btnRefreshSummary');
  const chkSelectAllRowsEl = document.getElementById('chkSelectAllRows');
  const btnPrevPageEl = document.getElementById('btnPrevPage');
  const btnNextPageEl = document.getElementById('btnNextPage');
  const operationResultEl = document.getElementById('operationResult');

  const deleteConfirmModalEl = document.getElementById('deleteConfirmModal');
  const deletePreviewSummaryEl = document.getElementById('deletePreviewSummary');
  const deletePreviewListEl = document.getElementById('deletePreviewList');
  const deleteConfirmInputEl = document.getElementById('deleteConfirmInput');
  const btnConfirmDeleteEl = document.getElementById('btnConfirmDelete');

  const clearAllConfirmModalEl = document.getElementById('clearAllConfirmModal');
  const clearAllSummaryEl = document.getElementById('clearAllSummary');
  const clearAllConfirmInputEl = document.getElementById('clearAllConfirmInput');
  const btnConfirmClearAllEl = document.getElementById('btnConfirmClearAll');

  let deleteModal = null;
  let clearAllModal = null;
  if (deleteConfirmModalEl && window.bootstrap && window.bootstrap.Modal) {
    deleteModal = window.bootstrap.Modal.getOrCreateInstance(deleteConfirmModalEl);
  }
  if (clearAllConfirmModalEl && window.bootstrap && window.bootstrap.Modal) {
    clearAllModal = window.bootstrap.Modal.getOrCreateInstance(clearAllConfirmModalEl);
  }

  const state = {
    summary: null,
    activeEntityType: '',
    page: 1,
    limit: 50,
    search: '',
    rows: [],
    total: 0,
    selectedIds: new Set(),
    pendingDeleteIds: []
  };

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;');
  }

  function showOperationResult(kind, message, detailsHtml = '') {
    if (!operationResultEl) return;
    const styles = {
      success: 'border-success',
      error: 'border-danger',
      warning: 'border-warning'
    };
    operationResultEl.className = `alert border ${styles[kind] || 'border-secondary'}`;
    operationResultEl.innerHTML = `<div class="fw-semibold">${escapeHtml(message)}</div>${detailsHtml ? `<div class="small mt-2">${detailsHtml}</div>` : ''}`;
    operationResultEl.hidden = false;
  }

  async function ensureAdminVerification() {
    if (typeof window.ensureAdminVerification === 'function') {
      return window.ensureAdminVerification();
    }
    return true;
  }

  function getActiveCatalogEntry() {
    const collections = Array.isArray(state.summary?.collections) ? state.summary.collections : [];
    return collections.find((row) => row.entityType === state.activeEntityType) || null;
  }

  function updateActionButtons() {
    const entry = getActiveCatalogEntry();
    const hasSelection = state.selectedIds.size > 0;
    const canDelete = entry && !entry.listOnly && entry.deleteStrategy !== 'unsupported';
    btnDeleteSelectedEl.disabled = !canDelete || !hasSelection;
    if (entry?.supportsClearAll) {
      btnClearAllEl.hidden = false;
      btnClearAllEl.disabled = false;
    } else {
      btnClearAllEl.hidden = true;
      btnClearAllEl.disabled = true;
    }
  }

  function renderCollectionNavError(message) {
    collectionNavEl.innerHTML = `<div class="text-danger small p-3">${escapeHtml(message || 'Could not load collections.')}</div>`;
  }

  function renderCollectionNav() {
    const groups = Array.isArray(state.summary?.groups) ? state.summary.groups : [];
    const collections = Array.isArray(state.summary?.collections) ? state.summary.collections : [];
    if (!groups.length || !collections.length) {
      collectionNavEl.innerHTML = '<div class="text-muted small p-3">No collections found.</div>';
      return;
    }

    const html = groups.map((group) => {
      const items = collections.filter((row) => row.group === group.id);
      if (!items.length) return '';
      const list = items.map((item) => {
        const active = item.entityType === state.activeEntityType ? ' active' : '';
        return `<button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center${active}" data-entity-type="${escapeHtml(item.entityType)}">
          <span>${escapeHtml(item.label)}</span>
          <span class="badge bg-light text-dark collection-count">${Number(item.count || 0)}</span>
        </button>`;
      }).join('');
      return `<div class="px-3 pt-3 pb-1 small text-uppercase text-muted fw-semibold">${escapeHtml(group.label)}</div>
        <div class="list-group list-group-flush border-0">${list}</div>`;
    }).join('');

    collectionNavEl.innerHTML = html;
    collectionNavEl.querySelectorAll('[data-entity-type]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const entityType = btn.getAttribute('data-entity-type');
        if (!entityType || entityType === state.activeEntityType) return;
        state.activeEntityType = entityType;
        state.page = 1;
        state.search = '';
        state.selectedIds = new Set();
        rowSearchInputEl.value = '';
        renderCollectionNav();
        loadRows();
      });
    });
  }

  function renderRowsTable() {
    const entry = getActiveCatalogEntry();
    if (!entry) {
      rowsPlaceholderEl.hidden = false;
      rowsPlaceholderEl.textContent = 'Select a collection from the sidebar to view records.';
      rowsTableWrapEl.hidden = true;
      rowsPagerEl.hidden = true;
      rowSearchInputEl.disabled = true;
      return;
    }

    activeCollectionLabelEl.textContent = entry.label;
    activeCollectionMetaEl.textContent = `${entry.collectionName} · ${entry.deleteStrategy}${entry.listOnly ? ' · list only' : ''}`;

    rowSearchInputEl.disabled = false;
    rowsPlaceholderEl.hidden = true;
    rowsTableWrapEl.hidden = false;
    rowsPagerEl.hidden = false;

    if (!state.rows.length) {
      rowsTableBodyEl.innerHTML = `<tr><td colspan="5" class="text-muted small p-3">No records found for this organization.</td></tr>`;
    } else {
      rowsTableBodyEl.innerHTML = state.rows.map((row) => {
        const checked = state.selectedIds.has(row.id) ? ' checked' : '';
        const disabled = !row.deletable ? ' disabled' : '';
        const title = row.protectionReason ? ` title="${escapeHtml(row.protectionReason)}"` : '';
        return `<tr>
          <td class="ps-3"><input type="checkbox" class="row-select" data-id="${escapeHtml(row.id)}"${checked}${disabled}${title}></td>
          <td class="font-monospace small">${escapeHtml(row.id)}</td>
          <td>${escapeHtml(row.label || '')}${row.protected ? ' <span class="badge bg-secondary">protected</span>' : ''}</td>
          <td>${escapeHtml(row.status || '')}</td>
          <td class="pe-3 small text-muted">${escapeHtml(row.updatedAt || '')}</td>
        </tr>`;
      }).join('');
    }

    const start = state.total ? ((state.page - 1) * state.limit) + 1 : 0;
    const end = Math.min(state.page * state.limit, state.total);
    rowsPagerSummaryEl.textContent = state.total
      ? `Showing ${start}-${end} of ${state.total}`
      : 'No records';

    btnPrevPageEl.disabled = state.page <= 1;
    btnNextPageEl.disabled = end >= state.total;

    rowsTableBodyEl.querySelectorAll('.row-select').forEach((chk) => {
      chk.addEventListener('change', () => {
        const id = chk.getAttribute('data-id');
        if (!id) return;
        if (chk.checked) state.selectedIds.add(id);
        else state.selectedIds.delete(id);
        updateActionButtons();
      });
    });

    const selectable = state.rows.filter((row) => row.deletable);
    chkSelectAllRowsEl.checked = selectable.length > 0 && selectable.every((row) => state.selectedIds.has(row.id));
    updateActionButtons();
  }

  async function loadSummary(selectFirst = false) {
    const response = await fetch('/school/data-maintenance/api/summary', {
      headers: { 'X-AJAX-Request': 'true' }
    });
    let payload = null;
    try {
      payload = await response.json();
    } catch (parseError) {
      throw new Error('Summary response was not valid JSON.');
    }
    if (!response.ok || payload.status !== 'success') {
      renderCollectionNavError(payload.message || `Could not load summary (HTTP ${response.status}).`);
      throw new Error(payload.message || 'Could not load summary.');
    }
    state.summary = payload.summary;
    renderCollectionNav();
    if (selectFirst && !state.activeEntityType) {
      const first = (state.summary.collections || [])[0];
      if (first?.entityType) {
        state.activeEntityType = first.entityType;
        renderCollectionNav();
        await loadRows();
      }
    } else if (state.activeEntityType) {
      await loadRows();
    }
  }

  async function loadRows() {
    if (!state.activeEntityType) {
      renderRowsTable();
      return;
    }
    const params = new URLSearchParams({
      page: String(state.page),
      limit: String(state.limit)
    });
    if (state.search) params.set('search', state.search);

    const response = await fetch(`/school/data-maintenance/api/${encodeURIComponent(state.activeEntityType)}/rows?${params.toString()}`, {
      headers: { 'X-AJAX-Request': 'true' }
    });
    const payload = await response.json();
    if (!response.ok || payload.status !== 'success') {
      throw new Error(payload.message || 'Could not load rows.');
    }

    state.rows = Array.isArray(payload.rows) ? payload.rows : [];
    state.total = Number(payload.total || 0);
    state.page = Number(payload.page || 1);
    state.limit = Number(payload.limit || 50);
    renderRowsTable();
  }

  async function openDeleteModal() {
    const ids = [...state.selectedIds];
    if (!ids.length || !state.activeEntityType) return;

    const response = await fetch(`/school/data-maintenance/api/${encodeURIComponent(state.activeEntityType)}/delete-preview`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-AJAX-Request': 'true'
      },
      body: JSON.stringify({ ids, actionStateId })
    });
    const payload = await response.json();
    if (!response.ok || payload.status !== 'success') {
      showOperationResult('error', payload.message || 'Could not build delete preview.');
      return;
    }

    const preview = payload.preview || {};
    state.pendingDeleteIds = (preview.items || []).filter((item) => item.status === 'ready').map((item) => item.id);
    deletePreviewSummaryEl.textContent = `${preview.readyCount || 0} ready, ${preview.skippedCount || 0} skipped in ${preview.catalogLabel || state.activeEntityType}.`;
    deletePreviewListEl.innerHTML = (preview.items || []).map((item) => {
      const badge = item.status === 'ready' ? 'success' : (item.status === 'missing' ? 'danger' : 'secondary');
      return `<li class="list-group-item d-flex justify-content-between gap-2">
        <span><span class="font-monospace">${escapeHtml(item.id)}</span> ${escapeHtml(item.label || '')}</span>
        <span class="badge bg-${badge}">${escapeHtml(item.status)}</span>
      </li>`;
    }).join('');

    deleteConfirmInputEl.value = '';
    btnConfirmDeleteEl.disabled = true;
    deleteModal?.show();
  }

  async function executeDelete() {
    if (!state.pendingDeleteIds.length || !state.activeEntityType) return;
    const verified = await ensureAdminVerification();
    if (!verified) return;

    const response = await fetch(`/school/data-maintenance/api/${encodeURIComponent(state.activeEntityType)}/delete`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-AJAX-Request': 'true'
      },
      body: JSON.stringify({ ids: state.pendingDeleteIds, actionStateId })
    });
    const payload = await response.json();
    if (payload?.status === 'access_required' || payload?.code === 'admin_required') {
      showOperationResult('warning', 'Admin verification is required.');
      return;
    }
    if (!response.ok || payload.status !== 'success') {
      showOperationResult('error', payload.message || 'Delete failed.');
      return;
    }

    deleteModal?.hide();
    state.selectedIds = new Set();
    const summary = payload.result?.summary || {};
    const detail = (payload.result?.results || []).filter((row) => row.status !== 'success')
      .map((row) => `${row.id}: ${row.message}`)
      .join('<br>');
    showOperationResult('success', payload.message || 'Delete completed.', detail);
    await loadSummary(false);
    await loadRows();
  }

  function openClearAllModal() {
    const entry = getActiveCatalogEntry();
    if (!entry?.supportsClearAll) return;
    clearAllSummaryEl.textContent = `This will clear all ${entry.count || 0} row(s) in ${entry.label} for the active organization.`;
    clearAllConfirmInputEl.value = '';
    btnConfirmClearAllEl.disabled = true;
    clearAllModal?.show();
  }

  async function executeClearAll() {
    const entry = getActiveCatalogEntry();
    if (!entry?.supportsClearAll || !state.activeEntityType) return;
    const verified = await ensureAdminVerification();
    if (!verified) return;

    const response = await fetch(`/school/data-maintenance/api/${encodeURIComponent(state.activeEntityType)}/clear-all`, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-AJAX-Request': 'true'
      },
      body: JSON.stringify({ actionStateId })
    });
    const payload = await response.json();
    if (!response.ok || payload.status !== 'success') {
      showOperationResult('error', payload.message || 'Clear all failed.');
      return;
    }

    clearAllModal?.hide();
    state.selectedIds = new Set();
    showOperationResult('success', payload.message || 'Collection cleared.');
    await loadSummary(false);
    await loadRows();
  }

  chkSelectAllRowsEl?.addEventListener('change', () => {
    const selectable = state.rows.filter((row) => row.deletable);
    if (chkSelectAllRowsEl.checked) {
      selectable.forEach((row) => state.selectedIds.add(row.id));
    } else {
      selectable.forEach((row) => state.selectedIds.delete(row.id));
    }
    renderRowsTable();
  });

  btnDeleteSelectedEl?.addEventListener('click', () => {
    openDeleteModal().catch((error) => showOperationResult('error', error.message));
  });

  btnClearAllEl?.addEventListener('click', openClearAllModal);

  deleteConfirmInputEl?.addEventListener('input', () => {
    btnConfirmDeleteEl.disabled = deleteConfirmInputEl.value.trim() !== 'DELETE' || !state.pendingDeleteIds.length;
  });

  btnConfirmDeleteEl?.addEventListener('click', () => {
    executeDelete().catch((error) => showOperationResult('error', error.message));
  });

  clearAllConfirmInputEl?.addEventListener('input', () => {
    btnConfirmClearAllEl.disabled = clearAllConfirmInputEl.value.trim() !== 'CLEAR ALL';
  });

  btnConfirmClearAllEl?.addEventListener('click', () => {
    executeClearAll().catch((error) => showOperationResult('error', error.message));
  });

  rowSearchInputEl?.addEventListener('change', () => {
    state.search = rowSearchInputEl.value.trim();
    state.page = 1;
    loadRows().catch((error) => showOperationResult('error', error.message));
  });

  btnPrevPageEl?.addEventListener('click', () => {
    if (state.page <= 1) return;
    state.page -= 1;
    loadRows().catch((error) => showOperationResult('error', error.message));
  });

  btnNextPageEl?.addEventListener('click', () => {
    const end = state.page * state.limit;
    if (end >= state.total) return;
    state.page += 1;
    loadRows().catch((error) => showOperationResult('error', error.message));
  });

  btnRefreshSummaryEl?.addEventListener('click', () => {
    loadSummary(false).catch((error) => showOperationResult('error', error.message));
  });

  loadSummary(true).catch((error) => {
    renderCollectionNavError(error.message);
    showOperationResult('error', error.message);
  });
})();
</script>
