    document.getElementById('btn_clearPerson')?.addEventListener('click', () => {
        document.getElementById('sch_personId').value = '';
        document.getElementById('sch_personName').value = '';
        const roleEl = document.getElementById('sch_role');
        if (roleEl) {
            roleEl.innerHTML = '<option value="">All Roles</option>';
            roleEl.value = '';
        }
        document.getElementById('scheduleTitle').innerText = 'Schedule';
        document.getElementById('scheduleContainer')?.classList.add('d-none');
        document.getElementById('viewModeIndicator').innerText = 'Ready';
        document.getElementById('scheduleHoursSummary')?.classList.add('d-none');
        const lblHours = document.getElementById('lbl_totalHours');
        if (lblHours) lblHours.innerHTML = '';
    });

    const roleSelect = document.getElementById('sch_role');
    if (roleSelect) {
        roleSelect.addEventListener('change', () => {
            if (document.getElementById('sch_personId').value && document.getElementById('sch_startDate').value && document.getElementById('sch_endDate').value) {
                document.getElementById('btn_loadSchedule').click();
            }
        });
    }
    const hasCasesFilter = document.getElementById('sch_hasCases');
    if (hasCasesFilter) {
        hasCasesFilter.addEventListener('change', () => {
            if (document.getElementById('sch_personId').value && document.getElementById('sch_startDate').value && document.getElementById('sch_endDate').value) {
                document.getElementById('btn_loadSchedule').click();
            }
        });
    }

    // --- 2. Data Fetch & Rendering Engine ---
    document.getElementById('btn_loadSchedule').addEventListener('click', async () => {
        const personId = document.getElementById('sch_personId').value;
        const startStr = document.getElementById('sch_startDate').value;
        const endStr = document.getElementById('sch_endDate').value;
        const role = document.getElementById('sch_role')?.value || '';

        if (!personId) { await uiAlert('Please select a person first.'); return; }

        const container = document.getElementById('visualDisplayArea');
        document.getElementById('scheduleContainer').classList.remove('d-none');
        container.innerHTML = `<div class="text-center py-5"><div class="spinner-border text-primary"></div><div class="mt-2 text-muted small">Loading schedule...</div></div>`;

        try {
            const params = new URLSearchParams({ personId, startDate: startStr, endDate: endStr });
            if (role) params.set('role', role);
            if (document.getElementById('sch_hasCases')?.checked) params.set('hasCases', '1');
            const res = await fetch(`/school/schedules/api/person-schedule?${params.toString()}`, {
                headers: { 'X-AJAX-Request': 'true' }
            });
            const result = await res.json();
            const guarded = typeof window.applyGuardedApiResult === 'function'
                ? await window.applyGuardedApiResult(result, { busyTitle: 'Schedule Load In Progress', replayTitle: 'Schedule Already Loaded' })
                : { stop: false };
            if (guarded.stop) return;
            if (result.status !== 'success') throw new Error(result.message);
            updateAdminRoleOptions(result.availableRoles, result.selectedRole);
            sessionStatusMetaMap = new Map(
                (Array.isArray(result.statusMeta) ? result.statusMeta : [])
                    .map((row) => [normalizeSessionStatus(row?.code), row])
                    .filter(([code]) => Boolean(code))
            );

            const events = result.events || [];
            const lblHours = document.getElementById('lbl_totalHours');
            
            if (events.length === 0) {
                if (lblHours) lblHours.innerHTML = '';
                document.getElementById('scheduleHoursSummary')?.classList.add('d-none');
                container.innerHTML = `<div class="alert alert-light text-center border py-5 text-muted"><i class="bi bi-calendar-x fs-1 d-block mb-2"></i>No schedule items found in this date range.</div>`;
                document.getElementById('viewModeIndicator').innerText = "Empty";
                return;
            }

            // Calculate and show category totals for the currently displayed events.
            if (lblHours) {
                lblHours.innerHTML = renderCategoryHourTotals(events);
                document.getElementById('scheduleHoursSummary')?.classList.remove('d-none');
            }

            const eventsByDate = {};
            events.forEach(ev => {
                if (!eventsByDate[ev.date]) eventsByDate[ev.date] = [];
                eventsByDate[ev.date].push(ev);
            });

            const startD = new Date(startStr);
            const endD = new Date(endStr);
            const diffDays = Math.ceil((endD - startD) / (1000 * 60 * 60 * 24));

            if (startStr === endStr || diffDays <= 0) {
                document.getElementById('viewModeIndicator').innerHTML = '<i class="bi bi-list-ul"></i> Single-Day List';
                document.getElementById('legendContainer').innerHTML = `
                    <div class="text-muted small">Vertical full-detail view for selected day</div>
                `;
                renderSingleDayListView(eventsByDate, container);
            } else if (diffDays <= 14) {
                document.getElementById('viewModeIndicator').innerHTML = '<i class="bi bi-distribute-vertical"></i> Timeline View';
                document.getElementById('legendContainer').innerHTML = `
                    <div><span class="d-inline-block rounded-circle" style="width:12px;height:12px;background:#0dcaf0;"></span> Teacher</div>
                    <div><span class="d-inline-block rounded-circle" style="width:12px;height:12px;background:#0d6efd;"></span> Student</div>
                    <div><span class="d-inline-block rounded-circle" style="width:12px;height:12px;background:#ffd43b;"></span> Approved Leave</div>
                    <div class="text-danger fw-bold"><span class="d-inline-block rounded-circle" style="width:12px;height:12px;background:#dc3545;"></span> Overlap</div>
                `;
                renderTimelineView(eventsByDate, container);
            } else {
                document.getElementById('viewModeIndicator').innerHTML = '<i class="bi bi-grid-3x3-gap"></i> Calendar Overview';
                document.getElementById('legendContainer').innerHTML = `
                    <div class="text-primary fw-bold"><i class="bi bi-circle-fill small"></i> Active Day</div>
                    <div class="text-danger fw-bold"><i class="bi bi-exclamation-circle-fill"></i> Conflict Day</div>
                    <div class="text-muted small">Click any day to zoom in</div>
                `;
                renderCalendarView(eventsByDate, startStr, endStr, container);
            }

        } catch (error) {
            container.innerHTML = `<div class="alert alert-danger text-center"><i class="bi bi-x-circle me-2"></i> ${error.message}</div>`;
        }
    });

    const TIMELINE_START_HOUR = 7;
    const TIMELINE_END_HOUR = 22;  
    const TOTAL_MINUTES = (TIMELINE_END_HOUR - TIMELINE_START_HOUR) * 60;

    function timeToMinutes(timeStr) {
        if (!timeStr) return 0;
        const [h, m] = timeStr.split(':').map(Number);
        return (h * 60) + m;
    }

    function calculatePosition(startStr, endStr) {
        let startMin = timeToMinutes(startStr);
        let endMin = timeToMinutes(endStr);
        const timelineStartMin = TIMELINE_START_HOUR * 60;
        const timelineEndMin = TIMELINE_END_HOUR * 60;
        
        if (startMin < timelineStartMin) startMin = timelineStartMin;
        if (endMin > timelineEndMin) endMin = timelineEndMin;
        if (endMin <= startMin) endMin = startMin + 30;

        const leftPercent = ((startMin - timelineStartMin) / TOTAL_MINUTES) * 100;
        const widthPercent = ((endMin - startMin) / TOTAL_MINUTES) * 100;

        return { left: leftPercent, width: widthPercent, startMin, endMin };
    }

    function renderSingleDayListView(eventsByDate, container) {
        container.innerHTML = '';
        const dates = Object.keys(eventsByDate || {}).sort();
        if (!dates.length) {
            container.innerHTML = `<div class="alert alert-light text-center border py-4 text-muted">No schedule items found for this day.</div>`;
            return;
        }

        let html = '<div class="single-day-list">';
        dates.forEach((dateStr) => {
            const dateObj = new Date(dateStr + 'T00:00:00');
            const displayDate = dateObj.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });
            const dayEvents = (eventsByDate[dateStr] || []).slice().sort((a, b) => {
                const aStart = timeToMinutes(a?.start);
                const bStart = timeToMinutes(b?.start);
                if (aStart !== bStart) return aStart - bStart;
                return String(a?.className || '').localeCompare(String(b?.className || ''));
            });
            const hasConflict = dayEvents.some((ev) => ev?.hasOverlap);

            html += `
                <div class="day-card">
                    <div class="day-card-header ${hasConflict ? 'conflict' : ''}">
                        <span>${escapeHtml(displayDate)}</span>
                        <span class="badge ${hasConflict ? 'bg-danger' : 'bg-primary'}">${dayEvents.length} item${dayEvents.length === 1 ? '' : 's'}</span>
                    </div>
            `;

            dayEvents.forEach((ev) => {
                const leaveEvent = isLeaveEvent(ev);
                const eventTitle = getEventTitle(ev);
                const statusLabel = formatStatusLabel(ev?.status);
                const statusStyle = getStatusTagStyle(ev?.status);
                const detailsUrl = String(ev?.detailsUrl || '').trim();
                const caseBadge = buildSessionCaseBadgeHtml(ev?.caseSummary);
                const openButton = detailsUrl
                    ? `<a class="btn btn-sm btn-outline-primary event-open" href="${escapeHtml(detailsUrl)}" target="_blank" rel="noopener">Open</a>`
                    : `<span class="text-muted small">No details</span>`;
                html += `
                    <div class="event-row ${ev?.hasOverlap ? 'overlap' : ''} ${leaveEvent ? 'leave-event' : ''}">
                        <div class="event-time">${escapeHtml(ev?.start || '-')} - ${escapeHtml(ev?.end || '-')}</div>
                        <div>
                            <div class="event-main-title">${escapeHtml(eventTitle)}</div>
                            <div class="event-meta-line">
                                <span class="badge ${leaveEvent ? 'bg-warning-subtle text-warning-emphasis border border-warning-subtle' : (String(ev?.role || '').toLowerCase() === 'student' ? 'bg-primary-subtle text-primary border' : 'bg-info-subtle text-info-emphasis border')}">${escapeHtml(leaveEvent ? 'Approved Leave' : (ev?.role || '-'))}</span>
                                <span class="session-status-tag" style="${statusStyle}">${escapeHtml(statusLabel)}</span>
                                ${caseBadge}
                                <span class="text-muted">${Number(ev?.duration || 0).toFixed(2)} h</span>
                            </div>
                            <div class="event-meta-line">${leaveEvent ? '<span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle">Leave request approved and reserved on schedule</span>' : buildLifecycleInline(ev)}</div>
                        </div>
                        <div class="event-actions">${openButton}</div>
                    </div>
                `;
            });

            html += '</div>';
        });
        html += '</div>';
        container.innerHTML = html;
    }

    function renderTimelineView(eventsByDate, container) {
        container.innerHTML = '';
        Object.keys(eventsByDate).sort().forEach(dateStr => {
            const dayEvents = eventsByDate[dateStr];
            const dateObj = new Date(dateStr + 'T00:00:00');
            const displayDate = dateObj.toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' });

            let tracks = [];
            const hasConflict = dayEvents.some((ev) => ev && ev.hasOverlap === true);

            dayEvents.forEach(ev => {
                const pos = calculatePosition(ev.start, ev.end);
                ev.pos = pos;

                let placed = false;
                for (let i = 0; i < tracks.length; i++) {
                    const lastEv = tracks[i][tracks[i].length - 1];
                    if (lastEv.pos.endMin <= pos.startMin) {
                        tracks[i].push(ev); ev.trackIndex = i; placed = true; break;
                    }
                }
                if (!placed) { tracks.push([ev]); ev.trackIndex = tracks.length - 1; }
            });

            const bodyHeight = Math.max(64, tracks.length * 56 + 10);
            const headerColorClass = hasConflict ? 'bg-danger text-white' : 'bg-light';

            let html = `
                <div class="timeline-container shadow-sm border ${hasConflict ? 'border-danger' : ''}">
                    <div class="timeline-header ${headerColorClass}">
                        <span>${displayDate}</span>
                        <span>${hasConflict ? '<i class="bi bi-exclamation-triangle-fill me-1"></i> Conflict Detected' : ''}</span>
                    </div>
                    <div class="timeline-body pb-3" style="height: ${bodyHeight}px;">
            `;
            
            dayEvents.forEach(ev => {
                const topPos = (ev.trackIndex * 54) + 5;
                const leaveEvent = isLeaveEvent(ev);
                const eventTitle = getEventTitle(ev);
                const roleText = String(ev.role || '').toLowerCase();
                const cssClass = leaveEvent ? 'event-leave' : ((roleText === 'teacher' || roleText === 'staff') ? 'role-teacher' : 'role-student');
                const statusLabel = formatStatusLabel(ev.status);
                const statusStyle = getStatusTagStyle(ev.status);
                const detailsUrl = String(ev.detailsUrl || '').trim();
                const encodedDetailsUrl = encodeURIComponent(detailsUrl);
                const caseBadge = buildSessionCaseBadgeHtml(ev?.caseSummary);
                const clickHandler = detailsUrl
                    ? `onclick="window.open(decodeURIComponent('${encodedDetailsUrl}'), '_blank')"`
                    : '';
                const openHint = detailsUrl ? 'Open item details' : 'No linked details';
                
                html += `
                        <div class="event-block ${cssClass} ${ev.hasOverlap ? 'border-danger border-2' : ''}" 
                             style="left: ${ev.pos.left}%; width: ${ev.pos.width}%; top: ${topPos}px;"
                             title="${escapeHtml(openHint)}: ${escapeHtml(eventTitle)} | ${escapeHtml(ev.start)} - ${escapeHtml(ev.end)} | ${escapeHtml(statusLabel)}${String(ev?.classLifecycle?.registrationMode || '').trim().toLowerCase() === 'rolling' ? ' | Rolling' : ''}"
                             ${clickHandler}>
                             <div class="fw-bold text-truncate">${escapeHtml(eventTitle)}</div>
                             ${caseBadge ? `<div>${caseBadge}</div>` : ''}
                             <div class="event-meta x-small">
                                    <span class="text-truncate">${escapeHtml(ev.start)} - ${escapeHtml(ev.end)}</span>
                            <span class="session-status-tag" style="${statusStyle}">${escapeHtml(statusLabel)}</span>
                         </div>
                    </div>
                `;
            });

            html += `<div class="hour-markers">`;
            for (let h = TIMELINE_START_HOUR; h < TIMELINE_END_HOUR; h++) {
                let displayHour = h > 12 ? (h - 12) + 'p' : (h === 12 ? '12p' : h + 'a');
                html += `<div class="hour-marker"><span class="hour-label">${displayHour}</span></div>`;
            }
            html += `</div></div></div>`; 

            container.innerHTML += html;
        });
    }

    function renderCalendarView(eventsByDate, startStr, endStr, container) {
        let current = new Date(startStr + 'T00:00:00');
        current.setDate(1); 
        
        const end = new Date(endStr + 'T00:00:00');
        end.setMonth(end.getMonth() + 1);
        end.setDate(0); 

        let html = '<div class="row g-4">';
        while (current <= end) {
            const year = current.getFullYear();
            const month = current.getMonth();
            const monthName = current.toLocaleString('default', { month: 'long', year: 'numeric' });
            const firstDayIndex = new Date(year, month, 1).getDay(); 
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            html += `
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 shadow-sm border-0">
                        <div class="card-header bg-dark text-white text-center fw-bold py-2">${monthName}</div>
                        <div class="card-body p-2 bg-light">
                            <div class="cal-grid">
            `;
            ['S','M','T','W','T','F','S'].forEach(d => html += `<div class="text-center x-small fw-bold text-muted mb-1">${d}</div>`);
            for(let i=0; i<firstDayIndex; i++) html += `<div class="cal-day empty"></div>`;
            
            for(let d=1; d<=daysInMonth; d++) {
                const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
                const dayEvents = eventsByDate[dateStr] || [];
                const hasConflict = dayEvents.some(e => e.hasOverlap);
                const hasLeave = dayEvents.some(e => isLeaveEvent(e));
                const count = dayEvents.length;
                let classes = 'cal-day ';
                let badges = '';
                
                if (hasConflict) {
                    classes += 'conflict';
                    badges = `<div class="cal-badge bg-danger">${count}</div>`;
                } else if (hasLeave) {
                    classes += 'leave';
                    badges = `<div class="cal-badge bg-warning text-dark">${count}</div>`;
                } else if (count > 0) {
                    classes += 'active';
                    badges = `<div class="cal-badge bg-primary">${count}</div>`;
                } else {
                    classes += 'empty';
                }

                html += `<div class="${classes}" data-date="${dateStr}" title="${count} classes scheduled">
                            <span class="d-block">${d}</span>
                            ${badges}
                         </div>`;
            }

            html += `</div></div></div></div>`;
            current.setMonth(current.getMonth() + 1);
        }
        
        html += '</div>';
        container.innerHTML = html;
    }

    document.getElementById('visualDisplayArea').addEventListener('click', (e) => {
        if (e.target.closest('.event-block')) return; 

        const dayEl = e.target.closest('.cal-day.active, .cal-day.conflict, .cal-day.leave');
        if (dayEl) {
            const dateStr = dayEl.getAttribute('data-date');
            if (dateStr) {
                document.getElementById('sch_startDate').value = dateStr;
                document.getElementById('sch_endDate').value = dateStr;
                document.getElementById('btn_loadSchedule').click();
            }
        }
    });

    // --- 3. Deep Link Auto-Loader (Moved to BOTTOM) ---
    // Pure Javascript URL parsing avoids EJS syntax breaks!
    const urlParams = new URLSearchParams(window.location.search);
    const prefillId = canSelectAnyPerson ? urlParams.get('personId') : document.getElementById('sch_personId').value;
    const prefillName = canSelectAnyPerson ? urlParams.get('personName') : document.getElementById('sch_personName').value;
    const prefillDate = urlParams.get('date');
    const prefillStartDate = urlParams.get('startDate');
    const prefillEndDate = urlParams.get('endDate');
    const prefillRole = urlParams.get('role');

    if (prefillId) {
        document.getElementById('sch_personId').value = prefillId;
        document.getElementById('sch_personName').value = prefillName || ('ID: ' + prefillId);
        
        const titleEl = document.getElementById('scheduleTitle');
        if (titleEl) titleEl.innerText = `Schedule: ${prefillName || prefillId}`;

        if (prefillRole && document.getElementById('sch_role')) {
            document.getElementById('sch_role').value = prefillRole;
        }

        if (prefillStartDate && prefillEndDate) {
            document.getElementById('sch_startDate').value = prefillStartDate;
            document.getElementById('sch_endDate').value = prefillEndDate;
        } else if (prefillDate) {
            const targetDate = new Date(prefillDate + 'T00:00:00');
            const day = targetDate.getDay() || 7; 
            const start = new Date(targetDate);
            start.setHours(-24 * (day - 1)); 
            const end = new Date(start);
            end.setDate(start.getDate() + 6); 
            
            setDateRange(start, end);
        } else {
            applyDefaultWeekRange();
        }
        
        // Everything is defined, click immediately!
        document.getElementById('btn_loadSchedule').click();
    } else {
        applyDefaultWeekRange();
        if (!canSelectAnyPerson && document.getElementById('sch_personId').value) {
            document.getElementById('btn_loadSchedule').click();
        }
    }

});
</script>
