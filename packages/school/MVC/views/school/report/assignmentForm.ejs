<%
  const isEdit = !!assignment;
  const rawTargetRows = Array.isArray(selectedTargetRows) && selectedTargetRows.length
    ? selectedTargetRows
    : (Array.isArray(assignment?.targetRows) ? assignment.targetRows : []);
  const firstTeacherId = Array.isArray(assignment?.teacherIds) && assignment.teacherIds.length ? assignment.teacherIds[0] : '';
  const initialTargetRows = rawTargetRows.length ? rawTargetRows : [];
  const sessionDatesForBounds = (Array.isArray(sessions) ? sessions : [])
    .map((row) => String(row?.date || '').trim())
    .filter((date) => /^\d{4}-\d{2}-\d{2}$/.test(date))
    .sort();
  const classFirstSessionDate = sessionDatesForBounds[0] || '';
  const classLastSessionDate = sessionDatesForBounds[sessionDatesForBounds.length - 1] || '';
  const classLabel = selectedClassTitle || selectedClassId || '';
  const templateLabel = selectedTemplateTitle || selectedTemplateId || '';
%>
<div class="sections-page">
  <div class="row g-2 align-items-start mb-4">
    <div class="col">
      <h1 class="page-heading size-md m-0 text-start" style="padding-left:0;"><i class="bi bi-journal-plus me-2"></i><%= title %></h1>
      <div class="text-muted small mt-1">Define shared report context once, then add target rows for session-linked or no-session reports.</div>
    </div>
    <div class="col-auto d-flex flex-column align-items-end gap-1">
      <% if (isEdit && assignment?.id) { %>
        <span class="badge bg-primary border font-monospace">ID: <%= assignment.id %></span>
      <% } %>
      <a href="/school/reports/assignments" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Assignments</a>
    </div>
  </div>

  <form method="POST" id="assignmentForm" action="<%= isEdit ? ('/school/reports/assignments/edit/' + assignment.id) : '/school/reports/assignments/new' %>">
    <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
    <input type="hidden" name="sessionIdsJson" id="sessionIdsJson" value="[]">
    <input type="hidden" name="dateTargetsJson" id="dateTargetsJson" value="[]">
    <input type="hidden" name="targetRowsJson" id="targetRowsJson" value='<%- JSON.stringify(initialTargetRows) %>'>
    <input type="hidden" name="targetStudentIdsJson" id="targetStudentIdsJson" value='<%- JSON.stringify(Array.isArray(selectedTargetStudentIds) ? selectedTargetStudentIds : []) %>'>
    <input type="hidden" name="reportStartDate" id="legacyReportStartDateInput" value="">
    <input type="hidden" name="reportDueDate" id="legacyReportDueDateInput" value="">
    <input type="hidden" name="taskStartTime" id="legacyTaskStartTimeInput" value="">
    <input type="hidden" name="taskEndTime" id="legacyTaskEndTimeInput" value="">
    <input type="hidden" name="conflictPermitted" id="legacyConflictPermittedInput" value="false">
    <input type="hidden" name="timesheetReflection" id="legacyTimesheetReflectionInput" value="false">
    <input type="hidden" name="allocatedHours" id="legacyAllocatedHoursInput" value="0">
    <input type="hidden" name="status" id="legacyStatusInput" value="active">

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-3">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label fw-bold">Class</label>
            <div class="input-group">
              <input type="hidden" name="classId" id="classIdInput" value="<%= selectedClassId || '' %>">
              <input type="text" class="form-control bg-white" id="classTitleInput" value="<%= classLabel %>" placeholder="Pick class..." readonly>
              <button type="button" class="btn btn-outline-primary" id="btnPickClass"><i class="bi bi-search"></i></button>
            </div>
            <div class="form-text">Selecting class reloads available sessions and students.</div>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Template</label>
            <div class="input-group">
              <input type="hidden" name="templateId" id="templateIdInput" value="<%= selectedTemplateId || '' %>">
              <input type="text" class="form-control bg-white" id="templateTitleInput" value="<%= templateLabel %>" placeholder="Pick template..." readonly>
              <button type="button" class="btn btn-outline-primary" id="btnPickTemplate"><i class="bi bi-search"></i></button>
            </div>
            <div class="form-text">Template is selected from report templates picker.</div>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Report Scope</label>
            <select class="form-select" id="reportScopeInput" name="reportScope">
              <% (assignmentReportScopes || ['class', 'each_student', 'selected_students']).forEach((scope) => { %>
                <% const selectedScope = String(selectedReportScope || assignment?.reportScope || 'class'); %>
                <option value="<%= scope %>" <%= selectedScope === scope ? 'selected' : '' %>>
                  <%= scope === 'class' ? 'Whole Class' : (scope === 'each_student' ? 'Each Student' : 'Specific Students') %>
                </option>
              <% }); %>
            </select>
            <div class="form-text">Choose whether reports are filled for class or student targets.</div>
          </div>

          <div class="col-md-8" id="specificStudentsSection">
            <label class="form-label fw-bold">Specific Students</label>
            <div class="input-group">
              <input type="text" class="form-control bg-white" id="targetStudentSummaryInput" placeholder="No students selected" readonly>
              <button type="button" class="btn btn-outline-primary" id="btnOpenStudentPicker"><i class="bi bi-people"></i></button>
            </div>
            <div id="selectedStudentsContainer" class="d-flex flex-wrap gap-1 mt-2"></div>
            <div id="scopeStudentHint" class="small text-muted mt-1">For "each student" scope, all active class students are used automatically.</div>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Assignment Notes</label>
            <input type="text" class="form-control" name="notes" maxlength="1500" value="<%= assignment?.notes || '' %>" placeholder="Optional assignment notes">
          </div>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div>
          <h5 class="m-0 fw-bold">Report Target Rows</h5>
          <div class="small text-muted">Each row creates report instances for one target and one teacher.</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
          <button type="button" class="btn btn-outline-primary btn-sm" id="btnAddMultipleTargetRows" <%= (selectedClassId && Array.isArray(sessions) && sessions.length) ? '' : 'disabled' %>><i class="bi bi-table me-1"></i>Add Multiple Rows</button>
          <button type="button" class="btn btn-outline-primary btn-sm" id="btnAddTargetRow"><i class="bi bi-plus-lg me-1"></i>Add Row</button>
        </div>
      </div>
      <div class="card-body p-3">
        <% if (classFirstSessionDate && classLastSessionDate) { %>
          <div class="alert alert-light border py-2 px-3 small mb-3">
            Report row dates must stay between <strong><%= classFirstSessionDate %></strong> and <strong><%= classLastSessionDate %></strong>.
          </div>
        <% } %>
        <div class="table-responsive table-scroll-wrapper" data-floating-row-actions="true">
          <table class="table table-sm align-middle mb-0" id="targetRowsTable">
            <thead>
              <tr>
                <th>Target</th>
                <th>Report Period</th>
                <th>Teacher</th>
                <th>Task Time</th>
                <th>Timesheet</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody id="targetRowsBody"></tbody>
          </table>
        </div>
        <div id="targetRowsEmpty" class="text-muted small py-3 d-none">No target rows yet. Click Add Row to define the first report target.</div>
      </div>
    </div>

    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Save Assignment</button>
      <a href="/school/reports/assignments" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </form>
</div>

<div class="modal fade" id="targetRowModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="targetRowModalTitle">Report Target Row</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="rowModalIndex" value="">
        <input type="hidden" id="rowModalRowId" value="">
        <input type="hidden" id="rowModalSessionId" value="">
        <input type="hidden" id="rowModalSessionDate" value="">
        <input type="hidden" id="rowModalTeacherId" value="">

        <div class="row g-3">
          <div class="col-md-3">
            <label class="form-label fw-bold">Target Mode</label>
            <select class="form-select" id="rowModalTargetType">
              <option value="session">Session</option>
              <option value="date">No session</option>
            </select>
          </div>

          <div class="col-md-9" id="rowModalSessionSection">
            <label class="form-label fw-bold">Session</label>
            <div class="input-group">
              <input type="text" class="form-control bg-white" id="rowModalSessionSummary" placeholder="No session selected" readonly>
              <button type="button" class="btn btn-outline-primary" id="btnPickRowSession"><i class="bi bi-calendar3 me-1"></i>Pick</button>
            </div>
          </div>

          <div class="col-md-4 d-none" id="rowModalDateSection">
            <label class="form-label fw-bold">Target Date</label>
            <input type="date" class="form-control" id="rowModalDueDate" min="<%= classFirstSessionDate %>" max="<%= classLastSessionDate %>">
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Report Start Date</label>
            <input type="date" class="form-control" id="rowModalReportStartDate" min="<%= classFirstSessionDate %>" max="<%= classLastSessionDate %>">
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Report Due Date</label>
            <input type="date" class="form-control" id="rowModalReportDueDate" min="<%= classFirstSessionDate %>" max="<%= classLastSessionDate %>">
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Teacher</label>
            <div class="input-group">
              <input type="text" class="form-control bg-white" id="rowModalTeacherSummary" placeholder="No teacher selected" readonly>
              <button type="button" class="btn btn-outline-primary" id="btnPickRowTeacher"><i class="bi bi-person-lines-fill me-1"></i>Pick</button>
            </div>
            <div class="form-text text-warning d-none" id="rowModalTeacherWarning">This teacher has no delivered session in the selected class. You can still save this row.</div>
          </div>

          <div class="col-md-2">
            <label class="form-label fw-bold">Task Start</label>
            <input type="time" class="form-control" id="rowModalTaskStartTime">
          </div>

          <div class="col-md-2">
            <label class="form-label fw-bold">Task End</label>
            <input type="time" class="form-control" id="rowModalTaskEndTime">
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Status</label>
            <select class="form-select" id="rowModalStatus">
              <% (assignmentStatuses || ['active', 'inactive', 'archived']).forEach((st) => { %>
                <option value="<%= st %>"><%= st %></option>
              <% }); %>
            </select>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold d-block">Conflict</label>
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="rowModalConflictPermitted">
              <label class="form-check-label" for="rowModalConflictPermitted">Intentional overlap permitted</label>
            </div>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold d-block">Timesheet</label>
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="rowModalTimesheetReflection">
              <label class="form-check-label" for="rowModalTimesheetReflection">Reflect on timesheet</label>
            </div>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Allocated Hours</label>
            <input type="number" class="form-control" id="rowModalAllocatedHours" min="0.25" max="24" step="0.25" placeholder="e.g. 1.5">
          </div>

          <div class="col-12">
            <label class="form-label fw-bold">Row Notes</label>
            <textarea class="form-control" id="rowModalNotes" rows="2" maxlength="1500"></textarea>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="btnSaveTargetRow">Save Row</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="bulkTargetRowsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Add Multiple Report Target Rows</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <% if (!selectedClassId || !Array.isArray(sessions) || !sessions.length) { %>
          <div class="alert alert-warning mb-0">Select a class with scheduled sessions before using bulk row generation.</div>
        <% } else { %>
          <div class="row g-3">
            <div class="col-12">
              <h6 class="fw-bold mb-2">Schedule</h6>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Preset</label>
              <select class="form-select" id="bulkPreset">
                <option value="end_of_month">End of Each Month</option>
                <option value="end_of_week">End of Each Week</option>
                <option value="end_of_each_day">End of Each Day (per session)</option>
                <option value="semi_monthly">Semi-Monthly (15th + month end)</option>
                <option value="custom">Custom Intervals</option>
              </select>
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">Start Date</label>
              <input type="date" class="form-control" id="bulkStartDate" min="<%= classFirstSessionDate %>" max="<%= classLastSessionDate %>" value="<%= classFirstSessionDate %>">
            </div>
            <div class="col-md-4">
              <label class="form-label fw-bold">End Date</label>
              <input type="date" class="form-control" id="bulkEndDate" min="<%= classFirstSessionDate %>" max="<%= classLastSessionDate %>" value="<%= classLastSessionDate %>">
            </div>
            <div class="col-md-4 d-none" id="bulkCustomStepSection">
              <label class="form-label fw-bold">Every N Days</label>
              <input type="number" class="form-control" id="bulkCustomStepDays" min="1" max="365" step="1" value="7">
            </div>
            <div class="col-md-8">
              <div class="form-text mt-2" id="bulkCountEstimate">~0 rows will be generated.</div>
              <div class="form-text text-warning d-none" id="bulkLargeBatchWarning">Large batch (50+ rows). Review the preview carefully before adding.</div>
            </div>

            <div class="col-12 mt-2">
              <h6 class="fw-bold mb-2">Defaults (applied to every row)</h6>
            </div>
            <input type="hidden" id="bulkTeacherId" value="<%= firstTeacherId || '' %>">
            <div class="col-md-4">
              <label class="form-label fw-bold">Teacher</label>
              <div class="input-group">
                <input type="text" class="form-control bg-white" id="bulkTeacherSummary" placeholder="Default teacher" readonly>
                <button type="button" class="btn btn-outline-primary" id="btnPickBulkTeacher"><i class="bi bi-person-lines-fill me-1"></i>Pick</button>
              </div>
            </div>
            <div class="col-md-2">
              <label class="form-label fw-bold">Task Start</label>
              <input type="time" class="form-control" id="bulkTaskStartTime" value="09:00">
              <div class="form-text">Used for every generated row (overrides session times).</div>
            </div>
            <div class="col-md-2">
              <label class="form-label fw-bold">Task End</label>
              <input type="time" class="form-control" id="bulkTaskEndTime" value="10:00">
            </div>
            <div class="col-md-2">
              <label class="form-label fw-bold">Status</label>
              <select class="form-select" id="bulkStatus">
                <% (assignmentStatuses || ['active', 'inactive', 'archived']).forEach((st) => { %>
                  <option value="<%= st %>" <%= st === 'active' ? 'selected' : '' %>><%= st %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-2">
              <label class="form-label fw-bold">Allocated Hours</label>
              <input type="number" class="form-control" id="bulkAllocatedHours" min="0.25" max="24" step="0.25" placeholder="e.g. 1.5">
            </div>
            <div class="col-md-3">
              <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="bulkLinkSessions" checked>
                <label class="form-check-label" for="bulkLinkSessions">Link sessions</label>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="bulkTimesheetReflection">
                <label class="form-check-label" for="bulkTimesheetReflection">Reflect on timesheet</label>
              </div>
            </div>
            <div class="col-md-3">
              <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="bulkConflictPermitted">
                <label class="form-check-label" for="bulkConflictPermitted">Intentional overlap permitted</label>
              </div>
            </div>

            <div class="col-12 d-flex flex-wrap gap-2">
              <button type="button" class="btn btn-outline-secondary btn-sm" id="btnBulkPreviewRows"><i class="bi bi-eye me-1"></i>Preview Rows</button>
            </div>

            <div class="col-12 d-none" id="bulkPreviewSection">
              <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-2">
                <h6 class="fw-bold m-0">Preview</h6>
                <div class="small text-muted" id="bulkPreviewSelectionHint">Select rows to add. Invalid rows cannot be selected.</div>
              </div>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0" id="bulkPreviewTable">
                  <thead>
                    <tr>
                      <th style="width:2.5rem;">
                        <input class="form-check-input mt-0" type="checkbox" id="bulkPreviewSelectAll" title="Select all valid rows" aria-label="Select all valid rows">
                      </th>
                      <th>Target</th>
                      <th>Report Period</th>
                      <th>Teacher</th>
                      <th>Task Time</th>
                      <th>Timesheet</th>
                      <th>Link Note</th>
                      <th>Status</th>
                    </tr>
                  </thead>
                  <tbody id="bulkPreviewBody"></tbody>
                </table>
              </div>
              <div class="small text-muted mt-2" id="bulkPreviewSummary"></div>
            </div>
          </div>
        <% } %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="btnBulkAddRows" disabled>Add Selected Rows to Assignment</button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/modal_GenericPicker') %>

<script>
  (function () {
    const classIdInput = document.getElementById('classIdInput');
    const classTitleInput = document.getElementById('classTitleInput');
    const templateIdInput = document.getElementById('templateIdInput');
    const templateTitleInput = document.getElementById('templateTitleInput');
    const targetRowsInput = document.getElementById('targetRowsJson');
    const sessionIdsInput = document.getElementById('sessionIdsJson');
    const dateTargetsInput = document.getElementById('dateTargetsJson');
    const targetStudentIdsInput = document.getElementById('targetStudentIdsJson');
    const reportScopeInput = document.getElementById('reportScopeInput');
    const targetStudentSummaryInput = document.getElementById('targetStudentSummaryInput');
    const selectedStudentsContainer = document.getElementById('selectedStudentsContainer');
    const specificStudentsSection = document.getElementById('specificStudentsSection');
    const scopeStudentHint = document.getElementById('scopeStudentHint');
    const targetRowsBody = document.getElementById('targetRowsBody');
    const targetRowsEmpty = document.getElementById('targetRowsEmpty');
    const formEl = document.getElementById('assignmentForm');

    const modalEl = document.getElementById('targetRowModal');
    const modalFields = {
      index: document.getElementById('rowModalIndex'),
      rowId: document.getElementById('rowModalRowId'),
      targetType: document.getElementById('rowModalTargetType'),
      sessionId: document.getElementById('rowModalSessionId'),
      sessionDate: document.getElementById('rowModalSessionDate'),
      sessionSummary: document.getElementById('rowModalSessionSummary'),
      dueDate: document.getElementById('rowModalDueDate'),
      reportStartDate: document.getElementById('rowModalReportStartDate'),
      reportDueDate: document.getElementById('rowModalReportDueDate'),
      teacherId: document.getElementById('rowModalTeacherId'),
      teacherSummary: document.getElementById('rowModalTeacherSummary'),
      teacherWarning: document.getElementById('rowModalTeacherWarning'),
      taskStartTime: document.getElementById('rowModalTaskStartTime'),
      taskEndTime: document.getElementById('rowModalTaskEndTime'),
      conflictPermitted: document.getElementById('rowModalConflictPermitted'),
      timesheetReflection: document.getElementById('rowModalTimesheetReflection'),
      allocatedHours: document.getElementById('rowModalAllocatedHours'),
      status: document.getElementById('rowModalStatus'),
      notes: document.getElementById('rowModalNotes')
    };

    const allSessions = <%- JSON.stringify(sessions || []) %>;
    const allStudents = <%- JSON.stringify(studentOptions || []) %>;
    const teacherOptions = <%- JSON.stringify(teacherOptions || []) %>;
    const classFirstSessionDate = <%- JSON.stringify(classFirstSessionDate) %>;
    const classLastSessionDate = <%- JSON.stringify(classLastSessionDate) %>;
    const firstTeacherId = <%- JSON.stringify(firstTeacherId) %>;
    const isEditAssignment = <%= isEdit ? 'true' : 'false' %>;
    const assignmentId = <%- JSON.stringify(assignment?.id || '') %>;
    let selectedTargetStudentIds = Array.isArray(<%- JSON.stringify(Array.isArray(selectedTargetStudentIds) ? selectedTargetStudentIds : []) %>) ? <%- JSON.stringify(Array.isArray(selectedTargetStudentIds) ? selectedTargetStudentIds : []) %> : [];
    let targetRows = Array.isArray(<%- JSON.stringify(initialTargetRows) %>) ? <%- JSON.stringify(initialTargetRows) %> : [];

    function showReportModal({ title = 'Notice', message = '', icon = 'warning', buttonClass = 'btn-primary' } = {}) {
      if (typeof hideLoading === 'function') hideLoading();
      if (typeof showMessageModal === 'function') {
        return showMessageModal({
          title,
          icon,
          message,
          buttons: [{ text: 'OK', class: buttonClass }]
        });
      }
      alert(String(message || title || 'Notice'));
      return Promise.resolve('OK');
    }

    function getTargetRowModalInstance() {
      if (!modalEl || !window.bootstrap?.Modal) return null;
      if (typeof window.bootstrap.Modal.getOrCreateInstance === 'function') {
        return window.bootstrap.Modal.getOrCreateInstance(modalEl);
      }
      return new window.bootstrap.Modal(modalEl);
    }

    function showTargetRowModal() {
      const modalInstance = getTargetRowModalInstance();
      if (modalInstance) {
        modalInstance.show();
        return;
      }
      if (!modalEl) return;
      modalEl.classList.add('show');
      modalEl.style.display = 'block';
      modalEl.removeAttribute('aria-hidden');
      modalEl.setAttribute('aria-modal', 'true');
      document.body.classList.add('modal-open');
    }

    function hideTargetRowModal() {
      const modalInstance = getTargetRowModalInstance();
      if (modalInstance) {
        modalInstance.hide();
        return;
      }
      if (!modalEl) return;
      modalEl.classList.remove('show');
      modalEl.style.display = 'none';
      modalEl.setAttribute('aria-hidden', 'true');
      modalEl.removeAttribute('aria-modal');
      document.body.classList.remove('modal-open');
    }

    function setSubmitLock(isLocked, activeButton, loadingLabel) {
      const submitButtons = Array.from(formEl?.querySelectorAll('button[type="submit"]') || []);
      submitButtons.forEach((button) => {
        if (!button) return;
        if (!button.dataset.originalHtml) button.dataset.originalHtml = button.innerHTML;
        button.disabled = isLocked;
      });
      if (activeButton) {
        if (!activeButton.dataset.originalHtml) activeButton.dataset.originalHtml = activeButton.innerHTML;
        activeButton.innerHTML = isLocked
          ? '<span class="spinner-border spinner-border-sm me-1"></span>' + String(loadingLabel || 'Saving...')
          : activeButton.dataset.originalHtml;
      }
      if (typeof showLoading === 'function') {
        if (isLocked) showLoading();
        else if (typeof hideLoading === 'function') hideLoading();
      }
    }

    function uniq(arr) {
      return [...new Set((Array.isArray(arr) ? arr : []).map((v) => String(v || '').trim()).filter(Boolean))];
    }

    function toDateOnly(value) {
      return /^\d{4}-\d{2}-\d{2}$/.test(String(value || '').trim()) ? String(value).trim() : '';
    }

    function escapeHtml(value) {
      return String(value || '').replace(/[&<>"']/g, (ch) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
      }[ch]));
    }

    function getSessionById(id) {
      return (allSessions || []).find((s) => String(s.sessionId || s.id || '') === String(id || '')) || null;
    }

    function getSessionDisplay(session) {
      if (!session) return '';
      const date = String(session.date || '');
      const start = String(session.startTime || '--:--');
      const end = String(session.endTime || '--:--');
      const sid = String(session.sessionId || session.id || '');
      return `${date} | ${start}-${end} (${sid})`;
    }

    function getTeacherName(id, fallback = '') {
      const teacher = (teacherOptions || []).find((row) => String(row?.id || '') === String(id || ''));
      return String(teacher?.name || fallback || id || '').trim();
    }

    function teacherHasDeliveredSession(teacherId) {
      const id = String(teacherId || '').trim();
      if (!id) return false;
      return (allSessions || []).some((session) => String(session?.delivery?.deliveredBy || '').trim() === id);
    }

    function getFirstClassTeacherId() {
      return String((teacherOptions || [])[0]?.id || firstTeacherId || '').trim();
    }

    function getSessionTeacherId(session) {
      return String(session?.delivery?.deliveredBy || '').trim() || getFirstClassTeacherId();
    }

    function generateTargetRowId() {
      return `row_${Date.now().toString(36)}_${Math.random().toString(36).slice(2, 8)}`;
    }

    function normalizeTargetRow(row = {}) {
      const targetType = String(row.targetType || (row.sessionId ? 'session' : 'date')).trim().toLowerCase() === 'date' ? 'date' : 'session';
      const session = targetType === 'session' ? getSessionById(row.sessionId) : null;
      const sessionDate = targetType === 'session' ? toDateOnly(row.sessionDate || session?.date || '') : '';
      const dueDate = targetType === 'date' ? toDateOnly(row.dueDate || row.sessionDate || '') : '';
      const teacherId = String(row.teacherId || (session ? getSessionTeacherId(session) : getFirstClassTeacherId()) || '').trim();
      return {
        rowId: String(row.rowId || '') || generateTargetRowId(),
        targetType,
        sessionId: targetType === 'session' ? String(row.sessionId || session?.sessionId || session?.id || '').trim() : '',
        sessionDate,
        dueDate,
        reportStartDate: toDateOnly(row.reportStartDate || sessionDate || dueDate),
        reportDueDate: toDateOnly(row.reportDueDate || sessionDate || dueDate),
        taskStartTime: String(row.taskStartTime || session?.startTime || '').trim(),
        taskEndTime: String(row.taskEndTime || session?.endTime || '').trim(),
        conflictPermitted: row.conflictPermitted !== undefined ? Boolean(row.conflictPermitted) : targetType === 'session',
        timesheetReflection: row.timesheetReflection === true,
        allocatedHours: row.allocatedHours !== undefined && row.allocatedHours !== null ? row.allocatedHours : '',
        teacherId,
        teacherName: String(row.teacherName || getTeacherName(teacherId)).trim(),
        status: String(row.status || 'active').trim().toLowerCase(),
        notes: String(row.notes || '').trim()
      };
    }

    function updateHiddenFields() {
      targetRows = targetRows.map(normalizeTargetRow);
      const activeRow = targetRows.find((row) => String(row.status || '').toLowerCase() === 'active') || targetRows[0] || {};
      const selectedSessionIds = uniq(targetRows.map((row) => row.sessionId));
      const selectedDateTargets = uniq(targetRows.map((row) => row.dueDate || row.sessionDate).filter(Boolean));
      sessionIdsInput.value = JSON.stringify(selectedSessionIds);
      dateTargetsInput.value = JSON.stringify(selectedDateTargets);
      targetStudentIdsInput.value = JSON.stringify(uniq(selectedTargetStudentIds));
      targetRowsInput.value = JSON.stringify(targetRows);
      document.getElementById('legacyReportStartDateInput').value = activeRow.reportStartDate || '';
      document.getElementById('legacyReportDueDateInput').value = activeRow.reportDueDate || '';
      document.getElementById('legacyTaskStartTimeInput').value = activeRow.taskStartTime || '';
      document.getElementById('legacyTaskEndTimeInput').value = activeRow.taskEndTime || '';
      document.getElementById('legacyConflictPermittedInput').value = activeRow.conflictPermitted ? 'true' : 'false';
      document.getElementById('legacyTimesheetReflectionInput').value = activeRow.timesheetReflection ? 'true' : 'false';
      document.getElementById('legacyAllocatedHoursInput').value = activeRow.allocatedHours || 0;
      document.getElementById('legacyStatusInput').value = activeRow.status || 'active';
    }

    function renderTargetRows() {
      targetRows = targetRows.map(normalizeTargetRow);
      updateHiddenFields();
      targetRowsEmpty?.classList.toggle('d-none', targetRows.length > 0);
      if (!targetRowsBody) return;
      if (!targetRows.length) {
        targetRowsBody.innerHTML = '';
        return;
      }
      targetRowsBody.innerHTML = targetRows.map((row, index) => {
        const targetLabel = row.targetType === 'date'
          ? `No session | ${row.dueDate || '-'}`
          : `Session | ${getSessionDisplay(getSessionById(row.sessionId)) || row.sessionId || '-'}`;
        const periodLabel = `${row.reportStartDate || '-'} to ${row.reportDueDate || '-'}`;
        const taskLabel = row.taskStartTime && row.taskEndTime ? `${row.taskStartTime} - ${row.taskEndTime}` : '-';
        const timesheetLabel = row.timesheetReflection ? `${row.allocatedHours || '-'} hr` : 'No';
        return `
          <tr data-target-row-index="${index}">
            <td>${escapeHtml(targetLabel)}</td>
            <td>${escapeHtml(periodLabel)}</td>
            <td>${escapeHtml(row.teacherName || row.teacherId || '-')}</td>
            <td>${escapeHtml(taskLabel)}</td>
            <td>${escapeHtml(timesheetLabel)}</td>
            <td><span class="badge ${row.status === 'active' ? 'bg-success' : 'bg-secondary'}">${escapeHtml(row.status || '-')}</span></td>
            <td class="table-actions pe-4">
              <div class="row-actions-wrap">
                <button
                  type="button"
                  class="btn btn-secondary btn-sm btn-row-actions-toggle"
                  data-row-actions-id="${escapeHtml(`target-row-${row.rowId || index}`)}"
                  title="Target Row Actions">
                  <i class="bi bi-three-dots-vertical"></i>
                </button>
                <div class="row-actions-menu d-none" data-row-actions-id="${escapeHtml(`target-row-${row.rowId || index}`)}" data-target-row-index="${index}">
                  <button type="button" class="btn btn-outline-secondary btn-sm js-edit-target-row" data-target-row-index="${index}"><i class="bi bi-pencil-square me-2"></i>Edit</button>
                  <button type="button" class="btn btn-outline-secondary btn-sm js-duplicate-target-row" data-target-row-index="${index}"><i class="bi bi-files me-2"></i>Duplicate</button>
                  <button type="button" class="btn btn-outline-danger btn-sm js-remove-target-row" data-target-row-index="${index}"><i class="bi bi-trash me-2"></i>Remove</button>
                </div>
              </div>
            </td>
          </tr>`;
      }).join('');
    }

    function setModalTargetMode() {
      const targetType = String(modalFields.targetType.value || 'session');
      document.getElementById('rowModalSessionSection')?.classList.toggle('d-none', targetType !== 'session');
      document.getElementById('rowModalDateSection')?.classList.toggle('d-none', targetType !== 'date');
      updateTeacherWarning();
    }

    function updateTeacherWarning() {
      const teacherId = String(modalFields.teacherId.value || '').trim();
      const show = Boolean(teacherId && !teacherHasDeliveredSession(teacherId));
      modalFields.teacherWarning?.classList.toggle('d-none', !show);
    }

    function populateRowModal(row = {}, index = '') {
      const normalized = normalizeTargetRow(row);
      modalFields.index.value = index;
      modalFields.rowId.value = normalized.rowId;
      modalFields.targetType.value = normalized.targetType;
      modalFields.sessionId.value = normalized.sessionId;
      modalFields.sessionDate.value = normalized.sessionDate;
      modalFields.sessionSummary.value = normalized.sessionId ? (getSessionDisplay(getSessionById(normalized.sessionId)) || normalized.sessionId) : '';
      modalFields.dueDate.value = normalized.dueDate;
      modalFields.reportStartDate.value = normalized.reportStartDate;
      modalFields.reportDueDate.value = normalized.reportDueDate;
      modalFields.teacherId.value = normalized.teacherId;
      modalFields.teacherSummary.value = normalized.teacherId ? (normalized.teacherName || getTeacherName(normalized.teacherId)) : '';
      modalFields.taskStartTime.value = normalized.taskStartTime;
      modalFields.taskEndTime.value = normalized.taskEndTime;
      modalFields.conflictPermitted.checked = normalized.conflictPermitted === true;
      modalFields.timesheetReflection.checked = normalized.timesheetReflection === true;
      modalFields.allocatedHours.value = normalized.allocatedHours || '';
      modalFields.status.value = normalized.status || 'active';
      modalFields.notes.value = normalized.notes || '';
      setModalTargetMode();
      showTargetRowModal();
    }

    function rowFromModal() {
      const targetType = String(modalFields.targetType.value || 'session') === 'date' ? 'date' : 'session';
      const session = targetType === 'session' ? getSessionById(modalFields.sessionId.value) : null;
      return normalizeTargetRow({
        rowId: modalFields.rowId.value,
        targetType,
        sessionId: targetType === 'session' ? modalFields.sessionId.value : '',
        sessionDate: targetType === 'session' ? (modalFields.sessionDate.value || session?.date || '') : '',
        dueDate: targetType === 'date' ? modalFields.dueDate.value : '',
        reportStartDate: modalFields.reportStartDate.value,
        reportDueDate: modalFields.reportDueDate.value,
        teacherId: modalFields.teacherId.value,
        teacherName: modalFields.teacherSummary.value,
        taskStartTime: modalFields.taskStartTime.value,
        taskEndTime: modalFields.taskEndTime.value,
        conflictPermitted: modalFields.conflictPermitted.checked,
        timesheetReflection: modalFields.timesheetReflection.checked,
        allocatedHours: modalFields.allocatedHours.value,
        status: modalFields.status.value,
        notes: modalFields.notes.value
      });
    }

    function getModalTargetRowIndex() {
      const rawIndex = String(modalFields.index.value || '').trim();
      if (!/^\d+$/.test(rawIndex)) return null;
      const index = Number(rawIndex);
      return Number.isInteger(index) ? index : null;
    }

    function validateRow(row, label = 'Target row') {
      if (!row.teacherId) return `${label}: select one teacher.`;
      if (row.targetType === 'session') {
        if (!row.sessionId) return `${label}: select a session.`;
      } else if (!row.dueDate) return `${label}: set a target date.`;
      if (!row.reportStartDate || !row.reportDueDate) return `${label}: set both report start and due date.`;
      if (row.reportStartDate > row.reportDueDate) return `${label}: report start date cannot be after due date.`;
      if (classFirstSessionDate && row.reportStartDate < classFirstSessionDate) return `${label}: start date cannot be before ${classFirstSessionDate}.`;
      if (classLastSessionDate && row.reportDueDate > classLastSessionDate) return `${label}: due date cannot be after ${classLastSessionDate}.`;
      if (!row.taskStartTime || !row.taskEndTime) return `${label}: set both task start and end time.`;
      if (row.taskStartTime >= row.taskEndTime) return `${label}: task end time must be later than task start time.`;
      if (row.timesheetReflection) {
        const allocated = Number(row.allocatedHours);
        if (!Number.isFinite(allocated) || allocated <= 0) return `${label}: enter allocated hours greater than zero.`;
      }
      return '';
    }

    function localSessionItems() {
      return (allSessions || []).map((session) => {
        const sessionId = String(session?.sessionId || session?.id || '').trim();
        const teacherId = String(session?.delivery?.deliveredBy || '').trim();
        return {
          id: sessionId,
          sessionId,
          date: String(session?.date || ''),
          startTime: String(session?.startTime || ''),
          endTime: String(session?.endTime || ''),
          className: String(classTitleInput?.value || ''),
          teacherId,
          teacherName: getTeacherName(teacherId, teacherId),
          title: getSessionDisplay(session)
        };
      }).filter((row) => Boolean(row.id));
    }

    const bulkModalEl = document.getElementById('bulkTargetRowsModal');
    const bulkFields = {
      preset: document.getElementById('bulkPreset'),
      startDate: document.getElementById('bulkStartDate'),
      endDate: document.getElementById('bulkEndDate'),
      customStepSection: document.getElementById('bulkCustomStepSection'),
      customStepDays: document.getElementById('bulkCustomStepDays'),
      countEstimate: document.getElementById('bulkCountEstimate'),
      largeBatchWarning: document.getElementById('bulkLargeBatchWarning'),
      teacherId: document.getElementById('bulkTeacherId'),
      teacherSummary: document.getElementById('bulkTeacherSummary'),
      taskStartTime: document.getElementById('bulkTaskStartTime'),
      taskEndTime: document.getElementById('bulkTaskEndTime'),
      status: document.getElementById('bulkStatus'),
      allocatedHours: document.getElementById('bulkAllocatedHours'),
      linkSessions: document.getElementById('bulkLinkSessions'),
      timesheetReflection: document.getElementById('bulkTimesheetReflection'),
      conflictPermitted: document.getElementById('bulkConflictPermitted'),
      previewSection: document.getElementById('bulkPreviewSection'),
      previewBody: document.getElementById('bulkPreviewBody'),
      previewSummary: document.getElementById('bulkPreviewSummary'),
      previewSelectAll: document.getElementById('bulkPreviewSelectAll'),
      previewSelectionHint: document.getElementById('bulkPreviewSelectionHint'),
      addRowsButton: document.getElementById('btnBulkAddRows'),
      previewButton: document.getElementById('btnBulkPreviewRows')
    };
    let bulkPreviewState = { accepted: [], skipped: [], previewResults: [], previewRows: [] };
    let bulkEstimateTimer = null;

    function getBulkApiUrl(suffix) {
      const cleanSuffix = String(suffix || '').replace(/^\//, '');
      if (isEditAssignment && assignmentId) {
        return `/school/reports/assignments/edit/${encodeURIComponent(assignmentId)}/${cleanSuffix}`;
      }
      return `/school/reports/assignments/${cleanSuffix}`;
    }

    function getBulkTargetRowModalInstance() {
      if (!bulkModalEl || !window.bootstrap?.Modal) return null;
      if (typeof window.bootstrap.Modal.getOrCreateInstance === 'function') {
        return window.bootstrap.Modal.getOrCreateInstance(bulkModalEl);
      }
      return new window.bootstrap.Modal(bulkModalEl);
    }

    function showBulkTargetRowsModal() {
      const modalInstance = getBulkTargetRowModalInstance();
      if (modalInstance) {
        modalInstance.show();
        return;
      }
      if (!bulkModalEl) return;
      bulkModalEl.classList.add('show');
      bulkModalEl.style.display = 'block';
      bulkModalEl.removeAttribute('aria-hidden');
      bulkModalEl.setAttribute('aria-modal', 'true');
      document.body.classList.add('modal-open');
    }

    function hideBulkTargetRowsModal() {
      const modalInstance = getBulkTargetRowModalInstance();
      if (modalInstance) {
        modalInstance.hide();
        return;
      }
      if (!bulkModalEl) return;
      bulkModalEl.classList.remove('show');
      bulkModalEl.style.display = 'none';
      bulkModalEl.setAttribute('aria-hidden', 'true');
      bulkModalEl.removeAttribute('aria-modal');
      document.body.classList.remove('modal-open');
    }

    function resetBulkPreview() {
      bulkPreviewState = { accepted: [], skipped: [], previewResults: [], previewRows: [] };
      bulkFields.previewSection?.classList.add('d-none');
      if (bulkFields.previewBody) bulkFields.previewBody.innerHTML = '';
      if (bulkFields.previewSummary) bulkFields.previewSummary.textContent = '';
      if (bulkFields.previewSelectAll) {
        bulkFields.previewSelectAll.checked = false;
        bulkFields.previewSelectAll.indeterminate = false;
        bulkFields.previewSelectAll.disabled = true;
      }
      updateBulkAddRowsButton();
    }

    function buildBulkPreviewRows(acceptedRows = [], skippedRows = [], previewResults = []) {
      const previewMap = new Map((Array.isArray(previewResults) ? previewResults : []).map((row) => [row.index, row]));
      const previewRows = [];

      (Array.isArray(acceptedRows) ? acceptedRows : []).forEach((row, index) => {
        const normalized = normalizeTargetRow(row);
        const clientIssue = validateRow(normalized, `Row ${index + 1}`);
        const serverPreview = previewMap.get(index) || { valid: true, errors: [], conflicts: [] };
        const issues = [];
        if (clientIssue) issues.push(clientIssue);
        (serverPreview.errors || []).forEach((msg) => issues.push(msg));
        (serverPreview.conflicts || []).forEach((msg) => issues.push(msg));
        const isValid = !issues.length;
        previewRows.push({
          kind: 'candidate',
          sourceIndex: index,
          row,
          normalized,
          valid: isValid,
          issues,
          selected: isValid
        });
      });

      (Array.isArray(skippedRows) ? skippedRows : []).forEach((entry) => {
        previewRows.push({
          kind: 'skipped',
          row: entry?.row || {},
          reason: String(entry?.reason || 'Skipped'),
          valid: false,
          selected: false
        });
      });

      return previewRows;
    }

    function getBulkSelectablePreviewRows() {
      return (Array.isArray(bulkPreviewState.previewRows) ? bulkPreviewState.previewRows : [])
        .filter((entry) => entry.kind === 'candidate' && entry.valid);
    }

    function getBulkSelectedPreviewRows() {
      return getBulkSelectablePreviewRows().filter((entry) => entry.selected);
    }

    function syncBulkPreviewSelectAllControl() {
      const selectAll = bulkFields.previewSelectAll;
      if (!selectAll) return;
      const selectable = getBulkSelectablePreviewRows();
      const selected = getBulkSelectedPreviewRows();
      selectAll.disabled = selectable.length === 0;
      if (!selectable.length) {
        selectAll.checked = false;
        selectAll.indeterminate = false;
        return;
      }
      selectAll.checked = selected.length === selectable.length;
      selectAll.indeterminate = selected.length > 0 && selected.length < selectable.length;
    }

    function updateBulkAddRowsButton() {
      const selectedCount = getBulkSelectedPreviewRows().length;
      const selectableCount = getBulkSelectablePreviewRows().length;
      const skippedCount = (bulkPreviewState.previewRows || []).filter((entry) => entry.kind === 'skipped').length;
      const invalidCount = (bulkPreviewState.previewRows || []).filter((entry) => entry.kind === 'candidate' && !entry.valid).length;

      if (bulkFields.previewSummary) {
        const parts = [`${selectedCount} of ${selectableCount} valid row${selectableCount === 1 ? '' : 's'} selected to add.`];
        if (skippedCount) parts.push(`${skippedCount} duplicate${skippedCount === 1 ? '' : 's'} skipped.`);
        if (invalidCount) parts.push(`${invalidCount} invalid row${invalidCount === 1 ? '' : 's'} ignored.`);
        bulkFields.previewSummary.textContent = parts.join(' ');
      }

      if (bulkFields.addRowsButton) {
        bulkFields.addRowsButton.disabled = selectedCount === 0;
        bulkFields.addRowsButton.textContent = selectedCount
          ? `Add ${selectedCount} Selected Row${selectedCount === 1 ? '' : 's'} to Assignment`
          : 'Add Selected Rows to Assignment';
      }

      syncBulkPreviewSelectAllControl();
    }

    function renderBulkPreviewTable() {
      const previewRows = Array.isArray(bulkPreviewState.previewRows) ? bulkPreviewState.previewRows : [];
      if (!bulkFields.previewBody) return;

      bulkFields.previewBody.innerHTML = previewRows.map((entry, displayIndex) => {
        const normalized = entry.normalized || normalizeTargetRow(entry.row || {});
        const targetLabel = normalized.targetType === 'date'
          ? `No session | ${normalized.dueDate || '-'}`
          : `Session | ${getSessionDisplay(getSessionById(normalized.sessionId)) || normalized.sessionId || '-'}`;
        const periodLabel = `${normalized.reportStartDate || '-'} to ${normalized.reportDueDate || '-'}`;
        const teacherLabel = normalized.teacherName || normalized.teacherId || '-';
        const taskLabel = normalized.taskStartTime && normalized.taskEndTime
          ? `${normalized.taskStartTime} - ${normalized.taskEndTime}`
          : '-';
        const timesheetLabel = normalized.timesheetReflection ? `${normalized.allocatedHours || '-'} hr` : 'No';
        const linkNote = entry.kind === 'skipped'
          ? String(entry.reason || 'Skipped')
          : String(entry.row?.linkNote || '-');
        const statusLabel = entry.kind === 'skipped'
          ? 'Skipped duplicate'
          : (entry.valid ? (normalized.status || 'active') : (entry.issues || []).join(' '));
        const rowClass = entry.kind === 'skipped'
          ? 'table-warning'
          : (entry.valid ? '' : 'table-danger');
        const canSelect = entry.kind === 'candidate' && entry.valid;
        const checked = canSelect && entry.selected;
        const checkboxTitle = canSelect
          ? 'Include this row when adding to the assignment'
          : (entry.kind === 'skipped' ? 'Duplicate row cannot be added' : 'Invalid row cannot be added');

        return `
          <tr class="${escapeHtml(rowClass)}" data-bulk-preview-index="${displayIndex}">
            <td>
              <input
                class="form-check-input mt-0 js-bulk-preview-row-select"
                type="checkbox"
                data-bulk-preview-index="${displayIndex}"
                ${checked ? 'checked' : ''}
                ${canSelect ? '' : 'disabled'}
                title="${escapeHtml(checkboxTitle)}"
                aria-label="Select row ${displayIndex + 1}"
              >
            </td>
            <td>${escapeHtml(targetLabel)}</td>
            <td>${escapeHtml(periodLabel)}</td>
            <td>${escapeHtml(teacherLabel)}</td>
            <td>${escapeHtml(taskLabel)}</td>
            <td>${escapeHtml(timesheetLabel)}</td>
            <td>${escapeHtml(linkNote)}</td>
            <td>${escapeHtml(statusLabel)}</td>
          </tr>
        `;
      }).join('');

      updateBulkAddRowsButton();
    }

    function setBulkPreviewRowSelected(displayIndex, selected) {
      const entry = bulkPreviewState.previewRows?.[displayIndex];
      if (!entry || entry.kind !== 'candidate' || !entry.valid) return;
      entry.selected = Boolean(selected);
      updateBulkAddRowsButton();
    }

    function setAllBulkPreviewRowsSelected(selected) {
      getBulkSelectablePreviewRows().forEach((entry) => {
        entry.selected = Boolean(selected);
      });
      renderBulkPreviewTable();
    }

    function bulkRowDedupeKey(row = {}) {
      const targetType = String(row?.targetType || '').trim().toLowerCase();
      const teacherId = String(row?.teacherId || '').trim();
      if (targetType === 'session') return `session:${String(row?.sessionId || '').trim()}`;
      return `date:${String(row?.dueDate || row?.sessionDate || '').trim()}:${teacherId}`;
    }

    function dedupeBulkRows(existingRows = [], candidateRows = []) {
      const seen = new Set((Array.isArray(existingRows) ? existingRows : []).map(bulkRowDedupeKey));
      const accepted = [];
      const skipped = [];
      (Array.isArray(candidateRows) ? candidateRows : []).forEach((row) => {
        const key = bulkRowDedupeKey(row);
        if (!key || key === 'date::' || key === 'session:') {
          skipped.push({ row, reason: 'Invalid row identity.' });
          return;
        }
        if (seen.has(key)) {
          skipped.push({ row, reason: 'Duplicate target already exists in this assignment.' });
          return;
        }
        seen.add(key);
        accepted.push(row);
      });
      return { accepted, skipped };
    }

    function getBulkDefaults() {
      const teacherId = String(bulkFields.teacherId?.value || getFirstClassTeacherId() || '').trim();
      return {
        teacherId,
        teacherName: getTeacherName(teacherId, teacherId),
        taskStartTime: String(bulkFields.taskStartTime?.value || '').trim(),
        taskEndTime: String(bulkFields.taskEndTime?.value || '').trim(),
        timesheetReflection: bulkFields.timesheetReflection?.checked === true,
        allocatedHours: bulkFields.allocatedHours?.value,
        conflictPermitted: bulkFields.conflictPermitted?.checked === true,
        status: String(bulkFields.status?.value || 'active').trim(),
        notes: ''
      };
    }

    function getBulkSchedulePayload() {
      return {
        classId: String(classIdInput.value || '').trim(),
        preset: String(bulkFields.preset?.value || 'end_of_month').trim(),
        startDate: String(bulkFields.startDate?.value || '').trim(),
        endDate: String(bulkFields.endDate?.value || '').trim(),
        customStepDays: Number(bulkFields.customStepDays?.value || 7),
        linkSessions: bulkFields.linkSessions?.checked !== false,
        defaults: getBulkDefaults()
      };
    }

    function updateBulkPresetUi() {
      const isCustom = String(bulkFields.preset?.value || '') === 'custom';
      bulkFields.customStepSection?.classList.toggle('d-none', !isCustom);
    }

    async function fetchBulkGeneratedRows() {
      const payload = getBulkSchedulePayload();
      const response = await fetch(getBulkApiUrl('generate-target-rows'), {
        method: 'POST',
        credentials: 'same-origin',
        headers: {
          'Content-Type': 'application/json',
          'Accept': 'application/json',
          'X-AJAX-Request': 'true'
        },
        body: JSON.stringify(payload)
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || data?.status === 'error') {
        throw new Error(data?.message || 'Unable to generate bulk rows.');
      }
      return data;
    }

    function scheduleBulkCountEstimate() {
      if (!bulkFields.countEstimate) return;
      clearTimeout(bulkEstimateTimer);
      bulkEstimateTimer = setTimeout(async () => {
        try {
          const data = await fetchBulkGeneratedRows();
          const count = Array.isArray(data?.rows) ? data.rows.length : Number(data?.anchorCount || 0);
          bulkFields.countEstimate.textContent = `~${count} row${count === 1 ? '' : 's'} will be generated.`;
          bulkFields.largeBatchWarning?.classList.toggle('d-none', count < 50);
        } catch (error) {
          bulkFields.countEstimate.textContent = error.message || 'Unable to estimate row count.';
          bulkFields.largeBatchWarning?.classList.add('d-none');
        }
      }, 250);
    }

    async function runBulkPreview() {
      if (!String(classIdInput.value || '').trim()) {
        await showReportModal({ title: 'Class Required', icon: 'warning', message: 'Select a class first.' });
        return;
      }
      const defaults = getBulkDefaults();
      if (!defaults.teacherId) {
        await showReportModal({ title: 'Teacher Required', icon: 'warning', message: 'Select a default teacher for bulk rows.' });
        return;
      }
      if (defaults.timesheetReflection) {
        const allocated = Number(defaults.allocatedHours);
        if (!Number.isFinite(allocated) || allocated <= 0) {
          await showReportModal({ title: 'Allocated Hours Required', icon: 'warning', message: 'Enter allocated hours when timesheet reflection is enabled.' });
          return;
        }
      }

      let loadingToken = null;
      if (bulkFields.previewButton) bulkFields.previewButton.disabled = true;
      try {
        loadingToken = typeof showLoading === 'function'
          ? showLoading({
            title: 'Generating Preview',
            note: 'Building schedule rows and checking conflicts...',
            operation: 'Report assignment bulk rows'
          })
          : null;

        const generated = await fetchBulkGeneratedRows();
        const candidates = (Array.isArray(generated?.rows) ? generated.rows : []).map((row) => normalizeTargetRow(row));
        const { accepted, skipped } = dedupeBulkRows(targetRows, candidates);
        let previewResults = [];
        if (accepted.length) {
          const previewResponse = await fetch(getBulkApiUrl('preview-target-rows'), {
            method: 'POST',
            credentials: 'same-origin',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json',
              'X-AJAX-Request': 'true'
            },
            body: JSON.stringify({
              classId: String(classIdInput.value || '').trim(),
              targetRows: accepted
            })
          });
          const previewPayload = await previewResponse.json().catch(() => ({}));
          if (!previewResponse.ok || previewPayload?.status === 'error') {
            throw new Error(previewPayload?.message || 'Unable to preview bulk rows.');
          }
          previewResults = Array.isArray(previewPayload?.rows) ? previewPayload.rows : [];
        }

        const previewRows = buildBulkPreviewRows(accepted, skipped, previewResults);
        bulkPreviewState = { accepted, skipped, previewResults, previewRows };
        bulkFields.previewSection?.classList.remove('d-none');
        renderBulkPreviewTable();
      } catch (error) {
        await showReportModal({ title: 'Preview Failed', icon: 'warning', message: error.message || 'Unable to preview bulk rows.' });
      } finally {
        if (loadingToken && typeof hideLoading === 'function') hideLoading(loadingToken);
        if (bulkFields.previewButton) bulkFields.previewButton.disabled = false;
      }
    }

    function initBulkTeacherSummary() {
      const teacherId = String(bulkFields.teacherId?.value || getFirstClassTeacherId() || '').trim();
      if (bulkFields.teacherId) bulkFields.teacherId.value = teacherId;
      if (bulkFields.teacherSummary) {
        bulkFields.teacherSummary.value = teacherId ? getTeacherName(teacherId, teacherId) : '';
      }
    }

    document.getElementById('btnAddMultipleTargetRows')?.addEventListener('click', () => {
      if (!String(classIdInput.value || '').trim() || !(allSessions || []).length) {
        showReportModal({ title: 'Class Required', icon: 'warning', message: 'Select a class with sessions first.' });
        return;
      }
      resetBulkPreview();
      updateBulkPresetUi();
      initBulkTeacherSummary();
      scheduleBulkCountEstimate();
      showBulkTargetRowsModal();
    });

    bulkFields.preset?.addEventListener('change', () => {
      resetBulkPreview();
      updateBulkPresetUi();
      scheduleBulkCountEstimate();
    });
    [bulkFields.startDate, bulkFields.endDate, bulkFields.customStepDays, bulkFields.linkSessions,
      bulkFields.taskStartTime, bulkFields.taskEndTime, bulkFields.timesheetReflection,
      bulkFields.conflictPermitted, bulkFields.status, bulkFields.allocatedHours].forEach((field) => {
      field?.addEventListener('change', () => {
        resetBulkPreview();
        scheduleBulkCountEstimate();
      });
    });
    bulkFields.teacherId?.addEventListener('change', () => {
      resetBulkPreview();
      scheduleBulkCountEstimate();
    });

    document.getElementById('btnPickBulkTeacher')?.addEventListener('click', () => {
      if (!window.GenericPicker || !window.GenericPickerPresets) return;
      GenericPicker.open(GenericPickerPresets.teacher({
        title: 'Select Default Teacher',
        placeholder: 'Search teachers...',
        multiselect: false,
        onSelect: function (item) {
          const id = String(item?.personId || item?.id || '').trim();
          if (!id) return;
          if (bulkFields.teacherId) bulkFields.teacherId.value = id;
          if (bulkFields.teacherSummary) {
            bulkFields.teacherSummary.value = String(item?.name || item?.title || getTeacherName(id, id));
          }
          resetBulkPreview();
          scheduleBulkCountEstimate();
        }
      }));
    });

    document.getElementById('btnBulkPreviewRows')?.addEventListener('click', runBulkPreview);

    bulkFields.previewSelectAll?.addEventListener('change', (event) => {
      setAllBulkPreviewRowsSelected(Boolean(event.target?.checked));
    });

    bulkFields.previewBody?.addEventListener('change', (event) => {
      const checkbox = event.target?.closest?.('.js-bulk-preview-row-select');
      if (!checkbox) return;
      const displayIndex = Number(checkbox.getAttribute('data-bulk-preview-index'));
      if (!Number.isInteger(displayIndex)) return;
      setBulkPreviewRowSelected(displayIndex, checkbox.checked);
      syncBulkPreviewSelectAllControl();
    });

    document.getElementById('btnBulkAddRows')?.addEventListener('click', async () => {
      const rowsToAdd = getBulkSelectedPreviewRows().map((entry) => entry.row);
      if (!rowsToAdd.length) {
        await showReportModal({ title: 'No Rows Selected', icon: 'info', message: 'Select at least one valid preview row to add.' });
        return;
      }
      rowsToAdd.forEach((row) => {
        const clean = { ...row };
        delete clean.linkNote;
        targetRows.push(normalizeTargetRow(clean));
      });
      renderTargetRows();
      hideBulkTargetRowsModal();
      resetBulkPreview();
    });

    bulkModalEl?.addEventListener('click', (event) => {
      if (event.target.closest('[data-bs-dismiss="modal"]') && !window.bootstrap?.Modal) {
        hideBulkTargetRowsModal();
      }
    });

    initBulkTeacherSummary();
    updateBulkPresetUi();

    document.getElementById('btnAddTargetRow')?.addEventListener('click', () => {
      populateRowModal({
        targetType: 'session',
        teacherId: getFirstClassTeacherId(),
        status: 'active'
      }, '');
    });

    function getTargetRowActionIndex(event) {
      const actionEl = event.target?.closest?.('.js-edit-target-row, .js-duplicate-target-row, .js-remove-target-row');
      const menuEl = event.target?.closest?.('.row-actions-menu');
      const rowEl = event.target?.closest?.('tr[data-target-row-index]');
      const rawIndex = actionEl?.getAttribute('data-target-row-index')
        || menuEl?.getAttribute('data-target-row-index')
        || rowEl?.getAttribute('data-target-row-index')
        || '';
      const index = Number(rawIndex);
      return Number.isInteger(index) ? index : null;
    }

    document.addEventListener('click', (event) => {
      if (!event.target?.closest?.('.js-edit-target-row, .js-duplicate-target-row, .js-remove-target-row')) return;
      const index = getTargetRowActionIndex(event);
      if (!Number.isInteger(index)) return;
      if (event.target.closest('.js-edit-target-row')) {
        event.preventDefault();
        populateRowModal(targetRows[index], String(index));
      } else if (event.target.closest('.js-duplicate-target-row')) {
        event.preventDefault();
        const copy = normalizeTargetRow({ ...targetRows[index], rowId: generateTargetRowId() });
        targetRows.splice(index + 1, 0, copy);
        renderTargetRows();
      } else if (event.target.closest('.js-remove-target-row')) {
        event.preventDefault();
        targetRows.splice(index, 1);
        renderTargetRows();
      }
    });

    modalEl?.addEventListener('click', (event) => {
      if (event.target.closest('[data-bs-dismiss="modal"]') && !window.bootstrap?.Modal) {
        hideTargetRowModal();
      }
    });

    modalFields.targetType?.addEventListener('change', setModalTargetMode);
    modalFields.teacherId?.addEventListener('change', updateTeacherWarning);

    document.getElementById('btnPickRowSession')?.addEventListener('click', () => {
      if (!String(classIdInput.value || '').trim()) {
        showReportModal({ title: 'Class Required', icon: 'warning', message: 'Select a class first to load sessions.' });
        return;
      }
      if (!window.GenericPicker || !window.GenericPickerPresets) return;
      const rows = localSessionItems();
      const selected = rows.find((row) => row.id === String(modalFields.sessionId.value || '').trim());
      GenericPicker.open(GenericPickerPresets.session({
        title: 'Select Session',
        placeholder: 'Search sessions by date, time, class, or id...',
        sourceMode: 'local',
        localItems: rows,
        searchFields: 'id,sessionId,date,startTime,endTime,className,teacherId,teacherName,title',
        limit: 5000,
        multiselect: false,
        selectedItems: selected ? [selected] : [],
        onSelect: function (item) {
          const selectedSessionId = String(item?.sessionId || item?.id || '').trim();
          const session = getSessionById(selectedSessionId);
          if (!session) return;
          modalFields.sessionId.value = selectedSessionId;
          modalFields.sessionDate.value = toDateOnly(session.date || '');
          modalFields.sessionSummary.value = getSessionDisplay(session);
          if (!modalFields.reportStartDate.value) modalFields.reportStartDate.value = toDateOnly(session.date || '');
          if (!modalFields.reportDueDate.value) modalFields.reportDueDate.value = toDateOnly(session.date || '');
          if (!modalFields.taskStartTime.value) modalFields.taskStartTime.value = String(session.startTime || '');
          if (!modalFields.taskEndTime.value) modalFields.taskEndTime.value = String(session.endTime || '');
          const sessionTeacherId = getSessionTeacherId(session);
          if (sessionTeacherId) {
            modalFields.teacherId.value = sessionTeacherId;
            modalFields.teacherSummary.value = getTeacherName(sessionTeacherId, sessionTeacherId);
          }
          updateTeacherWarning();
        }
      }));
    });

    document.getElementById('btnPickRowTeacher')?.addEventListener('click', () => {
      if (!window.GenericPicker || !window.GenericPickerPresets) return;
      GenericPicker.open(GenericPickerPresets.teacher({
        title: 'Select Teacher',
        placeholder: 'Search teachers...',
        multiselect: false,
        onSelect: function (item) {
          const id = String(item?.personId || item?.id || '').trim();
          if (!id) return;
          modalFields.teacherId.value = id;
          modalFields.teacherSummary.value = String(item?.name || item?.title || getTeacherName(id, id));
          updateTeacherWarning();
        }
      }));
    });

    document.getElementById('btnSaveTargetRow')?.addEventListener('click', async () => {
      const row = rowFromModal();
      const issue = validateRow(row, 'Target row');
      if (issue) {
        await showReportModal({ title: 'Row Incomplete', icon: 'warning', message: issue });
        return;
      }
      const index = getModalTargetRowIndex();
      if (index !== null && targetRows[index]) targetRows[index] = row;
      else targetRows.push(row);
      renderTargetRows();
      hideTargetRowModal();
    });

    function renderSelectedStudents() {
      const ids = uniq(selectedTargetStudentIds);
      selectedTargetStudentIds = ids;
      if (!ids.length) {
        targetStudentSummaryInput.value = 'No students selected';
        selectedStudentsContainer.innerHTML = '';
        return;
      }
      targetStudentSummaryInput.value = `${ids.length} student${ids.length === 1 ? '' : 's'} selected`;
      selectedStudentsContainer.innerHTML = ids.map((id) => {
        const student = (allStudents || []).find((s) => String(s.id || '') === String(id || '')) || null;
        const label = student ? `${student.name || id} (${id})` : id;
        return `<span class="badge bg-light text-dark border">${escapeHtml(label)}</span>`;
      }).join('');
    }

    function applyScopeState() {
      const scope = String(reportScopeInput?.value || 'class').trim().toLowerCase();
      const useSpecificStudents = scope === 'selected_students';
      specificStudentsSection.classList.toggle('opacity-50', !useSpecificStudents);
      targetStudentSummaryInput.disabled = !useSpecificStudents;
      document.getElementById('btnOpenStudentPicker').disabled = !useSpecificStudents;
      scopeStudentHint.textContent = scope === 'each_student'
        ? 'Each student in this class will receive a separate report instance.'
        : (scope === 'class'
          ? 'One report instance will be used for the whole class.'
          : 'Pick one or more students for this assignment.');
      if (!useSpecificStudents) {
        selectedTargetStudentIds = [];
        renderSelectedStudents();
      }
      updateHiddenFields();
    }

    function reloadForClass(classId) {
      const cleanClassId = String(classId || '').trim();
      const base = window.location.pathname.includes('/edit/')
        ? window.location.pathname
        : '/school/reports/assignments/new';
      const next = cleanClassId ? `${base}?classId=${encodeURIComponent(cleanClassId)}` : base;
      window.isFormSubmitting = true;
      window.location.assign(next);
    }

    document.getElementById('btnPickClass')?.addEventListener('click', function () {
      if (!window.GenericPicker || !window.GenericPickerPresets) return;
      GenericPicker.open(GenericPickerPresets.class({
        onSelect: function (item) {
          const id = String(item?.id || '').trim();
          if (!id) return;
          classIdInput.value = id;
          classTitleInput.value = String(item?.title || item?.name || id);
          reloadForClass(id);
        }
      }));
    });

    document.getElementById('btnPickTemplate')?.addEventListener('click', function () {
      if (!window.GenericPicker || !window.GenericPickerPresets) return;
      GenericPicker.open(GenericPickerPresets.normalizeConfig({
        title: 'Select Template',
        icon: 'bi-journal-text',
        apiEndpoint: '/school/reports/templates',
        placeholder: 'Search templates...',
        onSelect: function (item) {
          const id = String(item?.id || '').trim();
          if (!id) return;
          templateIdInput.value = id;
          const version = Number(item?.version || 1);
          templateTitleInput.value = `${item?.title || id} | ${item?.type || '-'} v${version}`;
        }
      }));
    });

    reportScopeInput?.addEventListener('change', applyScopeState);

    document.getElementById('btnOpenStudentPicker')?.addEventListener('click', function () {
      if (!window.GenericPicker || !window.GenericPickerPresets) return;
      if (!String(classIdInput.value || '').trim()) {
        showReportModal({ title: 'Class Required', icon: 'warning', message: 'Select a class first.' });
        return;
      }
      if (!allStudents.length) {
        showReportModal({ title: 'No Students', icon: 'info', message: 'No students are available for this class.' });
        return;
      }
      const localStudentItems = (allStudents || []).map((student) => {
        const id = String(student?.id || '').trim();
        const name = String(student?.name || '').trim();
        return { id, name, title: name ? `${name} (${id})` : id };
      }).filter((row) => Boolean(row.id));
      const allowedStudentIds = new Set(localStudentItems.map((row) => row.id));
      const selectedRowMap = new Map(localStudentItems.map((row) => [row.id, row]));
      GenericPicker.open(GenericPickerPresets.person({
        title: 'Select Students',
        icon: 'bi-people',
        placeholder: 'Search class students by name or id...',
        sourceMode: 'local',
        localItems: localStudentItems,
        searchFields: 'id,name,title',
        limit: 5000,
        multiselect: true,
        selectedItems: selectedTargetStudentIds.map((id) => selectedRowMap.get(String(id || '').trim())).filter(Boolean),
        itemFilter: function (item) {
          const id = String(item?.id || '').trim();
          return Boolean(id && allowedStudentIds.has(id));
        },
        onSelect: function (items) {
          const rows = Array.isArray(items) ? items : [items];
          selectedTargetStudentIds = rows
            .map((student) => String(student?.id || '').trim())
            .filter((id) => allowedStudentIds.has(id));
          renderSelectedStudents();
          updateHiddenFields();
        }
      }));
    });

    let isSavingAssignment = false;
    formEl?.addEventListener('submit', async function (event) {
      event.preventDefault();
      if (isSavingAssignment) return;

      const classId = String(classIdInput.value || '').trim();
      const templateId = String(templateIdInput.value || '').trim();
      if (!classId) {
        await showReportModal({ title: 'Class Required', icon: 'warning', message: 'Select a class.' });
        return;
      }
      if (!templateId) {
        await showReportModal({ title: 'Template Required', icon: 'warning', message: 'Select a template.' });
        return;
      }
      targetRows = targetRows.map(normalizeTargetRow);
      if (!targetRows.length) {
        await showReportModal({ title: 'Target Rows Required', icon: 'warning', message: 'Add at least one report target row.' });
        return;
      }
      if (String(reportScopeInput?.value || 'class').trim().toLowerCase() === 'selected_students' && !selectedTargetStudentIds.length) {
        await showReportModal({ title: 'Student Required', icon: 'warning', message: 'Select at least one student for the specific students scope.' });
        return;
      }
      for (let i = 0; i < targetRows.length; i += 1) {
        const issue = validateRow(targetRows[i], `Target row ${i + 1}`);
        if (issue) {
          await showReportModal({ title: 'Row Incomplete', icon: 'warning', message: issue });
          return;
        }
      }
      updateHiddenFields();

      const activeButton = event.submitter || formEl.querySelector('button[type="submit"]');
      try {
        isSavingAssignment = true;
        setSubmitLock(true, activeButton, 'Saving...');

        const actionStateToken = String(formEl.querySelector('input[name="actionStateId"]')?.value || '').trim();
        if (!actionStateToken) {
          await showReportModal({
            title: 'Session Expired',
            icon: 'warning',
            message: 'Action state is missing. Reload this form and try again.'
          });
          return;
        }

        const requestUrl = new URL(formEl.action, window.location.origin);
        requestUrl.searchParams.set('actionStateId', actionStateToken);

        const formData = new FormData(formEl);
        const encodedBody = new URLSearchParams();
        formData.forEach((value, key) => {
          if (value instanceof File) return;
          encodedBody.append(key, String(value ?? ''));
        });

        const response = await fetch(requestUrl.toString(), {
          method: 'POST',
          body: encodedBody,
          credentials: 'same-origin',
          headers: {
            'X-AJAX-Request': 'true',
            'Accept': 'application/json',
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
          }
        });

        const rawText = await response.text();
        let payload = null;
        try {
          payload = rawText ? JSON.parse(rawText) : null;
        } catch (parseError) {
          payload = null;
        }
        if (payload && typeof window.applyGuardedApiResult === 'function' && payload?.idempotency?.state) {
          const guarded = await window.applyGuardedApiResult(payload, {
            busyTitle: 'Save In Progress',
            replayTitle: 'Save Already Processed'
          });
          if (guarded.stop) return;
        }

        if (!response.ok || String(payload?.status || '').toLowerCase() !== 'success') {
          const message = String(payload?.message || '').trim() || 'Unable to save assignment.';
          await showReportModal({ title: 'Save Failed', icon: 'error', message, buttonClass: 'btn-danger' });
          return;
        }

        await showReportModal({
          title: 'Saved',
          icon: 'success',
          message: String(payload?.message || '').trim() || 'Assignment saved successfully.',
          buttonClass: 'btn-success'
        });
        window.isFormSubmitting = true;
        window.location.assign('/school/reports/assignments');
      } catch (error) {
        await showReportModal({
          title: 'Save Failed',
          icon: 'error',
          message: String(error?.message || 'Unexpected error while saving assignment.'),
          buttonClass: 'btn-danger'
        });
      } finally {
        isSavingAssignment = false;
        setSubmitLock(false, activeButton);
      }
    });

    renderSelectedStudents();
    renderTargetRows();
    applyScopeState();
  })();
</script>
