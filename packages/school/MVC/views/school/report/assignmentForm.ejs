<%
  const isEdit = !!assignment;
  const selectedTeacherIds = Array.isArray(assignment?.teacherIds) ? assignment.teacherIds : [];
  const initialSessionIds = Array.isArray(selectedSessionIds) ? selectedSessionIds.map((v) => String(v || '').trim()).filter(Boolean) : [];
  const initialDateTargets = Array.isArray(selectedDateTargets) ? selectedDateTargets.map((v) => String(v || '').trim()).filter(Boolean) : [];
  const initialTaskStartTime = String(((typeof selectedTaskStartTime !== 'undefined' ? selectedTaskStartTime : assignment?.taskStartTime) || '')).trim();
  const initialTaskEndTime = String(((typeof selectedTaskEndTime !== 'undefined' ? selectedTaskEndTime : assignment?.taskEndTime) || '')).trim();
  const initialConflictPermitted = (selectedSessionIds && selectedSessionIds.length)
    ? true
    : Boolean((typeof selectedConflictPermitted !== 'undefined' ? selectedConflictPermitted : assignment?.conflictPermitted));
  const initialReportStartDate = String(((typeof selectedReportStartDate !== 'undefined' ? selectedReportStartDate : assignment?.reportStartDate) || '')).trim();
  const initialReportDueDate = String(((typeof selectedReportDueDate !== 'undefined' ? selectedReportDueDate : assignment?.reportDueDate) || '')).trim();
  const initialTimesheetReflection = assignment?.timesheetReflection === true;
  const initialAllocatedHours = (assignment && assignment.allocatedHours != null && Number.isFinite(Number(assignment.allocatedHours)))
    ? Number(assignment.allocatedHours)
    : '';
  const classLabel = selectedClassTitle || selectedClassId || '';
  const templateLabel = selectedTemplateTitle || selectedTemplateId || '';
%>
<div class="sections-page">
  <div class="row g-2 align-items-start mb-4">
    <div class="col">
      <h1 class="page-heading size-md m-0 text-start" style="padding-left:0;"><i class="bi bi-journal-plus me-2"></i><%= title %></h1>
      <div class="text-muted small mt-1">Assign report templates by selecting sessions or due dates. Conflict validation applies to non-session targets; session-linked reports may overlap class time.</div>
    </div>
    <div class="col-auto d-flex flex-column align-items-end gap-1">
      <% if (isEdit && assignment?.id) { %>
        <span class="badge bg-primary border font-monospace">ID: <%= assignment.id %></span>
      <% } %>
      <a href="/school/reports/assignments" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Assignments</a>
    </div>
  </div>

  <form method="POST" id="assignmentForm" action="<%= isEdit ? ('/school/reports/assignments/edit/' + assignment.id) : '/school/reports/assignments/new' %>">
    <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
    <input type="hidden" name="sessionIdsJson" id="sessionIdsJson" value='<%- JSON.stringify(initialSessionIds) %>'>
    <input type="hidden" name="dateTargetsJson" id="dateTargetsJson" value='<%- JSON.stringify(initialDateTargets) %>'>
    <input type="hidden" name="targetStudentIdsJson" id="targetStudentIdsJson" value='<%- JSON.stringify(Array.isArray(selectedTargetStudentIds) ? selectedTargetStudentIds : []) %>'>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-3">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label fw-bold">Class</label>
            <div class="input-group">
              <input type="hidden" name="classId" id="classIdInput" value="<%= selectedClassId || '' %>">
              <input type="text" class="form-control bg-white" id="classTitleInput" value="<%= classLabel %>" placeholder="Pick class..." readonly>
              <button type="button" class="btn btn-outline-primary" id="btnPickClass"><i class="bi bi-search"></i></button>
            </div>
            <div class="form-text">Selecting class reloads sessions and teacher options.</div>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Template</label>
            <div class="input-group">
              <input type="hidden" name="templateId" id="templateIdInput" value="<%= selectedTemplateId || '' %>">
              <input type="text" class="form-control bg-white" id="templateTitleInput" value="<%= templateLabel %>" placeholder="Pick template..." readonly>
              <button type="button" class="btn btn-outline-primary" id="btnPickTemplate"><i class="bi bi-search"></i></button>
            </div>
            <div class="form-text">Template is selected from report templates picker.</div>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Sessions</label>
            <div class="input-group">
              <input type="text" class="form-control bg-white" id="sessionSummaryInput" placeholder="No sessions selected" readonly>
              <button type="button" class="btn btn-outline-primary" id="btnOpenSessionPicker"><i class="bi bi-calendar3"></i></button>
            </div>
            <div class="form-text">Pick multiple sessions, with select-all/deselect-all.</div>
            <div id="selectedSessionsContainer" class="d-flex flex-wrap gap-1 mt-2"></div>
          </div>

          <div class="col-md-4">
            <label class="form-label fw-bold">Report Scope</label>
            <select class="form-select" id="reportScopeInput" name="reportScope">
              <% (assignmentReportScopes || ['class', 'each_student', 'selected_students']).forEach((scope) => { %>
                <% const selectedScope = String(selectedReportScope || assignment?.reportScope || 'class'); %>
                <option value="<%= scope %>" <%= selectedScope === scope ? 'selected' : '' %>>
                  <%= scope === 'class' ? 'Whole Class' : (scope === 'each_student' ? 'Each Student' : 'Specific Students') %>
                </option>
              <% }); %>
            </select>
            <div class="form-text">Choose whether reports are filled for class or student targets.</div>
          </div>

          <div class="col-md-8" id="specificStudentsSection">
            <label class="form-label fw-bold">Specific Students (when scope is Specific Students)</label>
            <div class="input-group">
              <input type="text" class="form-control bg-white" id="targetStudentSummaryInput" placeholder="No students selected" readonly>
              <button type="button" class="btn btn-outline-primary" id="btnOpenStudentPicker"><i class="bi bi-people"></i></button>
            </div>
            <div id="selectedStudentsContainer" class="d-flex flex-wrap gap-1 mt-2"></div>
            <div id="scopeStudentHint" class="small text-muted mt-1">For "each student" scope, all active class students are used automatically.</div>
          </div>

          <div class="col-md-6">
            <label class="form-label fw-bold">Due Dates (when sessions are not selected)</label>
            <div id="dateTargetSection">
              <div class="d-flex gap-2">
                <input type="date" class="form-control" id="dateTargetInput">
                <button type="button" class="btn btn-outline-primary" id="btnAddDateTarget"><i class="bi bi-plus-lg"></i> Add</button>
                <button type="button" class="btn btn-outline-secondary" id="btnClearDateTargets">Clear</button>
              </div>
              <div id="selectedDatesContainer" class="d-flex flex-wrap gap-1 mt-2"></div>
            </div>
            <div id="sessionSelectedHint" class="alert alert-light border mt-2 mb-0 py-2 px-2 d-none">
              Session mode is active. Due date targets are ignored, and overlap with the selected class session is allowed.
            </div>
            <div class="form-text">If no session/date target is selected, Report Due Date will be used as the assignment schedule target.</div>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Task Start Time</label>
            <input type="time" class="form-control" id="taskStartTimeInput" name="taskStartTime" value="<%= initialTaskStartTime %>" required>
            <div class="form-text">Used in schedule and conflict detection.</div>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Task End Time</label>
            <input type="time" class="form-control" id="taskEndTimeInput" name="taskEndTime" value="<%= initialTaskEndTime %>" required>
            <div class="form-text">Must be later than task start time.</div>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold d-block">Conflict Policy</label>
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="conflictPermittedInput" name="conflictPermitted" value="true" <%= initialConflictPermitted ? 'checked' : '' %>>
              <label class="form-check-label" for="conflictPermittedInput">
                Intentional overlap permitted
              </label>
            </div>
            <div class="form-text" id="conflictPermittedHint">Enable only when overlap is intentionally allowed.</div>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Report Start Date</label>
            <input type="date" class="form-control" id="reportStartDateInput" name="reportStartDate" value="<%= initialReportStartDate %>">
            <div class="form-text">Used for date-span based metrics (attendance, totals, etc.).</div>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Report Due Date</label>
            <input type="date" class="form-control" id="reportDueDateInput" name="reportDueDate" value="<%= initialReportDueDate %>">
            <div class="form-text">End of reporting period for calculated values.</div>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Status</label>
            <select class="form-select" name="status">
              <% (assignmentStatuses || []).forEach((st) => { %>
                <option value="<%= st %>" <%= String(assignment?.status || 'active') === String(st) ? 'selected' : '' %>><%= st %></option>
              <% }); %>
            </select>
          </div>

          <div class="col-md-3">
            <label class="form-label fw-bold">Notes</label>
            <input type="text" class="form-control" name="notes" maxlength="1500" value="<%= assignment?.notes || '' %>" placeholder="Optional assignment notes">
          </div>

          <div class="col-12"><hr class="my-1 text-muted"></div>
          <div class="col-md-6">
            <label class="form-label fw-bold d-block">Timesheet reflection</label>
            <div class="form-check mt-2">
              <input class="form-check-input" type="checkbox" id="timesheetReflectionInput" name="timesheetReflection" value="true" <%= initialTimesheetReflection ? 'checked' : '' %>>
              <label class="form-check-label" for="timesheetReflectionInput">
                Count allocated hours in Master Schedule totals and on instructor timesheets (for the period that contains this task date).
              </label>
            </div>
            <div class="form-text">When enabled, scheduled task times still position the item on the calendar; hours for totals and payroll use <strong>Allocated hours</strong> below.</div>
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold" for="allocatedHoursInput">Allocated hours</label>
            <input type="number" class="form-control" id="allocatedHoursInput" name="allocatedHours" min="0.25" max="24" step="0.25"
              value="<%= initialAllocatedHours === '' ? '' : initialAllocatedHours %>"
              placeholder="e.g. 1.5">
            <div class="form-text">Required when Timesheet reflection is checked (max 24).</div>
          </div>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white d-flex align-items-center justify-content-between gap-2">
        <h5 class="m-0 fw-bold">Assigned Teachers</h5>
        <button type="button" class="btn btn-outline-primary btn-sm" id="btnOpenTeacherSchedulePreview">
          <i class="bi bi-calendar-week me-1"></i> View Teacher Schedule (Assignment Day)
        </button>
      </div>
      <div class="card-body p-3">
        <% if (!teacherOptions || !teacherOptions.length) { %>
          <div class="text-muted small">No teachers were resolved from class instructors/sessions. Select a class first.</div>
        <% } %>
        <div class="row g-2">
          <% (teacherOptions || []).forEach((teacher) => { %>
            <div class="col-md-4">
              <label class="form-check border rounded p-2 h-100">
                <input class="form-check-input me-2" type="checkbox" name="teacherIds" value="<%= teacher.id %>" <%= selectedTeacherIds.includes(teacher.id) ? 'checked' : '' %>>
                <span class="fw-semibold"><%= teacher.name %></span>
                <span class="small text-muted d-block font-monospace"><%= teacher.id %></span>
              </label>
            </div>
          <% }); %>
        </div>
      </div>
    </div>

    <div class="d-flex gap-2">
      <button class="btn btn-primary" type="submit">Save Assignment</button>
      <a href="/school/reports/assignments" class="btn btn-outline-secondary">Cancel</a>
    </div>
  </form>
</div>

<div class="modal fade" id="sessionPickerModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content border-0 shadow-sm">
      <div class="modal-header bg-light">
        <h5 class="modal-title fw-bold"><i class="bi bi-calendar3 me-2"></i>Select Sessions</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="d-flex gap-2 mb-3">
          <input type="text" class="form-control" id="sessionPickerSearch" placeholder="Search by date, time, or session id...">
          <button type="button" class="btn btn-outline-secondary" id="btnSessionSelectAll">Select All</button>
          <button type="button" class="btn btn-outline-secondary" id="btnSessionDeselectAll">Deselect All</button>
        </div>
        <div id="sessionPickerList" class="list-group small"></div>
      </div>
      <div class="modal-footer bg-white">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="btnApplySessionPicker">Apply</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="studentPickerModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content border-0 shadow-sm">
      <div class="modal-header bg-light">
        <h5 class="modal-title fw-bold"><i class="bi bi-people me-2"></i>Select Students</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="d-flex gap-2 mb-3">
          <input type="text" class="form-control" id="studentPickerSearch" placeholder="Search by student name or id...">
          <button type="button" class="btn btn-outline-secondary" id="btnStudentSelectAll">Select All</button>
          <button type="button" class="btn btn-outline-secondary" id="btnStudentDeselectAll">Deselect All</button>
        </div>
        <div id="studentPickerList" class="list-group small"></div>
      </div>
      <div class="modal-footer bg-white">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="btnApplyStudentPicker">Apply</button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/modal_GenericPicker') %>

<script>
  (function () {
    const classIdInput = document.getElementById('classIdInput');
    const classTitleInput = document.getElementById('classTitleInput');
    const templateIdInput = document.getElementById('templateIdInput');
    const templateTitleInput = document.getElementById('templateTitleInput');
    const sessionIdsInput = document.getElementById('sessionIdsJson');
    const dateTargetsInput = document.getElementById('dateTargetsJson');
    const sessionSummaryInput = document.getElementById('sessionSummaryInput');
    const selectedSessionsContainer = document.getElementById('selectedSessionsContainer');
    const selectedDatesContainer = document.getElementById('selectedDatesContainer');
    const targetStudentIdsInput = document.getElementById('targetStudentIdsJson');
    const reportScopeInput = document.getElementById('reportScopeInput');
    const targetStudentSummaryInput = document.getElementById('targetStudentSummaryInput');
    const selectedStudentsContainer = document.getElementById('selectedStudentsContainer');
    const specificStudentsSection = document.getElementById('specificStudentsSection');
    const scopeStudentHint = document.getElementById('scopeStudentHint');
    const reportStartDateInput = document.getElementById('reportStartDateInput');
    const reportDueDateInput = document.getElementById('reportDueDateInput');
    const taskStartTimeInput = document.getElementById('taskStartTimeInput');
    const taskEndTimeInput = document.getElementById('taskEndTimeInput');
    const conflictPermittedInput = document.getElementById('conflictPermittedInput');
    const conflictPermittedHint = document.getElementById('conflictPermittedHint');
    const btnOpenTeacherSchedulePreview = document.getElementById('btnOpenTeacherSchedulePreview');
    const dateTargetSection = document.getElementById('dateTargetSection');
    const sessionSelectedHint = document.getElementById('sessionSelectedHint');
    const formEl = document.getElementById('assignmentForm');

    const allSessions = <%- JSON.stringify(sessions || []) %>;
    const allStudents = <%- JSON.stringify(studentOptions || []) %>;
    let selectedSessionIds = Array.isArray(<%- JSON.stringify(initialSessionIds) %>) ? <%- JSON.stringify(initialSessionIds) %> : [];
    let selectedDateTargets = Array.isArray(<%- JSON.stringify(initialDateTargets) %>) ? <%- JSON.stringify(initialDateTargets) %> : [];
    let selectedTargetStudentIds = Array.isArray(<%- JSON.stringify(Array.isArray(selectedTargetStudentIds) ? selectedTargetStudentIds : []) %>) ? <%- JSON.stringify(Array.isArray(selectedTargetStudentIds) ? selectedTargetStudentIds : []) %> : [];
    let pendingSessionIds = new Set(selectedSessionIds);
    let pendingStudentIds = new Set(selectedTargetStudentIds);

    const sessionPickerModalEl = document.getElementById('sessionPickerModal');
    const sessionPickerSearch = document.getElementById('sessionPickerSearch');
    const sessionPickerList = document.getElementById('sessionPickerList');
    const studentPickerModalEl = document.getElementById('studentPickerModal');
    const studentPickerSearch = document.getElementById('studentPickerSearch');
    const studentPickerList = document.getElementById('studentPickerList');

    function showReportModal({ title = 'Notice', message = '', icon = 'warning', buttonClass = 'btn-primary' } = {}) {
      if (typeof hideLoading === 'function') {
        hideLoading();
      }
      if (typeof showMessageModal === 'function') {
        return showMessageModal({
          title,
          icon,
          message,
          buttons: [{ text: 'OK', class: buttonClass }]
        });
      }
      alert(String(message || title || 'Notice'));
      return Promise.resolve('OK');
    }

    function setSubmitLock(isLocked, activeButton, loadingLabel) {
      const submitButtons = Array.from(formEl?.querySelectorAll('button[type="submit"]') || []);
      submitButtons.forEach((button) => {
        if (!button) return;
        if (!button.dataset.originalHtml) button.dataset.originalHtml = button.innerHTML;
        button.disabled = isLocked;
      });

      if (activeButton) {
        if (!activeButton.dataset.originalHtml) activeButton.dataset.originalHtml = activeButton.innerHTML;
        if (isLocked) {
          activeButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + String(loadingLabel || 'Saving...');
        } else if (activeButton.dataset.originalHtml) {
          activeButton.innerHTML = activeButton.dataset.originalHtml;
        }
      }

      if (typeof showLoading === 'function') {
        if (isLocked) showLoading();
        else if (typeof hideLoading === 'function') hideLoading();
      }
    }

    function uniq(arr) {
      return [...new Set((Array.isArray(arr) ? arr : []).map((v) => String(v || '').trim()).filter(Boolean))];
    }

    function toDateOnly(value) {
      return /^\d{4}-\d{2}-\d{2}$/.test(String(value || '').trim()) ? String(value).trim() : '';
    }

    function getSessionDisplay(session) {
      if (!session) return '';
      const date = String(session.date || '');
      const start = String(session.startTime || '--:--');
      const end = String(session.endTime || '--:--');
      const sid = String(session.sessionId || '');
      return `${date} | ${start}-${end} (${sid})`;
    }

    function getSessionById(id) {
      return (allSessions || []).find((s) => String(s.sessionId || '') === String(id || '')) || null;
    }

    function getDerivedPeriodFromTargets() {
      const dates = [];
      if (selectedSessionIds.length) {
        selectedSessionIds.forEach((sid) => {
          const session = getSessionById(sid);
          const date = toDateOnly(session?.date || '');
          if (date) dates.push(date);
        });
      } else {
        selectedDateTargets.forEach((date) => {
          const clean = toDateOnly(date);
          if (clean) dates.push(clean);
        });
      }
      if (!dates.length) return { start: '', due: '' };
      dates.sort();
      return { start: dates[0], due: dates[dates.length - 1] };
    }

    function syncReportPeriodDefaults() {
      const derived = getDerivedPeriodFromTargets();
      if (!derived.start || !derived.due) return;
      const currentStart = toDateOnly(reportStartDateInput?.value || '');
      const currentDue = toDateOnly(reportDueDateInput?.value || '');
      if (!currentStart && reportStartDateInput) reportStartDateInput.value = derived.start;
      if (!currentDue && reportDueDateInput) reportDueDateInput.value = derived.due;
    }

    function syncTaskTimeDefaultsFromSessions() {
      if (!selectedSessionIds.length) return;
      const currentStart = String(taskStartTimeInput?.value || '').trim();
      const currentEnd = String(taskEndTimeInput?.value || '').trim();
      if (currentStart && currentEnd) return;
      const firstSession = getSessionById(selectedSessionIds[0]);
      const sessionStart = String(firstSession?.startTime || '').trim();
      const sessionEnd = String(firstSession?.endTime || '').trim();
      if (!sessionStart || !sessionEnd) return;
      if (!currentStart && taskStartTimeInput) taskStartTimeInput.value = sessionStart;
      if (!currentEnd && taskEndTimeInput) taskEndTimeInput.value = sessionEnd;
    }

    function updateHiddenFields() {
      sessionIdsInput.value = JSON.stringify(uniq(selectedSessionIds));
      dateTargetsInput.value = JSON.stringify(uniq(selectedDateTargets.map(toDateOnly).filter(Boolean)));
      targetStudentIdsInput.value = JSON.stringify(uniq(selectedTargetStudentIds));
    }

    function renderSelectedSessions() {
      const ids = uniq(selectedSessionIds);
      selectedSessionIds = ids;
      if (!ids.length) {
        sessionSummaryInput.value = 'No sessions selected';
        selectedSessionsContainer.innerHTML = '';
        return;
      }

      sessionSummaryInput.value = `${ids.length} session${ids.length === 1 ? '' : 's'} selected`;
      selectedSessionsContainer.innerHTML = ids.map((id) => {
        const session = getSessionById(id);
        const label = session ? getSessionDisplay(session) : id;
        return `<span class="badge bg-light text-dark border">${label}</span>`;
      }).join('');
    }

    function renderDateTargets() {
      selectedDateTargets = uniq(selectedDateTargets.map(toDateOnly).filter(Boolean)).sort();
      if (!selectedDateTargets.length) {
        selectedDatesContainer.innerHTML = '<span class="text-muted small">No dates selected.</span>';
        return;
      }

      selectedDatesContainer.innerHTML = selectedDateTargets.map((date) => (
        `<span class="badge bg-light text-dark border">
          ${date}
          <button type="button" class="btn btn-link btn-sm p-0 ms-1 text-danger text-decoration-none" data-remove-date="${date}">&times;</button>
        </span>`
      )).join('');
    }

    function applyTargetModeState() {
      const hasSessions = selectedSessionIds.length > 0;
      dateTargetSection.classList.toggle('opacity-50', hasSessions);
      const dateControls = dateTargetSection.querySelectorAll('input,button');
      dateControls.forEach((el) => { el.disabled = hasSessions; });
      sessionSelectedHint.classList.toggle('d-none', !hasSessions);
      if (conflictPermittedInput) {
        if (hasSessions) conflictPermittedInput.checked = true;
      }
      if (conflictPermittedHint) {
        conflictPermittedHint.textContent = hasSessions
          ? 'Session-linked reports are marked as intentional overlap automatically.'
          : 'Enable only when overlap is intentionally allowed.';
      }
      updateHiddenFields();
      syncReportPeriodDefaults();
      syncTaskTimeDefaultsFromSessions();
    }

    function getStudentById(id) {
      return (allStudents || []).find((s) => String(s.id || '') === String(id || '')) || null;
    }

    function renderSelectedStudents() {
      const ids = uniq(selectedTargetStudentIds);
      selectedTargetStudentIds = ids;
      if (!ids.length) {
        targetStudentSummaryInput.value = 'No students selected';
        selectedStudentsContainer.innerHTML = '';
        return;
      }
      targetStudentSummaryInput.value = `${ids.length} student${ids.length === 1 ? '' : 's'} selected`;
      selectedStudentsContainer.innerHTML = ids.map((id) => {
        const student = getStudentById(id);
        const label = student ? `${student.name || id} (${id})` : id;
        return `<span class="badge bg-light text-dark border">${label}</span>`;
      }).join('');
    }

    function applyScopeState() {
      const scope = String(reportScopeInput?.value || 'class').trim().toLowerCase();
      const useSpecificStudents = scope === 'selected_students';
      specificStudentsSection.classList.toggle('opacity-50', !useSpecificStudents);
      targetStudentSummaryInput.disabled = !useSpecificStudents;
      document.getElementById('btnOpenStudentPicker').disabled = !useSpecificStudents;
      scopeStudentHint.textContent = scope === 'each_student'
        ? 'Each student in this class will receive a separate report instance.'
        : (scope === 'class'
          ? 'One report instance will be used for the whole class.'
          : 'Pick one or more students for this assignment.');
      if (!useSpecificStudents) {
        selectedTargetStudentIds = [];
        renderSelectedStudents();
      }
      updateHiddenFields();
    }

    function renderSessionPickerList() {
      const keyword = String(sessionPickerSearch.value || '').trim().toLowerCase();
      const rows = (allSessions || []).filter((session) => {
        if (!keyword) return true;
        const hay = [
          session.sessionId,
          session.date,
          session.startTime,
          session.endTime,
          session.delivery?.deliveredBy
        ].map((v) => String(v || '').toLowerCase()).join(' ');
        return hay.includes(keyword);
      });

      if (!rows.length) {
        sessionPickerList.innerHTML = '<div class="text-muted small p-3 text-center">No sessions found.</div>';
        return;
      }

      sessionPickerList.innerHTML = rows.map((session) => {
        const sid = String(session.sessionId || '').trim();
        const checked = pendingSessionIds.has(sid) ? 'checked' : '';
        return `
          <label class="list-group-item d-flex align-items-start gap-2">
            <input class="form-check-input mt-1" type="checkbox" data-session-id="${sid}" ${checked}>
            <span class="small">${getSessionDisplay(session)}</span>
          </label>
        `;
      }).join('');
    }

    function renderStudentPickerList() {
      const keyword = String(studentPickerSearch.value || '').trim().toLowerCase();
      const rows = (allStudents || []).filter((student) => {
        if (!keyword) return true;
        const hay = [student.id, student.name].map((v) => String(v || '').toLowerCase()).join(' ');
        return hay.includes(keyword);
      });

      if (!rows.length) {
        studentPickerList.innerHTML = '<div class="text-muted small p-3 text-center">No students found.</div>';
        return;
      }

      studentPickerList.innerHTML = rows.map((student) => {
        const sid = String(student.id || '').trim();
        const checked = pendingStudentIds.has(sid) ? 'checked' : '';
        const label = `${String(student.name || sid)} (${sid})`;
        return `
          <label class="list-group-item d-flex align-items-start gap-2">
            <input class="form-check-input mt-1" type="checkbox" data-student-id="${sid}" ${checked}>
            <span class="small">${label}</span>
          </label>
        `;
      }).join('');
    }

    function reloadForClass(classId) {
      const cleanClassId = String(classId || '').trim();
      const base = window.location.pathname.includes('/edit/')
        ? window.location.pathname
        : '/school/reports/assignments/new';
      const next = cleanClassId ? `${base}?classId=${encodeURIComponent(cleanClassId)}` : base;
      window.isFormSubmitting = true;
      window.location.assign(next);
    }

    function resolvePreviewTargetDate() {
      const sessionDates = selectedSessionIds
        .map((sid) => getSessionById(sid))
        .map((session) => toDateOnly(session?.date || ''))
        .filter(Boolean)
        .sort();
      if (sessionDates.length) return sessionDates[0];

      const dateTargets = selectedDateTargets
        .map((date) => toDateOnly(date))
        .filter(Boolean)
        .sort();
      if (dateTargets.length) return dateTargets[0];

      return toDateOnly(reportDueDateInput?.value || '');
    }

    document.getElementById('btnPickClass')?.addEventListener('click', function () {
      if (!window.GenericPicker || !window.GenericPickerPresets) return;
      GenericPicker.open(GenericPickerPresets.class({
        onSelect: function (item) {
          const id = String(item?.id || '').trim();
          if (!id) return;
          classIdInput.value = id;
          classTitleInput.value = String(item?.title || item?.name || id);
          reloadForClass(id);
        }
      }));
    });

    document.getElementById('btnPickTemplate')?.addEventListener('click', function () {
      if (!window.GenericPicker || !window.GenericPickerPresets) return;
      GenericPicker.open(GenericPickerPresets.normalizeConfig({
        title: 'Select Template',
        icon: 'bi-journal-text',
        apiEndpoint: '/school/reports/templates',
        placeholder: 'Search templates...',
        onSelect: function (item) {
          const id = String(item?.id || '').trim();
          if (!id) return;
          templateIdInput.value = id;
          const version = Number(item?.version || 1);
          templateTitleInput.value = `${item?.title || id} | ${item?.type || '-'} v${version}`;
        }
      }));
    });

    btnOpenTeacherSchedulePreview?.addEventListener('click', function () {
      const selectedTeacherInput = formEl?.querySelector('input[name="teacherIds"]:checked');
      if (!selectedTeacherInput) {
        showReportModal({ title: 'Teacher Required', icon: 'warning', message: 'Select at least one teacher first.' });
        return;
      }

      const teacherId = String(selectedTeacherInput.value || '').trim();
      if (!teacherId) {
        showReportModal({ title: 'Teacher Required', icon: 'warning', message: 'Selected teacher id is invalid.' });
        return;
      }

      const labelEl = selectedTeacherInput.closest('label')?.querySelector('.fw-semibold');
      const teacherName = String(labelEl?.textContent || teacherId).trim() || teacherId;
      const targetDate = resolvePreviewTargetDate();
      if (!targetDate) {
        showReportModal({
          title: 'Target Date Required',
          icon: 'warning',
          message: 'Select a session, add a due date target, or set Report Due Date first.'
        });
        return;
      }

      const url = `/school/schedules?personId=${encodeURIComponent(teacherId)}&personName=${encodeURIComponent(teacherName)}&date=${encodeURIComponent(targetDate)}`;
      window.open(url, '_blank', 'noopener');
    });

    document.getElementById('btnOpenSessionPicker')?.addEventListener('click', function () {
      if (!window.bootstrap || !sessionPickerModalEl) return;
      const sessionPickerModal = bootstrap.Modal.getOrCreateInstance(sessionPickerModalEl);
      if (!String(classIdInput.value || '').trim()) {
        showReportModal({ title: 'Class Required', icon: 'warning', message: 'Select a class first to load sessions.', buttonClass: 'btn-secondary' });
        return;
      }
      pendingSessionIds = new Set(selectedSessionIds);
      sessionPickerSearch.value = '';
      renderSessionPickerList();
      sessionPickerModal.show();
    });

    sessionPickerSearch?.addEventListener('input', renderSessionPickerList);

    sessionPickerList?.addEventListener('change', function (event) {
      const target = event.target;
      if (!target || !target.matches('input[data-session-id]')) return;
      const sid = String(target.getAttribute('data-session-id') || '').trim();
      if (!sid) return;
      if (target.checked) pendingSessionIds.add(sid);
      else pendingSessionIds.delete(sid);
    });

    document.getElementById('btnSessionSelectAll')?.addEventListener('click', function () {
      (allSessions || []).forEach((session) => {
        const sid = String(session.sessionId || '').trim();
        if (sid) pendingSessionIds.add(sid);
      });
      renderSessionPickerList();
    });

    document.getElementById('btnSessionDeselectAll')?.addEventListener('click', function () {
      pendingSessionIds = new Set();
      renderSessionPickerList();
    });

    document.getElementById('btnApplySessionPicker')?.addEventListener('click', function () {
      selectedSessionIds = (allSessions || [])
        .map((session) => String(session.sessionId || '').trim())
        .filter((sid) => pendingSessionIds.has(sid));
      if (window.bootstrap && sessionPickerModalEl) {
        bootstrap.Modal.getOrCreateInstance(sessionPickerModalEl).hide();
      }
      renderSelectedSessions();
      applyTargetModeState();
    });

    reportScopeInput?.addEventListener('change', applyScopeState);

    document.getElementById('btnOpenStudentPicker')?.addEventListener('click', function () {
      if (!window.bootstrap || !studentPickerModalEl) return;
      if (!String(classIdInput.value || '').trim()) {
        showReportModal({ title: 'Class Required', icon: 'warning', message: 'Select a class first.' });
        return;
      }
      if (!allStudents.length) {
        showReportModal({ title: 'No Students', icon: 'info', message: 'No students are available for this class.' });
        return;
      }
      pendingStudentIds = new Set(selectedTargetStudentIds);
      studentPickerSearch.value = '';
      renderStudentPickerList();
      bootstrap.Modal.getOrCreateInstance(studentPickerModalEl).show();
    });

    studentPickerSearch?.addEventListener('input', renderStudentPickerList);

    studentPickerList?.addEventListener('change', function (event) {
      const target = event.target;
      if (!target || !target.matches('input[data-student-id]')) return;
      const sid = String(target.getAttribute('data-student-id') || '').trim();
      if (!sid) return;
      if (target.checked) pendingStudentIds.add(sid);
      else pendingStudentIds.delete(sid);
    });

    document.getElementById('btnStudentSelectAll')?.addEventListener('click', function () {
      (allStudents || []).forEach((student) => {
        const sid = String(student.id || '').trim();
        if (sid) pendingStudentIds.add(sid);
      });
      renderStudentPickerList();
    });

    document.getElementById('btnStudentDeselectAll')?.addEventListener('click', function () {
      pendingStudentIds = new Set();
      renderStudentPickerList();
    });

    document.getElementById('btnApplyStudentPicker')?.addEventListener('click', function () {
      selectedTargetStudentIds = (allStudents || [])
        .map((student) => String(student.id || '').trim())
        .filter((sid) => pendingStudentIds.has(sid));
      if (window.bootstrap && studentPickerModalEl) {
        bootstrap.Modal.getOrCreateInstance(studentPickerModalEl).hide();
      }
      renderSelectedStudents();
      updateHiddenFields();
    });

    document.getElementById('btnAddDateTarget')?.addEventListener('click', function () {
      const dateInput = document.getElementById('dateTargetInput');
      const date = toDateOnly(dateInput?.value || '');
      if (!date) return;
      if (!selectedDateTargets.includes(date)) selectedDateTargets.push(date);
      if (dateInput) dateInput.value = '';
      renderDateTargets();
      applyTargetModeState();
    });

    document.getElementById('btnClearDateTargets')?.addEventListener('click', function () {
      selectedDateTargets = [];
      renderDateTargets();
      applyTargetModeState();
    });

    selectedDatesContainer?.addEventListener('click', function (event) {
      const target = event.target;
      if (!target || !target.matches('button[data-remove-date]')) return;
      const date = String(target.getAttribute('data-remove-date') || '').trim();
      selectedDateTargets = selectedDateTargets.filter((d) => d !== date);
      renderDateTargets();
      applyTargetModeState();
    });

    let isSavingAssignment = false;

    formEl?.addEventListener('submit', async function (event) {
      event.preventDefault();
      if (isSavingAssignment) return;

      const classId = String(classIdInput.value || '').trim();
      const templateId = String(templateIdInput.value || '').trim();
      if (!classId) {
        await showReportModal({ title: 'Class Required', icon: 'warning', message: 'Select a class.' });
        return;
      }
      if (!templateId) {
        await showReportModal({ title: 'Template Required', icon: 'warning', message: 'Select a template.' });
        return;
      }
      const reportDueDateForTargetFallback = toDateOnly(reportDueDateInput?.value || '');
      if (!selectedSessionIds.length && !selectedDateTargets.length && !reportDueDateForTargetFallback) {
        await showReportModal({ title: 'Target Required', icon: 'warning', message: 'Select at least one session, add a due date target, or set Report Due Date.' });
        return;
      }
      if (String(reportScopeInput?.value || 'class').trim().toLowerCase() === 'selected_students' && !selectedTargetStudentIds.length) {
        await showReportModal({ title: 'Student Required', icon: 'warning', message: 'Select at least one student for the specific students scope.' });
        return;
      }
      if (selectedSessionIds.length && conflictPermittedInput) {
        conflictPermittedInput.checked = true;
      }
      syncReportPeriodDefaults();
      const reportStartDate = toDateOnly(reportStartDateInput?.value || '');
      const reportDueDate = toDateOnly(reportDueDateInput?.value || '');
      const taskStartTime = String(taskStartTimeInput?.value || '').trim();
      const taskEndTime = String(taskEndTimeInput?.value || '').trim();
      if (!taskStartTime || !taskEndTime) {
        await showReportModal({ title: 'Task Time Required', icon: 'warning', message: 'Set both task start and task end time.' });
        return;
      }
      if (taskStartTime >= taskEndTime) {
        await showReportModal({ title: 'Invalid Task Time', icon: 'warning', message: 'Task end time must be later than task start time.' });
        return;
      }
      if ((reportStartDate && !reportDueDate) || (!reportStartDate && reportDueDate)) {
        await showReportModal({ title: 'Invalid Report Period', icon: 'warning', message: 'Provide both report start date and report due date, or leave both empty.' });
        return;
      }
      if (reportStartDate && reportDueDate && reportStartDate > reportDueDate) {
        await showReportModal({ title: 'Invalid Report Period', icon: 'warning', message: 'Report start date cannot be after report due date.' });
        return;
      }
      updateHiddenFields();

      const activeButton = event.submitter || formEl.querySelector('button[type="submit"]');
      try {
        isSavingAssignment = true;
        setSubmitLock(true, activeButton, 'Saving...');

        const actionStateToken = String(formEl.querySelector('input[name="actionStateId"]')?.value || '').trim();
        if (!actionStateToken) {
          await showReportModal({
            title: 'Session Expired',
            icon: 'warning',
            message: 'Action state is missing. Reload this form and try again.'
          });
          return;
        }

        const requestUrl = new URL(formEl.action, window.location.origin);
        requestUrl.searchParams.set('actionStateId', actionStateToken);

        const formData = new FormData(formEl);
        const encodedBody = new URLSearchParams();
        formData.forEach((value, key) => {
          if (value instanceof File) return;
          encodedBody.append(key, String(value ?? ''));
        });

        const response = await fetch(requestUrl.toString(), {
          method: 'POST',
          body: encodedBody,
          credentials: 'same-origin',
          headers: {
            'X-AJAX-Request': 'true',
            'Accept': 'application/json',
            'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8'
          }
        });

        const rawText = await response.text();
        let payload = null;
        try {
          payload = rawText ? JSON.parse(rawText) : null;
        } catch (parseError) {
          payload = null;
        }
        if (payload && typeof window.applyGuardedApiResult === 'function' && payload?.idempotency?.state) {
          const guarded = await window.applyGuardedApiResult(payload, {
            busyTitle: 'Save In Progress',
            replayTitle: 'Save Already Processed'
          });
          if (guarded.stop) return;
        }

        if (!response.ok || String(payload?.status || '').toLowerCase() !== 'success') {
          const message = String(payload?.message || '').trim() || 'Unable to save assignment.';
          await showReportModal({
            title: 'Save Failed',
            icon: 'warning',
            message
          });
          return;
        }

        const successMessage = String(payload?.message || '').trim() || 'Assignment saved successfully.';
        await showReportModal({
          title: 'Saved',
          icon: 'success',
          message: successMessage,
          buttonClass: 'btn-success'
        });
        window.isFormSubmitting = true;
        window.location.assign('/school/reports/assignments');
      } catch (error) {
        await showReportModal({
          title: 'Save Failed',
          icon: 'warning',
          message: String(error?.message || 'Unexpected error while saving assignment.')
        });
      } finally {
        isSavingAssignment = false;
        setSubmitLock(false, activeButton);
      }
    });

    renderSelectedSessions();
    renderDateTargets();
    renderSelectedStudents();
    applyTargetModeState();
    applyScopeState();

    const timesheetReflectionInput = document.getElementById('timesheetReflectionInput');
    const allocatedHoursInput = document.getElementById('allocatedHoursInput');
    function syncTimesheetReflectionUi() {
      if (!timesheetReflectionInput || !allocatedHoursInput) return;
      const on = timesheetReflectionInput.checked;
      allocatedHoursInput.toggleAttribute('required', on);
      if (!on) allocatedHoursInput.setCustomValidity('');
    }
    if (timesheetReflectionInput) {
      timesheetReflectionInput.addEventListener('change', syncTimesheetReflectionUi);
    }
    if (allocatedHoursInput) {
      allocatedHoursInput.addEventListener('input', () => {
        if (!timesheetReflectionInput?.checked) return;
        const v = parseFloat(allocatedHoursInput.value);
        if (!Number.isFinite(v) || v <= 0) {
          allocatedHoursInput.setCustomValidity('Enter allocated hours greater than zero when Timesheet reflection is enabled.');
        } else {
          allocatedHoursInput.setCustomValidity('');
        }
      });
    }
    syncTimesheetReflectionUi();
  })();
</script>
