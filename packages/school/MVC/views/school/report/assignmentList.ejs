<%
  const assignmentStateFilters = (filters && typeof filters === 'object') ? filters : {};
  const parseCsvIds = (value) => String(value || '')
    .split(',')
    .map((item) => String(item || '').trim())
    .filter(Boolean);
  const selectedClassIdsSafe = Array.isArray(selectedClassIds) && selectedClassIds.length
    ? selectedClassIds.map((id) => String(id || '').trim()).filter(Boolean)
    : parseCsvIds(assignmentStateFilters?.classIds || assignmentStateFilters?.classId || '');
  const selectedClassesSafe = Array.isArray(selectedClasses) && selectedClasses.length
    ? selectedClasses
      .map((item) => ({
        id: String(item?.id || '').trim(),
        name: String(item?.name || item?.id || '').trim()
      }))
      .filter((item) => item.id)
    : selectedClassIdsSafe.map((id) => ({ id, name: id }));
  const selectedClassIdSafe = selectedClassIdsSafe[0] || '';
  const selectedClassIdsCsvSafe = selectedClassIdsSafe.join(',');
  const selectedClassLabelSafe = selectedClassesSafe.map((item) => item.name || item.id).filter(Boolean).join(', ');
  const selectedTeacherIdSafe = String(((typeof selectedTeacherId !== 'undefined' ? selectedTeacherId : assignmentStateFilters?.teacherPersonId) || '')).trim();
  const selectedTeacherNameSafe = String(((typeof selectedTeacherName !== 'undefined' ? selectedTeacherName : selectedTeacherIdSafe) || '')).trim();
  const selectedReportScopeSafe = String(((typeof selectedReportScope !== 'undefined' ? selectedReportScope : assignmentStateFilters?.reportScope) || '')).trim().toLowerCase();
  const hasAssignmentFiltersApplied = Boolean(
    selectedClassIdsSafe.length
    || String(assignmentStateFilters?.q || '').trim()
    || selectedTeacherIdSafe
    || selectedReportScopeSafe
  );
  const totalMatchedRows = Number(pagination?.totalItems ?? (Array.isArray(data) ? data.length : 0));
%>

<%- include('partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print,
  headerManageBtns: [
    `<a href="/school/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-house me-1"></i>Report Home</a>`,
  ]
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
    <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter Report Assignments</div>
    <button
      id="reportAssignmentFilterToggleBtn"
      type="button"
      class="btn btn-outline-secondary btn-sm px-2"
      data-bs-toggle="collapse"
      data-bs-target="#reportAssignmentFilterCollapse"
      aria-expanded="<%= hasAssignmentFiltersApplied ? 'true' : 'false' %>"
      aria-controls="reportAssignmentFilterCollapse"
      aria-label="<%= hasAssignmentFiltersApplied ? 'Close filters' : 'Open filters' %>">
      <i id="reportAssignmentFilterToggleIcon" class="bi <%= hasAssignmentFiltersApplied ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
    </button>
  </div>
  <div class="collapse<%= hasAssignmentFiltersApplied ? ' show' : '' %>" id="reportAssignmentFilterCollapse">
    <form method="GET" action="/school/reports/assignments" id="reportAssignmentFilterForm" class="card-body p-3">
      <input type="hidden" name="q" value="<%= filters?.q || '' %>">
      <div class="row g-3 align-items-end">
        <div class="col-lg-6">
          <label class="form-label">Classes</label>
          <div class="input-group">
            <input type="hidden" name="classId" id="classIdFilterInput" value="<%= selectedClassIdSafe %>">
            <input type="hidden" name="classIds" id="classIdsFilterInput" value="<%= selectedClassIdsCsvSafe %>">
            <input type="text" class="form-control bg-white" id="classTitleFilterInput" value="<%= selectedClassLabelSafe %>" placeholder="All Classes" readonly>
            <button type="button" class="btn btn-outline-primary" id="btnPickClassFilter" title="Pick Class">
              <i class="bi bi-search"></i>
            </button>
            <button type="button" class="btn btn-outline-secondary" id="btnClearClassFilter" title="Clear Class Filter">
              <i class="bi bi-x-lg"></i>
            </button>
          </div>
          <div id="classFilterChips" class="mt-2"></div>
        </div>
        <div class="col-lg-3">
          <label class="form-label">Select Person</label>
          <div class="input-group">
            <input type="hidden" name="teacherPersonId" id="teacherPersonIdFilterInput" value="<%= selectedTeacherIdSafe %>">
            <input type="text" class="form-control bg-white" id="teacherNameFilterInput" value="<%= selectedTeacherNameSafe %>" placeholder="All Teachers" readonly>
            <button type="button" class="btn btn-outline-primary" id="btnPickTeacherFilter" title="Pick Teacher">
              <i class="bi bi-person-badge"></i>
            </button>
            <button type="button" class="btn btn-outline-secondary" id="btnClearTeacherFilter" title="Clear Teacher Filter">
              <i class="bi bi-x-lg"></i>
            </button>
          </div>
        </div>
        <div class="col-lg-3">
          <label class="form-label" for="reportScopeFilterInput">Report Scope</label>
          <select class="form-select" id="reportScopeFilterInput" name="reportScope">
            <option value="" <%= !selectedReportScopeSafe ? 'selected' : '' %>>All Scopes</option>
            <option value="class" <%= selectedReportScopeSafe === 'class' ? 'selected' : '' %>>Whole Class</option>
            <option value="each_student" <%= selectedReportScopeSafe === 'each_student' ? 'selected' : '' %>>Each Student</option>
            <option value="selected_students" <%= selectedReportScopeSafe === 'selected_students' ? 'selected' : '' %>>Selected Students</option>
          </select>
        </div>
        <div class="col-12 d-flex justify-content-lg-end gap-2 pt-2">
          <button class="btn btn-filled btn-primary btn-md" type="submit"><i class="bi bi-funnel me-1"></i> Apply</button>
          <a href="/school/reports/assignments" class="btn btn-outline-secondary btn-md">Reset</a>
        </div>
      </div>
    </form>
  </div>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div class="small text-muted">
      Matched rows: <span class="fw-bold text-dark"><%= totalMatchedRows.toLocaleString() %></span>
    </div>
    <div class="small text-muted">
      Showing page: <span class="fw-bold text-dark"><%= Number(pagination?.currentPage || 1) %> / <%= Number(pagination?.totalPages || 1) %></span>
    </div>
  </div>
</div>

<%- include('partials/tablePages-search', {
  placeholder: 'Search assignments...',
  fields: []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Assignment</th>
        <th>Class</th>
        <th>Target</th>
        <th>Task Time</th>
        <th>Scope</th>
        <th>Template</th>
        <th>Teachers</th>
        <th>Report Period</th>
        <th>Status</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || !data.length) { %>
        <tr><td colspan="10" class="text-center py-4 text-muted">No assignments found.</td></tr>
      <% } %>
      <% (data || []).forEach((row) => { %>
        <% const lifecycleCycleNo = Number(row?.classLifecycle?.cycleNo || 1) > 0 ? Number(row?.classLifecycle?.cycleNo || 1) : 1; %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-dark font-monospace"><%= row.id %></div>
            <div class="x-small text-muted"><%= row.targetType === 'date' ? 'Date Target' : 'Session Target' %></div>
            <% if (Number(row.targetRowCount || 0) > 1) { %>
              <div class="x-small mt-1"><span class="badge bg-info-subtle text-info-emphasis border"><%= row.targetRowCount %> target rows</span></div>
            <% } %>
          </td>
          <td>
            <div class="fw-bold"><%= row.classTitle %></div>
            <div class="x-small text-muted mt-1">Cycle #<%= lifecycleCycleNo %></div>
          </td>
          <td>
            <div><%= row.targetDate || row.sessionDate || '-' %></div>
            <% if (String(row.targetType || '').toLowerCase() !== 'date') { %>
              <div class="x-small text-muted font-monospace"><%= row.sessionId || '-' %></div>
            <% } %>
            <% if (row.conflictPermitted) { %>
              <div class="x-small mt-1"><span class="badge bg-warning-subtle text-warning-emphasis border">Intentional overlap permitted</span></div>
            <% } %>
          </td>
          <td><%= row.taskTimeRange || '-' %></td>
          <td>
            <% const scope = String(row.reportScope || 'class').toLowerCase(); %>
            <% if (scope === 'each_student') { %>
              <span class="badge bg-info-subtle text-info-emphasis border">Each Student</span>
            <% } else if (scope === 'selected_students') { %>
              <span class="badge bg-warning-subtle text-warning-emphasis border">Specific Students (<%= Number(row.targetStudentCount || 0) %>)</span>
            <% } else { %>
              <span class="badge bg-light text-secondary border">Whole Class</span>
            <% } %>
          </td>
          <td>
            <div class="fw-bold text-dark"><%= row.templateTitle %></div>
            <div class="x-small text-muted">v<%= Number(row.templateVersion || 1) %></div>
          </td>
          <td class="small"><%= (row.teacherIds || []).join(', ') %></td>
          <td>
            <% if (row.reportStartDate || row.reportDueDate) { %>
              <div><%= row.reportStartDate || '-' %> to <%= row.reportDueDate || '-' %></div>
            <% } else { %>
              <%= row.dueDate || '-' %>
            <% } %>
          </td>
          <td>
            <span class="badge <%= String(row.status || '') === 'active' ? 'bg-success' : 'bg-secondary' %>"><%= row.status || '-' %></span>
          </td>
          <td class="table-actions pe-4">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= row.id %>"
                title="Assignment Actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= row.id %>">
                <% if (row.classId) { %>
                  <a href="/school/classes/edit-wizard/<%= encodeURIComponent(row.classId) %>" class="btn btn-outline-info btn-sm"><i class="bi bi-diagram-3 me-2"></i>Lifecycle</a>
                <% } %>
                <a href="/school/reports/assignments/edit/<%= row.id %>" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil-square me-2"></i>Edit</a>
                <% const firstTargetRow = Array.isArray(row.targetRows) && row.targetRows.length ? row.targetRows[0] : null; %>
                <a href="/school/reports/instances/start/<%= row.id %>?teacherId=<%= encodeURIComponent((row.teacherIds || [])[0] || '') %><%= firstTargetRow?.rowId ? ('&rowId=' + encodeURIComponent(firstTargetRow.rowId)) : '' %>" class="btn btn-outline-primary btn-sm"><i class="bi bi-play-circle me-2"></i>Start</a>
                <button type="button" class="btn btn-outline-danger btn-sm js-delete-report-assignment" data-assignment-id="<%= row.id %>" data-assignment-title="<%= row.title || row.id %>"><i class="bi bi-trash me-2"></i>Delete</button>
              </div>
            </div>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="<%= newUrl %>" hidden></span>
<input type="hidden" id="hid_actionStateId" value="<%= actionStateId || '' %>">

<div class="modal fade" id="reportAssignmentDeleteBlockedModal" tabindex="-1" aria-hidden="true" style="z-index: 1105;">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold"><i class="bi bi-exclamation-triangle me-2"></i>Resolve Report Instances First</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="reportAssignmentDeleteBlockedBody">
        <div class="text-muted">Loading...</div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-danger btn-sm" id="btnRetryReportAssignmentDelete">Retry Delete Assignment</button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/pagination', { pagination, filters, baseUrlPath: newUrl }) %>
<%- include('partials/tablePages-end') %>
<%- include('partials/modal_GenericPicker') %>

<script src="/scripts/reportAssignmentDelete.js"></script>
<script>
  (function () {
    const classIdInput = document.getElementById('classIdFilterInput');
    const classIdsInput = document.getElementById('classIdsFilterInput');
    const classTitleInput = document.getElementById('classTitleFilterInput');
    const classChipContainer = document.getElementById('classFilterChips');
    const btnPickClass = document.getElementById('btnPickClassFilter');
    const btnClearClass = document.getElementById('btnClearClassFilter');
    const teacherIdInput = document.getElementById('teacherPersonIdFilterInput');
    const teacherNameInput = document.getElementById('teacherNameFilterInput');
    const btnPickTeacher = document.getElementById('btnPickTeacherFilter');
    const btnClearTeacher = document.getElementById('btnClearTeacherFilter');
    let selectedClassItems = <%- JSON.stringify(selectedClassesSafe || []) %>;

    function normalizeItemId(value) {
      return String(value || '').trim();
    }

    function escapeHtmlClient(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function formatClassName(item, fallbackId) {
      return String(item?.title || item?.name || fallbackId || '').trim();
    }

    function formatTeacherName(item, fallbackId) {
      const directName = String(item?.displayName || item?.fullName || item?.personName || item?.label || item?.title || item?.name || '').trim();
      if (directName && directName !== '[object Object]') return directName;
      const objectName = item?.name && typeof item.name === 'object'
        ? [item.name.first, item.name.middle, item.name.last].map((part) => String(part || '').trim()).filter(Boolean).join(' ')
        : '';
      if (objectName) return objectName;
      return String(fallbackId || '').trim();
    }

    function showPickerUnavailable(message) {
      if (typeof showMessageModal === 'function') {
        showMessageModal({
          title: 'Picker Unavailable',
          icon: 'warning',
          message: message || 'Picker is not available on this page.',
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
      }
    }

    function renderClassChips() {
      if (!classChipContainer) return;
      if (!selectedClassItems.length) {
        classChipContainer.innerHTML = '<div class="small text-muted">No class filter selected.</div>';
        return;
      }
      classChipContainer.innerHTML = selectedClassItems.map((item) => [
        '<span class="badge rounded-pill text-bg-light border d-inline-flex align-items-center gap-1 px-2 py-1 me-1 mb-1">',
        '<span>', escapeHtmlClient(String(item?.name || item?.id || '')), '</span>',
        '<button type="button" class="btn-close btn-close-sm ms-1" style="font-size:0.62rem;" aria-label="Remove class" data-class-chip-remove="', escapeHtmlClient(String(item?.id || '')), '"></button>',
        '</span>'
      ].join('')).join('');
    }

    function syncClassInputs() {
      const ids = selectedClassItems
        .map((item) => normalizeItemId(item?.id))
        .filter(Boolean);
      if (classIdInput) classIdInput.value = ids[0] || '';
      if (classIdsInput) classIdsInput.value = ids.join(',');
      if (classTitleInput) {
        classTitleInput.value = selectedClassItems.map((item) => String(item?.name || item?.id || '').trim()).filter(Boolean).join(', ');
      }
      renderClassChips();
    }

    btnPickClass?.addEventListener('click', function () {
      if (!window.GenericPicker || !window.GenericPickerPresets) {
        showPickerUnavailable('Class picker is not available on this page.');
        return;
      }
      GenericPicker.open(GenericPickerPresets.class({
        title: 'Filter by Classes',
        multiselect: true,
        selectedItems: selectedClassItems.map((item) => ({
          id: normalizeItemId(item?.id),
          title: String(item?.name || item?.id || '').trim()
        })),
        onSelect: function (items) {
          (Array.isArray(items) ? items : [items]).forEach((item) => {
            const id = normalizeItemId(item?.id);
            if (!id || selectedClassItems.some((existing) => normalizeItemId(existing?.id) === id)) return;
            selectedClassItems.push({
              id,
              name: formatClassName(item, id)
            });
          });
          syncClassInputs();
        }
      }));
    });

    btnClearClass?.addEventListener('click', function () {
      selectedClassItems = [];
      syncClassInputs();
    });

    classChipContainer?.addEventListener('click', function (event) {
      const button = event.target && event.target.closest('[data-class-chip-remove]');
      if (!button) return;
      const removeId = normalizeItemId(button.getAttribute('data-class-chip-remove'));
      if (!removeId) return;
      selectedClassItems = selectedClassItems.filter((item) => normalizeItemId(item?.id) !== removeId);
      syncClassInputs();
    });

    btnPickTeacher?.addEventListener('click', function () {
      if (!window.GenericPicker || !window.GenericPickerPresets) {
        showPickerUnavailable('Teacher picker is not available on this page.');
        return;
      }
      GenericPicker.open(GenericPickerPresets.teacher({
        title: 'Filter by Assigned Teacher',
        context: window.GenericPickerContexts
          ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
          : undefined,
        onSelect: function (itemOrItems) {
          const selectedItem = Array.isArray(itemOrItems) ? itemOrItems[0] : itemOrItems;
          const id = normalizeItemId(selectedItem?.personId || selectedItem?.teacherPersonId || selectedItem?.id || selectedItem?._id);
          if (!id) return;
          if (teacherIdInput) teacherIdInput.value = id;
          if (teacherNameInput) teacherNameInput.value = formatTeacherName(selectedItem, id);
        }
      }));
    });

    btnClearTeacher?.addEventListener('click', function () {
      if (teacherIdInput) teacherIdInput.value = '';
      if (teacherNameInput) teacherNameInput.value = '';
    });

    syncClassInputs();

    function initCollapseToggleIcon(options = {}) {
      const collapseEl = document.getElementById(String(options.collapseId || ''));
      const buttonEl = document.getElementById(String(options.buttonId || ''));
      const iconEl = document.getElementById(String(options.iconId || ''));
      if (!collapseEl || !buttonEl || !iconEl) return;

      const openIcon = String(options.openIcon || 'bi-chevron-down');
      const closeIcon = String(options.closeIcon || 'bi-chevron-up');
      const openLabel = String(options.openLabel || 'Open filters');
      const closeLabel = String(options.closeLabel || 'Close filters');

      const setState = (expanded) => {
        iconEl.classList.remove(openIcon, closeIcon);
        iconEl.classList.add(expanded ? closeIcon : openIcon);
        buttonEl.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        buttonEl.setAttribute('aria-label', expanded ? closeLabel : openLabel);
      };

      setState(collapseEl.classList.contains('show'));
      collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
      collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
    }

    initCollapseToggleIcon({
      collapseId: 'reportAssignmentFilterCollapse',
      buttonId: 'reportAssignmentFilterToggleBtn',
      iconId: 'reportAssignmentFilterToggleIcon',
      openIcon: 'bi-chevron-down',
      closeIcon: 'bi-chevron-up',
      openLabel: 'Open filters',
      closeLabel: 'Close filters'
    });

    const blockedModalEl = document.getElementById('reportAssignmentDeleteBlockedModal');
    const blockedModalBody = document.getElementById('reportAssignmentDeleteBlockedBody');
    const retryDeleteBtn = document.getElementById('btnRetryReportAssignmentDelete');
    let blockedModalInstance = null;
    let activeAssignmentDeleteId = '';

    function cleanupModalLayerArtifacts() {
      if (typeof window.hideLoading === 'function') {
        window.hideLoading({ force: true });
      }
      const openModals = document.querySelectorAll('.modal.show');
      if (!openModals.length) {
        document.querySelectorAll('.modal-backdrop').forEach((backdrop) => backdrop.remove());
        document.body.classList.remove('modal-open');
        document.body.style.removeProperty('overflow');
        document.body.style.removeProperty('padding-right');
      }
    }

    function getBlockedModal() {
      if (!blockedModalEl || !window.bootstrap || typeof window.bootstrap.Modal !== 'function') return null;
      if (blockedModalEl.parentElement !== document.body) {
        document.body.appendChild(blockedModalEl);
      }
      if (!blockedModalInstance) {
        blockedModalInstance = window.bootstrap.Modal.getOrCreateInstance(blockedModalEl, {
          backdrop: true,
          keyboard: true,
          focus: true
        });
      }
      return blockedModalInstance;
    }

    function openBlockedModal() {
      cleanupModalLayerArtifacts();
      const modal = getBlockedModal();
      if (!modal) return;
      modal.show();
    }

    if (blockedModalEl) {
      blockedModalEl.addEventListener('shown.bs.modal', function () {
        const backdrops = document.querySelectorAll('.modal-backdrop');
        const backdrop = backdrops[backdrops.length - 1];
        if (backdrop) backdrop.style.zIndex = '1100';
        cleanupModalLayerArtifacts();
        const loadingEl = document.getElementById('globalLoadingModal');
        if (loadingEl && loadingEl.classList.contains('is-visible')) {
          loadingEl.classList.remove('is-visible');
          loadingEl.setAttribute('aria-hidden', 'true');
        }
      });
      blockedModalEl.addEventListener('hidden.bs.modal', function () {
        cleanupModalLayerArtifacts();
      });
    }

    function renderBlockedModal(preview) {
      if (!blockedModalBody || !window.ReportAssignmentDelete) return;
      const assignment = preview.assignment || {};
      const instancesHtml = window.ReportAssignmentDelete.renderInstancesTable(preview.instances || [], { bindDelete: true });
      const blockersHtml = window.ReportAssignmentDelete.renderBlockersList(preview.timesheetBlockers || preview.blockers || []);
      blockedModalBody.innerHTML = `
        <p class="mb-3">Cannot delete <strong>${window.ReportAssignmentDelete.escapeHtml(assignment.title || assignment.id || 'this assignment')}</strong> yet.</p>
        <p class="small text-muted">Delete all started report instances below before removing this assignment. Locked instances must be unlocked or deleted first. Assignment admins can unlock locked instances when needed.</p>
        ${blockersHtml}
        <div class="fw-bold mb-2">Report Instances</div>
        ${instancesHtml}
      `;
    }

    async function runAssignmentDeleteFlow(assignmentId) {
      if (!window.ReportAssignmentDelete) return;
      const id = String(assignmentId || '').trim();
      if (!id) return;
      activeAssignmentDeleteId = id;
      const preview = await window.ReportAssignmentDelete.withLoading('Checking assignment references...', function () {
        return window.ReportAssignmentDelete.fetchAssignmentDeletePreview(id);
      });
      if (preview.canDelete) {
        const title = String(preview.assignment?.title || id).trim();
        const confirmed = await window.ReportAssignmentDelete.confirmDelete(
          'Delete report assignment "' + title + '"? This cannot be undone.'
        );
        if (!confirmed) return;
        await window.ReportAssignmentDelete.withLoading('Deleting assignment...', function () {
          return window.ReportAssignmentDelete.deleteReportAssignment(id);
        });
        window.location.reload();
        return;
      }
      renderBlockedModal(preview);
      openBlockedModal();
    }

    document.addEventListener('click', function (event) {
      const deleteAssignmentBtn = event.target.closest('.js-delete-report-assignment');
      if (deleteAssignmentBtn) {
        event.preventDefault();
        event.stopPropagation();
        const assignmentId = String(deleteAssignmentBtn.getAttribute('data-assignment-id') || '').trim();
        runAssignmentDeleteFlow(assignmentId).catch(function (error) {
          window.ReportAssignmentDelete?.showError(error.message || 'Unable to delete assignment.');
        });
        return;
      }

      const unlockInstanceBtn = event.target.closest('[data-report-instance-unlock]');
      if (unlockInstanceBtn && activeAssignmentDeleteId && window.ReportAssignmentDelete) {
        event.preventDefault();
        event.stopPropagation();
        const instanceId = String(unlockInstanceBtn.getAttribute('data-instance-id') || '').trim();
        if (!instanceId) return;
        window.ReportAssignmentDelete.confirmUnlock('Unlock this report instance? It will become editable again.')
          .then(function (confirmed) {
            if (!confirmed) return null;
            return window.ReportAssignmentDelete.withLoading('Unlocking report instance...', function () {
              return window.ReportAssignmentDelete.unlockReportInstance(instanceId);
            });
          })
          .then(function (result) {
            if (!result) return null;
            return window.ReportAssignmentDelete.fetchAssignmentDeletePreview(activeAssignmentDeleteId);
          })
          .then(function (preview) {
            if (!preview) return;
            if (preview.canDelete) {
              const modal = getBlockedModal();
              if (modal) modal.hide();
              return runAssignmentDeleteFlow(activeAssignmentDeleteId);
            }
            renderBlockedModal(preview);
          })
          .catch(function (error) {
            window.ReportAssignmentDelete.showError(error.message || 'Unable to unlock report instance.');
          });
        return;
      }

      const deleteInstanceBtn = event.target.closest('[data-report-instance-delete]');
      if (deleteInstanceBtn && activeAssignmentDeleteId && window.ReportAssignmentDelete) {
        event.preventDefault();
        event.stopPropagation();
        const instanceId = String(deleteInstanceBtn.getAttribute('data-instance-id') || '').trim();
        if (!instanceId) return;
        window.ReportAssignmentDelete.confirmDelete('Delete this report instance? This cannot be undone.')
          .then(function (confirmed) {
            if (!confirmed) return null;
            return window.ReportAssignmentDelete.withLoading('Deleting report instance...', function () {
              return window.ReportAssignmentDelete.deleteReportInstance(instanceId);
            });
          })
          .then(function (result) {
            if (!result) return null;
            const row = deleteInstanceBtn.closest('[data-instance-row-id]');
            if (row) row.remove();
            return window.ReportAssignmentDelete.fetchAssignmentDeletePreview(activeAssignmentDeleteId);
          })
          .then(function (preview) {
            if (!preview) return;
            if (preview.canDelete) {
              const modal = getBlockedModal();
              if (modal) modal.hide();
              return runAssignmentDeleteFlow(activeAssignmentDeleteId);
            }
            renderBlockedModal(preview);
          })
          .catch(function (error) {
            window.ReportAssignmentDelete.showError(error.message || 'Unable to delete report instance.');
          });
      }
    });

    retryDeleteBtn?.addEventListener('click', function () {
      if (!activeAssignmentDeleteId) return;
      runAssignmentDeleteFlow(activeAssignmentDeleteId).catch(function (error) {
        window.ReportAssignmentDelete?.showError(error.message || 'Unable to delete assignment.');
      });
    });
  })();
</script>
