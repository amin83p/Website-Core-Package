<%
  const sharedFields = Array.isArray(matrix?.sharedFields) ? matrix.sharedFields : [];
  const commonFields = Array.isArray(matrix?.commonFields) ? matrix.commonFields : [];
  const tableFields = Array.isArray(matrix?.tableFields) ? matrix.tableFields : [];
  const rows = Array.isArray(matrix?.rows) ? matrix.rows : [];
  const progress = matrix?.progress || { total: rows.length, submitted: 0, drafts: 0, pending: rows.length };
  const fallbackSharedFields = sharedFields;
  const sharedGroups = Array.isArray(matrix?.sharedGroups) && matrix.sharedGroups.length
    ? matrix.sharedGroups
    : (fallbackSharedFields.length ? [{ id: 'shared-default', label: 'Shared fields', fields: fallbackSharedFields }] : []);
  const hasEditableRows = rows.some((row) => !row.locked);
  const statusBadgeClass = (status) => {
    const token = String(status || '').toLowerCase();
    if (token === 'submitted') return 'bg-success';
    if (token === 'locked') return 'bg-dark';
    if (token === 'draft') return 'bg-warning text-dark';
    return 'bg-info-subtle text-info-emphasis border';
  };
%>
<style>
  .report-matrix-page .matrix-summary-card { min-width: 115px; }
  .report-matrix-page .matrix-table-wrap { max-height: calc(100vh - 250px); overflow: auto; }
  .report-matrix-page .matrix-table { width: max-content; min-width: 100%; }
  .report-matrix-page .matrix-table th { position: sticky; top: 0; z-index: 4; min-width: 110px; width: 130px; max-width: 160px; vertical-align: middle; }
  .report-matrix-page .matrix-header-label { display: inline-block; white-space: normal; overflow-wrap: anywhere; line-height: 1.15; }
  .report-matrix-page .matrix-table th.matrix-student-col,
  .report-matrix-page .matrix-table td.matrix-student-col {
    position: sticky;
    left: 0;
    min-width: 230px;
    max-width: 280px;
    z-index: 3;
    background: var(--bs-body-bg);
    box-shadow: 3px 0 5px rgba(0, 0, 0, 0.06);
  }
  .report-matrix-page .matrix-table th.matrix-student-col { z-index: 6; background: var(--bs-light); }
  .report-matrix-page .matrix-table textarea { min-width: 180px; width: 100%; resize: vertical; }
  .report-matrix-page .matrix-table input[type="text"],
  .report-matrix-page .matrix-table input[type="number"],
  .report-matrix-page .matrix-table input[type="date"],
  .report-matrix-page .matrix-table select { min-width: 130px; width: 100%; }
  .report-matrix-page .matrix-help-icon { border: 0; background: transparent; color: var(--bs-secondary-color); padding: 0 .2rem; }
  .report-matrix-page .matrix-help-icon:hover,
  .report-matrix-page .matrix-help-icon:focus-visible { color: var(--bs-primary); }
  .report-matrix-page .matrix-row-dirty .matrix-student-name::after { content: " • Unsaved"; color: var(--bs-warning-text-emphasis); font-size: .75rem; }
</style>

<div class="sections-page report-matrix-page">
  <input type="hidden" name="actionStateId" id="reportMatrixActionStateId" value="<%= actionStateId || '' %>">
  <script type="application/json" id="reportMatrixData"><%- JSON.stringify(matrix || {}).replace(/</g, '\\u003c') %></script>

  <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
    <div>
      <h1 class="page-heading size-md m-0 text-start" style="padding-left:0;">Fill Reports</h1>
      <h5 class="fw-bold text-primary mt-2 mb-1"><%= matrix.templateTitle %></h5>
      <div class="text-muted small">
        <strong><%= matrix.className || matrix.classId %></strong>
        <span class="mx-1">|</span>
        Session <strong><%= matrix.sessionDate || '-' %></strong>
        <span class="mx-1">|</span>
        Teacher <strong><%= matrix.teacherName || matrix.teacherId %></strong>
      </div>
      <div class="text-muted small mt-1">Report period: <strong><%= matrix.reportStartDate || '-' %></strong> to <strong><%= matrix.reportDueDate || '-' %></strong></div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4" id="reportMatrixNavigation">
    <div class="card-body py-2">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <% if (matrix.classId && matrix.sessionId) { %>
          <a href="/school/classes/<%= encodeURIComponent(matrix.classId) %>/sessions/<%= encodeURIComponent(matrix.sessionId) %>" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Session</a>
        <% } %>
        <a href="/school/reports/instances" class="btn btn-outline-primary btn-sm"><i class="bi bi-list-check me-1"></i>Instances</a>
        <button type="button" class="btn btn-outline-warning btn-sm" id="btnMatrixPrefillPreview"><i class="bi bi-arrow-repeat me-1"></i>Preview Prefill Updates</button>
        <a href="/school/reports/instances/matrix/<%= encodeURIComponent(matrix.assignmentId) %>/export?format=docx" class="btn btn-outline-secondary btn-sm"><i class="bi bi-file-earmark-word me-1"></i>Export DOCX</a>
        <a href="/school/reports/instances/matrix/<%= encodeURIComponent(matrix.assignmentId) %>/export?format=json&download=1" class="btn btn-outline-secondary btn-sm"><i class="bi bi-download me-1"></i>Export Payload</a>
      </div>
    </div>
  </div>

  <div class="d-flex flex-wrap gap-2 mb-4">
    <div class="card border-0 shadow-sm matrix-summary-card"><div class="card-body py-2"><div class="small text-muted">Students</div><div class="fs-5 fw-bold" data-progress-key="total"><%= progress.total %></div></div></div>
    <div class="card border-0 shadow-sm matrix-summary-card"><div class="card-body py-2"><div class="small text-muted">Submitted</div><div class="fs-5 fw-bold text-success" data-progress-key="submitted"><%= progress.submitted %></div></div></div>
    <div class="card border-0 shadow-sm matrix-summary-card"><div class="card-body py-2"><div class="small text-muted">Drafts</div><div class="fs-5 fw-bold text-warning" data-progress-key="drafts"><%= progress.drafts %></div></div></div>
    <div class="card border-0 shadow-sm matrix-summary-card"><div class="card-body py-2"><div class="small text-muted">Not started</div><div class="fs-5 fw-bold text-info" data-progress-key="pending"><%= progress.pending %></div></div></div>
  </div>

  <% if (commonFields.length) { %>
    <div class="card border-0 shadow-sm mb-4" id="reportMatrixCommonFields">
      <div class="card-header bg-white py-3"><h5 class="m-0 fw-bold"><i class="bi bi-info-circle me-2 text-primary"></i>Common report values</h5><div class="small text-muted mt-1">These read-only values apply to every student.</div></div>
      <div class="card-body"><div class="row g-3">
        <% commonFields.forEach((field) => { const value = field.value === undefined || field.value === null ? '' : field.value; const col = field.fullPageWidth ? 'col-12' : 'col-12 col-md-6 col-xl-4'; %>
          <div class="<%= col %>"><label class="form-label fw-bold"><%= field.label %> <span class="badge bg-light text-secondary border ms-1">View only</span></label>
            <% if (field.type === 'textarea') { %><textarea class="form-control" rows="3" data-field-id="<%= field.id %>" readonly><%= value %></textarea>
            <% } else { %><input type="<%= field.type === 'number' || field.type === 'date' ? field.type : 'text' %>" class="form-control" data-field-id="<%= field.id %>" value="<%= value %>" readonly><% } %>
          </div>
        <% }); %>
      </div></div>
    </div>
  <% } %>
  <% if (sharedGroups.length) { %>
    <div class="card border-0 shadow-sm mb-4" id="reportMatrixSharedFields">
      <div class="card-header bg-white py-3"><h5 class="m-0 fw-bold"><i class="bi bi-people me-2 text-primary"></i>Shared report fields</h5><div class="small text-muted mt-1">Editable values are saved once and used by every student report.</div></div>
      <div class="card-body">
        <% if (sharedFields.some((field) => field.hasConflictingInitialValues)) { %><div class="alert alert-warning small">One or more shared fields have different initial values. Choose the common value explicitly.</div><% } %>
        <div class="accordion" id="reportMatrixSharedSections">
          <% sharedGroups.forEach((group, groupIndex) => { const collapseId = 'reportMatrixSharedGroup' + groupIndex; %>
            <div class="accordion-item"><h2 class="accordion-header" id="<%= collapseId %>Heading"><button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#<%= collapseId %>" aria-expanded="true"><%= group.label %> <span class="badge bg-info-subtle text-info-emphasis border ms-2"><%= group.fields.length %> field(s)</span></button></h2>
              <div id="<%= collapseId %>" class="accordion-collapse collapse show"><div class="accordion-body"><div class="row g-3">
                <% (group.fields || []).forEach((field) => { const value = field.value === undefined || field.value === null ? '' : field.value; const col = field.fullPageWidth ? 'col-12' : 'col-12 col-md-6 col-xl-4'; %>
                  <div class="<%= col %>"><label class="form-label fw-bold"><%= field.label %> <span class="badge bg-info-subtle text-info-emphasis border ms-1">Shared</span></label>
                    <% if (field.type === 'textarea') { %><textarea class="form-control js-matrix-shared-field" rows="3" data-field-id="<%= field.id %>"><%= value %></textarea>
                    <% } else if (field.type === 'select') { %><select class="form-select js-matrix-shared-field" data-field-id="<%= field.id %>"><option value="">Select...</option><% (field.options || []).forEach((option) => { %><option value="<%= option.value %>" <%= String(value) === String(option.value) ? 'selected' : '' %>><%= option.label %></option><% }); %></select>
                    <% } else { %><input type="<%= field.type === 'number' || field.type === 'date' ? field.type : 'text' %>" class="form-control js-matrix-shared-field" data-field-id="<%= field.id %>" value="<%= value %>"><% } %>
                  </div>
                <% }); %>
              </div></div></div>
            </div>
          <% }); %>
        </div>
      </div>
    </div>
  <% } %>

  <div class="card border-0 shadow-sm" id="reportMatrixStudentReports">
    <div class="card-header bg-white py-3 d-flex flex-wrap justify-content-between align-items-center gap-2">
      <div>
        <h5 class="m-0 fw-bold"><i class="bi bi-table me-2 text-primary"></i>Student reports</h5>
        <div class="small text-muted mt-1">Use the actions above to save or submit all editable student reports. Scroll horizontally to see every report field.</div>
      </div>
      <span class="badge bg-light text-dark border"><%= tableFields.length %> student-specific field(s)</span>
    </div>
    <div class="matrix-table-wrap">
      <table class="table table-bordered table-hover align-middle mb-0 matrix-table" id="reportMatrixTable">
        <thead class="table-light">
          <tr>
            <th class="matrix-student-col ps-3">Student</th>
            <% tableFields.forEach((field) => { %>
              <th>
                <span class="matrix-header-label"><%= field.label %></span>
                <% if (field.helpText) { %><button type="button" class="matrix-help-icon" data-bs-toggle="tooltip" title="<%= field.helpText %>" aria-label="Information for <%= field.label %>"><i class="bi bi-info-circle"></i></button><% } %>
                <% if (field.required) { %><span class="text-danger" title="Required" aria-label="Required">*</span><% } %>
                <% if (field.readOnly) { %><span class="badge bg-light text-secondary border d-block mt-1" style="width:max-content;">View only<%= field.calculated ? ' / calculated' : '' %></span><% } %>
              </th>
            <% }); %>
          </tr>
        </thead>
        <tbody>
          <% rows.forEach((row) => { %>
            <tr data-student-id="<%= row.studentId %>" class="<%= row.locked ? 'table-secondary' : '' %>">
              <td class="matrix-student-col ps-3">
                <div class="fw-bold matrix-student-name"><%= row.studentName %></div>
                <div class="mt-2 d-flex flex-wrap align-items-center gap-2">
                  <span class="badge text-capitalize js-matrix-status <%= statusBadgeClass(row.status) %>"><%= row.status %></span>
                  <a href="<%= row.editHref || '#' %>" class="btn btn-sm btn-outline-secondary js-matrix-open <%= row.editHref ? '' : 'd-none' %>" target="_blank" rel="noopener noreferrer" title="Open individual report"><i class="bi bi-box-arrow-up-right me-1"></i>Open</a>
                </div>
              </td>
              <% tableFields.forEach((field) => { %>
                <% const value = row.answers?.[field.id] === undefined || row.answers?.[field.id] === null ? '' : row.answers[field.id]; %>
                <% const disabled = row.locked || field.readOnly; %>
                <td data-matrix-cell="<%= field.id %>">
                  <% if (field.type === 'textarea') { %>
                    <textarea class="form-control form-control-sm js-matrix-row-field" rows="3" data-field-id="<%= field.id %>" placeholder="<%= field.placeholder || '' %>" <%= disabled ? 'readonly' : '' %>><%= value %></textarea>
                  <% } else if (field.type === 'select') { %>
                    <select class="form-select form-select-sm js-matrix-row-field" data-field-id="<%= field.id %>" <%= disabled ? 'disabled' : '' %>>
                      <option value="">Select...</option>
                      <% field.options.forEach((option) => { %><option value="<%= option.value %>" <%= String(value) === String(option.value) ? 'selected' : '' %>><%= option.label %></option><% }); %>
                    </select>
                  <% } else if (field.type === 'checkbox') { %>
                    <div class="form-check d-flex justify-content-center">
                      <input type="checkbox" class="form-check-input js-matrix-row-field" data-field-id="<%= field.id %>" <%= value === true || String(value).toLowerCase() === 'true' ? 'checked' : '' %> <%= disabled ? 'disabled' : '' %>>
                    </div>
                  <% } else { %>
                    <input type="<%= field.type === 'number' || field.type === 'date' ? field.type : 'text' %>" class="form-control form-control-sm js-matrix-row-field" data-field-id="<%= field.id %>" value="<%= value %>" placeholder="<%= field.placeholder || '' %>" <%= disabled ? 'readonly' : '' %>>
                  <% } %>
                </td>
              <% }); %>

            </tr>
          <% }); %>
          <% if (!rows.length) { %><tr><td colspan="<%= tableFields.length + 1 %>" class="text-center text-muted py-5">No students are targeted by this assignment.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="card border-0 shadow-sm mt-4" id="reportMatrixActions">
    <div class="card-body py-2">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <button type="button" class="btn btn-primary btn-sm js-matrix-bulk-action" data-action="save" <%= hasEditableRows ? '' : 'disabled' %>><i class="bi bi-save me-1"></i>Save All Drafts</button>
        <button type="button" class="btn btn-success btn-sm js-matrix-bulk-action" data-action="submit" <%= hasEditableRows ? '' : 'disabled' %>><i class="bi bi-send-check me-1"></i>Submit All Reports</button>
        <button type="button" class="btn btn-outline-dark btn-sm js-matrix-bulk-action" data-action="lock" <%= hasEditableRows ? '' : 'disabled' %>><i class="bi bi-lock me-1"></i>Lock All Reports</button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="reportMatrixPrefillModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable"><div class="modal-content">
    <div class="modal-header"><h5 class="modal-title"><i class="bi bi-arrow-repeat me-2"></i>Preview Prefill Updates</h5><button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button></div>
    <div class="modal-body"><div id="reportMatrixPrefillSummary" class="small text-muted mb-3">Loading...</div><div id="reportMatrixPrefillRows"></div></div>
    <div class="modal-footer"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><button type="button" class="btn btn-primary" id="btnApplyMatrixPrefill" disabled>Apply Selected Updates</button></div>
  </div></div>
</div>

<%- include('partials/calculatedFieldsRuntime') %>
<script>
  (function () {
    const dataEl = document.getElementById('reportMatrixData');
    let matrixState = JSON.parse(dataEl?.textContent || '{}');
    const dirtyStudents = new Set();
    let sharedDirty = false;

    function initializeTooltips() {
      if (typeof bootstrap === 'undefined' || !bootstrap?.Tooltip) return;
      document.querySelectorAll('.report-matrix-page [data-bs-toggle="tooltip"]').forEach((el) => {
        if (!bootstrap.Tooltip.getInstance(el)) new bootstrap.Tooltip(el);
      });
    }

    function showReportMatrixMessage({ title = 'Fill Reports', icon = 'info', message = '' } = {}) {
      if (typeof showMessageModal === 'function') {
        return showMessageModal({
          title,
          icon,
          message,
          buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : 'btn-primary' }]
        });
      }
      window.alert(String(message || title || 'Fill Reports'));
      return Promise.resolve();
    }

    function readControl(control) {
      if (!control) return '';
      if (control.type === 'checkbox') return control.checked;
      if (control.type === 'number') {
        if (control.value === '') return '';
        const value = Number(control.value);
        return Number.isFinite(value) ? value : control.value;
      }
      return control.value;
    }

    function writeControl(control, value) {
      if (!control) return;
      if (control.type === 'checkbox') control.checked = value === true || String(value).toLowerCase() === 'true';
      else control.value = value === undefined || value === null ? '' : String(value);
    }

    function collectControls(container, selector) {
      const out = {};
      container.querySelectorAll(selector).forEach((control) => {
        const fieldId = String(control.dataset.fieldId || '').trim();
        if (fieldId) out[fieldId] = readControl(control);
      });
      return out;
    }

    function allMatrixFields() {
      return [
        ...(matrixState.sharedFields || []),
        ...(matrixState.commonFields || []),
        ...(matrixState.tableFields || [])
      ];
    }

    function recalculateRow(row) {
      if (!row || !window.SchoolReportCalculatedFields?.recomputeCalculatedAnswers) return;
      const studentId = String(row.dataset.studentId || '');
      const rowState = (matrixState.rows || []).find((item) => String(item.studentId || '') === studentId);
      if (!rowState) return;
      const answers = {
        ...(rowState.answers || {}),
        ...collectControls(document, '#reportMatrixCommonFields [data-field-id]'),
        ...collectControls(document, '.js-matrix-shared-field'),
        ...collectControls(row, '.js-matrix-row-field')
      };
      const result = window.SchoolReportCalculatedFields.recomputeCalculatedAnswers({
        fields: allMatrixFields(),
        answers,
        prefill: rowState.calculationPrefill || {}
      });
      rowState.answers = result.answers;
      (matrixState.tableFields || []).filter((field) => field.calculated).forEach((field) => {
        const selector = `.js-matrix-row-field[data-field-id="${CSS.escape(field.id)}"]`;
        writeControl(row.querySelector(selector), result.answers[field.id]);
      });
    }

    function recalculateAllRows() {
      document.querySelectorAll('tr[data-student-id]').forEach(recalculateRow);
    }

    function badgeClass(status) {
      const token = String(status || '').toLowerCase();
      if (token === 'submitted') return 'badge text-capitalize js-matrix-status bg-success';
      if (token === 'locked') return 'badge text-capitalize js-matrix-status bg-dark';
      if (token === 'draft') return 'badge text-capitalize js-matrix-status bg-warning text-dark';
      return 'badge text-capitalize js-matrix-status bg-info-subtle text-info-emphasis border';
    }

    function applyMatrixState(nextMatrix, savedStudentId, options = {}) {
      const preserveStudentIds = options.preserveStudentIds instanceof Set ? options.preserveStudentIds : new Set();
      const preserveShared = options.preserveShared === true;
      if (!nextMatrix || typeof nextMatrix !== 'object') return;
      matrixState = nextMatrix;
      if (!preserveShared) {
        (nextMatrix.sharedFields || []).forEach((field) => {
          writeControl(document.querySelector(`.js-matrix-shared-field[data-field-id="${CSS.escape(field.id)}"]`), field.value);
        });
      }
      (nextMatrix.commonFields || []).forEach((field) => {
        writeControl(document.querySelector(`[data-field-id="${CSS.escape(field.id)}"]:not(.js-matrix-row-field)`), field.value);
      });
      const fieldMap = new Map((nextMatrix.tableFields || []).map((field) => [String(field.id), field]));
      (nextMatrix.rows || []).forEach((rowState) => {
        const row = document.querySelector(`tr[data-student-id="${CSS.escape(String(rowState.studentId))}"]`);
        if (!row) return;
        row.querySelectorAll('.js-matrix-row-field').forEach((control) => {
          const field = fieldMap.get(String(control.dataset.fieldId || ''));
          if (!field) return;
          const rowId = String(rowState.studentId);
          if (!preserveStudentIds.has(rowId) && (savedStudentId === undefined || savedStudentId === null || rowId === String(savedStudentId) || field.readOnly || field.calculated)) {
            writeControl(control, rowState.answers?.[field.id]);
          }
        });
        const status = row.querySelector('.js-matrix-status');
        if (status) {
          status.className = badgeClass(rowState.status);
          status.textContent = rowState.status;
        }
        const openLink = row.querySelector('.js-matrix-open');
        if (openLink && rowState.editHref) {
          openLink.href = rowState.editHref;
          openLink.classList.remove('d-none');
        }
        row.classList.toggle('table-secondary', Boolean(rowState.locked));
      });
      Object.entries(nextMatrix.progress || {}).forEach(([key, value]) => {
        const target = document.querySelector(`[data-progress-key="${CSS.escape(key)}"]`);
        if (target) target.textContent = String(value);
      });
    }

    async function runBulkAction(button) {
      const requestedAction = String(button?.dataset.action || 'save').toLowerCase();
      const submitAction = ['save', 'submit', 'lock'].includes(requestedAction) ? requestedAction : 'save';
      const rowStates = new Map((matrixState.rows || []).map((row) => [String(row.studentId), row]));
      const editableRows = Array.from(document.querySelectorAll('tr[data-student-id]')).filter((row) => {
        const state = rowStates.get(String(row.dataset.studentId || ''));
        return state ? !state.locked : !row.classList.contains('table-secondary');
      });
      if (!editableRows.length) {
        await showReportMatrixMessage({
          title: 'No Editable Reports',
          icon: 'info',
          message: 'There are no editable student reports to process.'
        });
        return;
      }
      const actionButtons = Array.from(document.querySelectorAll('.js-matrix-bulk-action'));
      actionButtons.forEach((item) => { item.disabled = true; });
      const loadingToken = typeof window.showLoading === 'function'
        ? window.showLoading(submitAction === 'submit'
          ? 'Submitting student reports...'
          : (submitAction === 'lock' ? 'Locking student reports...' : 'Saving student reports...'))
        : null;
      let feedback;
      try {
        const response = await fetch('/school/reports/instances/matrix/' + encodeURIComponent(matrixState.assignmentId) + '/save-all', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json',
            'x-ajax-request': 'true',
            'x-action-state-id': String(document.getElementById('reportMatrixActionStateId')?.value || '')
          },
          body: JSON.stringify({
            assignmentRowId: matrixState.assignmentRowId,
            teacherId: matrixState.teacherId,
            submitAction,
            rows: editableRows.map((row) => ({
              studentId: String(row.dataset.studentId || ''),
              answers: collectControls(row, '.js-matrix-row-field')
            })),
            sharedAnswers: collectControls(document, '.js-matrix-shared-field'),
            actionStateId: String(document.getElementById('reportMatrixActionStateId')?.value || '')
          })
        });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !['success', 'partial'].includes(result.status)) {
          throw new Error(result.message || 'Unable to process the report matrix.');
        }
        const unsuccessfulIds = new Set((result.results || [])
          .filter((item) => item.status !== 'success')
          .map((item) => String(item.studentId || '')));
        applyMatrixState(result.matrix, null, { preserveStudentIds: unsuccessfulIds, preserveShared: unsuccessfulIds.size > 0 });
        dirtyStudents.clear();
        document.querySelectorAll('tr[data-student-id]').forEach((row) => row.classList.remove('matrix-row-dirty'));
        unsuccessfulIds.forEach((studentId) => {
          dirtyStudents.add(studentId);
          document.querySelector('tr[data-student-id="' + CSS.escape(studentId) + '"]')?.classList.add('matrix-row-dirty');
        });
        sharedDirty = unsuccessfulIds.size > 0;
        const detail = (result.results || [])
          .filter((item) => item.status === 'error' && item.message)
          .slice(0, 3)
          .map((item) => String(item.studentId || '') + ': ' + item.message)
          .join(' | ');
        const message = [result.message || 'Report matrix processed.', detail].filter(Boolean).join(' ');
        feedback = {
          title: submitAction === 'submit' ? 'Reports Submitted' : (submitAction === 'lock' ? 'Reports Locked' : 'Reports Saved'),
          icon: result.status === 'partial' ? 'warning' : 'success',
          message
        };
      } catch (error) {
        feedback = {
          title: submitAction === 'submit'
            ? 'Unable to Submit Reports'
            : (submitAction === 'lock' ? 'Unable to Lock Reports' : 'Unable to Save Reports'),
          icon: 'error',
          message: error.message
        };
      } finally {
        const hasEditable = (matrixState.rows || []).some((row) => !row.locked);
        actionButtons.forEach((item) => { item.disabled = !hasEditable; });
        if (typeof window.hideLoading === 'function') window.hideLoading(loadingToken || { force: true });
      }
      await showReportMatrixMessage(feedback);
    }

    const prefillModal = document.getElementById('reportMatrixPrefillModal');
    const prefillRowsEl = document.getElementById('reportMatrixPrefillRows');
    const prefillSummaryEl = document.getElementById('reportMatrixPrefillSummary');
    const applyPrefillButton = document.getElementById('btnApplyMatrixPrefill');
    function escapeHtml(value) { return String(value ?? '').replace(/[&<>"']/g, (char) => ({ '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;' }[char])); }
    function updatePrefillApplyState() { if (applyPrefillButton) applyPrefillButton.disabled = !prefillRowsEl?.querySelector('.js-matrix-prefill-key:checked'); }
    function renderPrefillPreview(result) {
      const students = Array.isArray(result?.students) ? result.students : [];
      if (prefillSummaryEl) prefillSummaryEl.textContent = students.length ? (String(result.summary?.changed || 0) + ' student(s) have updates. Select individual prefill keys to apply.') : 'No student rows were found.';
      if (!prefillRowsEl) return;
      prefillRowsEl.innerHTML = students.map((student) => {
        const disabled = student.locked || student.pending || !student.changes?.length;
        const status = student.pending ? 'pending (no stored snapshot)' : (student.locked ? 'locked' : student.status);
        const changes = (student.changes || []).map((change) => '<label class="d-flex gap-2 align-items-start border rounded p-2 mb-2"><input type="checkbox" class="form-check-input js-matrix-prefill-key mt-1" data-student-id="' + escapeHtml(student.studentId) + '" data-prefill-key="' + escapeHtml(change.prefillKey) + '" ' + (disabled ? 'disabled' : '') + '><span><strong>' + escapeHtml(change.prefillKey) + '</strong><br><span class="small text-muted">' + (change.fields || []).map((field) => escapeHtml(field.label) + ': ' + escapeHtml(field.currentValue) + ' ? ' + escapeHtml(field.newValue)).join('<br>') + '</span></span></label>').join('');
        return '<div class="card mb-3"><div class="card-header py-2 d-flex justify-content-between"><strong>' + escapeHtml(student.studentName || student.studentId) + '</strong><span class="badge bg-light text-secondary border">' + escapeHtml(status) + '</span></div><div class="card-body py-2">' + (changes || '<span class="small text-muted">No applicable updates.</span>') + '</div></div>';
      }).join('');
      prefillRowsEl.querySelectorAll('.js-matrix-prefill-key').forEach((item) => item.addEventListener('change', updatePrefillApplyState));
      updatePrefillApplyState();
    }
    async function loadPrefillPreview() {
      if (prefillSummaryEl) prefillSummaryEl.textContent = 'Loading prefill updates...';
      if (prefillRowsEl) prefillRowsEl.innerHTML = '';
      if (typeof bootstrap !== 'undefined' && prefillModal) bootstrap.Modal.getOrCreateInstance(prefillModal).show();
      try {
        const response = await fetch('/school/reports/instances/matrix/' + encodeURIComponent(matrixState.assignmentId) + '/prefill-preview?assignmentRowId=' + encodeURIComponent(matrixState.assignmentRowId || '') + '&teacherId=' + encodeURIComponent(matrixState.teacherId || ''), { headers: { Accept: 'application/json', 'x-ajax-request': 'true' } });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || result.status !== 'success') throw new Error(result.message || 'Unable to preview prefill updates.');
        renderPrefillPreview(result);
      } catch (error) { if (prefillSummaryEl) prefillSummaryEl.textContent = error.message; }
    }
    async function applyPrefillUpdates() {
      const updates = {};
      prefillRowsEl?.querySelectorAll('.js-matrix-prefill-key:checked').forEach((item) => { const id = String(item.dataset.studentId || ''); (updates[id] ||= []).push(item.dataset.prefillKey); });
      const body = { assignmentRowId: matrixState.assignmentRowId, teacherId: matrixState.teacherId, updates: Object.entries(updates).map(([studentId, prefillKeys]) => ({ studentId, prefillKeys })), actionStateId: String(document.getElementById('reportMatrixActionStateId')?.value || '') };
      applyPrefillButton.disabled = true;
      try {
        const response = await fetch('/school/reports/instances/matrix/' + encodeURIComponent(matrixState.assignmentId) + '/prefill-apply', { method: 'POST', headers: { 'Content-Type': 'application/json', Accept: 'application/json', 'x-ajax-request': 'true', 'x-action-state-id': body.actionStateId }, body: JSON.stringify(body) });
        const result = await response.json().catch(() => ({}));
        if (!response.ok || !['success','partial'].includes(result.status)) throw new Error(result.message || 'Unable to apply prefill updates.');
        if (typeof bootstrap !== 'undefined' && prefillModal) bootstrap.Modal.getOrCreateInstance(prefillModal).hide();
        if (result.matrix) applyMatrixState(result.matrix, null);
        await showReportMatrixMessage({
          title: 'Prefill Updates Applied',
          icon: result.status === 'partial' ? 'warning' : 'success',
          message: result.message || 'Prefill updates applied.'
        });
        if (!result.matrix) window.location.reload();
      } catch (error) {
        await showReportMatrixMessage({ title: 'Unable to Apply Prefill Updates', icon: 'error', message: error.message });
        applyPrefillButton.disabled = false;
      }
    }
    document.getElementById('btnMatrixPrefillPreview')?.addEventListener('click', loadPrefillPreview);
    applyPrefillButton?.addEventListener('click', applyPrefillUpdates);

    document.querySelectorAll('.js-matrix-row-field').forEach((control) => {
      control.addEventListener('change', () => {
        const row = control.closest('tr[data-student-id]');
        if (!row) return;
        recalculateRow(row);
        dirtyStudents.add(String(row.dataset.studentId || ''));
        row.classList.add('matrix-row-dirty');
      });
      control.addEventListener('input', () => {
        const row = control.closest('tr[data-student-id]');
        if (!row) return;
        recalculateRow(row);
        dirtyStudents.add(String(row.dataset.studentId || ''));
        row.classList.add('matrix-row-dirty');
      });
    });
    document.querySelectorAll('.js-matrix-shared-field').forEach((control) => {
      control.addEventListener('change', () => { sharedDirty = true; recalculateAllRows(); });
      control.addEventListener('input', () => { sharedDirty = true; recalculateAllRows(); });
    });
    document.querySelectorAll('.js-matrix-bulk-action').forEach((button) => {
      button.addEventListener('click', () => runBulkAction(button));
    });
    window.addEventListener('beforeunload', (event) => {
      if (!sharedDirty && dirtyStudents.size === 0) return;
      event.preventDefault();
      event.returnValue = '';
    });
    recalculateAllRows();
    initializeTooltips();
  })();
</script>
