<%
  const isEdit = !!(template && template.id);
  const sourceTemplateForCopy = (typeof copySourceTemplate !== 'undefined' && copySourceTemplate) ? copySourceTemplate : null;
  const initialFields = Array.isArray(template?.schema?.fields) && template.schema.fields.length
    ? template.schema.fields
    : [
      { id: 'teacher_name', label: 'Teacher Name', type: 'text', required: false, readOnly: false, prefillKey: 'teacher_name', helpText: '', placeholder: '', options: [] },
      { id: 'class_name', label: 'Class Name', type: 'text', required: false, readOnly: false, prefillKey: 'class_name', helpText: '', placeholder: '', options: [] },
      { id: 'report_date', label: 'Report Date', type: 'date', required: false, readOnly: false, prefillKey: 'report_date', helpText: '', placeholder: '', options: [] }
    ];
  const initialMap = template?.placeholderMap || {};
  const prefillCatalogData = (typeof prefillCatalog !== 'undefined' && prefillCatalog)
    ? prefillCatalog
    : {
      common: [],
      classOnly: [],
      gradebookPeriodClass: [],
      gradebookPeriodSkillsClass: [],
      examPeriodClass: [],
      studentOnly: [],
      gradebookPeriodStudent: [],
      gradebookPeriodSkillsStudent: [],
      examPeriodStudent: []
    };
  const allPrefillKeys = [
    ...(Array.isArray(prefillCatalogData.common) ? prefillCatalogData.common : []),
    ...(Array.isArray(prefillCatalogData.classOnly) ? prefillCatalogData.classOnly : []),
    ...(Array.isArray(prefillCatalogData.gradebookPeriodClass) ? prefillCatalogData.gradebookPeriodClass : []),
    ...(Array.isArray(prefillCatalogData.gradebookPeriodSkillsClass) ? prefillCatalogData.gradebookPeriodSkillsClass : []),
    ...(Array.isArray(prefillCatalogData.examPeriodClass) ? prefillCatalogData.examPeriodClass : []),
    ...(Array.isArray(prefillCatalogData.studentOnly) ? prefillCatalogData.studentOnly : []),
    ...(Array.isArray(prefillCatalogData.gradebookPeriodStudent) ? prefillCatalogData.gradebookPeriodStudent : []),
    ...(Array.isArray(prefillCatalogData.gradebookPeriodSkillsStudent) ? prefillCatalogData.gradebookPeriodSkillsStudent : []),
    ...(Array.isArray(prefillCatalogData.examPeriodStudent) ? prefillCatalogData.examPeriodStudent : [])
  ];
%>
<div class="sections-page">
  <style>
    .prefill-item .font-monospace { font-size: 0.82rem; }
    .prefill-item .prefill-desc { font-size: 0.75rem; line-height: 1.25; }
    .prefill-item .btn-copy-key { min-width: 2rem; }
    .field-row-draggable { cursor: move; }
    .field-row-dragover { outline: 2px dashed #0d6efd; outline-offset: -2px; background: #f8fbff; }
    .field-drag-handle { cursor: grab; }
    .field-designer-table { width: 100%; table-layout: fixed; }
    .field-main-cell .field-label { display: block; font-weight: 600; }
    .field-main-cell .field-id { display: block; font-size: 0.8rem; color: #6c757d; word-break: break-all; }
    .field-summary-cell { white-space: normal; overflow-wrap: anywhere; word-break: break-word; line-height: 1.2; }
    .field-row-visual { background: #fcfcff; }
    .field-main-cell .field-kind { display: inline-block; font-size: 0.75rem; margin-right: 0.35rem; }
  </style>
  <div class="row g-2 align-items-start mb-4">
    <div class="col">
      <h1 class="page-heading size-md m-0 text-start" style="padding-left:0;"><i class="bi bi-pencil-square me-2"></i><%= title %></h1>
      <div class="text-muted small mt-1">Define online fields and map each field to DOCX placeholder tokens.</div>
    </div>
    <div class="col-auto d-flex flex-column align-items-end gap-1">
      <% if (isEdit && template?.id) { %>
        <span class="badge bg-primary border font-monospace">ID: <%= template.id %></span>
      <% } %>
      <a href="/school/reports/templates" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Templates</a>
    </div>
  </div>

  <form method="POST" action="<%= isEdit ? ('/school/reports/templates/edit/' + template.id) : '/school/reports/templates/new' %>" enctype="multipart/form-data" id="templateForm">
    <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
    <input type="hidden" name="schemaJson" id="schemaJsonInput">
    <input type="hidden" name="placeholderMapJson" id="placeholderMapJsonInput">
    <% if (!isEdit && sourceTemplateForCopy?.id) { %>
      <input type="hidden" name="copySourceTemplateId" value="<%= sourceTemplateForCopy.id %>">
    <% } %>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-3">
        <div class="row g-3">
          <div class="col-md-4">
            <label class="form-label fw-bold">Title</label>
            <input type="text" name="title" class="form-control" required maxlength="180" value="<%= template?.title || '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold">Type</label>
            <input type="text" name="type" class="form-control" required maxlength="80" value="<%= template?.type || 'progress_report_v1' %>">
          </div>
          <div class="col-md-2">
            <label class="form-label fw-bold">Version</label>
            <input type="number" name="version" class="form-control" required min="1" max="1000" value="<%= Number(template?.version || 1) %>">
          </div>
          <div class="col-md-3">
            <label class="form-label fw-bold">Status</label>
            <select name="status" class="form-select">
              <% (templateStatuses || []).forEach((st) => { %>
                <option value="<%= st %>" <%= String(template?.status || 'draft') === String(st) ? 'selected' : '' %>><%= st %></option>
              <% }); %>
            </select>
          </div>
          <div class="col-12">
            <label class="form-label fw-bold">Description</label>
            <textarea name="description" class="form-control" rows="2" maxlength="4000"><%= template?.description || '' %></textarea>
          </div>
          <div class="col-md-8">
            <label class="form-label fw-bold">DOCX Template File</label>
            <input type="file" name="docxTemplate" class="form-control" accept=".docx">
            <% if (template?.docxTemplate?.url) { %>
              <div class="small text-muted mt-1">
                Current: <a href="<%= template.docxTemplate.url %>" target="_blank"><%= template.docxTemplate.originalName || template.docxTemplate.fileName %></a>
              </div>
            <% } %>
          </div>
          <div class="col-md-4">
            <label class="form-label fw-bold">Schema Version</label>
            <input type="number" id="schemaVersionInput" class="form-control" min="1" max="1000" value="<%= Number(template?.schema?.version || 1) %>">
          </div>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="m-0 fw-bold">DOCX Prefill Keys Catalog</h5>
        <span class="badge bg-light text-dark border">Copy Supported</span>
      </div>
      <div class="card-body p-3">
        <div class="alert alert-light border small mb-3">
          These keys are available during export and can be mapped into DOCX placeholders via the field mapping.
          Use the copy button to copy ready-to-paste DOCX tokens (for example <code>{{student_full_name}}</code>).
          Student keys are intended for student-target assignments; class keys are intended for whole-class assignments.
        </div>
        <div class="d-flex flex-wrap gap-2 align-items-center mb-3">
          <input type="text" class="form-control form-control-sm" id="prefillKeySearch" placeholder="Search keys (id, address, phone, attendance...)" style="max-width: 360px;">
          <button type="button" class="btn btn-outline-secondary btn-sm" id="btnExpandPrefill">Expand All</button>
          <button type="button" class="btn btn-outline-secondary btn-sm" id="btnCollapsePrefill">Collapse All</button>
          <button type="button" class="btn btn-outline-primary btn-sm" id="btnExportPrefillJson"><i class="bi bi-filetype-json me-1"></i>Export JSON</button>
          <button type="button" class="btn btn-outline-primary btn-sm" id="btnExportPrefillCsv"><i class="bi bi-filetype-csv me-1"></i>Export CSV</button>
        </div>
        <div class="accordion" id="prefillCatalogAccordion">
          <div class="accordion-item">
            <h2 class="accordion-header" id="prefillCommonHeading">
              <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#prefillCommonPanel" aria-expanded="true" aria-controls="prefillCommonPanel">
                Common Keys
              </button>
            </h2>
            <div id="prefillCommonPanel" class="accordion-collapse collapse show" aria-labelledby="prefillCommonHeading" data-bs-parent="#prefillCatalogAccordion">
              <div class="accordion-body p-2">
                <% (prefillCatalogData.common || []).forEach((item) => { %>
                  <div class="prefill-item d-flex justify-content-between align-items-start border rounded px-2 py-2 mb-1">
                    <div class="me-2">
                      <div class="font-monospace small"><%= item.key %></div>
                      <div class="prefill-desc text-muted"><%= item.description || '' %></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{<%= item.key %>}}" title="Copy DOCX token">
                      <i class="bi bi-copy"></i>
                    </button>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header" id="prefillClassHeading">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#prefillClassPanel" aria-expanded="false" aria-controls="prefillClassPanel">
                Class-Focused Keys
              </button>
            </h2>
            <div id="prefillClassPanel" class="accordion-collapse collapse" aria-labelledby="prefillClassHeading" data-bs-parent="#prefillCatalogAccordion">
              <div class="accordion-body p-2">
                <% (prefillCatalogData.classOnly || []).forEach((item) => { %>
                  <div class="prefill-item d-flex justify-content-between align-items-start border rounded px-2 py-2 mb-1">
                    <div class="me-2">
                      <div class="font-monospace small"><%= item.key %></div>
                      <div class="prefill-desc text-muted"><%= item.description || '' %></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{<%= item.key %>}}" title="Copy DOCX token">
                      <i class="bi bi-copy"></i>
                    </button>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header" id="prefillGbClassHeading">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#prefillGbClassPanel" aria-expanded="false" aria-controls="prefillGbClassPanel">
                Gradebook - report period (class)
              </button>
            </h2>
            <div id="prefillGbClassPanel" class="accordion-collapse collapse" aria-labelledby="prefillGbClassHeading" data-bs-parent="#prefillCatalogAccordion">
              <div class="accordion-body p-2">
                <% (prefillCatalogData.gradebookPeriodClass || []).forEach((item) => { %>
                  <div class="prefill-item d-flex justify-content-between align-items-start border rounded px-2 py-2 mb-1">
                    <div class="me-2">
                      <div class="font-monospace small"><%= item.key %></div>
                      <div class="prefill-desc text-muted"><%= item.description || '' %></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{<%= item.key %>}}" title="Copy DOCX token">
                      <i class="bi bi-copy"></i>
                    </button>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header" id="prefillGbSkillsClassHeading">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#prefillGbSkillsClassPanel" aria-expanded="false" aria-controls="prefillGbSkillsClassPanel">
                Gradebook skills - report period (class)
              </button>
            </h2>
            <div id="prefillGbSkillsClassPanel" class="accordion-collapse collapse" aria-labelledby="prefillGbSkillsClassHeading" data-bs-parent="#prefillCatalogAccordion">
              <div class="accordion-body p-2">
                <% (prefillCatalogData.gradebookPeriodSkillsClass || []).forEach((item) => { %>
                  <div class="prefill-item d-flex justify-content-between align-items-start border rounded px-2 py-2 mb-1">
                    <div class="me-2">
                      <div class="font-monospace small"><%= item.key %></div>
                      <div class="prefill-desc text-muted"><%= item.description || '' %></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{<%= item.key %>}}" title="Copy DOCX token">
                      <i class="bi bi-copy"></i>
                    </button>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header" id="prefillExamClassHeading">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#prefillExamClassPanel" aria-expanded="false" aria-controls="prefillExamClassPanel">
                Exams - report period (class)
              </button>
            </h2>
            <div id="prefillExamClassPanel" class="accordion-collapse collapse" aria-labelledby="prefillExamClassHeading" data-bs-parent="#prefillCatalogAccordion">
              <div class="accordion-body p-2">
                <% (prefillCatalogData.examPeriodClass || []).forEach((item) => { %>
                  <div class="prefill-item d-flex justify-content-between align-items-start border rounded px-2 py-2 mb-1">
                    <div class="me-2">
                      <div class="font-monospace small"><%= item.key %></div>
                      <div class="prefill-desc text-muted"><%= item.description || '' %></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{<%= item.key %>}}" title="Copy DOCX token">
                      <i class="bi bi-copy"></i>
                    </button>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header" id="prefillStudentHeading">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#prefillStudentPanel" aria-expanded="false" aria-controls="prefillStudentPanel">
                Student-Focused Keys
              </button>
            </h2>
            <div id="prefillStudentPanel" class="accordion-collapse collapse" aria-labelledby="prefillStudentHeading" data-bs-parent="#prefillCatalogAccordion">
              <div class="accordion-body p-2">
                <% (prefillCatalogData.studentOnly || []).forEach((item) => { %>
                  <div class="prefill-item d-flex justify-content-between align-items-start border rounded px-2 py-2 mb-1">
                    <div class="me-2">
                      <div class="font-monospace small"><%= item.key %></div>
                      <div class="prefill-desc text-muted"><%= item.description || '' %></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{<%= item.key %>}}" title="Copy DOCX token">
                      <i class="bi bi-copy"></i>
                    </button>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header" id="prefillGbStudentHeading">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#prefillGbStudentPanel" aria-expanded="false" aria-controls="prefillGbStudentPanel">
                Gradebook - report period (student)
              </button>
            </h2>
            <div id="prefillGbStudentPanel" class="accordion-collapse collapse" aria-labelledby="prefillGbStudentHeading" data-bs-parent="#prefillCatalogAccordion">
              <div class="accordion-body p-2">
                <% (prefillCatalogData.gradebookPeriodStudent || []).forEach((item) => { %>
                  <div class="prefill-item d-flex justify-content-between align-items-start border rounded px-2 py-2 mb-1">
                    <div class="me-2">
                      <div class="font-monospace small"><%= item.key %></div>
                      <div class="prefill-desc text-muted"><%= item.description || '' %></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{<%= item.key %>}}" title="Copy DOCX token">
                      <i class="bi bi-copy"></i>
                    </button>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header" id="prefillGbSkillsStudentHeading">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#prefillGbSkillsStudentPanel" aria-expanded="false" aria-controls="prefillGbSkillsStudentPanel">
                Gradebook skills - report period (student)
              </button>
            </h2>
            <div id="prefillGbSkillsStudentPanel" class="accordion-collapse collapse" aria-labelledby="prefillGbSkillsStudentHeading" data-bs-parent="#prefillCatalogAccordion">
              <div class="accordion-body p-2">
                <% (prefillCatalogData.gradebookPeriodSkillsStudent || []).forEach((item) => { %>
                  <div class="prefill-item d-flex justify-content-between align-items-start border rounded px-2 py-2 mb-1">
                    <div class="me-2">
                      <div class="font-monospace small"><%= item.key %></div>
                      <div class="prefill-desc text-muted"><%= item.description || '' %></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{<%= item.key %>}}" title="Copy DOCX token">
                      <i class="bi bi-copy"></i>
                    </button>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
          <div class="accordion-item">
            <h2 class="accordion-header" id="prefillExamStudentHeading">
              <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#prefillExamStudentPanel" aria-expanded="false" aria-controls="prefillExamStudentPanel">
                Exams - report period (student)
              </button>
            </h2>
            <div id="prefillExamStudentPanel" class="accordion-collapse collapse" aria-labelledby="prefillExamStudentHeading" data-bs-parent="#prefillCatalogAccordion">
              <div class="accordion-body p-2">
                <% (prefillCatalogData.examPeriodStudent || []).forEach((item) => { %>
                  <div class="prefill-item d-flex justify-content-between align-items-start border rounded px-2 py-2 mb-1">
                    <div class="me-2">
                      <div class="font-monospace small"><%= item.key %></div>
                      <div class="prefill-desc text-muted"><%= item.description || '' %></div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{<%= item.key %>}}" title="Copy DOCX token">
                      <i class="bi bi-copy"></i>
                    </button>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="m-0 fw-bold">DOCX Repeat Tables</h5>
        <span class="badge bg-light text-dark border">Dynamic Rows</span>
      </div>
      <div class="card-body p-3">
        <div class="alert alert-light border small mb-3">
          Use one sample row in the Word table. Put the loop start in the first cell and the loop end in the last cell of the same row.
        </div>
        <div class="row g-3">
          <div class="col-lg-4">
            <div class="border rounded p-3 h-100">
              <div class="fw-bold mb-2">Students</div>
              <pre class="small bg-light border rounded p-2 mb-2 text-wrap"><code>{{#students}}{{student_no}} {{student_full_name}} {{student_attendance_span_percent}}{{/students}}</code></pre>
              <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{#students}}{{student_no}} {{student_full_name}} {{student_attendance_span_percent}}{{/students}}">
                <i class="bi bi-copy me-1"></i>Copy Example
              </button>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="border rounded p-3 h-100">
              <div class="fw-bold mb-2">Attendance Sessions</div>
              <pre class="small bg-light border rounded p-2 mb-2 text-wrap"><code>{{#attendance_sessions}}{{session_no}} {{session_date}} {{session_start_time}} {{session_end_time}}{{/attendance_sessions}}</code></pre>
              <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{#attendance_sessions}}{{session_no}} {{session_date}} {{session_start_time}} {{session_end_time}}{{/attendance_sessions}}">
                <i class="bi bi-copy me-1"></i>Copy Example
              </button>
            </div>
          </div>
          <div class="col-lg-4">
            <div class="border rounded p-3 h-100">
              <div class="fw-bold mb-2">Student Attendance Rows</div>
              <pre class="small bg-light border rounded p-2 mb-2 text-wrap"><code>{{#student_attendance_rows}}{{student_full_name}} {{session_date}} {{attendance_status_label}}{{/student_attendance_rows}}</code></pre>
              <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{#student_attendance_rows}}{{student_full_name}} {{session_date}} {{attendance_status_label}}{{/student_attendance_rows}}">
                <i class="bi bi-copy me-1"></i>Copy Example
              </button>
            </div>
          </div>
        </div>
        <div class="row g-3 mt-1">
          <div class="col-lg-6">
            <div class="border rounded p-3 h-100">
              <div class="fw-bold mb-2">Gradebook Skill Rows</div>
              <pre class="small bg-light border rounded p-2 mb-2 text-wrap"><code>{{#gradebook_skill_rows}}{{student_full_name}} {{skill_name}} {{activity_count}} {{avg_percent}}{{/gradebook_skill_rows}}</code></pre>
              <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{#gradebook_skill_rows}}{{student_full_name}} {{skill_name}} {{activity_count}} {{avg_percent}}{{/gradebook_skill_rows}}">
                <i class="bi bi-copy me-1"></i>Copy Example
              </button>
            </div>
          </div>
          <div class="col-lg-6">
            <div class="border rounded p-3 h-100">
              <div class="fw-bold mb-2">Student CLB Entries</div>
              <pre class="small bg-light border rounded p-2 mb-2 text-wrap"><code>{{#student_clb_entries}}{{student_full_name}} {{clb_recorded_at}} {{clb_result_listening}}{{/student_clb_entries}}</code></pre>
              <button type="button" class="btn btn-sm btn-outline-secondary btn-copy-key" data-copy-token="{{#student_clb_entries}}{{student_full_name}} {{clb_recorded_at}} {{clb_result_listening}}{{/student_clb_entries}}">
                <i class="bi bi-copy me-1"></i>Copy Example
              </button>
              <div class="small text-muted mt-2">Rows include entry identity, latest-entry flag, and all goal, current, and result skill values.</div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <div>
          <h5 class="m-0 fw-bold">Field Designer</h5>
          <div class="small text-muted mt-1">Rows are compact and read-only here. Use the three-dot menu to edit field details in a full modal. Drag rows to reorder.</div>
        </div>
        <div class="d-flex align-items-center gap-2">
          <button type="button" class="btn btn-sm btn-outline-secondary" id="btnPreviewTemplate"><i class="bi bi-eye"></i> Preview Form</button>
          <button type="button" class="btn btn-sm btn-outline-dark" id="btnAddSection"><i class="bi bi-layout-text-window-reverse"></i> Add Section</button>
          <button type="button" class="btn btn-sm btn-outline-dark" id="btnAddSubheader"><i class="bi bi-text-indent-left"></i> Add Subheader</button>
          <button type="button" class="btn btn-sm btn-outline-dark" id="btnAddRowBreak"><i class="bi bi-layout-three-columns me-1"></i> New Row</button>
          <button type="button" class="btn btn-sm btn-outline-primary" id="btnAddField"><i class="bi bi-plus-circle"></i> Add Field</button>
        </div>
      </div>
      <div class="card-body p-0">
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0 field-designer-table">
