  <div class="modal fade" id="fieldEditorModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title fw-bold" id="fieldEditorTitle">Field Editor</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <div class="row g-3">
            <div class="col-md-4">
              <label class="form-label fw-bold">Field ID</label>
              <input type="text" class="form-control" id="fieldEditorId" maxlength="80" placeholder="teacher_name">
              <div class="form-text">Allowed: letters, numbers, `_`, `-`, `:`.</div>
            </div>
            <div class="col-md-5">
              <label class="form-label fw-bold">Label</label>
              <input type="text" class="form-control" id="fieldEditorLabel" maxlength="180" placeholder="Teacher Name">
            </div>
            <div class="col-md-3">
              <label class="form-label fw-bold">Type</label>
              <select class="form-select" id="fieldEditorType">
