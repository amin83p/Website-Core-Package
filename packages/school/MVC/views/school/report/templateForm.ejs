<datalist id="prefillKeyOptions">
  <% allPrefillKeys.forEach((item) => { %>
    <option value="<%= item.key %>"><%= item.label || item.key %></option>
  <% }); %>
</datalist>

<script>
  (function () {
    const fieldTypes = <%- JSON.stringify(fieldTypes || []) %>;
    const initialFields = <%- JSON.stringify(initialFields).replace(/</g, '\\u003c') %>;
    const initialMap = <%- JSON.stringify(initialMap).replace(/</g, '\\u003c') %>;
    const tbody = document.getElementById('fieldRowsBody');
    const addBtn = document.getElementById('btnAddField');
    const addSectionBtn = document.getElementById('btnAddSection');
    const addSubheaderBtn = document.getElementById('btnAddSubheader');
    const addRowBreakBtn = document.getElementById('btnAddRowBreak');
    const previewBtn = document.getElementById('btnPreviewTemplate');
    const previewModalEl = document.getElementById('templatePreviewModal');
    const previewTitle = document.getElementById('templatePreviewTitle');
    const previewBody = document.getElementById('templatePreviewBody');
    const fieldEditorModalEl = document.getElementById('fieldEditorModal');
    const expressionHelpModalEl = document.getElementById('expressionHelpModal');
    const expressionHelpTitleEl = document.getElementById('expressionHelpTitle');
    const expressionHelpBodyEl = document.getElementById('expressionHelpBody');
    const btnValidationHelp = document.getElementById('btnValidationHelp');
    const btnConversionHelp = document.getElementById('btnConversionHelp');
    const fieldEditorTitle = document.getElementById('fieldEditorTitle');
    const fieldEditorIdInput = document.getElementById('fieldEditorId');
    const fieldEditorLabelInput = document.getElementById('fieldEditorLabel');
    const fieldEditorTypeInput = document.getElementById('fieldEditorType');
    const fieldEditorPrefillInput = document.getElementById('fieldEditorPrefill');
    const fieldEditorPlaceholderInput = document.getElementById('fieldEditorPlaceholder');
    const fieldEditorOptionsWrap = document.getElementById('fieldEditorOptionsWrap');
    const fieldEditorOptionsInput = document.getElementById('fieldEditorOptions');
    const fieldEditorHelpInput = document.getElementById('fieldEditorHelp');
    const fieldEditorValidationRulesInput = document.getElementById('fieldEditorValidationRules');
    const fieldEditorConversionEnabledInput = document.getElementById('fieldEditorConversionEnabled');
    const fieldEditorConversionExpressionInput = document.getElementById('fieldEditorConversionExpression');
    const fieldEditorConversionOnErrorInput = document.getElementById('fieldEditorConversionOnError');
    const fieldEditorCalculatedEnabledInput = document.getElementById('fieldEditorCalculatedEnabled');
    const fieldEditorCalculationExpressionInput = document.getElementById('fieldEditorCalculationExpression');
    const fieldEditorCalculationOnErrorInput = document.getElementById('fieldEditorCalculationOnError');
    const fieldEditorCalculationDependenciesInput = document.getElementById('fieldEditorCalculationDependencies');
    const fieldEditorCalculationFieldList = document.getElementById('fieldEditorCalculationFieldList');
    const insertCalcFieldFormulaBtn = document.getElementById('btnInsertCalcFieldFormula');
    const addCalcFieldDependencyBtn = document.getElementById('btnAddCalcFieldDependency');
    const fieldEditorRequiredInput = document.getElementById('fieldEditorRequired');
    const fieldEditorReadonlyInput = document.getElementById('fieldEditorReadonly');
    const fieldEditorSharedInput = document.getElementById('fieldEditorShared');
    const fieldEditorFullWidthInput = document.getElementById('fieldEditorFullWidth');
    const fieldEditorBorderInput = document.getElementById('fieldEditorBorder');
    const fieldEditorBackgroundColorInput = document.getElementById('fieldEditorBackgroundColor');
    const clearFieldEditorBackgroundColorBtn = document.getElementById('btnFieldEditorClearBackgroundColor');
    const saveFieldEditorBtn = document.getElementById('btnSaveFieldEditor');
    const form = document.getElementById('templateForm');
    const schemaJsonInput = document.getElementById('schemaJsonInput');
    const placeholderMapJsonInput = document.getElementById('placeholderMapJsonInput');
    const schemaVersionInput = document.getElementById('schemaVersionInput');
    const prefillSearchInput = document.getElementById('prefillKeySearch');
    const btnExpandPrefill = document.getElementById('btnExpandPrefill');
    const btnCollapsePrefill = document.getElementById('btnCollapsePrefill');
    const btnExportPrefillJson = document.getElementById('btnExportPrefillJson');
    const btnExportPrefillCsv = document.getElementById('btnExportPrefillCsv');
    const prefillCatalog = <%- JSON.stringify(prefillCatalogData).replace(/</g, '\\u003c') %>;
    const isEditMode = <%- JSON.stringify(isEdit) %>;
    const VALUE_MODES = Object.freeze({ MANUAL: 'manual', CALCULATED: 'calculated' });
    const CALC_ON_ERROR = Object.freeze({ KEEP_LAST: 'keep_last', EMPTY: 'empty' });
    let editingIndex = -1;
    let dragIndex = -1;
    let fieldsState = [];

    function escapeHtml(str) {
      return String(str || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function defaultField() {
      return {
        id: '',
        label: '',
        type: 'text',
        required: false,
        sharedAcrossStudents: false,
        readOnly: false,
        fullPageWidth: false,
        prefillKey: '',
        helpText: '',
        placeholderToken: '',
        valueMode: VALUE_MODES.MANUAL,
        calculationRule: { enabled: false, expression: '', onError: CALC_ON_ERROR.KEEP_LAST },
        calculationDependencies: [],
        hasBorder: false,
        backgroundColor: '',
        options: [],
        validationRules: [],
        conversionRule: { enabled: false, expression: '', onError: 'use_raw' }
      };
    }

    function normalizeHexColor(rawValue) {
      const trimmed = String(rawValue || '').trim();
      if (!trimmed) return '';
      return /^#(?:[0-9A-Fa-f]{6})$/.test(trimmed) ? trimmed.toLowerCase() : '';
    }

    function normalizeCalculationDependencies(rawList) {
      const list = Array.isArray(rawList)
        ? rawList
        : String(rawList || '').split(',').map((item) => String(item || '').trim()).filter(Boolean);
      const out = [];
      const seen = new Set();
      list.forEach((item) => {
        const token = String(item || '').trim();
        if (!token) return;
        const key = token.toLowerCase();
        if (seen.has(key)) return;
        seen.add(key);
        out.push(token);
      });
      return out;
    }

    function getCalculationFieldOptions() {
      const options = [];
      const taken = new Set();
      const currentId = String(fieldEditorIdInput?.value || '').trim().toLowerCase();

      (Array.isArray(fieldsState) ? fieldsState : []).forEach((field, idx) => {
        if (idx === editingIndex) return;
        const type = normalizeFieldType(field?.type || 'text');
        if (isVisualOnlyType(type)) return;
        const id = String(field?.id || '').trim();
        if (!id) return;
        const key = id.toLowerCase();
        if (key === currentId || taken.has(key)) return;
        taken.add(key);
        options.push({
          id,
          label: String(field?.label || id).trim(),
          type
        });
      });

      return options.sort((a, b) => String(a.label || '').localeCompare(String(b.label || '')));
    }

    function refreshCalculationFieldList() {
      if (!fieldEditorCalculationFieldList) return;
      const selectedBefore = String(fieldEditorCalculationFieldList.value || '').trim();
      const options = getCalculationFieldOptions();
      if (!options.length) {
        fieldEditorCalculationFieldList.innerHTML = '<option value="">No existing data field</option>';
        fieldEditorCalculationFieldList.value = '';
        return;
      }
      fieldEditorCalculationFieldList.innerHTML = options.map((item) => {
        const label = `${item.id} - ${item.label} (${item.type})`;
        return `<option value="${escapeHtml(item.id)}">${escapeHtml(label)}</option>`;
      }).join('');
      const hasPrevious = options.some((item) => item.id === selectedBefore);
      fieldEditorCalculationFieldList.value = hasPrevious ? selectedBefore : options[0].id;
    }

    function insertTextAtCursor(inputEl, snippet) {
      if (!inputEl) return;
      const text = String(snippet || '');
      if (!text) return;
      const value = String(inputEl.value || '');
      const start = Number.isInteger(inputEl.selectionStart) ? inputEl.selectionStart : value.length;
      const end = Number.isInteger(inputEl.selectionEnd) ? inputEl.selectionEnd : value.length;
      const left = value.slice(0, start);
      const right = value.slice(end);
      const needsLeftSpace = left && !/\s$|[([{,+\-*/%<>=!&|.]$/.test(left);
      const needsRightSpace = right && !/^\s|[)\]},.+\-*/%<>=!&|]/.test(right);
      const glued = `${left}${needsLeftSpace ? ' ' : ''}${text}${needsRightSpace ? ' ' : ''}${right}`;
      inputEl.value = glued;
      const caret = (left + (needsLeftSpace ? ' ' : '') + text).length;
      inputEl.focus();
      inputEl.setSelectionRange(caret, caret);
    }

    function appendCalculationDependency(fieldId) {
      const token = String(fieldId || '').trim();
      if (!token || !fieldEditorCalculationDependenciesInput) return;
      const current = normalizeCalculationDependencies(fieldEditorCalculationDependenciesInput.value);
      if (!current.some((item) => String(item || '').toLowerCase() === token.toLowerCase())) {
        current.push(token);
      }
      fieldEditorCalculationDependenciesInput.value = current.join(', ');
    }

    function isVisualOnlyType(rawType) {
      const t = String(rawType || '').trim().toLowerCase();
      return t === 'section' || t === 'subheader' || t === 'row_break';
    }

    function buildAutoVisualId(type, label, currentIndex = -1) {
      let prefix = 'section';
      if (type === 'subheader') prefix = 'subheader';
      if (type === 'row_break') prefix = 'row_break';
      const slug = String(label || '')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '_')
        .replace(/^_+|_+$/g, '')
        .slice(0, 30);
      const base = slug ? `__${prefix}_${slug}` : `__${prefix}`;
      const used = new Set(
        (Array.isArray(fieldsState) ? fieldsState : [])
          .map((field, idx) => (idx === currentIndex ? '' : String(field?.id || '').toLowerCase()))
          .filter(Boolean)
      );
      if (!used.has(base.toLowerCase())) return base;
      let i = 2;
      while (used.has(`${base}_${i}`.toLowerCase())) i += 1;
      return `${base}_${i}`;
    }

    async function showReportModal({ title = 'Notice', message = '', icon = 'warning', buttonClass = 'btn-primary' } = {}) {
      if (typeof showMessageModal === 'function') {
        return showMessageModal({
          title,
          icon,
          message,
          buttons: [{ text: 'OK', class: buttonClass }]
        });
      }
      if (typeof window !== 'undefined' && typeof window.alert === 'function') {
        window.alert(String(message || title || 'Notice'));
      }
      return 'OK';
    }

    async function confirmReportModal({
      title = 'Confirm',
      message = '',
      icon = 'warning',
      confirmText = 'Confirm',
      confirmClass = 'btn-danger',
      cancelText = 'Cancel',
      fallbackMessage = ''
    } = {}) {
      if (typeof showMessageModal === 'function') {
        const result = await showMessageModal({
          title,
          icon,
          message,
          buttons: [
            { text: cancelText, class: 'btn-secondary' },
            { text: confirmText, class: confirmClass }
          ]
        });
        return result === confirmText;
      }
      if (typeof window !== 'undefined' && typeof window.confirm === 'function') {
        return window.confirm(String(fallbackMessage || message || title || 'Are you sure?'));
      }
      return false;
    }

    function parseOptionsCsv(csvText) {
      return String(csvText || '')
        .split(',')
        .map((v) => String(v || '').trim())
        .filter(Boolean)
        .map((v) => ({ value: v, label: v }));
    }

    function toOptionsCsv(options) {
      const list = Array.isArray(options) ? options : [];
      return list.map((opt) => {
        if (opt && typeof opt === 'object') return String(opt.value || '').trim();
        return String(opt || '').trim();
      }).filter(Boolean).join(', ');
    }

    function parseValidationRulesJson(rawText) {
      const text = String(rawText || '').trim();
      if (!text) return [];
      let parsed;
      try {
        parsed = JSON.parse(text);
      } catch (_) {
        throw new Error('Validation Rules must be valid JSON.');
      }
      if (!Array.isArray(parsed)) throw new Error('Validation Rules must be a JSON array.');
      return parsed.map((rule, index) => {
        if (!rule || typeof rule !== 'object') throw new Error(`Validation rule #${index + 1} is invalid.`);
        const id = String(rule.id || `rule_${index + 1}`).trim() || `rule_${index + 1}`;
        const expression = String(rule.expression || '').trim();
        if (!expression) throw new Error(`Validation rule "${id}" is missing expression.`);
        if (expression.length > 240) throw new Error(`Validation rule "${id}" exceeds 240 chars.`);
        return {
          id,
          enabled: rule.enabled !== false && String(rule.enabled || '').trim().toLowerCase() !== 'false',
          severity: String(rule.severity || 'error').trim().toLowerCase() === 'warning' ? 'warning' : 'error',
          when: String(rule.when || 'always').trim().toLowerCase() === 'if_has_value' ? 'if_has_value' : 'always',
          expression,
          message: String(rule.message || '').trim()
        };
      });
    }

    function toValidationRulesJson(rules) {
      const list = Array.isArray(rules) ? rules : [];
      if (!list.length) return '';
      return JSON.stringify(list, null, 2);
    }

    function openExpressionHelp(kind) {
      if (!expressionHelpModalEl || !expressionHelpTitleEl || !expressionHelpBodyEl) return;
      const mode = String(kind || '').trim().toLowerCase();
      if (mode === 'conversion') {
        expressionHelpTitleEl.textContent = 'Conversion Help';
        expressionHelpBodyEl.innerHTML = `
          <h6 class="fw-bold">Number Conversions</h6>
          <pre class="small bg-light border rounded p-2 mb-2"><code>num(value) / 100
round(num(value), 2)
clamp(num(value), 0, 100)</code></pre>

          <h6 class="fw-bold">Branch / Case-Switch</h6>
          <pre class="small bg-light border rounded p-2 mb-2"><code>ifelse(num(value) >= 90, "A", "B")
caseof(value, "excellent", 4, "good", 3, "fair", 2, 0)</code></pre>

          <h6 class="fw-bold">Text/Select Mapping</h6>
          <pre class="small bg-light border rounded p-2 mb-2"><code>str(value)
caseof(value, "male", "M", "female", "F", "U")
ifelse(len(str(value)) > 0, str(value), "N/A")</code></pre>

          <h6 class="fw-bold">Checkbox / Boolean</h6>
          <pre class="small bg-light border rounded p-2 mb-2"><code>ifelse(value == true, "Yes", "No")</code></pre>

          <h6 class="fw-bold">Date (YYYY-MM-DD text)</h6>
          <pre class="small bg-light border rounded p-2 mb-0"><code>ifelse(value >= "2026-01-01", "Current", "Previous")</code></pre>
        `;
      } else {
        expressionHelpTitleEl.textContent = 'Validation Help';
        expressionHelpBodyEl.innerHTML = `
          <h6 class="fw-bold">Basic Required / Range</h6>
          <pre class="small bg-light border rounded p-2 mb-2"><code>// when = "always"
len(str(value)) > 0

// when = "if_has_value"
num(value) >= 0 && num(value) <= 100</code></pre>

          <h6 class="fw-bold">Text Length and Allowed Values</h6>
          <pre class="small bg-light border rounded p-2 mb-2"><code>len(str(value)) <= 120
value == "excellent" || value == "good" || value == "fair"</code></pre>

          <h6 class="fw-bold">Date Validation (YYYY-MM-DD)</h6>
          <pre class="small bg-light border rounded p-2 mb-2"><code>value >= "2025-01-01" && value <= "2027-12-31"</code></pre>

          <h6 class="fw-bold">Cross-Field Validation</h6>
          <pre class="small bg-light border rounded p-2 mb-2"><code>num(value) <= num(answers.total_score)
value != answers.previous_grade</code></pre>

          <h6 class="fw-bold">Warning-Level Example</h6>
          <pre class="small bg-light border rounded p-2 mb-0"><code>// severity = "warning"
num(value) <= 95</code></pre>
        `;
      }

      if (window.bootstrap && window.bootstrap.Modal) {
        window.bootstrap.Modal.getOrCreateInstance(expressionHelpModalEl).show();
      }
    }

    function normalizeFieldType(rawType) {
      const type = String(rawType || 'text').trim().toLowerCase();
      return fieldTypes.includes(type) ? type : 'text';
    }

    function normalizeField(raw = {}) {
      const id = String(raw.id || '').trim();
      const type = normalizeFieldType(raw.type);
      const visualOnly = isVisualOnlyType(type);
      const options = type === 'select'
        ? (Array.isArray(raw.options) ? raw.options : [])
            .map((opt) => {
              if (opt && typeof opt === 'object') {
                const value = String(opt.value || '').trim();
                const label = String(opt.label || opt.value || '').trim();
                if (!value) return null;
                return { value, label: label || value };
              }
              const value = String(opt || '').trim();
              if (!value) return null;
              return { value, label: value };
            })
            .filter(Boolean)
        : [];
      const fallbackToken = id ? `{{${id}}}` : '';
      const placeholderToken = String(raw.placeholderToken || raw.placeholder || '').trim() || fallbackToken;
      const validationRules = Array.isArray(raw.validationRules) ? raw.validationRules : [];
      const conversionRuleRaw = raw && typeof raw.conversionRule === 'object' ? raw.conversionRule : {};
      const valueModeRaw = String(raw?.valueMode || VALUE_MODES.MANUAL).trim().toLowerCase();
      const valueMode = visualOnly ? VALUE_MODES.MANUAL : (valueModeRaw === VALUE_MODES.CALCULATED ? VALUE_MODES.CALCULATED : VALUE_MODES.MANUAL);
      const calculationRuleRaw = raw && typeof raw.calculationRule === 'object' ? raw.calculationRule : {};
      const calculationDependencies = visualOnly ? [] : normalizeCalculationDependencies(raw?.calculationDependencies || []);
      const calcEnabled = valueMode === VALUE_MODES.CALCULATED;

      return {
        id: visualOnly ? (id || buildAutoVisualId(type, raw.label || '', -1)) : id,
        label: String(raw.label || '').trim(),
        type,
        required: visualOnly ? false : (raw.required === true || String(raw.required) === 'true'),
        sharedAcrossStudents: raw.sharedAcrossStudents === true || String(raw.sharedAcrossStudents) === 'true',
        readOnly: visualOnly ? false : (raw.readOnly === true || String(raw.readOnly) === 'true'),
        fullPageWidth: visualOnly ? true : (raw.fullPageWidth === true || String(raw.fullPageWidth) === 'true'),
        valueMode,
        calculationRule: visualOnly
          ? { enabled: false, expression: '', onError: CALC_ON_ERROR.KEEP_LAST }
          : {
              enabled: calcEnabled,
              expression: calcEnabled ? String(calculationRuleRaw?.expression || '').trim() : '',
              onError: String(calculationRuleRaw?.onError || CALC_ON_ERROR.KEEP_LAST).trim().toLowerCase() === CALC_ON_ERROR.EMPTY ? CALC_ON_ERROR.EMPTY : CALC_ON_ERROR.KEEP_LAST
            },
        calculationDependencies: calcEnabled ? calculationDependencies : [],
        hasBorder: visualOnly ? false : (raw.hasBorder === true || String(raw.hasBorder) === 'true'),
        backgroundColor: visualOnly ? '' : normalizeHexColor(raw.backgroundColor),
        prefillKey: visualOnly ? '' : String(raw.prefillKey || '').trim(),
        helpText: String(raw.helpText || '').trim(),
        placeholderToken: visualOnly ? '' : placeholderToken,
        options: visualOnly ? [] : options,
        validationRules: visualOnly ? [] : validationRules.map((rule, index) => ({
          id: String(rule?.id || `rule_${index + 1}`).trim() || `rule_${index + 1}`,
          enabled: rule?.enabled !== false && String(rule?.enabled || '').trim().toLowerCase() !== 'false',
          severity: String(rule?.severity || 'error').trim().toLowerCase() === 'warning' ? 'warning' : 'error',
          when: String(rule?.when || 'always').trim().toLowerCase() === 'if_has_value' ? 'if_has_value' : 'always',
          expression: String(rule?.expression || '').trim(),
          message: String(rule?.message || '').trim()
        })),
        conversionRule: visualOnly
          ? { enabled: false, expression: '', onError: 'use_raw' }
          : {
              enabled: conversionRuleRaw?.enabled === true || String(conversionRuleRaw?.enabled || '').trim().toLowerCase() === 'true',
              expression: String(conversionRuleRaw?.expression || '').trim(),
              onError: String(conversionRuleRaw?.onError || 'use_raw').trim().toLowerCase() === 'empty' ? 'empty' : 'use_raw'
            }
      };
    }

    function initializeState() {
      fieldsState = (Array.isArray(initialFields) ? initialFields : []).map((field) => {
        const id = String(field?.id || '').trim();
        return normalizeField({
          ...field,
          placeholderToken: String(initialMap[id] || field?.placeholder || '').trim()
        });
      });
    }

    async function copyText(value) {
      if (!value) return false;
      if (navigator.clipboard && navigator.clipboard.writeText) {
        try {
          await navigator.clipboard.writeText(value);
          return true;
        } catch (_) {
          // fallback below
        }
      }
      const temp = document.createElement('textarea');
      temp.value = value;
      temp.setAttribute('readonly', '');
      temp.style.position = 'absolute';
      temp.style.left = '-9999px';
      document.body.appendChild(temp);
      temp.select();
      let ok = false;
      try {
        ok = document.execCommand('copy');
      } catch (_) {
        ok = false;
      }
      temp.remove();
      return ok;
    }

    function buildFlagsHtml(field) {
      const flags = [];
      if (isVisualOnlyType(field.type)) flags.push('<span class="badge bg-dark-subtle text-dark border">Visual only</span>');
      if (field.required) flags.push('<span class="badge bg-danger-subtle text-danger border">Required</span>');
      if (field.readOnly) flags.push('<span class="badge bg-light text-secondary border">View only</span>');
      if (field.sharedAcrossStudents) flags.push('<span class="badge bg-info-subtle text-info-emphasis border">Shared</span>');
      if (field.fullPageWidth) flags.push('<span class="badge bg-primary-subtle text-primary-emphasis border">Full width</span>');
      if (String(field.valueMode || VALUE_MODES.MANUAL) === VALUE_MODES.CALCULATED) flags.push('<span class="badge bg-warning-subtle text-warning-emphasis border">Calculated</span>');
      if (field.hasBorder) flags.push('<span class="badge bg-secondary-subtle text-secondary-emphasis border">Border</span>');
      if (field.backgroundColor) flags.push(`<span class="badge border" style="background-color:${escapeHtml(field.backgroundColor)};">Back color</span>`);
      return flags.length ? flags.join(' ') : '<span class="text-muted small">None</span>';
    }

    function renderFieldRows() {
      if (!Array.isArray(fieldsState) || !fieldsState.length) {
        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">No fields yet. Click "Add Field" to start.</td></tr>';
        return;
      }

      tbody.innerHTML = fieldsState.map((field, idx) => {
        const visualOnly = isVisualOnlyType(field.type);
        const layoutSummary = field.fullPageWidth ? 'Layout: Full page width' : 'Layout: Row-based width';
        const prefillSummary = field.prefillKey ? `Prefill: ${field.prefillKey}` : '';
        const placeholderSummary = field.placeholderToken ? `Token: ${field.placeholderToken}` : '';
        const optionsSummary = field.type === 'select' && field.options.length
          ? `Options: ${toOptionsCsv(field.options)}`
          : '';
        const validationSummary = Array.isArray(field.validationRules) && field.validationRules.length
          ? `Validation rules: ${field.validationRules.length}`
          : '';
        const conversionSummary = field?.conversionRule?.enabled && String(field?.conversionRule?.expression || '').trim()
          ? `Conversion: ${String(field.conversionRule.expression).trim()}`
          : '';
        const calcSummary = String(field.valueMode || VALUE_MODES.MANUAL) === VALUE_MODES.CALCULATED
          ? `Calculated: ${String(field?.calculationRule?.expression || '').trim()} | deps: ${(Array.isArray(field?.calculationDependencies) ? field.calculationDependencies : []).join(', ')}`
          : '';
        const borderSummary = field.hasBorder ? 'Border: enabled' : '';
        const backgroundSummary = field.backgroundColor ? `Back color: ${field.backgroundColor}` : '';
        const detailsParts = visualOnly
          ? ['Display-only grouping row', String(field.helpText || '').trim()].filter(Boolean)
          : [layoutSummary, prefillSummary, placeholderSummary, optionsSummary, validationSummary, conversionSummary, calcSummary, borderSummary, backgroundSummary, String(field.helpText || '').trim()].filter(Boolean);
        const detailsText = detailsParts.join(' | ') || '-';
        const visualClass = visualOnly ? ' field-row-visual' : '';
        let visualKind = '';
        if (visualOnly) {
          if (field.type === 'section') {
            visualKind = '<span class="field-kind badge bg-primary-subtle text-primary-emphasis border">Section title</span>';
          } else if (field.type === 'subheader') {
            visualKind = '<span class="field-kind badge bg-secondary-subtle text-secondary-emphasis border">Subheader</span>';
          } else {
            visualKind = '<span class="field-kind badge bg-dark-subtle text-dark border">New Row</span>';
          }
        }
        return `
          <tr data-index="${idx}" class="field-row-draggable${visualClass}" draggable="true">
            <td class="text-center">
              <span class="text-muted field-drag-handle" title="Drag to reorder"><i class="bi bi-grip-vertical"></i></span>
              <span class="badge bg-light text-dark border ms-1">${idx + 1}</span>
            </td>
            <td class="field-main-cell">
              ${visualKind}
              <span class="field-label">${escapeHtml(field.label || '-')}</span>
              <span class="font-monospace field-id">${escapeHtml(field.id || '')}</span>
            </td>
            <td><span class="badge bg-secondary-subtle text-secondary border">${escapeHtml(field.type || 'text')}</span></td>
            <td>${buildFlagsHtml(field)}</td>
            <td class="field-summary-cell" title="${escapeHtml(detailsText)}">${escapeHtml(detailsText)}</td>
            <td class="text-center">
              <div class="dropdown">
                <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="dropdown" aria-expanded="false" title="Field actions">
                  <i class="bi bi-three-dots-vertical"></i>
                </button>
                <ul class="dropdown-menu dropdown-menu-end">
                  <li><button type="button" class="dropdown-item js-field-action" data-action="edit" data-index="${idx}"><i class="bi bi-pencil-square me-2"></i>Edit</button></li>
                  <li><button type="button" class="dropdown-item js-field-action" data-action="duplicate" data-index="${idx}"><i class="bi bi-files me-2"></i>Duplicate</button></li>
                  <li><hr class="dropdown-divider"></li>
                  <li><button type="button" class="dropdown-item text-danger js-field-action" data-action="delete" data-index="${idx}"><i class="bi bi-trash me-2"></i>Delete</button></li>
                </ul>
              </div>
            </td>
          </tr>
        `;
      }).join('');
    }

    function collect() {
      const fields = [];
      const placeholderMap = {};

      (Array.isArray(fieldsState) ? fieldsState : []).forEach((source) => {
        const id = String(source?.id || '').trim();
        const label = String(source?.label || '').trim();
        const visualOnly = isVisualOnlyType(source?.type);
        if (!label) return;
        if (!visualOnly && !id) return;
        const effectiveId = visualOnly ? (id || buildAutoVisualId(source?.type, label, -1)) : id;

        const normalizedType = normalizeFieldType(source?.type);
        const valueMode = visualOnly
          ? VALUE_MODES.MANUAL
          : (String(source?.valueMode || VALUE_MODES.MANUAL).trim().toLowerCase() === VALUE_MODES.CALCULATED ? VALUE_MODES.CALCULATED : VALUE_MODES.MANUAL);
        const calculationDependencies = valueMode === VALUE_MODES.CALCULATED
          ? normalizeCalculationDependencies(source?.calculationDependencies || [])
          : [];
        fields.push({
          id: effectiveId,
          label,
          type: normalizedType,
          required: visualOnly ? false : source?.required === true,
          readOnly: source?.readOnly === true,
          sharedAcrossStudents: source?.sharedAcrossStudents === true,
          fullPageWidth: visualOnly ? true : source?.fullPageWidth === true,
          valueMode,
          calculationRule: valueMode === VALUE_MODES.CALCULATED
            ? {
                enabled: true,
                expression: String(source?.calculationRule?.expression || '').trim(),
                onError: String(source?.calculationRule?.onError || CALC_ON_ERROR.KEEP_LAST).trim().toLowerCase() === CALC_ON_ERROR.EMPTY ? CALC_ON_ERROR.EMPTY : CALC_ON_ERROR.KEEP_LAST
              }
            : {
                enabled: false,
                expression: '',
                onError: CALC_ON_ERROR.KEEP_LAST
              },
          calculationDependencies,
          hasBorder: visualOnly ? false : source?.hasBorder === true,
          backgroundColor: visualOnly ? '' : normalizeHexColor(source?.backgroundColor),
          prefillKey: visualOnly ? '' : String(source?.prefillKey || '').trim(),
          helpText: String(source?.helpText || '').trim(),
          options: normalizedType === 'select'
            ? (Array.isArray(source?.options) ? source.options : []).map((opt) => ({
                value: String(opt?.value || '').trim(),
                label: String(opt?.label || opt?.value || '').trim()
              })).filter((opt) => opt.value)
            : [],
          validationRules: visualOnly ? [] : (Array.isArray(source?.validationRules) ? source.validationRules : []),
          conversionRule: visualOnly
            ? { enabled: false, expression: '', onError: 'use_raw' }
            : {
                enabled: source?.conversionRule?.enabled === true,
                expression: String(source?.conversionRule?.expression || '').trim(),
                onError: String(source?.conversionRule?.onError || 'use_raw').trim().toLowerCase() === 'empty' ? 'empty' : 'use_raw'
              }
        });

        if (!visualOnly) {
          const token = String(source?.placeholderToken || '').trim();
          if (token) placeholderMap[effectiveId] = token;
        }
      });

      return {
        schema: {
          version: Number(schemaVersionInput.value || 1) || 1,
          fields
        },
        placeholderMap
      };
    }

    function updateFieldEditorOptionsVisibility() {
      const type = normalizeFieldType(fieldEditorTypeInput?.value || 'text');
      const visualOnly = isVisualOnlyType(type);
      const calculatedMode = !visualOnly && fieldEditorCalculatedEnabledInput?.checked === true;
      if (fieldEditorOptionsWrap) fieldEditorOptionsWrap.style.display = (type === 'select' && !visualOnly) ? '' : 'none';
      if (fieldEditorPrefillInput) fieldEditorPrefillInput.disabled = visualOnly;
      if (fieldEditorPlaceholderInput) fieldEditorPlaceholderInput.disabled = visualOnly;
      if (fieldEditorRequiredInput) fieldEditorRequiredInput.disabled = visualOnly || calculatedMode;
      if (fieldEditorReadonlyInput) fieldEditorReadonlyInput.disabled = visualOnly || calculatedMode;
      if (fieldEditorFullWidthInput) fieldEditorFullWidthInput.disabled = visualOnly;
      if (fieldEditorBorderInput) fieldEditorBorderInput.disabled = visualOnly;
      if (fieldEditorBackgroundColorInput) fieldEditorBackgroundColorInput.disabled = visualOnly;
      if (fieldEditorValidationRulesInput) fieldEditorValidationRulesInput.disabled = visualOnly;
      if (fieldEditorConversionEnabledInput) fieldEditorConversionEnabledInput.disabled = visualOnly;
      if (fieldEditorConversionExpressionInput) fieldEditorConversionExpressionInput.disabled = visualOnly;
      if (fieldEditorConversionOnErrorInput) fieldEditorConversionOnErrorInput.disabled = visualOnly;
      if (fieldEditorCalculatedEnabledInput) fieldEditorCalculatedEnabledInput.disabled = visualOnly;
      if (fieldEditorCalculationExpressionInput) fieldEditorCalculationExpressionInput.disabled = visualOnly || !calculatedMode;
      if (fieldEditorCalculationOnErrorInput) fieldEditorCalculationOnErrorInput.disabled = visualOnly || !calculatedMode;
      if (fieldEditorCalculationDependenciesInput) fieldEditorCalculationDependenciesInput.disabled = visualOnly || !calculatedMode;
      if (fieldEditorCalculationFieldList) fieldEditorCalculationFieldList.disabled = visualOnly || !calculatedMode;
      if (insertCalcFieldFormulaBtn) insertCalcFieldFormulaBtn.disabled = visualOnly || !calculatedMode;
      if (addCalcFieldDependencyBtn) addCalcFieldDependencyBtn.disabled = visualOnly || !calculatedMode;
      if (visualOnly) {
        fieldEditorPrefillInput.value = '';
        fieldEditorPlaceholderInput.value = '';
        fieldEditorRequiredInput.checked = false;
        fieldEditorReadonlyInput.checked = false;
        fieldEditorFullWidthInput.checked = true;
        fieldEditorBorderInput.checked = false;
        fieldEditorBackgroundColorInput.value = '#ffffff';
        fieldEditorBackgroundColorInput.setAttribute('data-cleared', '1');
        fieldEditorOptionsInput.value = '';
        fieldEditorValidationRulesInput.value = '';
        fieldEditorConversionEnabledInput.checked = false;
        fieldEditorConversionExpressionInput.value = '';
        fieldEditorConversionOnErrorInput.value = 'use_raw';
        fieldEditorCalculatedEnabledInput.checked = false;
        fieldEditorCalculationExpressionInput.value = '';
        fieldEditorCalculationOnErrorInput.value = CALC_ON_ERROR.KEEP_LAST;
        fieldEditorCalculationDependenciesInput.value = '';
      }
      if (calculatedMode) {
        fieldEditorRequiredInput.checked = false;
        fieldEditorReadonlyInput.checked = true;
      }
    }

    function openFieldEditor(index = -1) {
      editingIndex = Number.isInteger(index) ? index : -1;
      const source = editingIndex >= 0 ? fieldsState[editingIndex] : defaultField();
      const field = normalizeField(source || {});

      fieldEditorTitle.textContent = editingIndex >= 0 ? `Edit Field: ${field.id || field.label || ''}` : 'Add Field';
      fieldEditorIdInput.value = field.id || '';
      fieldEditorLabelInput.value = field.label || '';
      fieldEditorTypeInput.value = normalizeFieldType(field.type);
      fieldEditorPrefillInput.value = field.prefillKey || '';
      fieldEditorPlaceholderInput.value = field.placeholderToken || '';
      fieldEditorOptionsInput.value = toOptionsCsv(field.options);
      fieldEditorHelpInput.value = field.helpText || '';
      fieldEditorValidationRulesInput.value = toValidationRulesJson(field.validationRules);
      fieldEditorConversionEnabledInput.checked = field?.conversionRule?.enabled === true;
      fieldEditorConversionExpressionInput.value = String(field?.conversionRule?.expression || '').trim();
      fieldEditorConversionOnErrorInput.value = String(field?.conversionRule?.onError || 'use_raw').trim().toLowerCase() === 'empty' ? 'empty' : 'use_raw';
      fieldEditorCalculatedEnabledInput.checked = String(field?.valueMode || VALUE_MODES.MANUAL) === VALUE_MODES.CALCULATED;
      fieldEditorCalculationExpressionInput.value = String(field?.calculationRule?.expression || '').trim();
      fieldEditorCalculationOnErrorInput.value = String(field?.calculationRule?.onError || CALC_ON_ERROR.KEEP_LAST).trim().toLowerCase() === CALC_ON_ERROR.EMPTY ? CALC_ON_ERROR.EMPTY : CALC_ON_ERROR.KEEP_LAST;
      fieldEditorCalculationDependenciesInput.value = normalizeCalculationDependencies(field?.calculationDependencies || []).join(', ');
      fieldEditorRequiredInput.checked = field.required === true;
      fieldEditorReadonlyInput.checked = field.readOnly === true;
      fieldEditorSharedInput.checked = field.sharedAcrossStudents === true;
      fieldEditorFullWidthInput.checked = field.fullPageWidth === true;
      fieldEditorBorderInput.checked = field.hasBorder === true;
      const normalizedBg = normalizeHexColor(field.backgroundColor);
      fieldEditorBackgroundColorInput.value = normalizedBg || '#ffffff';
      fieldEditorBackgroundColorInput.setAttribute('data-cleared', normalizedBg ? '0' : '1');
      refreshCalculationFieldList();
      updateFieldEditorOptionsVisibility();

      if (window.bootstrap && window.bootstrap.Modal && fieldEditorModalEl) {
        window.bootstrap.Modal.getOrCreateInstance(fieldEditorModalEl).show();
      }
    }

    function closeFieldEditor() {
      if (window.bootstrap && window.bootstrap.Modal && fieldEditorModalEl) {
        window.bootstrap.Modal.getOrCreateInstance(fieldEditorModalEl).hide();
      }
    }

    function buildUniqueDuplicateId(baseId) {
      const rawBase = String(baseId || 'field').trim() || 'field';
      let candidate = `${rawBase}_copy`;
      const used = new Set(fieldsState.map((f) => String(f.id || '').toLowerCase()));
      if (!used.has(candidate.toLowerCase())) return candidate;
      let i = 2;
      while (used.has(`${candidate}_${i}`.toLowerCase())) i += 1;
      return `${candidate}_${i}`;
    }

    function saveFieldEditor() {
      const id = String(fieldEditorIdInput.value || '').trim();
      const label = String(fieldEditorLabelInput.value || '').trim();
      const type = normalizeFieldType(fieldEditorTypeInput.value || 'text');
      const prefillKey = String(fieldEditorPrefillInput.value || '').trim();
      let placeholderToken = String(fieldEditorPlaceholderInput.value || '').trim();
      const helpText = String(fieldEditorHelpInput.value || '').trim();
      const required = fieldEditorRequiredInput.checked === true;
      const readOnly = fieldEditorReadonlyInput.checked === true;
      const sharedAcrossStudents = fieldEditorSharedInput.checked === true;
      const fullPageWidth = fieldEditorFullWidthInput.checked === true;
      const hasBorder = fieldEditorBorderInput.checked === true;
      const backgroundColorInput = String(fieldEditorBackgroundColorInput.value || '').trim();
      const backgroundCleared = String(fieldEditorBackgroundColorInput.getAttribute('data-cleared') || '') === '1';
      const backgroundColor = backgroundCleared ? '' : normalizeHexColor(backgroundColorInput);
      const options = type === 'select' ? parseOptionsCsv(fieldEditorOptionsInput.value) : [];
      const visualOnly = isVisualOnlyType(type);
      const calculatedEnabled = !visualOnly && fieldEditorCalculatedEnabledInput.checked === true;
      const calculationExpression = String(fieldEditorCalculationExpressionInput.value || '').trim();
      const calculationOnError = String(fieldEditorCalculationOnErrorInput.value || CALC_ON_ERROR.KEEP_LAST).trim().toLowerCase() === CALC_ON_ERROR.EMPTY ? CALC_ON_ERROR.EMPTY : CALC_ON_ERROR.KEEP_LAST;
      const calculationDependencies = calculatedEnabled
        ? normalizeCalculationDependencies(fieldEditorCalculationDependenciesInput.value)
        : [];
      let validationRules = [];
      try {
        validationRules = visualOnly ? [] : parseValidationRulesJson(fieldEditorValidationRulesInput.value);
      } catch (err) {
        showReportModal({ title: 'Invalid Validation Rules', icon: 'warning', message: String(err.message || 'Validation rule JSON is invalid.') });
        return;
      }
      const conversionEnabled = fieldEditorConversionEnabledInput.checked === true;
      const conversionExpression = String(fieldEditorConversionExpressionInput.value || '').trim();
      const conversionOnError = String(fieldEditorConversionOnErrorInput.value || 'use_raw').trim().toLowerCase() === 'empty' ? 'empty' : 'use_raw';
      if (!visualOnly && conversionEnabled && !conversionExpression) {
        showReportModal({ title: 'Invalid Conversion Rule', icon: 'warning', message: 'Conversion expression is required when conversion is enabled.' });
        return;
      }
      if (!visualOnly && conversionExpression.length > 240) {
        showReportModal({ title: 'Invalid Conversion Rule', icon: 'warning', message: 'Conversion expression must be 240 characters or less.' });
        return;
      }
      if (calculatedEnabled && !calculationExpression) {
        showReportModal({ title: 'Invalid Calculated Field', icon: 'warning', message: 'Calculation expression is required when calculated mode is enabled.' });
        return;
      }
      if (calculatedEnabled && calculationDependencies.length === 0) {
        showReportModal({ title: 'Invalid Calculated Field', icon: 'warning', message: 'At least one dependency is required for calculated fields.' });
        return;
      }
      const effectiveId = visualOnly ? (id || buildAutoVisualId(type, label, editingIndex)) : id;

      if (!label || (!visualOnly && !effectiveId)) {
        showReportModal({ title: 'Missing Data', icon: 'warning', message: visualOnly ? 'Label is required.' : 'Field ID and Label are required.' });
        return;
      }
      if (!/^[A-Za-z0-9:_-]+$/.test(effectiveId)) {
        showReportModal({ title: 'Invalid Field ID', icon: 'warning', message: 'Field ID format is invalid. Use letters, numbers, `_`, `-`, `:` only.' });
        return;
      }
      if (calculatedEnabled) {
        const selfConflict = calculationDependencies.some((dep) => String(dep || '').trim().toLowerCase() === String(effectiveId || '').trim().toLowerCase());
        if (selfConflict) {
          showReportModal({ title: 'Invalid Calculated Field', icon: 'warning', message: 'Calculated field cannot depend on itself.' });
          return;
        }
        const knownFieldIds = new Set(
          fieldsState
            .map((field, idx) => (idx === editingIndex ? '' : String(field?.id || '').trim()))
            .filter(Boolean)
            .map((fieldId) => fieldId.toLowerCase())
        );
        const unknownDep = calculationDependencies.find((dep) => !knownFieldIds.has(String(dep || '').trim().toLowerCase()));
        if (unknownDep) {
          showReportModal({ title: 'Invalid Calculated Field', icon: 'warning', message: `Dependency "${unknownDep}" does not exist in current field list.` });
          return;
        }
      }
      if (!visualOnly && type === 'select' && options.length === 0) {
        showReportModal({ title: 'Options Required', icon: 'warning', message: 'Select fields must define at least one option.' });
        return;
      }

      const duplicateIndex = fieldsState.findIndex((field, idx) => idx !== editingIndex && String(field.id || '').toLowerCase() === effectiveId.toLowerCase());
      if (duplicateIndex !== -1) {
        showReportModal({ title: 'Duplicate Field ID', icon: 'warning', message: `Field ID "${effectiveId}" is already used.` });
        return;
      }

      if (!visualOnly && !placeholderToken) placeholderToken = `{{${effectiveId}}}`;
      const nextField = normalizeField({
        id: effectiveId,
        label,
        type,
        prefillKey: visualOnly ? '' : prefillKey,
        placeholderToken: visualOnly ? '' : placeholderToken,
        helpText,
        required: visualOnly ? false : required,
        readOnly: visualOnly ? false : (calculatedEnabled ? true : readOnly),
        sharedAcrossStudents,
        fullPageWidth: visualOnly ? true : fullPageWidth,
        valueMode: visualOnly ? VALUE_MODES.MANUAL : (calculatedEnabled ? VALUE_MODES.CALCULATED : VALUE_MODES.MANUAL),
        calculationRule: visualOnly
          ? { enabled: false, expression: '', onError: CALC_ON_ERROR.KEEP_LAST }
          : (calculatedEnabled
            ? {
                enabled: true,
                expression: calculationExpression,
                onError: calculationOnError
              }
            : {
                enabled: false,
                expression: '',
                onError: CALC_ON_ERROR.KEEP_LAST
              }),
        calculationDependencies: visualOnly ? [] : (calculatedEnabled ? calculationDependencies : []),
        hasBorder: visualOnly ? false : hasBorder,
        backgroundColor: visualOnly ? '' : backgroundColor,
        options: visualOnly ? [] : options,
        validationRules: visualOnly ? [] : validationRules,
        conversionRule: visualOnly
          ? { enabled: false, expression: '', onError: 'use_raw' }
          : {
              enabled: conversionEnabled,
              expression: conversionExpression,
              onError: conversionOnError
            }
      });

      if (editingIndex >= 0) fieldsState[editingIndex] = nextField;
      else fieldsState.push(nextField);

      renderFieldRows();
      closeFieldEditor();
    }

    function buildPreviewControlHtml(field) {
      const type = String(field.type || 'text').toLowerCase();
      const prefillHint = field.prefillKey ? `[Prefill: ${field.prefillKey}]` : '';
      const valueHint = prefillHint || (type === 'checkbox' ? '' : 'Sample value');
      const options = Array.isArray(field.options) ? field.options : [];
      const calculatedMode = String(field.valueMode || VALUE_MODES.MANUAL) === VALUE_MODES.CALCULATED;

      if (field.readOnly || calculatedMode) {
        if (type === 'textarea') {
          return `<textarea class="form-control bg-light" rows="3" readonly>${escapeHtml(valueHint)}</textarea>`;
        }
        if (type === 'number') {
          return `<input type="number" class="form-control bg-light" value="0" readonly>`;
        }
        if (type === 'date') {
          return `<input type="date" class="form-control bg-light" value="" readonly>`;
        }
        if (type === 'checkbox') {
          return `
            <div class="form-check border rounded p-2 bg-light">
              <input type="checkbox" class="form-check-input" checked disabled>
              <label class="form-check-label">Checked</label>
            </div>
          `;
        }
        if (type === 'select') {
          const selectOpts = options.map((opt) => `<option value="${escapeHtml(opt.value || '')}">${escapeHtml(opt.label || opt.value || '')}</option>`).join('');
          return `<select class="form-select bg-light" disabled><option value="">Select...</option>${selectOpts}</select>`;
        }
        return `<input type="text" class="form-control bg-light" value="${escapeHtml(valueHint)}" readonly>`;
      }

      if (type === 'textarea') {
        return `<textarea class="form-control" rows="3" placeholder="Enter ${escapeHtml(field.label || 'value')}"></textarea>`;
      }
      if (type === 'number') {
        return `<input type="number" class="form-control" placeholder="Enter ${escapeHtml(field.label || 'value')}">`;
      }
      if (type === 'date') {
        return `<input type="date" class="form-control">`;
      }
      if (type === 'checkbox') {
        return `
          <div class="form-check border rounded p-2">
            <input type="checkbox" class="form-check-input">
            <label class="form-check-label">Checked</label>
          </div>
        `;
      }
      if (type === 'select') {
        const selectOpts = options.map((opt) => `<option value="${escapeHtml(opt.value || '')}">${escapeHtml(opt.label || opt.value || '')}</option>`).join('');
        return `<select class="form-select"><option value="">Select...</option>${selectOpts}</select>`;
      }
      return `<input type="text" class="form-control" placeholder="Enter ${escapeHtml(field.label || 'value')}">`;
    }

    function buildPreviewFieldHtml(field) {
      const visualOnly = isVisualOnlyType(field.type);
      if (visualOnly) {
        if (field.type === 'row_break') return '';
        const headerTag = field.type === 'section' ? 'h5' : 'h6';
        const className = field.type === 'section' ? 'fw-bold mt-2 mb-1' : 'fw-semibold mt-1 mb-1 text-muted';
        const helpHtml = field.helpText ? `<div class="small text-muted mb-2">${escapeHtml(field.helpText)}</div>` : '';
        return `
          <div class="col-12">
            <${headerTag} class="${className}">${escapeHtml(field.label || 'Untitled')}</${headerTag}>
            ${helpHtml}
          </div>
        `;
      }
      const badges = [
        field.required ? '<span class="badge bg-danger-subtle text-danger border ms-1">Required</span>' : '',
        field.readOnly ? '<span class="badge bg-light text-secondary border ms-1">View only</span>' : '',
        field.sharedAcrossStudents ? '<span class="badge bg-info-subtle text-info-emphasis border ms-1">Shared</span>' : '',
        field.fullPageWidth ? '<span class="badge bg-primary-subtle text-primary-emphasis border ms-1">Full width</span>' : '',
        String(field.valueMode || VALUE_MODES.MANUAL) === VALUE_MODES.CALCULATED ? '<span class="badge bg-warning-subtle text-warning-emphasis border ms-1">Auto-calculated</span>' : '',
        field.hasBorder ? '<span class="badge bg-secondary-subtle text-secondary-emphasis border ms-1">Border</span>' : '',
        field.backgroundColor ? `<span class="badge border ms-1" style="background-color:${escapeHtml(field.backgroundColor)};">Back color</span>` : ''
      ].filter(Boolean).join('');
      const helpHtml = field.helpText ? `<div class="small text-muted mt-1">${escapeHtml(field.helpText)}</div>` : '';
      const prefillHtml = field.prefillKey
        ? `<div class="small text-muted mt-1">Prefill key: <span class="font-monospace">${escapeHtml(field.prefillKey)}</span></div>`
        : '';
      const fieldCardClass = field.hasBorder ? 'border rounded p-2' : '';
      const fieldCardStyle = field.backgroundColor ? ` style="background-color:${escapeHtml(field.backgroundColor)};"` : '';

      return `
        <div class="${field.fullPageWidth ? 'col-12' : 'col'}">
          <div class="${fieldCardClass}"${fieldCardStyle}>
            <label class="form-label fw-bold">
              ${escapeHtml(field.label || field.id || 'Field')}
              ${badges}
            </label>
            ${buildPreviewControlHtml(field)}
            ${prefillHtml}
            ${helpHtml}
          </div>
        </div>
      `;
    }

    function buildPreviewRowsHtml(fields) {
      const rows = [];
      let current = [];
      const list = Array.isArray(fields) ? fields : [];

      const flushCurrent = () => {
        if (!current.length) return;
        rows.push({ items: [...current] });
        current = [];
      };

      list.forEach((field) => {
        const type = String(field?.type || '').trim().toLowerCase();
        const isRowBreak = type === 'row_break';
        const isSectionLike = type === 'section' || type === 'subheader';
        const isFullWidth = field?.fullPageWidth === true || String(field?.fullPageWidth || '').toLowerCase() === 'true';

        if (isRowBreak) {
          flushCurrent();
          return;
        }
        if (isSectionLike || isFullWidth) {
          flushCurrent();
          rows.push({ items: [field] });
          return;
        }
        current.push(field);
      });

      flushCurrent();
      return rows.map((row) => {
        const cols = row.items.map((field) => buildPreviewFieldHtml(field)).join('');
        return `<div class="row g-3 mb-4">${cols}</div>`;
      }).join('');
    }

    function buildPreviewSectionHtml(title, subtitle, fields) {
      const list = Array.isArray(fields) ? fields : [];
      if (!list.length) return '';
      const rows = buildPreviewRowsHtml(list);
      return `
        <div class="mb-4">
          <h6 class="fw-bold mb-1">${escapeHtml(title)}</h6>
          ${subtitle ? `<div class="small text-muted mb-3">${escapeHtml(subtitle)}</div>` : ''}
          ${rows}
        </div>
      `;
    }

    function openPreviewModal() {
      const payload = collect();
      const fields = Array.isArray(payload?.schema?.fields) ? payload.schema.fields : [];
      if (!fields.length) {
        showReportModal({ title: 'Field Required', icon: 'warning', message: 'Add at least one field to preview the report form.' });
        return;
      }

      const sharedCount = fields.filter((field) => field.sharedAcrossStudents === true).length;
      const formTitle = String(form.querySelector('input[name="title"]')?.value || '').trim();
      previewTitle.textContent = formTitle ? `${formTitle} - Form Preview` : 'Report Form Preview';
      previewBody.innerHTML = `
        <div class="alert alert-light border small mb-3">
          Preview of how users will see and fill this report template. Fields are shown in the exact order of the Field Designer list.
        </div>
        ${sharedCount ? `<div class="small text-muted mb-2"><span class="badge bg-info-subtle text-info-emphasis border me-1">Shared</span>${sharedCount} field(s) are marked shared and are still shown below in their original order.</div>` : ''}
        ${buildPreviewSectionHtml('Report Fields', '', fields)}
      `;

      if (window.bootstrap && window.bootstrap.Modal && previewModalEl) {
        window.bootstrap.Modal.getOrCreateInstance(previewModalEl).show();
      }
    }

    function clearDragOverStyles() {
      tbody.querySelectorAll('.field-row-dragover').forEach((row) => row.classList.remove('field-row-dragover'));
    }

    addBtn.addEventListener('click', () => openFieldEditor(-1));
    clearFieldEditorBackgroundColorBtn?.addEventListener('click', () => {
      if (fieldEditorBackgroundColorInput) {
        fieldEditorBackgroundColorInput.value = '#ffffff';
        fieldEditorBackgroundColorInput.setAttribute('data-cleared', '1');
      }
    });
    fieldEditorBackgroundColorInput?.addEventListener('input', () => {
      fieldEditorBackgroundColorInput.setAttribute('data-cleared', '0');
    });
    addSectionBtn?.addEventListener('click', () => {
      const next = defaultField();
      next.type = 'section';
      next.label = 'New Section';
      fieldsState.push(normalizeField(next));
      renderFieldRows();
    });
    addSubheaderBtn?.addEventListener('click', () => {
      const next = defaultField();
      next.type = 'subheader';
      next.label = 'New Subheader';
      fieldsState.push(normalizeField(next));
      renderFieldRows();
    });
    addRowBreakBtn?.addEventListener('click', () => {
      const next = defaultField();
      next.type = 'row_break';
      next.label = 'New Row';
      fieldsState.push(normalizeField(next));
      renderFieldRows();
    });
    previewBtn?.addEventListener('click', openPreviewModal);
    btnValidationHelp?.addEventListener('click', () => openExpressionHelp('validation'));
    btnConversionHelp?.addEventListener('click', () => openExpressionHelp('conversion'));
    fieldEditorTypeInput?.addEventListener('change', updateFieldEditorOptionsVisibility);
    fieldEditorCalculatedEnabledInput?.addEventListener('change', updateFieldEditorOptionsVisibility);
    insertCalcFieldFormulaBtn?.addEventListener('click', () => {
      const selected = String(fieldEditorCalculationFieldList?.value || '').trim();
      if (!selected) return;
      insertTextAtCursor(fieldEditorCalculationExpressionInput, `answers.${selected}`);
    });
    addCalcFieldDependencyBtn?.addEventListener('click', () => {
      const selected = String(fieldEditorCalculationFieldList?.value || '').trim();
      if (!selected) return;
      appendCalculationDependency(selected);
    });
    fieldEditorCalculationFieldList?.addEventListener('dblclick', () => {
      const selected = String(fieldEditorCalculationFieldList?.value || '').trim();
      if (!selected) return;
      insertTextAtCursor(fieldEditorCalculationExpressionInput, `answers.${selected}`);
    });
    saveFieldEditorBtn?.addEventListener('click', saveFieldEditor);

    fieldEditorIdInput?.addEventListener('input', () => {
      const current = String(fieldEditorPlaceholderInput.value || '').trim();
      if (!current || /^\{\{.*\}\}$/.test(current)) {
        const id = String(fieldEditorIdInput.value || '').trim();
        fieldEditorPlaceholderInput.value = id ? `{{${id}}}` : '';
      }
      refreshCalculationFieldList();
    });

    tbody.addEventListener('click', async (e) => {
      const actionBtn = e.target.closest('.js-field-action');
      if (!actionBtn) return;
      const action = String(actionBtn.getAttribute('data-action') || '').trim().toLowerCase();
      const index = Number(actionBtn.getAttribute('data-index'));
      if (!Number.isInteger(index) || index < 0 || index >= fieldsState.length) return;

      if (action === 'edit') {
        openFieldEditor(index);
        return;
      }
      if (action === 'duplicate') {
        const source = normalizeField(fieldsState[index]);
        const duplicate = normalizeField({
          ...source,
          id: buildUniqueDuplicateId(source.id),
          label: `${source.label} (Copy)`,
          placeholderToken: source.placeholderToken
        });
        fieldsState.splice(index + 1, 0, duplicate);
        renderFieldRows();
        return;
      }
      if (action === 'delete') {
        const fieldName = String(fieldsState[index].label || fieldsState[index].id || 'this field').trim();
        const ok = await confirmReportModal({
          title: 'Delete Field?',
          icon: 'warning',
          message: `Delete <b>${escapeHtml(fieldName)}</b> from this template?`,
          confirmText: 'Delete',
          confirmClass: 'btn-danger',
          cancelText: 'Cancel',
          fallbackMessage: `Delete "${fieldName}" from this template?`
        });
        if (!ok) return;
        fieldsState.splice(index, 1);
        renderFieldRows();
      }
    });

    tbody.addEventListener('dragstart', (e) => {
      const row = e.target.closest('tr[data-index]');
      if (!row) return;
      dragIndex = Number(row.getAttribute('data-index'));
      row.classList.add('opacity-50');
      if (e.dataTransfer) {
        e.dataTransfer.effectAllowed = 'move';
        try { e.dataTransfer.setData('text/plain', String(dragIndex)); } catch (_) {}
      }
    });

    tbody.addEventListener('dragend', (e) => {
      const row = e.target.closest('tr[data-index]');
      if (row) row.classList.remove('opacity-50');
      dragIndex = -1;
      clearDragOverStyles();
    });

    tbody.addEventListener('dragover', (e) => {
      const row = e.target.closest('tr[data-index]');
      if (!row) return;
      e.preventDefault();
      clearDragOverStyles();
      row.classList.add('field-row-dragover');
    });

    tbody.addEventListener('dragleave', (e) => {
      const row = e.target.closest('tr[data-index]');
      if (row) row.classList.remove('field-row-dragover');
    });

    tbody.addEventListener('drop', (e) => {
      const row = e.target.closest('tr[data-index]');
      if (!row) return;
      e.preventDefault();
      clearDragOverStyles();
      const dropIndex = Number(row.getAttribute('data-index'));
      const fromIndex = Number.isInteger(dragIndex) ? dragIndex : Number.NaN;
      if (!Number.isInteger(fromIndex) || fromIndex < 0 || fromIndex >= fieldsState.length) return;
      if (!Number.isInteger(dropIndex) || dropIndex < 0 || dropIndex >= fieldsState.length) return;
      if (fromIndex === dropIndex) return;

      const moved = fieldsState.splice(fromIndex, 1)[0];
      const targetIndex = Math.min(dropIndex, fieldsState.length);
      fieldsState.splice(targetIndex, 0, moved);
      renderFieldRows();
    });

    document.querySelectorAll('.btn-copy-key').forEach((button) => {
      button.addEventListener('click', async () => {
        const value = String(
          button.getAttribute('data-copy-token')
          || button.getAttribute('data-copy-value')
          || ''
        ).trim();
        if (!value) return;
        try {
          const copied = await copyText(value);
          if (!copied) return;
          const oldHtml = button.innerHTML;
          button.innerHTML = '<i class="bi bi-check2"></i>';
          setTimeout(() => { button.innerHTML = oldHtml; }, 1000);
        } catch (_) {
          // ignore clipboard errors quietly
        }
      });
    });
    function setAccordionPanelShown(panel, shouldShow) {
      if (!panel) return;
      if (window.bootstrap && window.bootstrap.Collapse) {
        window.bootstrap.Collapse.getOrCreateInstance(panel, { toggle: false })[shouldShow ? 'show' : 'hide']();
      } else {
        panel.classList.toggle('show', shouldShow);
      }
    }

    function applyPrefillFilter() {
      const q = String(prefillSearchInput.value || '').trim().toLowerCase();
      const accordion = document.getElementById('prefillCatalogAccordion');
      const parentSelector = accordion ? `#${accordion.id}` : '';
      document.querySelectorAll('#prefillCatalogAccordion .accordion-item').forEach((group) => {
        const panel = group.querySelector('.accordion-collapse');
        const button = group.querySelector('.accordion-button');
        const items = Array.from(group.querySelectorAll('.prefill-item'));
        let hasMatch = false;
        items.forEach((item) => {
          const txt = String(item.textContent || '').toLowerCase();
          const matched = !q || txt.includes(q);
          item.style.display = matched ? '' : 'none';
          if (matched) hasMatch = true;
        });
        group.style.display = hasMatch ? '' : 'none';
        if (q) {
          if (panel) {
            panel.classList.toggle('show', hasMatch);
            panel.removeAttribute('data-bs-parent');
          }
          if (button) {
            button.classList.toggle('collapsed', !hasMatch);
            button.setAttribute('aria-expanded', hasMatch ? 'true' : 'false');
          }
        } else if (panel && parentSelector) {
          panel.setAttribute('data-bs-parent', parentSelector);
        }
      });
    }

    function buildPrefillExportRows() {
      const payload = collect();
      const fields = Array.isArray(payload?.schema?.fields) ? payload.schema.fields : [];
      const placeholderMap = payload?.placeholderMap && typeof payload.placeholderMap === 'object'
        ? payload.placeholderMap
        : {};
      return fields
        .filter((field) => !isVisualOnlyType(field?.type))
        .map((field) => {
          const fieldId = String(field?.id || '').trim();
          const label = String(field?.label || fieldId || '').trim();
          const prefillKey = String(field?.prefillKey || '').trim();
          const rawToken = String(placeholderMap[fieldId] || '').trim();
          const token = rawToken || (fieldId ? `{{${fieldId}}}` : '');
          const key = token
            .replace(/^\{\{\s*/, '')
            .replace(/\s*\}\}$/, '')
            .trim() || fieldId;
          return {
            key,
            label,
            fieldId,
            prefillKey,
            docxToken: token
          };
        })
        .filter((row) => row.key && row.label)
        .sort((a, b) => String(a.key || '').localeCompare(String(b.key || '')));
    }

    function downloadTextFile(filename, text, mimeType) {
      const blob = new Blob([String(text || '')], { type: mimeType || 'text/plain;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const anchor = document.createElement('a');
      anchor.href = url;
      anchor.download = filename;
      document.body.appendChild(anchor);
      anchor.click();
      anchor.remove();
      setTimeout(() => URL.revokeObjectURL(url), 0);
    }

    function buildCsvValue(value) {
      const text = String(value || '');
      return `"${text.replace(/"/g, '""')}"`;
    }

    async function exportPrefillRows(format) {
      const rows = buildPrefillExportRows();
      if (!rows.length) {
        await showReportModal({ title: 'No Keys Found', icon: 'warning', message: 'No template keys are available to export yet. Add fields first.' });
        return;
      }
      const stamp = new Date().toISOString().slice(0, 10);
      if (format === 'csv') {
        const header = ['key', 'label', 'docxToken', 'fieldId', 'prefillKey'];
        const csvLines = [header.join(',')];
        rows.forEach((row) => {
          csvLines.push([
            buildCsvValue(row.key),
            buildCsvValue(row.label),
            buildCsvValue(row.docxToken),
            buildCsvValue(row.fieldId),
            buildCsvValue(row.prefillKey)
          ].join(','));
        });
        downloadTextFile(`report-template-keys-${stamp}.csv`, csvLines.join('\n'), 'text/csv;charset=utf-8');
        return;
      }
      downloadTextFile(`report-template-keys-${stamp}.json`, JSON.stringify(rows, null, 2), 'application/json;charset=utf-8');
    }

    prefillSearchInput?.addEventListener('input', applyPrefillFilter);
    btnExpandPrefill?.addEventListener('click', () => {
      document.querySelectorAll('#prefillCatalogAccordion .accordion-collapse').forEach((panel) => {
        setAccordionPanelShown(panel, true);
      });
    });
    btnCollapsePrefill?.addEventListener('click', () => {
      document.querySelectorAll('#prefillCatalogAccordion .accordion-collapse').forEach((panel) => {
        setAccordionPanelShown(panel, false);
      });
    });
    btnExportPrefillJson?.addEventListener('click', () => exportPrefillRows('json'));
    btnExportPrefillCsv?.addEventListener('click', () => exportPrefillRows('csv'));
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const payload = collect();
      if (!payload.schema.fields.length) {
        showReportModal({ title: 'Field Required', icon: 'warning', message: 'Add at least one field before saving the template.' });
        return;
      }
      schemaJsonInput.value = JSON.stringify(payload.schema);
      placeholderMapJsonInput.value = JSON.stringify(payload.placeholderMap);

      const submitter = e.submitter || form.querySelector('button[type="submit"]');
      const originalHtml = submitter ? submitter.innerHTML : '';
      if (submitter) {
        submitter.disabled = true;
        submitter.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Saving...';
      }

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          headers: { 'X-Requested-With': 'XMLHttpRequest' },
          body: new FormData(form)
        });

        let result = null;
        try { result = await response.json(); } catch (_) { result = null; }
        if (!response.ok || result?.status !== 'success') {
          const reason = String(result?.message || `Save failed (HTTP ${response.status}).`).trim();
          await showReportModal({ title: 'Save Failed', icon: 'error', message: reason, buttonClass: 'btn-danger' });
          return;
        }

        await showReportModal({
          title: 'Saved',
          icon: 'success',
          message: String(result?.message || 'Template saved successfully.'),
          buttonClass: 'btn-success'
        });

        // Keep existing flow after successful save.
        if (isEditMode) window.location.href = '/school/reports/templates';
        else window.location.href = '/school/reports/templates';
      } catch (error) {
        await showReportModal({
          title: 'Save Failed',
          icon: 'error',
          message: String(error?.message || 'Unexpected error while saving template.'),
          buttonClass: 'btn-danger'
        });
      } finally {
        if (submitter) {
          submitter.disabled = false;
          submitter.innerHTML = originalHtml;
        }
      }
    });

    initializeState();
    renderFieldRows();
    applyPrefillFilter();
  })();
</script>
