                  <label class="form-label mb-0 small" for="fieldEditorBackgroundColor">Back color</label>
                  <input class="form-control form-control-color p-1" type="color" id="fieldEditorBackgroundColor" value="#ffffff" title="Back color" data-cleared="1">
                  <button type="button" class="btn btn-sm btn-outline-secondary" id="btnFieldEditorClearBackgroundColor">Clear</button>
