            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold">Placeholder Token</label>
              <input type="text" class="form-control" id="fieldEditorPlaceholder" maxlength="180" placeholder="{{teacher_name}}">
            </div>

            <div class="col-12" id="fieldEditorOptionsWrap">
              <label class="form-label fw-bold">Options (for select)</label>
              <textarea class="form-control" id="fieldEditorOptions" rows="3" placeholder="Excellent, Good, Needs Improvement"></textarea>
              <div class="form-text">Comma-separated values. The same text will be used for both value and label.</div>
            </div>

            <div class="col-12">
              <label class="form-label fw-bold">Help Text</label>
              <textarea class="form-control" id="fieldEditorHelp" rows="2" maxlength="400" placeholder="Optional helper text shown to users"></textarea>
            </div>

            <div class="col-12">
              <div class="d-flex align-items-center justify-content-between">
                <label class="form-label fw-bold mb-1">Validation Rules (JSON Array)</label>
                <button type="button" class="btn btn-sm btn-outline-info" id="btnValidationHelp"><i class="bi bi-question-circle me-1"></i>Validation Help</button>
              </div>
              <textarea class="form-control font-monospace" id="fieldEditorValidationRules" rows="5" placeholder='[{"id":"range_check","enabled":true,"severity":"error","when":"if_has_value","expression":"num(value) >= 0 && num(value) <= 100","message":"Value must be between 0 and 100."}]'></textarea>
              <div class="form-text">Each rule supports: <code>id</code>, <code>enabled</code>, <code>severity</code> (error/warning), <code>when</code> (always/if_has_value), <code>expression</code>, <code>message</code>.</div>
            </div>

            <div class="col-12">
              <div class="d-flex align-items-center justify-content-between">
                <label class="form-label fw-bold mb-1">Conversion Rule (Export Only)</label>
                <button type="button" class="btn btn-sm btn-outline-info" id="btnConversionHelp"><i class="bi bi-question-circle me-1"></i>Conversion Help</button>
              </div>
              <div class="row g-2">
                <div class="col-md-2">
                  <div class="form-check mt-2">
                    <input class="form-check-input" type="checkbox" id="fieldEditorConversionEnabled">
                    <label class="form-check-label" for="fieldEditorConversionEnabled">Enable</label>
                  </div>
                </div>
