                  <textarea class="form-control font-monospace" id="fieldEditorCalculationExpression" rows="3" placeholder="round(num(answers.part_a) + num(answers.part_b), 2)"></textarea>
                </div>
                <div class="col-md-4">
                  <select class="form-select" id="fieldEditorCalculationOnError">
                    <option value="keep_last">On error: keep last value</option>
                    <option value="empty">On error: blank value</option>
