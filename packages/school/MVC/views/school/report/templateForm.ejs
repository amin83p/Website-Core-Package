              <div class="mt-2">
                <label class="form-label fw-bold mb-1">Dependencies (comma-separated field IDs)</label>
                <textarea class="form-control font-monospace" id="fieldEditorCalculationDependencies" rows="2" placeholder="part_a, part_b"></textarea>
