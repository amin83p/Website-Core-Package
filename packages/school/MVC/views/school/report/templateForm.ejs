                <div class="form-check m-0">
                  <input class="form-check-input" type="checkbox" id="fieldEditorShared">
                  <label class="form-check-label" for="fieldEditorShared">Shared across students</label>
                </div>
                <div class="form-check m-0">
                  <input class="form-check-input" type="checkbox" id="fieldEditorFullWidth">
