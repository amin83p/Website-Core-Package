<%
  const fields = Array.isArray(template?.schema?.fields) ? template.schema.fields : [];
  const reportScopeToken = String(assignment?.reportScope || '').trim().toLowerCase();
  const studentTargetedScope = reportScopeToken === 'each_student' || reportScopeToken === 'selected_students';
  const orderedFieldsList = fields;
  const hasSharedFields = studentTargetedScope && fields.some((f) => f?.sharedAcrossStudents === true);
  const validation = (typeof validationSummary !== 'undefined' && validationSummary && typeof validationSummary === 'object')
    ? validationSummary
    : { errors: [], warnings: [], issuesByField: {} };
  const validationByField = validation.issuesByField && typeof validation.issuesByField === 'object'
    ? validation.issuesByField
    : {};
  
  const isLocked = String(instance?.status || '').toLowerCase() === 'locked';
  const isSubmitted = String(instance?.status || '').toLowerCase() === 'submitted';
  const canUnlockReportInstanceSafe = Boolean(typeof canUnlockReportInstance !== 'undefined' && canUnlockReportInstance);
  const canReopenReportInstanceSafe = Boolean(typeof canReopenReportInstanceToDraft !== 'undefined' && canReopenReportInstanceToDraft);
  const canEditAnswersSafe = typeof canEditReportInstanceAnswers !== 'undefined'
    ? Boolean(canEditReportInstanceAnswers)
    : !isLocked;
  const isReadOnly = !canEditAnswersSafe;
  const lifecycleMode = String(classData?.registrationMode || 'term_based').trim().toLowerCase() === 'rolling' ? 'rolling' : 'term_based';
  const parsedCycleNo = Number.parseInt(String(classData?.cycleNo || '').trim(), 10);
  const lifecycleCycleNo = Number.isFinite(parsedCycleNo) && parsedCycleNo > 0 ? parsedCycleNo : 1;
  const instStatus = String(instance?.status || '').toLowerCase() || 'draft';
  const statusBadgeLabel = instStatus === 'submitted'
    ? 'Submitted (awaiting review)'
    : (instance.status || '-');
  const statusBadgeClass = instStatus === 'locked'
    ? 'bg-dark'
    : (instStatus === 'submitted' ? 'bg-success' : 'bg-secondary');
  const rptStart = String(assignment?.reportStartDate || '').trim();
  const rptDue = String(assignment?.reportDueDate || '').trim();
  const tsReflect = assignment?.timesheetReflection === true;
  const allocNum = Number(assignment?.allocatedHours);
  const allocDisplay = tsReflect && Number.isFinite(allocNum) && allocNum > 0 ? Number(allocNum.toFixed(2)) : '';
  const dtl = typeof instanceDetails !== 'undefined' && instanceDetails && typeof instanceDetails === 'object' ? instanceDetails : {};
  const requestedEditorVariant = String(typeof editorVariant === 'undefined' ? '' : editorVariant).trim().toLowerCase();
  const isV2 = requestedEditorVariant === 'v2';
  const reviewNav = (typeof reportReviewNavigator !== 'undefined' && reportReviewNavigator && typeof reportReviewNavigator === 'object')
    ? reportReviewNavigator
    : { rows: [], currentIndex: -1, olderCount: 0, olderHref: '', newerHref: '' };
  const reviewRows = Array.isArray(reviewNav.rows) ? reviewNav.rows : [];
  const reviewOlderCount = Number.isFinite(Number(reviewNav.olderCount)) ? Number(reviewNav.olderCount) : 0;
  const isVisualOnlyField = (field) => {
    const t = String(field?.type || '').trim().toLowerCase();
    return t === 'section' || t === 'subheader' || t === 'row_break';
  };
  const isRowBreakField = (field) => String(field?.type || '').trim().toLowerCase() === 'row_break';
  const sectionGroups = [];
  let currentSectionGroup = { header: null, rows: [] };
  let currentRow = [];
  const flushFieldRow = () => {
    if (!currentRow.length) return;
    currentSectionGroup.rows.push(currentRow);
    currentRow = [];
  };
  const flushSectionGroup = () => {
    flushFieldRow();
    if (!currentSectionGroup.header && currentSectionGroup.rows.length === 0) return;
    sectionGroups.push(currentSectionGroup);
    currentSectionGroup = { header: null, rows: [] };
  };
  orderedFieldsList.forEach((field) => {
    const fieldType = String(field?.type || '').trim().toLowerCase();
    const isSection = fieldType === 'section';
    const isSubheader = fieldType === 'subheader';
    const fullWidthField = field?.fullPageWidth === true || String(field?.fullPageWidth || '').toLowerCase() === 'true';
    if (isRowBreakField(field)) {
      flushFieldRow();
      return;
    }
    if (isSection) {
      flushSectionGroup();
      currentSectionGroup.header = field;
      return;
    }
    if (isSubheader || fullWidthField) {
      flushFieldRow();
      currentSectionGroup.rows.push([field]);
      return;
    }
    currentRow.push(field);
  });
  flushSectionGroup();
%>
<style>
  .report-instance-page #reportInstanceDetailsChevron { transition: transform 0.2s ease; display: inline-block; }
  .report-instance-page #reportInstanceDetailsToggle.collapsed #reportInstanceDetailsChevron { transform: rotate(-90deg); }
  .report-instance-page #validationSummaryChevron { transition: transform 0.2s ease; display: inline-block; }
  .report-instance-page #validationSummaryToggle.collapsed #validationSummaryChevron { transform: rotate(-90deg); }
  .report-instance-page .report-section-chevron { transition: transform 0.2s ease; display: inline-block; }
  .report-instance-page .report-section-toggle.collapsed .report-section-chevron { transform: rotate(-90deg); }
  .report-instance-page .report-section-title { font-size: 1.1rem; font-weight: 700; color: var(--bs-emphasis-color); }
  .report-instance-page .help-tooltip-icon {
    border: 0;
    background: transparent;
    padding: 0;
    margin-left: 0.35rem;
    color: var(--bs-secondary-color);
    line-height: 1;
  }
  .report-instance-page .help-tooltip-icon:hover,
  .report-instance-page .help-tooltip-icon:focus-visible { color: var(--bs-primary); }
  .report-instance-page .instance-detail-grid-v2 .card { border-radius: 0.75rem; }
</style>
<div class="sections-page report-instance-page">
  <input type="hidden" id="reportInstanceActionStateId" value="<%= actionStateId || '' %>">
  <input type="hidden" id="reportInstanceSafeReturnUrl" value="<%= typeof safeReturnUrl !== 'undefined' && safeReturnUrl ? safeReturnUrl : '' %>">
  <script type="application/json" id="reportInstanceFieldsConfig"><%- JSON.stringify(fields).replace(/</g, '\\u003c') %></script>
  <script type="application/json" id="reportInstanceMergedData"><%- JSON.stringify(mergedData || {}).replace(/</g, '\\u003c') %></script>
  <script type="application/json" id="reportInstancePrefillData"><%- JSON.stringify(instance?.prefillSnapshot || {}).replace(/</g, '\\u003c') %></script>

  <div class="row g-2 align-items-start mb-4">
    <div class="col">
      <h1 class="page-heading size-md m-0 text-start" style="padding-left:0;"><%= isV2 ? 'Report Instance (V2)' : 'Report Instance' %></h1>
      <h6 class="fw-semibold text-primary mt-2 mb-0"><%= template?.title || 'Report' %></h6>
      <div class="text-muted small mt-1">Instance ID: <strong class="font-monospace"><%= instance.id %></strong></div>
      <div class="text-muted small mt-1">
        Class: <strong><%= classData?.title || instance.classId || '-' %></strong>
        <span class="mx-1">|</span>
        Session date: <strong><%= instance.sessionDate || '-' %></strong>
      </div>
      <div class="text-muted small mt-2">
        <span class="text-muted">Report start date:</span> <strong class="text-body"><%= rptStart || '-' %></strong>
        <span class="mx-2">|</span>
        <span class="text-muted">Report due date:</span> <strong class="text-body"><%= rptDue || '-' %></strong>
      </div>
      <% if (tsReflect) { %>
      <div class="small mt-2">
        <span class="badge bg-info-subtle text-info-emphasis border border-info-subtle"><i class="bi bi-clock-history me-1"></i>Timesheet reflection</span>
        <span class="text-muted ms-2">Allocated hours: <strong class="text-body"><%= allocDisplay !== '' ? allocDisplay : '-' %></strong></span>
      </div>
      <% } %>
      <div class="small mt-2">
        <% if (lifecycleMode === 'rolling') { %>
          <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle">Rolling</span>
          <span class="badge bg-light text-dark border">Cycle #<%= lifecycleCycleNo %></span>
          <% if (classData?.isClosedForNewEnrollment) { %>
            <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Closed Enrollment</span>
          <% } %>
          <span class="text-muted ms-1">Cycle Window: <%= classData?.cycleStartDate || '?' %> -> <%= classData?.cycleEndDate || 'Open' %></span>
        <% } else { %>
          <span class="badge bg-light text-dark border">Term-Based</span>
        <% } %>
      </div>
    </div>
    <div class="col-auto d-flex flex-column align-items-end gap-1">
      <span class="badge bg-primary border font-monospace">ID: <%= instance.id %></span>
      <a href="/school/reports" class="btn btn-outline-secondary btn-sm"><i class="bi bi-house me-1"></i>Report Home</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <div class="card-body py-2">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <% if (!isV2) { %>
          <a href="/school/reports/instances" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Instances</a>
          <% if (instance?.classId) { %>
            <a href="/school/classes/edit-wizard/<%= encodeURIComponent(instance.classId) %>" class="btn btn-outline-info btn-sm"><i class="bi bi-diagram-3 me-1"></i>Class Lifecycle</a>
          <% } %>
        <% } else { %>
          <button type="button" class="btn btn-outline-secondary btn-sm" id="btnReviewPreviousReports" data-bs-toggle="modal" data-bs-target="#reportReviewNavigatorModal">
            <i class="bi bi-clock-history me-1"></i>Review Previous Reports
            <span class="badge bg-secondary ms-1"><%= reviewOlderCount %></span>
          </button>
        <% } %>
        <% if (template?.docxTemplate?.path) { %>
          <a href="/school/reports/instances/export/<%= instance.id %>?format=docx&download=1" class="btn btn-outline-primary btn-sm"><i class="bi bi-file-earmark-word me-1"></i>Export DOCX</a>
        <% } %>
        <% if (!isV2) { %>
          <a href="/school/reports/instances/export/<%= instance.id %>?download=1" class="btn btn-outline-dark btn-sm"><i class="bi bi-download me-1"></i>Export Payload</a>
        <% } %>
        <% if (!isReadOnly) { %>
          <button type="button" class="btn btn-outline-primary btn-sm" id="btnReviewPrefillUpdates"><i class="bi bi-arrow-repeat me-1"></i>Preview Prefill Updates</button>
        <% } %>
        <button type="button" class="btn btn-warning btn-md btn-filled ms-auto" id="btnCloseReportInstance"><i class="bi bi-x-lg me-1"></i>Close</button>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-4">
    <button type="button" class="card-header bg-white border-0 w-100 d-flex justify-content-between align-items-center py-3 text-start rounded-top" data-bs-toggle="collapse" data-bs-target="#reportInstanceDetailsCollapse" aria-expanded="true" aria-controls="reportInstanceDetailsCollapse" id="reportInstanceDetailsToggle">
      <span class="fw-bold text-body"><i class="bi bi-info-circle me-2 text-primary"></i>Instance details</span>
      <i class="bi bi-chevron-down text-muted" id="reportInstanceDetailsChevron" aria-hidden="true"></i>
    </button>
    <div id="reportInstanceDetailsCollapse" class="collapse show">
      <div class="card-body p-3 border-top">
        <% if (isV2) { %>
          <div class="row g-3 instance-detail-grid-v2">
            <div class="col-lg-4 col-md-6">
              <div class="card border h-100">
                <div class="card-body">
                  <div class="small text-muted text-uppercase">Status</div>
                  <div class="mt-1"><span class="badge <%= statusBadgeClass %>"><%= statusBadgeLabel %></span></div>
                </div>
              </div>
            </div>
            <div class="col-lg-4 col-md-6">
              <div class="card border h-100">
                <div class="card-body">
                  <div class="small text-muted text-uppercase">Teacher</div>
                  <div class="fw-semibold mt-1"><%= dtl.teacherName || instance.teacherId || '—' %></div>
                  <div class="x-small text-muted font-monospace"><%= instance.teacherId || '—' %></div>
                </div>
              </div>
            </div>
            <div class="col-lg-4 col-md-6">
              <div class="card border h-100">
                <div class="card-body">
                  <div class="small text-muted text-uppercase">Class</div>
                  <div class="fw-semibold mt-1"><%= dtl.className || instance.classId || '—' %></div>
                  <div class="x-small text-muted font-monospace"><%= instance.classId || '—' %></div>
                </div>
              </div>
            </div>
            <div class="col-lg-4 col-md-6">
              <div class="card border h-100">
                <div class="card-body">
                  <div class="small text-muted text-uppercase">Session Date</div>
                  <div class="fw-semibold mt-1"><%= instance.sessionDate || '-' %></div>
                  <div class="x-small text-muted font-monospace"><%= instance.sessionId || '—' %></div>
                </div>
              </div>
            </div>
            <div class="col-lg-4 col-md-6">
              <div class="card border h-100">
                <div class="card-body">
                  <div class="small text-muted text-uppercase">Student</div>
                  <div class="fw-semibold mt-1"><%- include('school/partials/studentNameLink', { name: dtl.studentName || (instance.studentId ? `Record ${instance.studentId}` : '-'), studentRecordId: dtl.studentRecordId, canOpenStudentProfile: typeof canOpenStudentProfile !== 'undefined' ? canOpenStudentProfile : false, linkClass: 'text-decoration-none' }) %></div>
                  <div class="x-small text-muted font-monospace">
                    <% if (dtl.studentLocalId) { %>Local <%= dtl.studentLocalId %> | <% } %>Record ID <%= instance.studentId || '-' %>
                  </div>
                </div>
              </div>
            </div>
            <div class="col-lg-4 col-md-6">
              <div class="card border h-100">
                <div class="card-body">
                  <div class="small text-muted text-uppercase">Assignment</div>
                  <div class="fw-semibold mt-1"><%= dtl.assignmentSummary || 'Assignment linked' %></div>
                  <div class="x-small text-muted font-monospace">ID <%= instance.assignmentId || '—' %></div>
                </div>
              </div>
            </div>
          </div>
        <% } else { %>
          <div class="row g-3">
            <div class="col-md-3">
              <div class="small text-muted">Status</div>
              <span class="badge <%= statusBadgeClass %>"><%= statusBadgeLabel %></span>
            </div>
            <div class="col-md-3">
              <div class="small text-muted">Teacher</div>
              <% if (dtl.teacherName) { %>
                <div class="fw-bold"><%= dtl.teacherName %></div>
                <div class="font-monospace x-small text-muted">ID <%= instance.teacherId || '—' %></div>
              <% } else { %>
                <div class="fw-bold font-monospace x-small"><%= instance.teacherId || '—' %></div>
              <% } %>
            </div>
            <div class="col-md-3">
              <div class="small text-muted">Template</div>
              <div class="fw-bold"><%= template.title %> <span class="text-muted fw-normal">(v<%= Number(template.version || 1) %>)</span></div>
            </div>
            <div class="col-md-3">
              <div class="small text-muted">Target</div>
              <% if (dtl.targetLabel) { %>
                <div class="fw-bold"><%= dtl.targetLabel %></div>
                <div class="font-monospace x-small text-muted"><%= instance.targetKey || '—' %></div>
              <% } else { %>
                <div class="fw-bold font-monospace x-small"><%= instance.targetKey || '—' %></div>
              <% } %>
            </div>
            <div class="col-md-3">
              <div class="small text-muted">Class</div>
              <% if (dtl.className) { %>
                <div class="fw-bold"><%= dtl.className %></div>
                <div class="font-monospace x-small text-muted">ID <%= instance.classId || '—' %></div>
              <% } else { %>
                <div class="fw-bold font-monospace x-small"><%= instance.classId || '—' %></div>
              <% } %>
            </div>
            <div class="col-md-3">
              <div class="small text-muted">Session</div>
              <% if (dtl.sessionSummary) { %>
                <div class="fw-bold"><%= dtl.sessionSummary %></div>
                <div class="font-monospace x-small text-muted"><%= instance.sessionId || '—' %></div>
              <% } else { %>
                <div class="fw-bold font-monospace x-small"><%= instance.sessionId || '—' %></div>
              <% } %>
            </div>
            <div class="col-md-3">
              <div class="small text-muted">Assignment</div>
              <% if (dtl.assignmentSummary) { %>
                <div class="fw-bold"><%= dtl.assignmentSummary %></div>
                <div class="font-monospace x-small text-muted">ID <%= instance.assignmentId || '—' %></div>
              <% } else { %>
                <div class="fw-bold font-monospace x-small"><%= instance.assignmentId || '—' %></div>
              <% } %>
            </div>
            <div class="col-md-3">
              <div class="small text-muted">Student</div>
              <% if (dtl.studentName) { %>
                <div class="fw-bold"><%- include('school/partials/studentNameLink', { name: dtl.studentName, studentRecordId: dtl.studentRecordId, canOpenStudentProfile: typeof canOpenStudentProfile !== 'undefined' ? canOpenStudentProfile : false, linkClass: 'text-decoration-none' }) %></div>
                <div class="font-monospace x-small text-muted">
                  <% if (dtl.studentLocalId) { %>Local <%= dtl.studentLocalId %> | <% } %>Record ID <%= instance.studentId || '-' %>
                </div>
              <% } else if (instance.studentId) { %>
                <div class="fw-bold font-monospace x-small">Record ID <%= instance.studentId %></div>
              <% } else { %>
                <div class="fw-bold font-monospace x-small">-</div>
              <% } %>
            </div>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <form method="POST" action="/school/reports/instances/edit/<%= instance.id %>">
    <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">

    <% if ((validation.errors || []).length || (validation.warnings || []).length) { %>
    <div class="card border-0 shadow-sm mb-4" id="validationSummaryCard">
      <button type="button" class="card-header bg-white border-0 w-100 d-flex justify-content-between align-items-center py-3 text-start rounded-top collapsed" data-bs-toggle="collapse" data-bs-target="#validationSummaryCollapse" aria-expanded="false" aria-controls="validationSummaryCollapse" id="validationSummaryToggle">
        <span class="fw-bold text-body">
          <i class="bi bi-shield-exclamation me-2 text-danger"></i>Validation Summary
          <% if ((validation.errors || []).length) { %><span class="badge bg-danger ms-2"><%= validation.errors.length %> error(s)</span><% } %>
          <% if ((validation.warnings || []).length) { %><span class="badge bg-warning text-dark ms-1"><%= validation.warnings.length %> warning(s)</span><% } %>
        </span>
        <i class="bi bi-chevron-down text-muted" id="validationSummaryChevron" aria-hidden="true"></i>
      </button>
      <div id="validationSummaryCollapse" class="collapse">
        <div class="card-body border-top">
          <% (validation.errors || []).slice(0, 6).forEach((issue) => { %>
            <div class="small text-danger mb-1"><i class="bi bi-x-circle me-1"></i><%= issue.message %></div>
          <% }); %>
          <% (validation.warnings || []).slice(0, 6).forEach((issue) => { %>
            <div class="small text-warning-emphasis mb-1"><i class="bi bi-exclamation-triangle me-1"></i><%= issue.message %></div>
          <% }); %>
          <div class="small text-muted mt-2">Collapsed by default. Click to expand details.</div>
        </div>
      </div>
    </div>
    <% } %>

    <div class="card border-0 shadow-sm mb-4">
      <div class="card-header bg-white">
        <h5 class="m-0 fw-bold">Report fields</h5>
        <% if (hasSharedFields) { %>
          <div class="small text-muted mt-1">Shared fields are marked and follow the template order.</div>
        <% } %>
      </div>
      <div class="card-body p-3">
        <% if (!orderedFieldsList.length) { %>
          <div class="text-muted">No fields defined in template schema.</div>
        <% } %>

        <% sectionGroups.forEach((group, groupIndex) => { %>
          <% const collapseId = `reportSectionCollapse_${groupIndex}`; %>
          <% if (group.header) { %>
            <div class="border rounded mb-4 bg-light-subtle">
              <button
                type="button"
                class="report-section-toggle card-header bg-transparent border-0 w-100 d-flex justify-content-between align-items-center py-3 text-start rounded-top"
                data-bs-toggle="collapse"
                data-bs-target="#<%= collapseId %>"
                aria-expanded="true"
                aria-controls="<%= collapseId %>">
                <span>
                  <span class="report-section-title">
                    <%= group.header.label %>
                    <% if (isV2 && group.header.helpText) { %>
                      <button type="button" class="help-tooltip-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= group.header.helpText %>" aria-label="Section help">
                        <i class="bi bi-info-circle"></i>
                      </button>
                    <% } %>
                  </span>
                  <% if (!isV2 && group.header.helpText) { %><span class="small text-muted d-block mt-1"><%= group.header.helpText %></span><% } %>
                </span>
                <i class="bi bi-chevron-down text-muted report-section-chevron" aria-hidden="true"></i>
              </button>
              <div id="<%= collapseId %>" class="collapse show">
                <div class="card-body border-top p-3">
                  <% (group.rows || []).forEach((rowFields) => { %>
                    <div class="row g-3 mb-4">
                      <% rowFields.forEach((field) => { %>
                        <% const studentFieldType = String(field.type || 'text').toLowerCase(); %>
                        <% const studentVisualOnly = isVisualOnlyField(field); %>
                        <% if (studentVisualOnly) { %>
                          <div class="col-12">
                            <% if (studentFieldType === 'subheader') { %>
                              <hr class="my-3 text-muted">
                              <h6 class="fw-semibold mt-1 mb-1 text-muted">
                                <%= field.label %>
                                <% if (isV2 && field.helpText) { %>
                                  <button type="button" class="help-tooltip-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= field.helpText %>" aria-label="Subheader help">
                                    <i class="bi bi-info-circle"></i>
                                  </button>
                                <% } %>
                              </h6>
                              <% if (!isV2 && field.helpText) { %><div class="small text-muted mb-1"><%= field.helpText %></div><% } %>
                            <% } %>
                          </div>
                        <% } else { %>
                          <% const fieldName = `field__${field.id}`; %>
                          <% const rawVal = mergedData[field.id]; %>
                          <% const value = (rawVal === undefined || rawVal === null) ? '' : rawVal; %>
                          <% const calculatedField = String(field.valueMode || 'manual').trim().toLowerCase() === 'calculated'; %>
                          <% const readOnlyField = field.readOnly === true || calculatedField; %>
                          <% const fullWidthField = field.fullPageWidth === true || String(field.fullPageWidth).toLowerCase() === 'true'; %>
                          <% const fieldColClass = fullWidthField ? 'col-12' : 'col'; %>
                          <% const selectOptSt = field.type === 'select' ? (field.options || []).find((o) => String(o.value) === String(value)) : null; %>
                          <% const displaySelectSt = selectOptSt ? (selectOptSt.label || selectOptSt.value) : value; %>
                          <% const serverFieldIssues = Array.isArray(validationByField[field.id]) ? validationByField[field.id] : []; %>
                          <% const hasFieldBorder = field.hasBorder === true || String(field.hasBorder).toLowerCase() === 'true'; %>
                          <% const fieldBackgroundColor = String(field.backgroundColor || '').trim(); %>
                          <% const hasFieldBackground = /^#[0-9A-Fa-f]{6}$/.test(fieldBackgroundColor); %>
                          <% const fieldShellClass = `${hasFieldBorder ? 'border rounded p-2' : ''}${hasFieldBackground ? ' p-2' : ''}`.trim(); %>
                          <% const fieldShellStyleValue = hasFieldBackground ? `background-color:${fieldBackgroundColor};` : ''; %>
                          <div class="<%= fieldColClass %>">
                            <div class="<%= fieldShellClass %>" style="<%= fieldShellStyleValue %>">
                              <label class="form-label fw-bold">
                                <%= field.label %>
                                <% if (isV2 && field.helpText) { %>
                                  <button type="button" class="help-tooltip-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= field.helpText %>" aria-label="Field help">
                                    <i class="bi bi-info-circle"></i>
                                  </button>
                                <% } %>
                                <% if (field.required) { %><span class="text-danger">*</span><% } %>
                                <% if (hasSharedFields && field.sharedAcrossStudents === true) { %><span class="badge bg-info-subtle text-info-emphasis border ms-1">Shared</span><% } %>
                                <% if (readOnlyField) { %><span class="badge bg-light text-secondary border ms-1">View only</span><% } %>
                                <% if (calculatedField) { %><span class="badge bg-warning-subtle text-warning-emphasis border ms-1">Auto-calculated</span><% } %>
                              </label>

                              <% if (readOnlyField) { %>
                                <% if (field.type === 'textarea') { %>
                                  <textarea class="form-control bg-light" data-field-id="<%= field.id %>" rows="4" readonly><%= value %></textarea>
                                <% } else if (field.type === 'number') { %>
                                  <input type="number" class="form-control bg-light" data-field-id="<%= field.id %>" value="<%= value %>" readonly>
                                <% } else if (field.type === 'date') { %>
                                  <input type="date" class="form-control bg-light" data-field-id="<%= field.id %>" value="<%= value %>" readonly>
                                <% } else if (field.type === 'checkbox') { %>
                                  <div class="form-check border rounded p-2 bg-light">
                                    <input type="checkbox" class="form-check-input" data-field-id="<%= field.id %>" <%= value === true || String(value).toLowerCase() === 'true' ? 'checked' : '' %> disabled>
                                    <label class="form-check-label">Checked</label>
                                  </div>
                                <% } else if (field.type === 'select') { %>
                                  <select class="form-select bg-light" data-field-id="<%= field.id %>" disabled>
                                    <option value="">Select...</option>
                                    <% (field.options || []).forEach((opt) => { %>
                                      <option value="<%= opt.value %>" <%= String(value) === String(opt.value) ? 'selected' : '' %>><%= opt.label || opt.value %></option>
                                    <% }); %>
                                  </select>
                                <% } else { %>
                                  <input type="text" class="form-control bg-light" data-field-id="<%= field.id %>" value="<%= displaySelectSt %>" readonly>
                                <% } %>
                              <% } else if (field.type === 'textarea') { %>
                                <textarea class="form-control js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" rows="4" <%= isReadOnly ? 'disabled' : '' %>><%= value %></textarea>
                              <% } else if (field.type === 'number') { %>
                                <input type="number" class="form-control js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" value="<%= value %>" <%= isReadOnly ? 'disabled' : '' %>>
                              <% } else if (field.type === 'date') { %>
                                <input type="date" class="form-control js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" value="<%= value %>" <%= isReadOnly ? 'disabled' : '' %>>
                              <% } else if (field.type === 'checkbox') { %>
                                <div class="form-check border rounded p-2">
                                  <input type="checkbox" class="form-check-input js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" <%= value === true || String(value).toLowerCase() === 'true' ? 'checked' : '' %> <%= isReadOnly ? 'disabled' : '' %>>
                                  <label class="form-check-label">Checked</label>
                                </div>
                              <% } else if (field.type === 'select') { %>
                                <select class="form-select js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" <%= isReadOnly ? 'disabled' : '' %>>
                                  <option value="">Select...</option>
                                  <% (field.options || []).forEach((opt) => { %>
                                    <option value="<%= opt.value %>" <%= String(value) === String(opt.value) ? 'selected' : '' %>><%= opt.label || opt.value %></option>
                                  <% }); %>
                                </select>
                              <% } else { %>
                                <input type="text" class="form-control js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" value="<%= value %>" <%= isReadOnly ? 'disabled' : '' %>>
                              <% } %>

                              <div class="small mt-1 js-field-validation" data-field-validation-for="<%= field.id %>">
                                <% serverFieldIssues.slice(0, 2).forEach((issue) => { %>
                                  <div class="<%= issue.severity === 'warning' ? 'text-warning-emphasis' : 'text-danger' %>">
                                    <i class="bi <%= issue.severity === 'warning' ? 'bi-exclamation-triangle' : 'bi-x-circle' %> me-1"></i><%= issue.message %>
                                  </div>
                                <% }); %>
                              </div>

                              <% if (!isV2 && field.helpText) { %>
                                <div class="small text-muted mt-1"><%= field.helpText %></div>
                              <% } %>
                            </div>
                          </div>
                        <% } %>
                      <% }); %>
                    </div>
                  <% }); %>
                </div>
              </div>
            </div>
          <% } else { %>
            <div class="mb-3">
              <% (group.rows || []).forEach((rowFields) => { %>
                <div class="row g-3 mb-4">
                  <% rowFields.forEach((field) => { %>
                    <% const studentFieldType = String(field.type || 'text').toLowerCase(); %>
                    <% const studentVisualOnly = isVisualOnlyField(field); %>
                    <% if (studentVisualOnly) { %>
                      <div class="col-12">
                        <% if (studentFieldType === 'subheader') { %>
                          <hr class="my-3 text-muted">
                          <h6 class="fw-semibold mt-1 mb-1 text-muted">
                            <%= field.label %>
                            <% if (isV2 && field.helpText) { %>
                              <button type="button" class="help-tooltip-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= field.helpText %>" aria-label="Subheader help">
                                <i class="bi bi-info-circle"></i>
                              </button>
                            <% } %>
                          </h6>
                          <% if (!isV2 && field.helpText) { %><div class="small text-muted mb-1"><%= field.helpText %></div><% } %>
                        <% } %>
                      </div>
                    <% } else { %>
                      <% const fieldName = `field__${field.id}`; %>
                      <% const rawVal = mergedData[field.id]; %>
                      <% const value = (rawVal === undefined || rawVal === null) ? '' : rawVal; %>
                      <% const calculatedField = String(field.valueMode || 'manual').trim().toLowerCase() === 'calculated'; %>
                      <% const readOnlyField = field.readOnly === true || calculatedField; %>
                      <% const fullWidthField = field.fullPageWidth === true || String(field.fullPageWidth).toLowerCase() === 'true'; %>
                      <% const fieldColClass = fullWidthField ? 'col-12' : 'col'; %>
                      <% const selectOptSt = field.type === 'select' ? (field.options || []).find((o) => String(o.value) === String(value)) : null; %>
                      <% const displaySelectSt = selectOptSt ? (selectOptSt.label || selectOptSt.value) : value; %>
                      <% const serverFieldIssues = Array.isArray(validationByField[field.id]) ? validationByField[field.id] : []; %>
                      <% const hasFieldBorder = field.hasBorder === true || String(field.hasBorder).toLowerCase() === 'true'; %>
                      <% const fieldBackgroundColor = String(field.backgroundColor || '').trim(); %>
                      <% const hasFieldBackground = /^#[0-9A-Fa-f]{6}$/.test(fieldBackgroundColor); %>
                      <% const fieldShellClass = `${hasFieldBorder ? 'border rounded p-2' : ''}${hasFieldBackground ? ' p-2' : ''}`.trim(); %>
                      <% const fieldShellStyleValue = hasFieldBackground ? `background-color:${fieldBackgroundColor};` : ''; %>
                      <div class="<%= fieldColClass %>">
                        <div class="<%= fieldShellClass %>" style="<%= fieldShellStyleValue %>">
                          <label class="form-label fw-bold">
                            <%= field.label %>
                            <% if (isV2 && field.helpText) { %>
                              <button type="button" class="help-tooltip-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= field.helpText %>" aria-label="Field help">
                                <i class="bi bi-info-circle"></i>
                              </button>
                            <% } %>
                            <% if (field.required) { %><span class="text-danger">*</span><% } %>
                            <% if (hasSharedFields && field.sharedAcrossStudents === true) { %><span class="badge bg-info-subtle text-info-emphasis border ms-1">Shared</span><% } %>
                            <% if (readOnlyField) { %><span class="badge bg-light text-secondary border ms-1">View only</span><% } %>
                            <% if (calculatedField) { %><span class="badge bg-warning-subtle text-warning-emphasis border ms-1">Auto-calculated</span><% } %>
                          </label>
                          <% if (readOnlyField) { %>
                            <% if (field.type === 'textarea') { %>
                              <textarea class="form-control bg-light" data-field-id="<%= field.id %>" rows="4" readonly><%= value %></textarea>
                            <% } else if (field.type === 'number') { %>
                              <input type="number" class="form-control bg-light" data-field-id="<%= field.id %>" value="<%= value %>" readonly>
                            <% } else if (field.type === 'date') { %>
                              <input type="date" class="form-control bg-light" data-field-id="<%= field.id %>" value="<%= value %>" readonly>
                            <% } else if (field.type === 'checkbox') { %>
                              <div class="form-check border rounded p-2 bg-light">
                                <input type="checkbox" class="form-check-input" data-field-id="<%= field.id %>" <%= value === true || String(value).toLowerCase() === 'true' ? 'checked' : '' %> disabled>
                                <label class="form-check-label">Checked</label>
                              </div>
                            <% } else if (field.type === 'select') { %>
                              <select class="form-select bg-light" data-field-id="<%= field.id %>" disabled>
                                <option value="">Select...</option>
                                <% (field.options || []).forEach((opt) => { %>
                                  <option value="<%= opt.value %>" <%= String(value) === String(opt.value) ? 'selected' : '' %>><%= opt.label || opt.value %></option>
                                <% }); %>
                              </select>
                            <% } else { %>
                              <input type="text" class="form-control bg-light" data-field-id="<%= field.id %>" value="<%= displaySelectSt %>" readonly>
                            <% } %>
                          <% } else if (field.type === 'textarea') { %>
                            <textarea class="form-control js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" rows="4" <%= isReadOnly ? 'disabled' : '' %>><%= value %></textarea>
                          <% } else if (field.type === 'number') { %>
                            <input type="number" class="form-control js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" value="<%= value %>" <%= isReadOnly ? 'disabled' : '' %>>
                          <% } else if (field.type === 'date') { %>
                            <input type="date" class="form-control js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" value="<%= value %>" <%= isReadOnly ? 'disabled' : '' %>>
                          <% } else if (field.type === 'checkbox') { %>
                            <div class="form-check border rounded p-2">
                              <input type="checkbox" class="form-check-input js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" <%= value === true || String(value).toLowerCase() === 'true' ? 'checked' : '' %> <%= isReadOnly ? 'disabled' : '' %>>
                              <label class="form-check-label">Checked</label>
                            </div>
                          <% } else if (field.type === 'select') { %>
                            <select class="form-select js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" <%= isReadOnly ? 'disabled' : '' %>>
                              <option value="">Select...</option>
                              <% (field.options || []).forEach((opt) => { %>
                                <option value="<%= opt.value %>" <%= String(value) === String(opt.value) ? 'selected' : '' %>><%= opt.label || opt.value %></option>
                              <% }); %>
                            </select>
                          <% } else { %>
                            <input type="text" class="form-control js-report-field" data-field-id="<%= field.id %>" name="<%= fieldName %>" value="<%= value %>" <%= isReadOnly ? 'disabled' : '' %>>
                          <% } %>
                          <div class="small mt-1 js-field-validation" data-field-validation-for="<%= field.id %>">
                            <% serverFieldIssues.slice(0, 2).forEach((issue) => { %>
                              <div class="<%= issue.severity === 'warning' ? 'text-warning-emphasis' : 'text-danger' %>">
                                <i class="bi <%= issue.severity === 'warning' ? 'bi-exclamation-triangle' : 'bi-x-circle' %> me-1"></i><%= issue.message %>
                              </div>
                            <% }); %>
                          </div>
                          <% if (!isV2 && field.helpText) { %>
                            <div class="small text-muted mt-1"><%= field.helpText %></div>
                          <% } %>
                        </div>
                      </div>
                    <% } %>
                  <% }); %>
                </div>
              <% }); %>
            </div>
          <% } %>
        <% }); %>
      </div>
    </div>

    <div class="card border-0 shadow-sm">
      <div class="card-body py-2">
        <div class="d-flex flex-wrap align-items-center gap-2">
          <% const saveDraftDisabled = isSubmitted || isLocked || isReadOnly; %>
          <% const submitDisabled = isLocked || isReadOnly; %>
          <% const lockDisabled = isLocked || isReadOnly; %>
          <button
            class="btn btn-primary btn-sm"
            type="submit"
            name="submitAction"
            value="save"
            <%= saveDraftDisabled ? 'disabled' : '' %>
            title="<%= isSubmitted ? 'Submitted reports cannot be saved as draft. Reopen for teacher first, or use Submit / Lock.' : (isLocked ? 'Locked reports cannot be saved.' : 'Save as draft') %>"
          ><i class="bi bi-save me-1"></i>Save Draft</button>
          <button
            class="btn btn-success btn-sm"
            type="submit"
            name="submitAction"
            value="submit"
            <%= submitDisabled ? 'disabled' : '' %>
            title="<%= isLocked ? 'Locked reports cannot be submitted.' : (isReadOnly ? 'This report is read-only until an administrator reopens it.' : 'Submit report') %>"
          ><i class="bi bi-send-check me-1"></i>Submit Report</button>
          <% if (!isLocked) { %>
            <button
              class="btn btn-outline-dark btn-sm"
              formaction="/school/reports/instances/lock/<%= instance.id %>"
              type="submit"
              <%= lockDisabled ? 'disabled' : '' %>
              title="<%= lockDisabled ? 'You cannot lock this report in its current state.' : 'Lock report' %>"
            ><i class="bi bi-lock me-1"></i>Lock Report</button>
          <% } %>

          <div class="d-flex flex-wrap align-items-center gap-2 ms-3 ms-md-4 ps-3 border-start">
            <div class="d-flex flex-wrap align-items-center gap-2">
              <span class="badge <%= isSubmitted ? 'bg-success' : 'bg-secondary-subtle text-secondary border' %> p-2">
                <%= isSubmitted ? 'Submitted (awaiting review)' : 'Submitted' %>
              </span>
              <% if (canReopenReportInstanceSafe) { %>
                <% if (isSubmitted) { %>
                  <button
                    type="button"
                    class="btn btn-outline-warning btn-sm js-reopen-report-instance"
                    data-instance-id="<%= instance.id %>"
                    title="Return this report to draft so the teacher can edit it"
                  >
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reopen for teacher
                  </button>
                <% } else { %>
                  <button type="button" class="btn btn-outline-warning btn-sm" disabled title="Available when the report is submitted">
                    <i class="bi bi-arrow-counterclockwise me-1"></i>Reopen for teacher
                  </button>
                <% } %>
              <% } else if (isSubmitted && isReadOnly) { %>
                <span class="small text-muted">Ask an administrator to reopen for edits.</span>
              <% } %>
            </div>

            <div class="mx-2 mx-md-4 text-muted user-select-none" aria-hidden="true">&middot;</div>

            <div class="d-flex flex-wrap align-items-center gap-2">
              <span class="badge <%= isLocked ? 'bg-dark' : 'bg-secondary-subtle text-secondary border' %> p-2">Locked</span>
              <% if (canUnlockReportInstanceSafe) { %>
                <% if (isLocked) { %>
                  <button
                    type="button"
                    class="btn btn-warning btn-sm js-unlock-report-instance"
                    data-instance-id="<%= instance.id %>"
                    title="Unlock returns the report to submitted"
                  >
                    <i class="bi bi-unlock me-1"></i>Unlock Report
                  </button>
                <% } else { %>
                  <button type="button" class="btn btn-warning btn-sm" disabled title="Available when the report is locked (super user)">
                    <i class="bi bi-unlock me-1"></i>Unlock Report
                  </button>
                <% } %>
              <% } else if (isLocked) { %>
                <span class="small text-muted">Only a super user can unlock.</span>
              <% } %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </form>
</div>

<% if (isV2) { %>
<div class="modal fade" id="reportReviewNavigatorModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-light">
        <div>
          <h5 class="modal-title mb-0"><i class="bi bi-clock-history me-2"></i>Review Previous Reports</h5>
          <div class="small text-muted mt-1">Same template, student target, and class.</div>
        </div>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
          <% if (reviewNav.olderHref) { %>
            <a class="btn btn-outline-primary btn-sm js-report-review-nav-link" href="<%= reviewNav.olderHref %>"><i class="bi bi-arrow-left me-1"></i>Older report</a>
          <% } else { %>
            <button type="button" class="btn btn-outline-secondary btn-sm" disabled><i class="bi bi-arrow-left me-1"></i>Older report</button>
          <% } %>
          <% if (reviewNav.newerHref) { %>
            <a class="btn btn-outline-primary btn-sm js-report-review-nav-link" href="<%= reviewNav.newerHref %>">Newer report<i class="bi bi-arrow-right ms-1"></i></a>
          <% } else { %>
            <button type="button" class="btn btn-outline-secondary btn-sm" disabled>Newer report<i class="bi bi-arrow-right ms-1"></i></button>
          <% } %>
          <span class="small text-muted ms-auto"><%= Math.max(0, reviewRows.length - 1) %> matching report(s) besides this one.</span>
        </div>
        <% if (reviewRows.length <= 1) { %>
          <div class="alert alert-light border mb-0">No previous matching reports were found for this student, class, and template.</div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th>Date</th>
                  <th>Status</th>
                  <th>Teacher</th>
                  <th class="text-end">Action</th>
                </tr>
              </thead>
              <tbody>
                <% reviewRows.forEach((row) => { %>
                  <tr class="<%= row.isCurrent ? 'table-primary' : '' %>">
                    <td>
                      <div class="fw-semibold"><%= row.sessionDate || '-' %></div>
                      <div class="x-small text-muted font-monospace"><%= row.id || '-' %></div>
                    </td>
                    <td>
                      <span class="badge <%= String(row.status || '').toLowerCase() === 'locked' ? 'bg-dark' : (String(row.status || '').toLowerCase() === 'submitted' ? 'bg-success' : 'bg-warning text-dark') %>"><%= row.status || '-' %></span>
                      <% if (row.isCurrent) { %><span class="badge bg-primary ms-1">Current</span><% } %>
                    </td>
                    <td class="font-monospace small"><%= row.teacherId || '-' %></td>
                    <td class="text-end">
                      <% if (row.isCurrent) { %>
                        <button type="button" class="btn btn-outline-secondary btn-sm" disabled>Current</button>
                      <% } else { %>
                        <a class="btn btn-outline-primary btn-sm js-report-review-nav-link" href="<%= row.href %>"><i class="bi bi-layout-text-window-reverse me-1"></i>Open V2</a>
                      <% } %>
                    </td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          </div>
        <% } %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
      </div>
    </div>
  </div>
</div>
<% } %>

<div class="modal fade" id="prefillRefreshReviewModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header bg-primary text-white">
        <h5 class="modal-title"><i class="bi bi-arrow-repeat me-2"></i>Preview Prefill Updates</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-info small">
          Select the prefill keys you want to replace. Applying a selected key updates the stored prefill snapshot and the linked report field values.
        </div>
        <div class="d-flex justify-content-between align-items-center mb-2">
          <div class="fw-semibold" id="prefillRefreshSummary">No changes loaded.</div>
          <button type="button" class="btn btn-outline-secondary btn-sm" id="btnToggleAllPrefillRefresh">Select All</button>
        </div>
        <div class="table-responsive">
          <table class="table table-sm align-middle">
            <thead>
              <tr>
                <th style="width: 48px;">Use</th>
                <th>Linked Fields</th>
                <th>Current Report Value</th>
                <th>Stored Prefill Value</th>
                <th>Recalculated Value</th>
              </tr>
            </thead>
            <tbody id="prefillRefreshRows"></tbody>
          </table>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="btnApplyPrefillRefresh"><i class="bi bi-check2-circle me-1"></i>Apply Selected</button>
      </div>
    </div>
  </div>
</div>

<%- include('partials/calculatedFieldsRuntime') %>
<script src="/scripts/reportAssignmentDelete.js"></script>
<script>
  (function () {
    const btnClose = document.getElementById('btnCloseReportInstance');
    const btnReviewPrefillUpdates = document.getElementById('btnReviewPrefillUpdates');
    const prefillRefreshModalEl = document.getElementById('prefillRefreshReviewModal');
    const prefillRefreshRows = document.getElementById('prefillRefreshRows');
    const prefillRefreshSummary = document.getElementById('prefillRefreshSummary');
    const btnApplyPrefillRefresh = document.getElementById('btnApplyPrefillRefresh');
    const btnToggleAllPrefillRefresh = document.getElementById('btnToggleAllPrefillRefresh');
    const returnInput = document.getElementById('reportInstanceSafeReturnUrl');
    const formEl = document.querySelector('form[action^="/school/reports/instances/edit/"]');
    const validationSummaryCard = document.getElementById('validationSummaryCard');
    const validationSummaryToggle = document.getElementById('validationSummaryToggle');
    const fieldConfigEl = document.getElementById('reportInstanceFieldsConfig');
    const mergedDataEl = document.getElementById('reportInstanceMergedData');
    const prefillDataEl = document.getElementById('reportInstancePrefillData');
    const reportReviewNavLinks = Array.from(document.querySelectorAll('.js-report-review-nav-link'));
    const instanceId = <%- JSON.stringify(String(instance?.id || '')) %>;
    const summaryFocusStorageKey = 'report_instance_validation_focus';
    let prefillRefreshModal = null;
    let prefillRefreshChanges = [];
    let reportInstanceSubmitting = false;
    let reportInstanceSubmitLoadingToken = null;

    function initializeTooltips() {
      if (typeof bootstrap === 'undefined' || !bootstrap || !bootstrap.Tooltip) return;
      document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach((el) => {
        if (!bootstrap.Tooltip.getInstance(el)) {
          new bootstrap.Tooltip(el);
        }
      });
    }
    initializeTooltips();

    function showReportInstanceMessage({ title = 'Report Instance', icon = 'info', message = '', buttons = null } = {}) {
      if (typeof showMessageModal === 'function') {
        return showMessageModal({
          title,
          icon,
          message,
          buttons: buttons || [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : 'btn-primary' }]
        });
      }
      window.alert(String(message || title || 'Report Instance'));
      return Promise.resolve();
    }

    function escapeHtml(value) {
      return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function formatPreviewValue(value) {
      if (value === undefined) return '<span class="text-muted">missing</span>';
      if (value === null || value === '') return '<span class="text-muted">empty</span>';
      if (typeof value === 'object') return `<code>${escapeHtml(JSON.stringify(value))}</code>`;
      return escapeHtml(value);
    }

    function showLoadingToken(options) {
      if (typeof window.showLoading === 'function') return window.showLoading(options || {});
      return null;
    }

    function hideLoadingToken(token) {
      try {
        if (token && typeof window.hideLoading === 'function') window.hideLoading(token);
      } catch (_) {}
    }

    function getReportInstanceActionStateId() {
      return String(
        formEl?.querySelector('input[name="actionStateId"]')?.value
        || document.getElementById('reportInstanceActionStateId')?.value
        || ''
      ).trim();
    }

    function setReportInstanceSubmitting(isSubmitting, submitter = null) {
      reportInstanceSubmitting = Boolean(isSubmitting);
      if (!formEl) return;
      formEl.querySelectorAll('button[type="submit"]').forEach((button) => {
        button.disabled = reportInstanceSubmitting;
        if (reportInstanceSubmitting) button.setAttribute('aria-disabled', 'true');
        else button.removeAttribute('aria-disabled');
      });
      if (reportInstanceSubmitting && submitter) {
        submitter.dataset.originalText = submitter.dataset.originalText || submitter.innerHTML;
        submitter.innerHTML = '<span class="spinner-border spinner-border-sm me-1" aria-hidden="true"></span>Saving...';
      }
    }

    async function showExpiredActionStateMessage() {
      const message = 'This report form session is no longer active. Reload the report instance, review your changes, and save again.';
      if (typeof showMessageModal === 'function') {
        const result = await showMessageModal({
          title: 'Form Session Expired',
          icon: 'warning',
          message,
          buttons: [
            { text: 'Stay', class: 'btn-secondary' },
            { text: 'Reload', class: 'btn-primary' }
          ]
        });
        if (result === 'Reload') window.location.reload();
        return;
      }
      window.alert(message);
    }

    function getPrefillRefreshModal() {
      if (!prefillRefreshModalEl) return null;
      if (prefillRefreshModal) return prefillRefreshModal;
      if (typeof window.bootstrap !== 'undefined' && window.bootstrap?.Modal) {
        prefillRefreshModal = window.bootstrap.Modal.getOrCreateInstance
          ? window.bootstrap.Modal.getOrCreateInstance(prefillRefreshModalEl)
          : new window.bootstrap.Modal(prefillRefreshModalEl);
        return prefillRefreshModal;
      }
      return null;
    }

    function showPrefillRefreshModalFallback() {
      if (!prefillRefreshModalEl) return false;
      prefillRefreshModalEl.classList.add('show');
      prefillRefreshModalEl.style.display = 'block';
      prefillRefreshModalEl.removeAttribute('aria-hidden');
      prefillRefreshModalEl.setAttribute('aria-modal', 'true');
      prefillRefreshModalEl.setAttribute('role', 'dialog');
      document.body.classList.add('modal-open');
      let backdrop = document.getElementById('prefillRefreshReviewBackdrop');
      if (!backdrop) {
        backdrop = document.createElement('div');
        backdrop.id = 'prefillRefreshReviewBackdrop';
        backdrop.className = 'modal-backdrop fade show';
        document.body.appendChild(backdrop);
      }
      return true;
    }

    function hidePrefillRefreshModalFallback() {
      if (!prefillRefreshModalEl) return;
      prefillRefreshModalEl.classList.remove('show');
      prefillRefreshModalEl.style.display = 'none';
      prefillRefreshModalEl.setAttribute('aria-hidden', 'true');
      prefillRefreshModalEl.removeAttribute('aria-modal');
      prefillRefreshModalEl.removeAttribute('role');
      const backdrop = document.getElementById('prefillRefreshReviewBackdrop');
      if (backdrop) backdrop.remove();
      document.body.classList.remove('modal-open');
    }

    function showPrefillRefreshModal() {
      const modal = getPrefillRefreshModal();
      if (modal) {
        modal.show();
        return true;
      }
      return showPrefillRefreshModalFallback();
    }

    function hidePrefillRefreshModal() {
      const modal = getPrefillRefreshModal();
      if (modal) modal.hide();
      hidePrefillRefreshModalFallback();
    }

    async function readJsonResponse(response, fallbackMessage) {
      const text = await response.text();
      let result = null;
      try {
        result = JSON.parse(text || '{}');
      } catch (_) {
        const stripped = String(text || '')
          .replace(/<script[\s\S]*?<\/script>/gi, ' ')
          .replace(/<style[\s\S]*?<\/style>/gi, ' ')
          .replace(/<[^>]+>/g, ' ')
          .replace(/\s+/g, ' ')
          .trim();
        throw new Error(stripped || fallbackMessage || 'Request failed.');
      }
      if (!response.ok || result?.status === 'error') {
        throw new Error(result?.message || fallbackMessage || 'Request failed.');
      }
      return result;
    }

    function bindPrefillRefreshControls() {
      if (btnReviewPrefillUpdates && btnReviewPrefillUpdates.dataset.prefillRefreshBound !== '1') {
        btnReviewPrefillUpdates.dataset.prefillRefreshBound = '1';
        btnReviewPrefillUpdates.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          reviewPrefillUpdates();
        });
      }
      if (btnApplyPrefillRefresh && btnApplyPrefillRefresh.dataset.prefillRefreshBound !== '1') {
        btnApplyPrefillRefresh.dataset.prefillRefreshBound = '1';
        btnApplyPrefillRefresh.addEventListener('click', (event) => {
          event.preventDefault();
          applySelectedPrefillUpdates();
        });
      }
      if (btnToggleAllPrefillRefresh && btnToggleAllPrefillRefresh.dataset.prefillRefreshBound !== '1') {
        btnToggleAllPrefillRefresh.dataset.prefillRefreshBound = '1';
        btnToggleAllPrefillRefresh.addEventListener('click', () => {
          const boxes = Array.from(document.querySelectorAll('.js-prefill-refresh-key'));
          const shouldCheck = boxes.some((box) => !box.checked);
          boxes.forEach((box) => { box.checked = shouldCheck; });
          btnToggleAllPrefillRefresh.textContent = shouldCheck ? 'Clear All' : 'Select All';
        });
      }
      prefillRefreshModalEl?.querySelectorAll('[data-bs-dismiss="modal"]').forEach((btn) => {
        if (btn.dataset.prefillRefreshDismissBound === '1') return;
        btn.dataset.prefillRefreshDismissBound = '1';
        btn.addEventListener('click', () => hidePrefillRefreshModal());
      });
    }

    bindPrefillRefreshControls();

    async function confirmLeave(title, message, confirmLabel) {
      const confirmText = confirmLabel || 'Close';
      if (typeof showMessageModal === 'function') {
        const res = await showMessageModal({
          title: title || 'Leave this page?',
          icon: 'question',
          message: message || 'Unsaved changes will be lost unless you save first.',
          buttons: [
            { text: 'Stay', class: 'btn-secondary' },
            { text: confirmText, class: 'btn-warning' }
          ]
        });
        return res === confirmText;
      }
      return window.confirm(message || 'Leave this page?');
    }

    function resolveReturnHref() {
      const fromServer = String(returnInput && returnInput.value ? returnInput.value : '').trim();
      if (fromServer) return fromServer;
      const ref = String(document.referrer || '').trim();
      if (!ref || !ref.startsWith(window.location.origin)) return '';
      try {
        const u = new URL(ref);
        if (u.pathname === window.location.pathname) return '';
        return ref;
      } catch (e) {
        return '';
      }
    }

    function bindReportReviewNavigatorLinks() {
      reportReviewNavLinks.forEach((link) => {
        if (!link || link.dataset.reportReviewNavBound === '1') return;
        link.dataset.reportReviewNavBound = '1';
        link.addEventListener('click', async (event) => {
          const href = String(link.getAttribute('href') || '').trim();
          if (!href) return;
          event.preventDefault();
          const ok = await confirmLeave(
            'Open another report?',
            'Open this report? Unsaved changes on the current form will be lost unless you save first.',
            'Open Report'
          );
          if (ok) window.location.href = href;
        });
      });
    }

    function parseJsonScript(el, fallback) {
      if (!el) return fallback;
      try { return JSON.parse(String(el.textContent || '').trim() || 'null') || fallback; } catch (_) { return fallback; }
    }

    function renderPrefillRefreshRows(changes) {
      prefillRefreshChanges = Array.isArray(changes) ? changes : [];
      if (prefillRefreshSummary) {
        prefillRefreshSummary.textContent = `${prefillRefreshChanges.length} changed prefill key${prefillRefreshChanges.length === 1 ? '' : 's'} ready for review.`;
      }
      if (btnToggleAllPrefillRefresh) btnToggleAllPrefillRefresh.textContent = 'Clear All';
      if (!prefillRefreshRows) return;
      if (!prefillRefreshChanges.length) {
        prefillRefreshRows.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-4">No prefill value changes were found.</td></tr>';
        return;
      }
      prefillRefreshRows.innerHTML = prefillRefreshChanges.map((change) => {
        const fields = Array.isArray(change.fields) ? change.fields : [];
        const labels = fields.map((field) => field.label || field.fieldId || 'Report field').join(', ');
        const currentValues = fields.map((field) => formatPreviewValue(field.currentValue)).join('<hr class="my-1">');
        const oldValues = fields.map((field) => formatPreviewValue(field.oldValue)).join('<hr class="my-1">');
        const newValues = fields.map((field) => formatPreviewValue(field.newValue)).join('<hr class="my-1">');
        return `
          <tr>
            <td><input type="checkbox" class="form-check-input js-prefill-refresh-key" value="${escapeHtml(change.prefillKey)}" checked></td>
            <td>${escapeHtml(labels || '-')}</td>
            <td>${currentValues || '<span class="text-muted">empty</span>'}</td>
            <td>${oldValues || '<span class="text-muted">empty</span>'}</td>
            <td>${newValues || '<span class="text-muted">empty</span>'}</td>
          </tr>
        `;
      }).join('');
    }

    async function reviewPrefillUpdates() {
      const token = showLoadingToken({
        title: 'Checking Prefill Updates',
        note: 'Please wait while current prefill values are compared with this report.',
        operation: 'Report Instance'
      });
      try {
        const response = await fetch(`/school/reports/instances/edit/${encodeURIComponent(instanceId)}/prefill-preview`, {
          headers: { 'X-AJAX-Request': 'true', 'Accept': 'application/json' },
          cache: 'no-store'
        });
        const result = await readJsonResponse(response, 'Could not preview prefill updates.');
        renderPrefillRefreshRows(result.changes || []);
        hideLoadingToken(token);
        if (!Array.isArray(result.changes) || !result.changes.length) {
          await showReportInstanceMessage({
            title: 'Prefill Updates',
            icon: 'info',
            message: result.message || 'No prefill value changes were found.'
          });
          return;
        }
        if (!showPrefillRefreshModal()) {
          await showReportInstanceMessage({
            title: 'Prefill Updates Ready',
            icon: 'info',
            message: 'Prefill changes were found, but the preview modal could not be opened on this page.'
          });
        }
      } catch (error) {
        hideLoadingToken(token);
        await showReportInstanceMessage({
          title: 'Prefill Update Check Failed',
          icon: 'error',
          message: error.message || 'Could not check prefill updates.'
        });
      }
    }

    async function applySelectedPrefillUpdates() {
      const selectedKeys = Array.from(document.querySelectorAll('.js-prefill-refresh-key:checked'))
        .map((input) => String(input.value || '').trim())
        .filter(Boolean);
      if (!selectedKeys.length) {
        await showReportInstanceMessage({
          title: 'Prefill Updates',
          icon: 'warning',
          message: 'Select at least one prefill key to replace.'
        });
        return;
      }
      hidePrefillRefreshModal();
      const token = showLoadingToken({
        title: 'Applying Prefill Updates',
        note: 'Please wait while selected prefill values are replaced.',
        operation: 'Report Instance'
      });
      try {
        const actionStateId = String(document.getElementById('reportInstanceActionStateId')?.value || '').trim();
        const response = await fetch(`/school/reports/instances/edit/${encodeURIComponent(instanceId)}/prefill-apply`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-AJAX-Request': 'true',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ selectedKeys, actionStateId })
        });
        const result = await readJsonResponse(response, 'Could not apply selected prefill updates.');
        hideLoadingToken(token);
        await showReportInstanceMessage({
          title: 'Prefill Updated',
          icon: 'success',
          message: result.message || 'Selected prefill values were updated.'
        });
        window.location.reload();
      } catch (error) {
        hideLoadingToken(token);
        await showReportInstanceMessage({
          title: 'Prefill Update Failed',
          icon: 'error',
          message: error.message || 'Could not apply selected prefill updates.'
        });
      }
    }

    function isVisualOnlyField(field) {
      const t = String(field?.type || '').trim().toLowerCase();
      return t === 'section' || t === 'subheader' || t === 'row_break';
    }

    function normalizeValueMode(rawMode) {
      return String(rawMode || 'manual').trim().toLowerCase() === 'calculated' ? 'calculated' : 'manual';
    }

    function isCalculatedField(field) {
      return !isVisualOnlyField(field) && normalizeValueMode(field?.valueMode) === 'calculated';
    }

    function normalizeCalculationRule(rawRule) {
      const rule = rawRule && typeof rawRule === 'object' ? rawRule : {};
      return {
        enabled: rule.enabled === true || String(rule.enabled || '').trim().toLowerCase() === 'true',
        expression: String(rule.expression || '').trim(),
        onError: String(rule.onError || 'keep_last').trim().toLowerCase() === 'empty' ? 'empty' : 'keep_last'
      };
    }

    function normalizeCalculationDependencies(rawList) {
      const list = Array.isArray(rawList)
        ? rawList
        : String(rawList || '').split(',').map((item) => String(item || '').trim()).filter(Boolean);
      const out = [];
      const seen = new Set();
      list.forEach((item) => {
        const token = String(item || '').trim();
        if (!token) return;
        const key = token.toLowerCase();
        if (seen.has(key)) return;
        seen.add(key);
        out.push(token);
      });
      return out;
    }

    function findValidationSlot(fieldId) {
      const slots = Array.from(document.querySelectorAll('.js-field-validation[data-field-validation-for]'));
      return slots.find((el) => String(el.getAttribute('data-field-validation-for') || '').trim() === String(fieldId || '').trim()) || null;
    }

    function setFieldIssues(fieldId, issues) {
      const slot = findValidationSlot(fieldId);
      if (!slot) return;
      const list = Array.isArray(issues) ? issues.slice(0, 2) : [];
      if (!list.length) {
        slot.innerHTML = '';
        return;
      }
      slot.innerHTML = list.map((issue) => {
        const severity = String(issue?.severity || 'error').trim().toLowerCase() === 'warning' ? 'warning' : 'error';
        const cls = severity === 'warning' ? 'text-warning-emphasis' : 'text-danger';
        const icon = severity === 'warning' ? 'bi-exclamation-triangle' : 'bi-x-circle';
        return `<div class="${cls}"><i class="bi ${icon} me-1"></i>${String(issue?.message || 'Validation failed.')}</div>`;
      }).join('');
    }

    function helpers() {
      return {
        num(value, fallback = 0) {
          const n = Number(value);
          return Number.isFinite(n) ? n : Number(fallback || 0);
        },
        str(value) {
          if (value === undefined || value === null) return '';
          return String(value);
        },
        len(value) {
          if (Array.isArray(value) || typeof value === 'string') return value.length;
          if (value && typeof value === 'object') return Object.keys(value).length;
          return 0;
        },
        round(value, decimals = 0) {
          const n = Number(value);
          if (!Number.isFinite(n)) return NaN;
          const d = Math.max(0, Math.min(8, Math.floor(Number(decimals) || 0)));
          const factor = 10 ** d;
          return Math.round(n * factor) / factor;
        },
        min() { return Math.min(...Array.from(arguments).map((v) => Number(v))); },
        max() { return Math.max(...Array.from(arguments).map((v) => Number(v))); },
        abs(value) { return Math.abs(Number(value)); },
        clamp(value, minValue, maxValue) {
          const n = Number(value);
          const min = Number(minValue);
          const max = Number(maxValue);
          if (!Number.isFinite(n) || !Number.isFinite(min) || !Number.isFinite(max)) return NaN;
          return Math.min(Math.max(n, min), max);
        },
        ifelse(condition, whenTrue, whenFalse = '') {
          return condition ? whenTrue : whenFalse;
        },
        caseof(value) {
          const branches = Array.from(arguments).slice(1);
          if (!branches.length) return value;
          const hasDefault = branches.length % 2 === 1;
          const pairLimit = hasDefault ? branches.length - 1 : branches.length;
          for (let i = 0; i < pairLimit; i += 2) {
            if (value == branches[i]) return branches[i + 1]; // eslint-disable-line eqeqeq
          }
          if (hasDefault) return branches[branches.length - 1];
          return value;
        }
      };
    }

    function tokenize(expression) {
      const src = String(expression || '').trim();
      if (!src) throw new Error('Empty expression.');
      const out = [];
      let i = 0;
      while (i < src.length) {
        const ch = src[i];
        if (/\s/.test(ch)) { i += 1; continue; }
        const two = src.slice(i, i + 2);
        if (['&&', '||', '==', '!=', '<=', '>='].includes(two)) { out.push({ t: 'op', v: two }); i += 2; continue; }
        if (['+', '-', '*', '/', '%', '<', '>', '!', '(', ')', ',', '.'].includes(ch)) {
          if (ch === '(' || ch === ')') out.push({ t: 'paren', v: ch });
          else if (ch === ',') out.push({ t: 'comma', v: ch });
          else out.push({ t: 'op', v: ch });
          i += 1;
          continue;
        }
        if (ch === '"' || ch === '\'') {
          const q = ch;
          i += 1;
          let s = '';
          let closed = false;
          while (i < src.length) {
            const c = src[i];
            if (c === '\\') {
              const next = src[i + 1];
              if (next === undefined) break;
              s += next === 'n' ? '\n' : next === 't' ? '\t' : next;
              i += 2;
              continue;
            }
            if (c === q) { i += 1; closed = true; break; }
            s += c;
            i += 1;
          }
          if (!closed) throw new Error('Unterminated string literal in expression.');
          out.push({ t: 'str', v: s });
          continue;
        }
        if (/[0-9]/.test(ch) || (ch === '.' && /[0-9]/.test(src[i + 1]))) {
          let e = i + 1;
          while (e < src.length && /[0-9.]/.test(src[e])) e += 1;
          out.push({ t: 'num', v: Number(src.slice(i, e)) });
          i = e;
          continue;
        }
        if (/[A-Za-z_]/.test(ch)) {
          let e = i + 1;
          while (e < src.length && /[A-Za-z0-9_]/.test(src[e])) e += 1;
          out.push({ t: 'id', v: src.slice(i, e) });
          i = e;
          continue;
        }
        throw new Error('Unsupported character in expression.');
      }
      out.push({ t: 'eof', v: '' });
      return out;
    }

    function evaluateExpression(expression, context) {
      const tokens = tokenize(expression);
      let pos = 0;
      const helperFns = helpers();
      const ctx = {
        value: context?.value,
        answers: context?.answers && typeof context.answers === 'object' ? context.answers : {},
        prefill: context?.prefill && typeof context.prefill === 'object' ? context.prefill : {}
      };

      function cur() { return tokens[pos]; }
      function match(type, value) {
        const t = cur();
        if (!t || t.t !== type) return false;
        if (value !== undefined && t.v !== value) return false;
        pos += 1;
        return true;
      }
      function expect(type, value) {
        if (match(type, value)) return tokens[pos - 1];
        throw new Error('Invalid expression syntax.');
      }
      function resolve(path) {
        const root = path[0];
        if (root === 'true') return true;
        if (root === 'false') return false;
        if (root === 'null') return null;
        if (root === 'undefined') return undefined;
        if (!Object.prototype.hasOwnProperty.call(ctx, root)) throw new Error('Unknown identifier.');
        let out = ctx[root];
        for (let i = 1; i < path.length; i += 1) {
          const key = path[i];
          if (out === null || out === undefined) return undefined;
          if (typeof out !== 'object' && typeof out !== 'function') return undefined;
          out = Object.prototype.hasOwnProperty.call(out, key) ? out[key] : undefined;
        }
        return out;
      }
      function primary() {
        const t = cur();
        if (match('num')) return { k: 'lit', v: t.v };
        if (match('str')) return { k: 'lit', v: t.v };
        if (match('paren', '(')) {
          const node = exprOr();
          expect('paren', ')');
          return node;
        }
        if (match('id')) {
          const path = [t.v];
          while (match('op', '.')) path.push(expect('id').v);
          if (match('paren', '(')) {
            const args = [];
            if (!match('paren', ')')) {
              while (true) {
                args.push(exprOr());
                if (match('paren', ')')) break;
                expect('comma', ',');
              }
            }
            return { k: 'call', path, args };
          }
          return { k: 'path', path };
        }
        throw new Error('Invalid expression syntax.');
      }
      function unary() {
        if (match('op', '!')) return { k: 'un', op: '!', a: unary() };
        if (match('op', '-')) return { k: 'un', op: '-', a: unary() };
        if (match('op', '+')) return { k: 'un', op: '+', a: unary() };
        return primary();
      }
      function mul() {
        let n = unary();
        while (true) {
          if (match('op', '*')) n = { k: 'bin', op: '*', l: n, r: unary() };
          else if (match('op', '/')) n = { k: 'bin', op: '/', l: n, r: unary() };
          else if (match('op', '%')) n = { k: 'bin', op: '%', l: n, r: unary() };
          else break;
        }
        return n;
      }
      function add() {
        let n = mul();
        while (true) {
          if (match('op', '+')) n = { k: 'bin', op: '+', l: n, r: mul() };
          else if (match('op', '-')) n = { k: 'bin', op: '-', l: n, r: mul() };
          else break;
        }
        return n;
      }
      function cmp() {
        let n = add();
        while (true) {
          if (match('op', '<')) n = { k: 'bin', op: '<', l: n, r: add() };
          else if (match('op', '>')) n = { k: 'bin', op: '>', l: n, r: add() };
          else if (match('op', '<=')) n = { k: 'bin', op: '<=', l: n, r: add() };
          else if (match('op', '>=')) n = { k: 'bin', op: '>=', l: n, r: add() };
          else break;
        }
        return n;
      }
      function eq() {
        let n = cmp();
        while (true) {
          if (match('op', '==')) n = { k: 'bin', op: '==', l: n, r: cmp() };
          else if (match('op', '!=')) n = { k: 'bin', op: '!=', l: n, r: cmp() };
          else break;
        }
        return n;
      }
      function exprAnd() {
        let n = eq();
        while (match('op', '&&')) n = { k: 'bin', op: '&&', l: n, r: eq() };
        return n;
      }
      function exprOr() {
        let n = exprAnd();
        while (match('op', '||')) n = { k: 'bin', op: '||', l: n, r: exprAnd() };
        return n;
      }
      function run(node) {
        if (!node) return undefined;
        if (node.k === 'lit') return node.v;
        if (node.k === 'path') return resolve(node.path);
        if (node.k === 'call') {
          if (!Array.isArray(node.path) || node.path.length !== 1) throw new Error('Invalid helper call.');
          const fn = helperFns[node.path[0]];
          if (typeof fn !== 'function') throw new Error('Unknown helper call.');
          return fn(...node.args.map((arg) => run(arg)));
        }
        if (node.k === 'un') {
          const v = run(node.a);
          if (node.op === '!') return !v;
          if (node.op === '-') return -Number(v);
          if (node.op === '+') return Number(v);
        }
        if (node.k === 'bin') {
          if (node.op === '&&') {
            const left = run(node.l);
            return left ? run(node.r) : left;
          }
          if (node.op === '||') {
            const left = run(node.l);
            return left ? left : run(node.r);
          }
          const l = run(node.l);
          const r = run(node.r);
          if (node.op === '+') return l + r;
          if (node.op === '-') return Number(l) - Number(r);
          if (node.op === '*') return Number(l) * Number(r);
          if (node.op === '/') return Number(l) / Number(r);
          if (node.op === '%') return Number(l) % Number(r);
          if (node.op === '<') return l < r;
          if (node.op === '>') return l > r;
          if (node.op === '<=') return l <= r;
          if (node.op === '>=') return l >= r;
          if (node.op === '==') return l == r; // eslint-disable-line eqeqeq
          if (node.op === '!=') return l != r; // eslint-disable-line eqeqeq
        }
        throw new Error('Invalid expression evaluation.');
      }
      const ast = exprOr();
      expect('eof');
      return run(ast);
    }

    function readFieldValue(field) {
      if (!formEl || !field?.id) return '';
      const name = `field__${field.id}`;
      const input = formEl.elements[name];
      if (!input) return '';
      const type = String(field.type || '').trim().toLowerCase();
      if (type === 'checkbox') return input.checked === true;
      if (type === 'number') {
        const raw = String(input.value || '').trim();
        if (!raw) return '';
        const n = Number(raw);
        return Number.isFinite(n) ? n : '';
      }
      return String(input.value || '').trim();
    }

    function findFieldElementById(fieldId) {
      if (!formEl || !fieldId) return null;
      const target = String(fieldId || '').trim();
      if (!target) return null;
      const candidates = Array.from(formEl.querySelectorAll('[data-field-id]'));
      return candidates.find((el) => String(el.getAttribute('data-field-id') || '').trim() === target) || null;
    }

    function writeFieldValue(field, nextValue) {
      if (!formEl || !field?.id) return;
      const name = `field__${field.id}`;
      let input = formEl.elements[name];
      if (input && typeof input.length === 'number' && !input.tagName) {
        input = input[0] || null;
      }
      if (!input) {
        input = findFieldElementById(field.id);
      }
      if (!input) return;
      const type = String(field.type || '').trim().toLowerCase();
      if (type === 'checkbox') {
        input.checked = nextValue === true || String(nextValue).toLowerCase() === 'true' || String(nextValue) === '1';
        return;
      }
      if (type === 'number') {
        if (nextValue === undefined || nextValue === null || nextValue === '') {
          input.value = '';
          return;
        }
        const n = Number(nextValue);
        input.value = Number.isFinite(n) ? String(n) : '';
        return;
      }
      if (nextValue === undefined || nextValue === null) {
        input.value = '';
        return;
      }
      input.value = String(nextValue);
    }

    function hasValue(v) {
      if (v === undefined || v === null) return false;
      if (typeof v === 'string') return v.trim() !== '';
      return true;
    }

    function buildCalculatedFieldPlan(fields) {
      const list = Array.isArray(fields) ? fields : [];
      const dataFields = list.filter((field) => !isVisualOnlyField(field) && field?.id);
      const fieldMap = new Map(dataFields.map((field) => [String(field.id), field]));
      const calculated = dataFields.filter((field) => isCalculatedField(field));
      const calculatedIds = new Set(calculated.map((field) => String(field.id)));
      const indegree = new Map();
      const reverseAdj = new Map();

      calculated.forEach((field) => {
        const id = String(field.id);
        indegree.set(id, 0);
        reverseAdj.set(id, []);
      });

      calculated.forEach((field) => {
        const fieldId = String(field.id);
        const deps = normalizeCalculationDependencies(field?.calculationDependencies || []);
        deps.forEach((depIdRaw) => {
          const depId = String(depIdRaw || '').trim();
          if (!depId || depId === fieldId) return;
          if (!fieldMap.has(depId)) return;
          if (!calculatedIds.has(depId)) return;
          reverseAdj.get(depId).push(fieldId);
          indegree.set(fieldId, (indegree.get(fieldId) || 0) + 1);
        });
      });

      const queue = [...calculatedIds].filter((id) => (indegree.get(id) || 0) === 0);
      const orderedIds = [];
      while (queue.length) {
        const current = queue.shift();
        orderedIds.push(current);
        const targets = reverseAdj.get(current) || [];
        targets.forEach((targetId) => {
          const next = (indegree.get(targetId) || 0) - 1;
          indegree.set(targetId, next);
          if (next === 0) queue.push(targetId);
        });
      }
      return {
        fieldMap,
        orderedIds
      };
    }

    function recomputeCalculatedAnswers(fields, mergedAnswers, prefill) {
      if (window.SchoolReportCalculatedFields?.recomputeCalculatedAnswers) {
        return window.SchoolReportCalculatedFields.recomputeCalculatedAnswers({
          fields,
          answers: mergedAnswers,
          prefill
        }).answers;
      }
      const nextAnswers = mergedAnswers && typeof mergedAnswers === 'object' ? { ...mergedAnswers } : {};
      const prefillSafe = prefill && typeof prefill === 'object' ? prefill : {};
      const plan = buildCalculatedFieldPlan(fields);

      plan.orderedIds.forEach((fieldId) => {
        const field = plan.fieldMap.get(fieldId);
        if (!field) return;
        const rule = normalizeCalculationRule(field?.calculationRule || {});
        if (!rule.enabled || !rule.expression) return;
        const prevValue = nextAnswers[fieldId];
        try {
          const computed = evaluateExpression(rule.expression, {
            value: prevValue,
            answers: nextAnswers,
            prefill: prefillSafe
          });
          nextAnswers[fieldId] = computed;
        } catch (_) {
          if (rule.onError === 'empty') nextAnswers[fieldId] = '';
          else nextAnswers[fieldId] = prevValue;
        }
      });

      return nextAnswers;
    }

    function collectAnswers(fields, mergedBefore) {
      const base = mergedBefore && typeof mergedBefore === 'object' ? { ...mergedBefore } : {};
      (Array.isArray(fields) ? fields : []).forEach((field) => {
        if (isVisualOnlyField(field) || !field?.id || field.readOnly === true || isCalculatedField(field)) return;
        base[field.id] = readFieldValue(field);
      });
      return base;
    }

    function validateFields(fields, mergedAnswers, prefill) {
      const issuesByField = {};
      const allIssues = [];
      (Array.isArray(fields) ? fields : []).forEach((field) => {
        if (isVisualOnlyField(field) || !field?.id) return;
        const fieldId = String(field.id || '').trim();
        const label = String(field.label || fieldId || 'Field').trim();
        const value = mergedAnswers[fieldId];
        const issues = [];
        if (field.required === true && !hasValue(value)) {
          issues.push({ severity: 'error', message: `Field "${label}" is required.` });
        }
        const type = String(field.type || '').trim().toLowerCase();
        if (type === 'number' && hasValue(value) && !Number.isFinite(Number(value))) {
          issues.push({ severity: 'error', message: `Invalid numeric value for "${label}".` });
        }
        const rules = Array.isArray(field.validationRules) ? field.validationRules : [];
        rules.forEach((rule, idx) => {
          const enabled = rule?.enabled !== false && String(rule?.enabled || '').trim().toLowerCase() !== 'false';
          if (!enabled) return;
          const when = String(rule?.when || 'always').trim().toLowerCase();
          if (when === 'if_has_value' && !hasValue(value)) return;
          const expr = String(rule?.expression || '').trim();
          if (!expr) return;
          try {
            const passed = Boolean(evaluateExpression(expr, { value, answers: mergedAnswers, prefill }));
            if (!passed) {
              const severity = String(rule?.severity || 'error').trim().toLowerCase() === 'warning' ? 'warning' : 'error';
              issues.push({
                severity,
                message: String(rule?.message || `Validation failed for "${label}" (rule ${idx + 1}).`).trim()
              });
            }
          } catch (err) {
            issues.push({
              severity: 'error',
              message: `Validation rule error for "${label}".`
            });
          }
        });
        issuesByField[fieldId] = issues;
        issues.forEach((issue) => allIssues.push({ ...issue, fieldId }));
      });
      return {
        issuesByField,
        allIssues,
        errors: allIssues.filter((issue) => issue.severity === 'error'),
        warnings: allIssues.filter((issue) => issue.severity === 'warning')
      };
    }

    function runClientValidation() {
      const fields = parseJsonScript(fieldConfigEl, []);
      const mergedBefore = parseJsonScript(mergedDataEl, {});
      const prefill = parseJsonScript(prefillDataEl, {});
      const userAnswers = collectAnswers(fields, mergedBefore);
      const mergedAnswers = recomputeCalculatedAnswers(fields, userAnswers, prefill);
      (Array.isArray(fields) ? fields : []).forEach((field) => {
        if (!isCalculatedField(field) || !field?.id) return;
        writeFieldValue(field, mergedAnswers[field.id]);
      });
      const summary = validateFields(fields, mergedAnswers, prefill);
      Object.keys(summary.issuesByField).forEach((fieldId) => {
        setFieldIssues(fieldId, summary.issuesByField[fieldId]);
      });
      return summary;
    }

    function rememberValidationSummaryFocus(submitAction) {
      const action = String(submitAction || '').trim().toLowerCase();
      if (!['save', 'submit'].includes(action)) return;
      try {
        sessionStorage.setItem(summaryFocusStorageKey, JSON.stringify({
          instanceId,
          action,
          at: Date.now()
        }));
      } catch (_) {
        // ignore storage errors
      }
    }

    function focusValidationSummaryIfRequested() {
      if (!validationSummaryCard || !validationSummaryToggle) return;
      let payload = null;
      try {
        payload = JSON.parse(String(sessionStorage.getItem(summaryFocusStorageKey) || 'null'));
      } catch (_) {
        payload = null;
      }
      if (!payload || String(payload.instanceId || '') !== instanceId) return;
      try { sessionStorage.removeItem(summaryFocusStorageKey); } catch (_) {}
      const elapsed = Date.now() - Number(payload.at || 0);
      if (!Number.isFinite(elapsed) || elapsed > 45000) return;
      validationSummaryCard.scrollIntoView({ behavior: 'smooth', block: 'start' });
      setTimeout(() => {
        try { validationSummaryToggle.focus({ preventScroll: true }); } catch (_) {}
      }, 220);
    }

    focusValidationSummaryIfRequested();

    if (formEl) {
      try {
        let validationDebounceTimer = null;
        const scheduleClientValidation = () => {
          if (validationDebounceTimer) clearTimeout(validationDebounceTimer);
          validationDebounceTimer = setTimeout(() => {
            validationDebounceTimer = null;
            runClientValidation();
          }, 120);
        };
        formEl.querySelectorAll('.js-report-field').forEach((input) => {
          input.addEventListener('input', scheduleClientValidation);
          input.addEventListener('change', scheduleClientValidation);
        });
        runClientValidation();

        formEl.querySelectorAll('button[type="submit"][name="submitAction"][value="submit"]').forEach((btn) => {
          btn.addEventListener('click', async (event) => {
            const summary = runClientValidation();
            if (!summary.errors.length) return;
            event.preventDefault();
            const first = summary.errors[0];
            if (typeof showMessageModal === 'function') {
              await showMessageModal({
                title: 'Validation Error',
                icon: 'warning',
                message: `${first.message} Please fix validation errors before submitting.`,
                buttons: [{ text: 'OK', class: 'btn-primary' }]
              });
            } else {
              window.alert(`${first.message} Please fix validation errors before submitting.`);
            }
          });
        });

        formEl.addEventListener('submit', async (event) => {
          const submitter = event.submitter || null;
          const submitAction = String(submitter?.value || '').trim().toLowerCase();
          rememberValidationSummaryFocus(submitAction);
          if (!getReportInstanceActionStateId()) {
            event.preventDefault();
            await showExpiredActionStateMessage();
            return;
          }
          if (submitAction === 'submit') {
            const summary = runClientValidation();
            if (summary.errors.length) {
              event.preventDefault();
              const first = summary.errors[0];
              if (typeof showMessageModal === 'function') {
                await showMessageModal({
                  title: 'Validation Error',
                  icon: 'warning',
                  message: `${first.message} Please fix validation errors before submitting.`,
                  buttons: [{ text: 'OK', class: 'btn-primary' }]
                });
              } else {
                window.alert(`${first.message} Please fix validation errors before submitting.`);
              }
              return;
            }
          }
          if (reportInstanceSubmitting) {
            event.preventDefault();
            await showReportInstanceMessage({
              title: 'Save Already Running',
              icon: 'info',
              message: 'This report save is already in progress. Please wait for it to finish.'
            });
            return;
          }
          setReportInstanceSubmitting(true, submitter);
          reportInstanceSubmitLoadingToken = showLoadingToken({
            title: submitAction === 'submit' ? 'Submitting Report' : 'Saving Report',
            note: 'Please wait while this report instance is saved.',
            operation: 'Report Instance'
          });
        }, true);
      } catch (error) {
        console.error('Report editor validation initialization failed:', error);
      }
    }

    if (btnClose) {
      btnClose.addEventListener('click', async () => {
        const ok = await confirmLeave(
          'Close report editor?',
          'Leave this page? Unsaved changes will be lost unless you save first.',
          'Close'
        );
        if (!ok) return;
        const target = resolveReturnHref();
        if (target) {
          window.location.href = target;
          return;
        }
        window.close();
        setTimeout(function () {
          try {
            if (window.history.length > 1) window.history.back();
            else window.location.href = '/school/reports/instances';
          } catch (err) { /* ignore */ }
        }, 200);
      });
    }

    bindReportReviewNavigatorLinks();
    bindPrefillRefreshControls();

    async function postReportLifecycleAction(kind, instanceId) {
      const id = String(instanceId || '').trim();
      if (!id) return;
      const api = window.ReportAssignmentDelete;
      if (!api || typeof api.reopenReportInstance !== 'function' || typeof api.unlockReportInstance !== 'function') {
        window.alert('Unable to process this action. Please hard-refresh the page (Ctrl+F5) and try again.');
        return;
      }
      const actionStateId = String(
        document.getElementById('reportInstanceActionStateId')?.value
        || formEl?.querySelector('input[name="actionStateId"]')?.value
        || ''
      ).trim();
      const confirmFn = kind === 'reopen'
        ? (typeof api.confirmReopen === 'function'
          ? (msg) => api.confirmReopen(msg)
          : async (msg) => window.confirm(String(msg || '')))
        : (typeof api.confirmUnlock === 'function'
          ? (msg) => api.confirmUnlock(msg)
          : async (msg) => window.confirm(String(msg || '')));
      try {
        if (kind === 'reopen') {
          const confirmed = await confirmFn(
            'Reopen this report as draft so the teacher can edit it?'
          );
          if (!confirmed) return;
          await api.withLoading('Reopening report...', function () {
            return api.reopenReportInstance(id, { actionStateId });
          });
        } else {
          const confirmed = await confirmFn(
            'Unlock this report? Status will return to submitted.'
          );
          if (!confirmed) return;
          await api.withLoading('Unlocking report...', function () {
            return api.unlockReportInstance(id, { actionStateId });
          });
        }
        window.location.reload();
      } catch (error) {
        if (typeof api.showError === 'function') {
          api.showError(error?.message || (kind === 'reopen'
            ? 'Unable to reopen report.'
            : 'Unable to unlock report.'));
        } else {
          window.alert(error?.message || 'Unable to process this action.');
        }
      }
    }

    document.querySelectorAll('.js-reopen-report-instance').forEach(function (button) {
      button.addEventListener('click', function () {
        postReportLifecycleAction('reopen', button.getAttribute('data-instance-id'));
      });
    });
    document.querySelectorAll('.js-unlock-report-instance').forEach(function (button) {
      button.addEventListener('click', function () {
        postReportLifecycleAction('unlock', button.getAttribute('data-instance-id'));
      });
    });
  })();
</script>

