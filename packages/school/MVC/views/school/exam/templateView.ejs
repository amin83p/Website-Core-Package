<div class="sections-page">
  <div class="row g-2 align-items-start mb-4">
    <div class="col">
      <h1 class="page-heading size-md m-0 text-start" style="padding-left:0;">Exam Template</h1>
      <h6 class="fw-semibold text-primary mt-2 mb-0"><%= template?.title || 'Exam Template' %></h6>
      <div class="text-muted small mt-1">
        <% if (template?.description) { %>
          <%= template.description %>
        <% } else { %>
          No description.
        <% } %>
      </div>
    </div>
    <div class="col-auto d-flex flex-column align-items-end gap-1">
      <span class="badge bg-primary border font-monospace">ID: <%= template?.id || '' %></span>
      <a href="/school/exams" class="btn btn-outline-secondary btn-sm"><i class="bi bi-house me-1"></i>Exam Home</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <a href="/school/exams/templates" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Templates</a>
        <% if (!(templateLockState?.isLocked)) { %>
          <a href="/school/exams/templates/edit/<%= template.id %>" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil-square me-1"></i>Edit</a>
          <a href="/school/exams/templates/edit/<%= template.id %>#tab-questions" class="btn btn-outline-primary btn-sm"><i class="bi bi-ui-checks-grid me-1"></i>Question Builder</a>
        <% } else { %>
          <button class="btn btn-outline-secondary btn-sm" type="button" disabled><i class="bi bi-lock me-1"></i>Locked</button>
        <% } %>
        <% if (!(templateLockState?.isLocked) && draftRevision) { %>
          <form method="POST" action="/school/exams/templates/<%= template.id %>/publish" class="d-inline">
            <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
            <button type="submit" class="btn btn-outline-warning btn-sm text-dark"><i class="bi bi-megaphone me-1"></i>Publish</button>
          </form>
        <% } %>
        <% if (publishedRevision) { %>
          <a href="/school/exams/templates/<%= template.id %>/allocate" class="btn btn-outline-success btn-sm"><i class="bi bi-calendar2-check me-1"></i>Allocate</a>
        <% } %>
        <% if (publishedRevision || template?.publishedRevisionId) { %>
          <form method="POST" action="/school/exams/templates/<%= template.id %>/revisions/create-copy" class="d-inline">
            <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
            <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-files me-1"></i>Create Revision Copy</button>
          </form>
        <% } else { %>
          <button type="button" class="btn btn-outline-secondary btn-sm" disabled title="Publish this template before creating a revision."><i class="bi bi-files me-1"></i>Create Revision Copy</button>
        <% } %>
      </div>
    </div>
  </div>

  <% if (templateLockState?.isLocked) { %>
    <div class="alert alert-warning small mb-3">
      This template is immutable because it is published and/or already allocated. Create a revision copy to make updates.
    </div>
  <% } %>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
      <div class="row g-3">
        <div class="col-md-3">
          <div class="small text-muted">Status</div>
          <% const st = String(template?.status || '').toLowerCase(); %>
          <span class="badge <%= st === 'active' ? 'bg-success' : (st === 'draft' ? 'bg-warning text-dark' : 'bg-secondary') %>"><%= st || '-' %></span>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Latest Revision</div>
          <div class="fw-bold">R<%= Number(template?.latestRevisionNo || 0) %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Published Revision</div>
          <div class="fw-bold font-monospace x-small"><%= template?.publishedRevisionId || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Owner User</div>
          <div class="fw-bold font-monospace"><%= template?.ownerUserId || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Visibility</div>
          <% const visibility = String(template?.visibility || 'private').toLowerCase(); %>
          <span class="badge <%= visibility === 'public' ? 'bg-success' : 'bg-secondary' %>"><%= visibility %></span>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Class Level</div>
          <div class="fw-bold"><%= template?.classLevel || '-' %></div>
        </div>
        <div class="col-md-6">
          <div class="small text-muted">Department</div>
          <div class="fw-bold">
            <%= template?.departmentName || '-' %>
            <% if (template?.departmentCode) { %>
              <span class="text-muted">(<%= template.departmentCode %>)</span>
            <% } %>
          </div>
        </div>
        <div class="col-md-6">
          <div class="small text-muted">Subjects</div>
          <% if (Array.isArray(templateSubjects) && templateSubjects.length) { %>
            <div class="d-flex flex-wrap gap-1">
              <% templateSubjects.forEach((row) => { %>
                <span class="badge bg-light text-dark border">
                  <%= row.code || row.id %><% if (row.title) { %>: <%= row.title %><% } %>
                </span>
              <% }) %>
            </div>
          <% } else { %>
            <div class="fw-bold">-</div>
          <% } %>
        </div>
        <div class="col-md-4">
          <div class="small text-muted">Parent ID</div>
          <div class="fw-bold font-monospace"><%= template?.parentTemplateId || '-' %></div>
        </div>
        <div class="col-md-4">
          <div class="small text-muted">Root ID</div>
          <div class="fw-bold font-monospace"><%= template?.rootTemplateId || template?.id || '-' %></div>
        </div>
        <div class="col-md-4">
          <div class="small text-muted">Revision Depth</div>
          <div class="fw-bold"><%= Number(template?.revisionDepth || 0) %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex align-items-center justify-content-between">
      <h5 class="m-0 fw-bold">Questions</h5>
      <div class="d-flex align-items-center gap-2">
        <% if (selectedQuestionRevision) { %>
          <span class="badge bg-light text-dark border d-inline-flex align-items-center">Snapshot R<%= Number(selectedQuestionRevision.revisionNo || 0) %></span>
        <% } %>
        <a class="btn btn-outline-primary btn-sm" href="/school/exams/templates/edit/<%= template.id %>#tab-questions"><i class="bi bi-ui-checks-grid me-1"></i>Open Question Builder</a>
      </div>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-3">#</th>
              <th>Type</th>
              <th>Mode</th>
              <th>Question</th>
              <th>Score</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% if (!selectedQuestions || !selectedQuestions.length) { %>
              <tr><td colspan="6" class="text-center py-4 text-muted">No questions found for this template yet.</td></tr>
            <% } %>
            <% (selectedQuestions || []).forEach((row) => { %>
              <tr>
                <td class="ps-3"><span class="badge bg-light text-dark border"><%= Number(row.sequenceNo || 0) %></span></td>
                <td><%= row.questionType || '-' %></td>
                <td><%= row.objectiveMode || '-' %></td>
                <td>
                  <div class="small"><%= row.promptText || '(rich text)' %></div>
                  <div class="x-small text-muted font-monospace"><%= row.id %></div>
                </td>
                <td><%= Number(row?.scoring?.maxScore || 0) %></td>
                <td><span class="badge bg-light text-dark border"><%= row.status || '-' %></span></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
