<%- include('../../partials/tablePages-start', {
  title,
  newUrl: null,
  newLabel: null,
  user,
  tableName: tableName || 'School_Exam_Take_Assignments',
  btn_export: true,
  print: true,
  headerManageBtns: [
    `<a href="/school/exams" class="btn btn-filled btn-secondary btn-md"><i class="bi bi-house me-1"></i> Exam Home</a>`
  ]
}) %>

<%- include('../../partials/tablePages-search', {
  placeholder: 'Search exams by name, class, student, status...',
  fields: []
}) %>

<input type="hidden" id="takeExamActionStateId" value="<%= actionStateId || '' %>">

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body p-3">
    <form method="GET" action="/school/exams/take" id="takeAssignmentFilterForm">
      <input type="hidden" id="takeExamDatePresetInput" name="datePreset" value="<%= filters?.datePreset || 'today' %>">
      <% if (filters?.q) { %><input type="hidden" name="q" value="<%= filters.q %>"><% } %>

      <div class="row g-2 align-items-end">
        <% if (isAdminViewer) { %>
          <div class="col-md-6">
            <label class="form-label small fw-bold mb-1">Student</label>
            <div class="input-group">
              <input type="hidden" id="personIdFilterInput" name="personId" value="<%= selectedPersonId || '' %>">
              <input type="text" id="personNameFilterInput" class="form-control bg-white" value="<%= selectedPersonDisplay || '' %>" placeholder="Pick a student person..." readonly>
              <button class="btn btn-outline-primary" type="button" id="btnPickPersonFilter"><i class="bi bi-search"></i></button>
              <button class="btn btn-outline-secondary" type="button" id="btnClearPersonFilter"><i class="bi bi-x-lg"></i></button>
            </div>
          </div>
        <% } %>

        <div class="<%= isAdminViewer ? 'col-md-3' : 'col-md-6' %>">
          <label class="form-label small fw-bold mb-1">Class</label>
          <select class="form-select" name="classId">
            <option value="">Any class</option>
            <% (classFilterOptions || []).forEach((cls) => { %>
              <option value="<%= cls.id %>" <%= String(filters?.classId || '') === String(cls.id || '') ? 'selected' : '' %>><%= cls.title || cls.id %></option>
            <% }); %>
          </select>
        </div>

        <div class="<%= isAdminViewer ? 'col-md-3' : 'col-md-6' %>">
          <label class="form-label small fw-bold mb-1">Exam state</label>
          <select class="form-select" name="lifecycle">
            <% (lifecycleOptions || []).forEach((opt) => { %>
              <option value="<%= opt.id %>" <%= String(filters?.lifecycle || '') === String(opt.id || '') ? 'selected' : '' %>><%= opt.label || opt.id %></option>
            <% }); %>
          </select>
        </div>
      </div>

      <div class="row g-2 align-items-end mt-1">
        <div class="col-md-6 col-lg-3">
          <label class="form-label small fw-bold mb-1">From</label>
          <input type="date" class="form-control" id="takeExamWindowStartDateInput" name="windowStartDate" value="<%= filters?.windowStartDate || '' %>">
        </div>

        <div class="col-md-6 col-lg-3">
          <label class="form-label small fw-bold mb-1">To</label>
          <input type="date" class="form-control" id="takeExamWindowEndDateInput" name="windowEndDate" value="<%= filters?.windowEndDate || '' %>">
        </div>

        <div class="col-12 col-lg-6 d-flex align-items-end justify-content-lg-end gap-2 pt-2 pt-lg-0">
          <button class="btn btn-primary" type="submit" name="apply" value="1"><i class="bi bi-funnel me-1"></i>Apply</button>
          <a class="btn btn-outline-secondary" href="/school/exams/take<%= isAdminViewer && selectedPersonId ? ('?personId=' + encodeURIComponent(selectedPersonId)) : '' %>"><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</a>
        </div>
      </div>
    </form>

    <div class="mt-3">
      <div class="small text-muted mb-2">Quick Date Shortcuts</div>
      <div class="d-flex flex-wrap gap-2">
        <button type="button" class="btn btn-sm <%= String(filters?.datePreset || '') === 'today' ? 'btn-primary' : 'btn-outline-primary' %> js-date-preset" data-preset="today">Today</button>
        <button type="button" class="btn btn-sm <%= String(filters?.datePreset || '') === 'next_7_days' ? 'btn-primary' : 'btn-outline-primary' %> js-date-preset" data-preset="next_7_days">Next 7 Days</button>
        <button type="button" class="btn btn-sm <%= String(filters?.datePreset || '') === 'next_30_days' ? 'btn-primary' : 'btn-outline-primary' %> js-date-preset" data-preset="next_30_days">Next 30 Days</button>
        <button type="button" class="btn btn-sm <%= String(filters?.datePreset || '') === 'this_month' ? 'btn-primary' : 'btn-outline-primary' %> js-date-preset" data-preset="this_month">This Month</button>
        <button type="button" class="btn btn-sm <%= String(filters?.datePreset || '') === 'all' ? 'btn-primary' : 'btn-outline-primary' %> js-date-preset" data-preset="all">All Dates</button>
      </div>
    </div>

    <% if (isAdminViewer) { %>
      <div class="small text-muted mt-2">Default view shows today&apos;s exams across all classes and students. Optionally pick a student and click <strong>Apply</strong> to narrow the list.</div>
    <% } else { %>
      <div class="small text-muted mt-2">Default view shows your exams for today across all classes. Click <strong>Apply</strong> with no filters to load all accessible items.</div>
    <% } %>
  </div>
</div>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Student</th>
        <th>Exam</th>
        <th>Status</th>
        <th>Window</th>
        <th>Attempt</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!rows || !rows.length) { %>
        <% if (Number(totalVisibleRows || 0) > 0) { %>
          <tr><td colspan="6" class="text-center py-4 text-muted">No assignments matched these filters.</td></tr>
        <% } else { %>
          <tr><td colspan="6" class="text-center py-4 text-muted">No assignments available for taking exam.</td></tr>
        <% } %>
      <% } %>
      <% (rows || []).forEach((row) => { %>
        <% const st = String(row?.status || '').toLowerCase(); %>
        <% const lifecycle = String(row?.lifecycleBucket || '').toLowerCase(); %>
        <tr>
          <td class="ps-4">
            <div class="fw-semibold"><%= row.studentName || row.studentId || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= row.studentId || '-' %></div>
            <% if (row.studentNo) { %><div class="x-small text-muted">No: <%= row.studentNo %></div><% } %>
          </td>
          <td>
            <div class="fw-semibold"><%= row.templateTitle || '-' %></div>
            <div class="x-small text-muted"><%= row.allocationName || '-' %> | <%= row.classTitle || '-' %> | <%= row.revisionLabel || '-' %></div>
          </td>
          <td>
            <span class="badge <%= st === 'started' ? 'bg-info' : (st === 'submitted' ? 'bg-primary' : (st === 'graded' ? 'bg-success' : 'bg-warning text-dark')) %>"><%= st || '-' %></span>
            <div class="x-small mt-1">
              <span class="badge <%= lifecycle === 'finished' ? 'bg-success' : (lifecycle === 'in_progress' ? 'bg-info text-dark' : (lifecycle === 'scheduled' ? 'bg-secondary' : (lifecycle === 'expired' ? 'bg-danger' : 'bg-primary'))) %>">
                <%= String(lifecycle || 'action_required').replace(/_/g, ' ') %>
              </span>
            </div>
          </td>
          <td>
            <div class="x-small text-muted">Start</div>
            <div class="x-small font-monospace"><%= row.startWindowUtc || '-' %></div>
            <div class="x-small text-muted mt-1">End</div>
            <div class="x-small font-monospace"><%= row.endWindowUtc || '-' %></div>
          </td>
          <td>
            <div class="x-small font-monospace"><%= row.activeAttemptId || '-' %></div>
            <div class="x-small text-muted"><%= row.latestAttemptStatus || '-' %></div>
          </td>
          <td class="table-actions pe-4 text-end">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= row.id %>"
                title="Assignment actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= row.id %>">
                <% if (row.canTake) { %>
                  <a class="btn btn-outline-primary btn-sm" href="/school/exams/take/<%= encodeURIComponent(row.id || '') %>"><i class="bi bi-box-arrow-up-right me-2"></i>Open</a>
                <% } else { %>
                  <button type="button" class="btn btn-outline-secondary btn-sm" disabled title="This assignment cannot be taken now."><i class="bi bi-box-arrow-up-right me-2"></i>Open</button>
                <% } %>
                <% if (row.canViewResult) { %>
                  <a class="btn btn-outline-success btn-sm" href="/school/exams/take/<%= encodeURIComponent(row.id || '') %>?view=result"><i class="bi bi-clipboard-data me-2"></i>View Result</a>
                <% } %>
                <% if (row.canStatusOverride) { %>
                  <button
                    type="button"
                    class="btn btn-outline-warning btn-sm js-open-assignment-status-modal"
                    data-assignment-id="<%= row.id || '' %>"
                    data-current-status="<%= st %>"
                    data-student-label="<%= encodeURIComponent(String(row.studentName || row.studentId || row.id || '')) %>"
                    data-exam-label="<%= encodeURIComponent(String(row.templateTitle || '')) %>">
                    <i class="bi bi-arrow-repeat me-2"></i>Change status
                  </button>
                <% } %>
              </div>
            </div>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<%- include('../../partials/pagination', { pagination, filters, baseUrlPath: 'school/exams/take' }) %>
<%- include('../../partials/tablePages-end') %>

<div class="modal fade" id="takeAssignmentStatusModal" tabindex="-1" aria-labelledby="takeAssignmentStatusModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="takeAssignmentStatusModalLabel"><i class="bi bi-arrow-repeat me-2"></i>Change assignment status</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="small text-muted mb-3" id="takeAssignmentStatusModalContext"></p>
        <input type="hidden" id="takeAssignmentStatusModalAssignmentId" value="">
        <label for="takeAssignmentStatusModalSelect" class="form-label fw-semibold">Status</label>
        <select id="takeAssignmentStatusModalSelect" class="form-select">
          <% (assignmentStatusOptions || []).forEach((stToken) => { %>
            <option value="<%= stToken %>"><%= String(stToken).replace(/_/g, ' ') %></option>
          <% }); %>
        </select>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="takeAssignmentStatusModalSave">
          <i class="bi bi-check-lg me-1"></i>Save
        </button>
      </div>
    </div>
  </div>
</div>

<%- include('../../partials/modal_GenericPicker') %>
<script>
  (function () {
    const isAdminViewer = <%= isAdminViewer ? 'true' : 'false' %>;
    const actionStateId = String(document.getElementById('takeExamActionStateId')?.value || '').trim();
    async function postJson(url, payload) {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
        body: JSON.stringify(payload || {})
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || data?.status !== 'success') throw new Error(String(data?.message || 'Operation failed.'));
      return data;
    }

    function getTakeAssignmentStatusModal() {
      const el = document.getElementById('takeAssignmentStatusModal');
      if (!el || !window.bootstrap || typeof window.bootstrap.Modal !== 'function') return null;
      return window.bootstrap.Modal.getOrCreateInstance(el);
    }

    const statusModalAssignmentId = document.getElementById('takeAssignmentStatusModalAssignmentId');
    const statusModalSelect = document.getElementById('takeAssignmentStatusModalSelect');
    const statusModalContext = document.getElementById('takeAssignmentStatusModalContext');
    const statusModalSave = document.getElementById('takeAssignmentStatusModalSave');

    function decodeDataLabel(raw) {
      const s = String(raw || '').trim();
      if (!s) return '';
      try {
        return decodeURIComponent(s);
      } catch (e) {
        return s;
      }
    }

    document.querySelectorAll('.js-open-assignment-status-modal').forEach((btn) => {
      btn.addEventListener('click', function () {
        const assignmentId = String(btn.getAttribute('data-assignment-id') || '').trim();
        const modal = getTakeAssignmentStatusModal();
        if (!assignmentId || !modal) return;
        const current = String(btn.getAttribute('data-current-status') || '').trim().toLowerCase();
        const studentLabel = decodeDataLabel(btn.getAttribute('data-student-label'));
        const examLabel = decodeDataLabel(btn.getAttribute('data-exam-label'));
        statusModalAssignmentId.value = assignmentId;
        if (statusModalSelect) statusModalSelect.value = current;
        if (statusModalContext) {
          const line = [studentLabel, examLabel].filter(Boolean).join(' - ');
          statusModalContext.textContent = line || assignmentId;
        }
        modal.show();
      });
    });

    statusModalSave?.addEventListener('click', async function () {
      const assignmentId = String(statusModalAssignmentId?.value || '').trim();
      const status = String(statusModalSelect?.value || '').trim().toLowerCase();
      if (!assignmentId || !status) return;
      try {
        statusModalSave.disabled = true;
        const prevHtml = statusModalSave.innerHTML;
        statusModalSave.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
        await postJson(`/school/exams/take/${encodeURIComponent(assignmentId)}/status`, {
          actionStateId,
          status
        });
        getTakeAssignmentStatusModal()?.hide();
        window.location.reload();
        statusModalSave.innerHTML = prevHtml;
      } catch (error) {
        alert(String(error?.message || error));
      } finally {
        statusModalSave.disabled = false;
      }
    });

    const filterForm = document.getElementById('takeAssignmentFilterForm');
    const datePresetInput = document.getElementById('takeExamDatePresetInput');
    const windowStartInput = document.getElementById('takeExamWindowStartDateInput');
    const windowEndInput = document.getElementById('takeExamWindowEndDateInput');

    document.querySelectorAll('.js-date-preset').forEach((btn) => {
      btn.addEventListener('click', function () {
        const preset = String(btn.getAttribute('data-preset') || '').trim();
        if (!preset || !filterForm) return;
        if (datePresetInput) datePresetInput.value = preset;
        if (preset !== 'custom' && preset !== 'all') {
          if (windowStartInput) windowStartInput.value = '';
          if (windowEndInput) windowEndInput.value = '';
        }
        if (preset === 'all') {
          if (windowStartInput) windowStartInput.value = '';
          if (windowEndInput) windowEndInput.value = '';
        }
        filterForm.submit();
      });
    });

    [windowStartInput, windowEndInput].forEach((input) => {
      input?.addEventListener('change', function () {
        if (datePresetInput) datePresetInput.value = 'custom';
      });
    });

    if (!isAdminViewer) return;
    const personIdInput = document.getElementById('personIdFilterInput');
    const personNameInput = document.getElementById('personNameFilterInput');
    const btnPickPerson = document.getElementById('btnPickPersonFilter');
    const btnClearPerson = document.getElementById('btnClearPersonFilter');

    btnPickPerson?.addEventListener('click', function () {
      if (!window.GenericPicker || !window.GenericPickerPresets) return;
      GenericPicker.open(GenericPickerPresets.normalizeConfig({
        title: 'Select Student Person',
        icon: 'bi-person-badge',
        apiEndpoint: '/school/exams/api/eligible-take-student-persons',
        placeholder: 'Search student persons...',
        searchFields: 'id,title,name',
        onSelect: function (item) {
          const id = String(item?.id || '').trim();
          if (!id) return;
          personIdInput.value = id;
          personNameInput.value = String(item?.title || id).trim();
        }
      }));
    });

    btnClearPerson?.addEventListener('click', function () {
      personIdInput.value = '';
      personNameInput.value = '';
    });
  })();
</script>
