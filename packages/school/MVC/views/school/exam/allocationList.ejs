<%- include('partials/tablePages-start', {
  title,
  newUrl: (typeof newUrl !== 'undefined' ? newUrl : null),
  newLabel,
  newHref: (typeof newHref !== 'undefined' ? newHref : null),
  user,
  tableName,
  btn_export: true,
  print,
  headerManageBtns: [
    `<a href="/school/exams" class="btn btn-filled btn-secondary btn-md"><i class="bi bi-house me-1"></i> Exam Home</a>`
  ],
  manageBtns: [
    `<a href="/school/exams/templates" class="btn btn-filled btn-primary btn-md mb-2"><i class="bi bi-journal-richtext me-1"></i> Templates</a>`,
    `<a href="/school/exams/teacher-assignments" class="btn btn-filled btn-info btn-md mb-2"><i class="bi bi-list-check me-1"></i> Teacher Queue</a>`
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search allocations...',
  fields: []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Allocation</th>
        <th>Class</th>
        <th>Revision</th>
        <th>Window (UTC)</th>
        <th>Status</th>
        <th>Assignments</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (!data || !data.length) { %>
        <tr><td colspan="7" class="text-center py-4 text-muted">No allocations found.</td></tr>
      <% } %>
      <% (data || []).forEach((row) => { %>
        <% const st = String(row.status || '').toLowerCase(); %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-dark"><%= row.allocationName || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= row.id %></div>
          </td>
          <td>
            <div class="fw-semibold"><%= row.className || row.classId || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= row.classId || '-' %></div>
          </td>
          <td>
            <div class="fw-semibold"><%= row.revisionLabel || row.revisionId || '-' %></div>
            <div class="x-small text-muted font-monospace"><%= row.revisionId || '-' %></div>
          </td>
          <td>
            <div class="x-small text-muted">Start</div>
            <div class="font-monospace x-small"><%= row.windowStartUtc || row.scheduling?.windowStartUtc || '-' %></div>
            <div class="x-small text-muted mt-1">End</div>
            <div class="font-monospace x-small"><%= row.windowEndUtc || row.scheduling?.windowEndUtc || '-' %></div>
          </td>
          <td>
            <span class="badge <%= st === 'open' ? 'bg-success' : (st === 'scheduled' ? 'bg-primary' : (st === 'closed' ? 'bg-secondary' : (st === 'cancelled' ? 'bg-danger' : 'bg-warning text-dark'))) %>"><%= st || '-' %></span>
          </td>
          <td>
            <span class="badge bg-light text-dark border me-1">T: <%= Number(row.assignmentCounts?.total || 0) %></span>
            <span class="badge bg-warning-subtle text-warning-emphasis border me-1">P: <%= Number(row.assignmentCounts?.pending || 0) %></span>
            <span class="badge bg-info-subtle text-info-emphasis border me-1">S: <%= Number(row.assignmentCounts?.started || 0) %></span>
            <span class="badge bg-primary-subtle text-primary-emphasis border me-1">Sub: <%= Number(row.assignmentCounts?.submitted || 0) %></span>
            <span class="badge bg-success-subtle text-success-emphasis border">G: <%= Number(row.assignmentCounts?.graded || 0) %></span>
          </td>
          <td class="table-actions pe-4 text-end">
            <div class="row-actions-wrap">
              <button
                type="button"
                class="btn btn-secondary btn-sm btn-row-actions-toggle"
                data-row-actions-id="<%= row.id %>"
                title="Allocation Actions">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="row-actions-menu d-none" data-row-actions-id="<%= row.id %>">
                <a class="btn btn-outline-secondary btn-sm" href="/school/exams/allocations/<%= row.id %>"><i class="bi bi-box-arrow-up-right me-2"></i>Open</a>
                <a class="btn btn-outline-primary btn-sm" href="/school/exams/allocations/<%= row.id %>"><i class="bi bi-list-check me-2"></i>Assignment</a>
                <% if (String(row?.classId || '').trim() && String(row?.sourceSessionId || '').trim()) { %>
                  <a
                    class="btn btn-outline-info btn-sm"
                    href="/school/classes/<%= encodeURIComponent(String(row.classId || '').trim()) %>/sessions/<%= encodeURIComponent(String(row.sourceSessionId || '').trim()) %>"
                    title="Open Manage Session for the assigned class session">
                    <i class="bi bi-journal-check me-2"></i>Go to Session
                  </a>
                <% } %>
                <% if (st !== 'cancelled' && st !== 'archived') { %>
                  <a class="btn btn-outline-secondary btn-sm" href="/school/exams/allocations/<%= row.id %>/edit"><i class="bi bi-pencil-square me-2"></i>Edit</a>
                  <button
                    type="button"
                    class="btn btn-outline-danger btn-sm js-cancel-allocation"
                    data-id="<%= row.id %>"
                    data-name="<%= row.allocationName || row.id %>">
                    <i class="bi bi-x-circle me-2"></i>Cancel
                  </button>
                <% } %>
                <% if (st === 'cancelled') { %>
                  <button
                    type="button"
                    class="btn btn-outline-danger btn-sm js-delete-allocation"
                    data-id="<%= row.id %>"
                    data-name="<%= row.allocationName || row.id %>">
                    <i class="bi bi-trash me-2"></i>Delete
                  </button>
                <% } %>
                <a class="btn btn-outline-secondary btn-sm" href="/school/exams/teacher-assignments/<%= row.id %>"><i class="bi bi-clipboard-check me-2"></i>Teacher Review</a>
              </div>
            </div>
          </td>
        </tr>
      <% }); %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="<%= (typeof newUrl !== 'undefined' ? newUrl : '') %>" hidden></span>
<%- include('partials/pagination', { pagination, filters, baseUrlPath: 'school/exams/allocations' }) %>
<%- include('partials/tablePages-end') %>
<%- include('partials/modal_GenericPicker') %>

<script>
  (function () {
    const actionStateId = String(document.getElementById('actionStateIdRef')?.dataset?.id || '');

    async function showModal(options) {
      if (typeof showMessageModal === 'function') return showMessageModal(options);
      const ok = window.confirm(String(options?.message || 'Are you sure?'));
      return ok ? 'Confirm' : 'Cancel';
    }

    async function runCancel(allocationId, allocationName, triggerButton) {
      const result = await showModal({
        title: 'Cancel Allocation?',
        icon: 'warning',
        message: `Cancel allocation <b>${String(allocationName || allocationId)}</b>? Pending/available assignments will be cancelled.`,
        buttons: [
          { text: 'Keep', class: 'btn-secondary' },
          { text: 'Confirm', class: 'btn-danger' }
        ]
      });
      if (result !== 'Confirm') return;

      if (triggerButton) {
        triggerButton.disabled = true;
        if (!triggerButton.dataset.originalHtml) triggerButton.dataset.originalHtml = triggerButton.innerHTML;
        triggerButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Cancelling...';
      }
      if (typeof showLoading === 'function') showLoading();

      try {
        const response = await fetch(`/school/exams/allocations/${encodeURIComponent(allocationId)}/cancel`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({ actionStateId })
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.status !== 'success') {
          throw new Error(String(payload?.message || 'Could not cancel allocation.'));
        }
        await showModal({
          title: 'Allocation Cancelled',
          icon: 'success',
          message: String(payload?.message || 'Allocation cancelled.'),
          buttons: [{ text: 'OK', class: 'btn-primary' }]
        });
        window.location.reload();
      } catch (error) {
        await showModal({
          title: 'Cancel Error',
          icon: 'warning',
          message: String(error?.message || error || 'Could not cancel allocation.'),
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
      } finally {
        if (typeof hideLoading === 'function') hideLoading();
        if (triggerButton) {
          triggerButton.disabled = false;
          if (triggerButton.dataset.originalHtml) triggerButton.innerHTML = triggerButton.dataset.originalHtml;
        }
      }
    }

    async function runDelete(allocationId, allocationName, triggerButton) {
      const result = await showModal({
        title: 'Delete Cancelled Allocation?',
        icon: 'warning',
        message: `Delete cancelled allocation <b>${String(allocationName || allocationId)}</b>? This permanently removes this allocation and its cancelled assignments.`,
        buttons: [
          { text: 'Keep', class: 'btn-secondary' },
          { text: 'Delete', class: 'btn-danger' }
        ]
      });
      if (result !== 'Delete') return;

      if (triggerButton) {
        triggerButton.disabled = true;
        if (!triggerButton.dataset.originalHtml) triggerButton.dataset.originalHtml = triggerButton.innerHTML;
        triggerButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Deleting...';
      }
      if (typeof showLoading === 'function') showLoading();

      try {
        const response = await fetch(`/school/exams/allocations/${encodeURIComponent(allocationId)}/delete`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({ actionStateId })
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.status !== 'success') {
          throw new Error(String(payload?.message || 'Could not delete allocation.'));
        }
        await showModal({
          title: 'Allocation Deleted',
          icon: 'success',
          message: String(payload?.message || 'Allocation deleted.'),
          buttons: [{ text: 'OK', class: 'btn-primary' }]
        });
        window.location.reload();
      } catch (error) {
        await showModal({
          title: 'Delete Error',
          icon: 'warning',
          message: String(error?.message || error || 'Could not delete allocation.'),
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
      } finally {
        if (typeof hideLoading === 'function') hideLoading();
        if (triggerButton) {
          triggerButton.disabled = false;
          if (triggerButton.dataset.originalHtml) triggerButton.innerHTML = triggerButton.dataset.originalHtml;
        }
      }
    }

    document.querySelectorAll('.js-cancel-allocation').forEach(function (button) {
      button.addEventListener('click', function () {
        const allocationId = String(button.getAttribute('data-id') || '').trim();
        const allocationName = String(button.getAttribute('data-name') || '').trim();
        if (!allocationId) return;
        runCancel(allocationId, allocationName, button);
      });
    });

    document.querySelectorAll('.js-delete-allocation').forEach(function (button) {
      button.addEventListener('click', function () {
        const allocationId = String(button.getAttribute('data-id') || '').trim();
        const allocationName = String(button.getAttribute('data-name') || '').trim();
        if (!allocationId) return;
        runDelete(allocationId, allocationName, button);
      });
    });

  })();
</script>
