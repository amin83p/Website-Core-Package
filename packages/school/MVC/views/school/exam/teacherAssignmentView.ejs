<%
  const backParts = [];
  if (typeof selectedTeacherId !== 'undefined' && selectedTeacherId) {
    backParts.push(`teacherId=${encodeURIComponent(selectedTeacherId)}`);
  } else if (typeof selectedPersonId !== 'undefined' && selectedPersonId) {
    backParts.push(`personId=${encodeURIComponent(selectedPersonId)}`);
  }
  const backQuery = backParts.length ? `?${backParts.join('&')}` : '';
%>
<div class="sections-page">
  <input type="hidden" id="teacherReviewActionStateId" value="<%= actionStateId || '' %>">
  <div class="row g-2 align-items-start mb-4">
    <div class="col">
      <h1 class="page-heading size-md m-0 text-start" style="padding-left:0;">Teacher Review</h1>
      <h6 class="fw-semibold text-primary mt-2 mb-0"><%= template?.title || allocation?.allocationName || 'Exam' %></h6>
      <div class="text-muted small mt-1">Allocation Name: <strong><%= allocation?.allocationName || '-' %></strong></div>
      <% if (selectedPersonId) { %>
        <div class="text-muted x-small mt-1">Teacher scope: <strong><%= selectedPersonDisplay || selectedPersonId %></strong></div>
      <% } %>
    </div>
    <div class="col-auto d-flex flex-column align-items-end gap-1">
      <span class="badge bg-primary border font-monospace">ID: <%= allocation?.id || '' %></span>
      <a href="/school/exams" class="btn btn-outline-secondary btn-sm"><i class="bi bi-house me-1"></i>Exam Home</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <a href="/school/exams/teacher-assignments<%= backQuery %>" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Teacher Exams</a>
        <a href="/school/exams/allocations" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Allocations</a>
        <a href="/school/exams/allocations/<%= allocation?.id %>" class="btn btn-outline-primary btn-sm"><i class="bi bi-box-arrow-up-right me-1"></i>Open allocation</a>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
      <div class="row g-3">
        <div class="col-md-3">
          <div class="small text-muted">Class</div>
          <div class="fw-bold"><%= classRow?.title || classRow?.name || allocation?.classId || '-' %></div>
          <div class="x-small text-muted font-monospace"><%= allocation?.classId || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Revision</div>
          <div class="fw-bold">R<%= Number(allocation?.revisionNo || revision?.revisionNo || 0) %></div>
          <div class="x-small text-muted font-monospace"><%= allocation?.revisionId || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Template</div>
          <div class="fw-bold"><%= template?.title || allocation?.templateId || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Status</div>
          <% const st = String(allocation?.status || '').toLowerCase(); %>
          <span class="badge <%= st === 'open' ? 'bg-success' : (st === 'scheduled' ? 'bg-primary' : (st === 'closed' ? 'bg-secondary' : (st === 'cancelled' ? 'bg-danger' : 'bg-warning text-dark'))) %>"><%= st || '-' %></span>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Timezone</div>
          <div class="fw-bold"><%= allocation?.timezone || allocation?.scheduling?.timezone || 'UTC' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Window Start (UTC)</div>
          <div class="fw-bold font-monospace x-small"><%= allocation?.windowStartUtc || allocation?.scheduling?.windowStartUtc || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Window End (UTC)</div>
          <div class="fw-bold font-monospace x-small"><%= allocation?.windowEndUtc || allocation?.scheduling?.windowEndUtc || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Duration</div>
          <div class="fw-bold"><%= Number(allocation?.durationMinutes || 0) %> min</div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Window Policy</div>
          <div class="fw-bold">
            <%= String(allocation?.windowPolicy || 'strict_fixed_window') === 'suggested_window' ? 'Suggested (guidance)' : 'Strict fixed window' %>
          </div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Question Presentation</div>
          <div class="fw-bold">
            <%= String(allocation?.questionPresentationMode || 'all_questions_on_one_page') === 'sequential_one_by_one' ? 'One by one' : 'All in one page' %>
          </div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">In Final Score</div>
          <div class="fw-bold"><%= allocation?.countsInFinalScore === false ? 'No' : 'Yes' %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white d-flex align-items-center justify-content-between flex-wrap gap-2">
      <h5 class="m-0 fw-bold">Assignments Summary</h5>
      <% if (selectedPersonId) { %>
        <span class="badge bg-secondary-subtle text-secondary-emphasis border">Filtered to teacher scope</span>
      <% } %>
    </div>
    <div class="card-body p-3">
      <div class="d-flex flex-wrap gap-2">
        <span class="badge bg-light text-dark border">Total: <%= Number(assignmentCounts?.total || 0) %></span>
        <span class="badge bg-warning-subtle text-warning-emphasis border">Pending: <%= Number(assignmentCounts?.pending || 0) %></span>
        <span class="badge bg-info-subtle text-info-emphasis border">Started: <%= Number(assignmentCounts?.started || 0) %></span>
        <span class="badge bg-primary-subtle text-primary-emphasis border">Submitted: <%= Number(assignmentCounts?.submitted || 0) %></span>
        <span class="badge bg-success-subtle text-success-emphasis border">Graded: <%= Number(assignmentCounts?.graded || 0) %></span>
      </div>
      <% if (selectedPersonId) { %>
        <div class="small text-muted mt-2">
          Allocation totals (all students in org):
          <span class="badge bg-light text-dark border ms-1">T <%= Number(allAssignmentCounts?.total || 0) %></span>
          <span class="badge bg-warning-subtle text-warning-emphasis border ms-1">P <%= Number(allAssignmentCounts?.pending || 0) %></span>
          <span class="badge bg-info-subtle text-info-emphasis border ms-1">S <%= Number(allAssignmentCounts?.started || 0) %></span>
          <span class="badge bg-primary-subtle text-primary-emphasis border ms-1">Sub <%= Number(allAssignmentCounts?.submitted || 0) %></span>
          <span class="badge bg-success-subtle text-success-emphasis border ms-1">G <%= Number(allAssignmentCounts?.graded || 0) %></span>
        </div>
      <% } %>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
      <h5 class="m-0 fw-bold">Assignments</h5>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-3">Student</th>
              <th>Status</th>
              <th>Window</th>
              <th>Score</th>
              <th>Attempt</th>
              <th>Review</th>
              <th class="pe-3 text-end">Updated</th>
            </tr>
          </thead>
          <tbody>
            <% if (!assignments || !assignments.length) { %>
              <tr><td colspan="7" class="text-center py-4 text-muted">No assignments available in this view.</td></tr>
            <% } %>
            <% (assignments || []).forEach((row) => { %>
              <% const rowStatus = String(row?.status || '').toLowerCase(); %>
              <% const statusBadgeClass = rowStatus === 'graded' ? 'bg-success' : ((rowStatus === 'submitted' || rowStatus === 'auto_submitted') ? 'bg-primary' : (rowStatus === 'started' ? 'bg-info' : (rowStatus === 'cancelled' ? 'bg-danger' : 'bg-warning text-dark'))); %>
              <tr>
                <td class="ps-3">
                  <div class="fw-semibold"><%- include('school/partials/studentNameLink', { name: row.studentName || row.studentId || '-', studentRecordId: row.studentRecordId || row.studentId, canOpenStudentProfile: typeof canOpenStudentProfile !== 'undefined' ? canOpenStudentProfile : false, linkClass: 'text-decoration-none' }) %></div>
                  <div class="x-small text-muted font-monospace"><%= row.studentId || '-' %></div>
                  <% if (row.studentNo) { %>
                    <div class="x-small text-muted">No: <%= row.studentNo %></div>
                  <% } %>
                  <div class="x-small text-muted font-monospace"><%= row.id || '' %></div>
                </td>
                <td>
                  <span class="badge <%= statusBadgeClass %>"><%= rowStatus || '-' %></span>
                </td>
                <td>
                  <div class="x-small font-monospace"><%= row.startWindowUtc || '-' %></div>
                  <div class="x-small font-monospace"><%= row.endWindowUtc || '-' %></div>
                </td>
                <td><%= Number(row.scoreComputed || 0) %> / <%= Number(row.maxScoreComputed || 0) %> (<%= Number(row.percentageComputed || 0) %>%)</td>
                <td class="font-monospace x-small"><%= row.startedAttemptId || row.submittedAttemptId || '-' %></td>
                <td>
                  <% const reviewTail = (() => {
                    const p = new URLSearchParams();
                    if (row.reviewAttemptId) p.set('attemptId', String(row.reviewAttemptId));
                    if (typeof selectedTeacherId !== 'undefined' && selectedTeacherId) p.set('teacherId', String(selectedTeacherId));
                    else if (selectedPersonId) p.set('personId', String(selectedPersonId));
                    const s = p.toString();
                    return s ? `?${s}` : '';
                  })(); %>
                  <% const reviewHref = `/school/exams/teacher-assignments/review/${encodeURIComponent(row.id)}${reviewTail}`; %>
                  <a href="<%= reviewHref %>" class="btn btn-outline-primary btn-sm"><i class="bi bi-clipboard-check me-1"></i>Review</a>
                </td>
                <td class="pe-3 text-end x-small"><%= row.audit?.lastUpdateDateTime || row.audit?.createDateTime || '-' %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
