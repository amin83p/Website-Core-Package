        if (!btnSave.dataset.originalHtml) btnSave.dataset.originalHtml = btnSave.innerHTML;
        btnSave.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
      }
      if (typeof showLoading === 'function') showLoading();

      try {
        const formData = new FormData(formEl);
        const encodedBody = new URLSearchParams();
        formData.forEach(function (value, key) {
          encodedBody.append(key, value == null ? '' : String(value));
        });
        const response = await fetch(formEl.action, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/x-www-form-urlencoded',
            'X-AJAX-Request': 'true'
          },
          body: encodedBody.toString()
        });
        const payload = await response.json().catch(function () { return {}; });
        if (!response.ok || String(payload?.status || '').toLowerCase() === 'error') {
          throw new Error(String(payload?.message || 'Could not save template.'));
        }

        const nextTemplateId = String(payload?.templateId || templateId || '').trim();
        await showMsg({
          title: 'Saved',
          icon: 'success',
          message: String(payload?.message || 'Template saved successfully.'),
          buttons: [{ text: 'OK', class: 'btn-primary' }]
        });

        if (nextTemplateId) {
          window.location.href = '/school/exams/templates/' + encodeURIComponent(nextTemplateId);
          return;
        }
        window.location.reload();
      } catch (error) {
        await showMsg({
          title: 'Save Failed',
          icon: 'error',
          message: String(error?.message || 'Could not save template.'),
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
