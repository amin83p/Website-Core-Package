        if (fromAnswerTypeMode) {
          if (qbType) qbType.value = 'objective';
          if (qbObjectiveMode) qbObjectiveMode.value = fromAnswerTypeMode;
        } else if (answerType) {
          if (qbType) qbType.value = 'subjective';
        }

        const isObjective = String(qbType?.value || '').toLowerCase() === 'objective';
        const objectiveMode = String(qbObjectiveMode?.value || 'single_choice').toLowerCase();
        if (qbObjectiveModeWrap) qbObjectiveModeWrap.classList.add('d-none');
        if (qbObjectiveCard) qbObjectiveCard.classList.toggle('d-none', !isObjective);
        if (qbSubjectiveCard) qbSubjectiveCard.classList.toggle('d-none', isObjective);
        if (qbOptionEditorWrap) qbOptionEditorWrap.classList.toggle('d-none', !(isObjective && objectiveMode !== 'true_false' && objectiveMode !== 'yes_no' && objectiveMode !== 'yes_no_na'));
        if (qbTrueFalseWrap) qbTrueFalseWrap.classList.toggle('d-none', !(isObjective && objectiveMode === 'true_false'));
        if (qbYesNoWrap) qbYesNoWrap.classList.toggle('d-none', !(isObjective && objectiveMode === 'yes_no'));
        if (qbYesNoNaWrap) qbYesNoNaWrap.classList.toggle('d-none', !(isObjective && objectiveMode === 'yes_no_na'));
        if (qbAddOptionBtn) qbAddOptionBtn.classList.toggle('d-none', !(isObjective && objectiveMode !== 'true_false' && objectiveMode !== 'yes_no' && objectiveMode !== 'yes_no_na'));
        if (qbRecordingAnswerPanel) qbRecordingAnswerPanel.classList.toggle('d-none', !(answerType === 'audio_recording' || answerType === 'video_recording'));
        if (qbUploadPhotoAnswerPanel) qbUploadPhotoAnswerPanel.classList.toggle('d-none', answerType !== 'upload_photos');
        if (qbShowAnswerKey) {
          const lockDisplayAnswer = answerType === 'written_answer';
          if (lockDisplayAnswer) qbShowAnswerKey.checked = true;
          qbShowAnswerKey.disabled = lockDisplayAnswer;
        }
      }

      function renderOptionRows() {
        if (!qbOptionsTbody) return;
        if (!qbCurrentOptions.length) {
          qbOptionsTbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted py-2">No options yet.</td></tr>';
          return;
        }
        const objectiveMode = String(qbObjectiveMode?.value || 'single_choice').toLowerCase();
        const isSingle = objectiveMode === 'single_choice' || objectiveMode === 'yes_no';
        const optionKey = function (idx) {
          return String.fromCharCode(65 + (idx % 26));
        };
        qbOptionsTbody.innerHTML = qbCurrentOptions.map(function (opt, idx) {
          return `
            <tr>
              <td><span class="badge bg-light text-dark border">${optionKey(idx)}</span></td>
              <td>
                <input class="form-check-input qb-opt-correct" type="${isSingle ? 'radio' : 'checkbox'}" name="qbCorrectOption" data-index="${idx}" ${opt.isCorrect ? 'checked' : ''}>
              </td>
              <td>
                <input type="text" class="form-control form-control-sm qb-opt-text" data-index="${idx}" value="${escapeHtml(opt.text || '')}">
              </td>
              <td class="text-end">
                <button type="button" class="btn btn-outline-danger btn-sm qb-opt-remove" data-index="${idx}"><i class="bi bi-trash"></i></button>
              </td>
            </tr>
          `;
        }).join('');

        qbOptionsTbody.querySelectorAll('.qb-opt-correct').forEach(function (el) {
          el.addEventListener('change', function () {
            const idx = Number.parseInt(String(el.getAttribute('data-index') || '-1'), 10);
            if (!Number.isFinite(idx) || idx < 0 || idx >= qbCurrentOptions.length) return;
            if (isSingle) {
              qbCurrentOptions = qbCurrentOptions.map(function (row, i) { return { text: row.text, isCorrect: i === idx }; });
            } else {
              qbCurrentOptions[idx].isCorrect = el.checked;
            }
          });
        });

        qbOptionsTbody.querySelectorAll('.qb-opt-text').forEach(function (el) {
          el.addEventListener('input', function () {
            const idx = Number.parseInt(String(el.getAttribute('data-index') || '-1'), 10);
            if (!Number.isFinite(idx) || idx < 0 || idx >= qbCurrentOptions.length) return;
            qbCurrentOptions[idx].text = String(el.value || '');
          });
        });

        qbOptionsTbody.querySelectorAll('.qb-opt-remove').forEach(function (el) {
          el.addEventListener('click', function () {
            const idx = Number.parseInt(String(el.getAttribute('data-index') || '-1'), 10);
            if (!Number.isFinite(idx) || idx < 0 || idx >= qbCurrentOptions.length) return;
            qbCurrentOptions.splice(idx, 1);
            renderOptionRows();
          });
        });
      }

      function normalizeModeForPersistence(mode) {
        return (mode === 'yes_no_na' || mode === 'yes_no') ? 'single_choice' : mode;
      }

      function optionLinesForSubmit() {
        const mode = String(qbObjectiveMode?.value || 'single_choice').toLowerCase();
        if (mode === 'true_false') return [];
        if (mode === 'yes_no') {
          const selected = String(document.querySelector('input[name="qbYnCorrect"]:checked')?.value || 'YES').toUpperCase();
          return ['YES', 'NO'].map(function (label) {
            return `${selected === label ? '*' : ''}${label === 'YES' ? 'Yes' : 'No'}`;
          });
        }
        if (mode === 'yes_no_na') {
          const selected = String(document.querySelector('input[name="qbYnaCorrect"]:checked')?.value || 'YES').toUpperCase();
          const labels = ['YES', 'NO', 'NA'];
          return labels.map(function (label) {
            return `${selected === label ? '*' : ''}${label === 'NA' ? 'N/A' : (label === 'YES' ? 'Yes' : 'No')}`;
          });
        }
        return qbCurrentOptions
          .map(function (opt) {
            const text = String(opt?.text || '').trim();
            if (!text) return '';
            return `${opt?.isCorrect ? '*' : ''}${text}`;
          })
          .filter(Boolean);
      }

      function fillModalFromQuestion(row) {
        const questionType = String(row?.questionType || 'objective').toLowerCase();
        const mode = String(row?.objectiveMode || 'single_choice').toLowerCase();
        const answerType = deriveAnswerTypeFromRow(row);
        qbQuestionId.value = String(row?.id || '');
        qbStatus.value = String(row?.status || 'draft');
        qbType.value = questionType;
        qbObjectiveMode.value = mode;
        if (qbAnswerType) qbAnswerType.value = answerType;
        qbSequenceNo.value = Number(row?.sequenceNo || (qbRows.length + 1));
        qbMaxScore.value = Number(row?.scoring?.maxScore || 1);
        if (qbNegativeScore) qbNegativeScore.value = Number(row?.scoring?.negativeScore || 0);
        if (qbMustBeAnswered) qbMustBeAnswered.value = row?.extensions?.mustBeAnswered === false ? 'false' : 'true';
        if (qbShowAnswerKey) qbShowAnswerKey.checked = row?.extensions?.showAnswerKey === true;
        qbRubricCriteria.value = Array.isArray(row?.scoring?.rubricCriteria) ? row.scoring.rubricCriteria.join('\n') : '';
        if (qbSubjectiveMinLength) qbSubjectiveMinLength.value = Number(row?.subjectiveConfig?.minLength ?? 0);
        if (qbSubjectiveMaxLength) qbSubjectiveMaxLength.value = Number(row?.subjectiveConfig?.maxLength ?? 4000);
        if (qbSubjectiveAllowAttachments) qbSubjectiveAllowAttachments.value = row?.subjectiveConfig?.allowAttachments ? 'true' : 'false';
        if (qbRecordingMaxDuration) qbRecordingMaxDuration.value = Number(row?.extensions?.responsePolicy?.maxDurationSeconds ?? 180);
        if (qbRecordingAllowRerecord) qbRecordingAllowRerecord.value = row?.extensions?.responsePolicy?.allowRerecord === false ? 'false' : 'true';
        if (qbUploadPhotoMaxCount) qbUploadPhotoMaxCount.value = Number(row?.extensions?.responsePolicy?.maxPhotoCount ?? 5);
        if (qbUploadPhotoMaxEachMb) qbUploadPhotoMaxEachMb.value = Number(row?.extensions?.responsePolicy?.maxPhotoSizeMb ?? 10);
        if (qbUploadPhotoTotalMb) qbUploadPhotoTotalMb.value = Number(row?.extensions?.responsePolicy?.maxTotalPhotoSizeMb ?? 30);
        promptEditor.setHtml(String(row?.promptHtml || row?.promptText || '<p><br></p>'));
        answerEditor.setHtml(String(row?.subjectiveConfig?.rubricHint || '<p><br></p>'));
        qbQuestionMediaItems = Array.isArray(row?.extensions?.questionMedia)
          ? row.extensions.questionMedia.map(function (item) {
              return {
                type: String(item?.type || '').trim().toLowerCase(),
                url: String(item?.url || '').trim(),
                playCount: Number(item?.playCount || 1),
                canStop: item?.canStop !== false,
                canPause: item?.canPause !== false,
                displaySeconds: Number(item?.displaySeconds || 30)
              };
            }).filter(function (item) {
              return item.type && item.url;
            })
          : [];
        qbCurrentOptions = Array.isArray(row?.objectiveOptions)
          ? row.objectiveOptions.map(function (opt) { return { text: String(opt?.text || ''), isCorrect: opt?.isCorrect === true }; })
          : [];

        if (mode === 'single_choice' && qbCurrentOptions.length >= 2) {
          const l0 = String(qbCurrentOptions[0]?.text || '').trim().toLowerCase();
          const l1 = String(qbCurrentOptions[1]?.text || '').trim().toLowerCase();
          const hasNa = qbCurrentOptions.some(function (opt) { return String(opt?.text || '').trim().toLowerCase() === 'n/a'; });
          if ((l0 === 'yes' && l1 === 'no') || (l0 === 'no' && l1 === 'yes')) {
            qbObjectiveMode.value = hasNa ? 'yes_no_na' : 'yes_no';
            const correct = qbCurrentOptions.find(function (opt) { return opt?.isCorrect; });
            const correctTxt = String(correct?.text || 'yes').trim().toLowerCase();
            if (hasNa) {
              if (correctTxt === 'no') document.getElementById('qbYnaNo').checked = true;
              else if (correctTxt === 'n/a') document.getElementById('qbYnaNa').checked = true;
              else document.getElementById('qbYnaYes').checked = true;
            } else {
              if (correctTxt === 'no') document.getElementById('qbYnNo').checked = true;
              else document.getElementById('qbYnYes').checked = true;
            }
          }
        }

        renderQuestionMediaRows();
        refreshQuestionMediaTypeUi();
        renderOptionRows();
        refreshYesNoNaVisibility();
        refreshQbModeUi();
      }

      function openModalForAdd() {
        ensureAnswerTypeOptions();
        qbModalTitle.textContent = 'Add Question';
        qbQuestionId.value = '';
        qbStatus.value = 'draft';
        qbType.value = 'objective';
        qbObjectiveMode.value = 'single_choice';
        if (qbAnswerType) qbAnswerType.value = 'single_option';
        qbSequenceNo.value = String(qbRows.length + 1);
        qbMaxScore.value = '1';
        if (qbNegativeScore) qbNegativeScore.value = '0';
        if (qbMustBeAnswered) qbMustBeAnswered.value = 'true';
        if (qbShowAnswerKey) qbShowAnswerKey.checked = false;
        qbRubricCriteria.value = '';
        if (qbSubjectiveMinLength) qbSubjectiveMinLength.value = '0';
        if (qbSubjectiveMaxLength) qbSubjectiveMaxLength.value = '4000';
        if (qbSubjectiveAllowAttachments) qbSubjectiveAllowAttachments.value = 'false';
        if (qbRecordingMaxDuration) qbRecordingMaxDuration.value = '180';
        if (qbRecordingAllowRerecord) qbRecordingAllowRerecord.value = 'true';
        if (qbUploadPhotoMaxCount) qbUploadPhotoMaxCount.value = '5';
        if (qbUploadPhotoMaxEachMb) qbUploadPhotoMaxEachMb.value = '10';
        if (qbUploadPhotoTotalMb) qbUploadPhotoTotalMb.value = '30';
        promptEditor.setHtml('<p><br></p>');
        answerEditor.setHtml('<p><br></p>');
        qbQuestionMediaItems = [];
        qbCurrentOptions = [{ text: 'Option 1', isCorrect: true }, { text: 'Option 2', isCorrect: false }];
        renderQuestionMediaRows();
        refreshQuestionMediaTypeUi();
        renderOptionRows();
        refreshYesNoNaVisibility();
        refreshQbModeUi();
        if (qbMediaFiles) qbMediaFiles.value = '';
        if (qbMediaUrl) qbMediaUrl.value = '';
        if (qbMediaLabel) qbMediaLabel.value = '';
        showQbModal();
      }

      function openModalForEdit(questionId) {
        const id = String(questionId || '').trim();
        if (!id) return;
        const row = qbRows.find(function (candidate) { return String(candidate?.id || '').trim() === id; });
        if (!row) return;
        ensureAnswerTypeOptions();
        qbModalTitle.textContent = 'Edit Question';
        fillModalFromQuestion(row);
        showQbModal();
      }

      async function deleteQuestionById(questionId) {
        const id = String(questionId || '').trim();
        if (!id) return;
        const decision = await showMsg({
          title: 'Delete Question?',
          icon: 'warning',
          message: 'This will remove the question from this template.',
          buttons: [{ text: 'No', class: 'btn-secondary' }, { text: 'Yes', class: 'btn-danger' }]
        });
        if (decision !== 'Yes') return;
        try {
          if (typeof showLoading === 'function') showLoading();
          const fd = new FormData();
          fd.append('actionStateId', actionStateId);
          await postFormData(`/school/exams/templates/${encodeURIComponent(templateId)}/questions/${encodeURIComponent(id)}/delete`, fd);
          qbRows = qbRows.filter(function (r) { return String(r?.id || '').trim() !== id; });
          renderQRows();
        } catch (error) {
          await showMsg({ title: 'Delete Failed', icon: 'error', message: error.message, buttons: [{ text: 'OK', class: 'btn-secondary' }] });
        } finally {
          if (typeof hideLoading === 'function') hideLoading();
        }
      }

      function renderQRows() {
        if (!qbTbody) return;
        if (!qbRows.length) {
          qbTbody.innerHTML = '<tr><td colspan="8" class="text-center py-4 text-muted">No questions yet. Use Add Question.</td></tr>';
          return;
        }

        qbRows.sort(function (a, b) { return Number(a?.sequenceNo || 0) - Number(b?.sequenceNo || 0); });
        qbRows.forEach(function (row, idx) { row.sequenceNo = idx + 1; });

        qbTbody.innerHTML = qbRows.map(function (row, idx) {
          const st = String(row?.status || '').toLowerCase();
          const badgeClass = st === 'active' ? 'bg-success' : (st === 'draft' ? 'bg-warning text-dark' : 'bg-secondary');
          const optionTexts = Array.isArray(row?.objectiveOptions) ? row.objectiveOptions.map(function (o) { return String(o?.text || '').trim().toLowerCase(); }) : [];
          const hasYesNo = optionTexts.includes('yes') && optionTexts.includes('no');
          const hasNa = optionTexts.includes('n/a');
          const modeToken = String(row?.objectiveMode || '-').toLowerCase() === 'single_choice' && hasYesNo
            ? (hasNa ? 'yes_no_na' : 'yes_no')
            : String(row?.objectiveMode || '-');
          const modeLabel = formatModeLabel(modeToken);
          const typeLabel = formatTokenLabel(String(row?.questionType || '-'));
          const statusLabel = formatTokenLabel(st || '-');
          return `
            <tr data-qid="${escapeHtml(String(row?.id || ''))}" draggable="true">
              <td class="ps-3"><span class="badge bg-light text-dark border">${idx + 1}</span></td>
              <td><span class="text-muted"><i class="bi bi-grip-vertical"></i></span></td>
              <td>
                <div class="small">${escapeHtml(stripHtml(row?.promptHtml || row?.promptText || '(media)')).slice(0, 120)}</div>
                <div class="x-small text-muted font-monospace">${escapeHtml(String(row?.id || 'new'))}</div>
              </td>
              <td>${escapeHtml(typeLabel)}</td>
              <td>${escapeHtml(modeLabel)}</td>
              <td>${Number(row?.scoring?.maxScore || 0)}</td>
              <td><span class="badge ${badgeClass}">${escapeHtml(statusLabel)}</span></td>
              <td class="text-end pe-3">
                <div class="row-actions-wrap">
                  <button type="button" class="btn btn-secondary btn-sm btn-row-actions-toggle" data-qid="${escapeHtml(String(row?.id || ''))}" title="Row actions">
                    <i class="bi bi-three-dots-vertical"></i>
                  </button>
                  <div class="row-actions-menu d-none" data-qid="${escapeHtml(String(row?.id || ''))}">
                    <button type="button" class="btn btn-outline-secondary btn-sm qb-row-edit" data-qid="${escapeHtml(String(row?.id || ''))}">
                      <i class="bi bi-pencil-square me-1"></i>Edit
                    </button>
                    <button type="button" class="btn btn-outline-danger btn-sm qb-row-delete" data-qid="${escapeHtml(String(row?.id || ''))}">
                      <i class="bi bi-trash me-1"></i>Delete
                    </button>
                  </div>
                </div>
              </td>
            </tr>
          `;
        }).join('');

        qbTbody.querySelectorAll('tr[data-qid]').forEach(function (rowEl) {
          rowEl.addEventListener('dragstart', function () {
            qbDragId = String(rowEl.getAttribute('data-qid') || '').trim();
            rowEl.classList.add('table-warning');
          });
          rowEl.addEventListener('dragend', function () {
            rowEl.classList.remove('table-warning');
          });
          rowEl.addEventListener('dragover', function (event) {
            event.preventDefault();
          });
          rowEl.addEventListener('drop', function (event) {
            event.preventDefault();
            const targetId = String(rowEl.getAttribute('data-qid') || '').trim();
            if (!qbDragId || !targetId || qbDragId === targetId) return;
            const fromIdx = qbRows.findIndex(function (r) { return String(r?.id || '').trim() === qbDragId; });
            const toIdx = qbRows.findIndex(function (r) { return String(r?.id || '').trim() === targetId; });
            if (fromIdx < 0 || toIdx < 0) return;
            const moved = qbRows.splice(fromIdx, 1)[0];
            qbRows.splice(toIdx, 0, moved);
            renderQRows();
          });
        });
      }

      qbAddOptionBtn?.addEventListener('click', function () {
        qbCurrentOptions.push({ text: `Option ${qbCurrentOptions.length + 1}`, isCorrect: false });
        renderOptionRows();
      });
      qbQuestionMediaType?.addEventListener('change', refreshQuestionMediaTypeUi);
      qbManageInsertMediaBtn?.addEventListener('click', openMediaManager);
      qbMediaManagerModalEl?.addEventListener('click', function (event) {
        const dismissTrigger = event.target.closest('[data-bs-dismiss="modal"]');
        if (dismissTrigger) {
          event.preventDefault();
          closeMediaManager();
        }
      });
      qbMediaManagerModalEl?.addEventListener('hidden.bs.modal', function () {
        if (qbRestoreQuestionModalAfterMedia) {
          qbRestoreQuestionModalAfterMedia = false;
          showQbModal();
        }
      });
      qbAddQuestionMediaBtn?.addEventListener('click', async function () {
        const item = buildQuestionMediaItemFromInputs();
        if (!String(item?.url || '').trim()) {
          await showMsg({ title: 'Validation', icon: 'warning', message: 'Please enter a media URL before adding.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
          return;
        }
        qbQuestionMediaItems.push(item);
        renderQuestionMediaRows();
        clearCurrentMediaTypeInputs();
      });
      qbMediaUploadInput?.addEventListener('change', async function () {
        if (!qbMediaUploadInput.files || !qbMediaUploadInput.files.length) return;
        const formData = new FormData();
        Array.from(qbMediaUploadInput.files).forEach(function (file) {
          formData.append('files', file);
        });
        try {
          qbMediaUploadZone?.classList.add('d-none');
          qbMediaUploadSpinner?.classList.remove('d-none');
          const fdTemplateId = String(templateId || '').trim();
          const fdQuestionId = String(qbQuestionId?.value || '_unsaved').trim() || '_unsaved';
          formData.append('actionStateId', actionStateId);
          formData.append('templateId', fdTemplateId);
          formData.append('questionId', fdQuestionId);
          const response = await fetch('/school/exams/api/upload-question-media', {
            method: 'POST',
            headers: { 'X-AJAX-Request': 'true' },
            body: formData
          });
          const payload = await response.json().catch(function () { return {}; });
          if (!response.ok || String(payload?.status || '').toLowerCase() !== 'success') {
            throw new Error(String(payload?.message || 'Upload failed.'));
          }
          const uploaded = Array.isArray(payload?.files) ? payload.files : [];
          uploaded.forEach(function (file) {
            const normalized = {
              url: String(file?.url || '').trim(),
              type: String(file?.type || '').trim(),
              name: String(file?.name || file?.fileName || 'Uploaded File').trim()
            };
            if (!normalized.url) return;
            if (!qbMediaLibraryItems.some(function (row) { return String(row?.url || '') === normalized.url; })) {
              qbMediaLibraryItems.unshift(normalized);
            }
          });
          renderMediaLibraryGrid();
          document.getElementById('qbMediaTabLibraryBtn')?.click();
          await showMsg({ title: 'Upload Complete', icon: 'success', message: `Uploaded ${uploaded.length} file(s).`, buttons: [{ text: 'OK', class: 'btn-secondary' }] });
        } catch (error) {
          await showMsg({ title: 'Upload Failed', icon: 'error', message: error.message, buttons: [{ text: 'OK', class: 'btn-secondary' }] });
        } finally {
          qbMediaUploadSpinner?.classList.add('d-none');
          qbMediaUploadZone?.classList.remove('d-none');
          qbMediaUploadInput.value = '';
        }
      });
      qbMediaLibraryGrid?.addEventListener('click', function (event) {
        const card = event.target.closest('.qb-media-library-card');
        if (!card) return;
        const idx = Number.parseInt(String(card.getAttribute('data-index') || '-1'), 10);
        if (!Number.isFinite(idx) || idx < 0 || idx >= qbMediaLibraryItems.length) return;
        qbSelectedLibraryMedia = qbMediaLibraryItems[idx];
        qbInsertSelectedMediaBtn && (qbInsertSelectedMediaBtn.disabled = false);
        if (qbMediaSelectionStatus) qbMediaSelectionStatus.innerHTML = `Selected: <strong>${escapeHtml(String(qbSelectedLibraryMedia?.name || 'Media'))}</strong>`;
        renderMediaLibraryGrid();
      });
      qbInsertSelectedMediaBtn?.addEventListener('click', async function () {
        if (!qbSelectedLibraryMedia?.url) return;
        const input = currentQuestionMediaUrlInput();
        if (!input) {
          await showMsg({ title: 'Insert Failed', icon: 'warning', message: 'No active media URL input found.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
          return;
        }
        input.value = String(qbSelectedLibraryMedia.url);
        closeMediaManager();
        await showMsg({ title: 'Inserted', icon: 'success', message: 'Media URL inserted into the current field.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
      });
      qbType?.addEventListener('change', function () {
        const qType = String(qbType?.value || '').toLowerCase();
        if (qType !== 'objective' && qbAnswerType && isObjectiveAnswerType(qbAnswerType.value)) {
          qbAnswerType.value = 'written_answer';
        }
        refreshQbModeUi();
      });
      qbAnswerType?.addEventListener('change', function () {
        const answerType = String(qbAnswerType?.value || '').toLowerCase();
        if (answerType === 'true_false') {
          const trueRadio = document.getElementById('qbTfTrue');
          if (trueRadio) trueRadio.checked = true;
        } else if (answerType === 'yes_no') {
          const yesRadio = document.getElementById('qbYnYes');
          if (yesRadio) yesRadio.checked = true;
        } else if (answerType === 'yes_no_na') {
          const yesRadio = document.getElementById('qbYnaYes');
          if (yesRadio) yesRadio.checked = true;
        }
        refreshQbModeUi();
        renderOptionRows();
        refreshYesNoNaVisibility();
      });
      qbObjectiveMode?.addEventListener('change', function () {
        const mode = String(qbObjectiveMode?.value || '').toLowerCase();
        if (qbAnswerType) {
          if (mode === 'true_false') qbAnswerType.value = 'true_false';
          else if (mode === 'yes_no') qbAnswerType.value = 'yes_no';
          else if (mode === 'yes_no_na') qbAnswerType.value = 'yes_no_na';
          else if (mode === 'multiple_choice') qbAnswerType.value = 'multiple_choice';
          else qbAnswerType.value = 'single_option';
        }
        renderOptionRows();
        refreshYesNoNaVisibility();
        refreshQbModeUi();
      });
      btnQbAdd?.addEventListener('click', openModalForAdd);
      qbCancelQuestionBtn?.addEventListener('click', hideQbModal);
      qbModalEl?.querySelector('.btn-close')?.addEventListener('click', hideQbModal);

      window.addEventListener('scroll', repositionOpenRowActionMenu, true);
      window.addEventListener('resize', repositionOpenRowActionMenu);
      qbTbody?.closest('.table-responsive')?.addEventListener('scroll', repositionOpenRowActionMenu, { passive: true });

      document.addEventListener('click', function (event) {
        const toggleBtn = event.target.closest('#tab-questions .btn-row-actions-toggle');
        if (toggleBtn) {
          const qid = String(toggleBtn.getAttribute('data-qid') || '').trim();
          const targetMenu = Array.from(document.querySelectorAll('#tab-questions .row-actions-menu, body > .row-actions-menu.row-actions-menu--floating'))
            .find(function (menu) { return String(menu.getAttribute('data-qid') || '').trim() === qid; });
          const willOpen = targetMenu ? targetMenu.classList.contains('d-none') : false;
          closeAllQuestionActionMenus();
          if (targetMenu && willOpen) {
            const wrap = toggleBtn.closest('.row-actions-wrap');
            targetMenu.classList.remove('d-none');
            document.body.appendChild(targetMenu);
            placeFloatingRowMenu(targetMenu, wrap);
            requestAnimationFrame(function () {
              requestAnimationFrame(repositionOpenRowActionMenu);
            });
          }
          return;
        }

        const editBtn = event.target.closest('#tab-questions .qb-row-edit, body > .row-actions-menu .qb-row-edit');
        if (editBtn) {
          closeAllQuestionActionMenus();
          openModalForEdit(editBtn.getAttribute('data-qid'));
          return;
        }

        const deleteBtn = event.target.closest('#tab-questions .qb-row-delete, body > .row-actions-menu .qb-row-delete');
        if (deleteBtn) {
          closeAllQuestionActionMenus();
          deleteQuestionById(deleteBtn.getAttribute('data-qid'));
          return;
        }

        const mediaRemoveBtn = event.target.closest('.qb-media-remove');
        if (mediaRemoveBtn) {
          const idx = Number.parseInt(String(mediaRemoveBtn.getAttribute('data-index') || '-1'), 10);
          if (Number.isFinite(idx) && idx >= 0 && idx < qbQuestionMediaItems.length) {
            qbQuestionMediaItems.splice(idx, 1);
            renderQuestionMediaRows();
          }
          return;
        }

        if (!event.target.closest('#tab-questions .row-actions-wrap') && !event.target.closest('body > .row-actions-menu')) {
          closeAllQuestionActionMenus();
        }
      });

      qbSaveQuestionBtn?.addEventListener('click', async function () {
        const answerType = String(qbAnswerType?.value || '').toLowerCase();
        const modeFromAnswerType = answerTypeToObjectiveMode(answerType);
        const qType = modeFromAnswerType ? 'objective' : String(qbType?.value || 'objective').toLowerCase();
        const modeUi = modeFromAnswerType || String(qbObjectiveMode?.value || 'single_choice').toLowerCase();
        const modePersist = normalizeModeForPersistence(modeUi);
        const promptHtml = String(promptEditor.getHtml() || '').trim();
        const promptText = stripHtml(promptHtml);
        if (!promptText) {
          await showMsg({ title: 'Validation', icon: 'warning', message: 'Question text is required.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
          return;
        }
        if (qType === 'subjective') {
          const minLen = Number(qbSubjectiveMinLength?.value || 0);
          const maxLen = Number(qbSubjectiveMaxLength?.value || 4000);
          if (!Number.isFinite(minLen) || minLen < 0) {
            await showMsg({ title: 'Validation', icon: 'warning', message: 'Minimum Length must be 0 or greater.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
            return;
          }
          if (!Number.isFinite(maxLen) || maxLen < 1) {
            await showMsg({ title: 'Validation', icon: 'warning', message: 'Maximum Length must be at least 1.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
            return;
          }
          if (maxLen < minLen) {
            await showMsg({ title: 'Validation', icon: 'warning', message: 'Maximum Length cannot be less than Minimum Length.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
            return;
          }
        }

        const fd = new FormData();
        fd.append('actionStateId', actionStateId);
        fd.append('questionId', String(qbQuestionId.value || '').trim());
        fd.append('templateId', templateId);
        fd.append('revisionId', qbRevisionId);
        fd.append('sequenceNo', String(qbSequenceNo.value || '1'));
        fd.append('status', String(qbStatus.value || 'draft'));
        fd.append('questionType', qType);
        fd.append('objectiveMode', modePersist);
        fd.append('promptHtml', promptHtml);
        fd.append('promptText', promptText);
        fd.append('maxScore', String(qbMaxScore.value || '1'));
        fd.append('negativeScore', String(qbNegativeScore?.value || '0'));
        fd.append('partialAllowed', modePersist === 'multiple_choice' ? 'true' : 'false');
        fd.append('mustBeAnswered', String(qbMustBeAnswered?.value || 'true'));
        const isWrittenAnswer = answerType === 'written_answer';
        fd.append('showAnswerKey', (isWrittenAnswer || qbShowAnswerKey?.checked) ? 'true' : 'false');
        fd.append('answerType', answerType || (qType === 'objective' ? 'single_option' : 'written_answer'));
        fd.append('mediaRulesJson', JSON.stringify(qbQuestionMediaItems));
        fd.append('recordingMaxDuration', String(qbRecordingMaxDuration?.value || '180'));
        fd.append('recordingAllowRerecord', String(qbRecordingAllowRerecord?.value || 'true'));
        fd.append('uploadPhotoMaxCount', String(qbUploadPhotoMaxCount?.value || '5'));
        fd.append('uploadPhotoMaxEachMb', String(qbUploadPhotoMaxEachMb?.value || '10'));
        fd.append('uploadPhotoTotalMb', String(qbUploadPhotoTotalMb?.value || '30'));
        fd.append('rubricCriteria', String(qbRubricCriteria.value || '').trim());
        fd.append('subjectiveRubricHint', String(answerEditor.getHtml() || '').trim());
        fd.append('subjectiveMinLength', String(qbSubjectiveMinLength?.value || '0'));
        fd.append('subjectiveMaxLength', String(qbSubjectiveMaxLength?.value || '4000'));
        fd.append('subjectiveAllowAttachments', String(qbSubjectiveAllowAttachments?.value || 'false'));

        if (qType === 'objective') {
          if (modeUi === 'true_false') {
            const tf = String(document.querySelector('input[name="qbTrueFalseCorrect"]:checked')?.value || 'true');
            fd.append('trueFalseCorrect', tf);
            fd.append('objectiveOptionsText', '');
          } else {
            const lines = optionLinesForSubmit();
            if (lines.length < 2) {
              await showMsg({ title: 'Validation', icon: 'warning', message: 'Add at least two objective options.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
              return;
            }
            const correctCount = lines.filter(function (line) { return String(line || '').startsWith('*'); }).length;
            if (modeUi === 'single_choice' && correctCount !== 1) {
              await showMsg({ title: 'Validation', icon: 'warning', message: 'Single Option requires exactly one correct answer.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
              return;
            }
            if (modeUi === 'yes_no' && correctCount !== 1) {
              await showMsg({ title: 'Validation', icon: 'warning', message: 'Yes / No requires exactly one correct answer.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
              return;
            }
            if (modeUi === 'multiple_choice' && correctCount < 1) {
              await showMsg({ title: 'Validation', icon: 'warning', message: 'Multiple Choice requires at least one correct answer.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
              return;
            }
            fd.append('objectiveOptionsText', lines.join('\n'));
          }
        } else {
          fd.append('objectiveOptionsText', '');
        }

        const mediaFiles = qbMediaFiles?.files ? Array.from(qbMediaFiles.files) : [];
        mediaFiles.forEach(function (file) { fd.append('mediaFiles', file); });
        if (String(qbMediaUrl?.value || '').trim()) {
          fd.append('mediaUrl', String(qbMediaUrl.value || '').trim());
          fd.append('mediaLabel', String(qbMediaLabel?.value || '').trim());
        }
        qbQuestionMediaItems.forEach(function (item) {
          if (!item?.url) return;
          fd.append('mediaUrl', String(item.url));
          fd.append('mediaLabel', String(item.type || '').toUpperCase());
        });

        try {
          if (typeof showLoading === 'function') showLoading();
          qbSaveQuestionBtn.disabled = true;
          const editingId = String(qbQuestionId.value || '').trim();
          const url = editingId
            ? `/school/exams/templates/${encodeURIComponent(templateId)}/questions/${encodeURIComponent(editingId)}/edit`
            : `/school/exams/templates/${encodeURIComponent(templateId)}/questions/new`;
          const result = await postFormData(url, fd);
          const savedId = String(result?.questionId || editingId || `tmp_${Date.now()}`).trim();
          const updatedRow = {
            ...(qbRows.find(function (r) { return String(r?.id || '') === savedId; }) || {}),
            id: savedId,
            templateId: templateId,
            revisionId: qbRevisionId,
            sequenceNo: Number(qbSequenceNo.value || 1),
            questionType: qType,
            objectiveMode: qType === 'objective' ? modePersist : '',
            promptText: promptText,
            promptHtml: promptHtml,
            objectiveOptions: qType === 'objective'
              ? (modeUi === 'true_false'
                ? [
                    { id: 'TRUE', text: 'True', isCorrect: String(document.querySelector('input[name="qbTrueFalseCorrect"]:checked')?.value || 'true') === 'true', order: 1 },
                    { id: 'FALSE', text: 'False', isCorrect: String(document.querySelector('input[name="qbTrueFalseCorrect"]:checked')?.value || 'true') !== 'true', order: 2 }
                  ]
                : (modeUi === 'yes_no'
                  ? [
                      { id: 'YES', text: 'Yes', isCorrect: String(document.querySelector('input[name="qbYnCorrect"]:checked')?.value || 'YES').toUpperCase() === 'YES', order: 1 },
                      { id: 'NO', text: 'No', isCorrect: String(document.querySelector('input[name="qbYnCorrect"]:checked')?.value || 'YES').toUpperCase() === 'NO', order: 2 }
                    ]
                : optionLinesForSubmit().map(function (line, idx) {
                    const correct = String(line).startsWith('*');
                    const txt = correct ? String(line).slice(1) : String(line);
                    return { id: `OPT_${idx + 1}`, text: txt, isCorrect: correct, order: idx + 1 };
                  })))
              : [],
            mediaRefs: qbQuestionMediaItems.map(function (item, idx) {
              return {
                id: `MEDIA_URL_${Date.now()}_${idx + 1}`,
                fileId: '',
                label: String(item?.type || '').toUpperCase(),
                fileName: '',
                originalName: '',
                mimeType: String(item?.type || ''),
                storagePath: '',
                url: String(item?.url || ''),
                sizeBytes: 0
              };
            }).filter(function (item) { return String(item?.url || '').trim(); }),
            subjectiveConfig: qType === 'subjective'
              ? {
                  rubricHint: String(answerEditor.getHtml() || '').trim(),
                  minLength: Number(qbSubjectiveMinLength?.value || 0),
                  maxLength: Number(qbSubjectiveMaxLength?.value || 4000),
                  allowAttachments: String(qbSubjectiveAllowAttachments?.value || 'false').toLowerCase() === 'true'
                }
              : {},
            scoring: {
              maxScore: Number(qbMaxScore.value || 1),
              negativeScore: Number(qbNegativeScore?.value || 0),
              rubricCriteria: String(qbRubricCriteria.value || '').split('\n').map(function (s) { return s.trim(); }).filter(Boolean)
            },
            extensions: {
              mustBeAnswered: String(qbMustBeAnswered?.value || 'true') === 'true',
              showAnswerKey: isWrittenAnswer || (qbShowAnswerKey?.checked === true),
              answerType: answerType || (qType === 'objective' ? 'single_option' : 'written_answer'),
              questionMedia: qbQuestionMediaItems.slice(),
              responsePolicy: {
                maxDurationSeconds: Number(qbRecordingMaxDuration?.value || 180),
                allowRerecord: String(qbRecordingAllowRerecord?.value || 'true') === 'true',
                maxPhotoCount: Number(qbUploadPhotoMaxCount?.value || 5),
                maxPhotoSizeMb: Number(qbUploadPhotoMaxEachMb?.value || 10),
                maxTotalPhotoSizeMb: Number(qbUploadPhotoTotalMb?.value || 30)
              }
            },
            status: String(qbStatus.value || 'draft')
          };

          const existingIdx = qbRows.findIndex(function (r) { return String(r?.id || '') === savedId; });
          if (existingIdx >= 0) qbRows[existingIdx] = updatedRow;
          else qbRows.push(updatedRow);
          seedMediaLibraryFromRows();
          renderQRows();
          hideQbModal();
          await showMsg({ title: 'Saved', icon: 'success', message: 'Question saved successfully.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
        } catch (error) {
          await showMsg({ title: 'Save Failed', icon: 'error', message: error.message, buttons: [{ text: 'OK', class: 'btn-secondary' }] });
        } finally {
          qbSaveQuestionBtn.disabled = false;
          if (typeof hideLoading === 'function') hideLoading();
        }
      });

      btnQbReorderSave?.addEventListener('click', async function () {
        if (!qbRows.length) return;
        try {
          if (typeof showLoading === 'function') showLoading();
          const fd = new FormData();
          fd.append('actionStateId', actionStateId);
          fd.append('questionOrder', qbRows.map(function (row) { return String(row?.id || '').trim(); }).filter(Boolean).join(','));
          await postFormData(`/school/exams/templates/${encodeURIComponent(templateId)}/questions/reorder`, fd);
          await showMsg({ title: 'Order Saved', icon: 'success', message: 'Question order updated.', buttons: [{ text: 'OK', class: 'btn-secondary' }] });
        } catch (error) {
          await showMsg({ title: 'Reorder Failed', icon: 'error', message: error.message, buttons: [{ text: 'OK', class: 'btn-secondary' }] });
        } finally {
          if (typeof hideLoading === 'function') hideLoading();
        }
      });

      renderQRows();
      seedMediaLibraryFromRows();
      refreshQbModeUi();
      refreshQuestionMediaTypeUi();
      renderQuestionMediaRows();
      refreshYesNoNaVisibility();
      renderOptionRows();
    }
  })();
</script>
