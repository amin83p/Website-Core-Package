<%
  const isEdit = !!template;
  const ownerUserId = String(currentOwnerUserId || template?.ownerUserId || user?.id || '').trim();
  const ownerLabel = String(currentOwnerDisplayName || user?.username || user?.id || ownerUserId).trim();
  const templateVisibility = String(template?.visibility || 'private').trim().toLowerCase() === 'public' ? 'public' : 'private';
  const initialDepartment = {
    id: String(template?.departmentId || '').trim(),
    code: String(template?.departmentCode || '').trim(),
    name: String(template?.departmentName || '').trim()
  };
  const initialSubjects = Array.isArray(selectedSubjects) ? selectedSubjects : [];
  const initialSubjectsJsonAttr = JSON.stringify(initialSubjects)
    .replace(/&/g, '&amp;')
    .replace(/"/g, '&quot;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
  const parentTemplateId = String(template?.parentTemplateId || '').trim();
  const rootTemplateId = String(template?.rootTemplateId || '').trim();
  const revisionDepth = Number(template?.revisionDepth || 0) || 0;
  const qbRevisionId = String(questionRevision?.id || '').trim();
  const qbRows = Array.isArray(questionRows) ? questionRows : [];
  const qbRowsJsonAttr = JSON.stringify(qbRows)
    .replace(/&/g, '&amp;')
    .replace(/"/g, '&quot;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;');
%>

<link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
<style>
  #tab-questions .row-actions-wrap {
    position: relative;
    display: inline-block;
  }
  #tab-questions .row-actions-wrap .row-actions-menu,
  body > .row-actions-menu.row-actions-menu--floating {
    min-width: 150px;
    max-width: min(100vw - 1rem, 240px);
    z-index: 1100;
    background: #fff;
    border: 1px solid #d0d7de;
    border-radius: 0.45rem;
    box-shadow: 0 0.45rem 1rem rgba(0, 0, 0, 0.15);
    padding: 0.35rem;
  }
  #tab-questions .row-actions-wrap > .row-actions-menu:not(.row-actions-menu--floating) {
    position: absolute;
    right: 0;
    top: calc(100% + 0.25rem);
    z-index: 12;
  }
  #tab-questions .row-actions-menu .btn,
  body > .row-actions-menu.row-actions-menu--floating .btn {
    width: 100%;
    text-align: left;
    justify-content: flex-start;
    margin-bottom: 0.25rem;
  }
  #tab-questions .row-actions-menu .btn:last-child,
  body > .row-actions-menu.row-actions-menu--floating .btn:last-child {
    margin-bottom: 0;
  }
  body > .row-actions-menu.row-actions-menu--floating {
    position: fixed;
    margin: 0;
  }
</style>

<div class="sections-page">
  <div class="row g-2 align-items-start mb-4">
    <div class="col">
      <h1 class="page-heading size-md m-0 text-start" style="padding-left:0;"><%= isEdit ? 'Edit Exam Template' : 'New Exam Template' %></h1>
      <% if (isEdit) { %>
        <h6 class="fw-semibold text-primary mt-2 mb-0"><%= template?.title || 'Exam Template' %></h6>
        <div class="text-muted small mt-1">Template code: <strong class="font-monospace"><%= template?.code || '-' %></strong></div>
      <% } else { %>
        <div class="text-muted small mt-2 mb-0">Define the exam shell, then add questions in the Question Builder tab.</div>
      <% } %>
    </div>
    <div class="col-auto d-flex flex-column align-items-end gap-1">
      <% if (isEdit) { %>
        <span class="badge bg-primary border font-monospace">ID: <%= template.id %></span>
      <% } %>
      <a href="/school/exams" class="btn btn-outline-secondary btn-sm"><i class="bi bi-house me-1"></i>Exam Home</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <a href="/school/exams/templates" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Templates</a>
        <% if (isEdit && canPublishFromForm) { %>
          <form method="POST" action="/school/exams/templates/<%= template.id %>/publish" class="m-0 d-inline">
            <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
            <button type="submit" class="btn btn-warning btn-sm text-dark"><i class="bi bi-upload me-1"></i>Publish</button>
          </form>
        <% } else { %>
          <button type="button" class="btn btn-warning btn-sm text-dark" disabled><i class="bi bi-upload me-1"></i>Publish</button>
        <% } %>
        <% if (isEdit && template?.publishedRevisionId) { %>
          <form method="POST" action="/school/exams/templates/<%= template.id %>/revisions/create-copy" class="m-0 d-inline">
            <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
            <button type="submit" class="btn btn-success btn-sm"><i class="bi bi-files me-1"></i>Create Revision</button>
          </form>
        <% } else { %>
          <button type="button" class="btn btn-success btn-sm" disabled title="Publish this template before creating a revision."><i class="bi bi-files me-1"></i>Create Revision</button>
        <% } %>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <span class="badge bg-light text-dark border font-monospace">Owner User: <%= ownerUserId || '-' %></span>
        <span class="badge bg-light text-dark border font-monospace">Parent ID: <%= parentTemplateId || '-' %></span>
        <span class="badge bg-light text-dark border font-monospace">Root ID: <%= rootTemplateId || (isEdit ? template.id : '-') %></span>
        <span class="badge bg-info-subtle text-info border border-info-subtle">Revision Depth: <%= revisionDepth %></span>
      </div>
      <div class="small text-muted mt-2">
        <% if (isEdit) { %>
          Build questions in this template, then publish this snapshot or create a revision copy.
        <% } else { %>
          Save the template first, then use the Question Builder tab to add items.
        <% } %>
      </div>
    </div>
  </div>

  <div class="form-container wide" style="max-width: 1400px;">
    <form id="templateForm" method="POST" action="<%= isEdit ? ('/school/exams/templates/edit/' + template.id) : '/school/exams/templates/new' %>">
      <input type="hidden" name="actionStateId" value="<%= actionStateId || '' %>">
      <input type="hidden" name="ownerUserId" id="inp_ownerUserId" value="<%= ownerUserId %>">
      <input type="hidden" name="departmentId" id="inp_departmentId" value="<%= initialDepartment.id %>">
      <input type="hidden" name="departmentCode" id="inp_departmentCode" value="<%= initialDepartment.code %>">
      <input type="hidden" name="departmentName" id="inp_departmentName" value="<%= initialDepartment.name %>">
      <input type="hidden" name="subjectIdsJson" id="inp_subjectIdsJson" value="<%- initialSubjectsJsonAttr %>">

      <ul class="nav nav-tabs mb-4" id="templateTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-general" type="button">General Info</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-owner" type="button">Ownership & Access</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-subjects" type="button">Department & Subjects</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-defaults" type="button">Defaults</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-questions" type="button">Question Builder</button></li>
      </ul>

      <div class="tab-content">
        <div class="tab-pane fade show active" id="tab-general">
          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label">Code</label>
              <input type="text" name="code" id="inp_code" class="form-control size-md" maxlength="80" value="<%= template?.code || '' %>" placeholder="e.g., EXM-LINC-READ-01">
            </div>
            <div class="col-md-8 mb-3">
              <label class="form-label">Title *</label>
              <input type="text" name="title" id="inp_title" class="form-control size-md" maxlength="220" value="<%= template?.title || '' %>" required placeholder="Template title">
            </div>
          </div>
          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label">Status</label>
              <select name="status" class="form-select size-md">
                <% (templateStatuses || ['draft', 'active', 'archived']).forEach((st) => { %>
                  <option value="<%= st %>" <%= String(template?.status || 'draft') === String(st) ? 'selected' : '' %>><%= st %></option>
                <% }); %>
              </select>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Class Level</label>
              <input type="text" name="classLevel" class="form-control size-md" maxlength="80" value="<%= template?.classLevel || '' %>" placeholder="e.g., CLB 4">
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Tags (CSV)</label>
              <input type="text" name="tags" class="form-control size-md" value="<%= Array.isArray(template?.tags) ? template.tags.join(', ') : '' %>" placeholder="assessment, housing">
            </div>
          </div>
          <div class="row">
            <div class="col-12 mb-3">
              <label class="form-label">Description</label>
              <textarea name="description" class="form-control size-md" rows="4" placeholder="Template description, context, and usage notes..."><%= template?.description || '' %></textarea>
            </div>
          </div>
        </div>

        <div class="tab-pane fade" id="tab-owner">
          <div class="row">
            <div class="col-md-6 mb-3">
              <label class="form-label">Owner User</label>
              <input type="text" class="form-control size-md bg-light" value="<%= ownerLabel %>" readonly>
              <div class="form-text small">Automatically assigned from the current signed-in user.</div>
            </div>
            <div class="col-md-6 mb-3">
              <label class="form-label">Template Visibility</label>
              <select name="visibility" class="form-select size-md">
                <option value="private" <%= templateVisibility === 'private' ? 'selected' : '' %>>Private (owner only)</option>
                <option value="public" <%= templateVisibility === 'public' ? 'selected' : '' %>>Public (available to other users)</option>
              </select>
              <div class="form-text small">Public templates can be reused by other authorized users in the organization.</div>
            </div>
          </div>
        </div>

        <div class="tab-pane fade" id="tab-subjects">
          <div class="card border-0 shadow-sm mb-3">
            <div class="card-body">
              <div class="row">
                <div class="col-md-9 mb-3">
                  <label class="form-label">Department *</label>
                  <div class="input-group">
                    <input type="text" id="inp_departmentDisplay" class="form-control size-md bg-white" value="<%= initialDepartment.name ? (initialDepartment.name + (initialDepartment.code ? (' (' + initialDepartment.code + ')') : '')) : '' %>" placeholder="Select department..." readonly required>
                    <button type="button" class="btn btn-outline-primary" id="btnPickDepartment"><i class="bi bi-diagram-3"></i></button>
                    <button type="button" class="btn btn-outline-secondary" id="btnClearDepartment"><i class="bi bi-x-lg"></i></button>
                  </div>
                  <div class="form-text small">Choose a department first, then select one or more linked subjects.</div>
                </div>
                <div class="col-md-3 mb-3 d-grid">
                  <label class="form-label d-block" style="visibility: hidden;">Department *</label>
                  <button type="button" class="btn btn-outline-primary size-md w-100" id="btnAddSubjects"><i class="bi bi-book me-1"></i>Add Subjects</button>
                </div>
              </div>
            </div>
          </div>

          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white d-flex justify-content-between align-items-center">
              <h6 class="m-0 fw-bold">Selected Subjects</h6>
              <span class="badge bg-light text-dark border" id="subjectsCountBadge">0</span>
            </div>
            <div class="card-body p-0">
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                  <thead class="table-light">
                    <tr>
                      <th class="ps-3">Subject</th>
                      <th>Code</th>
                      <th>Status</th>
                      <th>Credits</th>
                      <th class="text-end pe-3">Actions</th>
                    </tr>
                  </thead>
                  <tbody id="subjectsTbody"></tbody>
                </table>
              </div>
            </div>
          </div>
        </div>

        <div class="tab-pane fade" id="tab-defaults">
          <div class="row">
            <div class="col-md-3 mb-3">
              <label class="form-label">Default Duration (min)</label>
              <input type="number" name="defaultDurationMinutes" min="1" max="1440" class="form-control size-md" value="<%= Number(template?.settings?.defaultDurationMinutes || 60) %>">
            </div>
            <div class="col-md-3 mb-3">
              <label class="form-label">Pass Score (%)</label>
              <input type="number" name="passScorePercent" min="0" max="100" class="form-control size-md" value="<%= Number(template?.settings?.passScorePercent || 50) %>">
            </div>
            <div class="col-md-3 mb-3">
              <label class="form-label">Default Timezone</label>
              <input type="text" name="defaultTimezone" class="form-control size-md" maxlength="80" value="<%= template?.settings?.defaultTimezone || 'UTC' %>">
            </div>
          </div>
          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label">Shuffle Questions</label>
              <select name="shuffleQuestions" class="form-select size-md">
                <option value="false" <%= template?.settings?.shuffleQuestions ? '' : 'selected' %>>No</option>
                <option value="true" <%= template?.settings?.shuffleQuestions ? 'selected' : '' %>>Yes</option>
              </select>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Allow Back Navigation</label>
              <select name="allowBackNavigation" class="form-select size-md">
                <option value="true" <%= template?.settings?.allowBackNavigation === false ? '' : 'selected' %>>Yes</option>
                <option value="false" <%= template?.settings?.allowBackNavigation === false ? 'selected' : '' %>>No</option>
              </select>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Show Result Immediately</label>
              <select name="showResultImmediately" class="form-select size-md">
                <option value="false" <%= template?.settings?.showResultImmediately ? '' : 'selected' %>>No</option>
                <option value="true" <%= template?.settings?.showResultImmediately ? 'selected' : '' %>>Yes</option>
              </select>
            </div>
          </div>
          <div class="row">
            <div class="col-md-4 mb-3">
              <label class="form-label">Default Window Policy</label>
              <select name="defaultWindowPolicy" class="form-select size-md">
                <option value="strict_fixed_window" <%= String(template?.settings?.defaultWindowPolicy || 'strict_fixed_window') === 'strict_fixed_window' ? 'selected' : '' %>>Strict fixed window</option>
                <option value="suggested_window" <%= String(template?.settings?.defaultWindowPolicy || '') === 'suggested_window' ? 'selected' : '' %>>Suggested (guidance)</option>
              </select>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Default Question Presentation</label>
              <select name="defaultQuestionPresentationMode" class="form-select size-md">
                <option value="all_questions_on_one_page" <%= String(template?.settings?.defaultQuestionPresentationMode || 'all_questions_on_one_page') === 'all_questions_on_one_page' ? 'selected' : '' %>>All questions in one page</option>
                <option value="sequential_one_by_one" <%= String(template?.settings?.defaultQuestionPresentationMode || '') === 'sequential_one_by_one' ? 'selected' : '' %>>One by one (save then next)</option>
              </select>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label">Default Include In Final Score</label>
              <select name="defaultCountsInFinalScore" class="form-select size-md">
                <option value="true" <%= template?.settings?.defaultCountsInFinalScore === false ? '' : 'selected' %>>Yes</option>
                <option value="false" <%= template?.settings?.defaultCountsInFinalScore === false ? 'selected' : '' %>>No</option>
              </select>
            </div>
          </div>
        </div>

        <div class="tab-pane fade" id="tab-questions">
          <% if (!isEdit) { %>
            <div class="alert alert-info">
              Save this template first. After that, open this tab to add and reorder questions.
            </div>
          <% } else { %>
            <div class="card border-0 shadow-sm mb-3">
              <div class="card-header bg-white d-flex justify-content-between align-items-center">
                <div>
                  <h6 class="m-0 fw-bold">Question Builder</h6>
                  <div class="text-muted x-small">Internal revision: <span class="font-monospace"><%= qbRevisionId || '-' %></span></div>
                </div>
                <div class="d-flex gap-2">
                  <button type="button" class="btn btn-outline-primary btn-sm" id="btnQbReorderSave"><i class="bi bi-arrow-down-up me-1"></i>Save Order</button>
                  <button type="button" class="btn btn-primary btn-sm" id="btnQbAdd"><i class="bi bi-plus-circle me-1"></i>Add Question</button>
                </div>
              </div>
              <div class="card-body p-0">
                <div class="table-responsive">
                  <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                      <tr>
                        <th class="ps-3" style="width: 50px;">#</th>
                        <th style="width: 44px;"></th>
                        <th>Question</th>
                        <th>Type</th>
                        <th>Mode</th>
                        <th>Score</th>
                        <th>Status</th>
                        <th class="text-end pe-3">Actions</th>
                      </tr>
                    </thead>
                    <tbody id="qbTbody"></tbody>
                  </table>
                </div>
              </div>
            </div>
            <input type="hidden" id="qbRowsJson" value="<%- qbRowsJsonAttr %>">
            <input type="hidden" id="qbRevisionId" value="<%= qbRevisionId %>">
          <% } %>
        </div>
      </div>

      <div class="d-flex gap-2 mt-3">
        <button class="btn btn-filled btn-success btn-md" type="submit" id="btnSaveTemplate">Save Template</button>
        <% if (isEdit) { %>
          <a href="/school/exams/templates/<%= template.id %>" class="btn btn-filled btn-secondary btn-md">Cancel</a>
        <% } else { %>
          <a href="/school/exams/templates" class="btn btn-filled btn-secondary btn-md">Cancel</a>
        <% } %>
      </div>
    </form>
  </div>
</div>

<% if (isEdit) { %>
  <div class="modal fade" id="qbQuestionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title fw-bold"><i class="bi bi-question-diamond me-2"></i><span id="qbModalTitle">Add Question</span></h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <form id="qbQuestionForm">
            <input type="hidden" id="qbQuestionId">
            <ul class="nav nav-tabs mb-3" role="tablist">
              <li class="nav-item" role="presentation">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#qbTabInfo" type="button" role="tab">Question Information</button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#qbTabQuestion" type="button" role="tab">Question</button>
              </li>
              <li class="nav-item" role="presentation">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#qbTabAnswer" type="button" role="tab">Answer</button>
              </li>
            </ul>

            <div class="tab-content">
              <div class="tab-pane fade show active" id="qbTabInfo" role="tabpanel">
                <div class="row g-3 mb-1">
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Sequence</label>
                    <input type="number" id="qbSequenceNo" class="form-control" min="1" max="100000" value="1">
                  </div>
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Status</label>
                    <select id="qbStatus" class="form-select">
                      <% (questionStatuses || ['draft', 'active', 'archived']).forEach((st) => { %>
                        <option value="<%= st %>"><%= String(st || '').replace(/_/g, ' ').replace(/\b\w/g, (m) => m.toUpperCase()) %></option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Type</label>
                    <select id="qbType" class="form-select">
                      <% (questionTypes || ['objective', 'subjective']).forEach((tp) => { %>
                        <option value="<%= tp %>"><%= String(tp || '').replace(/_/g, ' ').replace(/\b\w/g, (m) => m.toUpperCase()) %></option>
                      <% }); %>
                    </select>
                  </div>
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Max Score</label>
                    <input type="number" id="qbMaxScore" class="form-control" min="0" step="0.01" value="1">
                  </div>
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Negative Score</label>
                    <input type="number" id="qbNegativeScore" class="form-control" max="0" step="0.01" value="0">
                  </div>
                  <div class="col-md-4">
                    <label class="form-label fw-bold">Must Be Answered</label>
                    <select id="qbMustBeAnswered" class="form-select">
                      <option value="true">Yes</option>
                      <option value="false">No</option>
                    </select>
                  </div>
                </div>
              </div>

              <div class="tab-pane fade" id="qbTabQuestion" role="tabpanel">
                <div class="mb-3">
                  <label class="form-label fw-bold">Question (Rich Text)</label>
                  <div id="qbPromptEditor" class="border rounded bg-white" style="height: 200px;"></div>
                </div>

                <div class="card border-0 shadow-sm mb-1">
                  <div class="card-header bg-white d-flex justify-content-between align-items-center flex-wrap gap-2">
                    <h6 class="m-0 fw-bold">Add Media to the question</h6>
                    <button type="button" class="btn btn-outline-secondary" id="qbManageInsertMediaBtn">
                      <i class="bi bi-images me-1"></i>Manage & Insert Media
                    </button>
                  </div>
                  <div class="card-body">
                    <div class="mb-3" style="max-width: 280px;">
                      <label class="form-label fw-bold">Select Media Type</label>
                      <select id="qbQuestionMediaType" class="form-select">
                        <option value="audio">Audio</option>
                        <option value="video">Video</option>
                        <option value="photo">Photo</option>
                      </select>
                    </div>

                    <div id="qbQuestionMediaAudioPanel">
                      <div class="row g-3 mb-2">
                        <div class="col-md-3">
                          <label class="form-label fw-bold">Playable Count</label>
                          <input type="number" id="qbMediaAudioPlayCount" class="form-control" min="1" max="100" value="1">
                        </div>
                        <div class="col-md-3">
                          <label class="form-label fw-bold">Can Be Stopped</label>
                          <select id="qbMediaAudioCanStop" class="form-select">
                            <option value="true">Yes</option>
                            <option value="false">No</option>
                          </select>
                        </div>
                        <div class="col-md-3">
                          <label class="form-label fw-bold">Can Be Paused</label>
                          <select id="qbMediaAudioCanPause" class="form-select">
                            <option value="true">Yes</option>
                            <option value="false">No</option>
                          </select>
                        </div>
                        <div class="col-md-12">
                          <label class="form-label fw-bold">Audio URL</label>
                          <input type="url" id="qbMediaAudioUrl" class="form-control" placeholder="https://...">
                        </div>
                      </div>
                    </div>

                    <div id="qbQuestionMediaVideoPanel" class="d-none">
                      <div class="row g-3 mb-2">
                        <div class="col-md-3">
                          <label class="form-label fw-bold">Playable Count</label>
