      function normalizeUploadedMediaType(raw) {
        const token = String(raw || '').trim().toLowerCase();
        if (token.includes('image')) return 'photo';
        if (token.includes('video')) return 'video';
        if (token.includes('audio')) return 'audio';
        return 'file';
      }

      function seedMediaLibraryFromRows() {
        const seeded = [];
        const pushSeed = function (entry) {
          const url = String(entry?.url || '').trim();
          if (!url) return;
          if (seeded.some(function (row) { return String(row?.url || '') === url; })) return;
          seeded.push({
            url,
            type: String(entry?.type || entry?.mimeType || '').trim(),
            name: String(entry?.name || entry?.label || entry?.originalName || entry?.fileName || 'Saved Media').trim()
          });
        };

        qbRows.forEach(function (row) {
          const mediaRefs = Array.isArray(row?.mediaRefs) ? row.mediaRefs : [];
          mediaRefs.forEach(function (m) {
            pushSeed({
              url: m?.url,
              type: m?.mimeType || m?.type,
              name: m?.label || m?.originalName || m?.fileName
            });
          });

          const questionMedia = Array.isArray(row?.extensions?.questionMedia) ? row.extensions.questionMedia : [];
          questionMedia.forEach(function (m) {
            pushSeed({
              url: m?.url,
              type: m?.type,
              name: `${formatTokenLabel(m?.type || 'Media')} - ${String(row?.id || '').trim() || 'Question'}`
            });
          });
        });

        qbMediaLibraryItems = seeded;
      }

      function renderMediaLibraryGrid() {
