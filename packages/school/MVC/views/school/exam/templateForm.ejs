<%- include('partials/modal_GenericPicker') %>
<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>

<script>
  (function () {
    const formEl = document.getElementById('templateForm');
    const titleInput = document.getElementById('inp_title');
    const ownerInput = document.getElementById('inp_ownerUserId');
    const depIdInput = document.getElementById('inp_departmentId');
    const depCodeInput = document.getElementById('inp_departmentCode');
    const depNameInput = document.getElementById('inp_departmentName');
    const depDisplayInput = document.getElementById('inp_departmentDisplay');
    const subjectsJsonInput = document.getElementById('inp_subjectIdsJson');
    const subjectsTbody = document.getElementById('subjectsTbody');
    const subjectsCountBadge = document.getElementById('subjectsCountBadge');
    const btnPickDepartment = document.getElementById('btnPickDepartment');
    const btnClearDepartment = document.getElementById('btnClearDepartment');
    const btnAddSubjects = document.getElementById('btnAddSubjects');
    const btnSave = document.getElementById('btnSaveTemplate');
    const actionStateId = '<%= actionStateId || '' %>';
    const initialDepartmentState = <%- JSON.stringify(initialDepartment || { id: '', code: '', name: '' }) %>;
    const templateId = '<%= template?.id || '' %>';
    const isEditTemplate = <%= isEdit ? 'true' : 'false' %>;

    let subjectsState = [];
    try {
      const parsed = JSON.parse(subjectsJsonInput.value || '[]');
      subjectsState = Array.isArray(parsed) ? parsed.map(function (row) {
        const id = String(row?.id || row?.subjectId || '').trim();
        return {
          id: id,
          code: String(row?.code || '').trim(),
          title: String(row?.title || id).trim(),
          status: String(row?.status || '').trim(),
          credits: Number(row?.credits || 0) || 0
        };
      }).filter(function (row) { return row.id; }) : [];
    } catch (_) {
      subjectsState = [];
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function showMsg(options) {
      if (typeof showMessageModal === 'function') return showMessageModal(options || {});
      const message = options && options.message ? options.message : 'Done';
      alert(message);
      return Promise.resolve('OK');
    }

    function stripHtml(value) {
      const div = document.createElement('div');
      div.innerHTML = String(value || '');
      return String(div.textContent || div.innerText || '').trim();
    }

    async function postFormData(url, formData) {
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'X-AJAX-Request': 'true' },
        body: formData
      });
      const result = await response.json().catch(function () { return {}; });
      if (!response.ok || String(result.status || '').toLowerCase() === 'error') {
        throw new Error(String(result?.message || 'Request failed.'));
      }
      return result;
    }

    function setDepartment(department) {
      depIdInput.value = String(department?.id || '').trim();
      depCodeInput.value = String(department?.code || '').trim().toUpperCase();
      depNameInput.value = String(department?.name || '').trim();
      depDisplayInput.value = depNameInput.value
        ? (depNameInput.value + (depCodeInput.value ? (' (' + depCodeInput.value + ')') : ''))
        : '';
      btnAddSubjects.disabled = !depIdInput.value;
    }

    function renderSubjects() {
      subjectsCountBadge.textContent = String(subjectsState.length);
      if (!subjectsState.length) {
        subjectsTbody.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No subjects selected.</td></tr>';
        return;
      }

      subjectsTbody.innerHTML = subjectsState.map(function (row, idx) {
        const st = String(row.status || '').trim().toLowerCase();
        const badgeClass = st === 'active' ? 'bg-success' : (st ? 'bg-warning text-dark' : 'bg-secondary');
        return `
          <tr>
            <td class="ps-3">
              <div class="fw-semibold">${escapeHtml(row.title || row.id)}</div>
              <div class="x-small text-muted font-monospace">${escapeHtml(row.id)}</div>
            </td>
            <td>${escapeHtml(row.code || '-')}</td>
            <td><span class="badge ${badgeClass}">${escapeHtml(st || '-')}</span></td>
            <td>${Number(row.credits || 0)}</td>
            <td class="text-end pe-3">
              <button type="button" class="btn btn-sm btn-outline-danger js-remove-subject" data-index="${idx}">
                <i class="bi bi-trash"></i>
              </button>
            </td>
          </tr>
        `;
      }).join('');

      subjectsTbody.querySelectorAll('.js-remove-subject').forEach(function (button) {
        button.addEventListener('click', function () {
          const idx = Number.parseInt(String(button.getAttribute('data-index') || '-1'), 10);
          if (!Number.isFinite(idx) || idx < 0 || idx >= subjectsState.length) return;
          subjectsState.splice(idx, 1);
          renderSubjects();
        });
      });
    }

    function syncHiddenSubjects() {
      subjectsJsonInput.value = JSON.stringify(subjectsState.map(function (row) {
        return {
          id: String(row.id || '').trim(),
          code: String(row.code || '').trim(),
          title: String(row.title || '').trim(),
          status: String(row.status || '').trim(),
          credits: Number(row.credits || 0) || 0
        };
      }));
    }

    async function clearDepartmentWithPrompt() {
      if (!subjectsState.length) {
        setDepartment({ id: '', code: '', name: '' });
        return;
      }
      const decision = await showMsg({
        title: 'Clear Department?',
        icon: 'warning',
        message: 'Clearing department also removes selected subjects. Continue?',
        buttons: [
          { text: 'No', class: 'btn-secondary' },
          { text: 'Yes', class: 'btn-danger' }
        ]
      });
      if (decision !== 'Yes') return;
      setDepartment({ id: '', code: '', name: '' });
      subjectsState = [];
      renderSubjects();
    }

    btnPickDepartment?.addEventListener('click', function () {
      if (!window.GenericPicker || !window.GenericPickerPresets) return;
      GenericPicker.open(GenericPickerPresets.department({
        title: 'Select Department',
        apiEndpoint: '/school/departments/api/data',
        onSelect: async function (item) {
          const nextId = String(item?.id || '').trim();
          if (!nextId) return;
          const currentId = String(depIdInput.value || '').trim();
          if (currentId && currentId !== nextId && subjectsState.length) {
            const decision = await showMsg({
              title: 'Change Department?',
              icon: 'warning',
              message: 'Changing department removes selected subjects. Continue?',
              buttons: [
                { text: 'No', class: 'btn-secondary' },
                { text: 'Yes', class: 'btn-danger' }
              ]
            });
            if (decision !== 'Yes') return;
            subjectsState = [];
            renderSubjects();
          }
          setDepartment(item);
        }
      }));
    });

    btnClearDepartment?.addEventListener('click', function () {
      clearDepartmentWithPrompt();
    });

    btnAddSubjects?.addEventListener('click', async function () {
      const departmentId = String(depIdInput.value || '').trim();
      if (!departmentId) {
        await showMsg({
          title: 'Department Required',
          icon: 'warning',
          message: 'Select department first, then add subjects.',
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
        return;
      }
      if (!window.GenericPicker || !window.GenericPickerPresets) return;
      GenericPicker.open(GenericPickerPresets.subject({
        title: 'Select Subjects',
        icon: 'bi-book',
        multiselect: true,
        apiEndpoint: '/school/exams/api/subjects-by-department?departmentId=' + encodeURIComponent(departmentId),
        placeholder: 'Search department subjects, select multiple, then Add Selected...',
        onSelect: function (items) {
          const rows = Array.isArray(items) ? items : [items];
          rows.forEach(function (item) {
            const subjectId = String(item?.id || '').trim();
            if (!subjectId) return;
            if (subjectsState.some(function (row) { return row.id === subjectId; })) return;
            subjectsState.push({
              id: subjectId,
              code: String(item?.code || '').trim(),
              title: String(item?.title || item?.name || subjectId).trim(),
              status: String(item?.status || '').trim(),
              credits: Number(item?.configuration?.credits || 0) || 0
            });
          });
          renderSubjects();
        }
      }));
    });

    formEl?.addEventListener('submit', async function (event) {
      event.preventDefault();
      const title = String(titleInput?.value || '').trim();
      const owner = String(ownerInput?.value || '').trim();
      const departmentId = String(depIdInput?.value || '').trim();
      if (!title) {
        await showMsg({
          title: 'Validation',
          icon: 'warning',
          message: 'Template title is required.',
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
        return;
      }
      if (!owner) {
        await showMsg({
          title: 'Validation',
          icon: 'warning',
          message: 'Owner user is required.',
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
        return;
      }
      if (!departmentId) {
        await showMsg({
          title: 'Validation',
          icon: 'warning',
          message: 'Department is required.',
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
        return;
      }
      if (!Array.isArray(subjectsState) || subjectsState.length <= 0) {
        await showMsg({
          title: 'Validation',
          icon: 'warning',
          message: 'Add at least one subject.',
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
