      function formatTokenLabel(raw) {
        return String(raw || '')
          .replace(/_/g, ' ')
          .replace(/\s+/g, ' ')
          .trim()
          .replace(/\b\w/g, function (m) { return m.toUpperCase(); });
      }

      function formatModeLabel(rawMode) {
        const token = String(rawMode || '').trim().toLowerCase();
        if (token === 'true_false') return 'True / False';
        if (token === 'yes_no') return 'Yes / No';
        if (token === 'yes_no_na') return 'Yes / No / N/A';
        return formatTokenLabel(token);
      }

      function isObjectiveAnswerType(answerType) {
        const token = String(answerType || '').trim().toLowerCase();
        return ['single_option', 'multiple_choice', 'true_false', 'yes_no', 'yes_no_na'].includes(token);
      }

      function answerTypeToObjectiveMode(answerType) {
        const token = String(answerType || '').trim().toLowerCase();
        if (token === 'single_option') return 'single_choice';
        if (token === 'multiple_choice') return 'multiple_choice';
        if (token === 'true_false') return 'true_false';
        if (token === 'yes_no') return 'yes_no';
        if (token === 'yes_no_na') return 'yes_no_na';
        return '';
      }

      function deriveAnswerTypeFromRow(row) {
        const extType = String(row?.extensions?.answerType || '').trim().toLowerCase();
        if (extType) return extType;
        const qType = String(row?.questionType || '').trim().toLowerCase();
        const mode = String(row?.objectiveMode || '').trim().toLowerCase();
        if (qType === 'objective') {
          if (mode === 'multiple_choice') return 'multiple_choice';
          if (mode === 'true_false') return 'true_false';
          if (mode === 'yes_no') return 'yes_no';
          if (mode === 'yes_no_na') return 'yes_no_na';
          const optionTexts = Array.isArray(row?.objectiveOptions)
            ? row.objectiveOptions.map(function (o) { return String(o?.text || '').trim().toLowerCase(); })
            : [];
          if (mode === 'single_choice' && optionTexts.includes('yes') && optionTexts.includes('no')) {
            return optionTexts.includes('n/a') ? 'yes_no_na' : 'yes_no';
          }
          return 'single_option';
        }
        return 'written_answer';
      }

      function ensureAnswerTypeOptions() {
        if (!qbAnswerType) return;
        const selected = String(qbAnswerType.value || '').trim().toLowerCase();
        const expected = [
          ['single_option', 'Single Option'],
          ['multiple_choice', 'Multiple Choice'],
          ['true_false', 'True / False'],
          ['yes_no', 'Yes / No'],
          ['yes_no_na', 'Yes / No / N/A'],
          ['written_answer', 'Written Answer'],
          ['audio_recording', 'Audio Recording'],
          ['video_recording', 'Video Recording'],
          ['upload_photos', 'Upload Photos']
        ];
        qbAnswerType.innerHTML = expected.map(function (row) {
          return `<option value="${row[0]}">${row[1]}</option>`;
        }).join('');
        const hasSelected = expected.some(function (row) { return row[0] === selected; });
        qbAnswerType.value = hasSelected ? selected : 'single_option';
      }

