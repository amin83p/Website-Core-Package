          const thumb = typeToken === 'photo'
            ? `<img src="${escapeHtml(url)}" class="object-fit-cover w-100 h-100" alt="${escapeHtml(name)}">`
            : `<div class="d-flex align-items-center justify-content-center text-white h-100 w-100 bg-secondary"><i class="bi ${typeToken === 'video' ? 'bi-file-earmark-play' : (typeToken === 'audio' ? 'bi-file-earmark-music' : 'bi-file-earmark')} fs-1"></i></div>`;
