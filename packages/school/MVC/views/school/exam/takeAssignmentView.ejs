<%
  const isResultView = resultViewMode === true;
  const inProgress = String(attempt?.status || '').toLowerCase() === 'in_progress';
  const attemptStatusToken = String(attempt?.status || '').toLowerCase();
  const doneState = ['submitted', 'auto_submitted', 'graded'].includes(attemptStatusToken);
  const canRevealResults = doneState && (showResultImmediately || attemptStatusToken === 'graded');
  const isSequential = String(presentationMode || 'all_questions_on_one_page') === 'sequential_one_by_one';
  const allowBack = allowBackNavigation === true;
  const answerMap = answerByQuestionId instanceof Map ? answerByQuestionId : new Map();
  const simExam = simulationMode === true;
  const assignmentStatusToken = String(assignment?.status || '').toLowerCase();
  const allocationStatusToken = String(allocation?.status || '').toLowerCase();
  const allocationIsOpen = allocationStatusToken === 'open';
  const assignmentStatusBadgeClass = assignmentStatusToken === 'graded'
    ? 'bg-success'
    : (assignmentStatusToken === 'submitted'
      ? 'bg-primary'
      : (assignmentStatusToken === 'started'
        ? 'bg-info'
        : (assignmentStatusToken === 'cancelled'
          ? 'bg-danger'
          : 'bg-warning text-dark')));
  const canStart = !simExam && !attempt && allocationIsOpen && ['pending', 'available', 'started'].includes(String(assignment?.status || '').toLowerCase());
  const canResumeInProgress = !simExam && inProgress && allocationIsOpen;
  const showQuestionWorkspace = simExam || (attempt && canResumeInProgress);
%>
<div class="sections-page">
  <input type="hidden" id="examActionStateId" value="<%= actionStateId || '' %>">
  <% if (isResultView) { %>
    <div class="row g-2 align-items-start mb-4">
      <div class="col">
        <h1 class="page-heading size-md m-0 text-start" style="padding-left:0;">Exam Result</h1>
        <h6 class="fw-semibold text-primary mt-2 mb-0"><%= template?.title || allocation?.allocationName || 'Exam' %></h6>
        <div class="text-muted small mt-1">Student: <strong><%= studentName || assignment?.studentId || '-' %></strong></div>
      </div>
      <div class="col-auto d-flex flex-column align-items-end gap-1">
        <span class="badge bg-primary border font-monospace">ID: <%= assignment?.id || '' %></span>
        <a href="/school/exams" class="btn btn-outline-secondary btn-sm"><i class="bi bi-house me-1"></i>Exam Home</a>
      </div>
    </div>
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body py-2">
        <div class="d-flex flex-wrap align-items-center gap-2">
          <a href="/school/exams/take" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Assigned Exams</a>
          <% if (canRevealResults) { %>
            <span class="badge bg-success-subtle text-success-emphasis border">Result Ready</span>
          <% } %>
        </div>
      </div>
    </div>
  <% } else { %>
    <div class="d-flex align-items-center justify-content-between mb-3">
      <div>
        <h1 class="page-heading size-md m-0"><i class="bi bi-pencil-square me-2"></i><%= template?.title || allocation?.allocationName || 'Exam' %></h1>
        <div class="text-muted small mt-1">
          Student: <strong><%= studentName || assignment?.studentId || '-' %></strong>
          <span class="font-monospace ms-2"><%= assignment?.studentId || '-' %></span>
        </div>
      </div>
      <div class="d-flex gap-2">
        <% if (simExam && simulationBackHref) { %>
          <a href="<%= simulationBackHref %>" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Manage Session</a>
        <% } else { %>
          <a href="/school/exams/take" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Assigned Exams</a>
        <% } %>
        <a href="/school/exams" class="btn btn-outline-secondary btn-sm"><i class="bi bi-house me-1"></i>Exam Home</a>
      </div>
    </div>
    <% if (simExam) { %>
    <div class="alert alert-info border-0 shadow-sm mb-3 py-2">
      <strong>Simulation.</strong> This mirrors the student exam experience. Nothing you enter here is saved or graded.
    </div>
    <% } %>
  <% } %>

  <div class="card border-0 shadow-sm mb-3">
    <% if (isResultView) { %>
      <div class="card-header bg-white d-flex align-items-center justify-content-between">
        <h5 class="m-0 fw-bold">Assignment Summary</h5>
        <span class="badge <%= assignmentStatusBadgeClass %>"><%= assignmentStatusToken || '-' %></span>
      </div>
    <% } %>
    <div class="card-body p-3">
      <div class="row g-3">
        <div class="col-md-3"><div class="small text-muted">Class</div><div class="fw-bold"><%= classRow?.title || classRow?.name || assignment?.classId || '-' %></div><div class="x-small text-muted font-monospace"><%= assignment?.classId || '-' %></div></div>
        <div class="col-md-3"><div class="small text-muted">Revision</div><div class="fw-bold">R<%= Number(revision?.revisionNo || assignment?.revisionNo || 0) %></div><div class="x-small text-muted font-monospace"><%= assignment?.revisionId || '-' %></div></div>
        <div class="col-md-3"><div class="small text-muted">Template</div><div class="fw-bold"><%= template?.title || assignment?.templateId || '-' %></div></div>
        <div class="col-md-3"><div class="small text-muted">Status</div><span class="badge <%= assignmentStatusBadgeClass %>"><%= assignmentStatusToken || '-' %></span></div>
        <div class="col-md-3"><div class="small text-muted">Allocation</div><div class="fw-bold"><%= allocation?.allocationName || allocation?.id || '-' %></div></div>
        <div class="col-md-3"><div class="small text-muted">Window Policy</div><div class="fw-bold"><%= String(allocation?.windowPolicy || 'strict_fixed_window').replace(/_/g, ' ') %></div></div>
        <div class="col-md-3"><div class="small text-muted">Presentation</div><div class="fw-bold"><%= isSequential ? 'Sequential' : 'All in one page' %></div></div>
        <div class="col-md-3"><div class="small text-muted">Counts In Final</div><div class="fw-bold"><%= allocation?.countsInFinalScore === false ? 'No' : 'Yes' %></div></div>
        <div class="col-md-6"><div class="small text-muted">Window</div><div class="x-small font-monospace"><%= assignment?.startWindowUtc || '-' %> -> <%= assignment?.endWindowUtc || '-' %></div></div>
        <div class="col-md-3"><div class="small text-muted">Duration</div><div class="fw-bold"><%= Number(assignment?.durationMinutes || allocation?.durationMinutes || 0) %> min</div></div>
        <div class="col-md-3"><div class="small text-muted">Attempt</div><div class="fw-bold font-monospace"><%= attempt?.id || '-' %></div></div>
      </div>
    </div>
  </div>

  <% if (canStart) { %>
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-3 d-flex align-items-center justify-content-between">
        <div>
          <div class="fw-bold">Ready to start</div>
          <div class="small text-muted">Click start to begin the exam timer.</div>
        </div>
        <button type="button" id="btnStartExam" class="btn btn-primary"><i class="bi bi-play-fill me-1"></i>Start Exam</button>
      </div>
    </div>
  <% } %>

  <% if (!simExam && !attempt && !allocationIsOpen) { %>
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-3">
        <div class="alert alert-warning mb-0 py-2">
          This exam is currently <strong><%= allocationStatusToken || 'closed' %></strong>. It can only be started when the allocation status is <strong>open</strong>.
        </div>
      </div>
    </div>
  <% } %>

  <% if (showQuestionWorkspace) { %>
    <% if (simExam) { %>
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div class="fw-semibold text-muted">Timer and submission are disabled in simulation.</div>
        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnSimDone"><i class="bi bi-check2 me-1"></i>Done preview</button>
      </div>
    </div>
    <% } else { %>
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
        <div class="fw-semibold">Time Remaining: <span id="countdownText" class="font-monospace">--:--:--</span></div>
        <button type="button" class="btn btn-success" id="btnSubmitExam"><i class="bi bi-check2-circle me-1"></i>Submit Exam</button>
      </div>
    </div>
    <% } %>

    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white">
        <h5 class="m-0 fw-bold">Questions</h5>
      </div>
      <div class="card-body p-3">
        <% (questions || []).forEach((q, idx) => { %>
          <% const qid = String(q?.id || ''); %>
          <% const saved = answerMap.get(qid) || null; %>
          <div class="border rounded p-3 mb-3 exam-question-card <%= isSequential && idx !== 0 ? 'd-none' : '' %>" data-question-idx="<%= idx %>" data-question-id="<%= qid %>">
            <div class="d-flex justify-content-between align-items-center mb-2">
              <div class="fw-bold">Q<%= idx + 1 %></div>
              <div class="small text-muted">Type: <%= String(q?.questionType || '').replace(/_/g, ' ') %></div>
            </div>
            <div class="mb-3"><%- q?.promptHtml || q?.promptText || '' %></div>

            <% if (String(q?.questionType || '').toLowerCase() === 'objective') { %>
              <% const mode = String(q?.objectiveMode || 'single_choice').toLowerCase(); %>
              <div class="d-flex flex-column gap-2">
                <% (q?.objectiveOptions || []).forEach((opt) => { %>
                  <% const optId = String(opt?.id || ''); %>
                  <% const selected = (saved?.objectiveResponse?.selectedOptionIds || []).includes(optId); %>
                  <label class="form-check">
                    <input class="form-check-input" type="<%= mode === 'multiple_choice' ? 'checkbox' : 'radio' %>" name="q_<%= qid %>" value="<%= optId %>" <%= selected ? 'checked' : '' %>>
                    <span class="form-check-label"><%= opt?.text || optId %></span>
                  </label>
                <% }); %>
              </div>
            <% } else { %>
              <textarea class="form-control" rows="6" id="txt_<%= qid %>" placeholder="Write your answer..."><%= saved?.subjectiveResponse?.text || '' %></textarea>
            <% } %>

            <div class="d-flex flex-wrap gap-2 mt-3">
              <button type="button" class="btn btn-outline-primary btn-sm btn-save-answer" data-question-id="<%= qid %>"><i class="bi bi-save me-1"></i>Save Answer</button>
              <% if (isSequential) { %>
                <button type="button" class="btn btn-outline-secondary btn-sm btn-prev-question" <%= (!allowBack || idx === 0) ? 'disabled' : '' %>>Previous</button>
                <button type="button" class="btn btn-outline-secondary btn-sm btn-next-question" <%= idx === (questions || []).length - 1 ? 'disabled' : '' %>>Next</button>
              <% } %>
            </div>
          </div>
        <% }); %>
      </div>
    </div>
  <% } %>

  <% if (attempt && doneState) { %>
    <div class="card border-0 shadow-sm">
      <% if (isResultView) { %>
        <div class="card-header bg-white">
          <h5 class="m-0 fw-bold">Result Summary</h5>
        </div>
      <% } %>
      <div class="card-body p-3">
        <h5 class="fw-bold mb-2"><%= canRevealResults ? 'Exam Result' : 'Exam Submitted' %></h5>
        <div class="small text-muted mb-2">Status: <strong><%= attemptStatusToken %></strong></div>
        <% if (canRevealResults) { %>
          <div class="fw-semibold">Score: <%= Number(attempt?.totalScoreComputed || 0) %> / <%= Number(attempt?.maxScoreComputed || 0) %> (<%= Number(attempt?.percentageComputed || 0) %>%)</div>
        <% } else { %>
          <div class="small text-muted">Results are hidden until teacher review is complete.</div>
        <% } %>
      </div>
    </div>

    <% if (canRevealResults) { %>
      <div class="card border-0 shadow-sm mt-3" id="examResultDetailsCard">
        <div class="card-header bg-white">
          <h5 class="m-0 fw-bold">Result Details</h5>
        </div>
        <div class="card-body p-3">
          <% (questions || []).forEach((q, idx) => { %>
            <% const qid = String(q?.id || ''); %>
            <% const saved = answerMap.get(qid) || null; %>
            <% const maxScore = Number(q?.scoring?.maxScore || 0); %>
            <% const awardedScore = saved ? (saved?.manualScore ?? saved?.finalScore ?? 0) : null; %>
            <div class="border rounded p-3 mb-3">
              <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="fw-bold">Q<%= idx + 1 %></div>
                <div class="small text-muted">Type: <%= String(q?.questionType || '').replace(/_/g, ' ') %></div>
              </div>
              <div class="mb-3"><%- q?.promptHtml || q?.promptText || '' %></div>

              <div class="border rounded p-2 bg-light-subtle">
                <div class="small fw-semibold mb-1">Your Answer</div>
                <% if (!saved) { %>
                  <div class="small text-muted">No answer submitted for this question.</div>
                <% } else if (String(q?.questionType || '').toLowerCase() === 'objective') { %>
                  <% const selectedIds = Array.isArray(saved?.objectiveResponse?.selectedOptionIds) ? saved.objectiveResponse.selectedOptionIds : []; %>
                  <% const selectedSet = new Set(selectedIds.map((id) => String(id || '').trim())); %>
                  <% const selectedOptions = (Array.isArray(q?.objectiveOptions) ? q.objectiveOptions : []).filter((opt) => selectedSet.has(String(opt?.id || '').trim())); %>
                  <% if (!selectedOptions.length) { %>
                    <div class="small text-muted">No option selected.</div>
                  <% } else { %>
                    <ul class="small mb-0 ps-3">
                      <% selectedOptions.forEach((opt) => { %>
                        <li><%= String(opt?.text || opt?.id || '').trim() %></li>
                      <% }); %>
                    </ul>
                  <% } %>
                <% } else { %>
                  <div class="small" style="white-space: pre-wrap;"><%= String(saved?.subjectiveResponse?.text || '').trim() || '(empty)' %></div>
                <% } %>
              </div>

              <div class="row g-2 mt-2">
                <div class="col-md-3">
                  <div class="small text-muted">Score</div>
                  <div class="fw-semibold"><%= awardedScore == null ? '-' : Number(awardedScore) %> / <%= maxScore %></div>
                </div>
                <div class="col-md-2">
                  <div class="small text-muted">Correct</div>
                  <div class="fw-semibold"><%= typeof saved?.isCorrect === 'boolean' ? (saved.isCorrect ? 'Yes' : 'No') : '-' %></div>
                </div>
                <div class="col-md-7">
                  <div class="small text-muted">Feedback</div>
                  <div class="small"><%= String(saved?.feedback || '').trim() || 'No feedback provided.' %></div>
                </div>
              </div>
              <% if (saved?.gradedAtUtc) { %>
                <div class="small text-muted mt-2">Graded at: <span class="font-monospace"><%= saved.gradedAtUtc %></span></div>
              <% } %>
            </div>
          <% }); %>
        </div>
      </div>
    <% } %>
  <% } %>

  <% if (!simExam && attempt && inProgress && !allocationIsOpen) { %>
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body p-3">
        <div class="alert alert-warning mb-0 py-2">
          This exam is temporarily paused by your teacher. You can continue when the allocation is set back to <strong>open</strong>.
        </div>
      </div>
    </div>
  <% } %>
</div>

<script>
  (function () {
    const simExam = <%- JSON.stringify(simExam === true) %>;
    const simulationBackHref = <%- JSON.stringify(simulationBackHref || '') %>;
    const assignmentId = '<%= assignment?.id || "" %>';
    const attemptId = '<%= attempt?.id || "" %>';
    const actionStateId = document.getElementById('examActionStateId')?.value || '';
    const inProgress = <%- JSON.stringify(canResumeInProgress === true) %> === true;
    const autoSubmitOnExpire = <%- JSON.stringify(allocation?.autoSubmitOnExpire !== false) %> === true;
    const expiresAtUtc = '<%= attempt?.expiresAtUtc || "" %>';
    const isSequential = <%- JSON.stringify(isSequential === true) %> === true;
    let activeQuestionIdx = 0;

    function escapeHtml(s) {
      return String(s || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    async function showExamMessageModal(options) {
      if (typeof window.showMessageModal === 'function') {
        return window.showMessageModal(options);
      }
      const msg = String(options?.message || '').replace(/<[^>]*>/g, '').trim();
      if (Array.isArray(options?.buttons) && options.buttons.length > 1) {
        return window.confirm(msg || options?.title || 'Confirm') ? options.buttons[1].text : options.buttons[0].text;
      }
      window.alert(msg || options?.title || 'Notice');
      return 'OK';
    }

    function getQuestionCards() {
      return Array.from(document.querySelectorAll('.exam-question-card'));
    }

    function showQuestionAt(index) {
      const cards = getQuestionCards();
      if (!cards.length) return;
      const bounded = Math.max(0, Math.min(index, cards.length - 1));
      activeQuestionIdx = bounded;
      cards.forEach((card, idx) => {
        card.classList.toggle('d-none', isSequential ? idx !== bounded : false);
      });
    }

    async function postJson(url, payload) {
      const response = await fetch(url, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-Requested-With': 'XMLHttpRequest'
        },
        body: JSON.stringify(payload || {})
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok || data?.status !== 'success') {
        throw new Error(String(data?.message || 'Operation failed.'));
      }
      return data;
    }

    async function saveAnswer(questionId) {
      if (simExam) return;
      const card = document.querySelector(`.exam-question-card[data-question-id="${questionId}"]`);
      if (!card) return;
      const objectiveInputs = Array.from(card.querySelectorAll(`input[name="q_${questionId}"]`));
      const isObjective = objectiveInputs.length > 0;
      const payload = { actionStateId, questionId };
      if (isObjective) {
        payload.selectedOptionIds = objectiveInputs.filter((el) => el.checked).map((el) => String(el.value || ''));
      } else {
        payload.text = String(document.getElementById(`txt_${questionId}`)?.value || '').trim();
      }
      await postJson(`/school/exams/take/${encodeURIComponent(assignmentId)}/attempts/${encodeURIComponent(attemptId)}/save-answer`, payload);
    }

    document.getElementById('btnSimDone')?.addEventListener('click', function () {
      if (simulationBackHref) {
        window.location.href = simulationBackHref;
      } else {
        window.history.back();
      }
    });

    document.getElementById('btnStartExam')?.addEventListener('click', async function () {
      try {
        await postJson(`/school/exams/take/${encodeURIComponent(assignmentId)}/start`, { actionStateId });
        window.location.reload();
      } catch (error) {
        await showExamMessageModal({
          title: 'Could not start exam',
          icon: 'error',
          message: `<p class="mb-0">${escapeHtml(String(error?.message || error || 'Operation failed.'))}</p>`,
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
      }
    });

    document.querySelectorAll('.btn-save-answer').forEach((btn) => {
      btn.addEventListener('click', async function () {
        const qid = String(btn.getAttribute('data-question-id') || '').trim();
        if (!qid) return;
        try {
          btn.disabled = true;
          const prev = btn.innerHTML;
          if (simExam) {
            btn.innerHTML = '<i class="bi bi-check2 me-1"></i>Recorded locally';
            setTimeout(() => { btn.innerHTML = prev; }, 1200);
            return;
          }
          btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
          await saveAnswer(qid);
          btn.innerHTML = '<i class="bi bi-check2 me-1"></i>Saved';
          setTimeout(() => { btn.innerHTML = prev; }, 1000);
        } catch (error) {
          await showExamMessageModal({
            title: 'Could not save answer',
            icon: 'error',
            message: `<p class="mb-0">${escapeHtml(String(error?.message || error || 'Operation failed.'))}</p>`,
            buttons: [{ text: 'OK', class: 'btn-secondary' }]
          });
        } finally {
          btn.disabled = false;
        }
      });
    });

    document.querySelectorAll('.btn-prev-question').forEach((btn) => {
      btn.addEventListener('click', function () { showQuestionAt(activeQuestionIdx - 1); });
    });
    document.querySelectorAll('.btn-next-question').forEach((btn) => {
      btn.addEventListener('click', function () { showQuestionAt(activeQuestionIdx + 1); });
    });

    document.getElementById('btnSubmitExam')?.addEventListener('click', async function () {
      const confirmResult = await showExamMessageModal({
        title: 'Submit exam?',
        icon: 'warning',
        message: '<p class="mb-0">Submit your exam now? You will not be able to change your answers after submitting.</p>',
        buttons: [
          { text: 'Cancel', class: 'btn-secondary' },
          { text: 'Submit', class: 'btn-primary' }
        ]
      });
      if (confirmResult !== 'Submit') return;
      try {
        await postJson(`/school/exams/take/${encodeURIComponent(assignmentId)}/attempts/${encodeURIComponent(attemptId)}/submit`, {
          actionStateId
        });
        window.location.reload();
      } catch (error) {
        await showExamMessageModal({
          title: 'Could not submit exam',
          icon: 'error',
          message: `<p class="mb-0">${escapeHtml(String(error?.message || error || 'Operation failed.'))}</p>`,
          buttons: [{ text: 'OK', class: 'btn-secondary' }]
        });
      }
    });

    function tickCountdown() {
      if (simExam) return;
      const label = document.getElementById('countdownText');
      if (!label || !expiresAtUtc) return;
      const remainingMs = new Date(expiresAtUtc).getTime() - Date.now();
      const seconds = Math.max(0, Math.floor(remainingMs / 1000));
      const hh = String(Math.floor(seconds / 3600)).padStart(2, '0');
      const mm = String(Math.floor((seconds % 3600) / 60)).padStart(2, '0');
      const ss = String(seconds % 60).padStart(2, '0');
      label.textContent = `${hh}:${mm}:${ss}`;
      if (remainingMs <= 0 && inProgress && autoSubmitOnExpire) {
        postJson(`/school/exams/take/${encodeURIComponent(assignmentId)}/attempts/${encodeURIComponent(attemptId)}/submit`, {
          actionStateId,
          autoSubmit: true
        }).finally(() => window.location.reload());
      }
    }

    showQuestionAt(0);
    const requestedView = String(new URLSearchParams(window.location.search).get('view') || '').trim().toLowerCase();
    if (requestedView === 'result') {
      document.getElementById('examResultDetailsCard')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
    const wantAutostart = String(new URLSearchParams(window.location.search).get('autostart') || '').trim() === '1';
    const canStartExam = <%- JSON.stringify(canStart === true) %> === true;
    if (!simExam && wantAutostart && canStartExam) {
      document.getElementById('btnStartExam')?.click();
    }
    if (!simExam && inProgress && expiresAtUtc) {
      tickCountdown();
      setInterval(tickCountdown, 1000);
    }
  })();
</script>
