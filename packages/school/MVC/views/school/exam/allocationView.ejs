<div class="sections-page">
  <input type="hidden" id="allocationActionStateId" value="<%= actionStateId || '' %>">
  <div class="row g-2 align-items-start mb-4">
    <div class="col">
      <h1 class="page-heading size-md m-0 text-start" style="padding-left:0;">Exam Allocation</h1>
      <h6 class="fw-semibold text-primary mt-2 mb-0"><%= template?.title || allocation?.allocationName || 'Exam' %></h6>
      <div class="text-muted small mt-1">Allocation Name: <strong><%= allocation?.allocationName || '-' %></strong></div>
    </div>
    <div class="col-auto d-flex flex-column align-items-end gap-1">
      <span class="badge bg-primary border font-monospace">ID: <%= allocation?.id || '' %></span>
      <a href="/school/exams" class="btn btn-outline-secondary btn-sm"><i class="bi bi-house me-1"></i>Exam Home</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2">
      <div class="d-flex flex-wrap align-items-center gap-2">
        <a href="/school/exams/allocations" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Allocations</a>
        <a href="/school/exams/teacher-assignments/<%= allocation.id %>" class="btn btn-outline-info btn-sm"><i class="bi bi-list-check me-1"></i>Teacher Queue</a>
        <% const stHeader = String(allocation?.status || '').toLowerCase(); %>
        <% if (stHeader !== 'cancelled' && stHeader !== 'archived') { %>
          <a href="/school/exams/allocations/<%= allocation.id %>/edit" class="btn btn-outline-primary btn-sm"><i class="bi bi-pencil-square me-1"></i>Edit</a>
          <button type="button" id="btnCancelAllocation" class="btn btn-outline-danger btn-sm"><i class="bi bi-x-circle me-1"></i>Cancel</button>
        <% } %>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
      <div class="row g-3">
        <div class="col-md-3">
          <div class="small text-muted">Class</div>
          <div class="fw-bold"><%= classRow?.title || classRow?.name || allocation?.classId || '-' %></div>
          <div class="x-small text-muted font-monospace"><%= allocation?.classId || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Revision</div>
          <div class="fw-bold">R<%= Number(allocation?.revisionNo || revision?.revisionNo || 0) %></div>
          <div class="x-small text-muted font-monospace"><%= allocation?.revisionId || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Template</div>
          <div class="fw-bold"><%= template?.title || allocation?.templateId || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Status</div>
          <% const st = String(allocation?.status || '').toLowerCase(); %>
          <span class="badge <%= st === 'open' ? 'bg-success' : (st === 'scheduled' ? 'bg-primary' : (st === 'closed' ? 'bg-secondary' : (st === 'cancelled' ? 'bg-danger' : 'bg-warning text-dark'))) %>"><%= st || '-' %></span>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Timezone</div>
          <div class="fw-bold"><%= allocation?.timezone || allocation?.scheduling?.timezone || 'UTC' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Window Start (UTC)</div>
          <div class="fw-bold font-monospace x-small"><%= allocation?.windowStartUtc || allocation?.scheduling?.windowStartUtc || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Window End (UTC)</div>
          <div class="fw-bold font-monospace x-small"><%= allocation?.windowEndUtc || allocation?.scheduling?.windowEndUtc || '-' %></div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Duration</div>
          <div class="fw-bold"><%= Number(allocation?.durationMinutes || 0) %> min</div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Window Policy</div>
          <div class="fw-bold">
            <%= String(allocation?.windowPolicy || 'strict_fixed_window') === 'suggested_window' ? 'Suggested (guidance)' : 'Strict fixed window' %>
          </div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">Question Presentation</div>
          <div class="fw-bold">
            <%= String(allocation?.questionPresentationMode || 'all_questions_on_one_page') === 'sequential_one_by_one' ? 'One by one' : 'All in one page' %>
          </div>
        </div>
        <div class="col-md-3">
          <div class="small text-muted">In Final Score</div>
          <div class="fw-bold"><%= allocation?.countsInFinalScore === false ? 'No' : 'Yes' %></div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white d-flex align-items-center justify-content-between">
      <h5 class="m-0 fw-bold">Assignments Summary</h5>
      <% const isCancelledAllocation = String(allocation?.status || '').toLowerCase() === 'cancelled'; %>
      <div class="d-flex flex-wrap justify-content-end align-items-center gap-2">
        <span class="badge bg-secondary-subtle text-secondary-emphasis border">Exempt Students: <%= Number((Array.isArray(allocation?.extensions?.exemptStudentIds) ? allocation.extensions.exemptStudentIds.length : 0)) %></span>
        <button class="btn btn-primary btn-sm" type="button" id="btnAssignAllClass" <%= isCancelledAllocation ? 'disabled title=\"Cancelled allocations cannot generate assignments.\"' : '' %>>
          <i class="bi bi-people-fill me-1"></i>Assign to all class
        </button>
      </div>
    </div>
    <div class="card-body p-3">
      <div class="d-flex flex-wrap gap-2">
        <span class="badge bg-light text-dark border">Total: <%= Number(assignmentCounts?.total || 0) %></span>
        <span class="badge bg-warning-subtle text-warning-emphasis border">Pending: <%= Number(assignmentCounts?.pending || 0) %></span>
        <span class="badge bg-info-subtle text-info-emphasis border">Started: <%= Number(assignmentCounts?.started || 0) %></span>
        <span class="badge bg-primary-subtle text-primary-emphasis border">Submitted: <%= Number(assignmentCounts?.submitted || 0) %></span>
        <span class="badge bg-success-subtle text-success-emphasis border">Graded: <%= Number(assignmentCounts?.graded || 0) %></span>
      </div>
      <div class="row g-2 mt-1 align-items-end">
        <div class="col-lg-12 d-flex gap-2 justify-content-lg-end">
          <button type="button" class="btn btn-outline-success btn-sm" id="btnAddStudents" <%= isCancelledAllocation ? 'disabled title=\"Cancelled allocations cannot be edited.\"' : '' %>><i class="bi bi-person-plus me-1"></i>Add students</button>
          <button type="button" class="btn btn-outline-warning btn-sm" id="btnExemptStudents" <%= isCancelledAllocation ? 'disabled title=\"Cancelled allocations cannot be edited.\"' : '' %>><i class="bi bi-person-dash me-1"></i>Exempt students</button>
        </div>
      </div>
      <div class="form-text mt-2">Generation is idempotent: duplicates are skipped and already-assigned students are not recreated. Add/Exempt opens a multi-select class student picker.</div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white">
      <h5 class="m-0 fw-bold">Assignments</h5>
    </div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-3">Student</th>
              <th>Status</th>
              <th>Window</th>
              <th>Score</th>
              <th>Attempt</th>
              <th class="pe-3 text-end">Updated</th>
            </tr>
          </thead>
          <tbody>
            <% if (!assignments || !assignments.length) { %>
              <tr><td colspan="6" class="text-center py-4 text-muted">No assignments generated yet.</td></tr>
            <% } %>
            <% (assignments || []).forEach((row) => { %>
              <% const st = String(row.status || '').toLowerCase(); %>
              <tr>
                <td class="ps-3">
                  <div class="fw-semibold"><%= row.studentName || row.studentId || '-' %></div>
                  <div class="x-small text-muted font-monospace"><%= row.studentId || '-' %></div>
                  <% if (row.studentNo) { %>
                    <div class="x-small text-muted">No: <%= row.studentNo %></div>
                  <% } %>
                  <div class="x-small text-muted font-monospace"><%= row.id || '' %></div>
                </td>
                <td>
                  <span class="badge <%= st === 'graded' ? 'bg-success' : (st === 'submitted' ? 'bg-primary' : (st === 'started' ? 'bg-info' : (st === 'cancelled' ? 'bg-danger' : 'bg-warning text-dark'))) %>"><%= st || '-' %></span>
                </td>
                <td>
                  <div class="x-small font-monospace"><%= row.startWindowUtc || '-' %></div>
                  <div class="x-small font-monospace"><%= row.endWindowUtc || '-' %></div>
                </td>
                <td><%= Number(row.scoreComputed || 0) %> / <%= Number(row.maxScoreComputed || 0) %> (<%= Number(row.percentageComputed || 0) %>%)</td>
                <td class="font-monospace x-small"><%= row.startedAttemptId || row.submittedAttemptId || '-' %></td>
                <td class="pe-3 text-end x-small"><%= row.audit?.lastUpdateDateTime || row.audit?.createDateTime || '-' %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    const btnAssignAllClass = document.getElementById('btnAssignAllClass');
    const btnAddStudents = document.getElementById('btnAddStudents');
    const btnExemptStudents = document.getElementById('btnExemptStudents');
    const actionStateInput = document.getElementById('allocationActionStateId');
    const btnCancelAllocation = document.getElementById('btnCancelAllocation');
    const allocationId = '<%= allocation?.id || "" %>';
    const allocationName = '<%= String(allocation?.allocationName || allocation?.id || "").replace(/'/g, "\\'") %>';

    function setButtonsLoading(isLoading) {
      [btnAssignAllClass, btnAddStudents, btnExemptStudents, btnCancelAllocation].forEach((buttonEl) => {
        if (!buttonEl) return;
        if (!buttonEl.dataset.originalHtml) buttonEl.dataset.originalHtml = buttonEl.innerHTML;
        if (!buttonEl.dataset.initialDisabled) {
          buttonEl.dataset.initialDisabled = buttonEl.disabled ? '1' : '0';
        }
        const initiallyDisabled = buttonEl.dataset.initialDisabled === '1';
        buttonEl.disabled = Boolean(isLoading || initiallyDisabled);
        if (isLoading) {
          buttonEl.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Working...';
        } else {
          buttonEl.innerHTML = buttonEl.dataset.originalHtml;
        }
      });
      if (typeof showLoading === 'function') {
        if (isLoading) showLoading();
        else if (typeof hideLoading === 'function') hideLoading();
      }
    }

    async function showResult(title, icon, message, buttons) {
      if (typeof showMessageModal === 'function') {
        return showMessageModal({
          title,
          icon,
          message,
          buttons: Array.isArray(buttons) && buttons.length
            ? buttons
            : [{ text: 'OK', class: icon === 'success' ? 'btn-primary' : 'btn-secondary' }]
        });
      }
      alert(message || title);
      return Promise.resolve('OK');
    }

    async function postAllocationAction(url, body, successTitle, successFallbackMessage) {
      setButtonsLoading(true);
      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify(body || {})
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.status !== 'success') {
          throw new Error(String(payload?.message || 'Assignment generation failed.'));
        }
        await showResult(successTitle, 'success', String(payload?.message || successFallbackMessage || 'Action completed.'));
        window.location.reload();
      } catch (error) {
        await showResult('Operation Error', 'warning', String(error?.message || error || 'Could not complete operation.'));
      } finally {
        setButtonsLoading(false);
      }
    }

    function openStudentPicker(mode) {
      if (!window.GenericPicker || !window.GenericPickerPresets) {
        showResult('Picker Missing', 'warning', 'Generic picker is not available on this page.');
        return;
      }
      const isExemptMode = String(mode || '').trim().toLowerCase() === 'exempt';
      GenericPicker.open(window.GenericPickerPresets.normalizeConfig({
        title: isExemptMode ? 'Exempt Students' : 'Add Students',
        icon: isExemptMode ? 'bi-person-dash' : 'bi-person-plus',
        apiEndpoint: `/school/exams/api/allocation-class-students?allocationId=${encodeURIComponent(allocationId)}`,
        placeholder: 'Search class students...',
        searchFields: 'id,title,name,studentNo,status',
        multiselect: true,
        context: (window.GenericPickerContexts && typeof window.GenericPickerContexts.activeOrganizationScope === 'function')
          ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
          : undefined,
        renderer: function (item) {
          const assigned = item?.assigned ? '<span class="badge bg-success-subtle text-success-emphasis border ms-1">Assigned</span>' : '';
          const exempt = item?.exempt ? '<span class="badge bg-warning-subtle text-warning-emphasis border ms-1">Exempt</span>' : '';
          return `
            <div class="d-flex align-items-center justify-content-between gap-2">
              <div>
                <div class="fw-semibold">${String(item?.title || item?.id || '')}</div>
                <div class="small text-muted font-monospace">${String(item?.studentNo || '')} ${String(item?.id || '')}</div>
              </div>
              <div class="text-end">${assigned}${exempt}</div>
            </div>
          `;
        },
        onSelect: async function (selectedItems) {
          const selected = Array.isArray(selectedItems) ? selectedItems : [];
          const studentIds = selected
            .map((row) => String(row?.id || '').trim())
            .filter(Boolean);
          if (!studentIds.length) {
            await showResult('No Students Selected', 'warning', 'Select one or more students.');
            return;
          }
          const endpoint = isExemptMode
            ? `/school/exams/allocations/${encodeURIComponent(allocationId)}/assignments/exempt-students`
            : `/school/exams/allocations/${encodeURIComponent(allocationId)}/assignments/add-students`;
          const successTitle = isExemptMode ? 'Students Exempted' : 'Students Added';
          const successMsg = isExemptMode
            ? 'Students were exempted from this allocation.'
            : 'Students were added to assignment list.';
          await postAllocationAction(
            endpoint,
            {
              actionStateId: String(actionStateInput?.value || '').trim(),
              studentIds
            },
            successTitle,
            successMsg
          );
        }
      }));
    }

    btnAssignAllClass?.addEventListener('click', async function () {
      await postAllocationAction(
        `/school/exams/allocations/${encodeURIComponent(allocationId)}/assignments/generate`,
        { actionStateId: String(actionStateInput?.value || '').trim() },
        'Assignments Generated',
        'Assignments were generated.'
      );
    });

    btnAddStudents?.addEventListener('click', async function () {
      openStudentPicker('add');
    });

    btnExemptStudents?.addEventListener('click', async function () {
      openStudentPicker('exempt');
    });

    btnCancelAllocation?.addEventListener('click', async function () {
      const decision = await showResult(
        'Cancel Allocation?',
        'warning',
        `Cancel allocation <b>${allocationName}</b>? Pending/available assignments will be cancelled.`,
        [
          { text: 'Keep', class: 'btn-secondary' },
          { text: 'Confirm', class: 'btn-danger' }
        ]
      );
      if (decision !== 'Confirm') return;

      setButtonsLoading(true);
      try {
        const response = await fetch(`/school/exams/allocations/${encodeURIComponent(allocationId)}/cancel`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest'
          },
          body: JSON.stringify({
            actionStateId: String(actionStateInput?.value || '').trim()
          })
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok || payload?.status !== 'success') {
          throw new Error(String(payload?.message || 'Could not cancel allocation.'));
        }
        await showResult('Allocation Cancelled', 'success', String(payload?.message || 'Allocation cancelled.'));
        window.location.reload();
      } catch (error) {
        await showResult('Cancel Error', 'warning', String(error?.message || error || 'Could not cancel allocation.'));
      } finally {
        setButtonsLoading(false);
      }
    });
  })();
</script>

<%- include('partials/modal_GenericPicker') %>
