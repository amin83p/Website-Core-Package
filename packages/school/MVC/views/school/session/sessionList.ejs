<style>
    .session-row { cursor: pointer; transition: filter 0.18s ease, box-shadow 0.18s ease; }
    .session-row:hover { filter: brightness(0.985); }
    .status-badge { font-size: 0.75rem; font-weight: bold; padding: 0.35em 0.65em; border-radius: 4px; }
    .session-row.session-row-locked { box-shadow: inset 4px 0 0 #6c757d; }
    .session-row.session-row-locked:hover { filter: brightness(0.975); }
</style>

<div class="sections-page">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="page-heading size-md m-0 text-start"><i class="bi bi-search me-2"></i> Session Explorer</h1>
            <div class="text-muted small mt-1">Search, filter, and manage all class sessions across the school.</div>
        </div>
      <a href="<%= schoolSectionDashboardHref %>" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2">
        <i class="bi bi-speedometer2 me-1"></i> Dashboard
      </a>
    </div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body bg-light rounded">
            <div class="row g-3 mb-3">
                <div class="col-md-3">
                    <label class="form-label fw-bold small">Start Date</label>
                    <input type="date" id="filter_startDate" class="form-control form-control-sm">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small">End Date</label>
                    <input type="date" id="filter_endDate" class="form-control form-control-sm">
                </div>
                
                <div class="col-md-3">
                    <label class="form-label fw-bold small">Start Time (From)</label>
                    <input type="time" id="filter_startTime" class="form-control form-control-sm">
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-bold small">End Time (To)</label>
                    <input type="time" id="filter_endTime" class="form-control form-control-sm">
                </div>

                <div class="col-md-5">
                    <label class="form-label fw-bold small">Filter by Teacher</label>
                    <div class="input-group input-group-sm">
                        <input type="hidden" id="filter_teacherId">
                        <input type="text" id="filter_teacherName" class="form-control bg-white" placeholder="All Teachers..." readonly>
                        <button type="button" class="btn btn-outline-danger" id="btn_clearTeacher" title="Clear"><i class="bi bi-x"></i></button>
                        <button type="button" class="btn btn-outline-primary" id="btn_openTeacherPicker"><i class="bi bi-person-badge"></i></button>
                    </div>
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-bold small">Filter by Class</label>
                    <div class="input-group input-group-sm">
                        <input type="hidden" id="filter_classId">
                        <input type="text" id="filter_className" class="form-control bg-white" placeholder="All Classes..." readonly>
                        <button type="button" class="btn btn-outline-danger" id="btn_clearClass" title="Clear"><i class="bi bi-x"></i></button>
                        <button type="button" class="btn btn-outline-primary" id="btn_openClassPicker"><i class="bi bi-book"></i></button>
                    </div>
                </div>

                <div class="col-md-2 d-flex align-items-end">
                    <button type="button" id="btn_loadData" class="btn btn-primary btn-sm w-100 fw-bold py-2"><i class="bi bi-funnel-fill me-1"></i> Filter</button>
                </div>
            </div>

            <div class="d-flex gap-2 pt-2 border-top">
                <button type="button" class="btn btn-sm btn-outline-secondary btn-range py-0" data-range="today">Today</button>
                <button type="button" class="btn btn-sm btn-outline-secondary btn-range py-0" data-range="thisWeek">This Week</button>
                <button type="button" class="btn btn-sm btn-outline-secondary btn-range py-0" data-range="thisMonth">This Month</button>
                <button type="button" class="btn btn-sm btn-outline-secondary btn-range py-0" data-range="allTime">All Time</button>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h5 class="m-0 fw-bold text-dark"><i class="bi bi-list-ul me-2"></i> Search Results</h5>
            <span class="badge bg-primary text-white" id="lbl_resultCount">0 Sessions</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 650px; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0" id="sessionsTable">
                    <thead class="table-light position-sticky top-0" style="z-index: 1;">
                        <tr>
                            <th class="ps-4" style="width: 120px;">Date</th>
                            <th style="width: 150px;">Time</th>
                            <th>Class Name</th>
                            <th>Teacher</th>
                            <th>Status</th>
                            <th>Notes</th>
                            <th class="text-end pe-4">Action</th>
                        </tr>
                    </thead>
                    <tbody id="sessionsBody">
                        <tr><td colspan="7" class="text-center py-5 text-muted">Select filters and click 'Filter' to load sessions.</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<%- include('partials/modal_GenericPicker') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const normalizeStatusCode = (value) => String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
    const toStatusLabel = (status) => {
        const normalized = normalizeStatusCode(status);
        if (!normalized) return 'Status';
        return normalized.replace(/_/g, ' ').replace(/\b\w/g, (ch) => ch.toUpperCase());
    };
    const normalizeHexColor = (value, fallback = '#e2e3e5') => {
        const raw = String(value || '').trim();
        const normalized = raw.startsWith('#') ? raw : `#${raw}`;
        return /^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(normalized) ? normalized : fallback;
    };
    const colorToRgba = (value, alpha = 1, fallback = '#e2e3e5') => {
        const hex = normalizeHexColor(value, fallback).replace('#', '');
        const full = hex.length === 3 ? hex.split('').map((ch) => ch + ch).join('') : hex;
        const r = Number.parseInt(full.slice(0, 2), 16);
        const g = Number.parseInt(full.slice(2, 4), 16);
        const b = Number.parseInt(full.slice(4, 6), 16);
        const safeAlpha = Math.max(0, Math.min(1, Number(alpha)));
        return `rgba(${r}, ${g}, ${b}, ${safeAlpha})`;
    };
    let sessionStatusMetaMap = new Map();
    const buildStatusBadgeHtml = (status) => {
        const normalized = normalizeStatusCode(status);
        const meta = sessionStatusMetaMap.get(normalized);
        if (meta) {
            return `<span class="status-badge border" style="background:${meta.colorBg || '#e2e3e5'};color:${meta.colorText || '#41464b'};border-color:${meta.colorBorder || '#c6c8ca'} !important;">${meta.label || toStatusLabel(normalized)}</span>`;
        }
        return `<span class="status-badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle">${toStatusLabel(normalized || 'other')}</span>`;
    };
    const buildRowStyle = (status, locked) => {
        const normalized = normalizeStatusCode(status);
        const meta = sessionStatusMetaMap.get(normalized);
        const colorBg = normalizeHexColor(meta?.colorBg, normalized === 'holiday' ? '#fff3cd' : '#e2e3e5');
        const colorBorder = normalizeHexColor(meta?.colorBorder, normalized === 'holiday' ? '#ffe69c' : '#c6c8ca');
        const baseLayer = `linear-gradient(${colorToRgba(colorBg, 0.20, colorBg)}, ${colorToRgba(colorBg, 0.20, colorBg)})`;
        const lockLayer = locked
            ? `, repeating-linear-gradient(-45deg, ${colorToRgba('#6c757d', 0.08, '#6c757d')} 0 10px, ${colorToRgba('#adb5bd', 0.18, '#adb5bd')} 10px 20px)`
            : '';
        return [
            `background-color:${colorToRgba(colorBg, locked ? 0.14 : 0.20, colorBg)}`,
            `background-image:${baseLayer}${lockLayer}`,
            `border-left:4px solid ${locked ? '#6c757d' : colorBorder}`
        ].join(';');
    };

    // --- 1. Date Range Logic ---
    const setDateRange = (start, end) => {
        document.getElementById('filter_startDate').value = start ? start.toISOString().split('T')[0] : '';
        document.getElementById('filter_endDate').value = end ? end.toISOString().split('T')[0] : '';
    };

    document.querySelectorAll('.btn-range').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const range = e.target.getAttribute('data-range');
            const today = new Date();
            let start = new Date(today); let end = new Date(today);

            if (range === 'today') {
                // keep today
            } else if (range === 'thisWeek') {
                const day = today.getDay() || 7; 
                start.setHours(-24 * (day - 1)); 
                end.setTime(start.getTime() + (6 * 24 * 60 * 60 * 1000));
            } else if (range === 'thisMonth') {
                start = new Date(today.getFullYear(), today.getMonth(), 1);
                end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
            } else if (range === 'allTime') {
                setDateRange(null, null); 
                document.getElementById('btn_loadData').click();
                return;
            }
            
            setDateRange(start, end);
            document.getElementById('btn_loadData').click();
        });
    });

    // Default to Today on load
    document.querySelector('.btn-range[data-range="today"]').click();

    // --- 2. Pickers & Clear Buttons ---
    document.getElementById('btn_openTeacherPicker').addEventListener('click', () => {
        GenericPicker.open(GenericPickerPresets.teacher({
            title: 'Filter by Teacher',
            placeholder: 'Search teachers...',
            context: GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' }),
            onSelect: (item) => {
                const teacherId = item.personId || item.id || '';
                const teacherName = `${item.firstName || ''} ${item.lastName || ''}`.trim()
                    || item.name
                    || teacherId;
                document.getElementById('filter_teacherId').value = teacherId;
                document.getElementById('filter_teacherName').value = teacherName;
                document.getElementById('btn_loadData').click();
            }
        }));
    });

    document.getElementById('btn_openClassPicker').addEventListener('click', () => {
        GenericPicker.open(GenericPickerPresets.class({
            title: 'Filter by Class',
            icon: 'bi-book',
            onSelect: (item) => {
                document.getElementById('filter_classId').value = item.id;
                document.getElementById('filter_className').value = item.title || item.id;
                document.getElementById('btn_loadData').click();
            }
        }));
    });

    document.getElementById('btn_clearTeacher').addEventListener('click', () => {
        document.getElementById('filter_teacherId').value = '';
        document.getElementById('filter_teacherName').value = '';
        document.getElementById('btn_loadData').click();
    });

    document.getElementById('btn_clearClass').addEventListener('click', () => {
        document.getElementById('filter_classId').value = '';
        document.getElementById('filter_className').value = '';
        document.getElementById('btn_loadData').click();
    });

    // --- 3. Render Engine ---
    document.getElementById('btn_loadData').addEventListener('click', async () => {
        const startDate = document.getElementById('filter_startDate').value;
        const endDate = document.getElementById('filter_endDate').value;
        const startTime = document.getElementById('filter_startTime').value;
        const endTime = document.getElementById('filter_endTime').value;
        const teacherId = document.getElementById('filter_teacherId').value;
        const classId = document.getElementById('filter_classId').value;

        const btn = document.getElementById('btn_loadData');
        const originalHtml = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        btn.disabled = true;

        const tbody = document.getElementById('sessionsBody');
        tbody.innerHTML = `<tr><td colspan="7" class="text-center py-5"><div class="spinner-border text-primary mb-2"></div><br><small class="text-muted">Fetching sessions...</small></td></tr>`;

        try {
            // Build Query String
            const params = new URLSearchParams();
            if (startDate) params.append('startDate', startDate);
            if (endDate) params.append('endDate', endDate);
            if (startTime) params.append('startTime', startTime);
            if (endTime) params.append('endTime', endTime);
            if (teacherId) params.append('teacherId', teacherId);
            if (classId) params.append('classId', classId);

            const res = await fetch(`/school/sessions/api/data?${params.toString()}`, { headers: { 'X-AJAX-Request': 'true' } });
            const result = await res.json();
            
            if (result.status !== 'success') throw new Error(result.message);
            sessionStatusMetaMap = new Map(
                (Array.isArray(result.statusMeta) ? result.statusMeta : [])
                    .map((row) => [normalizeStatusCode(row?.code), row])
                    .filter(([code]) => Boolean(code))
            );

            document.getElementById('lbl_resultCount').innerText = `${result.data.length} Sessions`;
            tbody.innerHTML = '';

            if (result.data.length === 0) {
                tbody.innerHTML = `<tr><td colspan="7" class="text-center py-5 text-muted"><i class="bi bi-search d-block fs-2 mb-2"></i>No sessions found matching these filters.</td></tr>`;
                return;
            }

            result.data.forEach(s => {
                // Formatting Date & Time
                const dObj = new Date(s.date + 'T00:00:00');
                const shortDate = dObj.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
                
                const badgeHtml = buildStatusBadgeHtml(s.status);
                const rowStyle = buildRowStyle(s.status, s.locked === true);

                // Interactive Icons
                const commentsIcon = s.hasComments ? `<i class="bi bi-chat-dots-fill text-primary ms-1" title="Interactive Notes inside"></i>` : '';
                const truncateNotes = s.notes && s.notes.length > 30 ? s.notes.substring(0, 30) + '...' : (s.notes || '-');

                const rowHtml = `
                    <tr class="session-row ${s.locked ? 'session-row-locked' : ''}" style="${rowStyle}" onclick="window.open('/school/classes/${s.classId}/sessions/${s.sessionId}', '_blank')">
                        <td class="ps-4 fw-bold text-dark">${shortDate}</td>
                        <td class="text-muted small"><i class="bi bi-clock me-1"></i> ${s.startTime} - ${s.endTime}</td>
                        <td class="fw-bold text-primary">${s.className}</td>
                        <td>${s.teacherName}</td>
                        <td>${badgeHtml}${s.locked ? '<span class="badge bg-dark-subtle text-dark border ms-1"><i class="bi bi-lock-fill me-1"></i>Locked</span>' : ''}</td>
                        <td class="text-muted small fst-italic">${truncateNotes} ${commentsIcon}</td>
                        <td class="text-end pe-4">
                            <button class="btn btn-sm btn-light border text-primary"><i class="bi bi-box-arrow-in-right"></i></button>
                        </td>
                    </tr>
                `;
                tbody.innerHTML += rowHtml;
            });

        } catch (error) {
            console.error(error);
            tbody.innerHTML = `<tr><td colspan="7" class="text-center py-4 text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>${error.message}</td></tr>`;
        } finally {
            btn.innerHTML = originalHtml;
            btn.disabled = false;
        }
    });

});
</script>
