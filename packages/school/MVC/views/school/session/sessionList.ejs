<%
  const explorerAccess = (typeof sessionExplorerAccess !== 'undefined' && sessionExplorerAccess)
    ? sessionExplorerAccess
    : { isAdminViewer: true, canFilterByTeacher: true, lockedTeacherPersonId: '', lockedTeacherName: '' };
  const dashHref = typeof schoolSectionDashboardHref === 'string' && schoolSectionDashboardHref
    ? schoolSectionDashboardHref
    : '/dashboard/section-nav/SCHOOL';
  const newUrl = 'school/sessions';
  const hasSessionAdvancedFilters = false;
%>

<style>
    .session-row.session-row-locked { box-shadow: inset 4px 0 0 #6c757d; }
    .session-status-badge { font-size: 0.75rem; font-weight: 600; padding: 0.35em 0.65em; border-radius: 4px; }
</style>

<%- include('partials/tablePages-start', {
  title,
  newUrl,
  newLabel: null,
  user,
  tableName: typeof tableName !== 'undefined' ? tableName : 'Session_Explorer',
  btn_export: false,
  print: true,
  headerManageBtns: [
    '<a href="' + dashHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>',
    '<a href="/dashboard/section-nav/SCHOOL_ACADEMIA" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-journal-bookmark me-1"></i> School Academia</a>'
  ]
}) %>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
    <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter Sessions</div>
    <button
      id="sessionFilterToggleBtn"
      type="button"
      class="btn btn-outline-secondary btn-sm px-2"
      data-bs-toggle="collapse"
      data-bs-target="#sessionFilterCollapse"
      aria-expanded="true"
      aria-controls="sessionFilterCollapse"
      aria-label="Close filters">
      <i id="sessionFilterToggleIcon" class="bi bi-chevron-up"></i>
    </button>
  </div>
  <div class="collapse show" id="sessionFilterCollapse">
    <div class="card-body p-3" id="sessionFilterForm">
      <div class="row g-3 align-items-end">
        <div class="col-md-6 col-xl-4">
          <label class="form-label" for="filter_startDate">Start Date</label>
          <input type="date" id="filter_startDate" class="form-control size-md">
        </div>
        <div class="col-md-6 col-xl-4">
          <label class="form-label" for="filter_endDate">End Date</label>
          <input type="date" id="filter_endDate" class="form-control size-md">
        </div>
        <div class="col-md-12 col-xl-4 d-flex justify-content-xl-end gap-2 pt-xl-4">
          <button type="button" id="btn_resetFilters" class="btn btn-outline-secondary btn-md">Reset</button>
          <button type="button" id="btn_loadData" class="btn btn-filled btn-primary btn-md">
            <i class="bi bi-funnel me-1"></i> Apply
          </button>
        </div>
      </div>

      <div class="border rounded-3 bg-light-subtle p-2 mt-3">
        <div class="d-flex align-items-center justify-content-between">
          <div class="small fw-bold text-uppercase text-muted">Advanced Filters</div>
          <button
            id="sessionAdvancedToggleBtn"
            type="button"
            class="btn btn-outline-secondary btn-sm px-2"
            data-bs-toggle="collapse"
            data-bs-target="#sessionAdvancedFilterCollapse"
            aria-expanded="<%= hasSessionAdvancedFilters ? 'true' : 'false' %>"
            aria-controls="sessionAdvancedFilterCollapse"
            aria-label="<%= hasSessionAdvancedFilters ? 'Close advanced filters' : 'Open advanced filters' %>">
            <i id="sessionAdvancedToggleIcon" class="bi <%= hasSessionAdvancedFilters ? 'bi-chevron-up' : 'bi-chevron-down' %>"></i>
          </button>
        </div>
        <div class="collapse mt-2<%= hasSessionAdvancedFilters ? ' show' : '' %>" id="sessionAdvancedFilterCollapse">
          <div class="row g-3">
            <div class="col-md-6 col-xl-3">
              <label class="form-label" for="filter_startTime">Start Time (From)</label>
              <input type="time" id="filter_startTime" class="form-control size-md">
            </div>
            <div class="col-md-6 col-xl-3">
              <label class="form-label" for="filter_endTime">End Time (To)</label>
              <input type="time" id="filter_endTime" class="form-control size-md">
            </div>

            <% if (explorerAccess.canFilterByTeacher) { %>
            <div class="col-md-6 col-xl-3">
              <label class="form-label" for="filter_teacherName">Teacher</label>
              <div class="input-group">
                <input type="hidden" id="filter_teacherId">
                <input type="text" id="filter_teacherName" class="form-control bg-white" placeholder="All Teachers" readonly>
                <button type="button" class="btn btn-outline-primary" id="btn_openTeacherPicker" title="Select teacher">
                  <i class="bi bi-person-badge"></i>
                </button>
                <button type="button" class="btn btn-outline-secondary" id="btn_clearTeacher" title="Clear teacher">
                  <i class="bi bi-x-lg"></i>
                </button>
              </div>
            </div>
            <% } else if (explorerAccess.lockedTeacherPersonId) { %>
            <div class="col-md-6 col-xl-3">
              <label class="form-label" for="filter_teacherName">Your Teacher Profile</label>
              <input type="hidden" id="filter_teacherId" value="<%= explorerAccess.lockedTeacherPersonId %>">
              <input type="text" id="filter_teacherName" class="form-control size-md bg-white" value="<%= explorerAccess.lockedTeacherName || explorerAccess.lockedTeacherPersonId %>" readonly>
            </div>
            <% } %>

            <div class="col-md-6 col-xl-3">
              <label class="form-label" for="filter_className">Class</label>
              <div class="input-group">
                <input type="hidden" id="filter_classId">
                <input type="text" id="filter_className" class="form-control bg-white" placeholder="All Classes" readonly>
                <button type="button" class="btn btn-outline-primary" id="btn_openClassPicker" title="Select class">
                  <i class="bi bi-book"></i>
                </button>
                <button type="button" class="btn btn-outline-secondary" id="btn_clearClass" title="Clear class">
                  <i class="bi bi-x-lg"></i>
                </button>
              </div>
            </div>

            <div class="col-12">
              <label class="form-label">Quick Ranges</label>
              <div class="d-flex flex-wrap gap-2">
                <button type="button" class="btn btn-outline-secondary btn-sm btn-range" data-range="today">Today</button>
                <button type="button" class="btn btn-outline-secondary btn-sm btn-range" data-range="thisWeek">This Week</button>
                <button type="button" class="btn btn-outline-secondary btn-sm btn-range" data-range="thisMonth">This Month</button>
                <button type="button" class="btn btn-outline-secondary btn-sm btn-range" data-range="allTime">All Time</button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="card border-0 shadow-sm mb-3">
  <div class="card-body py-2 px-3 d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div class="small text-muted">
      Matched rows: <span class="fw-bold text-dark" id="lbl_resultCount">0</span>
    </div>
    <div class="small text-muted">
      Showing page: <span class="fw-bold text-dark" id="lbl_resultPage">1 / 1</span>
    </div>
  </div>
</div>

<%- include('partials/tablePages-search', {
  placeholder: 'Search sessions by class, teacher, status, notes, or session id...',
  fields: searchableFields || []
}) %>

<div class="table-scroll-wrapper" data-floating-row-actions="true">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="draggable dragable ps-4" data-column="date" style="width: 140px;">Date <span class="sort-icon"></span></th>
        <th class="draggable dragable" data-column="time" style="width: 150px;">Time <span class="sort-icon"></span></th>
        <th class="draggable dragable" data-column="className">Class <span class="sort-icon"></span></th>
        <th class="draggable dragable" data-column="teacher">Teacher <span class="sort-icon"></span></th>
        <th class="draggable dragable" data-column="status">Status <span class="sort-icon"></span></th>
        <th class="draggable dragable" data-column="notes">Notes <span class="sort-icon"></span></th>
        <th class="text-end pe-4" data-column="actions">Action</th>
      </tr>
    </thead>
    <tbody id="sessionsBody">
      <tr>
        <td colspan="7" class="text-center py-4 text-muted">Select filters and click Apply to load sessions.</td>
      </tr>
    </tbody>
  </table>
</div>

<%- include('partials/modal_GenericPicker', { user }) %>
<%- include('partials/tablePages-end') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const sessionExplorerAccess = <%- JSON.stringify(explorerAccess) %>;
    const canFilterByTeacher = sessionExplorerAccess.canFilterByTeacher === true;
    let serverSearchQuery = '';
    const normalizeStatusCode = (value) => String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
    const escapeHtml = (value) => String(value || '').replace(/[&<>"']/g, (ch) => ({
        '&': '&amp;',
        '<': '&lt;',
        '>': '&gt;',
        '"': '&quot;',
        "'": '&#39;'
    }[ch]));

    const toStatusLabel = (status) => {
        const normalized = normalizeStatusCode(status);
        if (!normalized) return 'Status';
        return normalized.replace(/_/g, ' ').replace(/\b\w/g, (ch) => ch.toUpperCase());
    };
    const normalizeHexColor = (value, fallback = '#e2e3e5') => {
        const raw = String(value || '').trim();
        const normalized = raw.startsWith('#') ? raw : `#${raw}`;
        return /^#([0-9a-f]{3}|[0-9a-f]{6})$/i.test(normalized) ? normalized : fallback;
    };

    let sessionStatusMetaMap = new Map();
    const buildStatusBadgeHtml = (status) => {
        const normalized = normalizeStatusCode(status);
        const meta = sessionStatusMetaMap.get(normalized);
        if (meta) {
            return `<span class="badge session-status-badge border" style="background:${meta.colorBg || '#e2e3e5'};color:${meta.colorText || '#41464b'};border-color:${meta.colorBorder || '#c6c8ca'} !important;">${escapeHtml(meta.label || toStatusLabel(normalized))}</span>`;
        }
        return `<span class="badge session-status-badge bg-secondary bg-opacity-10 text-secondary border border-secondary-subtle">${escapeHtml(toStatusLabel(normalized || 'other'))}</span>`;
    };

    function initCollapseToggleIcon(options = {}) {
        const collapseEl = document.getElementById(String(options.collapseId || ''));
        const buttonEl = document.getElementById(String(options.buttonId || ''));
        const iconEl = document.getElementById(String(options.iconId || ''));
        if (!collapseEl || !buttonEl || !iconEl) return;

        const openIcon = String(options.openIcon || 'bi-chevron-down');
        const closeIcon = String(options.closeIcon || 'bi-chevron-up');
        const openLabel = String(options.openLabel || 'Open filters');
        const closeLabel = String(options.closeLabel || 'Close filters');

        const setState = (expanded) => {
            iconEl.classList.remove(openIcon, closeIcon);
            iconEl.classList.add(expanded ? closeIcon : openIcon);
            buttonEl.setAttribute('aria-expanded', expanded ? 'true' : 'false');
            buttonEl.setAttribute('aria-label', expanded ? closeLabel : openLabel);
        };

        setState(collapseEl.classList.contains('show'));
        collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
        collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
    }

    const setDateRange = (start, end) => {
        document.getElementById('filter_startDate').value = start ? start.toISOString().split('T')[0] : '';
        document.getElementById('filter_endDate').value = end ? end.toISOString().split('T')[0] : '';
    };

    const updateResultSummary = (count) => {
        const total = Number(count || 0);
        document.getElementById('lbl_resultCount').innerText = total.toLocaleString();
        document.getElementById('lbl_resultPage').innerText = total > 0 ? '1 / 1' : '0 / 0';
    };

    const resetFilters = ({ reload = true } = {}) => {
        setDateRange(null, null);
        document.getElementById('filter_startTime').value = '';
        document.getElementById('filter_endTime').value = '';
        serverSearchQuery = '';
        const classIdEl = document.getElementById('filter_classId');
        const classNameEl = document.getElementById('filter_className');
        if (classIdEl) classIdEl.value = '';
        if (classNameEl) classNameEl.value = '';
        if (canFilterByTeacher) {
            const teacherIdEl = document.getElementById('filter_teacherId');
            const teacherNameEl = document.getElementById('filter_teacherName');
            if (teacherIdEl) teacherIdEl.value = '';
            if (teacherNameEl) teacherNameEl.value = '';
        }
        const searchInput = document.getElementById('searchInput');
        if (searchInput) searchInput.value = '';
        if (reload) {
            document.querySelector('.btn-range[data-range="today"]')?.click();
        }
    };

    const tableSearchForm = document.getElementById('tableSearchModalForm');
    if (tableSearchForm) {
        tableSearchForm.addEventListener('submit', (event) => {
            event.preventDefault();
            event.stopImmediatePropagation();
            serverSearchQuery = String(document.getElementById('tsmQuery')?.value || '').trim();
            const quickSearchInput = document.getElementById('searchInput');
            if (quickSearchInput) quickSearchInput.value = serverSearchQuery;
            const modalEl = document.getElementById('tableSearchModal');
            if (modalEl && window.bootstrap?.Modal) {
                const instance = window.bootstrap.Modal.getInstance(modalEl) || new window.bootstrap.Modal(modalEl);
                instance.hide();
            }
            document.getElementById('btn_loadData').click();
        }, true);
    }

    const reloadBtn = document.getElementById('resetQueryBtn');
    if (reloadBtn) {
        reloadBtn.addEventListener('click', (event) => {
            event.preventDefault();
            document.getElementById('btn_loadData').click();
        });
    }

    document.querySelectorAll('.btn-range').forEach((btn) => {
        btn.addEventListener('click', (e) => {
            const range = e.currentTarget.getAttribute('data-range');
            const today = new Date();
            let start = new Date(today);
            let end = new Date(today);

            if (range === 'today') {
                // keep today
            } else if (range === 'thisWeek') {
                const day = today.getDay() || 7;
                start.setHours(-24 * (day - 1));
                end.setTime(start.getTime() + (6 * 24 * 60 * 60 * 1000));
            } else if (range === 'thisMonth') {
                start = new Date(today.getFullYear(), today.getMonth(), 1);
                end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
            } else if (range === 'allTime') {
                setDateRange(null, null);
                document.getElementById('btn_loadData').click();
                return;
            }

            setDateRange(start, end);
            document.getElementById('btn_loadData').click();
        });
    });

    document.getElementById('btn_resetFilters')?.addEventListener('click', () => resetFilters({ reload: true }));

    if (canFilterByTeacher) {
        document.getElementById('btn_openTeacherPicker')?.addEventListener('click', () => {
            GenericPicker.open(GenericPickerPresets.teacher({
                title: 'Filter by Teacher',
                placeholder: 'Search teachers...',
                context: GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' }),
                onSelect: (item) => {
                    const teacherId = item.personId || item.id || '';
                    const teacherName = `${item.firstName || ''} ${item.lastName || ''}`.trim()
                        || item.name
                        || teacherId;
                    document.getElementById('filter_teacherId').value = teacherId;
                    document.getElementById('filter_teacherName').value = teacherName;
                    document.getElementById('btn_loadData').click();
                }
            }));
        });

        document.getElementById('btn_clearTeacher')?.addEventListener('click', () => {
            document.getElementById('filter_teacherId').value = '';
            document.getElementById('filter_teacherName').value = '';
            document.getElementById('btn_loadData').click();
        });
    }

    document.getElementById('btn_openClassPicker')?.addEventListener('click', () => {
        GenericPicker.open(GenericPickerPresets.class({
            title: 'Filter by Class',
            icon: 'bi-book',
            onSelect: (item) => {
                document.getElementById('filter_classId').value = item.id;
                document.getElementById('filter_className').value = item.title || item.id;
                document.getElementById('btn_loadData').click();
            }
        }));
    });

    document.getElementById('btn_clearClass')?.addEventListener('click', () => {
        document.getElementById('filter_classId').value = '';
        document.getElementById('filter_className').value = '';
        document.getElementById('btn_loadData').click();
    });

    const buildSessionRowHtml = (session) => {
        const dObj = new Date(`${session.date}T00:00:00`);
        const shortDate = dObj.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' });
        const badgeHtml = buildStatusBadgeHtml(session.status);
        const commentsIcon = session.hasComments
            ? '<i class="bi bi-chat-dots-fill text-primary ms-1" title="Interactive notes inside"></i>'
            : '';
        const truncateNotes = session.notes && session.notes.length > 30
            ? `${session.notes.substring(0, 30)}...`
            : (session.notes || '-');
        const rowId = `${session.classId}-${session.sessionId}`;
        const sessionUrl = `/school/classes/${encodeURIComponent(session.classId)}/sessions/${encodeURIComponent(session.sessionId)}`;

        return `
            <tr class="${session.locked ? 'session-row-locked' : ''}" data-session-row-id="${escapeHtml(rowId)}">
                <td class="ps-4" data-sort-value="${escapeHtml(session.date || '')}">
                    <div class="fw-bold text-dark">${escapeHtml(shortDate)}</div>
                    <div class="x-small text-muted font-monospace">${escapeHtml(session.sessionId || '-')}</div>
                </td>
                <td data-sort-value="${escapeHtml(session.startTime || '')}">
                    <div class="small text-muted"><i class="bi bi-clock me-1"></i>${escapeHtml(session.startTime || '')} - ${escapeHtml(session.endTime || '')}</div>
                </td>
                <td data-sort-value="${escapeHtml(session.className || '')}">
                    <div class="fw-bold text-dark">${escapeHtml(session.className || '-')}</div>
                    <div class="x-small text-muted font-monospace">${escapeHtml(session.classId || '-')}</div>
                </td>
                <td data-sort-value="${escapeHtml(session.teacherName || '')}">
                    <div class="small fw-bold text-dark">${escapeHtml(session.teacherName || 'Unassigned')}</div>
                </td>
                <td data-sort-value="${escapeHtml(normalizeStatusCode(session.status))}">
                    ${badgeHtml}
                    ${session.locked ? '<span class="badge bg-dark-subtle text-dark border ms-1"><i class="bi bi-lock-fill me-1"></i>Locked</span>' : ''}
                </td>
                <td data-sort-value="${escapeHtml(session.notes || '')}">
                    <div class="small text-muted fst-italic">${escapeHtml(truncateNotes)} ${commentsIcon}</div>
                </td>
                <td class="table-actions text-end pe-4">
                    <div class="row-actions-wrap">
                        <button
                            type="button"
                            class="btn btn-secondary btn-sm btn-row-actions-toggle"
                            data-row-actions-id="${escapeHtml(rowId)}"
                            title="Session actions">
                            <i class="bi bi-three-dots-vertical"></i>
                        </button>
                        <div class="row-actions-menu d-none" data-row-actions-id="${escapeHtml(rowId)}">
                            <a href="${sessionUrl}" target="_blank" rel="noopener" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Open Session
                            </a>
                        </div>
                    </div>
                </td>
            </tr>
        `;
    };

    document.getElementById('btn_loadData').addEventListener('click', async () => {
        const startDate = document.getElementById('filter_startDate').value;
        const endDate = document.getElementById('filter_endDate').value;
        const startTime = document.getElementById('filter_startTime').value;
        const endTime = document.getElementById('filter_endTime').value;
        const teacherIdEl = document.getElementById('filter_teacherId');
        const teacherId = teacherIdEl ? teacherIdEl.value : '';
        const classId = document.getElementById('filter_classId').value;

        const btn = document.getElementById('btn_loadData');
        const originalHtml = btn.innerHTML;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';
        btn.disabled = true;

        const tbody = document.getElementById('sessionsBody');
        tbody.innerHTML = '<tr><td colspan="7" class="text-center py-4"><div class="spinner-border text-primary mb-2"></div><br><small class="text-muted">Fetching sessions...</small></td></tr>';

        try {
            const params = new URLSearchParams();
            if (startDate) params.append('startDate', startDate);
            if (endDate) params.append('endDate', endDate);
            if (startTime) params.append('startTime', startTime);
            if (endTime) params.append('endTime', endTime);
            if (teacherId) params.append('teacherId', teacherId);
            if (classId) params.append('classId', classId);
            if (serverSearchQuery) params.append('q', serverSearchQuery);

            const res = await fetch(`/school/sessions/api/data?${params.toString()}`, { headers: { 'X-AJAX-Request': 'true' } });
            const result = await res.json();

            if (result.status !== 'success') throw new Error(result.message);
            sessionStatusMetaMap = new Map(
                (Array.isArray(result.statusMeta) ? result.statusMeta : [])
                    .map((row) => [normalizeStatusCode(row?.code), row])
                    .filter(([code]) => Boolean(code))
            );

            updateResultSummary(result.data.length);
            tbody.innerHTML = '';

            if (result.data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="7" class="text-center py-4 text-muted">No sessions found matching these filters.</td></tr>';
                return;
            }

            tbody.innerHTML = result.data.map((session) => buildSessionRowHtml(session)).join('');

            const searchInput = document.getElementById('searchInput');
            if (searchInput && searchInput.value.trim()) {
                searchInput.dispatchEvent(new Event('input', { bubbles: true }));
            }
        } catch (error) {
            console.error(error);
            updateResultSummary(0);
            tbody.innerHTML = `<tr><td colspan="7" class="text-center py-4 text-danger"><i class="bi bi-exclamation-triangle-fill me-2"></i>${escapeHtml(error.message)}</td></tr>`;
        } finally {
            btn.innerHTML = originalHtml;
            btn.disabled = false;
        }
    });

    initCollapseToggleIcon({
        collapseId: 'sessionFilterCollapse',
        buttonId: 'sessionFilterToggleBtn',
        iconId: 'sessionFilterToggleIcon',
        openIcon: 'bi-chevron-down',
        closeIcon: 'bi-chevron-up',
        openLabel: 'Open filters',
        closeLabel: 'Close filters'
    });

    initCollapseToggleIcon({
        collapseId: 'sessionAdvancedFilterCollapse',
        buttonId: 'sessionAdvancedToggleBtn',
        iconId: 'sessionAdvancedToggleIcon',
        openIcon: 'bi-chevron-down',
        closeIcon: 'bi-chevron-up',
        openLabel: 'Open advanced filters',
        closeLabel: 'Close advanced filters'
    });

    document.querySelector('.btn-range[data-range="today"]')?.click();
});
</script>
