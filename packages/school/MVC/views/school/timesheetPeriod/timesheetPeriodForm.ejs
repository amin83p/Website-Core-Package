<%
  const p = period || {};
  const isEdit = !!p.id;
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
      <h1 class="page-heading size-md m-0"><i class="bi bi-calendar-plus me-2"></i><%= isEdit ? 'Edit Timesheet Period' : 'New Timesheet Period' %></h1>
      <% if(isEdit) { %> <span class="badge bg-primary border font-monospace">ID: <%= p.id %></span> <% } %>
  </div>

  <div class="form-container wide" style="max-width: 1400px;">
    <form id="periodForm" action="<%= isEdit ? '/school/timesheetPeriods/edit/'+p.id : '/school/timesheetPeriods/new' %>" method="POST">
      <input type="hidden" name="actionStateId" id="hid_actionStateId" value="<%= asid %>">
      
      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
           
           <div class="row">
              <div class="col-md-8 mb-3">
                 <label class="form-label fw-bold">Period Name *</label>
                 <input type="text" name="name" class="form-control size-md" placeholder="e.g. Feb 1 - 15, 2026" value="<%= p.name || '' %>" required>
                 <div class="form-text small">A clear, readable name for teachers to identify this pay period.</div>
              </div>
              <div class="col-md-4 mb-3">
                 <label class="form-label fw-bold">Status</label>
                 <select name="status" class="form-select size-md">
                    <option value="open" <%= p.status === 'open' ? 'selected' : '' %>>Open (Accepting Submissions)</option>
                    <option value="locked" <%= p.status === 'locked' ? 'selected' : '' %>>Locked (Review Phase)</option>
                    <option value="processed" <%= p.status === 'processed' ? 'selected' : '' %>>Processed (Paid)</option>
                 </select>
              </div>
           </div>

           <div class="row mt-2">
              <div class="col-md-4 mb-3">
                 <label class="form-label fw-bold">Start Date *</label>
                 <input type="date" name="startDate" class="form-control size-md" value="<%= p.startDate || '' %>" required>
              </div>
              <div class="col-md-4 mb-3">
                 <label class="form-label fw-bold">End Date *</label>
                 <input type="date" name="endDate" class="form-control size-md" value="<%= p.endDate || '' %>" required>
              </div>
              <div class="col-md-4 mb-3">
                 <label class="form-label fw-bold text-danger"><i class="bi bi-clock-history"></i> Submission Deadline *</label>
                 <input type="date" name="submissionDeadline" class="form-control size-md border-danger text-danger fw-bold" value="<%= p.submissionDeadline || '' %>" required>
              </div>
           </div>

           <div class="row mt-2">
               <div class="col-12 mb-3">
                 <label class="form-label fw-bold">Internal Notes</label>
                 <textarea name="notes" class="form-control size-md" rows="2" placeholder="Optional notes for payroll admin..."><%= p.notes || '' %></textarea>
              </div>
           </div>

        </div>
      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md">Save Period</button>
        <a href="/school/timesheetPeriods" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction" data-return-url="/school/timesheetPeriods">Cancel</a>
      </div>
    </form>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('periodForm');
    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';

        try {
            const formData = new FormData(form);
            const data = new URLSearchParams(formData);

            const response = await fetch(form.action, {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-AJAX-Request': 'true' },
                body: data.toString()
            });

            const contentType = response.headers.get("content-type");
            if (!contentType || !contentType.includes("application/json")) {
                 throw new Error(`Server returned non-JSON response (Status ${response.status})`);
            }

            const result = await response.json();
            const guarded = typeof window.applyGuardedApiResult === 'function'
                ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Processed' })
                : { stop: false };
            if (guarded.stop) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                return;
            }

            if (typeof showMessageModal === 'function') {
                await showMessageModal({
                    title: result.status === 'success' ? 'Success' : 'Error',
                    icon: result.status === 'success' ? 'success' : 'error',
                    message: result.message || 'Operation completed.',
                    buttons: [{ text: 'OK', class: result.status === 'success' ? 'btn-success' : 'btn-danger' }]
                });
            } else {
                alert(result.message);
            }

            if (result.status === 'success') {
                window.location.href = '/school/timesheetPeriods';
            } else {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
            }

        } catch (error) {
            console.error('Submission Error:', error);
            submitBtn.disabled = false;
            submitBtn.innerHTML = originalText;

            if (typeof showMessageModal === 'function') {
                await showMessageModal({
                    title: 'System Error', icon: 'error', message: error.message || 'An unexpected network error occurred.',
                    buttons: [{ text: 'Close', class: 'btn-secondary' }]
                });
            } else {
                alert(error.message);
            }
        }
    });
});
</script>
