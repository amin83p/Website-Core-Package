  }

  async function confirmAppendGapBatchSessions() {
    const batchEnd = String(qs('gap_batchEnd')?.value || '').trim();
    const cycleEnd = String(cycleWindow?.endDate || '').trim();
    const needsCycleExtend = Boolean(batchEnd && (!cycleEnd || batchEnd > cycleEnd));
    const lines = [
      'New sessions will be staged for this enrollment (not saved yet).',
      'They will be added to the class schedule only when enrollment completes successfully.',
      'They will count toward every enrolled student whose end date covers those session dates.'
    ];
    if (needsCycleExtend) {
      lines.push(`The cycle end date will be extended from ${cycleEnd || 'not set'} to ${batchEnd} when enrollment completes.`);
    }
    let confirmed = false;
    if (typeof window.showMessageModal === 'function') {
      const result = await window.showMessageModal({
        title: 'Add Class Sessions',
        icon: 'warning',
        message: lines.join('<br><br>'),
        buttons: [
          { text: 'Cancel', class: 'btn-secondary', value: false },
          { text: 'Stage Sessions', class: 'btn-warning', value: true }
        ]
      });
      // showMessageModal resolves with button text, not btn.value
      confirmed = result === true || String(result || '').trim() === 'Stage Sessions';
    } else {
      confirmed = window.confirm(lines.join('\n\n'));
    }
    return confirmed;
  }

  async function appendGapBatchSessions() {
    const body = buildGapBatchBody();
    const daysOfWeek = body.daysOfWeek || [];
    if (!body.startDate || !body.endDate || !daysOfWeek.length || !body.startTime || !body.endTime) {
      await showMsg('Validation', 'warning', 'Batch add requires date range, weekdays, and times.');
      return;
    }
    updateGapCycleExtendWarning();
    const confirmed = await confirmAppendGapBatchSessions();
    if (!confirmed) return;
    const batchEnd = String(body.endDate || '').trim();
    const cycleEnd = String(cycleWindow?.endDate || '').trim();
    const needsCycleExtend = Boolean(batchEnd && (!cycleEnd || batchEnd > cycleEnd));
    body.exceptionDates = await collectGapExceptionDates(body.startDate, body.endDate);
    try {
      showBusy('Staging sessions...');
      const result = await requestJson(`/school/classes/api/${encodeURIComponent(classId)}/sessions/preview-batch`, 'POST', {
        ...body,
        extendCycleEndDate: needsCycleExtend
      });
      if (!result) return;
      const proposedSessions = Array.isArray(result?.data?.proposedSessions) ? result.data.proposedSessions : [];
      const addedCount = appendUniqueStagedSessions(proposedSessions);
      if (!addedCount) {
        await showMsg('No Sessions', 'info', result.message || 'No new sessions would be added (dates may already exist).');
        return;
      }
      pendingGapBatch = {
        startDate: body.startDate,
        endDate: body.endDate,
        startTime: body.startTime,
        endTime: body.endTime,
        daysOfWeek,
        skipExistingDates: true,
        teacherId: body.teacherId,
        teacherName: body.teacherName,
        room: body.room,
        exceptionDates: body.exceptionDates,
        status: 'scheduled',
        extendCycleEndDate: needsCycleExtend
      };
      captureGapFormDraft();
      updateGapStagedBadge();
      await refreshAlignmentWithStagedSessions();
      syncEnrollmentWizardPrimaryButton();
      const conflictNote = result?.data?.hasConflicts
        ? ' Scheduling conflicts were detected and will be reviewed on the next step.'
        : '';
      await showMsg('Sessions Staged', 'success', `${addedCount} session(s) staged.${conflictNote} Complete enrollment to save them to the class.`);
    } catch (error) {
      await showMsg('Stage Sessions Failed', 'error', error.message || 'Unable to stage sessions.');
    } finally {
      hideBusy();
    }
  }

  async function proceedWithEnrollmentAfterAlignment() {
    const payload = collectEnrollmentPayloadFromForm();
    if (!payload.studentId || !payload.startDate) {
      await showMsg('Missing Required Fields', 'warning', 'Student and Start Date are required.');
      return;
    }
    if (cycleWindow?.isClosedForNewEnrollment) {
      await showMsg('Cycle closed', 'warning', 'This cycle is closed for new enrollment.');
      return;
    }
    const cycleDateIssue = validateCycleEnrollmentDates(payload.startDate, payload.endDate);
    if (cycleDateIssue) {
      await showMsg('Date out of range', 'warning', cycleDateIssue);
      return;
    }
    await refreshRollingEligibility();
    if (!lastRollingEligibility || lastRollingEligibility.eligible !== true) {
      await showMsg(
        'Not eligible',
        'warning',
        'The student must have an active program registration allowed for this class and meet prerequisites. Fix the issues shown under Program registration, then try again.'
      );
      return;
    }
    try {
      showBusy('Preparing enrollment...');
      const preview = await requestJson('/school/classes/api/enrollment-periods/preview-create', 'POST', payload);
      if (!preview) return;
      if (String(preview.mode || '').toLowerCase() === 'chargeable' && preview.requiresDraft) {
        hideBusy();
        openChargeModalWithDraft(payload, preview.draft || {});
        return;
      }

      const result = await requestJson('/school/classes/api/enrollment-periods/create-with-transactions', 'POST', payload);
      if (!result) return;
      addEnrollmentModal?.hide();
      const ledgerNote = academicLedgerHtmlNote(result.academicLedger);
      await showMsg('Success', 'success', (result.message || 'Enrollment period created.') + ledgerNote);
      await loadRows();
      clearEntryDraft();
      pendingPlannedNaSessionIds = [];
      clearPendingGapBatch();
    } catch (error) {
      await showMsg('Create Failed', 'error', error.message || 'Unable to create enrollment period.');
    } finally {
      hideBusy();
    }
  }

