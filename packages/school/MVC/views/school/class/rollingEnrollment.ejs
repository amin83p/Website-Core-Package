<style>
  .rolling-enrollment-page .card-body {
    padding: 0.9rem 1rem;
  }
  .rolling-enrollment-page .form-label {
    margin-bottom: 0.2rem;
    font-size: 0.82rem;
    font-weight: 600;
  }
  .rolling-enrollment-page .compact-help {
    font-size: 0.74rem;
  }
  .rolling-enrollment-page .table-sm thead th {
    font-size: 0.78rem;
    white-space: nowrap;
  }
  .rolling-enrollment-page .row-actions-wrap {
    position: relative;
    display: inline-block;
  }
  /* Base menu look (also when portaled to body so it is not clipped by the table) */
  .rolling-enrollment-page .row-actions-wrap .row-actions-menu,
  body > .row-actions-menu.row-actions-menu--floating {
    min-width: 148px;
    max-width: min(100vw - 1rem, 220px);
    z-index: 1100;
    background: #fff;
    border: 1px solid #d0d7de;
    border-radius: 0.45rem;
    box-shadow: 0 0.45rem 1rem rgba(0, 0, 0, 0.15);
    padding: 0.35rem;
  }
  .rolling-enrollment-page .row-actions-wrap > .row-actions-menu:not(.row-actions-menu--floating) {
    position: absolute;
    right: 0;
    top: calc(100% + 0.25rem);
    z-index: 15;
  }
  .rolling-enrollment-page .row-actions-menu .btn,
  body > .row-actions-menu.row-actions-menu--floating .btn {
    width: 100%;
    text-align: left;
    justify-content: flex-start;
    margin-bottom: 0.25rem;
  }
  .rolling-enrollment-page .row-actions-menu .btn:last-child,
  body > .row-actions-menu.row-actions-menu--floating .btn:last-child {
    margin-bottom: 0;
  }
  body > .row-actions-menu.row-actions-menu--floating {
    position: fixed;
    margin: 0;
  }
  .rolling-enrollment-page kbd {
    background: #f1f3f5;
