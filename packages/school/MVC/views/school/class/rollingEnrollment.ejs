  function bindKeyboardFlow() {
    const triggerAddOnEnterIds = [
      'inp_startDate',
      'inp_endDate',
      'inp_status',
      'inp_funderType',
      'inp_funderId',
      'inp_authorizationRef'
    ];
    triggerAddOnEnterIds.forEach((id) => {
      const el = qs(id);
      if (!el) return;
      el.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' || event.shiftKey || event.ctrlKey || event.altKey || event.metaKey) return;
        event.preventDefault();
        addButton?.click();
      });
    });

    qs('inp_reasonStart')?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && event.ctrlKey) {
        event.preventDefault();
        addButton?.click();
      }
    });

    qs('close_reasonEnd')?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && event.ctrlKey) {
        event.preventDefault();
        qs('btn_confirmClosePeriod')?.click();
      }
    });

    qs('reentry_reasonStart')?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && event.ctrlKey) {
        event.preventDefault();
        qs('btn_confirmReentry')?.click();
      }
    });

    document.addEventListener('keydown', (event) => {
      const key = String(event.key || '').toLowerCase();
      if (event.altKey && key === 's') {
        event.preventDefault();
        pickStudent();
        return;
      }
      if (event.altKey && key === 'a') {
        event.preventDefault();
        addButton?.click();
        return;
      }
      if (event.key === 'Escape') {
        if (addEnrollmentModalEl?.classList.contains('show')) addEnrollmentModal?.hide();
        if (closeModalEl?.classList.contains('show')) closeModal?.hide();
        if (reentryModalEl?.classList.contains('show')) reentryModal?.hide();
        if (editModalEl?.classList.contains('show')) editModal?.hide();
        if (chargeModalEl?.classList.contains('show')) chargeModal?.hide();
      }
    });

    closeModalEl?.addEventListener('shown.bs.modal', () => {
      qs('close_endDate')?.focus();
    });
    reentryModalEl?.addEventListener('shown.bs.modal', () => {
      qs('reentry_startDate')?.focus();
    });
    editModalEl?.addEventListener('shown.bs.modal', () => {
      qs('edit_startDate')?.focus();
    });
    chargeModalEl?.addEventListener('shown.bs.modal', () => {
      qs('btn_confirmChargeEnrollment')?.focus();
    });
    chargeModalEl?.addEventListener('hidden.bs.modal', () => {
      resetChargeModalState();
    });
  }

