  async function loadRows() {
    const search = (typeof window !== 'undefined' && window.location && window.location.search)
      ? window.location.search
      : '';
    const result = await requestJson(`/school/classes/api/${encodeURIComponent(classId)}/enrollment-periods${search}`);
    if (!result) return;
    periodRows = Array.isArray(result.items) ? result.items : [];
    renderRows();
  }

  async function addPeriod() {
    if (enrollWizardStep === 'form') {
      if (!hasTargetSessionCount()) {
        await proceedWithEnrollmentAfterAlignment();
        return;
      }
      const alignmentGate = await ensureEnrollmentSessionAlignment();
      if (alignmentGate.nextStep === 'addSessions') {
        enrollWizardPath = 'planA';
        enrollWizardStep = 'addSessions';
        prepareAddSessionsStep(alignmentGate.alignment);
        setEnrollmentWizardStepVisibility();
        return;
      }
      if (alignmentGate.nextStep === 'markNa') {
        enrollWizardPath = 'planB';
        enrollWizardStep = 'markNa';
        prepareMarkNaStep(alignmentGate.alignment);
        setEnrollmentWizardStepVisibility();
        return;
      }
      if (!alignmentGate.ok) return;
      await proceedWithEnrollmentAfterAlignment();
      return;
    }

    if (enrollWizardStep === 'addSessions') {
      const alignment = await refreshAlignmentWithStagedSessions();
      if (!pendingStagedSessions.length || String(alignment?.alignmentStatus || '') !== 'ok') {
        await showMsg('Sessions required', 'warning', 'Stage enough sessions to match Number of Sessions before continuing.');
        syncEnrollmentWizardPrimaryButton();
        return;
      }
      const loaded = await loadConflictReviewStep();
      if (!loaded) return;
      enrollWizardStep = 'conflicts';
      setEnrollmentWizardStepVisibility();
      return;
    }

    if (enrollWizardStep === 'markNa') {
      const required = Number(lastAlignmentResult?.requiredNaCount || 0);
      const selected = readSelectedNaSessionIds();
      if (selected.length !== required) {
        await showMsg('Validation', 'warning', `Select exactly ${required} session(s) to mark N/A.`);
        return;
      }
      pendingPlannedNaSessionIds = selected.slice();
      await proceedWithEnrollmentAfterAlignment();
      return;
    }

    if (enrollWizardStep === 'conflicts') {
      if (conflictReviewHasConflicts) {
        await showMsg('Conflicts remain', 'warning', 'Go Back to the add-sessions step and resolve conflicts before adding the enrollment period.');
        return;
      }
      await proceedWithEnrollmentAfterAlignment();
    }
  }

