  function bindKeyboardFlow() {
    const triggerAddOnEnterIds = [
      'inp_startDate',
      'inp_endDate',
      'inp_status',
      'inp_funderType',
      'inp_funderId',
      'inp_authorizationRef'
    ];
    triggerAddOnEnterIds.forEach((id) => {
      const el = qs(id);
      if (!el) return;
      el.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' || event.shiftKey || event.ctrlKey || event.altKey || event.metaKey) return;
        event.preventDefault();
        addButton?.click();
      });
    });

    qs('inp_reasonStart')?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && event.ctrlKey) {
        event.preventDefault();
        addButton?.click();
      }
    });

    qs('close_reasonEnd')?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && event.ctrlKey) {
        event.preventDefault();
        qs('btn_confirmClosePeriod')?.click();
      }
    });

    qs('reentry_reasonStart')?.addEventListener('keydown', (event) => {
      if (event.key === 'Enter' && event.ctrlKey) {
        event.preventDefault();
        qs('btn_confirmReentry')?.click();
      }
    });

    document.addEventListener('keydown', (event) => {
      const key = String(event.key || '').toLowerCase();
      if (event.altKey && key === 's') {
        event.preventDefault();
        pickStudent();
        return;
      }
      if (event.altKey && key === 'a') {
        event.preventDefault();
        addButton?.click();
        return;
      }
      if (event.key === 'Escape') {
        if (addEnrollmentModalEl?.classList.contains('show')) addEnrollmentModal?.hide();
        if (closeModalEl?.classList.contains('show')) closeModal?.hide();
        if (reentryModalEl?.classList.contains('show')) reentryModal?.hide();
        if (editModalEl?.classList.contains('show')) editModal?.hide();
        if (chargeModalEl?.classList.contains('show')) chargeModal?.hide();
      }
    });

    closeModalEl?.addEventListener('shown.bs.modal', () => {
      qs('close_endDate')?.focus();
    });
    reentryModalEl?.addEventListener('shown.bs.modal', () => {
      qs('reentry_startDate')?.focus();
    });
    editModalEl?.addEventListener('shown.bs.modal', () => {
      qs('edit_startDate')?.focus();
    });
    chargeModalEl?.addEventListener('shown.bs.modal', () => {
      qs('btn_confirmChargeEnrollment')?.focus();
    });
    chargeModalEl?.addEventListener('hidden.bs.modal', () => {
      resetChargeModalState();
    });
  }

  async function submitEditPeriod() {
    const periodId = String(qs('edit_periodId')?.value || '').trim();
    const startDate = String(qs('edit_startDate')?.value || '').trim();
    const endDate = String(qs('edit_endDate')?.value || '').trim();
    if (!periodId || !startDate) {
      await showMsg('Missing Fields', 'warning', 'Period and Start Date are required.');
      return;
    }
    const cycleDateIssue = validateCycleEnrollmentDates(startDate, endDate);
    if (cycleDateIssue) {
      await showMsg('Date out of range', 'warning', cycleDateIssue);
      return;
    }
    const nextStatus = String(qs('edit_status')?.value || 'active').trim().toLowerCase();
    if (cycleWindow?.isClosedForNewEnrollment && nextStatus === 'active') {
      const row = (Array.isArray(periodRows) ? periodRows : []).find((item) => String(item?.id || '') === periodId);
      const priorStatus = String(row?.status || '').trim().toLowerCase();
      if (['draft', 'planned', 'error'].includes(priorStatus)) {
        await showMsg('Cycle closed', 'warning', 'This cycle is closed for new enrollment. Draft periods cannot be approved to active.');
        return;
      }
    }
    try {
      showBusy('Saving enrollment period changes...');
      const editPayload = {
        startDate,
        endDate: String(qs('edit_endDate')?.value || '').trim(),
        status: String(qs('edit_status')?.value || 'active').trim(),
        funderType: String(qs('edit_funderType')?.value || '').trim(),
        funderId: String(qs('edit_funderId')?.value || '').trim(),
        authorizationRef: String(qs('edit_authorizationRef')?.value || '').trim(),
        reasonStart: String(qs('edit_reasonStart')?.value || '').trim(),
        sessionCountPolicy: 'all_non_na'
      };
      if (hasTargetSessionCount('edit_targetSessionCount')) {
        editPayload.targetSessionCount = String(qs('edit_targetSessionCount')?.value || '').trim();
      } else {
        editPayload.targetSessionCount = '';
      }
      const result = await requestJson(`/school/classes/api/enrollment-periods/${encodeURIComponent(periodId)}/edit`, 'POST', editPayload);
      if (!result) return;
      editModal?.hide();
      await showMsg('Updated', 'success', result.message || 'Enrollment period updated.');
      await loadRows();
    } catch (error) {
      await showMsg('Update Failed', 'error', error.message || 'Unable to update enrollment period.');
    } finally {
      hideBusy();
    }
  }

