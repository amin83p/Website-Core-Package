<script src="/scripts/wizardStepRail.js"></script>
<script>
(() => {
  const classId = <%- JSON.stringify(String(c.id || '')) %>;
  const actionStateId = <%- JSON.stringify(String(asid || '')) %>;
  const cycleWindow = {
    startDate: <%- JSON.stringify(cycleStartDate) %>,
    endDate: <%- JSON.stringify(cycleEndDate) %>,
    isClosedForNewEnrollment: <%- JSON.stringify(Boolean(isClosedForNewEnrollment)) %>
  };
  const periodTableColspan = 11;
  const studentOptions = <%- studentOptionsJson %>;
  const enrollmentProgramChoices = <%- enrollmentProgramChoicesJson %>;
  const canCreateProgramRegistrations = <%- canCreateProgramRegistrationsJson %>;
  const canCreatePriorSubjectCredits = <%- canCreatePriorSubjectCreditsJson %>;
  const defaultTeacher = <%- defaultTeacherJson %>;
  const studentMap = new Map((Array.isArray(studentOptions) ? studentOptions : []).map((row) => [String(row.id || ''), row]));
  let periodRows = <%- initialRowsJson %>;
  let pendingEnrollmentPayload = null;
  let pendingDraftTransactionItems = [];
  let manualRows = [];
  let chargeActionInProgress = false;
  let shortcutActionInProgress = false;
  let draftReviewMode = 'create';
  let lastRollingEligibility = null;
  let lastAlignmentResult = null;
  let pendingPlannedNaSessionIds = [];
  let pendingGapBatch = null;
  let pendingGapPreview = null;
  let pendingStagedSessions = [];
  let gapFormDraft = null;
  let gapFormDraftTimer = null;
  let alignmentDebounceTimer = null;
  let enrollWizardStep = 'form'; // form | addSessions | markNa | conflicts
  let enrollWizardPath = null; // null | 'planA' | 'planB'
  let lastConflictReview = null;
  let conflictReviewHasConflicts = false;

  const qs = (id) => document.getElementById(id);
  const tbody = qs('tbody_periods');

  function normalizeTargetSessionCountValue(value) {
    const parsed = Number.parseInt(String(value ?? '').trim(), 10);
    return Number.isFinite(parsed) && parsed > 0 ? parsed : 0;
  }

  function hasTargetSessionCount(inputId = 'inp_targetSessionCount') {
    return normalizeTargetSessionCountValue(qs(inputId)?.value) > 0;
  }

  function applyTargetSessionCountUi() {
    const targetSet = hasTargetSessionCount();
    qs('lbl_endDateRequired')?.classList.toggle('d-none', !targetSet);
  }

  function updateGapCycleExtendWarning() {
    const warning = qs('gapCycleExtendWarning');
    if (!warning) return;
    const batchEnd = String(qs('gap_batchEnd')?.value || '').trim();
    const cycleEnd = String(cycleWindow?.endDate || '').trim();
    if (batchEnd && cycleEnd && batchEnd > cycleEnd) {
      warning.classList.remove('d-none');
      warning.innerHTML = `<b>Cycle end date will be extended</b> from <b>${htmlEscape(cycleEnd)}</b> to <b>${htmlEscape(batchEnd)}</b> when enrollment completes successfully.`;
      return;
    }
    if (batchEnd && !cycleEnd) {
      warning.classList.remove('d-none');
      warning.innerHTML = `<b>Cycle end date will be set</b> to <b>${htmlEscape(batchEnd)}</b> when enrollment completes successfully.`;
      return;
    }
    warning.classList.add('d-none');
    warning.innerHTML = '';
  }

  function validateCycleEnrollmentDates(startDate) {
    const start = String(startDate || '').trim();
    const minDate = String(cycleWindow?.startDate || '').trim();
    const maxDate = String(cycleWindow?.endDate || '').trim();
    if (minDate && start && start < minDate) {
      return `Enrollment start date cannot be before the cycle start (${minDate}).`;
    }
    if (maxDate && start && start > maxDate) {
      return `Enrollment start date cannot be after the cycle end (${maxDate}).`;
    }
    return '';
  }

  function validateCycleRegistrationDate(registrationDate) {
    const regDate = String(registrationDate || '').trim();
    const minDate = String(cycleWindow?.startDate || '').trim();
    const maxDate = String(cycleWindow?.endDate || '').trim();
    if (minDate && regDate && regDate < minDate) {
      return `Program registration date cannot be before the cycle start (${minDate}).`;
    }
    if (maxDate && regDate && regDate > maxDate) {
      return `Program registration date cannot be after the cycle end (${maxDate}).`;
    }
    return '';
  }

  const periodCount = qs('lbl_periodCount');
  const addEnrollmentModalEl = qs('addEnrollmentPeriodModal');
  const closeModalEl = qs('closePeriodModal');
  const reentryModalEl = qs('reentryModal');
  const editModalEl = qs('editPeriodModal');
  const chargeModalEl = qs('enrollmentChargeModal');
  const programShortcutModalEl = qs('programRegistrationShortcutModal');
  const priorCreditRepairModalEl = qs('priorCreditRepairModal');
  const enrollmentSessionListModalEl = qs('enrollmentSessionListModal');
  const bootstrapApi = window.bootstrap || (typeof bootstrap !== 'undefined' ? bootstrap : null);

  function createModalController(modalEl) {
    if (!modalEl) return null;

    // Preferred path: Bootstrap modal API
    if (bootstrapApi && typeof bootstrapApi.Modal === 'function') {
      const instance = (typeof bootstrapApi.Modal.getOrCreateInstance === 'function')
        ? bootstrapApi.Modal.getOrCreateInstance(modalEl)
        : new bootstrapApi.Modal(modalEl);
      return {
        show: () => instance.show(),
        hide: () => instance.hide()
      };
    }

    // Fallback path: lightweight manual modal controller
    let backdropEl = null;

    const show = () => {
      if (modalEl.classList.contains('show')) return;
      modalEl.style.display = 'block';
      modalEl.removeAttribute('aria-hidden');
      modalEl.setAttribute('aria-modal', 'true');
      modalEl.classList.add('show');
      document.body.classList.add('modal-open');
      document.body.style.overflow = 'hidden';

      backdropEl = document.createElement('div');
      backdropEl.className = 'modal-backdrop fade show';
      backdropEl.setAttribute('data-fallback-backdrop', '1');
      document.body.appendChild(backdropEl);

      modalEl.dispatchEvent(new Event('shown.bs.modal'));
    };

    const hide = () => {
      if (!modalEl.classList.contains('show')) return;
      modalEl.classList.remove('show');
      modalEl.setAttribute('aria-hidden', 'true');
      modalEl.removeAttribute('aria-modal');
      modalEl.style.display = 'none';
      if (backdropEl && backdropEl.parentNode) {
        backdropEl.parentNode.removeChild(backdropEl);
      }
      backdropEl = null;

      if (!document.querySelector('.modal.show')) {
        document.body.classList.remove('modal-open');
        document.body.style.overflow = '';
      }
      modalEl.dispatchEvent(new Event('hidden.bs.modal'));
    };

    modalEl.addEventListener('click', (event) => {
      if (event.target === modalEl) hide();
    });
    modalEl.querySelectorAll('[data-bs-dismiss="modal"]').forEach((btn) => {
      btn.addEventListener('click', (event) => {
        event.preventDefault();
        hide();
      });
    });

    return { show, hide };
  }

  const addEnrollmentModal = createModalController(addEnrollmentModalEl);
  const closeModal = createModalController(closeModalEl);
  const reentryModal = createModalController(reentryModalEl);
  const editModal = createModalController(editModalEl);
  const chargeModal = createModalController(chargeModalEl);
  const programShortcutModal = createModalController(programShortcutModalEl);
  const priorCreditRepairModal = createModalController(priorCreditRepairModalEl);
  const enrollmentSessionListModal = createModalController(enrollmentSessionListModalEl);
  const addButton = qs('btn_addPeriod');

  function formatResolvedRegistrationLabel(resolved = {}) {
    const label = String(resolved?.label || '').trim();
    const regDate = String(resolved?.registrationDate || '').trim();
    if (!label) return '';
    if (!regDate) return htmlEscape(label);
    return htmlEscape(`${label} (${regDate})`);
  }

  function setRollingRegistrationPanelHtml(html) {
    const panel = qs('roll_enrollmentRegistrationPanel');
    if (panel) panel.innerHTML = html;
  }

  function isMissingProgramRegistrationMessage(message) {
    const text = String(message || '').toLowerCase();
    return text.includes('no active program registration') || text.includes('register the student in a program listed under this class');
  }

  function isMissingTermRegistrationMessage(message) {
    const text = String(message || '').toLowerCase();
    return text.includes('required term registration is missing') || text.includes('register the student in the required term');
  }

  function renderTermRegistrationShortcutPanel(message) {
    const student = getSelectedShortcutStudent();
    const params = new URLSearchParams();
    if (student.id) params.set('studentId', student.id);
    params.set('returnTo', window.location.pathname);
    setRollingRegistrationPanelHtml(
      '<div class="text-danger small mb-2">' + htmlEscape(message || 'Required term registration is missing.') + '</div>' +
      '<a class="btn btn-sm btn-outline-primary" target="_blank" rel="noopener" href="/school/programs/register-terms-batch-wizard?' + htmlEscape(params.toString()) + '">' +
        '<i class="bi bi-box-arrow-up-right me-1"></i>Go To Term Registration' +
      '</a>' +
      '<span class="small text-muted ms-2">Finalize the term registration, then click Retry Enrollment here.</span>'
    );
  }

  function getSelectedShortcutStudent() {
    const studentId = String(qs('inp_studentId')?.value || '').trim();
    const typedLabel = String(qs('inp_studentLabel')?.value || '').trim();
    const student = studentMap.get(studentId) || {};
    return {
      id: studentId,
      label: typedLabel || String(student.label || student.name || studentId || '').trim()
    };
  }

  function isCapacityWarningText(value) {
    return String(value || '').trim().toLowerCase().includes('enrollment is at capacity');
  }

  function renderClassCapacityWarningPanel(capacity) {
    const max = Number(capacity?.max || 0);
    const enrolled = Number(capacity?.enrolled || 0);
    if (!(capacity?.isAtCapacity === true && max > 0)) return '';
    const message = 'Enrollment is at capacity: ' + enrolled + ' of ' + max + ' open enrollment slot(s) are already used for this class. Increase Max Student Capacity to enroll more students.';
    return [
      '<div class="d-flex flex-wrap align-items-center gap-2 mt-1">',
      '<span class="text-warning small">' + htmlEscape(message) + '</span>',
      '<a class="btn btn-sm btn-outline-warning" href="/school/classes/edit/' + encodeURIComponent(classId) + '#inp_capacity" target="_blank" rel="noopener">',
      '<i class="bi bi-pencil-square me-1"></i>Edit Capacity',
      '</a>',
      '</div>'
    ].join('');
  }

  function renderProgramRegistrationShortcutPanel(message) {
    const issue = htmlEscape(message || 'This student needs an approved program registration before Rolling Enrollment can continue.');
    if (!canCreateProgramRegistrations) {
      setRollingRegistrationPanelHtml(
        '<div class="text-danger small mb-2">' + issue + '</div>' +
        '<div class="alert alert-warning border py-2 mb-0 small">You need Program Registration create access to register and finalize the student from here.</div>'
      );
      return;
    }
    const choices = Array.isArray(enrollmentProgramChoices) ? enrollmentProgramChoices : [];
    const choiceText = choices.length === 1
      ? 'The class has 1 allowed program available for this shortcut.'
      : 'The class has ' + choices.length + ' allowed programs available for this shortcut.';
    setRollingRegistrationPanelHtml(
      '<div class="text-danger small mb-2">' + issue + '</div>' +
      '<div class="d-flex flex-wrap align-items-center gap-2">' +
        '<button type="button" class="btn btn-sm btn-primary" id="btn_openProgramRegistrationShortcut">' +
          '<i class="bi bi-journal-plus me-1"></i>Register Student In Program' +
        '</button>' +
        '<span class="small text-muted">' + htmlEscape(choiceText) + '</span>' +
      '</div>'
    );
  }

  function getPriorRepairPrerequisite() {
    const prereq = lastRollingEligibility?.prerequisite || {};
    return {
      missingSubjects: Array.isArray(prereq.missingSubjects) ? prereq.missingSubjects : [],
      programId: String(prereq.repairProgramId || lastRollingEligibility?.resolved?.programId || '').trim(),
      programLabel: String(lastRollingEligibility?.resolved?.label || prereq.repairProgramId || lastRollingEligibility?.resolved?.programId || '').trim()
    };
  }

  function renderPriorCreditRepairPanel(message) {
    const repair = getPriorRepairPrerequisite();
    const issue = (Array.isArray(lastRollingEligibility?.prerequisite?.issues) && lastRollingEligibility.prerequisite.issues.length)
      ? lastRollingEligibility.prerequisite.issues.map((item) => htmlEscape(item)).join('<br>')
      : htmlEscape(message || 'Prerequisites are not satisfied for this class.');
    if (!repair.missingSubjects.length) {
      setRollingRegistrationPanelHtml('<div class="text-danger small">' + issue + '</div>');
      return;
    }
    if (!canCreatePriorSubjectCredits || lastRollingEligibility?.prerequisite?.canCreatePriorCredits === false) {
      setRollingRegistrationPanelHtml(
        '<div class="text-danger small mb-2">' + issue + '</div>' +
        '<div class="alert alert-warning border py-2 mb-0 small">You need Prior Subject Credits create access to add prerequisite credits from here.</div>'
      );
      return;
    }
    setRollingRegistrationPanelHtml(
      '<div class="text-danger small mb-2">' + issue + '</div>' +
      '<div class="d-flex flex-wrap align-items-center gap-2">' +
        '<button type="button" class="btn btn-sm btn-warning" id="btn_openPriorCreditRepair">' +
          '<i class="bi bi-mortarboard me-1"></i>Fix Prerequisites / Add Prior Credits' +
        '</button>' +
        '<span class="small text-muted">' + htmlEscape(String(repair.missingSubjects.length)) + ' suggested prerequisite credit' + (repair.missingSubjects.length === 1 ? '' : 's') + '.</span>' +
      '</div>'
    );
  }

  function renderPriorRepairSubjectList(subjects) {
    const box = qs('priorRepair_subjectList');
    if (!box) return;
    const list = Array.isArray(subjects) ? subjects : [];
    if (!list.length) {
      box.innerHTML = '<div class="text-muted">No missing prerequisite subjects were found in the latest eligibility result.</div>';
      return;
    }
    box.innerHTML = list.map((subject, index) => {
      const id = String(subject?.id || '').trim();
      return ''
        + '<label class="d-flex align-items-start gap-2 border rounded bg-white p-2 mb-2">'
        +   '<input type="checkbox" class="form-check-input mt-1 prior-repair-subject" value="' + htmlEscape(id) + '" checked>'
        +   '<span class="flex-grow-1">'
        +     '<span class="fw-semibold d-block">' + htmlEscape(subject?.label || id) + '</span>'
        +     '<span class="small text-muted">' + htmlEscape(subject?.reason || 'Required prerequisite') + '</span>'
        +   '</span>'
        + '</label>';
    }).join('');
  }

  async function openPriorCreditRepairModal() {
    const student = getSelectedShortcutStudent();
    const repair = getPriorRepairPrerequisite();
    if (!student.id) {
      await showMsg('Select Student', 'warning', 'Select a student first.');
      return;
    }
    if (!repair.programId) {
      await showMsg('Program Required', 'warning', 'Resolve the program registration before adding prior subject credits.');
      return;
    }
    if (!repair.missingSubjects.length) {
      await showMsg('No Suggestions', 'info', 'No missing prerequisite subjects were found in the latest eligibility result.');
      return;
    }
    if (qs('priorRepair_studentLabel')) qs('priorRepair_studentLabel').value = student.label || student.id || '';
    if (qs('priorRepair_programLabel')) qs('priorRepair_programLabel').value = repair.programLabel || repair.programId || '';
    if (qs('priorRepair_source')) qs('priorRepair_source').value = 'manual_waiver';
    if (qs('priorRepair_evidenceNote')) qs('priorRepair_evidenceNote').value = 'Added from Rolling Enrollment prerequisite repair';
    renderPriorRepairSubjectList(repair.missingSubjects);
    priorCreditRepairModal?.show();
  }

  function getSelectedPriorRepairSubjectIds() {
    return Array.from(document.querySelectorAll('.prior-repair-subject:checked'))
      .map((input) => String(input.value || '').trim())
      .filter(Boolean);
  }

  async function savePriorCreditRepair() {
    if (shortcutActionInProgress) return;
    const student = getSelectedShortcutStudent();
    const repair = getPriorRepairPrerequisite();
    const subjectIds = getSelectedPriorRepairSubjectIds();
    if (!student.id || !repair.programId) {
      await showMsg('Missing Context', 'warning', 'Student and program are required before adding prior credits.');
      return;
    }
    if (!subjectIds.length) {
      await showMsg('Select Subjects', 'warning', 'Select at least one suggested prerequisite subject.');
      return;
    }
    shortcutActionInProgress = true;
    try {
      showBusy('Saving prior subject credits...');
      const result = await requestJson('/school/classes/api/' + encodeURIComponent(classId) + '/rolling-prior-subject-credits/batch', 'POST', {
        studentId: student.id,
        studentIds: [student.id],
        programId: repair.programId,
        subjectIds,
        source: String(qs('priorRepair_source')?.value || 'manual_waiver').trim(),
        evidenceNote: String(qs('priorRepair_evidenceNote')?.value || '').trim()
      });
      if (!result) return;
      const errorList = Array.isArray(result.errors) ? result.errors : [];
      const createdCount = Number(result.createdCount || 0);
      const skippedCount = Number(result.skippedDuplicateCount || 0);
      const statusIcon = errorList.length ? 'warning' : 'success';
      const message = [
        `Created ${createdCount} prior subject credit${createdCount === 1 ? '' : 's'}.`,
        skippedCount ? `Skipped ${skippedCount} duplicate credit${skippedCount === 1 ? '' : 's'}.` : '',
        errorList.length ? errorList.map((row) => `${row.subjectId || 'Subject'}: ${row.message || 'Save failed.'}`).join('<br>') : ''
      ].filter(Boolean).join('<br>');
      await showMsg('Prior Credits Saved', statusIcon, message || 'Prior subject credits were saved.');
      await refreshRollingEligibility();
    } catch (error) {
      await showMsg('Prior Credits Failed', 'error', error.message || 'Unable to save prior subject credits.');
    } finally {
      shortcutActionInProgress = false;
      hideBusy();
    }
  }

  function renderShortcutPreviewHtml(rows, message) {
    const list = Array.isArray(rows) ? rows : [];
    if (!list.length) {
      return '<div class="text-muted">' + htmlEscape(message || 'No preview rows returned.') + '</div>';
    }
    return list.map(function (row) {
      const issues = Array.isArray(row?.issues) ? row.issues : [];
      const status = String(row?.status || '').trim().toLowerCase();
      const badge = status === 'ready' || status === 'draft' || status === 'success'
        ? 'bg-success'
        : (status === 'warning' ? 'bg-warning text-dark' : 'bg-danger');
      return ''
        + '<div class="border rounded p-2 bg-white mb-2">'
        +   '<div class="d-flex justify-content-between gap-2">'
        +     '<div class="fw-semibold">' + htmlEscape(row?.studentName || row?.studentId || 'Student') + '</div>'
        +     '<span class="badge ' + badge + '">' + htmlEscape(status || '-') + '</span>'
        +   '</div>'
        +   '<div class="small text-muted">Fee Category: ' + htmlEscape(row?.feeCategory || '-') + ' | Account: <span class="font-monospace">' + htmlEscape(row?.studentAccountId || '-') + '</span></div>'
        +   '<div class="small text-muted">Total Fee: <span class="fw-semibold">' + htmlEscape(Number(row?.totalAmount || 0).toFixed(2)) + '</span> | Transactions: <span class="fw-semibold">' + htmlEscape(row?.transactionCount || 0) + '</span></div>'
        +   (issues.length ? '<div class="text-danger small mt-1">' + issues.map((issue) => htmlEscape(issue)).join('<br>') + '</div>' : '')
        +   (row?.message ? '<div class="small mt-1">' + htmlEscape(row.message) + '</div>' : '')
        + '</div>';
    }).join('');
  }

  function resetProgramRegistrationShortcutModal() {
    const student = getSelectedShortcutStudent();
    if (qs('shortcut_registrationId')) qs('shortcut_registrationId').value = '';
    if (qs('shortcut_studentLabel')) qs('shortcut_studentLabel').value = student.label || student.id || '';
    if (qs('shortcut_registrationDate')) {
      qs('shortcut_registrationDate').value = String(qs('inp_startDate')?.value || '').trim() || new Date().toISOString().slice(0, 10);
    }
    if (qs('shortcut_externalReference')) qs('shortcut_externalReference').value = '';
    if (qs('shortcut_note')) qs('shortcut_note').value = 'Created from Rolling Enrollment shortcut';
    const select = qs('shortcut_programId');
    if (select) {
      const options = (Array.isArray(enrollmentProgramChoices) ? enrollmentProgramChoices : []).map(function (choice) {
        return '<option value="' + htmlEscape(String(choice?.programId || '')) + '">' + htmlEscape(String(choice?.label || choice?.programId || 'Program')) + '</option>';
      });
      select.innerHTML = options.length ? options.join('') : '<option value="">No allowed programs</option>';
      select.disabled = options.length === 0;
    }
    if (qs('shortcut_previewPanel')) qs('shortcut_previewPanel').innerHTML = 'Choose a program and click Preview.';
    if (qs('btn_shortcutApprove')) qs('btn_shortcutApprove').disabled = true;
  }

  function getProgramShortcutPayload() {
    const student = getSelectedShortcutStudent();
    return {
      classId,
      programId: String(qs('shortcut_programId')?.value || '').trim(),
      studentIds: [student.id],
      effectiveDate: String(qs('shortcut_registrationDate')?.value || '').trim(),
      externalReference: String(qs('shortcut_externalReference')?.value || '').trim(),
      note: String(qs('shortcut_note')?.value || '').trim()
    };
  }

  async function openProgramRegistrationShortcutModal() {
    if (!canCreateProgramRegistrations) {
      await showMsg('Access Required', 'warning', 'You need Program Registration create access to register and finalize the student from here.');
      return;
    }
    const student = getSelectedShortcutStudent();
    if (!student.id) {
      await showMsg('Select Student', 'warning', 'Select a student first.');
      return;
    }
    resetProgramRegistrationShortcutModal();
    programShortcutModal?.show();
  }

  async function previewProgramRegistrationShortcut() {
    if (shortcutActionInProgress) return;
    const payload = getProgramShortcutPayload();
    if (!payload.programId || !payload.studentIds[0] || !payload.effectiveDate) {
      await showMsg('Missing Fields', 'warning', 'Student, allowed program, and registration date are required.');
      return;
    }
    const regDateIssue = validateCycleRegistrationDate(payload.effectiveDate);
    if (regDateIssue) {
      await showMsg('Date out of range', 'warning', regDateIssue);
      return;
    }
    shortcutActionInProgress = true;
    try {
      showBusy('Previewing program registration...');
      const result = await requestJson('/school/classes/api/' + encodeURIComponent(classId) + '/rolling-program-registration/preview', 'POST', payload);
      if (!result) return;
      const rows = Array.isArray(result.previews) ? result.previews : [];
      if (qs('shortcut_previewPanel')) qs('shortcut_previewPanel').innerHTML = renderShortcutPreviewHtml(rows, result.message);
    } catch (error) {
      await showMsg('Preview Failed', 'error', error.message || 'Unable to preview program registration.');
    } finally {
      shortcutActionInProgress = false;
      hideBusy();
    }
  }

  async function saveProgramRegistrationShortcutDraft() {
    if (shortcutActionInProgress) return;
    const payload = getProgramShortcutPayload();
    if (!payload.programId || !payload.studentIds[0] || !payload.effectiveDate) {
      await showMsg('Missing Fields', 'warning', 'Student, allowed program, and registration date are required.');
      return;
    }
    const regDateIssue = validateCycleRegistrationDate(payload.effectiveDate);
    if (regDateIssue) {
      await showMsg('Date out of range', 'warning', regDateIssue);
      return;
    }
    shortcutActionInProgress = true;
    try {
      showBusy('Saving program registration draft...');
      const result = await requestJson('/school/classes/api/' + encodeURIComponent(classId) + '/rolling-program-registration/apply', 'POST', payload);
      if (!result) return;
      const draft = (Array.isArray(result.results) ? result.results : []).find((row) => String(row?.status || '').toLowerCase() === 'draft');
      if (draft?.registrationId && qs('shortcut_registrationId')) {
        qs('shortcut_registrationId').value = String(draft.registrationId);
      }
      if (qs('shortcut_previewPanel')) qs('shortcut_previewPanel').innerHTML = renderShortcutPreviewHtml(result.results, result.message);
      if (qs('btn_shortcutApprove')) qs('btn_shortcutApprove').disabled = !draft?.registrationId;
      await showMsg('Draft Saved', result.status === 'warning' ? 'warning' : 'success', result.message || 'Program registration draft saved.');
    } catch (error) {
      await showMsg('Draft Failed', 'error', error.message || 'Unable to save program registration draft.');
    } finally {
      shortcutActionInProgress = false;
      hideBusy();
    }
  }

  async function approveProgramRegistrationShortcutDraft() {
    if (shortcutActionInProgress) return;
    const registrationId = String(qs('shortcut_registrationId')?.value || '').trim();
    if (!registrationId) {
      await showMsg('Missing Draft', 'warning', 'Save the draft before approving and finalizing it.');
      return;
    }
    let confirmed = true;
    if (typeof window.showMessageModal === 'function') {
      confirmed = (await window.showMessageModal({
        title: 'Approve Program Registration?',
        icon: 'warning',
        message: 'Approve and finalize this program registration now? This will post finance transactions and academic entries.',
        buttons: [
          { text: 'Cancel', class: 'btn-secondary' },
          { text: 'Approve & Finalize', class: 'btn-success' }
        ]
      })) === 'Approve & Finalize';
    }
    if (!confirmed) return;
    shortcutActionInProgress = true;
    try {
      showBusy('Approving program registration...');
      const result = await requestJson('/school/classes/api/' + encodeURIComponent(classId) + '/rolling-program-registration/approve/' + encodeURIComponent(registrationId), 'POST', {
        note: String(qs('shortcut_note')?.value || 'Approved from Rolling Enrollment shortcut').trim()
      });
      if (!result) return;
      await showMsg('Finalized', result.status === 'warning' ? 'warning' : 'success', result.message || 'Program registration finalized.');
      await refreshRollingEligibility();
    } catch (error) {
      await showMsg('Approval Failed', 'error', error.message || 'Unable to approve program registration.');
    } finally {
      shortcutActionInProgress = false;
      hideBusy();
    }
  }

  async function refreshRollingEligibility() {
    const panel = qs('roll_enrollmentRegistrationPanel');
    const sid = String(qs('inp_studentId')?.value || '').trim();
    const startDate = String(qs('inp_startDate')?.value || '').trim();
    lastRollingEligibility = null;
    if (!panel) return;
    if (!sid) {
      setRollingRegistrationPanelHtml('<span class="text-muted">Select a student to verify program registration and prerequisites.</span>');
      return;
    }
    setRollingRegistrationPanelHtml('<span class="text-muted"><span class="spinner-border spinner-border-sm me-1" role="status"></span>Checking registration…</span>');
    try {
      let url = '/school/classes/api/' + encodeURIComponent(classId) + '/rolling-eligibility?studentId=' + encodeURIComponent(sid);
      if (startDate) url += '&startDate=' + encodeURIComponent(startDate);
      const data = await requestJson(url, 'GET');
      if (!data) {
        setRollingRegistrationPanelHtml('<span class="text-danger">Unable to check eligibility.</span>');
        return;
      }
      lastRollingEligibility = data;
      if (data.prerequisite && !data.resolved) {
        const issues = (data.prerequisite.issues || []).map((t) => htmlEscape(t)).join('<br>');
        const msg = issues || htmlEscape(data.message || 'Not eligible for this class.');
        const rawIssueMessage = data.message || (data.prerequisite.issues || []).join(' ');
        if (isMissingTermRegistrationMessage(rawIssueMessage)) {
          renderTermRegistrationShortcutPanel(rawIssueMessage);
          return;
        }
        if (isMissingProgramRegistrationMessage(rawIssueMessage)) {
          renderProgramRegistrationShortcutPanel(rawIssueMessage);
          return;
        }
        setRollingRegistrationPanelHtml('<div class="text-danger small">' + msg + '</div>');
        return;
      }
      if (data.resolved && data.prerequisite) {
        const ok = data.eligible === true;
        const issues = (data.prerequisite.issues || []).map((t) => htmlEscape(t)).join('<br>');
        const capacityWarningHtml = renderClassCapacityWarningPanel(data.prerequisite.capacity || {});
        const otherWarnings = (data.prerequisite.warnings || [])
          .filter((text) => !isCapacityWarningText(text))
          .map((t) => htmlEscape(t))
          .join('<br>');
        if (!ok && Array.isArray(data.prerequisite.missingSubjects) && data.prerequisite.missingSubjects.length) {
          renderPriorCreditRepairPanel(data.message || (data.prerequisite.issues || []).join(' '));
          return;
        }
        let inner = '<div class="fw-semibold text-dark">' + formatResolvedRegistrationLabel(data.resolved) + '</div>';
        if (issues) inner += '<div class="text-danger small mt-1">' + issues + '</div>';
        if (capacityWarningHtml) inner += capacityWarningHtml;
        if (otherWarnings) inner += '<div class="text-warning small mt-1">' + otherWarnings + '</div>';
        if (ok && !issues) inner += '<div class="text-success small mt-1">Prerequisites satisfied for this start date.</div>';
        setRollingRegistrationPanelHtml(inner);
        return;
      }
      if (data.message) {
        if (isMissingTermRegistrationMessage(data.message)) {
          renderTermRegistrationShortcutPanel(data.message);
          return;
        }
        if (isMissingProgramRegistrationMessage(data.message)) {
          renderProgramRegistrationShortcutPanel(data.message);
          return;
        }
        setRollingRegistrationPanelHtml('<div class="text-danger small">' + htmlEscape(data.message) + '</div>');
      }
    } catch (err) {
      lastRollingEligibility = null;
      const message = err?.message || 'Check failed.';
      if (isMissingTermRegistrationMessage(message)) {
        renderTermRegistrationShortcutPanel(message);
        return;
      }
      if (isMissingProgramRegistrationMessage(message)) {
        renderProgramRegistrationShortcutPanel(message);
        return;
      }
      setRollingRegistrationPanelHtml('<div class="text-danger small">' + htmlEscape(message) + '</div>');
    }
  }

  async function openAddEnrollmentModal() {
    const opener = qs('btn_openAddEnrollmentModal');
    if (opener && opener.disabled) return;
    if (!Array.isArray(enrollmentProgramChoices) || !enrollmentProgramChoices.length) {
      await showMsg(
        'Programs not configured',
        'warning',
        'This class has no allowed programs. Add at least one program on the class Program / terms tab, then try again.'
      );
      return;
    }
    clearEntryDraft();
    applyTargetSessionCountUi();
    resetEnrollmentWizard();
    setRollingRegistrationPanelHtml('<span class="text-muted">Select a student to verify program registration and prerequisites.</span>');
    addEnrollmentModal?.show();
  }

  function isOpenStatus(status) {
    const s = String(status || '').trim().toLowerCase();
    return ['draft', 'planned', 'active'].includes(s);
  }

  function oneDayAfter(dateText) {
    const raw = String(dateText || '').trim();
    if (!raw || !/^\d{4}-\d{2}-\d{2}$/.test(raw)) return '';
    const d = new Date(raw + 'T00:00:00');
    if (Number.isNaN(d.getTime())) return '';
    d.setDate(d.getDate() + 1);
    return d.toISOString().slice(0, 10);
  }

  function htmlEscape(value) {
    return String(value == null ? '' : value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  let rollingBusyDepth = 0;
  let rollingBusyToken = null;

  function showBusy(message = 'Please wait...') {
    rollingBusyDepth += 1;
    if (typeof window.showLoading === 'function') {
      if (!rollingBusyToken) {
        rollingBusyToken = window.showLoading({
          title: 'Working...',
          note: String(message || 'Please wait...'),
          operation: 'Rolling Enrollment'
        });
      } else if (typeof window.updateLoading === 'function') {
        window.updateLoading({
          note: String(message || 'Please wait...'),
          operation: 'Rolling Enrollment'
        });
      }
    }
  }

  function hideBusy() {
    rollingBusyDepth = Math.max(0, rollingBusyDepth - 1);
    if (rollingBusyDepth > 0) return;

    try {
      if (typeof window.hideLoading === 'function') {
        if (rollingBusyToken) window.hideLoading(rollingBusyToken);
        else window.hideLoading();
      }
    } catch (_) {}
    rollingBusyToken = null;
  }

  async function showMsg(title, icon, message) {
    // Busy overlay is z-index 20050; message modal must appear on top.
    while (rollingBusyDepth > 0) hideBusy();
    if (typeof window.showMessageModal === 'function') {
      await window.showMessageModal({ title, icon, message });
      return;
    }
    console.log(title + ': ' + message);
  }

  /** @param {object|null|undefined} al */
  function academicLedgerHtmlNote(al) {
    if (!al || typeof al !== 'object') return '';
    if (al.status === 'posted') {
      return '<p class="small text-muted mb-0 mt-2">' + htmlEscape(al.message || 'Recorded on academic ledger.') + '</p>';
    }
    if (al.status === 'already_synced') {
      return '<p class="small text-muted mb-0 mt-2">' + htmlEscape(al.message || '') + '</p>';
    }
    if (al.status === 'skipped_no_program' || al.status === 'skipped_program_not_found' || al.status === 'skipped_missing_context' || al.status === 'error') {
      return '<p class="small mb-0 mt-2"><span class="text-warning-emphasis fw-semibold">Academic ledger:</span> '
        + htmlEscape(al.message || 'Not updated.')
        + ' Use <strong>Sync academic ledger</strong> in the row menu after setting <strong>Allowed program terms</strong> on the class.</p>';
    }
    return '';
  }

  function collectEnrollmentPayloadFromForm() {
    const payload = {
      classId,
      studentId: String(qs('inp_studentId')?.value || '').trim(),
      startDate: String(qs('inp_startDate')?.value || '').trim(),
      endDate: String(qs('inp_endDate')?.value || '').trim(),
      status: String(qs('inp_status')?.value || 'active').trim(),
      funderType: String(qs('inp_funderType')?.value || '').trim(),
      funderId: String(qs('inp_funderId')?.value || '').trim(),
      authorizationRef: String(qs('inp_authorizationRef')?.value || '').trim(),
      reasonStart: String(qs('inp_reasonStart')?.value || '').trim(),
      sessionCountPolicy: 'all_non_na',
      plannedNotApplicableSessionIds: Array.isArray(pendingPlannedNaSessionIds) ? pendingPlannedNaSessionIds.slice() : []
    };
    if (hasTargetSessionCount()) {
      payload.targetSessionCount = String(qs('inp_targetSessionCount')?.value || '').trim();
    }
    if (pendingStagedSessions.length) {
      payload.pendingStagedSessions = pendingStagedSessions.map((row) => ({ ...row }));
    }
    if (pendingGapBatch) {
      payload.pendingGapBatch = { ...pendingGapBatch };
    }
    if (pendingGapBatch?.extendCycleEndDate === true) {
      payload.extendCycleEndDate = true;
    }
    return payload;
  }

  function buildAlignmentRequestBody(overrides = {}) {
    const payload = collectEnrollmentPayloadFromForm();
    const body = {
      classId,
      studentId: payload.studentId,
      startDate: String(overrides.startDate ?? payload.startDate ?? '').trim(),
      endDate: String(overrides.endDate ?? payload.endDate ?? '').trim(),
      targetSessionCount: String(overrides.targetSessionCount ?? payload.targetSessionCount ?? '').trim()
    };
    if (pendingStagedSessions.length) {
      body.pendingStagedSessions = pendingStagedSessions.map((row) => ({ ...row }));
    } else if (pendingGapBatch) {
      body.pendingGapBatch = { ...pendingGapBatch };
    }
    if (pendingGapBatch?.extendCycleEndDate === true) {
      body.extendCycleEndDate = true;
    }
    return body;
  }

  function sessionScheduleKeyClient(session = {}) {
    return [
      String(session?.date || '').trim(),
      String(session?.startTime || session?.start || '').trim(),
      String(session?.endTime || session?.end || '').trim()
    ].join('|');
  }

  function getStagedSessionIdSet() {
    return new Set(
      (Array.isArray(pendingStagedSessions) ? pendingStagedSessions : [])
        .map((row) => String(row?.sessionId || '').trim())
        .filter(Boolean)
    );
  }

  function isStagedSessionRow(row = {}) {
    if (row?.isStaged === true) return true;
    const id = String(row?.sessionId || '').trim();
    return Boolean(id && getStagedSessionIdSet().has(id));
  }

  function buildGapModalSessionRows() {
    const stagedIds = getStagedSessionIdSet();
    const stagedKeys = new Set(
      (Array.isArray(pendingStagedSessions) ? pendingStagedSessions : []).map((row) => sessionScheduleKeyClient(row))
    );
    const baseRows = (Array.isArray(lastAlignmentResult?.sessions) ? lastAlignmentResult.sessions : [])
      .filter((row) => {
        const id = String(row?.sessionId || '').trim();
        if (id && stagedIds.has(id)) return false;
        if (stagedKeys.has(sessionScheduleKeyClient(row))) return false;
        return true;
      });
    const stagedRows = (Array.isArray(pendingStagedSessions) ? pendingStagedSessions : []).map((row) => ({
      sessionId: row.sessionId,
      date: row.date,
      startTime: row.startTime,
      endTime: row.endTime,
      status: row.status || 'scheduled',
      countable: true,
      isStaged: true
    }));
    return [...baseRows, ...stagedRows].sort((a, b) => {
      const keyA = `${a.date || ''}|${a.startTime || ''}|${a.endTime || ''}`;
      const keyB = `${b.date || ''}|${b.startTime || ''}|${b.endTime || ''}`;
      return keyA.localeCompare(keyB);
    });
  }

  function clearPendingGapBatch({ clearFormDraft = true } = {}) {
    pendingGapBatch = null;
    pendingGapPreview = null;
    pendingStagedSessions = [];
    if (clearFormDraft) gapFormDraft = null;
    updateGapStagedBadge();
    renderGapSessionTable();
  }

  function captureGapFormDraft() {
    gapFormDraft = {
      startDate: String(qs('gap_batchStart')?.value || '').trim(),
      endDate: String(qs('gap_batchEnd')?.value || '').trim(),
      startTime: String(qs('gap_batchStartTime')?.value || '').trim(),
      endTime: String(qs('gap_batchEndTime')?.value || '').trim(),
      daysOfWeek: Array.from(document.querySelectorAll('.gap-day-cb:checked')).map((input) => Number(input.value)),
      teacherId: String(qs('gap_teacherId')?.value || '').trim(),
      teacherName: String(qs('gap_teacherName')?.value || '').trim(),
      room: String(qs('gap_room')?.value || '').trim(),
      exceptions: String(qs('gap_exceptions')?.value || '').trim(),
      skipHolidays: Boolean(qs('gap_skipHolidays')?.checked)
    };
  }

  function applyGapFormDraft(draft = {}) {
    if (!draft || typeof draft !== 'object') return;
    if (qs('gap_batchStart')) qs('gap_batchStart').value = String(draft.startDate || '').trim();
    if (qs('gap_batchEnd')) qs('gap_batchEnd').value = String(draft.endDate || '').trim();
    if (qs('gap_batchStartTime')) qs('gap_batchStartTime').value = String(draft.startTime || '').trim();
    if (qs('gap_batchEndTime')) qs('gap_batchEndTime').value = String(draft.endTime || '').trim();
    if (qs('gap_room')) qs('gap_room').value = String(draft.room || '').trim();
    if (qs('gap_teacherId')) qs('gap_teacherId').value = String(draft.teacherId || '').trim();
    if (qs('gap_teacherName')) qs('gap_teacherName').value = String(draft.teacherName || '').trim();
    if (qs('gap_exceptions')) qs('gap_exceptions').value = String(draft.exceptions || '').trim();
    if (qs('gap_skipHolidays')) qs('gap_skipHolidays').checked = draft.skipHolidays === true;
    const selected = new Set((Array.isArray(draft.daysOfWeek) ? draft.daysOfWeek : []).map((row) => String(row)));
    document.querySelectorAll('.gap-day-cb').forEach((input) => {
      input.checked = selected.has(String(input.value));
    });
    updateGapCycleExtendWarning();
  }

  function scheduleGapFormDraftCapture() {
    if (gapFormDraftTimer) clearTimeout(gapFormDraftTimer);
    gapFormDraftTimer = setTimeout(() => {
      gapFormDraftTimer = null;
      captureGapFormDraft();
    }, 200);
  }

  function appendUniqueStagedSessions(proposed = []) {
    const rows = Array.isArray(proposed) ? proposed : [];
    if (!rows.length) return 0;
    const existingKeys = new Set((pendingStagedSessions || []).map((row) => sessionScheduleKeyClient(row)));
    const existingIds = getStagedSessionIdSet();
    let added = 0;
    rows.forEach((row) => {
      const key = sessionScheduleKeyClient(row);
      const id = String(row?.sessionId || '').trim();
      if (existingKeys.has(key) || (id && existingIds.has(id))) return;
      pendingStagedSessions.push({ ...row });
      existingKeys.add(key);
      if (id) existingIds.add(id);
      added += 1;
    });
    pendingGapPreview = {
      createdCount: pendingStagedSessions.length,
      proposedSessions: pendingStagedSessions.slice()
    };
    return added;
  }

  async function refreshAlignmentWithStagedSessions() {
    const alignment = await fetchEnrollmentSessionAlignment(buildAlignmentRequestBody());
    if (alignment) {
      lastAlignmentResult = alignment;
      updateSessionCountHint(alignment);
      if (hasTargetSessionCount() && alignment.alignmentStatus !== 'insufficient_sessions') {
        const targetInput = qs('inp_targetSessionCount');
        if (targetInput && !String(targetInput.dataset.userEdited || '').trim()) {
          targetInput.value = String(alignment.availableCount || '');
        }
      }
    }
    renderGapSessionTable();
    updateGapStagedBadge();
    syncEnrollmentWizardPrimaryButton();
    return alignment;
  }

  async function removeStagedSession(sessionId) {
    const id = String(sessionId || '').trim();
    if (!id) return;
    pendingStagedSessions = (Array.isArray(pendingStagedSessions) ? pendingStagedSessions : [])
      .filter((row) => String(row?.sessionId || '').trim() !== id);
    if (!pendingStagedSessions.length) {
      pendingGapBatch = null;
      pendingGapPreview = null;
    } else {
      pendingGapPreview = {
        createdCount: pendingStagedSessions.length,
        proposedSessions: pendingStagedSessions.slice()
      };
    }
    updateGapStagedBadge();
    await refreshAlignmentWithStagedSessions();
    syncEnrollmentWizardPrimaryButton();
  }

  function updateGapStagedBadge() {
    const badge = qs('gapStagedBadge');
    const clearBtn = qs('btn_gapClearStaged');
    const count = Number(
      pendingStagedSessions.length
      || pendingGapPreview?.createdCount
      || pendingGapPreview?.proposedSessions?.length
      || 0
    );
    if (!badge) return;
    if (!count) {
      badge.classList.add('d-none');
      badge.innerHTML = '';
      clearBtn?.classList.add('d-none');
      return;
    }
    badge.classList.remove('d-none');
    badge.innerHTML = `<b>${count} session(s) staged (not saved yet).</b> They will be added to the class schedule when enrollment completes successfully.`;
    clearBtn?.classList.remove('d-none');
  }

  async function showSessionConflictModal(conflicts = []) {
    const rows = Array.isArray(conflicts) ? conflicts : [];
    if (!rows.length) return false;
    let msg = `<b>Found ${rows.length} scheduling conflict(s)!</b><br><br><ul class="text-start mb-0">`;
    rows.slice(0, 5).forEach((c) => {
      msg += `<li><b>${htmlEscape(c.date || '')}</b>: ${htmlEscape(c.teacherName || '')} overlaps <i>${htmlEscape(c.conflictClass || '')}</i> (${htmlEscape(c.existTime || '')})</li>`;
    });
    if (rows.length > 5) msg += `<li>...and ${rows.length - 5} more.</li>`;
    msg += '</ul><br>Resolve conflicts before staging sessions or enrolling.';
    if (typeof window.showMessageModal === 'function') {
      await window.showMessageModal({ title: 'Scheduling Conflicts', icon: 'error', message: msg, buttons: [{ text: 'OK', class: 'btn-primary', value: true }] });
    } else {
      window.alert(msg.replace(/<[^>]+>/g, ' '));
    }
    return true;
  }

  function buildGapBatchBody() {
    const daysOfWeek = Array.from(document.querySelectorAll('.gap-day-cb:checked')).map((input) => Number(input.value));
    return {
      ...buildAlignmentRequestBody(),
      startDate: String(qs('gap_batchStart')?.value || '').trim(),
      endDate: String(qs('gap_batchEnd')?.value || '').trim(),
      startTime: String(qs('gap_batchStartTime')?.value || '').trim(),
      endTime: String(qs('gap_batchEndTime')?.value || '').trim(),
      daysOfWeek,
      skipExistingDates: true,
      teacherId: String(qs('gap_teacherId')?.value || '').trim(),
      teacherName: String(qs('gap_teacherName')?.value || '').trim(),
      room: String(qs('gap_room')?.value || '').trim()
    };
  }

  async function fetchEnrollmentSessionAlignment(body = {}) {
    const result = await requestJson(`/school/classes/api/${encodeURIComponent(classId)}/enrollment-session-alignment`, 'POST', body);
    return result?.data || null;
  }

  function updateViewSessionsButton(alignment) {
    const btn = qs('btn_viewEnrollmentSessions');
    if (!btn) return;
    const endDate = String(qs('inp_endDate')?.value || '').trim();
    const count = Number(alignment?.availableCount || 0);
    const sessions = Array.isArray(alignment?.sessions) ? alignment.sessions : [];
    const show = Boolean(endDate && count > 0 && sessions.length);
    btn.classList.toggle('d-none', !show);
  }

  function openEnrollmentSessionListModal() {
    const rows = pendingStagedSessions.length
      ? buildGapModalSessionRows()
      : (lastAlignmentResult?.sessions || []);
    renderSessionWindowTable(rows, 'enrollmentSessionListTbody', { highlightStaged: true });
    enrollmentSessionListModal?.show();
  }

  function updateSessionCountHint(alignment) {
    const hint = qs('hint_sessionAlignment');
    if (!hint) return;
    const targetSet = hasTargetSessionCount();
    if (!alignment || alignment.alignmentStatus === 'no_end_date') {
      hint.className = 'form-text compact-help text-muted mb-0';
      hint.textContent = targetSet
        ? 'Set start and end dates to count available sessions.'
        : 'Set an end date to see how many countable sessions fall in the enrollment window.';
      updateViewSessionsButton(null);
      syncEnrollmentWizardPrimaryButton();
      return;
    }
    const available = Number(alignment.availableCount || 0);
    if (!targetSet) {
      hint.className = 'form-text compact-help text-muted mb-0';
      hint.textContent = `${available} countable session(s) in this window.`;
      updateViewSessionsButton(alignment);
      syncEnrollmentWizardPrimaryButton();
      return;
    }
    const target = Number(alignment.targetSessionCount || alignment.effectiveTarget || 0);
    if (alignment.alignmentStatus === 'insufficient_sessions') {
      hint.className = 'form-text compact-help text-danger mb-0';
      hint.textContent = `Only ${available} countable session(s) in this window${target ? `; need ${target}` : ''}. Use Next to add sessions.`;
      updateViewSessionsButton(alignment);
      syncEnrollmentWizardPrimaryButton();
      return;
    }
    if (alignment.alignmentStatus === 'overage_requires_na') {
      hint.className = 'form-text compact-help text-warning mb-0';
      hint.textContent = `${available} countable sessions in window. Use Next to select ${alignment.requiredNaCount} as N/A for ${target}.`;
      updateViewSessionsButton(alignment);
      syncEnrollmentWizardPrimaryButton();
      return;
    }
    hint.className = 'form-text compact-help text-success mb-0';
    hint.textContent = `${available} countable session(s) in this window.`;
    updateViewSessionsButton(alignment);
    syncEnrollmentWizardPrimaryButton();
  }

  function getEnrollmentWizardStepMeta() {
    if (enrollWizardPath === 'planA') {
      return [
        { id: 'form', label: 'Enrollment' },
        { id: 'addSessions', label: 'Sessions' },
        { id: 'conflicts', label: 'Conflicts' }
      ];
    }
    if (enrollWizardPath === 'planB') {
      return [
        { id: 'form', label: 'Enrollment' },
        { id: 'markNa', label: 'Mark N/A' }
      ];
    }
    return [{ id: 'form', label: 'Enrollment' }];
  }

  function renderEnrollmentWizardStepIndicator() {
    const host = qs('enrollWizardStepIndicator');
    const pillHost = qs('enrollWizardStepPills');
    if (!host || !pillHost) return;
    const steps = getEnrollmentWizardStepMeta();
    if (steps.length <= 1) {
      host.classList.add('d-none');
      host.setAttribute('aria-hidden', 'true');
      pillHost.innerHTML = '';
      return;
    }
    host.classList.remove('d-none');
    host.setAttribute('aria-hidden', 'false');
    const activeIdx = Math.max(0, steps.findIndex((row) => row.id === enrollWizardStep));
    const progress = ((activeIdx + 1) / steps.length) * 100;
    const badge = qs('enrollWizardStepBadge');
    const progressPct = qs('enrollWizardProgressPct');
    const progressBar = qs('enrollWizardProgressBar');
    if (badge) badge.textContent = `Step ${activeIdx + 1} of ${steps.length}`;
    if (progressPct) progressPct.textContent = `${Math.round(progress)}%`;
    if (progressBar) progressBar.style.width = `${progress.toFixed(2)}%`;
    pillHost.innerHTML = steps.map((step, idx) => {
      const stateClass = idx === activeIdx ? 'active' : (idx < activeIdx ? 'completed' : '');
      return `<button type="button" class="wizard-step-pill ${stateClass}" tabindex="-1" aria-disabled="true">${idx + 1}. ${htmlEscape(step.label)}</button>`;
    }).join('');
    if (window.WizardStepRail) window.WizardStepRail.sync(pillHost);
  }

  function setEnrollmentWizardStepVisibility() {
    qs('enrollWizardStepForm')?.classList.toggle('d-none', enrollWizardStep !== 'form');
    qs('enrollWizardStepAddSessions')?.classList.toggle('d-none', enrollWizardStep !== 'addSessions');
    qs('enrollWizardStepMarkNa')?.classList.toggle('d-none', enrollWizardStep !== 'markNa');
    qs('enrollWizardStepConflicts')?.classList.toggle('d-none', enrollWizardStep !== 'conflicts');
    qs('btn_enrollWizardBack')?.classList.toggle('d-none', enrollWizardStep === 'form');
    renderEnrollmentWizardStepIndicator();
    syncEnrollmentWizardPrimaryButton();
  }

  function syncEnrollmentWizardPrimaryButton() {
    const btn = qs('btn_addPeriod');
    if (!btn) return;
    const iconPlus = '<i class="bi bi-plus-circle me-1"></i>';
    const iconNext = '<i class="bi bi-arrow-right me-1"></i>';
    if (enrollWizardStep === 'form') {
      const status = String(lastAlignmentResult?.alignmentStatus || '');
      const needsNext = hasTargetSessionCount()
        && (status === 'insufficient_sessions' || status === 'overage_requires_na');
      btn.innerHTML = needsNext ? `${iconNext}Next` : `${iconPlus}Add Enrollment Period`;
      if (isRollingClass()) btn.disabled = false;
      return;
    }
    if (enrollWizardStep === 'addSessions') {
      const ok = String(lastAlignmentResult?.alignmentStatus || '') === 'ok'
        && pendingStagedSessions.length > 0;
      btn.innerHTML = `${iconNext}Next`;
      btn.disabled = !ok;
      return;
    }
    if (enrollWizardStep === 'markNa') {
      const required = Number(lastAlignmentResult?.requiredNaCount || 0);
      const selected = readSelectedNaSessionIds().length;
      btn.innerHTML = `${iconPlus}Add Enrollment Period`;
      btn.disabled = required <= 0 || selected !== required;
      return;
    }
    if (enrollWizardStep === 'conflicts') {
      btn.innerHTML = `${iconPlus}Add Enrollment Period`;
      btn.disabled = conflictReviewHasConflicts === true;
    }
  }

  function isRollingClass() {
    return <%= JSON.stringify(Boolean(isRolling)) %>;
  }

  function resetEnrollmentWizard() {
    enrollWizardStep = 'form';
    enrollWizardPath = null;
    lastConflictReview = null;
    conflictReviewHasConflicts = false;
    setEnrollmentWizardStepVisibility();
  }

  function prepareAddSessionsStep(alignment) {
    lastAlignmentResult = alignment || lastAlignmentResult;
    const need = Number(alignment?.effectiveTarget || alignment?.targetSessionCount || 0);
    const available = Number(alignment?.availableCount || 0);
    const summary = qs('gapSummaryText');
    if (summary) {
      summary.textContent = `Need ${need || 'at least 1'} countable session(s) between ${alignment?.startDate || ''} and ${alignment?.endDate || ''}, but only ${available} exist. Stage missing sessions below or reduce Number of Sessions.`;
    }
    if (gapFormDraft) {
      applyGapFormDraft(gapFormDraft);
    } else {
      applyScheduleDefaultsToGapForm(alignment?.scheduleDefaults || {});
    }
    renderGapSessionTable();
    updateGapCycleExtendWarning();
    updateGapStagedBadge();
  }

  function prepareMarkNaStep(alignment) {
    lastAlignmentResult = alignment || lastAlignmentResult;
    const required = Number(alignment?.requiredNaCount || 0);
    const target = Number(alignment?.targetSessionCount || alignment?.effectiveTarget || 0);
    const available = Number(alignment?.availableCount || 0);
    const summary = qs('naSummaryText');
    if (summary) {
      summary.textContent = `This enrollment uses ${target} session(s), but ${available} countable sessions exist in the window. Select exactly ${required} session(s) to mark N/A (they will not count toward enrollment).`;
    }
    const preselected = pendingPlannedNaSessionIds.length === required
      ? pendingPlannedNaSessionIds.slice()
      : [];
    renderNaSessionTable(alignment?.countableSessions || [], preselected);
  }

  function renderConflictReview(review = {}) {
    lastConflictReview = review || null;
    conflictReviewHasConflicts = review?.hasConflicts === true;
    const readyPanel = qs('conflictReviewReadyPanel');
    const conflictPanel = qs('conflictReviewConflictPanel');
    readyPanel?.classList.toggle('d-none', conflictReviewHasConflicts);
    conflictPanel?.classList.toggle('d-none', !conflictReviewHasConflicts);

    const host = qs('conflictReviewStudentsHost');
    const students = (Array.isArray(review?.students) ? review.students : [])
      .filter((student) => student?.hasConflicts === true);
    if (host) {
      if (!conflictReviewHasConflicts) {
        host.innerHTML = '';
      } else if (!students.length) {
        host.innerHTML = '';
      } else {
        host.innerHTML = students.map((student) => {
          const roleLabel = student.role === 'enrolling' ? 'Enrolling' : 'Enrolled';
          const windowLabel = `${student.windowStart || '?'} → ${student.windowEnd || 'Open'}`;
          const conflictSessions = (Array.isArray(student.sessions) ? student.sessions : [])
            .filter((session) => session?.hasConflict === true);
          const rows = conflictSessions.length
            ? conflictSessions.map((session) => `<tr class="conflict-session-row">
                <td>${htmlEscape(session.date || '-')}</td>
                <td>${htmlEscape([session.startTime, session.endTime].filter(Boolean).join(' - ') || '-')}</td>
                <td><span class="badge bg-danger-subtle text-danger border">Conflict</span> ${htmlEscape(session.conflictDetail || '')}</td>
              </tr>`).join('')
            : '<tr><td colspan="3" class="text-center text-muted py-2">No conflicting sessions found.</td></tr>';
          return `<div class="mb-3">
            <div class="fw-semibold mb-1">${htmlEscape(student.displayName || student.studentId || '')}
              <span class="badge bg-secondary-subtle text-secondary border ms-1">${roleLabel}</span>
              <span class="text-muted small ms-2">${htmlEscape(windowLabel)}</span>
            </div>
            <div class="table-responsive border rounded">
              <table class="table table-sm align-middle mb-0">
                <thead class="table-light"><tr><th>Date</th><th>Time</th><th>Conflict</th></tr></thead>
                <tbody>${rows}</tbody>
              </table>
            </div>
          </div>`;
        }).join('');
      }
    }

    const teacherSection = qs('conflictReviewTeacherSection');
    const teacherBody = qs('conflictReviewTeacherTbody');
    const teacherConflicts = Array.isArray(review?.teacherConflicts) ? review.teacherConflicts : [];
    teacherSection?.classList.toggle('d-none', !teacherConflicts.length);
    if (teacherBody && teacherConflicts.length) {
      teacherBody.innerHTML = teacherConflicts.map((row) => `<tr class="conflict-session-row">
          <td>${htmlEscape(row.date || '-')}</td>
          <td>${htmlEscape(row.teacherName || '-')}</td>
          <td>${htmlEscape(row.conflictClass || '-')}</td>
          <td>${htmlEscape(row.existTime || '-')}</td>
          <td>${htmlEscape(row.conflictType || '-')}</td>
        </tr>`).join('');
    } else if (teacherBody) {
      teacherBody.innerHTML = '';
    }
    syncEnrollmentWizardPrimaryButton();
  }

  async function loadConflictReviewStep() {
    if (!pendingStagedSessions.length) {
      await showMsg('Sessions required', 'warning', 'Stage the missing sessions before reviewing conflicts.');
      return false;
    }
    try {
      showBusy('Checking session conflicts...');
      const payload = collectEnrollmentPayloadFromForm();
      const result = await requestJson(
        `/school/classes/api/${encodeURIComponent(classId)}/sessions/enrollment-gap-conflict-review`,
        'POST',
        {
          studentId: payload.studentId,
          startDate: payload.startDate,
          endDate: payload.endDate,
          pendingStagedSessions: pendingStagedSessions.map((row) => ({ ...row })),
          pendingGapBatch: pendingGapBatch ? { ...pendingGapBatch } : undefined,
          teacherId: String(qs('gap_teacherId')?.value || pendingGapBatch?.teacherId || '').trim()
        }
      );
      if (!result) return false;
      renderConflictReview(result.data || {});
      return true;
    } catch (error) {
      await showMsg('Conflict Review Failed', 'error', error.message || 'Unable to review conflicts.');
      return false;
    } finally {
      hideBusy();
    }
  }

  async function goEnrollmentWizardBack() {
    if (enrollWizardStep === 'conflicts') {
      captureGapFormDraft();
      enrollWizardStep = 'addSessions';
      setEnrollmentWizardStepVisibility();
      return;
    }
    if (enrollWizardStep === 'addSessions' || enrollWizardStep === 'markNa') {
      if (enrollWizardStep === 'addSessions') captureGapFormDraft();
      if (enrollWizardStep === 'markNa') {
        pendingPlannedNaSessionIds = readSelectedNaSessionIds();
      }
      enrollWizardStep = 'form';
      enrollWizardPath = null;
      setEnrollmentWizardStepVisibility();
      await runAlignmentRefresh({ showSpinner: false });
    }
  }

  async function ensureEnrollmentSessionAlignment() {
    if (!hasTargetSessionCount()) {
      return { ok: true, alignment: lastAlignmentResult, nextStep: null };
    }
    const alignment = await runAlignmentRefresh({ showSpinner: true });
    if (!alignment) return { ok: false, alignment: null, nextStep: null };
    const endDate = String(qs('inp_endDate')?.value || '').trim();
    const targetSessionCount = String(qs('inp_targetSessionCount')?.value || '').trim();
    if (!endDate || !targetSessionCount) {
      await showMsg('Session count required', 'warning', 'End date and Number of Sessions are required when you set a target session count.');
      return { ok: false, alignment, nextStep: null };
    }
    if (alignment.alignmentStatus === 'insufficient_sessions') {
      return { ok: false, alignment, nextStep: 'addSessions' };
    }
    if (alignment.alignmentStatus === 'overage_requires_na') {
      const required = Number(alignment.requiredNaCount || 0);
      if (pendingPlannedNaSessionIds.length !== required) {
        return { ok: false, alignment, nextStep: 'markNa' };
      }
    } else {
      pendingPlannedNaSessionIds = [];
    }
    return { ok: true, alignment, nextStep: null };
  }

