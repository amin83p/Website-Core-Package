      return `
        <tr>
          <td class="ps-4">
            <div class="fw-semibold">${htmlEscape(String(row?.studentLabel || studentMap.get(studentId)?.label || studentId || '-'))}</div>
            <div class="x-small text-muted font-monospace">${htmlEscape(studentId)}</div>
