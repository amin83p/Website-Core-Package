    }
  }

  async function removeOrRollbackPeriod(periodId) {
    const row = (Array.isArray(periodRows) ? periodRows : []).find((item) => String(item?.id || '') === String(periodId || ''));
    if (!row) return;
    const status = String(row?.status || '').trim().toLowerCase();
    const postedCount = Array.isArray(row?.transactionSummary?.postedTransactionIds)
      ? row.transactionSummary.postedTransactionIds.length
      : 0;
    const isRollback = status !== 'draft' && postedCount > 0;
    const actionLabel = isRollback ? 'Rollback Posted Enrollment' : 'Delete Draft Enrollment';
    const personLabel = String(row?.studentLabel || row?.studentId || periodId).trim();

    let confirmed = false;
    if (typeof window.showMessageModal === 'function') {
      const result = await window.showMessageModal({
        title: actionLabel,
        icon: isRollback ? 'warning' : 'question',
        message: isRollback
          ? `Rollback posted transactions for <b>${htmlEscape(personLabel)}</b>?`
          : `Delete draft enrollment for <b>${htmlEscape(personLabel)}</b> before posting?`,
        buttons: [
          { text: 'Cancel', class: 'btn-secondary' },
          { text: isRollback ? 'Rollback' : 'Delete', class: 'btn-danger' }
        ]
      });
      confirmed = result === (isRollback ? 'Rollback' : 'Delete');
    } else {
      confirmed = window.confirm(`${actionLabel} for ${personLabel}?`);
    }
    if (!confirmed) return;

    try {
      showBusy(isRollback ? 'Rolling back posted enrollment...' : 'Deleting draft enrollment...');
      const result = await requestJson(`/school/classes/api/enrollment-periods/${encodeURIComponent(periodId)}/remove`, 'POST', {});
      if (!result) return;
      await showMsg('Success', result.status === 'warning' ? 'warning' : 'success', result.message || 'Operation completed.');
      await loadRows();
    } catch (error) {
      await showMsg('Operation Failed', 'error', error.message || 'Unable to complete the operation.');
    } finally {
      hideBusy();
    }
  }

  function findWrapByPeriodId(periodId) {
    const want = String(periodId || '');
    const btns = document.querySelectorAll('.rolling-enrollment-page .rolling-row-actions-toggle');
    for (let i = 0; i < btns.length; i += 1) {
      const b = btns[i];
      if (String(b.getAttribute('data-period-id') || '') === want) {
        return b.closest('.rolling-row-actions-wrap');
      }
    }
    return null;
  }

  function dockRowActionsMenu(menu) {
    if (!menu || menu.parentElement !== document.body) return;
    const wrap = findWrapByPeriodId(menu.getAttribute('data-period-id'));
    if (wrap) wrap.appendChild(menu);
  }

  function resetFloatingMenuStyles(menu) {
    if (!menu) return;
    menu.classList.remove('rolling-row-actions-menu--floating');
    menu.style.left = '';
    menu.style.top = '';
    menu.style.right = '';
    menu.style.visibility = '';
    menu.style.position = '';
  }

  function placeFloatingRowMenu(menu, wrap) {
    if (!menu || !wrap) return;
    const rect = wrap.getBoundingClientRect();
    const zoomRaw = Number.parseFloat(document.body?.dataset?.appZoom || '');
    const zoom = Number.isFinite(zoomRaw) && zoomRaw > 0 ? zoomRaw : 1;
    const viewportWidth = window.innerWidth / zoom;
    const viewportHeight = window.innerHeight / zoom;
    const rectTop = rect.top / zoom;
    const rectRight = rect.right / zoom;
    const rectBottom = rect.bottom / zoom;
    menu.classList.add('rolling-row-actions-menu--floating');
    menu.style.visibility = 'hidden';
    menu.style.position = 'fixed';
    menu.style.left = '0';
    menu.style.top = '0';
    const mw = Math.max(menu.offsetWidth || 0, 148);
    const mh = menu.offsetHeight || 0;
    let left = rectRight - mw;
    left = Math.max(8, Math.min(left, viewportWidth - mw - 8));
    const gap = 4;
    let top = rectBottom + gap;
    if (mh > 0 && top + mh > viewportHeight - 8) {
      top = Math.max(8, rectTop - mh - gap);
    }
    if (mh > 0 && top + mh > viewportHeight - 8) {
      top = Math.max(8, viewportHeight - mh - 8);
    }
    if (mw > 0 && left + mw > viewportWidth - 8) {
      left = Math.max(8, viewportWidth - mw - 8);
    }
    menu.style.left = `${Math.round(left)}px`;
    menu.style.top = `${Math.round(top)}px`;
    menu.style.visibility = '';
  }

  function repositionOpenRowActionMenu() {
    const menu = document.querySelector('.rolling-row-actions-menu.rolling-row-actions-menu--floating:not(.d-none)');
    if (!menu) return;
    const wrap = findWrapByPeriodId(menu.getAttribute('data-period-id'));
    if (wrap) placeFloatingRowMenu(menu, wrap);
  }

  function closeAllActionMenus() {
    document.querySelectorAll('.rolling-row-actions-menu').forEach((menu) => {
      menu.classList.add('d-none');
      resetFloatingMenuStyles(menu);
      dockRowActionsMenu(menu);
    });
  }

  window.addEventListener('scroll', repositionOpenRowActionMenu, true);
  window.addEventListener('resize', repositionOpenRowActionMenu);
  document.querySelector('.rolling-enrollment-page .table-scroll-wrapper')?.addEventListener('scroll', repositionOpenRowActionMenu, { passive: true });

  document.addEventListener('click', (event) => {
    const toggleBtn = event.target.closest('.rolling-row-actions-toggle');
    if (toggleBtn) {
      const periodId = String(toggleBtn.getAttribute('data-period-id') || '').trim();
      const targetMenu = Array.from(document.querySelectorAll('.rolling-row-actions-menu'))
        .find((menu) => String(menu.getAttribute('data-period-id') || '').trim() === periodId);
      const willOpen = targetMenu ? targetMenu.classList.contains('d-none') : false;
      closeAllActionMenus();
      if (targetMenu && willOpen) {
        const wrap = toggleBtn.closest('.rolling-row-actions-wrap');
        targetMenu.classList.remove('d-none');
        document.body.appendChild(targetMenu);
        placeFloatingRowMenu(targetMenu, wrap);
        requestAnimationFrame(() => {
          requestAnimationFrame(repositionOpenRowActionMenu);
        });
      }
      return;
    }

    const programShortcutBtn = event.target.closest('#btn_openProgramRegistrationShortcut');
    if (programShortcutBtn) {
      event.preventDefault();
      openProgramRegistrationShortcutModal();
      return;
    }

    const priorCreditRepairBtn = event.target.closest('#btn_openPriorCreditRepair');
    if (priorCreditRepairBtn) {
      event.preventDefault();
      openPriorCreditRepairModal();
      return;
    }

    const editBtn = event.target.closest('.btn-row-edit');
    if (editBtn) {
      closeAllActionMenus();
      openEditModal(editBtn.getAttribute('data-period-id'));
      return;
    }

    const closeBtn = event.target.closest('.btn-row-close');
    if (closeBtn) {
      closeAllActionMenus();
      openCloseModal(closeBtn.getAttribute('data-period-id'));
      return;
    }

    const reviewBtn = event.target.closest('.btn-row-review-draft');
    if (reviewBtn) {
      closeAllActionMenus();
      openDraftReviewModal(reviewBtn.getAttribute('data-period-id'));
      return;
    }

    const syncLedgerBtn = event.target.closest('.btn-row-sync-ledger');
    if (syncLedgerBtn) {
      closeAllActionMenus();
      syncAcademicLedgerForPeriod(syncLedgerBtn.getAttribute('data-period-id'));
      return;
    }

    const removeBtn = event.target.closest('.btn-row-remove');
    if (removeBtn) {
      closeAllActionMenus();
      removeOrRollbackPeriod(removeBtn.getAttribute('data-period-id'));
      return;
    }

    const reentryBtn = event.target.closest('.btn-row-reentry');
    if (reentryBtn) {
      closeAllActionMenus();
      openReentryModal(reentryBtn.getAttribute('data-period-id'));
      return;
    }

    if (!event.target.closest('.rolling-row-actions-wrap') && !event.target.closest('.rolling-row-actions-menu')) {
      closeAllActionMenus();
    }
  });

