<%
  const c = classData || {};
  const lifecycle = lifecycleContext || {};
  const isRolling = String(c.registrationMode || '').trim().toLowerCase() === 'rolling';
  const cycleStartDate = String(lifecycle.cycleStartDate || c.cycleStartDate || '').trim();
  const cycleEndDate = String(lifecycle.cycleEndDate || c.cycleEndDate || '').trim();
  const isClosedForNewEnrollment = lifecycle.isClosedForNewEnrollment === true
    || c.isClosedForNewEnrollment === true
    || String(lifecycle.isClosedForNewEnrollment || c.isClosedForNewEnrollment || '').trim().toLowerCase() === 'true';
  const nextCycleClassId = String(lifecycle.nextClass?.id || c.nextClassId || '').trim();
  const nextCycleClassTitle = String(lifecycle.nextClass?.title || '').trim();
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
  const initialRowsJson = JSON.stringify(Array.isArray(periodRows) ? periodRows : []);
  const studentOptionsJson = JSON.stringify(Array.isArray(studentOptions) ? studentOptions : []);
  const enrollmentProgramChoicesJson = JSON.stringify(Array.isArray(enrollmentProgramChoices) ? enrollmentProgramChoices : []);
  const canCreateProgramRegistrationsJson = JSON.stringify(Boolean(typeof canCreateProgramRegistrations !== 'undefined' && canCreateProgramRegistrations));
  const canCreatePriorSubjectCreditsJson = JSON.stringify(Boolean(typeof canCreatePriorSubjectCredits !== 'undefined' && canCreatePriorSubjectCredits));
  const classInstructors = Array.isArray(c.instructors) ? c.instructors : [];
  const defaultInstructor = classInstructors.find((row) => String(row?.status || '').trim().toLowerCase() === 'active') || classInstructors[0] || null;
  const defaultTeacherJson = JSON.stringify({
    teacherId: String(defaultInstructor?.personId || '').trim(),
    teacherName: String(defaultInstructor?.name || '').trim()
  });
%>

<style>
  .rolling-enrollment-page .card-body {
    padding: 0.9rem 1rem;
  }
  .rolling-enrollment-page .form-label {
    margin-bottom: 0.2rem;
    font-size: 0.82rem;
    font-weight: 600;
  }
  .rolling-enrollment-page .compact-help {
    font-size: 0.74rem;
  }
  .rolling-enrollment-page .table-sm thead th {
    font-size: 0.78rem;
    white-space: nowrap;
  }
  .rolling-enrollment-page tr.gap-session-row-staged > td {
    background-color: var(--bs-warning-bg-subtle, #fff3cd);
  }
  .rolling-enrollment-page tr.conflict-session-row > td {
    background-color: var(--bs-danger-bg-subtle, #f8d7da);
  }
  #addEnrollmentPeriodModal .enroll-wizard-guide {
    margin-bottom: 1rem;
  }
  #addEnrollmentPeriodModal .wizard-step-rail {
    display: flex;
    gap: 0.5rem;
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 0.25rem;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  #addEnrollmentPeriodModal .wizard-step-rail::-webkit-scrollbar {
    display: none;
  }
  #addEnrollmentPeriodModal .wizard-step-pill {
    flex: 0 0 auto;
    white-space: nowrap;
    border: 1px solid #c8d1dc;
    background: #f8fafc;
    color: #17324d;
    font-weight: 600;
    font-size: 0.9rem;
    border-radius: 999px;
    padding: 0.35rem 0.8rem;
    transition: all 0.2s ease;
    pointer-events: none;
  }
  #addEnrollmentPeriodModal .wizard-step-pill.active {
    background: #17324d;
    color: #fff;
    border-color: #17324d;
  }
  #addEnrollmentPeriodModal .wizard-step-pill.completed {
    background: #e8f5ee;
    border-color: #95d5b2;
    color: #1b6f4a;
  }
  #addEnrollmentPeriodModal .wizard-progress {
    height: 0.35rem;
    background: #e8edf3;
    border-radius: 999px;
    overflow: hidden;
  }
  #addEnrollmentPeriodModal .wizard-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, #17324d 0%, #2f5d8a 100%);
    width: 0;
    transition: width 0.25s ease;
  }
  .rolling-enrollment-page .rolling-row-actions-wrap {
    position: relative;
    display: inline-block;
  }
  /* Base menu look (also when portaled to body so it is not clipped by the table) */
  .rolling-enrollment-page .rolling-row-actions-wrap .rolling-row-actions-menu,
  body > .rolling-row-actions-menu.rolling-row-actions-menu--floating {
    min-width: 148px;
    max-width: min(100vw - 1rem, 220px);
    z-index: 1100;
    background: #fff;
    border: 1px solid #d0d7de;
    border-radius: 0.45rem;
    box-shadow: 0 0.45rem 1rem rgba(0, 0, 0, 0.15);
    padding: 0.35rem;
  }
  .rolling-enrollment-page .rolling-row-actions-wrap > .rolling-row-actions-menu:not(.rolling-row-actions-menu--floating) {
    position: absolute;
    right: 0;
    top: calc(100% + 0.25rem);
    z-index: 15;
  }
  .rolling-enrollment-page .rolling-row-actions-menu .btn,
  body > .rolling-row-actions-menu.rolling-row-actions-menu--floating .btn {
    width: 100%;
    text-align: left;
    justify-content: flex-start;
    margin-bottom: 0.25rem;
  }
  .rolling-enrollment-page .rolling-row-actions-menu .btn:last-child,
  body > .rolling-row-actions-menu.rolling-row-actions-menu--floating .btn:last-child {
    margin-bottom: 0;
  }
  body > .rolling-row-actions-menu.rolling-row-actions-menu--floating {
    position: fixed;
    margin: 0;
  }
  .rolling-enrollment-page kbd {
    background: #f1f3f5;
    color: #495057;
    border: 1px solid #dee2e6;
    font-size: 0.7rem;
    padding: 0.08rem 0.3rem;
    border-radius: 0.25rem;
  }
</style>

<%
  const encClassId = encodeURIComponent(String(c.id || ''));
  const dashHref = typeof schoolSectionDashboardHref !== 'undefined' ? String(schoolSectionDashboardHref || '').trim() : '';
  const rollingHeaderManageBtns = [
    `<a href="/school/classes" class="btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-arrow-left me-1"></i> Classes</a>`,
    `<a href="${dashHref || '#'}" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>`
  ];
  const rollingManageBtns = [
    `<a href="/school/classes/edit/${encClassId}" class="btn btn-filled btn-primary btn-md mb-2"><i class="bi bi-pencil-square me-1"></i> Class Form</a>`,
    `<a href="/school/classes/${encClassId}/cycle-rollover" class="btn btn-filled btn-warning btn-md mb-2"><i class="bi bi-arrow-repeat me-1"></i> Cycle Rollover</a>`
  ];
  const rollingOptionalBtnsBeforePrint = [
    `<button type="button" id="btn_openAddEnrollmentModal" class="btn btn-filled btn-add btn-md me-2 mb-2"${isRolling && !isClosedForNewEnrollment ? '' : ' disabled'}><i class="bi bi-plus-circle me-1"></i>New Enrollment</button>`
  ];
%>

<div class="rolling-enrollment-page">
<%- include('partials/tablePages-start', {
  title: 'Rolling Enrollment',
  newUrl: '',
  user,
  tableName,
  btn_export: true,
  print,
  headerManageBtns: rollingHeaderManageBtns,
  belowHeadingInclude: 'school/class/rollingEnrollmentBelowHeading',
  manageBtns: rollingManageBtns,
  optionalBtnsBeforePrint: rollingOptionalBtnsBeforePrint
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search enrollment periods...',
  fields: []
}) %>

  <% if (!isRolling) { %>
    <div class="alert alert-warning border shadow-sm mb-3">
      This class is currently <b>Term-Based</b>. Switch Registration Mode to <b>Rolling</b> in Class Form before managing enrollment periods here.
    </div>
  <% } else if (isClosedForNewEnrollment) { %>
    <div class="alert alert-danger border shadow-sm mb-3">
      This cycle is <b>closed for new enrollment</b>. You can still edit existing enrollment periods, but new enrollments and draft approvals are blocked.
      <% if (nextCycleClassId) { %>
        <a href="/school/classes/<%= encodeURIComponent(nextCycleClassId) %>/rolling-enrollment" class="alert-link ms-1">Open next cycle<%= nextCycleClassTitle ? `: ${nextCycleClassTitle}` : '' %></a>.
      <% } %>
    </div>
  <% } %>

  <div class="table-scroll-wrapper" data-floating-row-actions="true">
    <table class="table-responsive size-md" id="first-table">
      <thead>
        <tr>
          <th class="ps-4">Student / ID</th>
          <th>Start Date</th>
          <th>End Date</th>
          <th class="text-center">Target</th>
          <th class="text-center">Consumed</th>
          <th class="text-center">Remaining</th>
          <th>Completion</th>
          <th class="text-center">Period Status</th>
          <th>Funder (Type / ID)</th>
          <th>Auth Ref</th>
          <th class="text-end pe-4">Actions</th>
        </tr>
      </thead>
      <tbody id="tbody_periods"></tbody>
    </table>
  </div>

<%- include('partials/tablePages-end') %>
</div>

<div class="modal fade" id="addEnrollmentPeriodModal" tabindex="-1" aria-labelledby="addEnrollmentPeriodModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="addEnrollmentPeriodModalLabel"><i class="bi bi-person-plus me-1"></i>New Enrollment Period</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="enroll-wizard-guide d-none" id="enrollWizardStepIndicator" aria-hidden="true">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
            <div class="fw-bold text-primary small">Enrollment wizard</div>
            <div class="d-flex align-items-center gap-2">
              <span class="badge bg-light text-dark border" id="enrollWizardStepBadge">Step 1 of 1</span>
              <span class="badge bg-primary-subtle text-primary border border-primary-subtle" id="enrollWizardProgressPct">0%</span>
            </div>
          </div>
          <div class="wizard-progress mb-3"><div class="wizard-progress-bar" id="enrollWizardProgressBar"></div></div>
          <div class="wizard-step-rail" id="enrollWizardStepPills"></div>
        </div>

        <div id="enrollWizardStepForm">
          <input type="hidden" id="inp_studentId">
          <div class="mb-2">
            <label class="form-label">Student *</label>
            <div class="input-group">
              <input type="text" id="inp_studentLabel" class="form-control bg-white" placeholder="Select student..." readonly>
              <button type="button" class="btn btn-outline-primary" id="btn_pickStudent"><i class="bi bi-person-vcard"></i></button>
            </div>
          </div>
          <div class="mb-2" id="wrap_enrollmentRegistration">
            <label class="form-label" id="lbl_enrollmentRegistration">Program registration</label>
            <div id="roll_enrollmentRegistrationPanel" class="form-control bg-light small py-2" style="min-height: 2.4rem;">
              <span class="text-muted">Select a student to verify program registration and prerequisites.</span>
            </div>
            <div class="form-text small text-muted" id="hint_enrollmentRegistration">
              The student must already be registered in a program that appears under this class’s allowed programs (and in the required term, if the class specifies one). Prerequisites are checked before enrollment is saved.
            </div>
          </div>
          <div class="row g-2">
            <div class="col-md-4">
              <label class="form-label">Start Date *</label>
              <input type="date" id="inp_startDate" class="form-control"<% if (cycleStartDate) { %> min="<%= cycleStartDate %>"<% } %><% if (cycleEndDate) { %> max="<%= cycleEndDate %>"<% } %>>
            </div>
            <div class="col-md-4">
              <label class="form-label" id="lbl_endDate">End Date<span id="lbl_endDateRequired" class="d-none"> *</span></label>
              <input type="date" id="inp_endDate" class="form-control"<% if (cycleStartDate) { %> min="<%= cycleStartDate %>"<% } %>>
            </div>
            <div class="col-md-4" id="wrap_inp_targetSessionCount">
              <label class="form-label">Number of Sessions <span class="text-muted fw-normal">(optional)</span></label>
              <input type="number" id="inp_targetSessionCount" class="form-control" min="1" step="1" placeholder="e.g. 10">
              <div class="form-text compact-help">Leave blank to enroll by date window only. N/A sessions do not count.</div>
              <div class="d-flex flex-wrap align-items-center gap-2 mt-1">
                <div class="form-text compact-help mb-0" id="hint_sessionAlignment">Set an end date to see how many countable sessions fall in the enrollment window.</div>
                <button type="button" class="btn btn-outline-secondary btn-sm py-0 px-2 d-none" id="btn_viewEnrollmentSessions">View Sessions</button>
              </div>
            </div>
          </div>
          <div class="row g-2 mt-2">
            <div class="col-md-4">
              <label class="form-label">Funder ID</label>
              <input type="text" id="inp_funderId" class="form-control" placeholder="Optional">
            </div>
            <div class="col-md-4">
              <label class="form-label">Funder Type</label>
              <input type="text" id="inp_funderType" class="form-control" placeholder="e.g. WCB">
            </div>
            <div class="col-md-4">
              <label class="form-label">Authorization Ref</label>
              <input type="text" id="inp_authorizationRef" class="form-control" placeholder="Optional">
            </div>
          </div>
          <div class="row g-2 mt-2">
            <div class="col-md-4">
              <label class="form-label">Status</label>
              <select id="inp_status" class="form-select">
                <option value="active" selected>Active</option>
                <option value="planned">Planned</option>
                <option value="draft">Draft</option>
              </select>
            </div>
          </div>
          <div class="mt-2">
            <label class="form-label">Reason Start</label>
            <textarea id="inp_reasonStart" class="form-control" rows="2" placeholder="Optional start note"></textarea>
          </div>
          <div class="alert alert-light border small mb-0 mt-3 text-secondary">
            <div class="fw-semibold text-dark mb-1">Tips</div>
            <p class="mb-1">When Number of Sessions does not match scheduled sessions, use Next to add sessions or mark N/A before saving.</p>
            <p class="mb-0"><kbd>Alt</kbd>+<kbd>S</kbd> pick student, <kbd>Alt</kbd>+<kbd>A</kbd> primary action, <kbd>Ctrl</kbd>+<kbd>Enter</kbd> from notes.</p>
          </div>
        </div>

        <div id="enrollWizardStepAddSessions" class="d-none">
          <div class="alert alert-warning border small" id="gapSummaryText">Session alignment issue.</div>
          <div class="alert alert-info border small mb-3">
            <b>Class-wide impact:</b> Sessions staged here are <b>not saved</b> until enrollment completes successfully. They will count toward every enrolled student whose end date covers those session dates once saved.
          </div>
          <div class="alert alert-primary border small mb-3 d-none" id="gapStagedBadge"></div>
          <div class="alert alert-warning border small mb-3 d-none" id="gapCycleExtendWarning"></div>
          <div class="mb-3">
            <div class="fw-semibold mb-2">Sessions currently in enrollment window</div>
            <div class="table-responsive border rounded">
              <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                  <tr><th>Date</th><th>Time</th><th>Status</th><th>Countable</th><th class="text-end">Actions</th></tr>
                </thead>
                <tbody id="gapSessionsTbody">
                  <tr><td colspan="5" class="text-center text-muted py-3">No sessions loaded.</td></tr>
                </tbody>
              </table>
            </div>
          </div>
          <div class="border rounded p-3 bg-light-subtle" id="gapBatchPanel">
            <div class="fw-semibold mb-2">Quick batch add</div>
            <div class="row g-2">
              <div class="col-md-3"><label class="form-label small">Start</label><input type="date" id="gap_batchStart" class="form-control form-control-sm"></div>
              <div class="col-md-3"><label class="form-label small">End</label><input type="date" id="gap_batchEnd" class="form-control form-control-sm"></div>
              <div class="col-md-3"><label class="form-label small">Start time</label><input type="time" id="gap_batchStartTime" class="form-control form-control-sm"></div>
              <div class="col-md-3"><label class="form-label small">End time</label><input type="time" id="gap_batchEndTime" class="form-control form-control-sm"></div>
              <div class="col-12">
                <label class="form-label small">Weekdays</label>
                <div class="d-flex flex-wrap gap-2" id="gap_weekdayWrap">
                  <% ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'].forEach((label, idx) => { %>
                    <label class="form-check form-check-inline small mb-0"><input type="checkbox" class="form-check-input gap-day-cb" value="<%= idx %>"> <%= label %></label>
                  <% }) %>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label small">Teacher</label>
                <div class="input-group input-group-sm">
                  <input type="hidden" id="gap_teacherId">
                  <input type="text" id="gap_teacherName" class="form-control bg-white" placeholder="Select teacher..." readonly>
                  <button type="button" class="btn btn-outline-secondary" id="btn_gapPickTeacher" title="Select Teacher"><i class="bi bi-person"></i></button>
                </div>
              </div>
              <div class="col-md-6">
                <label class="form-label small">Room</label>
                <input type="text" id="gap_room" class="form-control form-control-sm" placeholder="Optional">
              </div>
              <div class="col-12">
                <label class="form-label small text-muted">Skip Specific Dates (comma-separated YYYY-MM-DD)</label>
                <input type="text" id="gap_exceptions" class="form-control form-control-sm" placeholder="2026-11-26, 2026-12-25">
                <div class="form-check form-switch mt-2">
                  <input class="form-check-input" type="checkbox" role="switch" id="gap_skipHolidays">
                  <label class="form-check-label small text-muted" for="gap_skipHolidays">Skip Holidays/Off Days</label>
                  <div class="small text-muted" id="gap_holidayHint" style="display:none;"></div>
                </div>
              </div>
            </div>
            <div class="d-flex flex-wrap gap-2 mt-3">
              <button type="button" class="btn btn-primary btn-sm" id="btn_gapAppendSessions"><i class="bi bi-plus-circle me-1"></i>Stage Sessions</button>
              <button type="button" class="btn btn-outline-danger btn-sm d-none" id="btn_gapClearStaged"><i class="bi bi-x-circle me-1"></i>Clear Staged</button>
              <a class="btn btn-outline-secondary btn-sm" id="gap_classFormLink" href="/school/classes/edit/<%= encodeURIComponent(c.id || '') %>" target="_blank" rel="noopener noreferrer"><i class="bi bi-box-arrow-up-right me-1"></i>Open Class Session Builder</a>
            </div>
          </div>
        </div>

        <div id="enrollWizardStepMarkNa" class="d-none">
          <div class="alert alert-info border small" id="naSummaryText">Select sessions that should not count toward this enrollment.</div>
          <div class="small text-muted mb-2" id="naSelectionCounter">Selected 0 / 0</div>
          <div class="table-responsive border rounded">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light">
                <tr><th style="width:3rem;">N/A</th><th>Date</th><th>Time</th><th>Status</th></tr>
              </thead>
              <tbody id="naSessionsTbody">
                <tr><td colspan="4" class="text-center text-muted py-3">No sessions loaded.</td></tr>
              </tbody>
            </table>
          </div>
        </div>

        <div id="enrollWizardStepConflicts" class="d-none">
          <div class="alert alert-success border d-none" id="conflictReviewReadyPanel">
            <div class="fw-semibold mb-1"><i class="bi bi-check-circle-fill me-1"></i>Ready for enrollment</div>
            <div class="small mb-0">No scheduling conflicts found for the staged sessions. You can add this enrollment period.</div>
          </div>
          <div id="conflictReviewConflictPanel" class="d-none">
            <div class="alert alert-danger border small" id="conflictReviewBlockingAlert">
              Resolve scheduling conflicts by going Back to the add-sessions step before you can add this enrollment period.
            </div>
            <div id="conflictReviewStudentsHost"></div>
            <div class="mt-3 d-none" id="conflictReviewTeacherSection">
              <div class="fw-semibold mb-2">Teacher conflicts</div>
              <div class="table-responsive border rounded">
                <table class="table table-sm align-middle mb-0">
                  <thead class="table-light">
                    <tr><th>Date</th><th>Teacher</th><th>Conflict</th><th>Time</th><th>Type</th></tr>
                  </thead>
                  <tbody id="conflictReviewTeacherTbody"></tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-outline-secondary btn-sm d-none" id="btn_enrollWizardBack">
          <i class="bi bi-arrow-left me-1"></i>Back
        </button>
        <button type="button" class="btn btn-filled btn-primary btn-sm" id="btn_addPeriod" <%= isRolling ? '' : 'disabled' %>>
          <i class="bi bi-plus-circle me-1"></i>Add Enrollment Period
        </button>
      </div>
    </div>
  </div>
</div>

<div class="modal fade" id="programRegistrationShortcutModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-journal-plus me-1"></i>Register Student In Program</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <input type="hidden" id="shortcut_registrationId">
        <div class="alert alert-info border small">
          Create a program registration draft for this student, approve/finalize it, then retry Rolling Enrollment eligibility.
        </div>
        <div class="mb-2">
          <label class="form-label">Student</label>
          <input type="text" id="shortcut_studentLabel" class="form-control bg-light" readonly>
        </div>
        <div class="row g-2">
          <div class="col-md-7">
            <label class="form-label">Allowed Program *</label>
            <select id="shortcut_programId" class="form-select"></select>
          </div>
          <div class="col-md-5">
            <label class="form-label">Registration Date *</label>
            <input type="date" id="shortcut_registrationDate" class="form-control"<% if (cycleStartDate) { %> min="<%= cycleStartDate %>"<% } %><% if (cycleEndDate) { %> max="<%= cycleEndDate %>"<% } %>>
          </div>
          <div class="col-md-6">
            <label class="form-label">External Reference</label>
            <input type="text" id="shortcut_externalReference" class="form-control" placeholder="Optional">
          </div>
          <div class="col-md-6">
            <label class="form-label">Note</label>
            <input type="text" id="shortcut_note" class="form-control" placeholder="Optional">
          </div>
        </div>
        <div class="mt-3">
          <div class="fw-semibold small mb-1">Preview / Result</div>
          <div id="shortcut_previewPanel" class="border rounded bg-light p-2 small text-muted">
            Choose a program and click Preview.
          </div>
        </div>
      </div>
      <div class="modal-footer flex-wrap gap-2">
        <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-outline-primary btn-sm" id="btn_shortcutPreview"><i class="bi bi-eye me-1"></i>Preview</button>
        <button type="button" class="btn btn-primary btn-sm" id="btn_shortcutSaveDraft"><i class="bi bi-save me-1"></i>Save Draft</button>
        <button type="button" class="btn btn-success btn-sm" id="btn_shortcutApprove" disabled><i class="bi bi-check2-circle me-1"></i>Approve &amp; Finalize</button>
