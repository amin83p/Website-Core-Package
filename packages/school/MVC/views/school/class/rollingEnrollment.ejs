  function parseGapExceptionDatesInput() {
    const raw = String(qs('gap_exceptions')?.value || '').trim();
    if (!raw) return [];
    return raw.split(',').map((row) => String(row || '').trim()).filter((row) => /^\d{4}-\d{2}-\d{2}$/.test(row));
  }

  async function collectGapExceptionDates(startDate, endDate) {
    const exceptions = new Set(parseGapExceptionDatesInput());
    if (!qs('gap_skipHolidays')?.checked) {
      return Array.from(exceptions);
    }
    const holidayHint = qs('gap_holidayHint');
    if (holidayHint) {
      holidayHint.style.display = 'none';
      holidayHint.textContent = '';
    }
    try {
      const resp = await fetch(`/school/holidays/api/range?start=${encodeURIComponent(startDate)}&end=${encodeURIComponent(endDate)}`, {
        headers: { 'X-AJAX-Request': 'true' }
      });
      const txt = await resp.text();
      let data;
      try { data = JSON.parse(txt); } catch { data = { status: 'error', message: 'Non-JSON response from holiday API.' }; }
      if (!resp.ok || data.status !== 'success') {
        await showMsg('Holiday lookup failed', 'warning', data.message || 'Unable to load holidays. Continuing without skipping holidays.');
        return Array.from(exceptions);
      }
      const holidays = Array.isArray(data.holidays) ? data.holidays : [];
      holidays.forEach((holiday) => {
        if (holiday && holiday.date) exceptions.add(String(holiday.date).trim());
      });
      if (holidayHint) {
        holidayHint.style.display = 'block';
        holidayHint.textContent = `Holidays in range: ${holidays.length}`;
      }
    } catch (error) {
      await showMsg('Holiday lookup failed', 'warning', error.message || 'Unable to load holidays. Continuing without skipping holidays.');
    }
    return Array.from(exceptions);
  }

