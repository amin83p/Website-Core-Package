  function openDraftReviewModal(periodId) {
    const row = (Array.isArray(periodRows) ? periodRows : []).find((item) => String(item?.id || '') === String(periodId || ''));
    if (!row) return;
    const transactionSummary = (row?.transactionSummary && typeof row.transactionSummary === 'object') ? row.transactionSummary : {};
    const draftTransactionItems = Array.isArray(transactionSummary?.draftTransactionItems) ? transactionSummary.draftTransactionItems : [];
    const draftPreviewRows = Array.isArray(transactionSummary?.draftPreviewRows) ? transactionSummary.draftPreviewRows : [];
    if (!draftTransactionItems.length || !draftPreviewRows.length) {
      showMsg('Draft Missing', 'warning', 'No draft transaction rows were found for this enrollment period.');
      return;
    }

    const payload = {
      classId,
      studentId: String(row?.studentId || '').trim(),
      startDate: String(row?.startDate || '').trim(),
      endDate: String(row?.endDate || '').trim(),
      status: String(row?.status || 'draft').trim().toLowerCase() || 'draft',
      funderType: String(row?.funderType || '').trim(),
      funderId: String(row?.funderId || '').trim(),
      authorizationRef: String(row?.authorizationRef || '').trim(),
      reasonStart: String(row?.reasonStart || '').trim(),
      targetSessionCount: String(row?.targetSessionCount || '').trim(),
      sessionCountPolicy: String(row?.sessionCountPolicy || 'all_non_na').trim() || 'all_non_na'
    };

    openChargeModalWithDraft(payload, {
      draftTransactionItems,
      draftPreviewRows,
      totalAmount: Number(transactionSummary?.totalAmount || 0),
      feeCategory: String(row?.feeCategory || '').trim(),
      classFeeRule: { transactionDefinitionName: 'Draft Enrollment Transactions' }
    }, {
      mode: 'review',
      periodId: String(row?.id || '').trim()
    });
  }

  async function requestJson(url, method = 'GET', payload = null) {
    const upperMethod = String(method || 'GET').toUpperCase();
    const isMutating = ['POST', 'PUT', 'PATCH', 'DELETE'].includes(upperMethod);
    const normalizedPayload = (payload && typeof payload === 'object') ? { ...payload } : payload;
    if (isMutating && actionStateId && normalizedPayload && typeof normalizedPayload === 'object' && !normalizedPayload.actionStateId) {
      normalizedPayload.actionStateId = actionStateId;
    }
    const classScopedEnrollmentAction = isMutating
      && /^\/school\/classes\/api\/enrollment-periods\/(preview-create|create-with-transactions|create|check-overlap|evaluate-reentry)(\?|$)/.test(String(url || ''));
    const urlParams = [];
    if (!isMutating && actionStateId) {
      urlParams.push('actionStateId=' + encodeURIComponent(actionStateId));
    }
    if (classScopedEnrollmentAction && classId && !/[?&]id=/.test(String(url || ''))) {
      urlParams.push('id=' + encodeURIComponent(classId));
    }
    const urlWithActionState = urlParams.length
      ? `${url}${url.includes('?') ? '&' : '?'}${urlParams.join('&')}`
      : url;
    const headers = { 'X-AJAX-Request': 'true' };
    if (actionStateId) headers['X-Action-State-Id'] = actionStateId;
    if (normalizedPayload) headers['Content-Type'] = 'application/json';
    const response = await fetch(urlWithActionState, {
      method: upperMethod,
      headers,
      body: normalizedPayload ? JSON.stringify(normalizedPayload) : undefined
    });
    const result = await response.json().catch(() => ({}));
    if (window.applyGuardedApiResult) {
      const wrapped = await window.applyGuardedApiResult(result, {
        busyTitle: 'Operation In Progress',
        replayTitle: 'Already Processed'
      });
      if (wrapped.stop) return null;
    }
    if (!response.ok || String(result.status || '').toLowerCase() === 'error') {
      throw new Error(result?.message || 'Request failed.');
    }
    return result;
  }

  function renderRows() {
    closeAllActionMenus();
    const rows = Array.isArray(periodRows) ? [...periodRows] : [];
    rows.sort((a, b) => String(a?.startDate || '').localeCompare(String(b?.startDate || '')));
    periodCount.textContent = `${rows.length} row${rows.length === 1 ? '' : 's'}`;
    if (!rows.length) {
      tbody.innerHTML = '<tr><td colspan="' + String(periodTableColspan) + '" class="text-center py-4 text-muted">No enrollment periods found.</td></tr>';
      return;
    }

    tbody.innerHTML = rows.map((row) => {
      const studentId = String(row?.studentId || '');
      const status = String(row?.status || '').trim().toLowerCase();
      const badgeClass = status === 'active' ? 'bg-success'
        : (status === 'planned' ? 'bg-primary' : (status === 'draft' ? 'bg-warning text-dark' : 'bg-secondary'));
      const canClose = isOpenStatus(status);
      const canReviewDraft = status === 'draft' && Array.isArray(row?.transactionSummary?.draftPreviewRows) && row.transactionSummary.draftPreviewRows.length > 0;
      const hasPostedTransactions = status !== 'draft'
        && Array.isArray(row?.transactionSummary?.postedTransactionIds)
        && row.transactionSummary.postedTransactionIds.length > 0;
      const canSyncAcademicLedger = hasPostedTransactions || status === 'active';
      const removeLabel = hasPostedTransactions ? 'Rollback' : 'Delete';
      const funderLabel = [row?.funderType, row?.funderId].filter(Boolean).join(' / ') || '-';
      const targetSessionCount = Number(row?.targetSessionCount || 0);
      const consumedSessionCount = Number(row?.consumedSessionCount || 0);
      const remainingSessionCount = targetSessionCount ? Math.max(0, Number(row?.remainingSessionCount ?? (targetSessionCount - consumedSessionCount))) : null;
      const completion = row?.sessionCompletion || (row?.completionDate ? { date: row.completionDate, sessionId: row?.completionSessionId || '', reason: row?.completionReason || '' } : null);
      const completionHtml = completion?.date
        ? '<div class="small fw-semibold">' + htmlEscape(String(completion.date || '')) + '</div>'
          + (completion.sessionId ? '<div class="x-small text-muted font-monospace">' + htmlEscape(String(completion.sessionId)) + '</div>' : '')
        : '<span class="text-muted">-</span>';
      return `
        <tr>
          <td class="ps-4">
            <div class="fw-semibold">${(typeof schoolRenderStudentNameHtml === 'function' ? schoolRenderStudentNameHtml(String(row?.studentLabel || studentMap.get(studentId)?.label || studentId || '-'), row?.studentRecordId || studentId, { className: 'text-decoration-none fw-semibold' }) : htmlEscape(String(row?.studentLabel || studentMap.get(studentId)?.label || studentId || '-')))}</div>
            <div class="x-small text-muted font-monospace">${htmlEscape(studentId)}</div>
          </td>
          <td>${htmlEscape(String(row?.startDate || '-'))}</td>
          <td>${htmlEscape(String(row?.endDate || 'Open'))}</td>
          <td class="text-center">${targetSessionCount ? htmlEscape(String(targetSessionCount)) : '<span class="text-muted">-</span>'}</td>
          <td class="text-center">${targetSessionCount ? htmlEscape(String(consumedSessionCount)) : '<span class="text-muted">-</span>'}</td>
          <td class="text-center">${targetSessionCount ? htmlEscape(String(remainingSessionCount)) : '<span class="text-muted">-</span>'}</td>
          <td>${completionHtml}</td>
          <td class="text-center"><span class="badge ${badgeClass}">${htmlEscape(status || '-')}</span></td>
          <td>${htmlEscape(funderLabel)}</td>
          <td>${htmlEscape(String(row?.authorizationRef || '-'))}</td>
          <td class="text-end table-actions pe-4">
            <div class="rolling-row-actions-wrap">
              <button type="button" class="btn btn-secondary btn-sm rolling-row-actions-toggle" data-period-id="${htmlEscape(String(row?.id || ''))}">
                <i class="bi bi-three-dots-vertical"></i>
              </button>
              <div class="rolling-row-actions-menu d-none" data-period-id="${htmlEscape(String(row?.id || ''))}">
                <button type="button" class="btn btn-outline-primary btn-sm btn-row-edit" data-period-id="${htmlEscape(String(row?.id || ''))}"><i class="bi bi-pencil-square me-1"></i>Edit</button>
                ${canReviewDraft ? `<button type="button" class="btn btn-outline-primary btn-sm btn-row-review-draft" data-period-id="${htmlEscape(String(row?.id || ''))}"><i class="bi bi-journal-text me-1"></i>Review Draft</button>` : ''}
                <button type="button" class="btn btn-outline-secondary btn-sm btn-row-reentry" data-period-id="${htmlEscape(String(row?.id || ''))}"><i class="bi bi-arrow-repeat me-1"></i>Next</button>
                ${canClose ? `<button type="button" class="btn btn-outline-danger btn-sm btn-row-close" data-period-id="${htmlEscape(String(row?.id || ''))}"><i class="bi bi-x-circle me-1"></i>Close</button>` : ''}
                ${canSyncAcademicLedger ? `<button type="button" class="btn btn-outline-info btn-sm btn-row-sync-ledger" data-period-id="${htmlEscape(String(row?.id || ''))}"><i class="bi bi-journal-bookmark me-1"></i>Sync academic ledger</button>` : ''}
                <button type="button" class="btn btn-outline-danger btn-sm btn-row-remove" data-period-id="${htmlEscape(String(row?.id || ''))}"><i class="bi bi-trash me-1"></i>${removeLabel}</button>
              </div>
            </div>
          </td>
        </tr>
      `;
    }).join('');
  }

  function pickStudent() {
    if (!window.GenericPicker || !window.GenericPickerPresets) {
      showMsg('Picker Unavailable', 'warning', 'Student picker is not loaded on this page.');
      return;
    }
    GenericPicker.open(GenericPickerPresets.student({
      title: 'Select Student',
      multiselect: false,
      searchFields: 'id,firstName,lastName,name.first,name.last,studentNumber,personId',
      context: (window.GenericPickerContexts && typeof window.GenericPickerContexts.activeOrganizationScope === 'function')
        ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
        : undefined,
      onSelect: (selected) => {
        const item = Array.isArray(selected) ? selected[0] : selected;
        if (!item) return;
        const id = String(item?.id || '').trim();
        const firstName = String(item?.firstName || item?.name?.first || '').trim();
        const lastName = String(item?.lastName || item?.name?.last || '').trim();
        const personName = [firstName, lastName].filter(Boolean).join(' ').trim() || String(item?.name || '').trim();
        const studentNum = String(item?.studentNumber || '').trim();
        qs('inp_studentId').value = id;
        qs('inp_studentLabel').value = studentNum ? `${personName} (${studentNum})` : (personName || id);
        refreshRollingEligibility();
        qs('inp_startDate')?.focus();
      }
    }));
  }

  function clearEntryDraft() {
    if (qs('inp_studentId')) qs('inp_studentId').value = '';
    if (qs('inp_studentLabel')) qs('inp_studentLabel').value = '';
    qs('inp_startDate').value = '';
    qs('inp_endDate').value = '';
    qs('inp_status').value = 'active';
    qs('inp_funderType').value = '';
    qs('inp_funderId').value = '';
    qs('inp_authorizationRef').value = '';
    qs('inp_reasonStart').value = '';
    if (qs('inp_targetSessionCount')) {
      qs('inp_targetSessionCount').value = '';
      delete qs('inp_targetSessionCount').dataset.userEdited;
    }
    lastRollingEligibility = null;
    lastAlignmentResult = null;
    pendingPlannedNaSessionIds = [];
    clearPendingGapBatch({ clearFormDraft: true });
    lastConflictReview = null;
    conflictReviewHasConflicts = false;
    enrollWizardStep = 'form';
    enrollWizardPath = null;
    updateSessionCountHint(null);
    setEnrollmentWizardStepVisibility();
    setRollingRegistrationPanelHtml('<span class="text-muted">Select a student to verify program registration and prerequisites.</span>');
