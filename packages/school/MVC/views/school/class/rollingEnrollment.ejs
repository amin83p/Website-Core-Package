        +   '<td><div class="fw-bold font-monospace">' + htmlEscape(row.creditAccountCode || row.creditAccountId || '-') + '</div><div class="small text-muted">' + htmlEscape(row.creditAccountName || '-') + '</div></td>'
        +   '<td class="fw-bold">' + Number(row.amount || 0).toFixed(2) + ' ' + htmlEscape(row.currency || 'CAD') + '</td>'
        +   '<td class="small">' + htmlEscape(row.memo || '-') + '</td>'
        +   '<td class="text-end"><button type="button" class="btn btn-outline-danger btn-sm" data-remove-manual-row="' + index + '">Remove</button></td>'
        + '</tr>';
    }).join('');

    tbodyManual.querySelectorAll('button[data-remove-manual-row]').forEach(function (button) {
      button.addEventListener('click', function () {
        const idx = Number(button.getAttribute('data-remove-manual-row'));
        if (!Number.isInteger(idx) || idx < 0 || idx >= manualRows.length) return;
        manualRows.splice(idx, 1);
        renderManualRows();
      });
    });
    updateDraftTotalsIndicator();
  }

  function renderDraftTransactionRows(rows) {
    const tbodyDraft = qs('draftTransactionsTbody');
    const draftRows = Array.isArray(rows) ? rows : [];
    if (!tbodyDraft) return;
    if (!draftRows.length) {
      tbodyDraft.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No draft transaction rows available.</td></tr>';
      return;
    }

    tbodyDraft.innerHTML = draftRows.map(function (row) {
      const amount = Number(row?.amount || 0);
      return ''
        + '<tr data-draft-row-index="' + Number(row?.rowIndex || 0) + '">'
        +   '<td><div class="form-check"><input class="form-check-input draft-include" type="checkbox" checked></div></td>'
        +   '<td>'
        +     '<div class="fw-bold font-monospace draft-debit-account-code">' + htmlEscape(row?.debitAccount?.code || row?.debitAccount?.id || '-') + '</div>'
        +     '<div class="small text-muted draft-debit-account-name">' + htmlEscape(row?.debitAccount?.name || '-') + '</div>'
        +     '<input type="hidden" class="draft-debit-account-id" value="' + htmlEscape(String(row?.debitAccount?.id || '')) + '">'
        +     '<button type="button" class="btn btn-outline-secondary btn-sm mt-1 draft-change-debit-account"><i class="bi bi-search me-1"></i>Change</button>'
        +   '</td>'
        +   '<td>'
        +     '<div class="fw-bold font-monospace draft-credit-account-code">' + htmlEscape(row?.creditAccount?.code || row?.creditAccount?.id || '-') + '</div>'
        +     '<div class="small text-muted draft-credit-account-name">' + htmlEscape(row?.creditAccount?.name || '-') + '</div>'
        +     '<input type="hidden" class="draft-credit-account-id" value="' + htmlEscape(String(row?.creditAccount?.id || '')) + '">'
        +     '<button type="button" class="btn btn-outline-secondary btn-sm mt-1 draft-change-credit-account"><i class="bi bi-search me-1"></i>Change</button>'
        +   '</td>'
        +   '<td><div class="input-group input-group-sm"><input type="number" class="form-control draft-amount" min="0.01" step="0.01" value="' + Number(amount.toFixed(2)) + '"><span class="input-group-text">' + htmlEscape(row?.currency || 'CAD') + '</span></div></td>'
        +   '<td><input type="text" class="form-control form-control-sm draft-memo" value="' + htmlEscape(row?.memo || '') + '" placeholder="Memo"></td>'
        + '</tr>';
    }).join('');

    document.querySelectorAll('#draftTransactionsTbody .draft-include, #draftTransactionsTbody .draft-amount').forEach(function (el) {
      el.addEventListener('change', updateDraftTotalsIndicator);
      el.addEventListener('input', updateDraftTotalsIndicator);
    });
    bindDraftRowAccountPickers();
    updateDraftTotalsIndicator();
  }

  function resetChargeModalState() {
    pendingEnrollmentPayload = null;
    pendingDraftTransactionItems = [];
    manualRows = [];
    draftReviewMode = 'create';
    if (qs('charge_draftPeriodId')) qs('charge_draftPeriodId').value = '';
    if (qs('charge_startDate')) qs('charge_startDate').value = '';
    if (qs('charge_endDate')) qs('charge_endDate').value = '';
    if (qs('charge_status')) qs('charge_status').value = 'draft';
    renderDraftTransactionRows([]);
    renderManualRows();
    clearManualAccount('Debit');
    clearManualAccount('Credit');
    if (qs('inp_manualAmount')) qs('inp_manualAmount').value = '';
    if (qs('inp_manualCurrency')) qs('inp_manualCurrency').value = 'CAD';
    if (qs('inp_manualMemo')) qs('inp_manualMemo').value = '';
    setChargeSummaryText('Review and adjust draft rows before posting.');
    setChargeModalMode('create');
  }

  function openChargeModalWithDraft(payload, draft, options = {}) {
    pendingEnrollmentPayload = { ...(payload || {}) };
    pendingDraftTransactionItems = Array.isArray(draft?.draftTransactionItems) ? draft.draftTransactionItems : [];
    manualRows = [];
    const isReview = String(options?.mode || '').trim().toLowerCase() === 'review';
    setChargeModalMode(isReview ? 'review' : 'create');

    if (qs('charge_draftPeriodId')) qs('charge_draftPeriodId').value = String(options?.periodId || '').trim();
    if (qs('charge_startDate')) qs('charge_startDate').value = String(payload?.startDate || '').trim();
    if (qs('charge_endDate')) qs('charge_endDate').value = String(payload?.endDate || '').trim();
    if (qs('charge_status')) qs('charge_status').value = String(payload?.status || 'draft').trim().toLowerCase() || 'draft';

    renderManualRows();
    renderDraftTransactionRows(Array.isArray(draft?.draftPreviewRows) ? draft.draftPreviewRows : []);
    const txName = String(draft?.classFeeRule?.transactionDefinitionName || draft?.classFeeRule?.transactionDefinitionCode || '').trim();
    const feeCategory = String(draft?.feeCategory || '').trim();
    const total = Number(draft?.totalAmount || 0).toFixed(2);
    const summaryParts = [
      feeCategory ? `Fee Category: ${feeCategory}` : '',
      txName ? `Template: ${txName}` : '',
      `Draft Total: ${total}`,
      isReview ? 'Mode: Review Draft' : 'Mode: New Draft'
    ].filter(Boolean);
    setChargeSummaryText(summaryParts.join(' | '));

    if (!chargeModal || typeof chargeModal.show !== 'function') {
      showMsg(
        'Draft Unavailable',
        'error',
        'Draft was generated, but the review panel could not be opened. Transactions were not posted. Please reload the page and try again.'
      );
      return;
    }

    addEnrollmentModal?.hide();
    chargeModal.show();
  }

  async function addManualRow() {
    const debitAccountId = String(qs('inp_manualDebitAccountId')?.value || '').trim();
    const creditAccountId = String(qs('inp_manualCreditAccountId')?.value || '').trim();
    const debitLabel = String(qs('inp_manualDebitAccountLabel')?.value || '').trim();
    const creditLabel = String(qs('inp_manualCreditAccountLabel')?.value || '').trim();
    const amount = Number(qs('inp_manualAmount')?.value || 0);
    const currency = String(qs('inp_manualCurrency')?.value || 'CAD').trim().toUpperCase();
    const memo = String(qs('inp_manualMemo')?.value || '').trim();

    if (!debitAccountId || !creditAccountId) {
      await showMsg('Validation', 'warning', 'Both debit and credit accounts are required.');
      return;
    }
    if (debitAccountId === creditAccountId) {
      await showMsg('Validation', 'warning', 'Debit and credit accounts cannot be the same.');
      return;
    }
    if (!Number.isFinite(amount) || amount <= 0) {
      await showMsg('Validation', 'warning', 'Amount must be greater than zero.');
      return;
    }
    if (!/^[A-Z]{3}$/.test(currency)) {
      await showMsg('Validation', 'warning', 'Currency must be a valid ISO code (for example CAD).');
      return;
    }

    manualRows.push({
      debitAccountId,
      debitAccountCode: debitLabel.split(' - ')[0] || debitAccountId,
      debitAccountName: debitLabel,
      creditAccountId,
      creditAccountCode: creditLabel.split(' - ')[0] || creditAccountId,
      creditAccountName: creditLabel,
      amount,
      currency,
      memo
    });

    clearManualAccount('Debit');
    clearManualAccount('Credit');
    if (qs('inp_manualAmount')) qs('inp_manualAmount').value = '';
    if (qs('inp_manualCurrency')) qs('inp_manualCurrency').value = 'CAD';
    if (qs('inp_manualMemo')) qs('inp_manualMemo').value = '';
    renderManualRows();
  }

  async function submitChargeableEnrollment() {
    if (chargeActionInProgress) return;
    if (!pendingEnrollmentPayload || !pendingDraftTransactionItems.length) {
      await showMsg('Missing Draft', 'warning', 'Transaction draft is missing. Re-run Add Period.');
      return;
    }
    chargeActionInProgress = true;
    try {
      showBusy('Saving enrollment and posting transactions...');
      const draftContext = readChargeModalDraftContext();
      if (!draftContext.startDate) {
        await showMsg('Validation', 'warning', 'Effective Start Date is required.');
        return;
      }
      const result = await requestJson('/school/classes/api/enrollment-periods/create-with-transactions', 'POST', {
        ...pendingEnrollmentPayload,
        startDate: draftContext.startDate,
        endDate: draftContext.endDate,
        status: draftContext.status || 'draft',
        funderType: draftContext.funderType,
        funderId: draftContext.funderId,
        authorizationRef: draftContext.authorizationRef,
        reasonStart: draftContext.reasonStart,
        targetSessionCount: draftContext.targetSessionCount,
        sessionCountPolicy: draftContext.sessionCountPolicy,
        plannedNotApplicableSessionIds: Array.isArray(pendingEnrollmentPayload?.plannedNotApplicableSessionIds)
          ? pendingEnrollmentPayload.plannedNotApplicableSessionIds
          : [],
        draftTransactionItems: pendingDraftTransactionItems,
        editedRows: collectEditedRows(),
        addedRows: collectAddedRows()
      });
      if (!result) return;
      chargeModal?.hide();
      await showMsg('Success', 'success', result.message || 'Draft enrollment saved.');
      await loadRows();
      clearEntryDraft();
      resetChargeModalState();
      qs('inp_startDate')?.focus();
    } catch (error) {
      await showMsg('Create Failed', 'error', error.message || 'Unable to create enrollment and post transactions.');
    } finally {
      chargeActionInProgress = false;
      hideBusy();
    }
  }

