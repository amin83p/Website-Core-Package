  async function runAlignmentRefresh({ showSpinner = false } = {}) {
    const body = buildAlignmentRequestBody();
    if (!body.startDate) {
      lastAlignmentResult = null;
      updateSessionCountHint(null);
      return null;
    }
    try {
      if (showSpinner) showBusy('Counting sessions...');
      const alignment = await fetchEnrollmentSessionAlignment(body);
      lastAlignmentResult = alignment;
      updateSessionCountHint(alignment);
      if (hasTargetSessionCount() && alignment && body.endDate && alignment.alignmentStatus !== 'insufficient_sessions') {
        const targetInput = qs('inp_targetSessionCount');
        if (targetInput && !String(targetInput.dataset.userEdited || '').trim()) {
          targetInput.value = String(alignment.availableCount || '');
        }
      }
      return alignment;
    } catch (error) {
      if (showSpinner) {
        await showMsg('Session Count Failed', 'warning', error.message || 'Unable to count sessions.');
      }
      return null;
    } finally {
      if (showSpinner) hideBusy();
    }
  }

  function scheduleAlignmentRefresh() {
    if (alignmentDebounceTimer) clearTimeout(alignmentDebounceTimer);
    alignmentDebounceTimer = setTimeout(() => {
      alignmentDebounceTimer = null;
      runAlignmentRefresh({ showSpinner: true });
