  function openChargeModalWithDraft(payload, draft, options = {}) {
    pendingEnrollmentPayload = { ...(payload || {}) };
    pendingDraftTransactionItems = Array.isArray(draft?.draftTransactionItems) ? draft.draftTransactionItems : [];
    manualRows = [];
    const isReview = String(options?.mode || '').trim().toLowerCase() === 'review';
    setChargeModalMode(isReview ? 'review' : 'create');

    if (qs('charge_draftPeriodId')) qs('charge_draftPeriodId').value = String(options?.periodId || '').trim();
    if (qs('charge_startDate')) qs('charge_startDate').value = String(payload?.startDate || '').trim();
    if (qs('charge_endDate')) qs('charge_endDate').value = String(payload?.endDate || '').trim();
    if (qs('charge_status')) qs('charge_status').value = String(payload?.status || 'draft').trim().toLowerCase() || 'draft';

    renderManualRows();
    renderDraftTransactionRows(Array.isArray(draft?.draftPreviewRows) ? draft.draftPreviewRows : []);
    const txName = String(draft?.classFeeRule?.transactionDefinitionName || draft?.classFeeRule?.transactionDefinitionCode || '').trim();
    const feeCategory = String(draft?.feeCategory || '').trim();
    const total = Number(draft?.totalAmount || 0).toFixed(2);
    const summaryParts = [
      feeCategory ? `Fee Category: ${feeCategory}` : '',
      txName ? `Template: ${txName}` : '',
      `Draft Total: ${total}`,
      isReview ? 'Mode: Review Draft' : 'Mode: New Draft'
    ].filter(Boolean);
    setChargeSummaryText(summaryParts.join(' | '));

    if (!chargeModal || typeof chargeModal.show !== 'function') {
      showMsg(
        'Draft Unavailable',
        'error',
        'Draft was generated, but the review panel could not be opened. Transactions were not posted. Please reload the page and try again.'
      );
      return;
    }

    addEnrollmentModal?.hide();
    chargeModal.show();
  }

  async function addManualRow() {
    const debitAccountId = String(qs('inp_manualDebitAccountId')?.value || '').trim();
    const creditAccountId = String(qs('inp_manualCreditAccountId')?.value || '').trim();
    const debitLabel = String(qs('inp_manualDebitAccountLabel')?.value || '').trim();
    const creditLabel = String(qs('inp_manualCreditAccountLabel')?.value || '').trim();
    const amount = Number(qs('inp_manualAmount')?.value || 0);
    const currency = String(qs('inp_manualCurrency')?.value || 'CAD').trim().toUpperCase();
    const memo = String(qs('inp_manualMemo')?.value || '').trim();

    if (!debitAccountId || !creditAccountId) {
      await showMsg('Validation', 'warning', 'Both debit and credit accounts are required.');
      return;
    }
    if (debitAccountId === creditAccountId) {
      await showMsg('Validation', 'warning', 'Debit and credit accounts cannot be the same.');
      return;
    }
    if (!Number.isFinite(amount) || amount <= 0) {
      await showMsg('Validation', 'warning', 'Amount must be greater than zero.');
      return;
    }
    if (!/^[A-Z]{3}$/.test(currency)) {
      await showMsg('Validation', 'warning', 'Currency must be a valid ISO code (for example CAD).');
      return;
    }

    manualRows.push({
      debitAccountId,
      debitAccountCode: debitLabel.split(' - ')[0] || debitAccountId,
      debitAccountName: debitLabel,
      creditAccountId,
      creditAccountCode: creditLabel.split(' - ')[0] || creditAccountId,
      creditAccountName: creditLabel,
      amount,
      currency,
      memo
    });

    clearManualAccount('Debit');
    clearManualAccount('Credit');
    if (qs('inp_manualAmount')) qs('inp_manualAmount').value = '';
    if (qs('inp_manualCurrency')) qs('inp_manualCurrency').value = 'CAD';
    if (qs('inp_manualMemo')) qs('inp_manualMemo').value = '';
    renderManualRows();
  }

  async function submitChargeableEnrollment() {
    if (chargeActionInProgress) return;
    if (!pendingEnrollmentPayload || !pendingDraftTransactionItems.length) {
      await showMsg('Missing Draft', 'warning', 'Transaction draft is missing. Re-run Add Period.');
      return;
    }
    chargeActionInProgress = true;
    try {
      showBusy('Saving enrollment and posting transactions...');
      const draftContext = readChargeModalDraftContext();
      if (!draftContext.startDate) {
        await showMsg('Validation', 'warning', 'Effective Start Date is required.');
        return;
      }
      const result = await requestJson('/school/classes/api/enrollment-periods/create-with-transactions', 'POST', {
        ...pendingEnrollmentPayload,
        startDate: draftContext.startDate,
        endDate: draftContext.endDate,
        status: draftContext.status || 'draft',
        funderType: draftContext.funderType,
        funderId: draftContext.funderId,
        authorizationRef: draftContext.authorizationRef,
        reasonStart: draftContext.reasonStart,
