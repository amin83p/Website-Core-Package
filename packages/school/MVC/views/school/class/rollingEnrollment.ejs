  function updateDraftTotalsIndicator() {
    const draftRowsTotal = Array.from(document.querySelectorAll('#draftTransactionsTbody tr[data-draft-row-index]')).reduce(function (sum, row) {
      const include = row.querySelector('.draft-include')?.checked !== false;
      if (!include) return sum;
      const amount = Number(row.querySelector('.draft-amount')?.value || 0);
      if (!Number.isFinite(amount) || amount <= 0) return sum;
      return sum + amount;
    }, 0);

    const manualRowsTotal = manualRows.reduce(function (sum, row) {
      const amount = Number(row?.amount || 0);
      if (!Number.isFinite(amount) || amount <= 0) return sum;
      return sum + amount;
    }, 0);

    const draftTotal = Number(draftRowsTotal.toFixed(2));
    const manualTotal = Number(manualRowsTotal.toFixed(2));
    const projected = Number((draftTotal + manualTotal).toFixed(2));

    const draftLabel = qs('txt_draftRowsTotal');
    const manualLabel = qs('txt_manualRowsTotal');
    const projectedLabel = qs('txt_projectedRowsTotal');
    if (draftLabel) draftLabel.textContent = draftTotal.toFixed(2);
    if (manualLabel) manualLabel.textContent = manualTotal.toFixed(2);
    if (projectedLabel) projectedLabel.textContent = projected.toFixed(2);
  }

  function collectEditedRows() {
    return Array.from(document.querySelectorAll('#draftTransactionsTbody tr[data-draft-row-index]')).map(function (row) {
      const rowIndex = Number(row.getAttribute('data-draft-row-index'));
      const include = row.querySelector('.draft-include')?.checked !== false;
      const amount = Number(row.querySelector('.draft-amount')?.value || 0);
      const memo = String(row.querySelector('.draft-memo')?.value || '').trim();
      const debitAccountId = String(row.querySelector('.draft-debit-account-id')?.value || '').trim();
      const creditAccountId = String(row.querySelector('.draft-credit-account-id')?.value || '').trim();
      return { rowIndex, include, amount, memo, debitAccountId, creditAccountId };
    }).filter(function (row) {
      return Number.isInteger(row.rowIndex) && row.rowIndex >= 0;
    });
  }

  function collectAddedRows() {
    return manualRows.map(function (row) {
      return {
        debitAccountId: String(row.debitAccountId || '').trim(),
        creditAccountId: String(row.creditAccountId || '').trim(),
        amount: Number(row.amount || 0),
        currency: String(row.currency || 'CAD').trim().toUpperCase() || 'CAD',
        memo: String(row.memo || '').trim()
      };
    });
  }

  function renderManualRows() {
    const tbodyManual = qs('manualRowsTbody');
    if (!tbodyManual) return;
    if (!manualRows.length) {
      tbodyManual.innerHTML = '<tr data-empty-row="1"><td colspan="5" class="text-center text-muted py-3">No manual rows added.</td></tr>';
      updateDraftTotalsIndicator();
      return;
    }

    tbodyManual.innerHTML = manualRows.map(function (row, index) {
      return ''
        + '<tr data-manual-row-index="' + index + '">'
        +   '<td><div class="fw-bold font-monospace">' + htmlEscape(row.debitAccountCode || row.debitAccountId || '-') + '</div><div class="small text-muted">' + htmlEscape(row.debitAccountName || '-') + '</div></td>'
        +   '<td><div class="fw-bold font-monospace">' + htmlEscape(row.creditAccountCode || row.creditAccountId || '-') + '</div><div class="small text-muted">' + htmlEscape(row.creditAccountName || '-') + '</div></td>'
        +   '<td class="fw-bold">' + Number(row.amount || 0).toFixed(2) + ' ' + htmlEscape(row.currency || 'CAD') + '</td>'
        +   '<td class="small">' + htmlEscape(row.memo || '-') + '</td>'
        +   '<td class="text-end"><button type="button" class="btn btn-outline-danger btn-sm" data-remove-manual-row="' + index + '">Remove</button></td>'
        + '</tr>';
    }).join('');

    tbodyManual.querySelectorAll('button[data-remove-manual-row]').forEach(function (button) {
      button.addEventListener('click', function () {
        const idx = Number(button.getAttribute('data-remove-manual-row'));
        if (!Number.isInteger(idx) || idx < 0 || idx >= manualRows.length) return;
        manualRows.splice(idx, 1);
        renderManualRows();
      });
    });
    updateDraftTotalsIndicator();
  }

  function renderDraftTransactionRows(rows) {
    const tbodyDraft = qs('draftTransactionsTbody');
    const draftRows = Array.isArray(rows) ? rows : [];
    if (!tbodyDraft) return;
    if (!draftRows.length) {
      tbodyDraft.innerHTML = '<tr><td colspan="5" class="text-center text-muted py-3">No draft transaction rows available.</td></tr>';
      return;
    }

    tbodyDraft.innerHTML = draftRows.map(function (row) {
      const amount = Number(row?.amount || 0);
      return ''
        + '<tr data-draft-row-index="' + Number(row?.rowIndex || 0) + '">'
        +   '<td><div class="form-check"><input class="form-check-input draft-include" type="checkbox" checked></div></td>'
        +   '<td>'
        +     '<div class="fw-bold font-monospace draft-debit-account-code">' + htmlEscape(row?.debitAccount?.code || row?.debitAccount?.id || '-') + '</div>'
        +     '<div class="small text-muted draft-debit-account-name">' + htmlEscape(row?.debitAccount?.name || '-') + '</div>'
        +     '<input type="hidden" class="draft-debit-account-id" value="' + htmlEscape(String(row?.debitAccount?.id || '')) + '">'
        +     '<button type="button" class="btn btn-outline-secondary btn-sm mt-1 draft-change-debit-account"><i class="bi bi-search me-1"></i>Change</button>'
        +   '</td>'
        +   '<td>'
        +     '<div class="fw-bold font-monospace draft-credit-account-code">' + htmlEscape(row?.creditAccount?.code || row?.creditAccount?.id || '-') + '</div>'
        +     '<div class="small text-muted draft-credit-account-name">' + htmlEscape(row?.creditAccount?.name || '-') + '</div>'
        +     '<input type="hidden" class="draft-credit-account-id" value="' + htmlEscape(String(row?.creditAccount?.id || '')) + '">'
        +     '<button type="button" class="btn btn-outline-secondary btn-sm mt-1 draft-change-credit-account"><i class="bi bi-search me-1"></i>Change</button>'
        +   '</td>'
        +   '<td><div class="input-group input-group-sm"><input type="number" class="form-control draft-amount" min="0.01" step="0.01" value="' + Number(amount.toFixed(2)) + '"><span class="input-group-text">' + htmlEscape(row?.currency || 'CAD') + '</span></div></td>'
        +   '<td><input type="text" class="form-control form-control-sm draft-memo" value="' + htmlEscape(row?.memo || '') + '" placeholder="Memo"></td>'
        + '</tr>';
    }).join('');

    document.querySelectorAll('#draftTransactionsTbody .draft-include, #draftTransactionsTbody .draft-amount').forEach(function (el) {
      el.addEventListener('change', updateDraftTotalsIndicator);
      el.addEventListener('input', updateDraftTotalsIndicator);
    });
    bindDraftRowAccountPickers();
    updateDraftTotalsIndicator();
  }

  function resetChargeModalState() {
