                method: 'DELETE',
                headers: { 'Content-Type': 'application/json', 'x-ajax-request': 'true', 'Accept': 'application/json' },
                body: JSON.stringify({ actionStateId })
            });
            const result = await res.json().catch(() => ({}));
            if (!res.ok || result.status !== 'success') throw new Error(result.message || 'Failed to delete student case.');
            await refreshStudentCases();
            hideStudentCaseBusy();
            return showStudentCaseMessage('Case Deleted', result.message || 'Student case deleted.', 'success');
        } catch (error) {
            hideStudentCaseBusy();
            throw error;
