    async function confirmSessionNavigation(title, message, confirmButtonText) {
        const msg = message || 'You may lose unsaved changes unless you save first. Continue?';
        const confirmLabel = confirmButtonText || 'Continue';
        if (typeof showMessageModal === 'function') {
            const res = await showMessageModal({
                title: title || 'Leave this page?',
                icon: 'question',
                message: msg,
                buttons: [
                    { text: 'Stay', class: 'btn-secondary' },
                    { text: confirmLabel, class: 'btn-primary' }
                ]
            });
            return res === confirmLabel;
        }
        return window.confirm(msg);
    }

    document.querySelectorAll('a.session-manager-nav-away').forEach((link) => {
        link.addEventListener('click', async (e) => {
            e.preventDefault();
            const title = link.getAttribute('data-confirm-title') || 'Leave this page?';
            const message = link.getAttribute('data-confirm-message') || '';
            const ok = await confirmSessionNavigation(title, message);
            if (!ok) return;
            const href = link.getAttribute('href');
            if (link.id === 'linkAttendanceMatrix' || link.id === 'linkGradesMatrix') {
                const matrixHref = link.getAttribute('data-matrix-href') || href;
                const isNarrow = window.matchMedia('(max-width: 768px)').matches;
                if (isNarrow) {
                    window.location.href = matrixHref;
