    function wouldBlockCompletionStatus(statusCode) {
        if (!isSessionCompletionStatus(statusCode)) return false;
        const target = normalizeStatusCode(statusCode);
        const saved = normalizeStatusCode(sessionInitialStatusCode);
        if (target === saved && isSessionCompletionStatus(saved)) return false;
        return getUnsubmittedSessionReports().length > 0;
