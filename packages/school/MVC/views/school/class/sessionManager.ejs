<style>
    .session-manager-page { --session-sidebar-w: 260px; --session-sidebar-collapsed-w: 72px; --session-topbar-h: auto; }
    .att-label { background-color: transparent; border: 1px solid transparent; color: #adb5bd; transition: all 0.2s ease-in-out; }
    .att-label:hover { background-color: #f8f9fa; color: #495057; }
    .btn-check[value="present"]:checked + .att-label { background-color: #198754; color: #fff; font-weight: bold; }
    .btn-check[value="late"]:checked + .att-label { background-color: #ffc107; color: #000; font-weight: bold; }
    .btn-check[value="excused"]:checked + .att-label { background-color: #0dcaf0; color: #000; font-weight: bold; }
    .btn-check[value="absent"]:checked + .att-label { background-color: #dc3545; color: #fff; font-weight: bold; }
    .btn-check[value="not_applicable"]:checked + .att-label { background-color: #6c757d; color: #fff; font-weight: bold; }
    .conduct-rating-input {
        max-width: 7rem;
        text-align: center;
        font-weight: 700;
        border-radius: 10px;
    }
    .conduct-rating-input:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 0.18rem rgba(37, 99, 235, 0.12);
    }
    .conduct-rating-help {
        color: #64748b;
        font-size: 0.75rem;
        line-height: 1.25;
    }

    .comment-thread { max-height: 250px; overflow-y: auto; background: #f8f9fa; border-radius: 6px; padding: 10px; }
    .comment-bubble { background: #fff; border: 1px solid #e9ecef; border-radius: 8px; padding: 10px; margin-bottom: 10px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
    .comment-author { font-weight: bold; font-size: 0.8rem; color: #495057; }
    .comment-time { font-size: 0.7rem; color: #adb5bd; float: right; }
    .mention-badge { background-color: #e7f1ff; color: #0d6efd; font-size: 0.75rem; padding: 2px 6px; border-radius: 12px; font-weight: bold; border: 1px solid #b6d4fe; }

    .session-summary-card {
        border: 1px solid #e6ecf5;
        border-radius: 12px;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        padding: 10px 12px;
    }
    .session-summary-label { color: #6c757d; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; }
    .session-summary-value { color: #1f2a37; font-size: 1.1rem; font-weight: 700; line-height: 1.1; }

    /* Page header: match term edit — title row + dashboard; second row for other actions */
    .session-manager-toolbar-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-end;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }
    .session-manager-toolbar-row .btn-save-session,
    .session-manager-toolbar-row .btn-close-session {
        min-width: 7.5rem;
        font-weight: 600;
    }

    .session-manager-quick-nav {
        margin-bottom: 1rem;
    }
    .session-manager-class-nav {
        display: inline-flex;
        flex-direction: column;
        align-items: stretch;
        min-width: min(100%, 280px);
    }
    .session-manager-class-nav-toggle {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        width: 100%;
        padding: 0.62rem 0.95rem;
        border: 1px solid #a5b4fc;
        border-radius: 12px;
        background: linear-gradient(135deg, #ffffff 0%, #eef2ff 55%, #e0e7ff 100%);
        color: #312e81;
        font-weight: 700;
        text-align: left;
        box-shadow: 0 6px 18px rgba(79, 70, 229, 0.14);
        transition: border-color 0.15s ease, box-shadow 0.15s ease, transform 0.15s ease;
    }
    .session-manager-class-nav-toggle:hover:not(:disabled) {
        border-color: #818cf8;
        box-shadow: 0 8px 22px rgba(79, 70, 229, 0.2);
        transform: translateY(-1px);
        color: #1e1b4b;
    }
    .session-manager-class-nav-toggle[aria-expanded="true"] {
        border-bottom-left-radius: 0;
        border-bottom-right-radius: 0;
        border-bottom-color: #c7d2fe;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.1);
    }
    .session-manager-class-nav-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2rem;
        height: 2rem;
        border-radius: 9px;
        background: rgba(99, 102, 241, 0.14);
        color: #4338ca;
        flex-shrink: 0;
    }
    .session-manager-class-nav-copy {
        display: flex;
        flex-direction: column;
        gap: 0.1rem;
        min-width: 0;
        flex: 1;
    }
    .session-manager-class-nav-title {
        font-size: 0.92rem;
        line-height: 1.2;
    }
    .session-manager-class-nav-sub {
        font-size: 0.72rem;
        font-weight: 600;
        color: #6366f1;
        letter-spacing: 0.02em;
    }
    .session-class-nav-chevron {
        transition: transform 0.2s ease;
        font-size: 0.9em;
        color: #6366f1;
        flex-shrink: 0;
    }
    .session-manager-class-nav-toggle[aria-expanded="true"] .session-class-nav-chevron {
        transform: rotate(180deg);
    }
    .session-manager-class-nav-links {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
        padding: 0.55rem;
        border: 1px solid #a5b4fc;
        border-top: 1px solid #c7d2fe;
        border-radius: 0 0 12px 12px;
        background: #fff;
        box-shadow: 0 10px 24px rgba(79, 70, 229, 0.1);
    }
    .session-manager-class-nav-link {
        display: flex;
        align-items: center;
        gap: 0.55rem;
        padding: 0.55rem 0.7rem;
        border-radius: 9px;
        text-decoration: none;
        font-weight: 600;
        font-size: 0.9rem;
        color: #1e293b;
        border: 1px solid transparent;
        transition: background 0.14s ease, border-color 0.14s ease, color 0.14s ease;
    }
    .session-manager-class-nav-link:hover {
        background: #f8fafc;
        border-color: #e2e8f0;
        color: #1d4ed8;
    }
    .session-manager-class-nav-link i {
        font-size: 1rem;
        opacity: 0.9;
    }
    .session-manager-class-nav-link--outcomes {
        color: #166534;
    }
    .session-manager-class-nav-link--outcomes:hover {
        background: #f0fdf4;
        border-color: #bbf7d0;
        color: #15803d;
    }

    /* Info card: collapsible header + expandable detail tiles */
    .session-manager-info-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #dbe3ef !important;
        border-radius: 14px;
        overflow: hidden;
    }
    .session-info-header {
        display: flex;
        align-items: stretch;
        gap: 0.65rem;
        padding: 0.7rem 0.85rem;
        flex-wrap: wrap;
    }
    .session-info-details-toggle {
        flex: 1 1 240px;
        min-width: 0;
        display: flex;
        align-items: center;
        gap: 0.55rem;
        border: 1px solid #e2e8f0;
        border-radius: 11px;
        background: #fff;
        padding: 0.55rem 0.75rem;
        text-align: left;
        color: #0f172a;
        cursor: pointer;
        transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }
    .session-info-details-toggle:focus-visible {
        outline: 2px solid rgba(59, 130, 246, 0.45);
        outline-offset: 2px;
    }
    .session-info-details-toggle:hover {
        border-color: #cbd5e1;
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.06);
    }
    .session-info-details-toggle[aria-expanded="true"] {
        border-color: #93c5fd;
        background: #f8fbff;
        box-shadow: inset 0 0 0 1px rgba(59, 130, 246, 0.12);
    }
    .session-info-summary {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.3rem 0.45rem;
        flex: 1;
        min-width: 0;
        font-size: 0.84rem;
        font-weight: 600;
        color: #334155;
        line-height: 1.3;
    }
    .session-info-summary-class {
        color: #1d4ed8;
        max-width: 11rem;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        font-weight: 700;
    }
    .session-info-summary-sep {
        color: #cbd5e1;
        font-weight: 400;
    }
    .session-info-summary-chip {
        display: inline-flex;
        align-items: center;
        gap: 0.25rem;
        padding: 0.12rem 0.45rem;
        border-radius: 999px;
        background: #f1f5f9;
        border: 1px solid #e2e8f0;
        font-size: 0.78rem;
        font-weight: 600;
        color: #475569;
        white-space: nowrap;
    }
    .session-info-summary-chip.is-muted:empty {
        display: none;
    }
    .session-info-expand-meta {
        display: flex;
        flex-direction: column;
        align-items: flex-end;
        gap: 0.05rem;
        flex-shrink: 0;
    }
    .session-info-expand-label {
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #64748b;
        font-weight: 700;
    }
    .session-info-expand-chevron {
        font-size: 0.95rem;
        color: #64748b;
        transition: transform 0.2s ease;
    }
    .session-info-details-toggle[aria-expanded="true"] .session-info-expand-chevron {
        transform: rotate(180deg);
    }
    .session-info-status-slot {
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        min-width: min(100%, 210px);
        flex: 0 1 210px;
        padding: 0.45rem 0.55rem;
        border-radius: 11px;
        border: 2px solid #f59e0b;
        background: linear-gradient(180deg, #fffbeb 0%, #fff 100%);
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.12);
    }
    .session-info-status-slot-label {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.35rem;
        font-size: 0.65rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: #b45309;
        font-weight: 700;
        line-height: 1.2;
    }
    .session-info-status-slot .session-status-button {
        margin-top: 0;
        min-height: 2.35rem;
        font-size: 0.9rem;
    }
    .session-info-details-body {
        padding: 0 0.85rem 0.85rem;
        border-top: 1px solid #e8edf4;
        margin-top: 0;
        padding-top: 0.85rem;
    }
    .session-manager-info-card .card-body {
        padding: 0;
    }
    .session-info-grid,
    .session-info-meta-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 0.65rem;
    }
    .session-info-meta-grid {
        margin-top: 0.85rem;
        padding-top: 0.85rem;
        border-top: 1px solid #e8edf4;
    }
    .session-info-tile {
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 0.7rem 0.85rem;
        min-width: 0;
        box-shadow: 0 1px 2px rgba(15, 23, 42, 0.04);
    }
    .session-info-tile--accent {
        background: linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
        border-color: #c7d7f5;
    }
    .session-info-tile--location {
        grid-column: 1 / -1;
    }
    @media (min-width: 992px) {
        .session-info-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
        }
    }
    .session-info-tile-value-with-badge {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        min-width: 0;
    }
    .session-class-info-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.35rem;
        height: 1.35rem;
        padding: 0;
        border: none;
        border-radius: 999px;
        background: #dbeafe;
        color: #1d4ed8;
        flex-shrink: 0;
        line-height: 1;
        cursor: help;
    }
    .session-class-info-badge:hover,
    .session-class-info-badge:focus-visible {
        background: #bfdbfe;
        color: #1e3a8a;
        outline: none;
        box-shadow: 0 0 0 2px rgba(59, 130, 246, 0.25);
    }
    .session-class-info-badge.is-danger {
        background: #fee2e2;
        color: #b91c1c;
    }
    .session-class-info-badge.is-danger:hover,
    .session-class-info-badge.is-danger:focus-visible {
        background: #fecaca;
        color: #991b1b;
        box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.25);
    }
    .session-class-info-badge i {
        font-size: 0.82rem;
    }
    .session-info-tile--status-required {
        border-color: #fbbf24;
        background: linear-gradient(180deg, #fffbeb 0%, #ffffff 100%);
        box-shadow: 0 0 0 1px rgba(245, 158, 11, 0.12);
    }
    .session-status-required-badge {
        font-size: 0.62rem;
        letter-spacing: 0.04em;
        vertical-align: middle;
    }
    .session-status-required-hint {
        font-size: 0.72rem;
        color: #b45309;
        font-weight: 600;
        margin-top: 0.2rem;
        line-height: 1.25;
    }
    .session-info-tile .session-status-button {
        margin-top: 0.15rem;
    }
    .session-status-button--action-required:not(:disabled) {
        border-width: 2px !important;
        box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.22), inset 0 1px 2px rgba(15, 23, 42, 0.05);
        animation: session-status-attention 2.4s ease-in-out infinite;
    }
    @keyframes session-status-attention {
        0%, 100% { box-shadow: 0 0 0 3px rgba(245, 158, 11, 0.18), inset 0 1px 2px rgba(15, 23, 42, 0.05); }
        50% { box-shadow: 0 0 0 6px rgba(245, 158, 11, 0.28), inset 0 1px 2px rgba(15, 23, 42, 0.05); }
    }
    .session-info-tile-label {
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.07em;
        color: #64748b;
        font-weight: 700;
        margin-bottom: 0.35rem;
        line-height: 1.2;
    }
    .session-info-tile-value {
        font-size: 1.02rem;
        font-weight: 700;
        color: #0f172a;
        line-height: 1.35;
        word-break: break-word;
    }
    .session-info-tile-value-sm {
        font-size: 0.92rem;
        font-weight: 600;
    }
    .session-info-tile-muted {
        color: #94a3b8;
        font-weight: 600;
    }
    .session-info-tile #sessionRoom,
    .session-info-tile #sessionDate,
    .session-info-tile #sessionStartTime,
    .session-info-tile #sessionEndTime,
    .session-info-tile #sessionTeacherName {
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-weight: 600;
        font-size: 0.95rem;
        color: #0f172a;
        background: #fff;
        margin-top: 0.1rem;
    }
    .session-info-tile #sessionRoom:focus,
    .session-info-tile #sessionDate:focus,
    .session-info-tile #sessionStartTime:focus,
    .session-info-tile #sessionEndTime:focus,
    .session-info-tile #sessionTeacherName:focus {
        border-color: #3b82f6;
        box-shadow: 0 0 0 0.15rem rgba(59, 130, 246, 0.15);
    }
    .session-manager-info-card .info-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        font-weight: 600;
        margin-bottom: 0.15rem;
    }
    .session-manager-info-card .info-value {
        font-size: 0.95rem;
        font-weight: 600;
        color: #0f172a;
        line-height: 1.25;
    }
    .session-status-button {
        width: 100%;
        max-width: 100%;
        font-weight: 600;
        font-size: 0.875rem;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 0.45rem 0.7rem;
        box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.05);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem;
        text-align: left;
    }
    .session-status-modal-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
        gap: 0.75rem;
    }
    .session-status-option-btn {
        border-radius: 14px;
        min-height: 76px;
        text-align: left;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        font-weight: 700;
        box-shadow: 0 10px 22px rgba(15, 23, 42, 0.08);
        transition: transform 0.14s ease, box-shadow 0.14s ease;
    }
    .session-status-option-btn:hover,
    .session-status-option-btn:focus {
        transform: translateY(-1px);
        box-shadow: 0 14px 28px rgba(15, 23, 42, 0.12);
    }
    .session-status-option-btn.is-selected {
        outline: 3px solid rgba(13, 110, 253, 0.25);
    }
    .session-manager-field-placeholder {
        min-height: calc(1.5em + 0.75rem + 2px);
        border: 1px dashed #e2e8f0;
        border-radius: 8px;
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        color: #94a3b8;
    }

    .session-exam-open-switch {
        min-height: 1.75rem;
        padding-top: 0.15rem;
    }
    .session-exam-open-switch .form-check-input {
        width: 2.25rem;
        height: 1.15rem;
        cursor: pointer;
    }
    .session-exam-open-switch .form-check-label {
        cursor: pointer;
        color: #334155;
        font-weight: 600;
    }

    /* Shell + sidebar */
    .session-manager-shell {
        display: flex;
        align-items: stretch;
        gap: 0;
        min-height: 60vh;
    }
    .session-manager-sidebar {
        flex: 0 0 var(--session-sidebar-w);
        width: var(--session-sidebar-w);
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px 0 0 12px;
        display: flex;
        flex-direction: column;
        transition: width 0.22s ease, flex-basis 0.22s ease;
        overflow: hidden;
    }
    .session-manager-sidebar.collapsed {
        flex-basis: var(--session-sidebar-collapsed-w);
        width: var(--session-sidebar-collapsed-w);
    }
    .session-manager-sidebar-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.5rem 0.5rem 0.5rem 0.65rem;
        border-bottom: 1px solid #f1f5f9;
        background: #fafbfc;
    }
    .session-manager-sidebar-nav {
        flex: 1;
        padding: 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        overflow-y: auto;
    }
    .session-manager-nav-item {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        width: 100%;
        text-align: left;
        border: none;
        background: transparent;
        border-radius: 10px;
        padding: 0.65rem 0.75rem;
        font-weight: 600;
        font-size: 0.9rem;
        color: #475569;
        transition: background 0.15s ease, color 0.15s ease;
    }
    .session-manager-nav-item:hover:not(:disabled) { background: #f1f5f9; color: #0f172a; }
    .session-manager-nav-item.active { background: #e0ecff; color: #1d4ed8; }
    .session-manager-nav-item:disabled { opacity: 0.45; cursor: not-allowed; }
    .session-manager-sidebar.collapsed .session-manager-nav-label { display: none; }
    .session-manager-sidebar.collapsed .session-manager-nav-item { justify-content: center; padding: 0.65rem; }
    .session-manager-sidebar.collapsed .session-manager-sidebar-head .session-manager-nav-label { display: none; }

    .session-manager-main {
        flex: 1;
        min-width: 0;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-left: none;
        border-radius: 0 12px 12px 0;
        padding: 1rem 1.15rem 1.25rem;
    }
    @media (max-width: 991.98px) {
        .session-manager-shell { flex-direction: column; }
        .session-manager-sidebar {
            flex-basis: auto;
            width: 100%;
            border-radius: 12px 12px 0 0;
            border-bottom: none;
            flex-direction: row;
            flex-wrap: wrap;
            align-items: center;
        }
        .session-manager-sidebar.collapsed { width: 100%; flex-basis: auto; }
        .session-manager-sidebar-nav {
            flex-direction: row;
            flex-wrap: wrap;
            width: 100%;
            padding: 0.35rem;
        }
        .session-manager-nav-item { flex: 1 1 auto; min-width: 120px; justify-content: center; }
        .session-manager-main { border-radius: 0 0 12px 12px; border: 1px solid #e2e8f0; border-top: none; }
    }

    .session-panel { display: none; animation: sessionPanelIn 0.2s ease; }
    .session-panel.active { display: block; }
    .session-inactive-workspace .session-panel { display: none !important; }
    @keyframes sessionPanelIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

    .session-placeholder-card {
        border: 2px dashed #e2e8f0;
        border-radius: 12px;
        padding: 2.5rem 1.5rem;
        text-align: center;
        color: #64748b;
        background: #fafbfc;
    }

    .session-gradebook-card .gb-activity-body {
        white-space: pre-wrap;
        font-size: 0.9rem;
        max-height: 220px;
        overflow-y: auto;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 0.75rem 1rem;
    }
    .session-gradebook-card .gb-score-input:disabled {
        background: #f1f5f9;
        cursor: not-allowed;
    }
    .session-gradebook-card .gb-collapse-toggle {
        flex-shrink: 0;
        line-height: 1;
        color: #64748b;
    }
    .session-gradebook-card .gb-collapse-toggle:hover {
        color: #1d4ed8;
        background: #f1f5f9 !important;
    }
</style>

<div class="sections-page session-manager-page">
    <% const disabledAttr = isReadOnly ? 'disabled' : ''; %>
    <% function jsonForScript(value) {
        if (value === undefined) return 'undefined';
        const s = JSON.stringify(value);
        if (s === undefined) return 'null';
        return s.replace(/</g, '\\u003c').replace(/\u2028/g, '\\u2028').replace(/\u2029/g, '\\u2029').replace(/&/g, '\\u0026');
    } %>
    <%
        const sessionRatingValue = (value) => {
            const n = Number(value);
            if (!Number.isFinite(n)) return 100;
            return Math.max(0, Math.min(100, Math.round(n * 100) / 100));
        };
        const statusRows = Array.isArray(sessionStatusMeta) ? sessionStatusMeta : [];
        const activeStatusRows = statusRows.filter((row) => row && row.active !== false);
        const availableStatusRows = activeStatusRows.length ? activeStatusRows : statusRows;
        const fallbackStatusCode = String(defaultSessionStatusCode || availableStatusRows.find((row) => row?.code === 'scheduled')?.code || availableStatusRows[0]?.code || 'scheduled').toLowerCase();
        const normalizeStatusCode = (value) => String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
        const attendanceSummary = (session.roster || []).reduce((acc, row) => {
            const rawKey = String(row?.attendance || '').trim().toLowerCase();
            const key = (rawKey === 'n/a' || rawKey === 'na') ? 'not_applicable' : rawKey;
            if (Object.prototype.hasOwnProperty.call(acc, key)) acc[key] += 1;
            return acc;
        }, { present: 0, late: 0, excused: 0, absent: 0, not_applicable: 0 });
        const normalizedSessionStatus = normalizeStatusCode(session.status || fallbackStatusCode);
        const currentSessionStatus = availableStatusRows.some((row) => normalizeStatusCode(row?.code) === normalizedSessionStatus)
            ? normalizedSessionStatus
            : fallbackStatusCode;
        const currentSessionStatusMeta = availableStatusRows.find((row) => normalizeStatusCode(row?.code) === currentSessionStatus) || null;
        const isMakeupRequiredInactive = currentSessionStatusMeta && currentSessionStatusMeta.makeUpRequired === true;
        const canCreateMakeupSession = !isReadOnly && currentSessionStatusMeta && currentSessionStatusMeta.makeUpRequired === true;
        const existingMakeupHistory = Array.isArray(session.makeupHistory) ? session.makeupHistory : [];
        const isMakeupSession = session.makeup && session.makeup.isMakeup === true;
        const workDisabledAttr = (isReadOnly || isMakeupRequiredInactive) ? 'disabled' : '';
        const attendanceMatrixHref = '/school/attendances?classId=' + encodeURIComponent(classData.id) + '&range=allTime';
        const gradesMatrixHref = '/school/grades-matrix?classId=' + encodeURIComponent(classData.id) + '&range=allTime';
        const smRegMode = String(classData.registrationMode || 'term_based').trim().toLowerCase();
        const smIsRolling = smRegMode === 'rolling';
        const smCycleStart = String(classData.cycleStartDate || '').trim();
        const smCycleEnd = String(classData.cycleEndDate || '').trim();
        const smCycleWindowLabel = smIsRolling
            ? (smCycleStart ? `${smCycleStart}${smCycleEnd ? ' to ' + smCycleEnd : ' onward'}` : 'Cycle start date missing')
            : '';
        const smSessionDate = String(session.date || '').trim();
        const smSessionOutsideCycle = smIsRolling
            && smCycleStart
            && (smSessionDate < smCycleStart || (smCycleEnd && smSessionDate > smCycleEnd));
        const finalGradesNavHref = smIsRolling
            ? '/school/classes/' + encodeURIComponent(classData.id) + '/enrollment-outcomes'
            : '/school/classes/' + encodeURIComponent(classData.id) + '/final-grades';
        const finalGradesNavLabel = smIsRolling ? 'Enrollment outcomes' : 'Final Grades';
        const smCycleTooltipText = smIsRolling
            ? (smSessionOutsideCycle
                ? 'This session date is outside the rolling cycle window. Update the class cycle dates or rebuild the session ledger before saving session changes.'
                : `Rolling sessions are limited to the cycle window: ${smCycleWindowLabel}.`)
            : '';
        const smRoomLabel = String(session.room || '').trim();
        const smTeacherLabel = String(session.delivery?.deliveredByName || session.delivery?.deliveredBy || '').trim();
        const smCurrentStatusLabel = String(currentSessionStatusMeta?.label || currentSessionStatus || 'Scheduled').trim();
        const canEditSessionMetadataFlag = typeof canEditSessionMetadata !== 'undefined' && canEditSessionMetadata === true;
    %>

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <h1 class="page-heading size-md m-0 text-start"><i class="bi bi-journal-check me-2 text-primary"></i>Manage Session</h1>
        <a href="<%= schoolSectionDashboardHref %>" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md session-manager-nav-away" id="linkSessionDashboard" data-confirm-title="Go to dashboard?" data-confirm-message="Leave this page and go to the school dashboard? Unsaved changes will be lost unless you save first."><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
    </div>

    <div class="session-manager-quick-nav">
        <div class="session-manager-class-nav">
            <button
                type="button"
                class="session-manager-class-nav-toggle"
                id="btnToggleSessionClassNav"
                data-bs-toggle="collapse"
                data-bs-target="#sessionManagerClassNavCollapse"
                aria-expanded="false"
                aria-controls="sessionManagerClassNavCollapse">
                <span class="session-manager-class-nav-icon" aria-hidden="true"><i class="bi bi-box-arrow-up-right"></i></span>
                <span class="session-manager-class-nav-copy">
                    <span class="session-manager-class-nav-title">Class navigation</span>
                    <span class="session-manager-class-nav-sub">Outcomes &amp; matrices</span>
                </span>
                <i class="bi bi-chevron-down session-class-nav-chevron" aria-hidden="true"></i>
            </button>
            <div class="collapse" id="sessionManagerClassNavCollapse">
                <div class="session-manager-class-nav-links">
                    <a href="<%= finalGradesNavHref %>" class="session-manager-class-nav-link session-manager-class-nav-link--outcomes session-manager-nav-away" id="linkFinalGradesNav" data-confirm-title="Leave session manager?" data-confirm-message="Open <%= finalGradesNavLabel %>? Unsaved changes on this page will be lost unless you save first."><i class="bi bi-award"></i><%= finalGradesNavLabel %></a>
                    <a href="<%= attendanceMatrixHref %>" class="session-manager-class-nav-link session-manager-nav-away" id="linkAttendanceMatrix" data-matrix-href="<%= attendanceMatrixHref %>" data-confirm-title="Open attendance matrix?" data-confirm-message="Open the attendance matrix? Unsaved changes on this page will be lost unless you save first."><i class="bi bi-grid-3x3"></i>Attendance matrix</a>
                    <a href="<%= gradesMatrixHref %>" class="session-manager-class-nav-link session-manager-nav-away" id="linkGradesMatrix" data-matrix-href="<%= gradesMatrixHref %>" data-confirm-title="Open grades matrix?" data-confirm-message="Open the grades matrix? Unsaved changes on this page will be lost unless you save first."><i class="bi bi-table"></i>Grades matrix</a>
                </div>
            </div>
        </div>
    </div>

    <div class="session-manager-toolbar-row">
        <div class="btn-group shadow-sm">
            <% if (prevSessionId) { %>
                <a href="/school/classes/<%= classData.id %>/sessions/<%= prevSessionId %>" class="btn btn-outline-primary bg-grey btn-md session-manager-nav-away" id="linkPrevSession" title="Previous session" data-confirm-title="Open previous session?" data-confirm-message="Leave this page and open the previous class session? Unsaved changes will be lost unless you save first."><i class="bi bi-chevron-left"></i></a>
            <% } else { %>
                <button type="button" class="btn btn-outline-secondary bg-light btn-md" disabled><i class="bi bi-chevron-left"></i></button>
            <% } %>
            <% if (nextSessionId) { %>
                <a href="/school/classes/<%= classData.id %>/sessions/<%= nextSessionId %>" class="btn btn-outline-primary bg-grey btn-md session-manager-nav-away" id="linkNextSession" title="Next session" data-confirm-title="Open next session?" data-confirm-message="Leave this page and open the next class session? Unsaved changes will be lost unless you save first."><i class="bi bi-chevron-right"></i></a>
            <% } else { %>
                <button type="button" class="btn btn-outline-secondary bg-light btn-md" disabled><i class="bi bi-chevron-right"></i></button>
            <% } %>
        </div>
        <% if (canCreateMakeupSession) { %>
            <button type="button" class="btn btn-outline-warning btn-md fw-semibold shadow-md" id="btnCreateMakeupSession"><i class="bi bi-calendar-plus me-1"></i>Create make-up session</button>
        <% } %>
        <% if (!isReadOnly) { %>
            <button type="button" class="btn btn-primary btn-md btn-filled btn-save-session shadow-md" id="btnSaveSession"><i class="bi bi-save me-1"></i>Save session</button>
        <% } %>
        <button type="button" class="btn btn-warning btn-md btn-filled btn-close-session" id="btnCloseSessionManager"><i class="bi bi-x-lg me-1"></i>Close</button>
    </div>

    <div class="card session-manager-info-card shadow-sm mb-3">
        <div class="session-info-header">
            <div
                class="session-info-details-toggle"
                id="btnToggleSessionInfoDetails"
                role="button"
                tabindex="0"
                data-bs-toggle="collapse"
                data-bs-target="#sessionInfoDetailsCollapse"
                aria-expanded="false"
                aria-controls="sessionInfoDetailsCollapse">
                <div class="session-info-summary">
                    <span class="session-info-summary-class text-truncate" title="<%= classData.title %>"><%= classData.title %></span>
                    <% if (smIsRolling && smCycleTooltipText) { %>
                        <button
                            type="button"
                            class="session-class-info-badge<%= smSessionOutsideCycle ? ' is-danger' : '' %>"
                            data-bs-toggle="tooltip"
                            data-bs-placement="top"
                            title="<%= smCycleTooltipText %>"
                            aria-label="Rolling cycle window information"
                            onclick="event.stopPropagation();">
                            <i class="bi <%= smSessionOutsideCycle ? 'bi-exclamation-triangle-fill' : 'bi-info-circle-fill' %>" aria-hidden="true"></i>
                        </button>
                    <% } %>
                    <span class="session-info-summary-sep" aria-hidden="true">·</span>
                    <span class="session-info-summary-chip" id="sessionInfoSummaryDate"><i class="bi bi-calendar3 me-1" aria-hidden="true"></i><%= session.date %></span>
                    <span class="session-info-summary-chip" id="sessionInfoSummaryTime"><i class="bi bi-clock me-1" aria-hidden="true"></i><%= session.startTime %>–<%= session.endTime %></span>
                    <% if (smTeacherLabel) { %>
                        <span class="session-info-summary-chip d-none d-lg-inline-flex" id="sessionInfoSummaryTeacher" title="Teacher"><i class="bi bi-person-badge me-1" aria-hidden="true"></i><%= smTeacherLabel %></span>
                    <% } else if (canEditSessionMetadataFlag) { %>
                        <span class="session-info-summary-chip d-none d-lg-inline-flex is-muted" id="sessionInfoSummaryTeacher" title="Teacher"></span>
                    <% } %>
                    <% if (smIsRolling) { %>
                        <span class="session-info-summary-chip d-none d-md-inline-flex" title="Cycle window"><i class="bi bi-arrow-repeat me-1" aria-hidden="true"></i><%= smCycleWindowLabel %></span>
                    <% } %>
                    <span class="session-info-summary-chip session-info-summary-chip--location<%= smRoomLabel ? '' : ' is-muted' %>" id="sessionInfoSummaryLocation" title="Location"><% if (smRoomLabel) { %><i class="bi bi-geo-alt me-1" aria-hidden="true"></i><%= smRoomLabel %><% } %></span>
                </div>
                <span class="session-info-expand-meta">
                    <span class="session-info-expand-label">Details</span>
                    <i class="bi bi-chevron-down session-info-expand-chevron" aria-hidden="true"></i>
                </span>
            </div>
            <div class="session-info-status-slot">
                <div class="session-info-status-slot-label">
                    <span>Session status</span>
                    <span class="badge bg-warning text-dark session-status-required-badge">Required</span>
                </div>
                <button type="button" id="sessionStatusButton" class="btn session-status-button session-status-button--action-required" <%= disabledAttr ? 'disabled' : '' %>>
                    <span id="sessionStatusButtonLabel"><%= smCurrentStatusLabel %></span>
                    <i class="bi bi-pencil-square" aria-hidden="true"></i>
                </button>
                <select id="sessionStatusSelect" class="d-none" aria-hidden="true" tabindex="-1" <%= disabledAttr ? 'disabled' : '' %>>
                    <% availableStatusRows.forEach((statusRow) => { %>
                        <% const statusCode = normalizeStatusCode(statusRow?.code); %>
                        <% if (statusCode) { %>
                            <option
                                value="<%= statusCode %>"
                                data-label="<%= statusRow?.label || statusCode %>"
                                data-color-bg="<%= statusRow?.colorBg || '#e2e3e5' %>"
                                data-color-text="<%= statusRow?.colorText || '#41464b' %>"
                                data-color-border="<%= statusRow?.colorBorder || '#c6c8ca' %>"
                                <%= currentSessionStatus === statusCode ? 'selected' : '' %>>
                                <%= statusRow?.label || statusCode %>
                            </option>
                        <% } %>
                    <% }) %>
                </select>
                <div id="sessionPendingReportsHint" class="small text-warning mt-1 d-none" role="status"></div>
            </div>
        </div>
        <div class="collapse" id="sessionInfoDetailsCollapse">
            <div class="session-info-details-body">
                <div class="session-info-grid">
                    <div class="session-info-tile session-info-tile--accent">
                        <div class="session-info-tile-label">Class</div>
                        <div class="session-info-tile-value session-info-tile-value-with-badge">
                            <span class="text-truncate" title="<%= classData.title %>"><%= classData.title %></span>
                            <% if (smIsRolling && smCycleTooltipText) { %>
                                <button
                                    type="button"
                                    class="session-class-info-badge<%= smSessionOutsideCycle ? ' is-danger' : '' %>"
                                    data-bs-toggle="tooltip"
                                    data-bs-placement="top"
                                    title="<%= smCycleTooltipText %>"
                                    aria-label="Rolling cycle window information">
                                    <i class="bi <%= smSessionOutsideCycle ? 'bi-exclamation-triangle-fill' : 'bi-info-circle-fill' %>" aria-hidden="true"></i>
                                </button>
                            <% } %>
                        </div>
                    </div>
                    <div class="session-info-tile">
                        <div class="session-info-tile-label">Date</div>
                        <% if (canEditSessionMetadataFlag) { %>
                            <input type="date" id="sessionDate" class="form-control form-control-sm" value="<%= session.date || '' %>" <%- disabledAttr %>>
                        <% } else { %>
                            <div class="session-info-tile-value"><%= session.date %></div>
                        <% } %>
                    </div>
                    <div class="session-info-tile">
                        <div class="session-info-tile-label">Time</div>
                        <% if (canEditSessionMetadataFlag) { %>
                            <div class="d-flex gap-2 flex-wrap">
                                <input type="time" id="sessionStartTime" class="form-control form-control-sm" value="<%= session.startTime || '' %>" aria-label="Start time" <%- disabledAttr %>>
                                <input type="time" id="sessionEndTime" class="form-control form-control-sm" value="<%= session.endTime || '' %>" aria-label="End time" <%- disabledAttr %>>
                            </div>
                        <% } else { %>
                            <div class="session-info-tile-value text-nowrap"><%= session.startTime %> – <%= session.endTime %></div>
                        <% } %>
                    </div>
                    <% if (canEditSessionMetadataFlag) { %>
                    <div class="session-info-tile">
                        <div class="session-info-tile-label">Teacher</div>
                        <input type="hidden" id="sessionTeacherId" value="<%= session.delivery?.deliveredBy || '' %>">
                        <div class="input-group input-group-sm">
                            <input type="text" class="form-control bg-white" id="sessionTeacherName" value="<%= session.delivery?.deliveredByName || session.delivery?.deliveredBy || '' %>" readonly placeholder="Select teacher" <%- disabledAttr %>>
                            <button type="button" class="btn btn-outline-primary" id="sessionPickTeacher" <%= disabledAttr ? 'disabled' : '' %> aria-label="Pick teacher"><i class="bi bi-person-check"></i></button>
                        </div>
                    </div>
                    <% } else if (smTeacherLabel) { %>
                    <div class="session-info-tile">
                        <div class="session-info-tile-label">Teacher</div>
                        <div class="session-info-tile-value text-truncate" title="<%= smTeacherLabel %>"><%= smTeacherLabel %></div>
                    </div>
                    <% } %>
                    <% if (smIsRolling) { %>
                    <div class="session-info-tile session-info-tile--cycle">
                        <div class="session-info-tile-label">Cycle window</div>
                        <div class="session-info-tile-value text-nowrap"><%= smCycleWindowLabel %></div>
                    </div>
                    <% } %>
                    <div class="session-info-tile session-info-tile--location">
                        <label class="session-info-tile-label mb-0" for="sessionRoom">Location</label>
                        <input type="text" id="sessionRoom" class="form-control form-control-sm" value="<%= session.room || '' %>" placeholder="Room, lab, field…" <%- disabledAttr %> autocomplete="off">
                    </div>
                </div>
                <div class="session-info-meta-grid">
                    <div class="session-info-tile">
                        <div class="session-info-tile-label">Make-up</div>
                        <div class="session-info-tile-value session-info-tile-value-sm">
                            <% if (isMakeupSession) { %>
                                <span><i class="bi bi-arrow-return-left me-1 text-warning"></i>For <%= session.makeup.originalSessionId || 'original session' %></span>
                            <% } else if (existingMakeupHistory.length) { %>
                                <span><i class="bi bi-calendar-check me-1 text-success"></i><%= existingMakeupHistory.length %> created</span>
                            <% } else if (canCreateMakeupSession) { %>
                                <span><i class="bi bi-calendar-plus me-1 text-warning"></i>Available</span>
                            <% } else { %>
                                <span class="session-info-tile-muted">Not required</span>
                            <% } %>
                        </div>
                    </div>
                    <div class="session-info-tile">
                        <div class="session-info-tile-label">Reserved</div>
                        <div class="session-info-tile-value session-info-tile-value-sm session-info-tile-muted">—</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <% if (isSessionLocked) { %>
        <div class="alert alert-warning border-warning shadow-sm d-flex align-items-center mb-3">
            <i class="bi bi-lock-fill fs-3 me-3 text-warning"></i>
            <div>
                <h6 class="fw-bold mb-1">Session Locked</h6>
                <div class="small">
                    <% if (isReadOnly) { %>
                        This session has been locked by an administrator. You can view the details, but modifications are disabled.
                    <% } else { %>
                        This session is locked, but you have administrative override permissions to make changes.
                    <% } %>
                </div>
            </div>
        </div>
    <% } %>
    <% if (isMakeupRequiredInactive) { %>
        <div class="alert alert-warning border-warning shadow-sm d-flex align-items-start mb-3">
            <i class="bi bi-calendar-plus fs-3 me-3 text-warning"></i>
            <div>
                <h6 class="fw-bold mb-1">Original session requires a make-up</h6>
                <div class="small">
                    This session is inactive for attendance, class conduct, gradebook, content, student cases, and file work because its current status requires a make-up session.
                    Create or open the make-up session to complete instructional work.
                </div>
                <% if (existingMakeupHistory.length) { %>
                    <div class="small mt-2">
                        <strong>Existing make-up session(s):</strong>
                        <%= existingMakeupHistory.map((row) => row.makeupSessionId || row.sessionId || '').filter(Boolean).join(', ') %>
                    </div>
                <% } %>
            </div>
        </div>
    <% } %>

    <div class="session-manager-shell" id="sessionManagerShell">
        <aside class="session-manager-sidebar" id="sessionManagerSidebar" aria-label="Session sections">
            <div class="session-manager-sidebar-head w-100">
                <span class="session-manager-nav-label small fw-bold text-secondary text-uppercase" style="letter-spacing:0.06em;">Sections</span>
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" id="btnToggleSessionSidebar" title="Collapse sidebar" aria-expanded="true" aria-controls="sessionManagerSidebar">
                    <i class="bi bi-layout-sidebar-inset" id="sessionSidebarToggleIcon"></i>
                </button>
            </div>
            <nav class="session-manager-sidebar-nav" role="tablist">
                <button type="button" class="session-manager-nav-item active" data-session-panel="attendance" role="tab" aria-selected="true" <%= isMakeupRequiredInactive ? 'disabled title="Inactive original session"' : '' %>>
                    <i class="bi bi-people-fill fs-5"></i><span class="session-manager-nav-label">Attendance</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="conduct" role="tab" aria-selected="false" <%= isMakeupRequiredInactive ? 'disabled title="Inactive original session"' : '' %>>
                    <i class="bi bi-person-hearts fs-5"></i><span class="session-manager-nav-label">Class Conduct</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="session" role="tab" aria-selected="false" <%= isMakeupRequiredInactive ? 'disabled title="Inactive original session"' : '' %>>
                    <i class="bi bi-journal-text fs-5"></i><span class="session-manager-nav-label">Session &amp; notes</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="curriculum" role="tab" aria-selected="false" <%= isMakeupRequiredInactive ? 'disabled title="Inactive original session"' : '' %>>
                    <i class="bi bi-book fs-5"></i><span class="session-manager-nav-label">Curriculum</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="content" title="<%= isMakeupRequiredInactive ? 'Inactive original session' : 'Coming soon' %>" <%= isMakeupRequiredInactive ? 'disabled' : '' %>>
                    <i class="bi bi-folder2-open fs-5"></i><span class="session-manager-nav-label">Content</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="assignments" <%= isMakeupRequiredInactive ? 'disabled title="Inactive original session"' : '' %>>
                    <i class="bi bi-clipboard-check fs-5"></i><span class="session-manager-nav-label">Reports</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="student-cases" <%= isMakeupRequiredInactive ? 'disabled title="Inactive original session"' : '' %>>
                    <i class="bi bi-folder-check fs-5"></i><span class="session-manager-nav-label">Student Cases</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="gradebook" title="<%= isMakeupRequiredInactive ? 'Inactive original session' : 'Coming soon' %>" <%= isMakeupRequiredInactive ? 'disabled' : '' %>>
                    <i class="bi bi-journal-bookmark fs-5"></i><span class="session-manager-nav-label">Grade book</span>
                </button>
            </nav>
        </aside>

        <main class="session-manager-main <%= isMakeupRequiredInactive ? 'session-inactive-workspace' : '' %>">
            <% if (isMakeupRequiredInactive) { %>
                <div class="session-placeholder-card">
                    <i class="bi bi-calendar-plus fs-1 text-warning d-block mb-3"></i>
                    <h5 class="fw-bold text-dark mb-2">Instructional work is paused for this original session</h5>
                    <p class="text-muted mb-3">
                        Attendance, class conduct, gradebook, content, assignments, and student cases belong on the make-up session, not this original session.
                    </p>
                    <% if (canCreateMakeupSession) { %>
                        <button type="button" class="btn btn-warning fw-bold" id="btnCreateMakeupSessionInline"><i class="bi bi-calendar-plus me-1"></i>Create make-up session</button>
                    <% } %>
                </div>
            <% } %>
            <div class="session-panel active" id="session-panel-attendance" role="tabpanel">
                <div class="row g-2 mb-3">
                    <div class="col-6 col-md">
                        <div class="session-summary-card h-100">
                            <div class="session-summary-label">Present</div>
                            <div class="session-summary-value text-success"><%= attendanceSummary.present %></div>
                        </div>
                    </div>
                    <div class="col-6 col-md">
                        <div class="session-summary-card h-100">
                            <div class="session-summary-label">Late</div>
                            <div class="session-summary-value text-warning"><%= attendanceSummary.late %></div>
                        </div>
                    </div>
                    <div class="col-6 col-md">
                        <div class="session-summary-card h-100">
                            <div class="session-summary-label">Excused</div>
                            <div class="session-summary-value text-info"><%= attendanceSummary.excused %></div>
                        </div>
                    </div>
                    <div class="col-6 col-md">
                        <div class="session-summary-card h-100">
                            <div class="session-summary-label">Absent</div>
                            <div class="session-summary-value text-danger"><%= attendanceSummary.absent %></div>
                        </div>
                    </div>
                    <div class="col-6 col-md">
                        <div class="session-summary-card h-100">
                            <div class="session-summary-label">N/A</div>
                            <div class="session-summary-value text-secondary"><%= attendanceSummary.not_applicable %></div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <h5 class="m-0 fw-bold text-primary"><i class="bi bi-people-fill me-2"></i>Attendance roster</h5>
                        <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                            <% if (!isReadOnly && session.roster.length > 0) { %>
                                <div class="btn-group btn-group-sm" role="group" aria-label="Bulk attendance">
                                    <button type="button" class="btn btn-outline-success" id="btnAllPresent">All Present</button>
                                    <button type="button" class="btn btn-outline-warning" id="btnAllLate">All Late</button>
                                    <button type="button" class="btn btn-outline-danger" id="btnAllAbsent">All Absent</button>
                                    <button type="button" class="btn btn-outline-secondary" id="btnAllNotApplicable">All N/A</button>
                                </div>
                            <% } %>
                            <span class="badge bg-light text-dark border"><%= session.roster.length %> Students</span>
                        </div>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: min(70vh, 700px); overflow-y: auto;">
                            <table class="table table-hover align-middle mb-0" id="attendanceTable">
                                <thead class="table-light position-sticky top-0" style="z-index: 1;">
                                    <tr>
                                        <th class="ps-4">Student Name</th>
                                        <th style="min-width: 280px;">Attendance Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (session.roster.length === 0) { %>
                                        <tr><td colspan="2" class="text-center py-4 text-muted">No active students enrolled.</td></tr>
                                    <% } else { %>
                                        <% session.roster.forEach((student, i) => { %>
                                            <tr class="roster-row" data-personid="<%= student.personId %>">
                                                <td class="ps-4 fw-bold align-middle">
                                                    <%= student.name %>
                                                    <% if (student.comments && student.comments.length > 0) { %>
                                                        <i class="bi bi-chat-dots-fill text-primary ms-1" style="font-size: 0.75rem;" title="Notes Exist"></i>
                                                    <% } %>
                                                </td>
                                                <td class="pe-3 py-3">
                                                    <div class="d-flex gap-2 align-items-center flex-wrap">
                                                        <div class="btn-group btn-group-sm flex-grow-1" role="group">
                                                            <input type="radio" class="btn-check att-radio" name="att_<%= i %>" id="p_<%= i %>" value="present" <%= student.attendance === 'present' ? 'checked' : '' %> <%- disabledAttr %>>
                                                            <label class="btn att-label" for="p_<%= i %>" title="Present"><i class="bi bi-check-lg me-1"></i>Present</label>
                                                            <input type="radio" class="btn-check att-radio" name="att_<%= i %>" id="l_<%= i %>" value="late" <%= student.attendance === 'late' ? 'checked' : '' %> <%- disabledAttr %>>
                                                            <label class="btn att-label" for="l_<%= i %>" title="Late"><i class="bi bi-clock-history"></i> Late</label>
                                                            <input type="radio" class="btn-check att-radio" name="att_<%= i %>" id="e_<%= i %>" value="excused" <%= student.attendance === 'excused' ? 'checked' : '' %> <%- disabledAttr %>>
                                                            <label class="btn att-label" for="e_<%= i %>" title="Excused Absence"><i class="bi bi-envelope-paper"></i> Excused</label>
                                                            <input type="radio" class="btn-check att-radio" name="att_<%= i %>" id="a_<%= i %>" value="absent" <%= student.attendance === 'absent' ? 'checked' : '' %> <%- disabledAttr %>>
                                                            <label class="btn att-label" for="a_<%= i %>" title="Absent"><i class="bi bi-x-lg"></i> Absent</label>
                                                            <input type="radio" class="btn-check att-radio" name="att_<%= i %>" id="na_<%= i %>" value="not_applicable" <%= (student.attendance === 'not_applicable' || student.attendance === 'N/A' || student.attendance === 'n/a') ? 'checked' : '' %> <%- disabledAttr %>>
                                                            <label class="btn att-label" for="na_<%= i %>" title="Not applicable"><i class="bi bi-dash-circle"></i> N/A</label>
                                                        </div>
                                                        <% const hasDetails = student.lateMinutes || student.earlyLeaveMinutes || student.excuseRef || student.excuseAttachment || (student.comments && student.comments.length > 0); %>
                                                        <% if (!isReadOnly) { %>
                                                        <button type="button" class="btn btn-sm btn-outline-primary btn-open-student-case" title="Open student case" data-person-id="<%= student.personId %>" data-student-name="<%= student.name.replace(/'/g, "\\'") %>">
                                                            <i class="bi bi-folder-plus"></i>
                                                        </button>
                                                        <% } %>
                                                        <button type="button"
                                                                class="btn btn-sm btn-details <%= hasDetails ? 'btn-warning text-dark' : 'btn-outline-secondary' %>"
                                                                title="Notes / Excuses / Mentions"
                                                                onclick="openDetailsModal('<%= student.personId %>', '<%= student.name.replace(/'/g, "\\'") %>')">
                                                            <i class="bi <%= hasDetails ? 'bi-sticky-fill' : 'bi-three-dots' %>"></i>
                                                        </button>
                                                    </div>
                                                    <input type="hidden" class="att-late" value="<%= student.lateMinutes || '' %>">
                                                    <input type="hidden" class="att-leave" value="<%= student.earlyLeaveMinutes || '' %>">
                                                    <input type="hidden" class="att-excuse" value="<%= student.excuseRef || '' %>">
                                                    <input type="hidden" class="att-excuse-attachment" value='<%- JSON.stringify(student.excuseAttachment || null).replace(/</g, "\\u003c").replace(/'/g, "&#39;") %>'>
                                                    <input type="hidden" class="att-comments" value='<%- JSON.stringify(student.comments || []).replace(/</g, "\\u003c").replace(/'/g, "&#39;") %>'>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="session-panel" id="session-panel-conduct" role="tabpanel">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <h5 class="m-0 fw-bold text-primary"><i class="bi bi-person-hearts me-2"></i>Class Conduct</h5>
                            <div class="conduct-rating-help mt-1">Values default to 100%. Adjust only when a student's effort, participation, or respect needs a different session rating.</div>
                        </div>
                        <span class="badge bg-light text-dark border"><%= session.roster.length %> Students</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive" style="max-height: min(70vh, 700px); overflow-y: auto;">
                            <table class="table table-hover align-middle mb-0" id="conductTable">
                                <thead class="table-light position-sticky top-0" style="z-index: 1;">
                                    <tr>
                                        <th class="ps-4">Student Name</th>
                                        <th class="text-center">Class Effort</th>
                                        <th class="text-center">Class Participation</th>
                                        <th class="text-center">Respects The Teachers</th>
                                        <th class="text-center pe-4">Treats Other Students With Respect</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (session.roster.length === 0) { %>
                                        <tr><td colspan="5" class="text-center py-4 text-muted">No active students enrolled.</td></tr>
                                    <% } else { %>
                                        <% session.roster.forEach((student) => { %>
                                            <tr class="conduct-row" data-personid="<%= student.personId %>">
                                                <td class="ps-4 fw-bold align-middle">
                                                    <%= student.name %>
                                                    <div class="small text-muted font-monospace"><%= student.personId %></div>
                                                </td>
                                                <td class="text-center">
                                                    <input type="number" class="form-control form-control-sm conduct-rating-input mx-auto conduct-class-effort" min="0" max="100" step="1" value="<%= sessionRatingValue(student.classEffortPercent) %>" <%- disabledAttr %>>
                                                </td>
                                                <td class="text-center">
                                                    <input type="number" class="form-control form-control-sm conduct-rating-input mx-auto conduct-class-participation" min="0" max="100" step="1" value="<%= sessionRatingValue(student.classParticipationPercent) %>" <%- disabledAttr %>>
                                                </td>
                                                <td class="text-center">
                                                    <input type="number" class="form-control form-control-sm conduct-rating-input mx-auto conduct-respects-teachers" min="0" max="100" step="1" value="<%= sessionRatingValue(student.respectsTeachersPercent) %>" <%- disabledAttr %>>
                                                </td>
                                                <td class="text-center pe-4">
                                                    <input type="number" class="form-control form-control-sm conduct-rating-input mx-auto conduct-respects-students" min="0" max="100" step="1" value="<%= sessionRatingValue(student.respectsStudentsPercent) %>" <%- disabledAttr %>>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="session-panel" id="session-panel-session" role="tabpanel">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="m-0 fw-bold text-primary"><i class="bi bi-journal-text me-2"></i>Session &amp; notes</h5>
                        <div class="small text-muted mt-1">Edit <strong>location</strong> and <strong>session status</strong> in the summary card above. Notes below are saved with <strong>Save session</strong> in the header.</div>
                    </div>
                    <div class="card-body">
                        <div class="mb-0">
                            <label class="form-label fw-bold">Teacher notes / homework</label>
                            <textarea id="sessionNotes" class="form-control" rows="8" placeholder="Log what was covered today..." <%- disabledAttr %>><%= session.notes %></textarea>
                        </div>
                        <% if (isReadOnly) { %>
                            <p class="small text-muted mb-0 mt-3"><i class="bi bi-lock-fill me-1"></i>This session is read-only.</p>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="session-panel" id="session-panel-curriculum" role="tabpanel">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3">
                        <h5 class="m-0 fw-bold text-primary"><i class="bi bi-book me-2"></i>Curriculum reference</h5>
                    </div>
                    <div class="card-body p-0">
                        <% if (classSubjects.length === 0) { %>
                            <div class="p-4 text-center text-muted small">No subjects assigned to this class.</div>
                        <% } else { %>
                            <div class="accordion accordion-flush" id="curriculumAccordion">
                                <% classSubjects.forEach((sub, i) => { %>
                                    <div class="accordion-item">
                                        <h2 class="accordion-header" id="heading_<%= i %>">
                                            <button class="accordion-button <%= i===0 ? '' : 'collapsed' %> fw-bold bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#collapse_<%= i %>">
                                                <%= sub.code %>: <%= sub.name %>
                                            </button>
                                        </h2>
                                        <div id="collapse_<%= i %>" class="accordion-collapse collapse <%= i===0 ? 'show' : '' %>" data-bs-parent="#curriculumAccordion">
                                            <div class="accordion-body small">
                                                <p class="text-muted mb-2"><%= sub.description %></p>
                                                <% if(sub.modules && sub.modules.length > 0) { %>
                                                    <ul class="list-group list-group-flush border-top mt-2 pt-2">
                                                        <% sub.modules.forEach(mod => { %>
                                                            <li class="list-group-item px-0 py-1 bg-transparent text-dark"><i class="bi bi-check2-circle text-success me-2"></i><%= mod.title %></li>
                                                        <% }) %>
                                                    </ul>
                                                <% } %>
                                            </div>
                                        </div>
                                    </div>
                                <% }) %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <div class="session-panel" id="session-panel-content" role="tabpanel">
                <div class="card border-0 shadow-sm mb-3">
                    <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between gap-2 flex-wrap">
                        <h5 class="m-0 fw-bold text-primary"><i class="bi bi-folder2-open me-2"></i>Session content</h5>
                        <% if (!isReadOnly) { %>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-outline-primary btn-sm" id="btnAddHtmlContent"><i class="bi bi-filetype-html me-1"></i>Add HTML</button>
                            <button type="button" class="btn btn-outline-primary btn-sm" id="btnAddFileContent"><i class="bi bi-paperclip me-1"></i>Add file</button>
                        </div>
                        <% } %>
                    </div>
                    <div class="card-body">
                        <div class="small text-muted mb-2">Items are delivered in order. Allocated exams are included automatically for this session.</div>
                        <div id="sessionContentList"></div>
                    </div>
                </div>
            </div>
            <div class="session-panel" id="session-panel-assignments" role="tabpanel">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <h5 class="m-0 fw-bold text-primary"><i class="bi bi-clipboard-check me-2"></i>Report instances</h5>
                            <div class="small text-muted mt-1">Concrete report instances for this session (one row per student or class target). Use <strong>Open V2</strong> or <strong>Start</strong> to fill out reports. To change assignment settings (teachers, dates, scope), use <strong>Reports → Assignments</strong>.</div>
                        </div>
                        <button type="button" class="btn btn-outline-secondary btn-sm flex-shrink-0" id="btnRefreshSessionReportInstances"><i class="bi bi-arrow-clockwise me-1"></i>Refresh</button>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Report</th>
                                        <th>Student / target</th>
                                        <th>Teacher</th>
                                        <th>Status</th>
                                        <th class="pe-4 text-end">Action</th>
                                    </tr>
                                </thead>
                                <tbody id="sessionReportInstancesBody">
                                    <tr><td colspan="5" class="text-center py-4 text-muted">No report instances for this session, or none visible for your account.</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="session-panel" id="session-panel-student-cases" role="tabpanel">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-start flex-wrap gap-2">
                        <div>
                            <h5 class="m-0 fw-bold text-primary"><i class="bi bi-folder-check me-2"></i>Student Cases</h5>
                            <div class="small text-muted mt-1">Open a case only when a student needs extra reflection, support, or office follow-up. Attendance details stay in the attendance panel.</div>
                        </div>
                        <span class="badge bg-light text-dark border" id="studentCasesCountBadge">0 Cases</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover align-middle mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th class="ps-4">Student</th>
                                        <th>Category</th>
                                        <th>Severity</th>
                                        <th>Status</th>
                                        <th>Summary</th>
                                        <th>Updated</th>
                                        <th class="text-end pe-4">Actions</th>
                                    </tr>
                                </thead>
                                <tbody id="studentCasesTableBody">
                                    <tr><td colspan="7" class="text-center py-4 text-muted">No student cases for this session.</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>            <div class="session-panel" id="session-panel-gradebook" role="tabpanel">
                <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-2">
                    <h5 class="m-0 fw-bold text-primary"><i class="bi bi-journal-bookmark me-2"></i>Session gradebook</h5>
                    <% if (!isReadOnly) { %>
                    <button type="button" class="btn btn-primary btn-sm" id="btnOpenGradebookModal"><i class="bi bi-plus-lg me-1"></i>Add activity</button>
                    <% } %>
                </div>
                <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
                    <p class="small text-muted mb-0 flex-grow-1">Add activities (name, skill focus, total points, instructions). Scores follow the <strong>attendance roster</strong>; <strong>absent</strong> and <strong>N/A</strong> show N/A. Save attendance with <strong>Save session</strong> before saving scores if you changed who was present.</p>
                    <% if (!isReadOnly) { %>
                    <button type="button" class="btn btn-success btn-sm flex-shrink-0" id="btnSaveGradebooks"><i class="bi bi-check2-circle me-1"></i>Save gradebook</button>
                    <% } %>
                </div>
                <div id="sessionGradebooksList"></div>
            </div>
        </main>
    </div>
</div>

<div class="modal fade" id="attendanceDetailsModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold">
                    <i class="bi bi-person-lines-fill me-2"></i>
                    Details: <span id="modalStudentName"></span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="modalPersonId">

                <div class="row g-3 mb-2">
                    <div class="col-md-4">
                        <label class="form-label fw-bold small">Late Arrival (Mins)</label>
                        <input type="number" class="form-control" id="modalLateMins" placeholder="e.g. 15" min="0" <%- disabledAttr %>>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold small">Left Early (Mins)</label>
                        <input type="number" class="form-control" id="modalLeaveMins" placeholder="e.g. 30" min="0" <%- disabledAttr %>>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold small">Excuse / reference notes</label>
                        <div class="row g-2 align-items-start">
                            <div class="col-md-8">
                                <textarea class="form-control" id="modalExcuseRef" rows="3" placeholder="Add details..." <%- disabledAttr %>></textarea>
                            </div>
                            <div class="col-md-4">
                                <input type="file" class="form-control form-control-sm" id="modalExcuseFile" <%- disabledAttr %>>
                                <div class="small text-muted mt-1">Attach supporting file if needed.</div>
                            </div>
                        </div>
                        <div class="small mt-2" id="modalExcuseAttachmentPreview"></div>
                    </div>
                    <div class="col-12">
                        <p class="small text-muted mb-0" id="attendanceMatrixThresholdHint"></p>
                    </div>
                </div>

                <div class="mb-2">
                    <label class="fw-bold text-primary"><i class="bi bi-chat-text me-1"></i> Admin & Teacher Notes</label>
                    <div class="comment-thread mb-3" id="det_commentsThread">
                    </div>

                    <div class="border rounded p-2 bg-white shadow-sm">
                        <div class="d-flex flex-wrap gap-1 mb-2" id="pendingMentionsArea"></div>
                        <textarea class="form-control border-0 bg-transparent p-0 mb-2" id="inp_newComment" rows="2" placeholder="Write a note or tag someone..."></textarea>
                        <input type="file" class="form-control form-control-sm mb-2" id="inp_newCommentFile" <%- disabledAttr %>>
                        <div class="d-flex justify-content-between align-items-center border-top pt-2">
                            <button class="btn btn-sm btn-outline-secondary" id="btn_mentionUser"><i class="bi bi-at"></i> Tag User</button>
                            <button class="btn btn-sm btn-primary fw-bold" id="btn_saveComment">Save Note Directly</button>
                        </div>
                    </div>
                </div>

            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <% if (!isReadOnly) { %>
                    <button type="button" class="btn btn-primary fw-bold" id="btnSaveDetails">Apply Time/Excuse</button>
                <% } %>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="gradebookActivityModal" tabindex="-1" aria-labelledby="gradebookActivityModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="gradebookActivityModalTitle"><i class="bi bi-journal-plus me-2"></i>Add activity</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="gbModalEditId" value="">
                <div class="mb-3">
                    <label class="form-label fw-bold" for="gbModalName">Activity name</label>
                    <input type="text" class="form-control" id="gbModalName" maxlength="200" placeholder="e.g. Unit 3 quiz" autocomplete="off">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold" for="gbModalSkill">Skill focus</label>
                    <input type="text" class="form-control" id="gbModalSkill" maxlength="500" placeholder="e.g. Reading comprehension" autocomplete="off">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold" for="gbModalTotal">Total score (points)</label>
                    <input type="number" class="form-control" id="gbModalTotal" min="0.01" step="any" placeholder="e.g. 20">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold" for="gbModalContent">Activity content / instructions</label>
                    <textarea class="form-control" id="gbModalContent" rows="10" placeholder="Describe the activity, expectations, or paste instructions..."></textarea>
                </div>
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" id="gbModalInclude" checked>
                    <label class="form-check-label" for="gbModalInclude">Include in grade calculation</label>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary fw-bold" id="gbModalSaveBtn">Save activity</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="sessionContentModal" tabindex="-1" aria-labelledby="sessionContentModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold" id="sessionContentModalTitle"><i class="bi bi-folder2-open me-2"></i>Session Content</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="contentModalEditId" value="">
                <input type="hidden" id="contentModalType" value="">
                <div class="row g-3">
                    <div class="col-md-8">
                        <label class="form-label fw-bold" for="contentModalTitleInput">Title</label>
                        <input type="text" class="form-control" id="contentModalTitleInput" maxlength="200" placeholder="Content title">
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold" for="contentModalTimeInput">Time (optional)</label>
                        <input type="time" class="form-control" id="contentModalTimeInput">
                    </div>
                    <div class="col-12" id="contentModalHtmlWrap">
                        <label class="form-label fw-bold" for="contentModalHtmlInput">HTML Content</label>
                        <textarea class="form-control" id="contentModalHtmlInput" rows="9" placeholder="Paste HTML content"></textarea>
                    </div>
                    <div class="col-12 d-none" id="contentModalFileWrap">
                        <label class="form-label fw-bold" for="contentModalFileUrlInput">File link or uploaded file</label>
                        <input type="url" class="form-control mb-2" id="contentModalFileUrlInput" placeholder="Paste an external link, or upload a file below">
                        <input type="file" class="form-control" id="contentModalFileInput">
                        <div class="form-text">Uploaded files are stored in the School class workspace.</div>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold" for="contentModalNotesInput">Notes (optional)</label>
                        <textarea class="form-control" id="contentModalNotesInput" rows="3" placeholder="Short notes for this content item"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary fw-bold" id="contentModalSaveBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="studentCaseModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="bi bi-folder-plus me-2"></i><span id="studentCaseModalTitle">Student Case</span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="studentCaseId">
                <input type="hidden" id="studentCasePersonId">
                <div class="alert alert-light border small mb-3" id="studentCaseContext"></div>
                <div class="row g-3">
                    <div class="col-md-3"><label class="form-label fw-bold" for="studentCaseCategory">Category</label><select class="form-select" id="studentCaseCategory"><option value="learning">Learning</option><option value="technology">Technology</option><option value="engagement">Engagement</option><option value="behavior">Behavior</option><option value="support">Additional Support</option><option value="resources">Resources</option><option value="lesson_delivery">Lesson Delivery</option><option value="other">Other</option></select></div>
                    <div class="col-md-3"><label class="form-label fw-bold" for="studentCaseSeverity">Severity</label><select class="form-select" id="studentCaseSeverity"><option value="info">Info</option><option value="warning">Warning</option><option value="urgent">Urgent</option></select></div>
                    <div class="col-md-6"><label class="form-label fw-bold" for="studentCaseSummary">Summary</label><input type="text" class="form-control" id="studentCaseSummary" maxlength="260" placeholder="Short reason for opening this case"></div>
                    <div class="col-12"><label class="form-label fw-bold" for="studentCaseDetails">Issue / support details</label><textarea class="form-control" id="studentCaseDetails" rows="4" maxlength="5000" placeholder="Describe what happened, what support is needed, or what office/admin should know."></textarea></div>
                </div>
            </div>
            <div class="modal-footer bg-light d-flex justify-content-between flex-wrap gap-2"><button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button><div class="d-flex flex-wrap gap-2"><button type="button" class="btn btn-outline-success fw-bold" id="btnResolveStudentCase"><i class="bi bi-check2-circle me-1"></i>Save &amp; Resolve</button><button type="button" class="btn btn-primary fw-bold" id="btnSaveStudentCase"><i class="bi bi-save me-1"></i>Save Case</button></div></div>
        </div>
    </div>
</div>
<%- include('partials/modal_GenericPicker') %>

<script>
let detailsModalInstance = null;
let currentMentions = [];

document.addEventListener('DOMContentLoaded', () => {
    const actionStateId = <%- jsonForScript((typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '') %>;
    const defaultSessionStatusCode = <%- jsonForScript(fallbackStatusCode) %>;
    const sessionInitialStatusCode = <%- jsonForScript(currentSessionStatus) %>;
    const sessionManagerClassId = <%- jsonForScript(classData.id) %>;
    const sessionManagerSessionId = <%- jsonForScript(session.sessionId) %>;
    const sessionStatusMeta = <%- jsonForScript(availableStatusRows || []) %>;
    const sessionMakeupHistory = <%- jsonForScript(existingMakeupHistory || []) %>;
    const sessionCanCreateMakeup = <%- jsonForScript(Boolean(canCreateMakeupSession)) %>;
    const sessionInstructionalInactive = <%- jsonForScript(Boolean(isMakeupRequiredInactive)) %>;
    const sessionDefaultTeacherId = <%- jsonForScript(session.delivery?.deliveredBy || '') %>;
    const sessionDefaultTeacherName = <%- jsonForScript(session.delivery?.deliveredByName || '') %>;
    const sessionDefaultRoom = <%- jsonForScript(session.room || '') %>;
    const sessionDefaultDate = <%- jsonForScript(session.date || '') %>;
    const sessionDefaultStartTime = <%- jsonForScript(session.startTime || '') %>;
    const sessionDefaultEndTime = <%- jsonForScript(session.endTime || '') %>;
    const sessionCanEditMetadata = <%- jsonForScript(Boolean(canEditSessionMetadataFlag)) %>;
    const normalizeStatusCode = (value) => String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
    const sessionStatusMap = new Map((sessionStatusMeta || []).map((row) => [normalizeStatusCode(row.code), row]));
    const resolveStatusMeta = (statusCode) => sessionStatusMap.get(normalizeStatusCode(statusCode)) || null;
    const attendanceAttachmentEscape = (value) => String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    function parseAttendanceAttachment(value) {
        if (!value) return null;
        if (typeof value === 'object') return value;
        try {
            const parsed = JSON.parse(String(value || 'null'));
            return parsed && typeof parsed === 'object' ? parsed : null;
        } catch (_error) {
            return null;
        }
    }
    async function uploadSchoolSessionFile(input, category, personId = '') {
        const file = input?.files && input.files[0];
        if (!file) return null;
        const body = new FormData();
        body.append('kind', category || 'file');
        body.append('classId', sessionManagerClassId);
        body.append('sessionId', sessionManagerSessionId);
        if (personId) body.append('studentPersonId', personId);
        body.append('actionStateId', actionStateId);
        body.append('file', file);
        const res = await fetch(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/files/upload`, {
            method: 'POST',
            headers: { 'X-AJAX-Request': 'true' },
            body
        });
        const result = await res.json().catch(() => null);
        if (!res.ok || !result || result.status !== 'success') {
            throw new Error(result?.message || 'File upload failed.');
        }
        return result.file || null;
    }
    function renderAttendanceAttachmentLink(attachment, emptyText = '') {
        const att = parseAttendanceAttachment(attachment);
        if (!att) return emptyText;
        const href = att.dataUrl || att.url || att.uploadUrl || att.storagePath || att.path || '';
        if (!href) return `<span class="text-muted">${attendanceAttachmentEscape(att.name || 'Attached file')}</span>`;
        return `<a href="${attendanceAttachmentEscape(href)}" target="_blank" rel="noopener" class="text-decoration-none"><i class="bi bi-paperclip me-1"></i>${attendanceAttachmentEscape(att.name || att.originalName || 'Open attachment')}</a>`;
    }
    window.parseAttendanceAttachment = parseAttendanceAttachment;
    window.renderAttendanceAttachmentLink = renderAttendanceAttachmentLink;

    function showMakeupMessage(options) {
        if (typeof window.showMessageModal === 'function') return window.showMessageModal(options || {});
        if (options?.message) window.alert(options.message);
        return Promise.resolve('');
    }

    function ensureMakeupSessionModal() {
        let modal = document.getElementById('makeupSessionModal');
        if (modal) return modal;
        modal = document.createElement('div');
        modal.className = 'modal fade';
        modal.id = 'makeupSessionModal';
        modal.tabIndex = -1;
        modal.setAttribute('aria-hidden', 'true');
        modal.innerHTML = [
            '<div class="modal-dialog modal-lg modal-dialog-scrollable">',
            '<div class="modal-content">',
            '<div class="modal-header bg-warning text-dark">',
            '<h5 class="modal-title fw-bold"><i class="bi bi-calendar-plus me-2"></i>Create Make-up Session</h5>',
            '<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>',
            '</div>',
            '<div class="modal-body">',
            '<div class="alert alert-light border small" id="makeupSessionContext"></div>',
            '<input type="hidden" id="makeupSessionTeacherId">',
            '<div class="row g-3">',
            '<div class="col-md-4"><label class="form-label fw-bold">Date</label><input type="date" class="form-control" id="makeupSessionDate"></div>',
            '<div class="col-md-4"><label class="form-label fw-bold">Start Time</label><input type="time" class="form-control" id="makeupSessionStart"></div>',
            '<div class="col-md-4"><label class="form-label fw-bold">End Time</label><input type="time" class="form-control" id="makeupSessionEnd"></div>',
            '<div class="col-md-6"><label class="form-label fw-bold">Teacher</label><div class="input-group"><input type="text" class="form-control bg-white" id="makeupSessionTeacherName" readonly><button type="button" class="btn btn-outline-primary" id="makeupSessionPickTeacher"><i class="bi bi-person-check"></i></button></div></div>',
            '<div class="col-md-6"><label class="form-label fw-bold">Location</label><input type="text" class="form-control" id="makeupSessionRoom" maxlength="200"></div>',
            '<div class="col-12"><label class="form-label fw-bold">Reason</label><textarea class="form-control" id="makeupSessionReason" rows="3" maxlength="1000" placeholder="Why is this make-up session needed?"></textarea></div>',
            '</div>',
            '</div>',
            '<div class="modal-footer bg-light">',
            '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>',
            '<button type="button" class="btn btn-warning fw-bold" id="makeupSessionCreate"><i class="bi bi-calendar-plus me-1"></i>Create Make-up Session</button>',
            '</div>',
            '</div>',
            '</div>'
        ].join('');
        document.body.appendChild(modal);
        modal.querySelector('#makeupSessionPickTeacher')?.addEventListener('click', function () {
            if (!window.GenericPicker || !window.GenericPickerPresets) {
                showMakeupMessage({ title: 'Teacher Picker', icon: 'warning', message: 'Teacher picker is not available yet.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
                return;
            }
            window.GenericPicker.open(window.GenericPickerPresets.teacher({
                title: 'Select Make-up Teacher',
                placeholder: 'Search teachers...',
                context: window.GenericPickerContexts
                    ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
                    : undefined,
                onSelect: function (item) {
                    const id = String(item?.id || item?.personId || item?.value || '').trim();
                    const name = String(item?.name || item?.label || [item?.firstName, item?.lastName].filter(Boolean).join(' ') || id).trim();
                    modal.querySelector('#makeupSessionTeacherId').value = id;
                    modal.querySelector('#makeupSessionTeacherName').value = name;
                }
            }));
        });
        modal.querySelector('#makeupSessionCreate')?.addEventListener('click', createMakeupSessionFromModal);
        return modal;
    }

    function openMakeupSessionModal() {
        const modal = ensureMakeupSessionModal();
        modal.querySelector('#makeupSessionDate').value = '';
        modal.querySelector('#makeupSessionStart').value = sessionDefaultStartTime || '';
        modal.querySelector('#makeupSessionEnd').value = sessionDefaultEndTime || '';
        modal.querySelector('#makeupSessionTeacherId').value = sessionDefaultTeacherId || '';
        modal.querySelector('#makeupSessionTeacherName').value = sessionDefaultTeacherName || sessionDefaultTeacherId || '';
        modal.querySelector('#makeupSessionRoom').value = sessionDefaultRoom || '';
        modal.querySelector('#makeupSessionReason').value = '';
        const historyNote = sessionMakeupHistory.length
            ? '<div class="mt-2 text-warning"><i class="bi bi-exclamation-triangle me-1"></i>' + sessionMakeupHistory.length + ' make-up session(s) already exist for this original session.</div>'
            : '';
        modal.querySelector('#makeupSessionContext').innerHTML = '<strong>Original session:</strong> ' + attendanceAttachmentEscape(sessionManagerSessionId) + historyNote;
        if (window.bootstrap) window.bootstrap.Modal.getOrCreateInstance(modal).show();
    }

    async function createMakeupSessionFromModal() {
        const modal = ensureMakeupSessionModal();
        const button = modal.querySelector('#makeupSessionCreate');
        const oldHtml = button ? button.innerHTML : '';
        const payload = {
            date: modal.querySelector('#makeupSessionDate')?.value || '',
            startTime: modal.querySelector('#makeupSessionStart')?.value || '',
            endTime: modal.querySelector('#makeupSessionEnd')?.value || '',
            teacherId: modal.querySelector('#makeupSessionTeacherId')?.value || '',
            teacherName: modal.querySelector('#makeupSessionTeacherName')?.value || '',
            room: modal.querySelector('#makeupSessionRoom')?.value || '',
            reason: modal.querySelector('#makeupSessionReason')?.value || '',
            actionStateId
        };
        if (!payload.date) {
            await showMakeupMessage({ title: 'Date Required', icon: 'warning', message: 'Please select the make-up session date.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
            return;
        }
        try {
            if (button) {
                button.disabled = true;
                button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Creating...';
            }
            if (typeof window.showLoading === 'function') window.showLoading('Creating make-up session...');
            const submitMakeup = async (bodyPayload) => {
                const response = await fetch(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/makeup`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true', 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin',
                    body: JSON.stringify(bodyPayload)
                });
                const parsed = await response.json().catch(() => ({ status: 'error', message: 'Unable to read server response.' }));
                return { response, parsed };
            };
            let { response, parsed: result } = await submitMakeup(payload);
            if (result.status === 'warning' && result.code === 'MAKEUP_SESSION_WARNINGS') {
                const warningList = Array.isArray(result?.data?.warnings) && result.data.warnings.length
                    ? '<ul>' + result.data.warnings.map((w) => '<li>' + attendanceAttachmentEscape(w) + '</li>').join('') + '</ul>'
                    : '';
                if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
                const selected = await showMakeupMessage({
                    title: 'Review Make-up Warnings',
                    icon: 'warning',
                    message: (result.message || 'Review warnings before creating this make-up session.') + warningList,
                    buttons: [{ text: 'Cancel', class: 'btn-secondary' }, { text: 'Create Anyway', class: 'btn-warning' }]
                });
                if (selected !== 'Create Anyway') return;
                if (typeof window.showLoading === 'function') window.showLoading('Creating make-up session...');
                ({ response, parsed: result } = await submitMakeup({ ...payload, force: true }));
            }
            if (!response.ok || result.status !== 'success') throw new Error(result.message || 'Could not create make-up session.');
            if (window.bootstrap) window.bootstrap.Modal.getOrCreateInstance(modal).hide();
            const warnings = Array.isArray(result?.data?.warnings) && result.data.warnings.length
                ? '<hr><strong>Warnings</strong><ul>' + result.data.warnings.map((w) => '<li>' + attendanceAttachmentEscape(w) + '</li>').join('') + '</ul>'
                : '';
            const selected = await showMakeupMessage({
                title: 'Make-up Session Created',
                icon: result?.data?.warnings?.length ? 'warning' : 'success',
                message: (result.message || 'Make-up session created.') + warnings,
                buttons: [{ text: 'Open Make-up Session', class: 'btn-primary' }, { text: 'Close', class: 'btn-secondary' }]
            });
            const newSessionId = result?.data?.makeupSession?.sessionId;
            if (selected === 'Open Make-up Session' && newSessionId) {
                window.open(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(newSessionId))}`, '_blank', 'noopener');
            }
            window.location.reload();
        } catch (error) {
            await showMakeupMessage({ title: 'Make-up Session Failed', icon: 'error', message: error.message || 'Could not create make-up session.', buttons: [{ text: 'Close', class: 'btn-secondary' }] });
        } finally {
            if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
            if (button) {
                button.disabled = false;
                button.innerHTML = oldHtml;
            }
        }
    }

    if (sessionCanCreateMakeup) {
        document.getElementById('btnCreateMakeupSession')?.addEventListener('click', openMakeupSessionModal);
        document.getElementById('btnCreateMakeupSessionInline')?.addEventListener('click', openMakeupSessionModal);
    }

    window.__attendanceMatrixPolicy = <%- JSON.stringify(typeof attendanceMatrixPolicyResolved !== 'undefined' && attendanceMatrixPolicyResolved ? attendanceMatrixPolicyResolved : { disqualifyLateMinutes: 30, disqualifyEarlyLeaveMinutes: 30, disqualifyCombinedMissedMinutes: null, scheduledMinutes: 180 }) %>;
    let studentCasesState = <%- jsonForScript(Array.isArray(sessionStudentCases) ? sessionStudentCases : []) %>;
    let sessionReportInstancesState = <%- jsonForScript(Array.isArray(sessionReportInstanceRows) ? sessionReportInstanceRows : []) %>;
    const requestedStudentCaseId = new URLSearchParams(window.location.search || '').get('caseId') || '';
    let requestedStudentCaseHandled = false;
    let studentCaseModalInstance = null;
    const studentCaseModalEl = document.getElementById('studentCaseModal');
    if (studentCaseModalEl && window.bootstrap) studentCaseModalInstance = new bootstrap.Modal(studentCaseModalEl);

    function scEscapeHtml(value) {
        return String(value || '').replace(/[&<>"']/g, (ch) => ({
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#39;'
        }[ch]));
    }

    async function showStudentCaseMessage(title, message, icon = 'info') {
        if (typeof window.showMessageModal === 'function') {
            return window.showMessageModal({
                title: title || 'Student Case',
                message: message || '',
                icon,
                buttons: [{ text: 'OK', class: icon === 'error' ? 'btn-danger' : 'btn-primary' }]
            });
        }
        console.warn(`${title || 'Student Case'}: ${message || ''}`);
        return 'OK';
    }

    let studentCaseBusyToken = null;

    function showStudentCaseBusy(title, message) {
        if (typeof window.showLoading === 'function') {
            studentCaseBusyToken = window.showLoading({
                title: title || 'Student Case',
                note: message || 'Please wait while the operation is completed.',
                operation: 'Student Case'
            });
        }
    }

    function hideStudentCaseBusy() {
        if (typeof window.hideLoading === 'function') {
            if (studentCaseBusyToken) window.hideLoading(studentCaseBusyToken);
            else window.hideLoading({ force: true });
        }
        studentCaseBusyToken = null;
    }

    function studentCaseBadgeClass(value, type) {
        const key = String(value || '').toLowerCase();
        if (type === 'severity') {
            if (key === 'urgent') return 'bg-danger';
            if (key === 'warning') return 'bg-warning text-dark';
            return 'bg-info text-dark';
        }
        if (key === 'resolved') return 'bg-success';
        if (key === 'reopened') return 'bg-warning text-dark';
        if (key === 'cancelled') return 'bg-secondary';
        if (key === 'in_progress') return 'bg-primary';
        return 'bg-dark';
    }

    function renderStudentCases() {
        const body = document.getElementById('studentCasesTableBody');
        const badge = document.getElementById('studentCasesCountBadge');
        if (!body) return;
        const rows = Array.isArray(studentCasesState) ? studentCasesState : [];
        if (badge) badge.textContent = `${rows.length} ${rows.length === 1 ? 'Case' : 'Cases'}`;
        if (!rows.length) {
            body.innerHTML = '<tr><td colspan="7" class="text-center py-4 text-muted">No student cases for this session.</td></tr>';
            return;
        }
        body.innerHTML = rows.map((row) => {
            const status = String(row.status || 'open').toLowerCase();
            const severity = String(row.severity || 'info').toLowerCase();
            const updated = row?.audit?.lastUpdateDateTime || row?.audit?.createDateTime || '';
            const canResolve = !['resolved', 'cancelled'].includes(status);
            return `
                <tr data-case-id="${scEscapeHtml(row.id)}">
                    <td class="ps-4 fw-semibold">${scEscapeHtml(row.studentName || row.studentPersonId)}<div class="small text-muted font-monospace">${scEscapeHtml(row.studentPersonId)}</div></td>
                    <td class="text-capitalize">${scEscapeHtml(String(row.category || 'other').replace(/_/g, ' '))}</td>
                    <td><span class="badge ${studentCaseBadgeClass(severity, 'severity')}">${scEscapeHtml(severity.toUpperCase())}</span></td>
                    <td><span class="badge ${studentCaseBadgeClass(status, 'status')}">${scEscapeHtml(status.replace(/_/g, ' ').toUpperCase())}</span></td>
                    <td>${scEscapeHtml(row.summary || '-')}</td>
                    <td class="small text-muted font-monospace">${scEscapeHtml(updated || '-')}</td>
                    <td class="text-end pe-4">
                        <div class="btn-group btn-group-sm">
                            <button type="button" class="btn btn-outline-primary btn-edit-student-case" data-case-id="${scEscapeHtml(row.id)}"><i class="bi bi-pencil-square me-1"></i>Edit</button>
                            ${canResolve ? `<button type="button" class="btn btn-outline-success btn-status-student-case" data-case-id="${scEscapeHtml(row.id)}" data-status="resolved"><i class="bi bi-check2-circle me-1"></i>Resolve</button>` : `<button type="button" class="btn btn-outline-warning btn-status-student-case" data-case-id="${scEscapeHtml(row.id)}" data-status="reopened"><i class="bi bi-arrow-counterclockwise me-1"></i>Reopen</button>`}
                        </div>
                    </td>
                </tr>`;
        }).join('');
    }

    function renderSessionReportInstances() {
        const body = document.getElementById('sessionReportInstancesBody');
        if (!body) return;
        const rows = Array.isArray(sessionReportInstancesState) ? sessionReportInstancesState : [];
        if (!rows.length) {
            body.innerHTML = '<tr><td colspan="5" class="text-center py-4 text-muted">No report instances for this session, or none visible for your account.</td></tr>';
            syncPendingReportsHint();
            return;
        }
        body.innerHTML = rows.map((row) => {
            const statusLabel = String(row.statusLabel || row.status || 'draft');
            const badgeClass = String(row.statusBadgeClass || 'bg-warning text-dark');
            const actionLabel = String(row.actionLabel || (row.isPending ? 'Start' : 'Open V2'));
            const href = String(row.href || '#');
            const studentSub = row.studentId
                ? `<div class="small text-muted font-monospace">${scEscapeHtml(row.studentId)}</div>`
                : '';
            return `
                <tr data-report-instance-id="${scEscapeHtml(row.id)}">
                    <td class="ps-4 fw-semibold">${scEscapeHtml(row.templateTitle)}</td>
                    <td>${scEscapeHtml(row.studentName)}${studentSub}</td>
                    <td>${scEscapeHtml(row.teacherName)}</td>
                    <td><span class="badge ${badgeClass} text-capitalize">${scEscapeHtml(statusLabel)}</span></td>
                    <td class="pe-4 text-end">
                        <a href="${scEscapeHtml(href)}" class="btn btn-sm btn-outline-primary" target="_blank" rel="noopener noreferrer"><i class="bi bi-box-arrow-up-right me-1"></i>${scEscapeHtml(actionLabel)}</a>
                    </td>
                </tr>`;
        }).join('');
        syncPendingReportsHint();
    }

    async function refreshSessionReportInstances() {
        const btn = document.getElementById('btnRefreshSessionReportInstances');
        if (btn) btn.disabled = true;
        if (typeof window.showLoading === 'function') window.showLoading('Refreshing report instances...');
        try {
            const res = await fetch(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/report-instances`, {
                headers: { 'x-ajax-request': 'true', 'Accept': 'application/json' }
            });
            const result = await res.json().catch(() => ({}));
            if (!res.ok || result.status !== 'success') throw new Error(result.message || 'Failed to load report instances.');
            sessionReportInstancesState = result.rows || [];
            renderSessionReportInstances();
            renderSessionStatusButtons();
        } finally {
            if (btn) btn.disabled = false;
            if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
        }
    }

    function getStudentCaseById(id) {
        return (Array.isArray(studentCasesState) ? studentCasesState : []).find((row) => String(row.id) === String(id)) || null;
    }

    function setStudentCaseResolveButtonVisible(visible) {
        const button = document.getElementById('btnResolveStudentCase');
        if (button) button.classList.toggle('d-none', !visible);
    }

    function resetStudentCaseModal() {
        document.getElementById('studentCaseId').value = '';
        document.getElementById('studentCasePersonId').value = '';
        document.getElementById('studentCaseCategory').value = 'learning';
        document.getElementById('studentCaseSeverity').value = 'info';
        document.getElementById('studentCaseSummary').value = '';
        document.getElementById('studentCaseDetails').value = '';
        setStudentCaseResolveButtonVisible(true);
    }

    function openStudentCaseModal({ personId, studentName, caseRow = null }) {
        resetStudentCaseModal();
        const row = caseRow || {};
        const pid = String(row.studentPersonId || personId || '').trim();
        const name = String(row.studentName || studentName || pid || 'Student').trim();
        document.getElementById('studentCaseId').value = row.id || '';
        document.getElementById('studentCasePersonId').value = pid;
        document.getElementById('studentCaseModalTitle').textContent = row.id ? `Edit Case - ${name}` : `Open Case - ${name}`;
        document.getElementById('studentCaseContext').innerHTML = `<strong>${scEscapeHtml(name)}</strong> in <strong>${scEscapeHtml(<%- jsonForScript(classData.title || classData.id) %>)}</strong> on <strong>${scEscapeHtml(<%- jsonForScript(session.date || session.sessionId) %>)}</strong>.`;
        document.getElementById('studentCaseCategory').value = row.category || 'learning';
