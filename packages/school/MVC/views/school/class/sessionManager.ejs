        try {
            const res = await fetch(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/cases/${encodeURIComponent(caseId)}/status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'x-ajax-request': 'true', 'Accept': 'application/json' },
                body: JSON.stringify({ actionStateId, status })
            });
            const result = await res.json().catch(() => ({}));
            if (!res.ok || result.status !== 'success') throw new Error(result.message || 'Failed to update student case.');
            await refreshStudentCases();
            hideStudentCaseBusy();
            return showStudentCaseMessage('Case Updated', result.message || 'Student case updated.', 'success');
