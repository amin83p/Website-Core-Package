    function parseNonNegAttendanceMins(v) {
        const n = Number(String(v ?? '').trim());
        return Number.isFinite(n) && n >= 0 ? Math.floor(n) : 0;
    }

    function getRosterStudentName(row) {
        const fromDataset = String(row?.dataset?.studentName || '').trim();
        if (fromDataset) return fromDataset;
        return String(row?.querySelector('td')?.textContent || 'student').trim().replace(/\s+/g, ' ') || 'student';
    }

    function isLateMissingMinutes(row) {
        if (!row) return false;
        const attendance = row.querySelector('.att-radio:checked')?.value || '';
        if (attendance !== 'late') return false;
        const late = parseNonNegAttendanceMins(row.querySelector('.att-late')?.value);
        const early = parseNonNegAttendanceMins(row.querySelector('.att-leave')?.value);
        return late <= 0 && early <= 0;
    }

    function updateLateMissingMinuteState(row) {
        if (!row) return false;
        const missing = isLateMissingMinutes(row);
        row.classList.toggle('attendance-late-missing-minutes', missing);
        return missing;
    }

    function getLateMissingMinuteRows() {
        return Array.from(document.querySelectorAll('.roster-row')).filter((row) => updateLateMissingMinuteState(row));
    }

