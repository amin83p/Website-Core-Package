                row.querySelector('.att-late').value = lateVal;
                row.querySelector('.att-leave').value = leaveVal;
                row.querySelector('.att-excuse').value = excuseVal;
                if (excuseAttachmentInput) excuseAttachmentInput.value = JSON.stringify(excuseAttachment || null);

                applyAttendanceRulesToRow(row);
