    /* --- Session content stream (manual content + linked exams) --- */
    const contentReadOnly = <%= JSON.stringify(!!isReadOnly) %>;
    let manualSessionContentState = <%- jsonForScript(sessionContentItems || []) %>;
    const sessionExamContentItems = <%- jsonForScript(sessionExamContentItems || []) %>;
    let sessionContentOrderState = <%- jsonForScript(sessionContentOrder || []) %>;

    function contentEscapeHtml(str) {
        const d = document.createElement('div');
        d.textContent = str == null ? '' : String(str);
        return d.innerHTML;
    }

    function contentSortKey(item = {}) {
        const time = String(item?.time || '').trim() || '99:99';
        const type = String(item?.type || '').trim().toLowerCase();
        const id = String(item?.id || '').trim();
        return `${time}_${type}_${id}`;
    }

    function contentNormalizeOrder(orderRaw = []) {
        return Array.from(new Set((Array.isArray(orderRaw) ? orderRaw : [])
            .map((id) => String(id || '').trim())
            .filter(Boolean)));
    }

    function buildSessionContentCombined() {
        const map = new Map();
        (Array.isArray(manualSessionContentState) ? manualSessionContentState : []).forEach((item) => {
            if (!item || typeof item !== 'object') return;
            const id = String(item.id || '').trim();
            if (!id) return;
            map.set(id, { ...item, source: 'manual' });
        });
        (Array.isArray(sessionExamContentItems) ? sessionExamContentItems : []).forEach((item) => {
            if (!item || typeof item !== 'object') return;
            const id = String(item.id || '').trim();
            if (!id) return;
            map.set(id, { ...item, source: 'exam' });
        });

        const rows = Array.from(map.values());
        const orderMap = new Map(contentNormalizeOrder(sessionContentOrderState).map((id, index) => [id, index]));
        rows.sort((a, b) => {
            const aId = String(a?.id || '').trim();
            const bId = String(b?.id || '').trim();
            const aOrder = orderMap.has(aId) ? orderMap.get(aId) : Number.MAX_SAFE_INTEGER;
            const bOrder = orderMap.has(bId) ? orderMap.get(bId) : Number.MAX_SAFE_INTEGER;
            if (aOrder !== bOrder) return aOrder - bOrder;
            return contentSortKey(a).localeCompare(contentSortKey(b));
        });
        return rows;
    }

    function ensureContentOrderCoverage(rows = []) {
        const normalized = contentNormalizeOrder(sessionContentOrderState);
        const idSet = new Set((Array.isArray(rows) ? rows : []).map((row) => String(row?.id || '').trim()).filter(Boolean));
        const next = normalized.filter((id) => idSet.has(id));
        (Array.isArray(rows) ? rows : []).forEach((row) => {
            const id = String(row?.id || '').trim();
            if (!id || next.includes(id)) return;
            next.push(id);
        });
        sessionContentOrderState = next;
    }

    function renderSessionContentList() {
        const host = document.getElementById('sessionContentList');
        if (!host) return;
        const rows = buildSessionContentCombined();
        ensureContentOrderCoverage(rows);
        if (!rows.length) {
            host.innerHTML = `<div class="session-placeholder-card mb-0">
                <div class="fw-semibold text-dark mb-1">No session content yet</div>
                <div class="small">Add HTML/files and linked exams will also appear here.</div>
            </div>`;
            return;
        }
        const parts = rows.map((item, index) => {
            const id = String(item?.id || '').trim();
            const isExam = String(item?.type || '').trim().toLowerCase() === 'exam';
            const badge = isExam
                ? '<span class="badge bg-primary-subtle text-primary-emphasis border me-1">Exam</span>'
                : `<span class="badge bg-light text-dark border me-1">${contentEscapeHtml(String(item?.type || '').toUpperCase())}</span>`;
            const time = String(item?.time || '').trim();
            const timeHtml = time ? `<span class="badge bg-light text-dark border">${contentEscapeHtml(time)}</span>` : '';
            const actions = contentReadOnly ? '' : `
                <button type="button" class="btn btn-outline-secondary btn-sm content-move-up" data-id="${contentEscapeHtml(id)}" ${index === 0 ? 'disabled' : ''}><i class="bi bi-arrow-up"></i></button>
                <button type="button" class="btn btn-outline-secondary btn-sm content-move-down" data-id="${contentEscapeHtml(id)}" ${index === rows.length - 1 ? 'disabled' : ''}><i class="bi bi-arrow-down"></i></button>
                ${isExam ? '' : `<button type="button" class="btn btn-outline-primary btn-sm content-edit" data-id="${contentEscapeHtml(id)}"><i class="bi bi-pencil"></i></button>
                <button type="button" class="btn btn-outline-danger btn-sm content-remove" data-id="${contentEscapeHtml(id)}"><i class="bi bi-trash"></i></button>`}
            `;

            const details = isExam
                ? `<div class="small mt-2">
                      ${(() => {
                          const status = String(item?.status || '').trim().toLowerCase();
                          const openUrl = contentEscapeHtml(String(item?.links?.openAllocation || '').trim());
                          const swId = `exam-open-sw-${contentEscapeHtml(String(id).replace(/[^a-zA-Z0-9_-]/g, '_'))}`;
                          if (status === 'cancelled' || status === 'archived') {
                              return `<span class="badge ${status === 'cancelled' ? 'bg-danger-subtle text-danger-emphasis' : 'bg-secondary-subtle text-secondary-emphasis'} border me-1"><i class="bi bi-lock me-1"></i>${contentEscapeHtml(status)}</span>`;
                          }
                          if (contentReadOnly) {
                              if (status === 'open') {
                                  return '<span class="badge bg-success-subtle text-success-emphasis border me-1"><i class="bi bi-unlock me-1"></i>Open</span>';
                              }
                              return '<span class="badge bg-secondary-subtle text-secondary-emphasis border me-1"><i class="bi bi-lock me-1"></i>Not open</span>';
                          }
                          const checked = status === 'open' ? 'checked' : '';
                          const labelText = status === 'open' ? 'Exam open' : 'Exam locked';
                          return `<div class="form-check form-switch session-exam-open-switch d-inline-flex align-items-center gap-2 me-2 mb-1">
                              <input class="form-check-input content-allocation-open-toggle" type="checkbox" role="switch" id="${swId}"
                                data-status-url="${openUrl}" data-content-id="${contentEscapeHtml(id)}" ${checked}>
                              <label class="form-check-label mb-0" for="${swId}">${contentEscapeHtml(labelText)}</label>
                          </div>`;
                      })()}
                      <a href="${contentEscapeHtml(String(item?.links?.allocationEdit || item?.links?.allocation || '#'))}" class="btn btn-outline-secondary btn-sm me-1"><i class="bi bi-pencil-square me-1"></i>Allocation</a>
                      <a href="${contentEscapeHtml(String(item?.links?.assignment || item?.links?.teacherQueue || '#'))}" class="btn btn-outline-primary btn-sm me-1"><i class="bi bi-list-check me-1"></i>Assignment</a>
                      <a href="${contentEscapeHtml(String(item?.links?.start || '#'))}" class="btn btn-outline-success btn-sm me-1"><i class="bi bi-play-fill me-1"></i>Start</a>
                      <a href="${contentEscapeHtml(String(item?.links?.review || item?.links?.teacherQueue || '#'))}" class="btn btn-outline-info btn-sm me-1"><i class="bi bi-clipboard-check me-1"></i>Review</a>
                      ${item?.links?.template ? `<a href="${contentEscapeHtml(String(item.links.template))}" class="btn btn-outline-secondary btn-sm"><i class="bi bi-journal-text me-1"></i>Template</a>` : ''}
                      <details class="mt-2">
                        <summary class="fw-semibold">Questions & expected answers (${Number((item?.questions || []).length || 0)})</summary>
                        <div class="small mt-2 ps-2">
                          ${(Array.isArray(item?.questions) ? item.questions : []).map((q) => {
                              const qTitle = contentEscapeHtml(q?.promptText || q?.promptHtml || `Question ${Number(q?.sequenceNo || 0)}`);
                              const options = Array.isArray(q?.answerOptions) ? q.answerOptions : [];
                              const optionHtml = options.length
                                  ? `<ul class="mb-1">${options.map((opt) => `<li>${contentEscapeHtml(opt?.text || '')}${opt?.isCorrect ? ' <strong>(Correct)</strong>' : ''}</li>`).join('')}</ul>`
                                  : '<div class="text-muted">Subjective answer</div>';
                              return `<div class="border rounded p-2 mb-2">
                                  <div class="fw-semibold">Q${Number(q?.sequenceNo || 0)}: ${qTitle}</div>
                                  ${optionHtml}
                              </div>`;
                          }).join('')}
                        </div>
                      </details>
                    </div>`
                : `<div class="small text-muted mt-2">
                      ${item?.type === 'html'
                        ? `HTML content${item?.notes ? ` | ${contentEscapeHtml(item.notes)}` : ''}`
                        : `${item?.fileUrl ? `<a href="${contentEscapeHtml(String(item.fileUrl))}" target="_blank" rel="noopener">Open file</a>` : 'File link not set'}${item?.notes ? ` | ${contentEscapeHtml(item.notes)}` : ''}`}
                    </div>`;

            return `<div class="card border shadow-sm mb-2" data-content-id="${contentEscapeHtml(id)}">
                <div class="card-body py-2 px-3">
                    <div class="d-flex align-items-start justify-content-between gap-2">
                        <div class="min-w-0">
                            <div class="fw-semibold">${badge}${contentEscapeHtml(item?.title || id)} ${timeHtml}</div>
                            <div class="x-small text-muted font-monospace">${contentEscapeHtml(id)}</div>
                        </div>
                        <div class="d-flex gap-1 flex-shrink-0">${actions}</div>
                    </div>
                    ${details}
                </div>
            </div>`;
        });
        host.innerHTML = parts.join('');
    }

    function moveContentItem(id, dir) {
        const targetId = String(id || '').trim();
        if (!targetId) return;
        const combined = buildSessionContentCombined();
        const order = contentNormalizeOrder(sessionContentOrderState);
        const indexed = combined.map((row) => String(row?.id || '').trim()).filter(Boolean);
        const merged = order.filter((idVal) => indexed.includes(idVal));
        indexed.forEach((idVal) => { if (!merged.includes(idVal)) merged.push(idVal); });
        const currentIndex = merged.indexOf(targetId);
        if (currentIndex < 0) return;
        const nextIndex = dir === 'up' ? currentIndex - 1 : currentIndex + 1;
        if (nextIndex < 0 || nextIndex >= merged.length) return;
        const temp = merged[currentIndex];
        merged[currentIndex] = merged[nextIndex];
        merged[nextIndex] = temp;
        sessionContentOrderState = merged;
        renderSessionContentList();
    }

    let sessionContentModal = null;
    const sessionContentModalEl = document.getElementById('sessionContentModal');
    if (sessionContentModalEl && typeof bootstrap !== 'undefined') {
        sessionContentModal = new bootstrap.Modal(sessionContentModalEl);
    }

    function openSessionContentModal(mode, id = '') {
        if (contentReadOnly || !sessionContentModalEl) return;
        const editId = String(id || '').trim();
        const editing = !!editId;
        const type = mode === 'file' ? 'file' : 'html';
        const current = editing
            ? (Array.isArray(manualSessionContentState) ? manualSessionContentState.find((row) => String(row?.id || '').trim() === editId) : null)
            : null;
        document.getElementById('contentModalEditId').value = editing ? editId : '';
        document.getElementById('contentModalType').value = editing ? String(current?.type || type) : type;
        document.getElementById('contentModalTitleInput').value = editing ? String(current?.title || '') : '';
        document.getElementById('contentModalTimeInput').value = editing ? String(current?.time || '') : '';
        document.getElementById('contentModalHtmlInput').value = editing ? String(current?.html || '') : '';
        document.getElementById('contentModalFileUrlInput').value = editing ? String(current?.fileUrl || '') : '';
        document.getElementById('contentModalNotesInput').value = editing ? String(current?.notes || '') : '';
        const activeType = String(document.getElementById('contentModalType').value || '').trim().toLowerCase();
        document.getElementById('contentModalHtmlWrap').classList.toggle('d-none', activeType !== 'html');
        document.getElementById('contentModalFileWrap').classList.toggle('d-none', activeType !== 'file');
        const titleEl = document.getElementById('sessionContentModalTitle');
        titleEl.innerHTML = editing ? '<i class="bi bi-pencil-square me-2"></i>Edit Content' : `<i class="bi bi-plus-circle me-2"></i>Add ${activeType === 'file' ? 'File' : 'HTML'} Content`;
        if (sessionContentModal) sessionContentModal.show();
    }

    function saveSessionContentModal() {
        if (contentReadOnly) return;
        const editId = String(document.getElementById('contentModalEditId').value || '').trim();
        const type = String(document.getElementById('contentModalType').value || '').trim().toLowerCase();
        const title = String(document.getElementById('contentModalTitleInput').value || '').trim();
        const time = String(document.getElementById('contentModalTimeInput').value || '').trim();
        const html = String(document.getElementById('contentModalHtmlInput').value || '').trim();
        const fileUrl = String(document.getElementById('contentModalFileUrlInput').value || '').trim();
        const notes = String(document.getElementById('contentModalNotesInput').value || '').trim();
        if (!title) {
            if (typeof showMessageModal === 'function') {
                showMessageModal({ title: 'Title Required', icon: 'warning', message: 'Please set a title for the content item.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
            } else {
                alert('Please set a title for the content item.');
            }
            return;
        }
        if (type === 'html' && !html) {
            if (typeof showMessageModal === 'function') {
                showMessageModal({ title: 'HTML Required', icon: 'warning', message: 'Please provide HTML content.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
            } else {
                alert('Please provide HTML content.');
            }
            return;
        }
        if (type === 'file' && !fileUrl) {
            if (typeof showMessageModal === 'function') {
                showMessageModal({ title: 'File URL Required', icon: 'warning', message: 'Please provide a file URL.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
            } else {
                alert('Please provide a file URL.');
            }
            return;
        }
        const item = {
            id: editId || `CNT_${Date.now()}_${Math.random().toString(36).slice(2, 8)}`,
            type,
            title,
            time,
            html: type === 'html' ? html : '',
            fileUrl: type === 'file' ? fileUrl : '',
            notes
        };
        if (editId) {
            manualSessionContentState = (Array.isArray(manualSessionContentState) ? manualSessionContentState : []).map((row) => String(row?.id || '').trim() === editId ? item : row);
        } else {
            manualSessionContentState.push(item);
        }
        if (!sessionContentOrderState.includes(item.id)) sessionContentOrderState.push(item.id);
        if (sessionContentModal) sessionContentModal.hide();
        renderSessionContentList();
    }

    function removeSessionContentItem(id) {
        if (contentReadOnly) return;
        const targetId = String(id || '').trim();
        if (!targetId) return;
        manualSessionContentState = (Array.isArray(manualSessionContentState) ? manualSessionContentState : [])
            .filter((row) => String(row?.id || '').trim() !== targetId);
        sessionContentOrderState = contentNormalizeOrder(sessionContentOrderState).filter((row) => row !== targetId);
        renderSessionContentList();
    }

    async function handleAllocationOpenToggleChange(ev) {
        const toggle = ev.target;
        if (!toggle || !toggle.classList.contains('content-allocation-open-toggle')) return;
        const statusUrl = String(toggle.getAttribute('data-status-url') || '').trim();
        const contentId = String(toggle.getAttribute('data-content-id') || '').trim();
        if (!statusUrl || !contentId) return;

        const intendedOpen = toggle.checked;
        const targetStatus = intendedOpen ? 'open' : 'scheduled';
        toggle.checked = !intendedOpen;

        const isOpenAction = intendedOpen;
        const confirmTitle = isOpenAction ? 'Open exam for students?' : 'Lock exam (pause)?';
        const confirmMessage = isOpenAction
            ? 'Set this exam allocation to <strong>open</strong> so students can start?'
            : 'Set this exam allocation to <strong>scheduled</strong> to temporarily lock the exam?';
        const confirmButton = isOpenAction ? 'Open' : 'Lock';
        const successTitle = isOpenAction ? 'Exam opened' : 'Exam locked';
        const successFallback = isOpenAction
            ? 'Students can now start the exam.'
            : 'The exam is temporarily locked.';
        const errorTitle = isOpenAction ? 'Open failed' : 'Lock failed';

        const proceed = typeof showMessageModal === 'function'
            ? (await showMessageModal({
                title: confirmTitle,
                icon: 'question',
                message: confirmMessage,
                buttons: [
                    { text: 'Cancel', class: 'btn-secondary' },
                    { text: confirmButton, class: 'btn-primary' }
                ]
            })) === confirmButton
            : window.confirm(isOpenAction ? 'Open this exam allocation for students?' : 'Pause (lock) this exam allocation?');
        if (!proceed) return;

        toggle.checked = intendedOpen;
        toggle.disabled = true;
        try {
            const response = await fetch(statusUrl, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                    'X-Requested-With': 'XMLHttpRequest'
                },
                body: JSON.stringify({ status: targetStatus })
            });
            const payload = await response.json().catch(() => ({}));
            if (!response.ok || String(payload?.status || '').toLowerCase() !== 'success') {
                throw new Error(String(payload?.message || 'Could not update exam allocation status.'));
            }
            const target = (Array.isArray(sessionExamContentItems) ? sessionExamContentItems : [])
                .find((row) => String(row?.id || '').trim() === contentId);
            if (target) target.status = String(payload?.allocationStatus || targetStatus).trim().toLowerCase();
            renderSessionContentList();
            if (typeof showMessageModal === 'function') {
                await showMessageModal({
                    title: successTitle,
                    icon: 'success',
                    message: String(payload?.message || successFallback),
                    buttons: [{ text: 'OK', class: 'btn-primary' }]
                });
            }
        } catch (error) {
            toggle.checked = !intendedOpen;
            if (typeof showMessageModal === 'function') {
                await showMessageModal({
                    title: errorTitle,
                    icon: 'warning',
                    message: String(error?.message || error || 'Could not update exam allocation status.'),
                    buttons: [{ text: 'OK', class: 'btn-secondary' }]
                });
            } else {
                window.alert(String(error?.message || error || 'Could not update exam allocation status.'));
            }
        } finally {
            toggle.disabled = false;
        }
    }

    document.getElementById('btnAddHtmlContent')?.addEventListener('click', () => openSessionContentModal('html'));
    document.getElementById('btnAddFileContent')?.addEventListener('click', () => openSessionContentModal('file'));
    document.getElementById('contentModalSaveBtn')?.addEventListener('click', () => saveSessionContentModal());

    document.getElementById('sessionContentList')?.addEventListener('change', (event) => {
        if (event.target.classList.contains('content-allocation-open-toggle')) {
            handleAllocationOpenToggleChange(event);
        }
    });

    document.getElementById('sessionContentList')?.addEventListener('click', (event) => {
        const up = event.target.closest('.content-move-up');
        if (up) { moveContentItem(up.getAttribute('data-id'), 'up'); return; }
        const down = event.target.closest('.content-move-down');
        if (down) { moveContentItem(down.getAttribute('data-id'), 'down'); return; }
        const edit = event.target.closest('.content-edit');
        if (edit) { openSessionContentModal('html', edit.getAttribute('data-id')); return; }
        const del = event.target.closest('.content-remove');
        if (del) { removeSessionContentItem(del.getAttribute('data-id')); }
    });

    renderSessionContentList();

    /* --- Session gradebook (multiple activities per session) --- */
    const gbReadOnly = <%= JSON.stringify(!!isReadOnly) %>;
    const gbClassId = sessionManagerClassId;
    const gbSessionId = sessionManagerSessionId;
    const gradebookRoster = <%- jsonForScript((session.roster || []).map((r) => ({ personId: String(r.personId), name: r.name || 'Student' }))) %>;
    let gradebooksState = [];
    const gbCollapsedIds = new Set();

    function gbEscapeHtml(str) {
        const d = document.createElement('div');
        d.textContent = str == null ? '' : String(str);
        return d.innerHTML;
    }

    const gbCssEscape = typeof CSS !== 'undefined' && typeof CSS.escape === 'function'
        ? (s) => CSS.escape(String(s))
        : (s) => String(s).replace(/["\\.#:[\],]/g, (ch) => '\\' + ch);

    function gbIsPersonAbsent(personId) {
        const row = document.querySelector(`.roster-row[data-personid="${gbCssEscape(personId)}"]`);
        if (!row) return true;
        return (row.querySelector('.att-radio:checked')?.value || 'absent') === 'absent';
    }

    function gbNormalizeIncoming(list) {
        const arr = Array.isArray(list) ? list : [];
        return arr.map((gb) => {
            const totalScore = Number(gb.totalScore);
            const scores = {};
            gradebookRoster.forEach(({ personId }) => {
                const pid = String(personId);
                let v = gb.scores && (Object.prototype.hasOwnProperty.call(gb.scores, pid) ? gb.scores[pid] : gb.scores[personId]);
                if (v === '' || v === undefined) v = null;
                if (v !== null && v !== undefined) v = Number(v);
                scores[pid] = (v === null || Number.isNaN(v)) ? null : v;
            });
            if (gb.scores && typeof gb.scores === 'object') {
                Object.keys(gb.scores).forEach((k) => {
                    const pid = String(k);
                    if (Object.prototype.hasOwnProperty.call(scores, pid)) return;
                    let v = gb.scores[k];
                    if (v === '' || v === undefined) v = null;
                    if (v !== null && v !== undefined) v = Number(v);
                    scores[pid] = (v === null || Number.isNaN(v)) ? null : v;
                });
            }
            return {
                id: String(gb.id || '').trim() || `gb_${Date.now()}_${Math.random().toString(36).slice(2, 10)}`,
                name: String(gb.name || '').trim(),
                skillFocus: String(gb.skillFocus || '').trim(),
                totalScore: Number.isFinite(totalScore) && totalScore > 0 ? totalScore : 10,
                activityContent: String(gb.activityContent || ''),
                includeInGradeCalculation: gb.includeInGradeCalculation !== false,
                scores
            };
        });
    }

    gradebooksState = gbNormalizeIncoming(<%- jsonForScript(session.gradebooks || []) %>);

    function gbFormatPct(score, total) {
        if (score === null || score === undefined || Number.isNaN(Number(score))) return '—';
        const t = Number(total);
        if (!Number.isFinite(t) || t <= 0) return '—';
        return `${((Number(score) / t) * 100).toFixed(1)}%`;
    }

    function gbSyncScoresFromInputs() {
        gradebooksState.forEach((gb) => {
            const total = Number(gb.totalScore);
            gradebookRoster.forEach(({ personId }) => {
                const pid = String(personId);
                if (gbIsPersonAbsent(pid)) {
                    gb.scores[pid] = null;
                    return;
                }
                const inp = document.querySelector(`input.gb-score-input[data-gb-id="${gbCssEscape(gb.id)}"][data-person-id="${gbCssEscape(pid)}"]`);
                if (!inp) return;
                const raw = String(inp.value || '').trim();
                if (raw === '') {
                    gb.scores[pid] = null;
                    return;
                }
                let n = Number(raw);
                if (!Number.isFinite(n)) {
                    gb.scores[pid] = null;
                    return;
                }
                if (n < 0) n = 0;
                if (n > total) n = total;
                gb.scores[pid] = n;
                if (String(inp.value) !== String(n)) inp.value = n;
            });
        });
    }

    function gbRenderList() {
        const host = document.getElementById('sessionGradebooksList');
        if (!host) return;

        if (!gradebookRoster.length && !gradebooksState.length) {
            host.innerHTML = '<div class="alert alert-light border text-muted small mb-0">No students on the roster — add enrollments before using the gradebook.</div>';
            return;
        }

        if (!gradebooksState.length) {
            host.innerHTML = `
                <div class="session-placeholder-card mb-3">
                    <div class="fw-semibold text-dark mb-1">No activities yet</div>
                    <div class="small">Use <strong>Add activity</strong> to create your first gradebook entry.</div>
                </div>`;
            return;
        }

        const parts = [];
        const validGbIds = new Set(gradebooksState.map((g) => g.id));
        Array.from(gbCollapsedIds).forEach((id) => {
            if (!validGbIds.has(id)) gbCollapsedIds.delete(id);
        });

        gradebooksState.forEach((gb) => {
            const total = Number(gb.totalScore);
            const collapsed = gbCollapsedIds.has(gb.id);
            const incl = gb.includeInGradeCalculation ? '<span class="badge bg-light text-success border">In grade</span>' : '<span class="badge bg-light text-secondary border">Excluded</span>';
            const headActions = gbReadOnly ? '' : `
                <button type="button" class="btn btn-outline-primary btn-sm gb-edit" data-gb-id="${gbEscapeHtml(gb.id)}" title="Edit"><i class="bi bi-pencil"></i></button>
                <button type="button" class="btn btn-outline-danger btn-sm gb-del" data-gb-id="${gbEscapeHtml(gb.id)}" title="Remove"><i class="bi bi-trash"></i></button>`;
            const chevronCls = collapsed ? 'bi-chevron-right' : 'bi-chevron-down';

            const rows = gradebookRoster.length
                ? gradebookRoster.map(({ personId, name }) => {
                    const pid = String(personId);
                    const absent = gbIsPersonAbsent(pid);
                    const sc = gb.scores[pid];
                    if (absent) {
                        return `<tr>
                        <td class="ps-3">${gbEscapeHtml(name)}</td>
                        <td class="text-muted"><span class="badge bg-light text-muted border">N/A</span></td>
                        <td class="text-muted">N/A</td>
                    </tr>`;
                    }
                    const val = sc !== null && sc !== undefined && !Number.isNaN(Number(sc)) ? String(sc) : '';
                    return `<tr>
                    <td class="ps-3">${gbEscapeHtml(name)}</td>
                    <td style="max-width:140px;">
                        <input type="number" class="form-control form-control-sm gb-score-input" data-gb-id="${gbEscapeHtml(gb.id)}" data-person-id="${gbEscapeHtml(pid)}"
                            min="0" max="${total}" step="any" ${gbReadOnly ? 'disabled' : ''} value="${gbEscapeHtml(val)}" placeholder="—">
                    </td>
                    <td class="gb-pct small text-nowrap">${gbFormatPct(sc, total)}</td>
                </tr>`;
                }).join('')
                : `<tr><td colspan="3" class="text-muted small ps-3 py-2">No students on the attendance roster yet. Add enrollments to enter scores; saved activities and settings are shown below.</td></tr>`;

            parts.push(`
                <div class="card border shadow-sm session-gradebook-card mb-3" data-gb-id="${gbEscapeHtml(gb.id)}">
                    <div class="card-header bg-white d-flex flex-wrap align-items-start gap-2 py-3">
                        <button type="button" class="btn btn-light border-0 gb-collapse-toggle mt-1" data-gb-id="${gbEscapeHtml(gb.id)}" aria-expanded="${collapsed ? 'false' : 'true'}" title="${collapsed ? 'Expand' : 'Collapse'}">
                            <i class="bi ${chevronCls}" aria-hidden="true"></i>
                        </button>
                        <div class="flex-grow-1 min-w-0">
                            <div class="fw-bold text-primary">${gbEscapeHtml(gb.name || 'Untitled')}</div>
                            <div class="small text-muted mt-1">${gb.skillFocus ? `<span class="me-2"><i class="bi bi-bullseye me-1"></i>${gbEscapeHtml(gb.skillFocus)}</span>` : ''}
                                <span class="me-2"><i class="bi bi-calculator me-1"></i>Total: <strong>${total}</strong> pts</span>${incl}
                            </div>
                        </div>
                        <div class="d-flex gap-1 flex-shrink-0 ms-auto">${headActions}</div>
                    </div>
                    <div class="card-body pt-0 gb-card-collapsible${collapsed ? ' d-none' : ''}">
                        ${gb.activityContent ? `<div class="gb-activity-body mb-3">${gbEscapeHtml(gb.activityContent)}</div>` : '<p class="small text-muted mb-3 fst-italic">No activity description.</p>'}
                        <div class="table-responsive">
                            <table class="table table-sm table-bordered align-middle mb-0">
                                <thead class="table-light"><tr><th class="ps-3">Student</th><th style="min-width:120px;">Score</th><th style="min-width:72px;">%</th></tr></thead>
                                <tbody>${rows}</tbody>
                            </table>
                        </div>
                    </div>
                </div>`);
        });

        host.innerHTML = parts.join('');

        host.querySelectorAll('input.gb-score-input').forEach((inp) => {
            inp.addEventListener('input', () => {
                const gid = inp.getAttribute('data-gb-id');
                const pid = inp.getAttribute('data-person-id');
                const gb = gradebooksState.find((g) => g.id === gid);
                if (!gb) return;
                const total = Number(gb.totalScore);
                const raw = String(inp.value || '').trim();
                if (raw === '') {
                    gb.scores[pid] = null;
                    inp.closest('tr').querySelector('.gb-pct').textContent = '—';
                    return;
                }
                let n = Number(raw);
                if (!Number.isFinite(n)) return;
                if (n < 0) n = 0;
                if (n > total) n = total;
                gb.scores[pid] = n;
                if (String(inp.value) !== String(n)) inp.value = n;
                inp.closest('tr').querySelector('.gb-pct').textContent = gbFormatPct(n, total);
            });
        });

        host.querySelectorAll('.gb-edit').forEach((btn) => {
            btn.addEventListener('click', () => gbOpenModal(btn.getAttribute('data-gb-id')));
        });
        host.querySelectorAll('.gb-del').forEach((btn) => {
            btn.addEventListener('click', () => gbDeleteActivity(btn.getAttribute('data-gb-id')));
        });
    }

    function gbApplyCollapseDom(gbId) {
        const host = document.getElementById('sessionGradebooksList');
        if (!host) return;
        const card = host.querySelector(`.session-gradebook-card[data-gb-id="${gbCssEscape(String(gbId))}"]`);
        if (!card) return;
        const body = card.querySelector('.gb-card-collapsible');
        const btn = card.querySelector('.gb-collapse-toggle');
        const icon = btn && btn.querySelector('i');
        const collapsed = gbCollapsedIds.has(gbId);
        if (body) body.classList.toggle('d-none', collapsed);
        if (btn) {
            btn.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
            btn.setAttribute('title', collapsed ? 'Expand' : 'Collapse');
        }
        if (icon) icon.className = `bi ${collapsed ? 'bi-chevron-right' : 'bi-chevron-down'}`;
    }

    document.getElementById('sessionGradebooksList')?.addEventListener('click', (e) => {
        const btn = e.target.closest('.gb-collapse-toggle');
        if (!btn) return;
        e.preventDefault();
        const id = btn.getAttribute('data-gb-id');
        if (!id) return;
        if (gbCollapsedIds.has(id)) gbCollapsedIds.delete(id);
        else gbCollapsedIds.add(id);
        gbApplyCollapseDom(id);
    });

    async function gbPersistGradebooks(options = {}) {
        const {
            saveButton = null,
            successTitle = 'Saved',
            successMessage = null,
            showSuccessModal = true
        } = options;
        if (gbReadOnly) return { ok: false, error: 'Read-only' };
        gbSyncScoresFromInputs();
        const btn = saveButton;
        const orig = btn ? btn.innerHTML : '';
        if (btn) {
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';
        }
        try {
            const res = await fetch(`/school/classes/${encodeURIComponent(gbClassId)}/sessions/${encodeURIComponent(gbSessionId)}/gradebooks/save`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
                body: JSON.stringify({ gradebooks: gradebooksState, actionStateId })
            });
            let result;
            try {
                result = await res.json();
            } catch (pe) {
                throw new Error('Invalid server response.');
            }
            const guarded = typeof window.applyGuardedApiResult === 'function'
                ? await window.applyGuardedApiResult(result, { busyTitle: 'Save Gradebook In Progress', replayTitle: 'Gradebook Already Saved' })
                : { stop: false };
            if (guarded.stop) return { ok: false, error: 'stopped' };
            if (result.status !== 'success') throw new Error(result.message || 'Save failed');
            if (result.gradebooks) gradebooksState = gbNormalizeIncoming(result.gradebooks);
            gbRenderList();
            if (showSuccessModal) {
                const msg = successMessage != null ? successMessage : (result.message || 'Gradebook activities saved.');
                if (typeof showMessageModal === 'function') {
                    await showMessageModal({
                        title: successTitle,
                        icon: 'success',
                        message: msg,
                        buttons: [{ text: 'OK', class: 'btn-success' }]
                    });
                } else {
                    alert(msg);
                }
            }
            return { ok: true };
        } catch (err) {
            if (typeof showMessageModal === 'function') {
                showMessageModal({ title: 'Error', icon: 'error', message: err.message, buttons: [{ text: 'Close', class: 'btn-secondary' }] });
            } else {
                alert(err.message);
            }
            return { ok: false, error: err.message };
        } finally {
            if (btn) {
                btn.disabled = false;
                btn.innerHTML = orig;
            }
        }
    }

    function gbDeleteActivity(id) {
        if (gbReadOnly) return;
        const run = async () => {
            const prev = JSON.parse(JSON.stringify(gradebooksState));
            gradebooksState = gradebooksState.filter((g) => g.id !== id);
            gbCollapsedIds.delete(id);
            gbRenderList();
            const out = await gbPersistGradebooks({
                showSuccessModal: true,
                successTitle: 'Removed',
                successMessage: 'The activity was removed and saved.'
            });
            if (!out.ok) {
                gradebooksState = gbNormalizeIncoming(prev);
                gbRenderList();
            }
        };
        if (typeof showMessageModal === 'function') {
            showMessageModal({
                title: 'Remove activity?',
                icon: 'question',
                message: 'Remove this activity from the gradebook? The list will be saved immediately.',
                buttons: [{ text: 'Cancel', class: 'btn-secondary' }, { text: 'Remove', class: 'btn-danger' }]
            }).then((res) => {
                if (res === 'Remove') void run();
            });
            return;
        }
        if (window.confirm('Remove this activity from the gradebook? It will be saved immediately.')) void run();
    }

    let gradebookModalInstance = null;
    const gbModalEl = document.getElementById('gradebookActivityModal');
    if (gbModalEl && typeof bootstrap !== 'undefined') {
        gradebookModalInstance = new bootstrap.Modal(gbModalEl);
    }

    function gbOpenModal(editId) {
        const isEdit = !!editId;
        document.getElementById('gradebookActivityModalTitle').innerHTML = isEdit
            ? '<i class="bi bi-pencil-square me-2"></i>Edit activity'
            : '<i class="bi bi-journal-plus me-2"></i>Add activity';
        document.getElementById('gbModalEditId').value = isEdit ? editId : '';
        if (isEdit) {
            const gb = gradebooksState.find((g) => g.id === editId);
            if (!gb) return;
            document.getElementById('gbModalName').value = gb.name || '';
            document.getElementById('gbModalSkill').value = gb.skillFocus || '';
            document.getElementById('gbModalTotal').value = gb.totalScore || '';
            document.getElementById('gbModalContent').value = gb.activityContent || '';
            document.getElementById('gbModalInclude').checked = gb.includeInGradeCalculation !== false;
        } else {
            document.getElementById('gbModalName').value = '';
            document.getElementById('gbModalSkill').value = '';
            document.getElementById('gbModalTotal').value = '';
            document.getElementById('gbModalContent').value = '';
            document.getElementById('gbModalInclude').checked = true;
        }
        if (gradebookModalInstance) gradebookModalInstance.show();
    }

    function gbApplyModalSave() {
        if (gbReadOnly) return;
        gbSyncScoresFromInputs();
        const editId = document.getElementById('gbModalEditId').value.trim();
        const name = document.getElementById('gbModalName').value.trim();
        const skillFocus = document.getElementById('gbModalSkill').value.trim();
        const totalScore = Number(document.getElementById('gbModalTotal').value);
        const activityContent = document.getElementById('gbModalContent').value;
        const includeInGradeCalculation = document.getElementById('gbModalInclude').checked;

        if (!name) {
            if (typeof showMessageModal === 'function') {
                showMessageModal({ title: 'Name required', icon: 'warning', message: 'Please enter an activity name.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
            } else { alert('Please enter an activity name.'); }
            return;
        }
        if (!Number.isFinite(totalScore) || totalScore <= 0) {
            if (typeof showMessageModal === 'function') {
                showMessageModal({ title: 'Invalid total', icon: 'warning', message: 'Total score must be a positive number.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
            } else { alert('Total score must be a positive number.'); }
            return;
        }

        if (editId) {
            const gb = gradebooksState.find((g) => g.id === editId);
            if (!gb) return;
            const oldTotal = Number(gb.totalScore);
            gb.name = name;
            gb.skillFocus = skillFocus;
            gb.totalScore = totalScore;
            gb.activityContent = activityContent;
            gb.includeInGradeCalculation = includeInGradeCalculation;
            if (oldTotal !== totalScore) {
                gradebookRoster.forEach(({ personId }) => {
                    const pid = String(personId);
                    const v = gb.scores[pid];
                    if (v !== null && v !== undefined && Number(v) > totalScore) gb.scores[pid] = totalScore;
                });
            }
        } else {
            const scores = {};
            gradebookRoster.forEach(({ personId }) => {
                scores[String(personId)] = null;
            });
            gradebooksState.push({
                id: `gb_${Date.now()}_${Math.random().toString(36).slice(2, 10)}`,
                name,
                skillFocus,
                totalScore,
                activityContent,
                includeInGradeCalculation,
                scores
            });
        }
        if (gradebookModalInstance) gradebookModalInstance.hide();
        gbRenderList();
    }

    const btnOpenGradebookModal = document.getElementById('btnOpenGradebookModal');
    if (btnOpenGradebookModal) {
        btnOpenGradebookModal.addEventListener('click', () => gbOpenModal(null));
    }
    const gbModalSaveBtn = document.getElementById('gbModalSaveBtn');
    if (gbModalSaveBtn) gbModalSaveBtn.addEventListener('click', () => gbApplyModalSave());

    function gbOnAttendanceChanged() {
        gbSyncScoresFromInputs();
        gradebooksState.forEach((gb) => {
            gradebookRoster.forEach(({ personId }) => {
                const pid = String(personId);
                if (gbIsPersonAbsent(pid)) gb.scores[pid] = null;
            });
        });
        gbRenderList();
    }

    const attendanceTableEl = document.getElementById('attendanceTable');
    if (attendanceTableEl) {
        attendanceTableEl.addEventListener('change', (e) => {
            if (!e.target || !e.target.classList.contains('att-radio')) return;
            const row = e.target.closest('.roster-row');
            if (row) applyAttendanceRulesToRow(row);
            gbOnAttendanceChanged();
        });
    }

    const btnAllPresentGb = document.getElementById('btnAllPresent');
    if (btnAllPresentGb) btnAllPresentGb.addEventListener('click', () => { applyBulkAttendance('present'); gbOnAttendanceChanged(); });
    const btnAllLateGb = document.getElementById('btnAllLate');
    if (btnAllLateGb) btnAllLateGb.addEventListener('click', () => { applyBulkAttendance('late'); gbOnAttendanceChanged(); });
    const btnAllAbsentGb = document.getElementById('btnAllAbsent');
    if (btnAllAbsentGb) btnAllAbsentGb.addEventListener('click', () => { applyBulkAttendance('absent'); gbOnAttendanceChanged(); });

    const btnSaveGradebooks = document.getElementById('btnSaveGradebooks');
    if (btnSaveGradebooks) {
        btnSaveGradebooks.addEventListener('click', async () => {
            if (gbReadOnly) return;
            await gbPersistGradebooks({
                saveButton: btnSaveGradebooks,
                successTitle: 'Saved',
                successMessage: null,
                showSuccessModal: true
            });
        });
    }

    if (gbReadOnly) {
        const gbModalName = document.getElementById('gbModalName');
        const gbModalSkill = document.getElementById('gbModalSkill');
        const gbModalTotal = document.getElementById('gbModalTotal');
        const gbModalContent = document.getElementById('gbModalContent');
        const gbModalInclude = document.getElementById('gbModalInclude');
        if (gbModalName) gbModalName.disabled = true;
        if (gbModalSkill) gbModalSkill.disabled = true;
        if (gbModalTotal) gbModalTotal.disabled = true;
        if (gbModalContent) gbModalContent.disabled = true;
        if (gbModalInclude) gbModalInclude.disabled = true;
        if (gbModalSaveBtn) gbModalSaveBtn.disabled = true;
    }

    gbRenderList();

    if (!contentReadOnly) {
        document.querySelectorAll('.roster-row').forEach((row) => applyAttendanceRulesToRow(row));
    }

    const btnSaveSession = document.getElementById('btnSaveSession');
    if (btnSaveSession) {
        btnSaveSession.addEventListener('click', async () => {
            const btn = document.getElementById('btnSaveSession');
            const originalHtml = btn.innerHTML;

            const status = getSelectedSessionStatus();
            const notes = document.getElementById('sessionNotes').value;
            const room = document.getElementById('sessionRoom').value;

            const roster = [];
            const conductRowsByPersonId = new Map(Array.from(document.querySelectorAll('.conduct-row')).map((row) => [row.getAttribute('data-personid'), row]));
            const readConductRating = (conductRow, selector) => {
                if (!conductRow) return 100;
                const raw = conductRow.querySelector(selector)?.value;
                const n = Number(String(raw ?? '').trim());
                if (!Number.isFinite(n)) return 100;
                return Math.max(0, Math.min(100, Math.round(n * 100) / 100));
            };
            document.querySelectorAll('.roster-row').forEach(row => {
                const personId = row.getAttribute('data-personid');
                const attendance = row.querySelector('.att-radio:checked')?.value || 'absent';
                const lateMinutes = row.querySelector('.att-late').value || null;
                const earlyLeaveMinutes = row.querySelector('.att-leave').value || null;
                const excuseRef = row.querySelector('.att-excuse').value || '';
                const conductRow = conductRowsByPersonId.get(personId);

                roster.push({
                    personId,
                    attendance,
                    lateMinutes,
                    earlyLeaveMinutes,
                    excuseRef,
                    notes: '',
                    classEffortPercent: readConductRating(conductRow, '.conduct-class-effort'),
                    classParticipationPercent: readConductRating(conductRow, '.conduct-class-participation'),
                    respectsTeachersPercent: readConductRating(conductRow, '.conduct-respects-teachers'),
                    respectsStudentsPercent: readConductRating(conductRow, '.conduct-respects-students')
                });
            });

            const payload = {
                status,
                notes,
                room,
                roster: JSON.stringify(roster),
                contentItems: JSON.stringify(Array.isArray(manualSessionContentState) ? manualSessionContentState : []),
                contentOrder: JSON.stringify(Array.isArray(sessionContentOrderState) ? sessionContentOrderState : []),
                actionStateId
            };

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>Saving...';

            try {
                const res = await fetch(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/save`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
                    body: JSON.stringify(payload)
                });
                const result = await res.json();
                const guarded = typeof window.applyGuardedApiResult === 'function'
                    ? await window.applyGuardedApiResult(result, { busyTitle: 'Save Session In Progress', replayTitle: 'Session Already Saved' })
                    : { stop: false };
                if (guarded.stop) return;

                if (typeof showMessageModal === 'function') {
                    await showMessageModal({
                        title: result.status === 'success' ? 'Saved' : 'Error',
                        icon: result.status === 'success' ? 'success' : 'error',
                        message: result.message,
                        buttons: [{ text: 'OK', class: result.status === 'success' ? 'btn-success' : 'btn-danger' }]
                    });
                    if (result.status === 'success') window.location.reload();
                } else {
                    alert(result.message);
                    if (result.status === 'success') window.location.reload();
                }
            } catch (error) {
                console.error(error);
                if (typeof showMessageModal === 'function') {
                    showMessageModal({
                        title: 'Network Error', icon: 'error',
                        message: 'A network error occurred while trying to save the session.',
                        buttons: [{ text: 'Close', class: 'btn-secondary' }]
                    });
                } else { alert('A network error occurred.'); }
            } finally {
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        });
    }
});

function openDetailsModal(personId, name) {
    document.getElementById('modalPersonId').value = personId;
    document.getElementById('modalStudentName').innerText = name;
    if (typeof window.refreshAttendanceMatrixHint === 'function') window.refreshAttendanceMatrixHint();

    const row = document.querySelector(`.roster-row[data-personid="${personId}"]`);
    if (row) {
        document.getElementById('modalLateMins').value = row.querySelector('.att-late').value;
        document.getElementById('modalLeaveMins').value = row.querySelector('.att-leave').value;
        document.getElementById('modalExcuseRef').value = row.querySelector('.att-excuse').value;

        const commentsStr = row.querySelector('.att-comments').value;
        const comments = JSON.parse(commentsStr || "[]");
        const thread = document.getElementById('det_commentsThread');
        thread.innerHTML = '';

        if (comments && comments.length > 0) {
            comments.forEach(c => {
                let mentionHtml = '';
                (c.mentions || []).forEach(m => mentionHtml += `<span class="mention-badge me-1">@${m.name}</span>`);

                thread.innerHTML += `
                    <div class="comment-bubble">
                        <span class="comment-time">${new Date(c.timestamp).toLocaleString()}</span>
                        <div class="comment-author">${c.authorName}</div>
                        <div class="mt-1">${mentionHtml} ${c.text}</div>
                    </div>
                `;
            });
        } else {
            thread.innerHTML = '<div class="text-muted small text-center py-2">No notes yet. Be the first to comment.</div>';
        }
    }

    document.getElementById('inp_newComment').value = '';
    currentMentions = [];
    const area = document.getElementById('pendingMentionsArea');
    if(area) area.innerHTML = '';

    if (detailsModalInstance) detailsModalInstance.show();
}
</script>
