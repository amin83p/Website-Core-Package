    function parseSessionTimeToMinutes(value) {
        const token = String(value || '').trim();
        if (!/^\d{2}:\d{2}$/.test(token)) return null;
        const parts = token.split(':').map(Number);
        if (!Number.isInteger(parts[0]) || !Number.isInteger(parts[1])) return null;
        return (parts[0] * 60) + parts[1];
    }

    function calculateSessionReportAllocatedHours() {
        const modal = getSessionReportAssignmentModal();
        if (!modal) return 0;
        const start = parseSessionTimeToMinutes(modal.querySelector('#sessionReportTaskStart')?.value || '');
        const end = parseSessionTimeToMinutes(modal.querySelector('#sessionReportTaskEnd')?.value || '');
        if (start === null || end === null || end <= start) return 0;
        return Math.round(((end - start) / 60) * 100) / 100;
    }

    function syncSessionReportAllocatedHours(force = false) {
        const modal = getSessionReportAssignmentModal();
        if (!modal) return;
        const reflect = modal.querySelector('#sessionReportTimesheetReflection')?.checked === true;
        const input = modal.querySelector('#sessionReportAllocatedHours');
        if (!input) return;
        input.disabled = !reflect;
        if (reflect && (force || !Number(input.value || 0))) {
            input.value = String(calculateSessionReportAllocatedHours() || 0);
        }
        if (!reflect) input.value = '0';
    }

    function getSessionReportRosterItems() {
        const seen = new Set();
        return (Array.isArray(sessionReportRosterRows) ? sessionReportRosterRows : [])
