            btn.style.borderColor = opt.getAttribute('data-color-border') || '#cbd5e1';
            btn.innerHTML = `<span>${opt.getAttribute('data-label') || opt.textContent || code}</span><i class="bi ${selected === code ? 'bi-check-circle-fill' : 'bi-circle'}"></i>`;
            if (blocked) {
                btn.disabled = true;
                btn.title = 'Submit all assigned reports before marking this session completed.';
                btn.classList.add('opacity-50');
