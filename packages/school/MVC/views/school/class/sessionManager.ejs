                    <div class="col-md-4">
                        <label class="form-label fw-bold" for="sessionReportDueDate">Due Date</label>
                        <input type="date" class="form-control bg-light" id="sessionReportDueDate" value="<%= session.date || '' %>" readonly>
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold" for="sessionReportTaskStart">Task Start</label>
                        <input type="time" class="form-control" id="sessionReportTaskStart" min="<%= session.startTime || '' %>" max="<%= session.endTime || '' %>">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label fw-bold" for="sessionReportTaskEnd">Task End</label>
                        <input type="time" class="form-control" id="sessionReportTaskEnd" min="<%= session.startTime || '' %>" max="<%= session.endTime || '' %>">
                    </div>
                    <div class="col-12 d-none" id="sessionReportSpecificStudentsWrap">
                        <label class="form-label fw-bold" for="sessionReportStudentSummary">Specific Students</label>
                        <div class="input-group">
                            <input type="text" class="form-control bg-white" id="sessionReportStudentSummary" placeholder="No students selected" readonly>
                            <button type="button" class="btn btn-outline-primary" id="btnPickSessionReportStudents"><i class="bi bi-people"></i></button>
                        </div>
                        <div id="sessionReportSelectedStudents" class="d-flex flex-wrap gap-1 mt-2"></div>
                        <div class="form-text">Only students shown on this session roster are accepted.</div>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold" for="sessionReportAllocatedHours">Allocated Hours</label>
                        <input type="number" class="form-control" id="sessionReportAllocatedHours" min="0" step="0.25" value="0">
                    </div>
                    <div class="col-md-8 d-flex align-items-end flex-wrap gap-4">
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="sessionReportTimesheetReflection">
                            <label class="form-check-label" for="sessionReportTimesheetReflection">Reflect on timesheet</label>
                        </div>
                        <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="sessionReportConflictPermitted">
                            <label class="form-check-label" for="sessionReportConflictPermitted">Permit schedule conflict</label>
                        </div>
                    </div>
                    <div class="col-12">
                        <label class="form-label fw-bold" for="sessionReportNotes">Notes</label>
                        <textarea class="form-control" id="sessionReportNotes" rows="3" maxlength="1500" placeholder="Optional assignment notes"></textarea>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary fw-bold" id="btnSaveSessionReportAssignment"><i class="bi bi-save me-1"></i>Save Assignment</button>
            </div>
        </div>
    </div>
</div>
<%- include('partials/modal_GenericPicker') %>

<script>
let detailsModalInstance = null;
let currentMentions = [];

function formatSchoolInstant(value) {
    if (window.AppOrgDateTime && typeof window.AppOrgDateTime.formatSchoolInstant === 'function') {
        return window.AppOrgDateTime.formatSchoolInstant(value);
    }
    if (window.AppOrgDateTime && typeof window.AppOrgDateTime.formatInstant === 'function') {
        return window.AppOrgDateTime.formatInstant(value);
    }
    return '-';
}

document.addEventListener('DOMContentLoaded', () => {
    const actionStateId = <%- jsonForScript((typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '') %>;
    const defaultSessionStatusCode = <%- jsonForScript(fallbackStatusCode) %>;
    const sessionInitialStatusCode = <%- jsonForScript(currentSessionStatus) %>;
    const sessionManagerClassId = <%- jsonForScript(classData.id) %>;
    const sessionManagerSessionId = <%- jsonForScript(session.sessionId) %>;
    const sessionStatusMeta = <%- jsonForScript(availableStatusRows || []) %>;
    const sessionMakeupHistory = <%- jsonForScript(existingMakeupHistory || []) %>;
    const sessionCanCreateMakeup = <%- jsonForScript(Boolean(canCreateMakeupSession)) %>;
    const sessionInstructionalInactive = <%- jsonForScript(Boolean(isMakeupRequiredInactive)) %>;
    const sessionDefaultTeacherId = <%- jsonForScript(session.delivery?.deliveredBy || '') %>;
    const sessionDefaultTeacherName = <%- jsonForScript(session.delivery?.deliveredByName || '') %>;
    const sessionDefaultRoom = <%- jsonForScript(session.room || '') %>;
    const sessionDefaultDate = <%- jsonForScript(session.date || '') %>;
    const sessionDefaultStartTime = <%- jsonForScript(session.startTime || '') %>;
    const sessionDefaultEndTime = <%- jsonForScript(session.endTime || '') %>;
    const sessionOriginalDurationHours = <%- jsonForScript((() => {
        const start = String(session.startTime || '').trim();
        const end = String(session.endTime || '').trim();
        if (start && end && /^\d{2}:\d{2}$/.test(start) && /^\d{2}:\d{2}$/.test(end)) {
            const [sh, sm] = start.split(':').map(Number);
            const [eh, em] = end.split(':').map(Number);
            const minutes = ((eh * 60) + em) - ((sh * 60) + sm);
            if (minutes > 0) return Number((minutes / 60).toFixed(2));
        }
        const fallback = Number(session.durationHours || 0);
        return Number.isFinite(fallback) && fallback > 0 ? fallback : 0;
    })()) %>;
    const sessionMakeupDefaultPercent = <%- jsonForScript(Number(currentSessionStatusMeta?.makeupDurationPercent || 100)) %>;
    const sessionCanAssignReports = <%- jsonForScript(Boolean(canAssignSessionReports)) %>;
    const sessionReportRosterRows = <%- jsonForScript(Array.isArray(session.roster) ? session.roster : []) %>;
    const sessionManagerClassTitle = <%- jsonForScript(classData.title || classData.id || '') %>;
    const sessionCanEditMetadata = <%- jsonForScript(Boolean(canEditSessionMetadataFlag)) %>;
    const sessionCanToggleLock = <%- jsonForScript(Boolean(canToggleSessionLock)) %>;
    const normalizeStatusCode = (value) => String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
    const sessionStatusMap = new Map((sessionStatusMeta || []).map((row) => [normalizeStatusCode(row.code), row]));
    const resolveStatusMeta = (statusCode) => sessionStatusMap.get(normalizeStatusCode(statusCode)) || null;
    const attendanceAttachmentEscape = (value) => String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    function parseAttendanceAttachment(value) {
        if (!value) return null;
        if (typeof value === 'object') return value;
        try {
            const parsed = JSON.parse(String(value || 'null'));
            return parsed && typeof parsed === 'object' ? parsed : null;
        } catch (_error) {
            return null;
        }
    }
    async function uploadSchoolSessionFile(input, category, personId = '') {
        const file = input?.files && input.files[0];
        if (!file) return null;
        const body = new FormData();
        body.append('kind', category || 'file');
        body.append('classId', sessionManagerClassId);
        body.append('sessionId', sessionManagerSessionId);
        if (personId) body.append('studentPersonId', personId);
        body.append('actionStateId', actionStateId);
        body.append('file', file);
        const res = await fetch(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/files/upload`, {
            method: 'POST',
            headers: { 'X-AJAX-Request': 'true' },
            body
        });
        const result = await res.json().catch(() => null);
        if (!res.ok || !result || result.status !== 'success') {
            throw new Error(result?.message || 'File upload failed.');
        }
        return result.file || null;
    }
    function renderAttendanceAttachmentLink(attachment, emptyText = '') {
        const att = parseAttendanceAttachment(attachment);
        if (!att) return emptyText;
        const href = att.dataUrl || att.url || att.uploadUrl || att.storagePath || att.path || '';
        if (!href) return `<span class="text-muted">${attendanceAttachmentEscape(att.name || 'Attached file')}</span>`;
        return `<a href="${attendanceAttachmentEscape(href)}" target="_blank" rel="noopener" class="text-decoration-none"><i class="bi bi-paperclip me-1"></i>${attendanceAttachmentEscape(att.name || att.originalName || 'Open attachment')}</a>`;
    }
    window.parseAttendanceAttachment = parseAttendanceAttachment;
    window.renderAttendanceAttachmentLink = renderAttendanceAttachmentLink;

    function showMakeupMessage(options) {
        if (typeof window.showMessageModal === 'function') return window.showMessageModal(options || {});
        if (options?.message) window.alert(options.message);
        return Promise.resolve('');
    }

    function ensureMakeupSessionModal() {
        let modal = document.getElementById('makeupSessionModal');
        if (modal) return modal;
        modal = document.createElement('div');
        modal.className = 'modal fade';
        modal.id = 'makeupSessionModal';
        modal.tabIndex = -1;
        modal.setAttribute('aria-hidden', 'true');
        modal.innerHTML = [
            '<div class="modal-dialog modal-lg modal-dialog-scrollable">',
            '<div class="modal-content">',
            '<div class="modal-header bg-warning text-dark">',
            '<h5 class="modal-title fw-bold"><i class="bi bi-calendar-plus me-2"></i>Create Make-up Session</h5>',
            '<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>',
            '</div>',
            '<div class="modal-body">',
            '<div class="alert alert-light border small" id="makeupSessionContext"></div>',
            '<input type="hidden" id="makeupSessionTeacherId">',
            '<div class="row g-3">',
            '<div class="col-md-4"><label class="form-label fw-bold">Date</label><input type="date" class="form-control" id="makeupSessionDate"></div>',
            '<div class="col-md-4"><label class="form-label fw-bold">Start Time</label><input type="time" class="form-control" id="makeupSessionStart"></div>',
            '<div class="col-md-4"><label class="form-label fw-bold">End Time</label><input type="time" class="form-control" id="makeupSessionEnd"></div>',
            '<div class="col-md-4"><label class="form-label fw-bold">Make-up Duration %</label><input type="number" class="form-control" id="makeupSessionDurationPercent" min="1" max="100" step="1"></div>',
            '<div class="col-md-8"><div class="alert alert-light border small mb-0 h-100" id="makeupSessionDurationSummary"></div></div>',
            '<div class="col-md-6"><label class="form-label fw-bold">Teacher</label><div class="input-group"><input type="text" class="form-control bg-white" id="makeupSessionTeacherName" readonly><button type="button" class="btn btn-outline-primary" id="makeupSessionPickTeacher"><i class="bi bi-person-check"></i></button></div></div>',
            '<div class="col-md-6"><label class="form-label fw-bold">Location</label><input type="text" class="form-control" id="makeupSessionRoom" maxlength="200"></div>',
            '<div class="col-12"><label class="form-label fw-bold">Reason</label><textarea class="form-control" id="makeupSessionReason" rows="3" maxlength="1000" placeholder="Why is this make-up session needed?"></textarea></div>',
            '</div>',
            '</div>',
            '<div class="modal-footer bg-light">',
            '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>',
            '<button type="button" class="btn btn-warning fw-bold" id="makeupSessionCreate"><i class="bi bi-calendar-plus me-1"></i>Create Make-up Session</button>',
            '</div>',
            '</div>',
            '</div>'
        ].join('');
        document.body.appendChild(modal);
        modal.querySelector('#makeupSessionPickTeacher')?.addEventListener('click', function () {
            if (!window.GenericPicker || !window.GenericPickerPresets) {
                showMakeupMessage({ title: 'Teacher Picker', icon: 'warning', message: 'Teacher picker is not available yet.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
                return;
            }
            window.GenericPicker.open(window.GenericPickerPresets.teacher({
                title: 'Select Make-up Teacher',
                placeholder: 'Search teachers...',
                context: window.GenericPickerContexts
                    ? window.GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' })
                    : undefined,
                onSelect: function (item) {
                    const id = String(item?.personId || item?.id || item?.value || '').trim();
                    const name = String(item?.name || item?.label || [item?.firstName, item?.lastName].filter(Boolean).join(' ') || id).trim();
                    modal.querySelector('#makeupSessionTeacherId').value = id;
                    modal.querySelector('#makeupSessionTeacherName').value = name;
                }
            }));
        });
        modal.querySelector('#makeupSessionCreate')?.addEventListener('click', createMakeupSessionFromModal);
        modal.querySelector('#makeupSessionDurationPercent')?.addEventListener('input', syncMakeupSessionDurationPreview);
        modal.querySelector('#makeupSessionStart')?.addEventListener('input', syncMakeupSessionDurationPreview);
        return modal;
    }

    function addMinutesToClockTimeClient(startTime, minutesToAdd) {
        const start = String(startTime || '').trim();
        if (!/^\d{2}:\d{2}$/.test(start)) return '';
        const [h, m] = start.split(':').map(Number);
        const totalMinutes = (h * 60) + m + Number(minutesToAdd || 0);
        if (!Number.isFinite(totalMinutes) || totalMinutes <= 0) return '';
        const endH = Math.floor(totalMinutes / 60) % 24;
        const endM = totalMinutes % 60;
        return String(endH).padStart(2, '0') + ':' + String(endM).padStart(2, '0');
    }

    function formatDurationHoursLabel(hours) {
        const safe = Number(hours);
        if (!Number.isFinite(safe) || safe <= 0) return '0 hr';
        const minutes = Math.round(safe * 60);
        const wholeHours = Math.floor(minutes / 60);
        const remainderMinutes = minutes % 60;
        if (wholeHours && remainderMinutes) return wholeHours + ' hr ' + remainderMinutes + ' min';
        if (wholeHours) return wholeHours + ' hr';
        return remainderMinutes + ' min';
    }

    function syncMakeupSessionDurationPreview() {
        const modal = document.getElementById('makeupSessionModal');
        if (!modal) return;
        const percentInput = modal.querySelector('#makeupSessionDurationPercent');
        const startInput = modal.querySelector('#makeupSessionStart');
        const endInput = modal.querySelector('#makeupSessionEnd');
        const summary = modal.querySelector('#makeupSessionDurationSummary');
        const percent = Math.max(1, Math.min(100, Number(percentInput?.value || sessionMakeupDefaultPercent || 100)));
        if (percentInput) percentInput.value = String(percent);
        const makeupHours = Number((Number(sessionOriginalDurationHours || 0) * (percent / 100)).toFixed(2));
        if (startInput?.value) {
            const computedEnd = addMinutesToClockTimeClient(startInput.value, Math.round(makeupHours * 60));
            if (computedEnd && endInput) endInput.value = computedEnd;
        }
        if (!summary) return;
        summary.innerHTML = '<strong>Original session:</strong> ' + formatDurationHoursLabel(sessionOriginalDurationHours)
            + '<br><strong>Make-up at ' + percent + '%:</strong> ' + formatDurationHoursLabel(makeupHours)
            + '<br><span class="text-muted">Original session payroll uses Timesheet Formula on the full duration. Make-up payroll applies when the make-up session is completed.</span>';
    }

    function openMakeupSessionModal() {
        const modal = ensureMakeupSessionModal();
        modal.querySelector('#makeupSessionDate').value = '';
        modal.querySelector('#makeupSessionStart').value = sessionDefaultStartTime || '';
        modal.querySelector('#makeupSessionEnd').value = sessionDefaultEndTime || '';
        modal.querySelector('#makeupSessionDurationPercent').value = String(sessionMakeupDefaultPercent || 100);
        modal.querySelector('#makeupSessionTeacherId').value = sessionDefaultTeacherId || '';
        modal.querySelector('#makeupSessionTeacherName').value = sessionDefaultTeacherName || sessionDefaultTeacherId || '';
        modal.querySelector('#makeupSessionRoom').value = sessionDefaultRoom || '';
        modal.querySelector('#makeupSessionReason').value = '';
        const historyNote = sessionMakeupHistory.length
            ? '<div class="mt-2 text-warning"><i class="bi bi-exclamation-triangle me-1"></i>' + sessionMakeupHistory.length + ' make-up session(s) already exist for this original session.</div>'
            : '';
        modal.querySelector('#makeupSessionContext').innerHTML = '<strong>Original session:</strong> ' + attendanceAttachmentEscape(sessionManagerSessionId) + historyNote;
        syncMakeupSessionDurationPreview();
        if (window.bootstrap) window.bootstrap.Modal.getOrCreateInstance(modal).show();
    }

    async function createMakeupSessionFromModal() {
        const modal = ensureMakeupSessionModal();
        const button = modal.querySelector('#makeupSessionCreate');
        const oldHtml = button ? button.innerHTML : '';
        const payload = {
            date: modal.querySelector('#makeupSessionDate')?.value || '',
            startTime: modal.querySelector('#makeupSessionStart')?.value || '',
            endTime: modal.querySelector('#makeupSessionEnd')?.value || '',
            makeupDurationPercent: modal.querySelector('#makeupSessionDurationPercent')?.value || sessionMakeupDefaultPercent || 100,
            teacherId: modal.querySelector('#makeupSessionTeacherId')?.value || '',
            teacherName: modal.querySelector('#makeupSessionTeacherName')?.value || '',
            room: modal.querySelector('#makeupSessionRoom')?.value || '',
            reason: modal.querySelector('#makeupSessionReason')?.value || '',
            actionStateId
        };
        if (!payload.date) {
            await showMakeupMessage({ title: 'Date Required', icon: 'warning', message: 'Please select the make-up session date.', buttons: [{ text: 'OK', class: 'btn-primary' }] });
            return;
        }
        try {
            if (button) {
                button.disabled = true;
                button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Creating...';
            }
            if (typeof window.showLoading === 'function') window.showLoading('Creating make-up session...');
            const submitMakeup = async (bodyPayload) => {
                const response = await fetch(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/makeup`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true', 'X-Requested-With': 'XMLHttpRequest' },
                    credentials: 'same-origin',
                    body: JSON.stringify(bodyPayload)
                });
                const parsed = await response.json().catch(() => ({ status: 'error', message: 'Unable to read server response.' }));
                return { response, parsed };
            };
            let { response, parsed: result } = await submitMakeup(payload);
            if (result.status === 'warning' && result.code === 'MAKEUP_SESSION_WARNINGS') {
                const warningList = Array.isArray(result?.data?.warnings) && result.data.warnings.length
                    ? '<ul>' + result.data.warnings.map((w) => '<li>' + attendanceAttachmentEscape(w) + '</li>').join('') + '</ul>'
                    : '';
                if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
                const selected = await showMakeupMessage({
                    title: 'Review Make-up Warnings',
                    icon: 'warning',
                    message: (result.message || 'Review warnings before creating this make-up session.') + warningList,
                    buttons: [{ text: 'Cancel', class: 'btn-secondary' }, { text: 'Create Anyway', class: 'btn-warning' }]
                });
                if (selected !== 'Create Anyway') return;
                if (typeof window.showLoading === 'function') window.showLoading('Creating make-up session...');
                ({ response, parsed: result } = await submitMakeup({ ...payload, force: true }));
            }
            if (!response.ok || result.status !== 'success') throw new Error(result.message || 'Could not create make-up session.');
            if (window.bootstrap) window.bootstrap.Modal.getOrCreateInstance(modal).hide();
            const warnings = Array.isArray(result?.data?.warnings) && result.data.warnings.length
                ? '<hr><strong>Warnings</strong><ul>' + result.data.warnings.map((w) => '<li>' + attendanceAttachmentEscape(w) + '</li>').join('') + '</ul>'
                : '';
            const selected = await showMakeupMessage({
                title: 'Make-up Session Created',
                icon: result?.data?.warnings?.length ? 'warning' : 'success',
                message: (result.message || 'Make-up session created.') + warnings,
                buttons: [{ text: 'Open Make-up Session', class: 'btn-primary' }, { text: 'Close', class: 'btn-secondary' }]
            });
            const newSessionId = result?.data?.makeupSession?.sessionId;
            if (selected === 'Open Make-up Session' && newSessionId) {
                window.open(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(newSessionId))}`, '_blank', 'noopener');
            }
            window.location.reload();
        } catch (error) {
            await showMakeupMessage({ title: 'Make-up Session Failed', icon: 'error', message: error.message || 'Could not create make-up session.', buttons: [{ text: 'Close', class: 'btn-secondary' }] });
        } finally {
            if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
            if (button) {
                button.disabled = false;
                button.innerHTML = oldHtml;
            }
        }
    }

    if (sessionCanCreateMakeup) {
        document.getElementById('btnCreateMakeupSession')?.addEventListener('click', openMakeupSessionModal);
        document.getElementById('btnCreateMakeupSessionInline')?.addEventListener('click', openMakeupSessionModal);
    }

    document.getElementById('btnToggleSessionLock')?.addEventListener('click', async () => {
        const btn = document.getElementById('btnToggleSessionLock');
        if (!btn || !sessionCanToggleLock) return;
        if (typeof showMessageModal !== 'function') return;
        const nextLocked = String(btn.dataset.nextLocked || '').toLowerCase() === 'true';
        const actionLabel = nextLocked ? 'lock' : 'unlock';
        const confirmButton = nextLocked ? 'Lock session' : 'Unlock session';
        const proceed = (await showMessageModal({
            title: nextLocked ? 'Lock session?' : 'Unlock session?',
            icon: 'question',
            message: nextLocked
                ? 'Teachers will no longer be able to edit this session until an administrator unlocks it.'
                : 'Teachers will be able to edit this session again.',
            buttons: [
                { text: 'Cancel', class: 'btn-secondary' },
                { text: confirmButton, class: nextLocked ? 'btn-warning' : 'btn-success' }
            ]
        })) === confirmButton;
        if (!proceed) return;
        btn.disabled = true;
        try {
            const body = new URLSearchParams();
            body.set('locked', nextLocked ? 'true' : 'false');
            body.set('actionStateId', actionStateId);
            const res = await fetch(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/lock`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-AJAX-Request': 'true',
                    'Accept': 'application/json'
                },
                body: body.toString()
            });
            const result = await res.json().catch(() => null);
            if (!res.ok || !result || result.status !== 'success') {
                throw new Error(result?.message || `Failed to ${actionLabel} session.`);
            }
            window.location.reload();
        } catch (error) {
            await showMessageModal({
                title: 'Lock update failed',
                icon: 'error',
                message: error?.message || `Failed to ${actionLabel} session.`,
                buttons: [{ text: 'OK', class: 'btn-primary' }]
            });
            btn.disabled = false;
        }
    });

    window.__attendanceMatrixPolicy = <%- JSON.stringify(typeof attendanceMatrixPolicyResolved !== 'undefined' && attendanceMatrixPolicyResolved ? attendanceMatrixPolicyResolved : { disqualifyLateMinutes: 30, disqualifyEarlyLeaveMinutes: 30, disqualifyCombinedMissedMinutes: null, scheduledMinutes: 180 }) %>;
    window.__conductRatingScale = <%- JSON.stringify(typeof conductRatingScaleResolved !== 'undefined' && conductRatingScaleResolved ? conductRatingScaleResolved : { levels: conductScaleDefaultLevels }) %>;
    const sessionConductReadOnly = <%= JSON.stringify(!!isReadOnly) %>;
    const canManageConductRatingScaleClient = <%- jsonForScript(Boolean(canManageConductRatingScaleFlag)) %>;
    const conductDimensionMeta = <%- jsonForScript(conductDimensions) %>;
    const CONDUCT_SCALE_FALLBACK_LEVELS = <%- jsonForScript(conductScaleDefaultLevels) %>;
    const CONDUCT_NA_LEVEL = <%- jsonForScript(conductNaLevel) %>;
    let sessionConductReadyForReports = <%- jsonForScript(Boolean(conductReadyForReports)) %>;
    const sessionHasReportsForConduct = <%- jsonForScript(Boolean(hasSessionReportsAssigned)) %>;

    function conductEscapeHtml(value) {
        return String(value || '').replace(/[&<>"']/g, (ch) => ({
            '&': '&amp;',
            '<': '&lt;',
            '>': '&gt;',
            '"': '&quot;',
            "'": '&#39;'
        }[ch]));
    }

    function getConductScaleLevels() {
        const levels = window.__conductRatingScale?.levels;
        return Array.isArray(levels) && levels.length ? levels : CONDUCT_SCALE_FALLBACK_LEVELS;
    }

    function getConductPickerLevels() {
        return [...getConductScaleLevels(), CONDUCT_NA_LEVEL];
    }

    function conductDisplayCode(level) {
        if (!level) return '';
        return String(level.displayCode || level.code || '').trim();
    }

    function normalizeConductPercent(value, fallback = 100) {
        if (value === null || value === undefined || value === '') {
            if (fallback === null || fallback === undefined) return null;
            return normalizeConductPercent(fallback, 100);
        }
        const token = String(value).trim().toLowerCase();
        if (token === 'n/a' || token === 'na') return null;
        const n = Number(value);
        if (!Number.isFinite(n)) {
            if (fallback === null || fallback === undefined) return null;
            const fallbackNumber = Number(fallback);
            if (!Number.isFinite(fallbackNumber)) return null;
            return Math.max(0, Math.min(100, Math.round(fallbackNumber * 10) / 10));
        }
        return Math.max(0, Math.min(100, Math.round(n * 10) / 10));
    }

    function percentToConductLevel(percent) {
        if (percent === null || percent === undefined || percent === '') return { ...CONDUCT_NA_LEVEL };
        const value = normalizeConductPercent(percent, null);
        if (value === null) return { ...CONDUCT_NA_LEVEL };
        const levels = getConductScaleLevels();
        const match = levels.find((row) => value >= Number(row.minPercent) && value <= Number(row.maxPercent));
        return match ? { ...match } : { ...levels[0] };
    }

    function levelByConductCode(code) {
        const key = String(code || '').trim();
        if (key === 'NA' || key === 'N/A') return { ...CONDUCT_NA_LEVEL };
        const match = getConductScaleLevels().find((row) => row.code === key);
        return match ? { ...match } : null;
    }

    function updateConductCellUi(cell) {
        if (!cell) return;
        const percentInput = cell.querySelector('.conduct-percent-input');
        const raw = percentInput?.value;
        const isEmpty = raw === '' || raw === null || raw === undefined;
        const percent = isEmpty ? null : normalizeConductPercent(raw, null);
        const level = percentToConductLevel(percent);
        cell.querySelectorAll('.conduct-emoji-btn, .conduct-code-btn').forEach((btn) => {
            const active = btn.dataset.code === level.code;
            btn.classList.toggle('active', active);
            btn.setAttribute('aria-pressed', active ? 'true' : 'false');
        });
        if (percentInput) {
            percentInput.value = percent === null ? '' : String(percent);
        }
        cell.dataset.levelCode = level.code;
    }

    function applyConductLevel(cell, code, options = {}) {
        const level = levelByConductCode(code);
        if (!level || !cell) return;
        const percentInput = cell.querySelector('.conduct-percent-input');
        if (percentInput && !options.keepPercent) {
            percentInput.value = level.code === 'NA' || level.defaultPercent == null ? '' : String(level.defaultPercent);
        }
        updateConductCellUi(cell);
    }

    function applyConductPercent(cell, percent) {
        if (!cell) return;
        const percentInput = cell.querySelector('.conduct-percent-input');
        if (percentInput) {
            const normalized = normalizeConductPercent(percent, null);
            percentInput.value = normalized === null ? '' : String(normalized);
        }
        updateConductCellUi(cell);
    }

    function readConductPercentFromCell(cell, fallback = null) {
        if (!cell) return normalizeConductPercent(fallback, null);
        return normalizeConductPercent(cell.querySelector('.conduct-percent-input')?.value, fallback);
    }

    function initConductRatingCell(cell) {
        if (!cell) return;
        updateConductCellUi(cell);
        if (cell.dataset.conductBound === '1') return;
        cell.dataset.conductBound = '1';
        cell.querySelectorAll('.conduct-emoji-btn, .conduct-code-btn').forEach((btn) => {
            btn.addEventListener('click', () => {
                if (sessionConductReadOnly) return;
                applyConductLevel(cell, btn.dataset.code);
            });
        });
        const percentInput = cell.querySelector('.conduct-percent-input');
        percentInput?.addEventListener('change', () => updateConductCellUi(cell));
        percentInput?.addEventListener('input', () => updateConductCellUi(cell));
    }

    function initAllConductRatingCells(root = document) {
        root.querySelectorAll('.conduct-rating-cell').forEach(initConductRatingCell);
    }

    function buildConductEmojiPickerHtml(dimensionKey, personId) {
        const levels = getConductPickerLevels();
        const buttons = levels.map((level) => {
            const title = level.code === 'NA'
                ? conductEscapeHtml(level.label)
                : `${conductEscapeHtml(level.label)} (${level.minPercent}%–${level.maxPercent}%)`;
            return `<button type="button" class="conduct-emoji-btn conduct-code-btn" data-code="${conductEscapeHtml(level.code)}" title="${title}">${conductEscapeHtml(conductDisplayCode(level))}</button>`;
        }).join('');
        return `<div class="conduct-rating-cell" data-dimension="${conductEscapeHtml(dimensionKey)}" data-personid="${conductEscapeHtml(personId)}"><div class="conduct-emoji-picker" role="group">${buttons}</div><input type="number" class="form-control form-control-sm conduct-percent-input" min="0" max="100" step="0.5" value=""${sessionConductReadOnly ? ' disabled' : ''}></div>`;
    }

    function renderConductBulkLegend() {
        const host = document.getElementById('conductBulkLegend');
        if (!host) return;
        host.innerHTML = getConductPickerLevels().map((level) => {
            const range = level.code === 'NA' ? '' : `<span class="text-muted">${level.minPercent}%–${level.maxPercent}%</span>`;
            return `<span class="conduct-legend-chip" title="${conductEscapeHtml(level.label)}"><strong>${conductEscapeHtml(conductDisplayCode(level))}</strong><span class="text-muted">${conductEscapeHtml(level.label)}</span>${range}</span>`;
        }).join('');
    }

    function setConductReadyUi(ready) {
        sessionConductReadyForReports = !!ready;
        const badge = document.getElementById('conductReadyBadge');
        if (badge) {
            badge.className = `badge ${sessionConductReadyForReports ? 'bg-success' : 'bg-warning text-dark'}`;
            badge.textContent = sessionConductReadyForReports ? 'Completed' : 'Required before reports';
        }
        renderSessionReportInstances();
    }

    function showConductRequiredModal() {
        const message = 'Complete and save class conduct (Step 1) before opening or filling reports for this session.';
        if (typeof showMessageModal === 'function') {
            return showMessageModal({
                title: 'Class conduct required',
                icon: 'warning',
                message,
                buttons: [{ text: 'OK', class: 'btn-primary' }]
            });
        }
        window.alert(message);
        return Promise.resolve();
    }

    function collectConductRosterPayload() {
        return Array.from(document.querySelectorAll('#conductTable .conduct-row')).map((row) => {
            const personId = String(row.dataset.personid || '').trim();
            const payload = { personId };
            (conductDimensionMeta || []).forEach((dim) => {
                const cell = row.querySelector(`.conduct-rating-cell[data-dimension="${dim.key}"]`);
                const value = readConductPercentFromCell(cell, null);
                payload[dim.valueKey] = value;
            });
            return payload;
        }).filter((row) => row.personId);
    }

    async function saveSessionConductForReports() {
        if (sessionConductReadOnly) return;
        const btn = document.getElementById('btnSaveSessionConduct');
        if (btn) btn.disabled = true;
        if (typeof window.showLoading === 'function') window.showLoading('Saving class conduct...');
        try {
            const body = new URLSearchParams();
            body.set('roster', JSON.stringify(collectConductRosterPayload()));
            body.set('actionStateId', actionStateId);
            const res = await fetch(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/conduct`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-AJAX-Request': 'true',
                    'Accept': 'application/json'
                },
                body: body.toString()
            });
            const result = await res.json().catch(() => ({}));
            if (!res.ok || result.status !== 'success') {
                throw new Error(result.message || 'Failed to save class conduct.');
            }
            setConductReadyUi(true);
            if (typeof showMessageModal === 'function') {
                await showMessageModal({
                    title: 'Class conduct saved',
                    icon: 'success',
                    message: result.message || 'You can now fill reports for this session.',
                    buttons: [{ text: 'OK', class: 'btn-primary' }]
                });
            }
        } catch (error) {
            if (typeof showMessageModal === 'function') {
                await showMessageModal({
                    title: 'Unable to save class conduct',
                    icon: 'error',
                    message: error?.message || 'Failed to save class conduct.',
                    buttons: [{ text: 'OK', class: 'btn-danger' }]
                });
            } else {
                window.alert(error?.message || 'Failed to save class conduct.');
            }
        } finally {
            if (btn) btn.disabled = false;
            if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
        }
    }

    document.getElementById('btnSaveSessionConduct')?.addEventListener('click', () => {
        saveSessionConductForReports();
    });

    document.addEventListener('click', function (event) {
        const gated = event.target.closest('.js-report-action-requires-conduct');
        if (!gated) return;
        if (!sessionHasReportsForConduct || sessionConductReadyForReports) return;
        event.preventDefault();
        event.stopPropagation();
        showConductRequiredModal();
    }, true);

    function getConductTableCell(personId, dimensionKey) {
        const row = document.querySelector(`.conduct-row[data-personid="${CSS.escape(String(personId || ''))}"]`);
        return row?.querySelector(`.conduct-rating-cell[data-dimension="${dimensionKey}"]`) || null;
    }

    function syncConductModalFromTable() {
        const body = document.getElementById('conductBulkRatingBody');
        if (!body) return;
        const rows = Array.from(document.querySelectorAll('.conduct-row'));
        body.innerHTML = rows.map((row) => {
            const personId = row.getAttribute('data-personid') || '';
            const studentName = row.getAttribute('data-student-name') || personId;
            const cells = conductDimensionMeta.map((dim) => {
                const tableCell = getConductTableCell(personId, dim.key);
                const percent = readConductPercentFromCell(tableCell, 100);
                return `<td class="text-center"><div class="conduct-bulk-cell" data-personid="${conductEscapeHtml(personId)}" data-dimension="${conductEscapeHtml(dim.key)}">${buildConductEmojiPickerHtml(dim.key, personId)}</div></td>`;
            }).join('');
            return `<tr data-personid="${conductEscapeHtml(personId)}"><td class="conduct-bulk-student-name ps-3 fw-semibold">${conductEscapeHtml(studentName)}</td>${cells}</tr>`;
        }).join('');
        body.querySelectorAll('.conduct-rating-cell').forEach((cell) => {
            const personId = cell.closest('.conduct-bulk-cell')?.dataset.personid || cell.dataset.personid;
            const dimensionKey = cell.closest('.conduct-bulk-cell')?.dataset.dimension || cell.dataset.dimension;
            const tableCell = getConductTableCell(personId, dimensionKey);
            const percent = readConductPercentFromCell(tableCell, 100);
            applyConductPercent(cell, percent);
            initConductRatingCell(cell);
        });
    }

    function syncConductTableFromModal() {
        document.querySelectorAll('#conductBulkRatingBody .conduct-bulk-cell').forEach((bulkCell) => {
            const personId = bulkCell.dataset.personid;
            const dimensionKey = bulkCell.dataset.dimension;
            const modalCell = bulkCell.querySelector('.conduct-rating-cell');
            const tableCell = getConductTableCell(personId, dimensionKey);
            if (!modalCell || !tableCell) return;
            applyConductPercent(tableCell, readConductPercentFromCell(modalCell, 100));
        });
    }


    function setAllConductCellsToLevel(code, root = document) {
        const level = levelByConductCode(code);
        if (!level || sessionConductReadOnly) return;
        root.querySelectorAll(".conduct-rating-cell").forEach((cell) => applyConductLevel(cell, level.code));
    }

    function setConductColumnToLevel(dimensionKey, code, root = document) {
        const level = levelByConductCode(code);
        if (!level || sessionConductReadOnly) return;
        const selector = '.conduct-rating-cell[data-dimension="' + CSS.escape(String(dimensionKey || '')) + '"]';
        root.querySelectorAll(selector).forEach((cell) => applyConductLevel(cell, level.code));
    }

    function refreshConductScaleUi() {
        renderConductBulkLegend();
        document.querySelectorAll('#conductScaleSettingsBody .conduct-scale-level-row').forEach((row, index) => {
            const level = getConductScaleLevels()[index];
            if (!level) return;
            row.querySelector('.conduct-scale-label').value = level.label || level.code;
            row.querySelector('.conduct-scale-display').value = level.displayCode || level.code || '';
            row.querySelector('.conduct-scale-min').value = level.minPercent;
            row.querySelector('.conduct-scale-max').value = level.maxPercent;
            row.querySelector('.conduct-scale-default').value = level.defaultPercent;
        });
    }

    function collectConductScaleSettingsFromForm() {
        return Array.from(document.querySelectorAll('#conductScaleSettingsBody .conduct-scale-level-row')).map((row) => ({
            code: row.querySelector('td.fw-bold')?.textContent?.trim() || '',
            label: row.querySelector('.conduct-scale-label')?.value || '',
            displayCode: row.querySelector('.conduct-scale-display')?.value || '',
            minPercent: row.querySelector('.conduct-scale-min')?.value,
            maxPercent: row.querySelector('.conduct-scale-max')?.value,
            defaultPercent: row.querySelector('.conduct-scale-default')?.value
        }));
    }

    let conductBulkModalInstance = null;
    const conductBulkModalEl = document.getElementById('conductBulkRatingModal');
    if (conductBulkModalEl && window.bootstrap) conductBulkModalInstance = new bootstrap.Modal(conductBulkModalEl);
    let conductScaleSettingsModalInstance = null;
    const conductScaleSettingsModalEl = document.getElementById('conductScaleSettingsModal');
    if (conductScaleSettingsModalEl && window.bootstrap) conductScaleSettingsModalInstance = new bootstrap.Modal(conductScaleSettingsModalEl);

