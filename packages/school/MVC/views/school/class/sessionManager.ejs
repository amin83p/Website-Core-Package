<style>
    .session-manager-page { --session-sidebar-w: 260px; --session-sidebar-collapsed-w: 72px; --session-topbar-h: auto; }
    .att-label { background-color: transparent; border: 1px solid transparent; color: #adb5bd; transition: all 0.2s ease-in-out; }
    .att-label:hover { background-color: #f8f9fa; color: #495057; }
    .btn-check[value="present"]:checked + .att-label { background-color: #198754; color: #fff; font-weight: bold; }
    .btn-check[value="late"]:checked + .att-label { background-color: #ffc107; color: #000; font-weight: bold; }
    .btn-check[value="excused"]:checked + .att-label { background-color: #0dcaf0; color: #000; font-weight: bold; }
    .btn-check[value="absent"]:checked + .att-label { background-color: #dc3545; color: #fff; font-weight: bold; }
    .conduct-rating-input {
        max-width: 7rem;
        text-align: center;
        font-weight: 700;
        border-radius: 10px;
    }
    .conduct-rating-input:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 0.18rem rgba(37, 99, 235, 0.12);
    }
    .conduct-rating-help {
        color: #64748b;
        font-size: 0.75rem;
        line-height: 1.25;
    }

    .comment-thread { max-height: 250px; overflow-y: auto; background: #f8f9fa; border-radius: 6px; padding: 10px; }
    .comment-bubble { background: #fff; border: 1px solid #e9ecef; border-radius: 8px; padding: 10px; margin-bottom: 10px; box-shadow: 0 1px 2px rgba(0,0,0,0.05); }
    .comment-author { font-weight: bold; font-size: 0.8rem; color: #495057; }
    .comment-time { font-size: 0.7rem; color: #adb5bd; float: right; }
    .mention-badge { background-color: #e7f1ff; color: #0d6efd; font-size: 0.75rem; padding: 2px 6px; border-radius: 12px; font-weight: bold; border: 1px solid #b6d4fe; }

    .session-summary-card {
        border: 1px solid #e6ecf5;
        border-radius: 12px;
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
        padding: 10px 12px;
    }
    .session-summary-label { color: #6c757d; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.04em; }
    .session-summary-value { color: #1f2a37; font-size: 1.1rem; font-weight: 700; line-height: 1.1; }

    /* Page header: match term edit — title row + dashboard; second row for other actions */
    .session-manager-toolbar-row {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-end;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }
    .session-manager-toolbar-row .btn-save-session,
    .session-manager-toolbar-row .btn-close-session {
        min-width: 7.5rem;
        font-weight: 600;
    }

    /* Info card: compact cluster + location top-right; three equal “slots” on second row */
    .session-manager-info-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e2e8f0 !important;
        border-radius: 14px;
    }
    .session-manager-info-card .info-label {
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #64748b;
        font-weight: 600;
        margin-bottom: 0.15rem;
    }
    .session-manager-info-card .info-value {
        font-size: 0.95rem;
        font-weight: 600;
        color: #0f172a;
        line-height: 1.25;
    }
    .session-info-cluster {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        gap: 0.35rem 1.25rem;
    }
    .session-info-cluster .info-block {
        min-width: 0;
    }
    .session-manager-location-block {
        min-width: 200px;
        max-width: 340px;
    }
    .session-manager-location-block #sessionRoom {
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        font-weight: 500;
        font-size: 0.9rem;
    }
    #sessionStatusSelect.session-status-select-compact {
        width: 100%;
        max-width: 100%;
        font-weight: 600;
        font-size: 0.875rem;
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        padding: 0.35rem 2rem 0.35rem 0.5rem;
        box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.05);
    }
    .session-manager-field-placeholder {
        min-height: calc(1.5em + 0.75rem + 2px);
        border: 1px dashed #e2e8f0;
        border-radius: 8px;
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 0.75rem;
        color: #94a3b8;
    }

    .session-exam-open-switch {
        min-height: 1.75rem;
        padding-top: 0.15rem;
    }
    .session-exam-open-switch .form-check-input {
        width: 2.25rem;
        height: 1.15rem;
        cursor: pointer;
    }
    .session-exam-open-switch .form-check-label {
        cursor: pointer;
        color: #334155;
        font-weight: 600;
    }

    /* Shell + sidebar */
    .session-manager-shell {
        display: flex;
        align-items: stretch;
        gap: 0;
        min-height: 60vh;
    }
    .session-manager-sidebar {
        flex: 0 0 var(--session-sidebar-w);
        width: var(--session-sidebar-w);
        background: #fff;
        border: 1px solid #e2e8f0;
        border-radius: 12px 0 0 12px;
        display: flex;
        flex-direction: column;
        transition: width 0.22s ease, flex-basis 0.22s ease;
        overflow: hidden;
    }
    .session-manager-sidebar.collapsed {
        flex-basis: var(--session-sidebar-collapsed-w);
        width: var(--session-sidebar-collapsed-w);
    }
    .session-manager-sidebar-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.5rem 0.5rem 0.5rem 0.65rem;
        border-bottom: 1px solid #f1f5f9;
        background: #fafbfc;
    }
    .session-manager-sidebar-nav {
        flex: 1;
        padding: 0.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
        overflow-y: auto;
    }
    .session-manager-nav-item {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        width: 100%;
        text-align: left;
        border: none;
        background: transparent;
        border-radius: 10px;
        padding: 0.65rem 0.75rem;
        font-weight: 600;
        font-size: 0.9rem;
        color: #475569;
        transition: background 0.15s ease, color 0.15s ease;
    }
    .session-manager-nav-item:hover:not(:disabled) { background: #f1f5f9; color: #0f172a; }
    .session-manager-nav-item.active { background: #e0ecff; color: #1d4ed8; }
    .session-manager-nav-item:disabled { opacity: 0.45; cursor: not-allowed; }
    .session-manager-sidebar.collapsed .session-manager-nav-label { display: none; }
    .session-manager-sidebar.collapsed .session-manager-nav-item { justify-content: center; padding: 0.65rem; }
    .session-manager-sidebar.collapsed .session-manager-sidebar-head .session-manager-nav-label { display: none; }

    .session-manager-main {
        flex: 1;
        min-width: 0;
        background: #fff;
        border: 1px solid #e2e8f0;
        border-left: none;
        border-radius: 0 12px 12px 0;
        padding: 1rem 1.15rem 1.25rem;
    }
    @media (max-width: 991.98px) {
        .session-manager-shell { flex-direction: column; }
        .session-manager-sidebar {
            flex-basis: auto;
            width: 100%;
            border-radius: 12px 12px 0 0;
            border-bottom: none;
            flex-direction: row;
            flex-wrap: wrap;
            align-items: center;
        }
        .session-manager-sidebar.collapsed { width: 100%; flex-basis: auto; }
        .session-manager-sidebar-nav {
            flex-direction: row;
            flex-wrap: wrap;
            width: 100%;
            padding: 0.35rem;
        }
        .session-manager-nav-item { flex: 1 1 auto; min-width: 120px; justify-content: center; }
        .session-manager-main { border-radius: 0 0 12px 12px; border: 1px solid #e2e8f0; border-top: none; }
    }

    .session-panel { display: none; animation: sessionPanelIn 0.2s ease; }
    .session-panel.active { display: block; }
    @keyframes sessionPanelIn { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: none; } }

    .session-placeholder-card {
        border: 2px dashed #e2e8f0;
        border-radius: 12px;
        padding: 2.5rem 1.5rem;
        text-align: center;
        color: #64748b;
        background: #fafbfc;
    }

    .session-gradebook-card .gb-activity-body {
        white-space: pre-wrap;
        font-size: 0.9rem;
        max-height: 220px;
        overflow-y: auto;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 0.75rem 1rem;
    }
    .session-gradebook-card .gb-score-input:disabled {
        background: #f1f5f9;
        cursor: not-allowed;
    }
    .session-gradebook-card .gb-collapse-toggle {
        flex-shrink: 0;
        line-height: 1;
        color: #64748b;
    }
    .session-gradebook-card .gb-collapse-toggle:hover {
        color: #1d4ed8;
        background: #f1f5f9 !important;
    }
</style>

<div class="sections-page session-manager-page">
    <% const disabledAttr = isReadOnly ? 'disabled' : ''; %>
    <% function jsonForScript(value) {
        if (value === undefined) return 'undefined';
        const s = JSON.stringify(value);
        if (s === undefined) return 'null';
        return s.replace(/</g, '\\u003c').replace(/\u2028/g, '\\u2028').replace(/\u2029/g, '\\u2029').replace(/&/g, '\\u0026');
    } %>
    <%
        const sessionRatingValue = (value) => {
            const n = Number(value);
            if (!Number.isFinite(n)) return 100;
            return Math.max(0, Math.min(100, Math.round(n * 100) / 100));
        };
        const statusRows = Array.isArray(sessionStatusMeta) ? sessionStatusMeta : [];
        const activeStatusRows = statusRows.filter((row) => row && row.active !== false);
        const availableStatusRows = activeStatusRows.length ? activeStatusRows : statusRows;
        const fallbackStatusCode = String(defaultSessionStatusCode || availableStatusRows.find((row) => row?.code === 'scheduled')?.code || availableStatusRows[0]?.code || 'scheduled').toLowerCase();
        const normalizeStatusCode = (value) => String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
        const attendanceSummary = (session.roster || []).reduce((acc, row) => {
            const key = String(row?.attendance || '').trim().toLowerCase();
            if (Object.prototype.hasOwnProperty.call(acc, key)) acc[key] += 1;
            return acc;
        }, { present: 0, late: 0, excused: 0, absent: 0 });
        const normalizedSessionStatus = normalizeStatusCode(session.status || fallbackStatusCode);
        const currentSessionStatus = availableStatusRows.some((row) => normalizeStatusCode(row?.code) === normalizedSessionStatus)
            ? normalizedSessionStatus
            : fallbackStatusCode;
        const attendanceMatrixHref = '/school/attendances?classId=' + encodeURIComponent(classData.id) + '&range=allTime';
        const gradesMatrixHref = '/school/grades-matrix?classId=' + encodeURIComponent(classData.id) + '&range=allTime';
        const smRegMode = String(classData.registrationMode || 'term_based').trim().toLowerCase();
        const smIsRolling = smRegMode === 'rolling';
        const smCycleStart = String(classData.cycleStartDate || '').trim();
        const smCycleEnd = String(classData.cycleEndDate || '').trim();
        const smCycleWindowLabel = smIsRolling
            ? (smCycleStart ? `${smCycleStart}${smCycleEnd ? ' to ' + smCycleEnd : ' onward'}` : 'Cycle start date missing')
            : '';
        const smSessionDate = String(session.date || '').trim();
        const smSessionOutsideCycle = smIsRolling
            && smCycleStart
            && (smSessionDate < smCycleStart || (smCycleEnd && smSessionDate > smCycleEnd));
        const finalGradesNavHref = smIsRolling
            ? '/school/classes/' + encodeURIComponent(classData.id) + '/enrollment-outcomes'
            : '/school/classes/' + encodeURIComponent(classData.id) + '/final-grades';
        const finalGradesNavLabel = smIsRolling ? 'Enrollment outcomes' : 'Final Grades';
    %>

    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
        <h1 class="page-heading size-md m-0 text-start"><i class="bi bi-journal-check me-2 text-primary"></i>Manage Session</h1>
        <a href="<%= schoolSectionDashboardHref %>" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md session-manager-nav-away" id="linkSessionDashboard" data-confirm-title="Go to dashboard?" data-confirm-message="Leave this page and go to the school dashboard? Unsaved changes will be lost unless you save first."><i class="bi bi-speedometer2 me-1"></i>Dashboard</a>
    </div>

    <div class="d-flex flex-wrap align-items-center gap-2 mb-3">
        <a href="<%= finalGradesNavHref %>" class="btn btn-outline-success btn-md session-manager-nav-away" id="linkFinalGradesNav" data-confirm-title="Leave session manager?" data-confirm-message="Open <%= finalGradesNavLabel %>? Unsaved changes on this page will be lost unless you save first."><i class="bi bi-award me-1"></i><%= finalGradesNavLabel %></a>
    </div>

    <div class="session-manager-toolbar-row">
        <div class="btn-group shadow-sm">
            <% if (prevSessionId) { %>
                <a href="/school/classes/<%= classData.id %>/sessions/<%= prevSessionId %>" class="btn btn-outline-primary bg-grey btn-md session-manager-nav-away" id="linkPrevSession" title="Previous session" data-confirm-title="Open previous session?" data-confirm-message="Leave this page and open the previous class session? Unsaved changes will be lost unless you save first."><i class="bi bi-chevron-left"></i></a>
            <% } else { %>
                <button type="button" class="btn btn-outline-secondary bg-light btn-md" disabled><i class="bi bi-chevron-left"></i></button>
            <% } %>
            <% if (nextSessionId) { %>
                <a href="/school/classes/<%= classData.id %>/sessions/<%= nextSessionId %>" class="btn btn-outline-primary bg-grey btn-md session-manager-nav-away" id="linkNextSession" title="Next session" data-confirm-title="Open next session?" data-confirm-message="Leave this page and open the next class session? Unsaved changes will be lost unless you save first."><i class="bi bi-chevron-right"></i></a>
            <% } else { %>
                <button type="button" class="btn btn-outline-secondary bg-light btn-md" disabled><i class="bi bi-chevron-right"></i></button>
            <% } %>
        </div>
        <a href="<%= attendanceMatrixHref %>" class="btn btn-outline-primary btn-md  fw-semibold session-manager-nav-away shadow-md" id="linkAttendanceMatrix" data-matrix-href="<%= attendanceMatrixHref %>" data-confirm-title="Open attendance matrix?" data-confirm-message="Open the attendance matrix? Unsaved changes on this page will be lost unless you save first."><i class="bi bi-grid-3x3 me-1"></i>Attendance matrix</a>
        <a href="<%= gradesMatrixHref %>" class="btn btn-outline-primary btn-md fw-semibold session-manager-nav-away shadow-md" id="linkGradesMatrix" data-matrix-href="<%= gradesMatrixHref %>" data-confirm-title="Open grades matrix?" data-confirm-message="Open the grades matrix? Unsaved changes on this page will be lost unless you save first."><i class="bi bi-table me-1"></i>Grades matrix</a>
        <% if (!isReadOnly) { %>
            <button type="button" class="btn btn-primary btn-md btn-filled btn-save-session shadow-md" id="btnSaveSession"><i class="bi bi-save me-1"></i>Save session</button>
        <% } %>
        <button type="button" class="btn btn-warning btn-md btn-filled btn-close-session" id="btnCloseSessionManager"><i class="bi bi-x-lg me-1"></i>Close</button>
    </div>

    <div class="card session-manager-info-card shadow-sm mb-3">
        <div class="card-body p-3">
            <div class="row g-2 g-md-3 align-items-start mb-3">
                <div class="col">
                    <div class="session-info-cluster">
                        <div class="info-block">
                            <div class="info-label">Class</div>
                            <div class="info-value text-truncate" style="max-width: 28rem;" title="<%= classData.title %>"><%= classData.title %></div>
                        </div>
                        <div class="info-block">
                            <div class="info-label">Date</div>
                            <div class="info-value"><%= session.date %></div>
                        </div>
                        <div class="info-block">
                            <div class="info-label">Time</div>
                            <div class="info-value text-nowrap"><%= session.startTime %> – <%= session.endTime %></div>
                        </div>
                        <% if (smIsRolling) { %>
                        <div class="info-block">
                            <div class="info-label">Cycle window</div>
                            <div class="info-value text-nowrap"><%= smCycleWindowLabel %></div>
                        </div>
                        <% } %>
                    </div>
                </div>
                <div class="col-12 col-md-auto ms-md-auto session-manager-location-block text-md-end">
                    <label class="info-label d-block text-md-end" for="sessionRoom">Location</label>
                    <input type="text" id="sessionRoom" class="form-control form-control-sm text-md-end" value="<%= session.room || '' %>" placeholder="Room, lab, field…" <%- disabledAttr %> autocomplete="off">
                </div>
            </div>
            <% if (smIsRolling) { %>
              <div class="alert <%= smSessionOutsideCycle ? 'alert-danger' : 'alert-info' %> border small py-2 mb-3">
                <% if (smSessionOutsideCycle) { %>
                  This session date is outside the rolling cycle window. Update the class cycle dates or rebuild the session ledger before saving session changes.
                <% } else { %>
                  Rolling sessions are limited to the cycle window: <strong><%= smCycleWindowLabel %></strong>.
                <% } %>
              </div>
            <% } %>
            <div class="row g-2 align-items-end">
                <div class="col-md-4">
                    <label class="info-label d-block" for="sessionStatusSelect">Session status</label>
                    <select id="sessionStatusSelect" class="form-select form-select-sm session-status-select-compact" <%= disabledAttr ? 'disabled' : '' %>>
                        <% availableStatusRows.forEach((statusRow) => { %>
                            <% const statusCode = normalizeStatusCode(statusRow?.code); %>
                            <% if (statusCode) { %>
                                <option
                                    value="<%= statusCode %>"
                                    data-label="<%= statusRow?.label || statusCode %>"
                                    data-color-bg="<%= statusRow?.colorBg || '#e2e3e5' %>"
                                    data-color-text="<%= statusRow?.colorText || '#41464b' %>"
                                    data-color-border="<%= statusRow?.colorBorder || '#c6c8ca' %>"
                                    <%= currentSessionStatus === statusCode ? 'selected' : '' %>>
                                    <%= statusRow?.label || statusCode %>
                                </option>
                            <% } %>
                        <% }) %>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="info-label d-block text-muted">Reserved</label>
                    <div class="session-manager-field-placeholder" title="Reserved for future session fields">—</div>
                </div>
                <div class="col-md-4">
                    <label class="info-label d-block text-muted">Reserved</label>
                    <div class="session-manager-field-placeholder" title="Reserved for future session fields">—</div>
                </div>
            </div>
        </div>
    </div>

    <% if (isSessionLocked) { %>
        <div class="alert alert-warning border-warning shadow-sm d-flex align-items-center mb-3">
            <i class="bi bi-lock-fill fs-3 me-3 text-warning"></i>
            <div>
                <h6 class="fw-bold mb-1">Session Locked</h6>
                <div class="small">
                    <% if (isReadOnly) { %>
                        This session has been locked by an administrator. You can view the details, but modifications are disabled.
                    <% } else { %>
                        This session is locked, but you have administrative override permissions to make changes.
                    <% } %>
                </div>
            </div>
        </div>
    <% } %>

    <div class="session-manager-shell" id="sessionManagerShell">
        <aside class="session-manager-sidebar" id="sessionManagerSidebar" aria-label="Session sections">
            <div class="session-manager-sidebar-head w-100">
                <span class="session-manager-nav-label small fw-bold text-secondary text-uppercase" style="letter-spacing:0.06em;">Sections</span>
                <button type="button" class="btn btn-sm btn-outline-secondary rounded-pill" id="btnToggleSessionSidebar" title="Collapse sidebar" aria-expanded="true" aria-controls="sessionManagerSidebar">
                    <i class="bi bi-layout-sidebar-inset" id="sessionSidebarToggleIcon"></i>
                </button>
            </div>
            <nav class="session-manager-sidebar-nav" role="tablist">
                <button type="button" class="session-manager-nav-item active" data-session-panel="attendance" role="tab" aria-selected="true">
                    <i class="bi bi-people-fill fs-5"></i><span class="session-manager-nav-label">Attendance</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="conduct" role="tab" aria-selected="false">
                    <i class="bi bi-person-hearts fs-5"></i><span class="session-manager-nav-label">Class Conduct</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="session" role="tab" aria-selected="false">
                    <i class="bi bi-journal-text fs-5"></i><span class="session-manager-nav-label">Session &amp; notes</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="curriculum" role="tab" aria-selected="false">
                    <i class="bi bi-book fs-5"></i><span class="session-manager-nav-label">Curriculum</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="content" title="Coming soon">
                    <i class="bi bi-folder2-open fs-5"></i><span class="session-manager-nav-label">Content</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="assignments">
                    <i class="bi bi-clipboard-check fs-5"></i><span class="session-manager-nav-label">Assignments</span>
                </button>
                <button type="button" class="session-manager-nav-item" data-session-panel="gradebook" title="Coming soon">
                    <i class="bi bi-journal-bookmark fs-5"></i><span class="session-manager-nav-label">Grade book</span>
                </button>
            </nav>
        </aside>

        <main class="session-manager-main">
            <div class="session-panel active" id="session-panel-attendance" role="tabpanel">
                <div class="row g-2 mb-3">
                    <div class="col-6 col-md-3">
                        <div class="session-summary-card h-100">
                            <div class="session-summary-label">Present</div>
                            <div class="session-summary-value text-success"><%= attendanceSummary.present %></div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="session-summary-card h-100">
                            <div class="session-summary-label">Late</div>
                            <div class="session-summary-value text-warning"><%= attendanceSummary.late %></div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="session-summary-card h-100">
                            <div class="session-summary-label">Excused</div>
                            <div class="session-summary-value text-info"><%= attendanceSummary.excused %></div>
                        </div>
                    </div>
                    <div class="col-6 col-md-3">
                        <div class="session-summary-card h-100">
                            <div class="session-summary-label">Absent</div>
                            <div class="session-summary-value text-danger"><%= attendanceSummary.absent %></div>
                        </div>
                    </div>
                </div>

                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
                        <h5 class="m-0 fw-bold text-primary"><i class="bi bi-people-fill me-2"></i>Attendance roster</h5>
                        <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
                            <% if (!isReadOnly && session.roster.length > 0) { %>
                                <div class="btn-group btn-group-sm" role="group" aria-label="Bulk attendance">
                                    <button type="button" class="btn btn-outline-success" id="btnAllPresent">All Present</button>
                                    <button type="button" class="btn btn-outline-warning" id="btnAllLate">All Late</button>
                                    <button type="button" class="btn btn-outline-danger" id="btnAllAbsent">All Absent</button>
                                </div>
                            <% } %>
