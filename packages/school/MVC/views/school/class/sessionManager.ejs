                    const mentionId = item.userId || item.id;
                    const name = item.displayName || item.name || item.email || mentionId;
                    if (mentionId && mentionId !== 'undefined' && !currentMentions.find(m => m.id === mentionId)) {
                        currentMentions.push({ id: mentionId, name: name });
                        renderMentions();
                    }
                }
            }));
        });
    }

    function renderMentions() {
        const area = document.getElementById('pendingMentionsArea');
        area.innerHTML = '';
        currentMentions.forEach(m => {
            area.innerHTML += `<span class="mention-badge shadow-sm">@${m.name} <i class="bi bi-x-circle ms-1" style="cursor:pointer;" onclick="removeMention('${m.id}')"></i></span>`;
        });
    }

    window.removeMention = (id) => {
        currentMentions = currentMentions.filter(m => m.id !== id);
        renderMentions();
    };

    const btnSaveComment = document.getElementById('btn_saveComment');
    if (btnSaveComment) {
        btnSaveComment.addEventListener('click', async () => {
            const studentId = document.getElementById('modalPersonId').value;
            const text = document.getElementById('inp_newComment').value;

            if (!text.trim()) return;

            const btn = document.getElementById('btn_saveComment');
            const origBtn = btn.innerHTML;
            btn.innerHTML = 'Saving...'; btn.disabled = true;

            try {
                const payload = {
                    classId: sessionManagerClassId,
                    sessionId: sessionManagerSessionId,
                    studentPersonId: studentId,
                    text: text,
                    mentions: currentMentions,
                    attachment: await uploadSchoolSessionFile(document.getElementById('inp_newCommentFile'), 'comment', studentId),
                    actionStateId
                };

                const res = await fetch('/school/attendances/api/comment', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'X-AJAX-Request': 'true' },
                    body: JSON.stringify(payload)
                });

                let result;
                try {
                    result = await res.json();
                } catch (parseError) {
                    throw new Error('Server returned an invalid response. Please verify the API route exists.');
                }
                const guarded = typeof window.applyGuardedApiResult === 'function'
                    ? await window.applyGuardedApiResult(result, { busyTitle: 'Save Comment In Progress', replayTitle: 'Comment Already Saved' })
                    : { stop: false };
                if (guarded.stop) return;

                if (result.status !== 'success') throw new Error(result.message);

                const thread = document.getElementById('det_commentsThread');
                let mentionHtml = '';
                (result.comment.mentions || []).forEach(m => mentionHtml += `<span class="mention-badge me-1">@${m.name}</span>`);
                const attachmentHtml = result.comment.attachment ? `<div class="small mt-1">${renderAttendanceAttachmentLink(result.comment.attachment)}</div>` : '';

                thread.innerHTML += `
                    <div class="comment-bubble">
                        <span class="comment-time">${new Date(result.comment.timestamp).toLocaleString()}</span>
                        <div class="comment-author">${result.comment.authorName}</div>
                        <div class="mt-1">${mentionHtml} ${result.comment.text}</div>
                        ${attachmentHtml}
                    </div>
                `;
                thread.scrollTop = thread.scrollHeight;

                document.getElementById('inp_newComment').value = '';
                const commentFileInput = document.getElementById('inp_newCommentFile');
                if (commentFileInput) commentFileInput.value = '';
                currentMentions = [];
                const area = document.getElementById('pendingMentionsArea');
                if(area) area.innerHTML = '';

                const row = document.querySelector(`.roster-row[data-personid="${studentId}"]`);
                if (row) {
                    const commentsInput = row.querySelector('.att-comments');
                    if (commentsInput) {
                        const existingComments = JSON.parse(commentsInput.value || "[]");
                        existingComments.push(result.comment);
                        commentsInput.value = JSON.stringify(existingComments);
                    }

                    const btnDetails = row.querySelector('.btn-details');
                    const iconDetails = btnDetails.querySelector('i');
                    btnDetails.className = 'btn btn-sm btn-details btn-warning text-dark';
                    iconDetails.className = 'bi bi-sticky-fill';

                    const nameCell = row.querySelector('.ps-4.fw-bold.align-middle');
                    if (nameCell && !nameCell.querySelector('.bi-chat-dots-fill')) {
                        nameCell.innerHTML += ` <i class="bi bi-chat-dots-fill text-primary ms-1" style="font-size: 0.75rem;" title="Notes Exist"></i>`;
                    }
                }

            } catch (err) {
                if (typeof showMessageModal === 'function') {
                    showMessageModal({
                        title: 'Error Saving Note',
                        icon: 'error',
                        message: err.message,
                        buttons: [{ text: 'Close', class: 'btn-secondary' }]
                    });
                } else {
                    alert(err.message);
                }
            } finally {
                btn.innerHTML = origBtn;
                btn.disabled = false;
            }
        });
    }

    const btnSaveDetails = document.getElementById('btnSaveDetails');
    if (btnSaveDetails) {
        btnSaveDetails.addEventListener('click', async () => {
            const personId = document.getElementById('modalPersonId').value;
            const row = document.querySelector(`.roster-row[data-personid="${personId}"]`);

            if (row) {
                const lateVal = document.getElementById('modalLateMins').value;
                const leaveVal = document.getElementById('modalLeaveMins').value;
                const excuseVal = document.getElementById('modalExcuseRef').value;
                const commentsStr = row.querySelector('.att-comments').value;
                const excuseAttachmentInput = row.querySelector('.att-excuse-attachment');
                const selectedExcuseAttachment = await uploadSchoolSessionFile(document.getElementById('modalExcuseFile'), 'excuse', personId);
                const currentExcuseAttachment = parseAttendanceAttachment(excuseAttachmentInput?.value);
