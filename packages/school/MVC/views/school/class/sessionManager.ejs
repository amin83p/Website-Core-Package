        const selected = getSelectedSessionStatus();
        grid.innerHTML = '';
        Array.from(statusSelect.options || []).forEach((opt) => {
            const code = normalizeStatusCode(opt.value);
            if (!code) return;
            const blocked = wouldBlockCompletionStatus(code);
            const btn = document.createElement('button');
            btn.type = 'button';
            btn.className = `btn session-status-option-btn${selected === code ? ' is-selected' : ''}`;
            btn.style.backgroundColor = opt.getAttribute('data-color-bg') || '#f8fafc';
