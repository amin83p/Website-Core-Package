    async function saveStudentCase(options = {}) {
        const caseId = document.getElementById('studentCaseId').value;
        const shouldResolve = options && options.resolve === true;
        const payload = collectStudentCasePayload();
        if (shouldResolve) payload.status = 'resolved';
        if (!payload.studentPersonId) return showStudentCaseMessage('Student Required', 'Select a student before saving this case.', 'error');
        if (!String(payload.summary || '').trim()) return showStudentCaseMessage('Summary Required', 'Enter a short summary before saving this case.', 'error');
        const url = caseId
            ? `/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/cases/${encodeURIComponent(caseId)}`
            : `/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/cases`;
        showStudentCaseBusy(shouldResolve ? 'Resolving Case' : (caseId ? 'Updating Case' : 'Saving Case'), shouldResolve ? 'Saving changes and resolving the student case...' : (caseId ? 'Updating the student case...' : 'Saving the student case...'));
        try {
            const res = await fetch(url, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json', 'x-ajax-request': 'true', 'Accept': 'application/json' },
                body: JSON.stringify(payload)
            });
            const result = await res.json().catch(() => ({}));
            if (!res.ok || result.status !== 'success') throw new Error(result.message || 'Failed to save student case.');
            if (studentCaseModalInstance) studentCaseModalInstance.hide();
            await refreshStudentCases();
            hideStudentCaseBusy();
            return showStudentCaseMessage(shouldResolve ? 'Case Resolved' : 'Case Saved', result.message || (shouldResolve ? 'Student case saved and resolved.' : 'Student case saved.'), 'success');
        } catch (error) {
            hideStudentCaseBusy();
            throw error;
        }
    }

