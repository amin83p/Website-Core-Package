            btnToggleSidebar.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
            if (sidebarIcon) sidebarIcon.className = collapsed ? 'bi bi-layout-sidebar' : 'bi bi-layout-sidebar-inset';
