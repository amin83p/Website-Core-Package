<%- include('partials/modal_GenericPicker') %>

<script>
let detailsModalInstance = null;
let currentMentions = [];

document.addEventListener('DOMContentLoaded', () => {
    const actionStateId = <%- jsonForScript((typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '') %>;
    const defaultSessionStatusCode = <%- jsonForScript(fallbackStatusCode) %>;
    const sessionManagerClassId = <%- jsonForScript(classData.id) %>;
    const sessionManagerSessionId = <%- jsonForScript(session.sessionId) %>;
    const sessionStatusMeta = <%- jsonForScript(availableStatusRows || []) %>;
    const normalizeStatusCode = (value) => String(value || '').trim().toLowerCase().replace(/[^a-z0-9]+/g, '_').replace(/^_+|_+$/g, '');
    const sessionStatusMap = new Map((sessionStatusMeta || []).map((row) => [normalizeStatusCode(row.code), row]));
    const resolveStatusMeta = (statusCode) => sessionStatusMap.get(normalizeStatusCode(statusCode)) || null;

    window.__attendanceMatrixPolicy = <%- JSON.stringify(typeof attendanceMatrixPolicyResolved !== 'undefined' && attendanceMatrixPolicyResolved ? attendanceMatrixPolicyResolved : { disqualifyLateMinutes: 30, disqualifyEarlyLeaveMinutes: 30, disqualifyCombinedMissedMinutes: null, scheduledMinutes: 180 }) %>;

    function parseNonNegAttendanceMins(v) {
        const n = Number(String(v ?? '').trim());
        return Number.isFinite(n) && n >= 0 ? Math.floor(n) : 0;
    }

    function setAttendanceRadio(row, value) {
        const r = row.querySelector(`.att-radio[value="${value}"]`);
        if (r && !r.disabled) r.checked = true;
    }

    function applyAttendanceRulesToRow(row) {
        if (!row) return;
        const pol = window.__attendanceMatrixPolicy || {};
        const late = parseNonNegAttendanceMins(row.querySelector('.att-late')?.value);
        const early = parseNonNegAttendanceMins(row.querySelector('.att-leave')?.value);
        let att = row.querySelector('.att-radio:checked')?.value || 'absent';

        const lateCut = Number(pol.disqualifyLateMinutes);
        const earlyCut = Number(pol.disqualifyEarlyLeaveMinutes);
        const comb = pol.disqualifyCombinedMissedMinutes;

        if ((Number.isFinite(lateCut) && late >= lateCut) || (Number.isFinite(earlyCut) && early >= earlyCut)) {
            setAttendanceRadio(row, 'absent');
            return;
        }
        const combN = comb === null || comb === undefined || comb === '' ? null : Number(comb);
        if (combN != null && Number.isFinite(combN) && late + early >= combN) {
            setAttendanceRadio(row, 'absent');
            return;
        }
        if ((late > 0 || early > 0) && (att === 'present' || att === 'excused')) {
            setAttendanceRadio(row, 'late');
        }
    }

    function refreshAttendanceMatrixHint() {
        const el = document.getElementById('attendanceMatrixThresholdHint');
        if (!el) return;
        const pol = window.__attendanceMatrixPolicy || {};
        const lateCut = pol.disqualifyLateMinutes;
        const earlyCut = pol.disqualifyEarlyLeaveMinutes;
        const comb = pol.disqualifyCombinedMissedMinutes;
        const parts = [
            `Late ≥ ${lateCut} min or left early ≥ ${earlyCut} min counts as absent`
        ];
        if (comb != null && comb !== '' && Number.isFinite(Number(comb))) {
            parts.push(`combined late + early ≥ ${comb} min counts as absent`);
        }
        parts.push('any late/early minutes with Present or Excused switches status to Late');
        el.textContent = parts.join('. ') + '.';
    }
