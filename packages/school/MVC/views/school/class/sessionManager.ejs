    function validateSessionReportAssignmentPayload(payload) {
        if (!payload.templateId) return 'Select a report template.';
        if (!payload.reportStartDate) return 'Select the report start date.';
        if (sessionDefaultDate && payload.reportStartDate > sessionDefaultDate) return 'Report Start Date cannot be after the session date.';
        if (!payload.taskStartTime || !payload.taskEndTime) return 'Task Start and Task End are required.';
        if (payload.taskStartTime >= payload.taskEndTime) return 'Task End must be later than Task Start.';
        if (sessionDefaultStartTime && payload.taskStartTime < sessionDefaultStartTime) return `Task Start cannot be before the session start time (${sessionDefaultStartTime}).`;
        if (sessionDefaultEndTime && payload.taskEndTime > sessionDefaultEndTime) return `Task End cannot be after the session end time (${sessionDefaultEndTime}).`;
        if (payload.reportScope === 'selected_students' && !payload.targetStudentIds.length) return 'Select at least one student for Specific Students scope.';
        if (payload.timesheetReflection && Number(payload.allocatedHours || 0) <= 0) return 'Allocated Hours must be greater than zero when timesheet reflection is enabled.';
        return '';
    }

    async function saveSessionReportAssignment() {
        if (savingSessionReportAssignment) return;
        const modal = getSessionReportAssignmentModal();
        if (!modal) return;
        const button = modal.querySelector('#btnSaveSessionReportAssignment');
        const oldHtml = button ? button.innerHTML : '';
        const payload = {
            templateId: String(modal.querySelector('#sessionReportTemplateId')?.value || '').trim(),
            reportScope: String(modal.querySelector('#sessionReportScope')?.value || 'class').trim(),
            reportStartDate: String(modal.querySelector('#sessionReportStartDate')?.value || '').trim(),
            taskStartTime: String(modal.querySelector('#sessionReportTaskStart')?.value || '').trim(),
            taskEndTime: String(modal.querySelector('#sessionReportTaskEnd')?.value || '').trim(),
            conflictPermitted: modal.querySelector('#sessionReportConflictPermitted')?.checked === true,
            timesheetReflection: modal.querySelector('#sessionReportTimesheetReflection')?.checked === true,
            allocatedHours: String(modal.querySelector('#sessionReportAllocatedHours')?.value || '0').trim(),
            notes: String(modal.querySelector('#sessionReportNotes')?.value || '').trim(),
            targetStudentIds: Array.from(selectedSessionReportStudents.keys())
        };
        const issue = validateSessionReportAssignmentPayload(payload);
        if (issue) {
            await showStudentCaseMessage('Assignment Incomplete', issue, 'warning');
            return;
        }
        const body = new URLSearchParams();
        body.set('actionStateId', actionStateId || '');
        Object.entries(payload).forEach(([key, value]) => {
            if (Array.isArray(value)) body.set(key, value.join(','));
            else body.set(key, String(value));
        });
        try {
            savingSessionReportAssignment = true;
            if (button) {
                button.disabled = true;
                button.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
            }
            if (typeof window.showLoading === 'function') window.showLoading('Assigning report to session...');
            const res = await fetch(`/school/classes/${encodeURIComponent(String(sessionManagerClassId))}/sessions/${encodeURIComponent(String(sessionManagerSessionId))}/report-assignments`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded;charset=UTF-8',
                    'x-ajax-request': 'true',
                    'X-Requested-With': 'XMLHttpRequest',
                    'Accept': 'application/json'
                },
                credentials: 'same-origin',
                body
            });
            const result = await res.json().catch(() => ({ status: 'error', message: 'Unable to read server response.' }));
            if (!res.ok || result.status !== 'success') throw new Error(result.message || 'Could not assign report to this session.');
            sessionReportInstancesState = Array.isArray(result.rows) ? result.rows : [];
            renderSessionReportInstances();
            renderSessionStatusButtons();
            if (sessionReportAssignmentModalInstance) sessionReportAssignmentModalInstance.hide();
            await showStudentCaseMessage('Report Assigned', result.message || 'Report assigned to this session.', 'success');
        } catch (error) {
            await showStudentCaseMessage('Assignment Failed', error.message || 'Could not assign report to this session.', 'error');
        } finally {
            if (typeof window.hideLoading === 'function') window.hideLoading({ force: true });
            if (button) {
                button.disabled = false;
                button.innerHTML = oldHtml;
            }
            savingSessionReportAssignment = false;
        }
    }
