                const name = String(row?.name || row?.studentName || row?.displayName || row?.preferredName || [row?.firstName, row?.lastName].filter(Boolean).join(' ') || id).trim();
                if (!id || seen.has(id)) return null;
                seen.add(id);
                return { id, personId: id, name, title: name ? `${name} (${id})` : id };
            })
            .filter(Boolean);
    }

