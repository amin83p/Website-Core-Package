                                                            <input type="radio" class="btn-check att-radio" name="att_<%= i %>" id="e_<%= i %>" value="excused" <%= student.attendance === 'excused' ? 'checked' : '' %> <%- disabledAttr %>>
                                                            <label class="btn att-label" for="e_<%= i %>" title="Excused Absence"><i class="bi bi-envelope-paper"></i> Excused</label>
                                                            <input type="radio" class="btn-check att-radio" name="att_<%= i %>" id="a_<%= i %>" value="absent" <%= student.attendance === 'absent' ? 'checked' : '' %> <%- disabledAttr %>>
                                                            <label class="btn att-label" for="a_<%= i %>" title="Absent"><i class="bi bi-x-lg"></i> Absent</label>
                                                        </div>
                                                        <% const hasDetails = student.lateMinutes || student.earlyLeaveMinutes || student.excuseRef || (student.comments && student.comments.length > 0); %>
                                                        <button type="button"
                                                                class="btn btn-sm btn-details <%= hasDetails ? 'btn-warning text-dark' : 'btn-outline-secondary' %>"
                                                                title="Notes / Excuses / Mentions"
                                                                onclick="openDetailsModal('<%= student.personId %>', '<%= student.name.replace(/'/g, "\\'") %>')">
                                                            <i class="bi <%= hasDetails ? 'bi-sticky-fill' : 'bi-three-dots' %>"></i>
                                                        </button>
                                                    </div>
                                                    <input type="hidden" class="att-late" value="<%= student.lateMinutes || '' %>">
                                                    <input type="hidden" class="att-leave" value="<%= student.earlyLeaveMinutes || '' %>">
                                                    <input type="hidden" class="att-excuse" value="<%= student.excuseRef || '' %>">
                                                    <input type="hidden" class="att-comments" value='<%- JSON.stringify(student.comments || []) %>'>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
