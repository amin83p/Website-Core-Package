    function getSelectedSessionStatus() {
        const select = document.getElementById('sessionStatusSelect');
        return normalizeStatusCode(select?.value || defaultSessionStatusCode) || 'scheduled';
    }
    function isSessionStatusMakeupRequired(statusCode) {
        const meta = resolveStatusMeta(statusCode);
        return Boolean(meta && meta.makeUpRequired === true);
    }
    function isSessionCompletionStatus(statusCode) {
        const meta = resolveStatusMeta(statusCode);
        if (!meta) return normalizeStatusCode(statusCode) === 'completed';
        return meta.isFinal === true && meta.makeUpRequired !== true && meta.excludeFromAttendance !== true;
    }
    function isReportRowSubmitted(row) {
        if (row?.isPending) return false;
        const status = String(row?.status || '').trim().toLowerCase();
        return status === 'submitted' || status === 'locked';
    }
    function getUnsubmittedSessionReports() {
        return (Array.isArray(sessionReportInstancesState) ? sessionReportInstancesState : [])
            .filter((row) => !isReportRowSubmitted(row));
    }
    function wouldBlockCompletionStatus(statusCode) {
        if (!isSessionCompletionStatus(statusCode)) return false;
        const target = normalizeStatusCode(statusCode);
        const saved = normalizeStatusCode(sessionInitialStatusCode);
        if (target === saved && isSessionCompletionStatus(saved)) return false;
        return getUnsubmittedSessionReports().length > 0;
    }
    function buildPendingReportsMessageHtml(rows) {
        const list = Array.isArray(rows) ? rows : [];
        if (!list.length) return '';
        const items = list.map((row) => {
            const title = attendanceAttachmentEscape(row.templateTitle || 'Report');
            const student = attendanceAttachmentEscape(row.studentName || 'Whole class');
            const teacher = attendanceAttachmentEscape(row.teacherName || '-');
            const status = attendanceAttachmentEscape(row.statusLabel || row.status || 'draft');
            const href = String(row.href || '').trim();
            const link = href
                ? ` <a href="${attendanceAttachmentEscape(href)}" target="_blank" rel="noopener noreferrer" class="ms-1">${attendanceAttachmentEscape(row.isPending ? 'Start' : 'Open')}</a>`
                : '';
            return `<li><strong>${title}</strong> — ${student} · ${teacher} · <span class="text-capitalize">${status}</span>${link}</li>`;
        }).join('');
        return `<div class="mt-3"><strong>Pending reports:</strong><ul class="mt-2 mb-0 text-start">${items}</ul></div><div class="mt-3">Open the <strong>Report instances</strong> panel to submit each report before marking this session completed.</div>`;
    }
    async function showPendingReportsBlockModal(rows) {
        const message = 'This session cannot be marked completed until all assigned reports are submitted.'
