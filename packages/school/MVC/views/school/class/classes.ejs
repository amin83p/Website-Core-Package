<%- include('partials/tablePages-start', {
  title: 'Class Management',
  newUrl: 'school/classes', 
  newLabel: 'New Class',
  user,
  tableName: 'Classes_List',
  btn_export: true,
  print: true,
  manageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>',
  `
      <a href="/school/classes/new-wizard" class="btn btn-filled btn-primary btn-md mb-2">
        <i class="bi bi-signpost-split me-1"></i> Wizard
      </a>
  `]

}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search classes...',
  fields: []
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Title / ID</th>
        <th>Organization</th>
        <th>Delivery Dept</th>
        <th>Lifecycle</th>
        <th>Schedule</th>
        <th>Curriculum</th>
        <th class="text-center">Status</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length === 0) { %>
         <tr><td colspan="8" class="text-center py-4 text-muted">No classes found.</td></tr>
      <% } %>
      
      <% data.forEach(item => { %>
        <tr>
          <td class="ps-4">
             <div class="fw-bold text-dark"><%= item.title %></div>
             <div class="x-small text-muted font-monospace"><%= item.id %></div>
          </td>
          
          <td>
             <div class="d-flex align-items-center gap-2">
                 <div class="rounded-circle bg-light border d-flex align-items-center justify-content-center text-primary" style="width:32px;height:32px;">
                    <i class="bi bi-building"></i>
                 </div>
                 <div class="fw-bold text-dark small"><%= item.orgName %></div>
             </div>
          </td>

          <td>
             <span class="badge bg-light text-dark border"><%= item.deliveryDepartmentName || item.deliveryDepartmentId || 'N/A' %></span>
          </td>

          <td>
             <% const lifecycleMode = String(item.registrationMode || 'term_based').trim().toLowerCase() === 'rolling' ? 'rolling' : 'term_based'; %>
             <div class="d-flex flex-column gap-1">
                <span class="badge <%= lifecycleMode === 'rolling' ? 'bg-warning-subtle text-warning-emphasis border border-warning-subtle' : 'bg-light text-dark border' %>">
                  <%= lifecycleMode === 'rolling' ? 'Rolling' : 'Term-Based' %>
                </span>
                <span class="x-small text-muted">Active Periods: <%= Number(item.activePeriodCount || 0) %></span>
                <% if (lifecycleMode === 'rolling') { %>
                  <span class="x-small text-muted">Cycle #<%= Number(item.cycleNo || 1) > 0 ? Number(item.cycleNo || 1) : 1 %></span>
                  <% if (item.cycleStartDate || item.cycleEndDate) { %>
                    <span class="x-small text-muted"><%= item.cycleStartDate || '?' %> -> <%= item.cycleEndDate || 'Open' %></span>
                  <% } %>
                  <% if (item.previousClassId || item.nextClassId) { %>
                    <span class="x-small text-muted">
                      <% if (item.previousClassId) { %>
                        Prev:
                        <a href="/school/classes/edit/<%= encodeURIComponent(item.previousClassId) %>"><%= item.previousClassTitle || item.previousClassId %></a>
                      <% } %>
                      <% if (item.previousClassId && item.nextClassId) { %> | <% } %>
                      <% if (item.nextClassId) { %>
                        Next:
                        <a href="/school/classes/edit/<%= encodeURIComponent(item.nextClassId) %>"><%= item.nextClassTitle || item.nextClassId %></a>
                      <% } %>
                    </span>
                  <% } %>
                  <% if (item.isClosedForNewEnrollment) { %>
                    <span class="badge bg-danger-subtle text-danger border border-danger-subtle">Closed Enrollment</span>
                  <% } %>
                <% } %>
             </div>
          </td>

          <td>
             <div class="small">
                <% if(item.schedule && item.schedule.current && item.schedule.current.startDate) { %>
                    <div class="fw-bold">
                        <%= item.schedule.current.startDate %> <i class="bi bi-arrow-right mx-1 text-muted"></i> <%= item.schedule.current.endDate %>
                    </div>
                    <div class="text-muted x-small mt-1">
                        <% const days = item.schedule.current.daysOfWeek || []; %>
                        <%= days.map(d => typeof d === 'string' ? d.substring(0,3) : d).join(', ') %> 
                        <% if(item.schedule.current.startTime) { %>
                            (@ <%= item.schedule.current.startTime %> - <%= item.schedule.current.endTime %>)
                        <% } %>
                    </div>
                <% } else { %>
                    <span class="text-muted fst-italic">Not Scheduled</span>
                <% } %>
             </div>
          </td>

          <td>
             <div class="d-flex flex-wrap gap-1 mb-1">
                <% if(item.curriculum && item.curriculum.subjects && item.curriculum.subjects.length > 0) { %>
                    <% item.curriculum.subjects.forEach(sub => { %>
                        <span class="badge bg-light text-secondary border"><%= sub.code || sub.subjectId %></span>
                    <% }) %>
                <% } else { %>
                    <span class="text-muted small fst-italic">No subjects</span>
                <% } %>
             </div>
             <div class="x-small text-muted">
                 <%= item.curriculum?.totalHours || 0 %> Total Hrs
             </div>
          </td>

          <td class="text-center">
             <% 
               let badge = 'bg-secondary';
               if(item.status === 'active') badge = 'bg-success';
               if(item.status === 'draft') badge = 'bg-warning text-dark';
               if(item.status === 'completed') badge = 'bg-primary';
               if(item.status === 'cancelled') badge = 'bg-danger';
             %>
             <span class="badge <%= badge %>"><%= (item.status || 'unknown').toUpperCase() %></span>
          </td>

          <td class="table-actions text-end pe-4">
             <% if (lifecycleMode === 'rolling') { %>
               <a href="/school/classes/<%= encodeURIComponent(item.id) %>/rolling-enrollment" class="btn btn-sm btn-outline-primary me-1">Enrollment</a>
               <a href="/school/classes/<%= encodeURIComponent(item.id) %>/cycle-rollover" class="btn btn-sm btn-outline-warning me-1">Rollover</a>
             <% } %>
             <a href="/school/classes/edit-wizard/<%= item.id %>" class="btn btn-sm btn-outline-info me-1">Wizard</a>
             <a href="/school/classes/edit/<%= item.id %>" class="btn btn-sm btn-filled btn-edit me-1">Edit</a>
             <button class="btn btn-sm btn-filled btn-delete delete-btn" data-id="<%= item.id %>">Delete</button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/classes" hidden></span>

<%- include('partials/pagination', { 
    pagination: pagination, 
    filters: filters, 
    baseUrlPath: 'school/classes' 
}) %>

<%- include('partials/tablePages-end') %>
