<% const c = classData || {};
  const pending = Array.isArray(pendingRows) ? pendingRows : [];
  const summary = matrixPayloadSummary || {};
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
%>
<style>
  .enrollment-outcomes-page .eo-actions { min-width: 220px; }
  .enrollment-outcomes-page .table thead th { font-size: 0.78rem; white-space: nowrap; }
</style>

<div class="sections-page enrollment-outcomes-page">
  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
      <h1 class="page-heading size-md m-0 text-start"><i class="bi bi-person-check me-2 text-primary"></i> Enrollment outcomes</h1>
      <p class="text-muted small mb-0 mt-1">
        For enrollment periods that have <strong>ended</strong> (or are closed) and do not yet have an outcome, choose <strong>Pass</strong>, <strong>Continue</strong>, or <strong>Withdraw</strong>.
        Suggested % comes from the same <a href="/school/grades-matrix?classId=<%= encodeURIComponent(c.id) %>&amp;range=allTime">grades matrix</a> final column as the student’s current roster.
      </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <a href="/school/classes/<%= encodeURIComponent(c.id) %>/rolling-enrollment" class="btn btn-outline-secondary btn-md"><i class="bi bi-arrow-left me-1"></i> Rolling enrollment</a>
      <a href="<%= typeof schoolSectionDashboardHref !== 'undefined' ? schoolSectionDashboardHref : '/dashboard' %>" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-3 small text-muted">
      <strong><%= summary.className || c.title || 'Class' %></strong>
      <% if (summary.evaluation && summary.evaluation.passingScore != null) { %>
        · Passing <%= summary.evaluation.passingScore %>%
      <% } %>
    </div>
  </div>

  <% if (!pending.length) { %>
    <div class="alert alert-info border-0 shadow-sm">
      No enrollment periods are waiting for an outcome. When a period ends (or is completed) and no Pass / Continue / Withdraw is recorded yet, it will appear here.
    </div>
  <% } else { %>
    <div class="table-responsive border rounded shadow-sm bg-white">
      <table class="table table-hover table-sm align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Student</th>
            <th>Period</th>
            <th>Status</th>
            <th class="text-end">Suggested final %</th>
            <th class="eo-actions">Outcome</th>
            <th>Notes</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% pending.forEach((row) => { %>
            <tr data-period-id="<%= row.periodId %>">
              <td class="fw-semibold"><%- include('../partials/studentNameLink', { name: row.studentName, studentRecordId: row.studentRecordId || row.studentId, canOpenStudentProfile: typeof canOpenStudentProfile !== 'undefined' ? canOpenStudentProfile : false, linkClass: 'text-decoration-none fw-semibold' }) %></td>
              <td class="small text-muted"><%= row.startDate || '—' %> → <%= row.endDate || '—' %></td>
              <td><span class="badge bg-light text-dark border"><%= row.status || '' %></span></td>
              <td class="text-end font-monospace"><%= row.suggestedFinalPercent != null ? row.suggestedFinalPercent : '—' %></td>
              <td>
                <select class="form-select form-select-sm eo-decision" aria-label="Outcome for <%= row.studentName %>">
                  <option value="" <%= !row.completionDecision ? 'selected' : '' %>>Select…</option>
                  <option value="pass" <%= row.completionDecision === 'pass' ? 'selected' : '' %>>Pass</option>
                  <option value="continue" <%= row.completionDecision === 'continue' ? 'selected' : '' %>>Continue</option>
                  <option value="withdraw" <%= row.completionDecision === 'withdraw' ? 'selected' : '' %>>Withdraw</option>
                </select>
              </td>
              <td style="min-width: 12rem;">
                <input type="text" class="form-control form-control-sm eo-notes" maxlength="2000" placeholder="Optional notes" value="<%= row.completionDecisionNotes || '' %>">
              </td>
              <td class="text-end">
                <button type="button" class="btn btn-sm btn-primary eo-save">Save</button>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<script>
(function () {
  const actionStateId = <%- JSON.stringify(asid) %>;

  function bindRow(tr) {
    const periodId = tr.getAttribute('data-period-id');
    if (!periodId) return;
    const btn = tr.querySelector('.eo-save');
    if (!btn) return;
    btn.addEventListener('click', async () => {
      const decision = String(tr.querySelector('.eo-decision')?.value || '').trim().toLowerCase();
      const notes = String(tr.querySelector('.eo-notes')?.value || '').trim();
      if (!decision) {
        alert('Please choose Pass, Continue, or Withdraw.');
        return;
      }
      btn.disabled = true;
      try {
        const res = await fetch('/school/classes/api/enrollment-periods/' + encodeURIComponent(periodId) + '/completion-decision', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'X-Requested-With': 'XMLHttpRequest',
            Accept: 'application/json'
          },
          body: JSON.stringify({
            completionDecision: decision,
            completionDecisionNotes: notes,
            actionStateId
          })
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || data.status !== 'success') {
          throw new Error(data.message || 'Save failed.');
        }
        tr.remove();
        if (!document.querySelector('tr[data-period-id]')) {
          window.location.reload();
        }
      } catch (e) {
        alert(e.message || 'Save failed.');
      } finally {
        btn.disabled = false;
      }
    });
  }

  document.querySelectorAll('.enrollment-outcomes-page tr[data-period-id]').forEach(bindRow);
})();
</script>
