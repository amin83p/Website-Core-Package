<% const c = classData || {};
  const mp = matrixPayload || {};
  const rows = Array.isArray(mp.matrix) ? mp.matrix : [];
  const ev = mp.evaluation || {};
  const passing = (ev.passingScore != null) ? Number(ev.passingScore) : 60;
  const official = (typeof officialFinalGradesWorkflow === 'object' && officialFinalGradesWorkflow) ? officialFinalGradesWorkflow : {};
  const cap = finalGradesCapabilities || {};
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
  function phaseLabel(ph) {
    const x = String(ph || 'draft').trim();
    if (x === 'pending_dept') return 'Awaiting dept approval';
    if (x === 'pending_senior') return 'Awaiting final lock';
    if (x === 'locked') return 'Locked';
    return 'Draft';
  }
  function jsonForScript(value) {
    if (value === undefined) return 'undefined';
    const s = JSON.stringify(value);
    if (s === undefined) return 'null';
    return s.replace(/</g, '\\u003c').replace(/\u2028/g, '\\u2028').replace(/\u2029/g, '\\u2029').replace(/&/g, '\\u0026');
  }
%>
<style>
  .final-grades-page .fg-num { font-variant-numeric: tabular-nums; }
  .final-grades-page .table thead th { font-size: 0.78rem; white-space: nowrap; }
  .final-grades-page .fg-actions .btn { margin-bottom: 0.25rem; }
  .fg-history-table { font-size: 0.82rem; }
  .fg-history-table td { vertical-align: top; }
</style>

<div class="sections-page final-grades-page">
  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <div>
      <h1 class="page-heading size-md m-0 text-start"><i class="bi bi-award me-2 text-primary"></i> Final Grades</h1>
      <p class="text-muted small mb-0 mt-1">
        <strong>1)</strong> Instructor enters the official % and <strong>submits for approval</strong>.
        <strong>2)</strong> A department administrator approves.
        <strong>3)</strong> A school class administrator <strong>locks</strong> the grade.
        To change a locked grade, an administrator must <strong>release the lock</strong> (reason required), then the instructor re-submits through the same steps.
        Suggested % matches the <a href="/school/grades-matrix?classId=<%= encodeURIComponent(c.id) %>&amp;range=allTime">grades matrix</a>.
      </p>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <a href="/school/classes/edit/<%= encodeURIComponent(c.id) %>" class="btn btn-outline-secondary btn-md"><i class="bi bi-arrow-left me-1"></i> Class</a>
      <a href="<%= typeof schoolSectionDashboardHref !== 'undefined' ? schoolSectionDashboardHref : '/dashboard' %>" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body py-2 px-3 small text-muted">
      <strong><%= (mp.className || c.title || 'Class') %></strong>
      · Passing <%= passing %>% ·
      Weights: Attendance <%= ev.weights && ev.weights.attendance != null ? ev.weights.attendance : '—' %>%, Assignments <%= ev.weights && ev.weights.assignments != null ? ev.weights.assignments : '—' %>%
      <% if (mp.registrationMode !== 'rolling') { %>
        · Midterm <%= ev.weights && ev.weights.midterm != null ? ev.weights.midterm : '—' %>%, Final <%= ev.weights && ev.weights.finalExam != null ? ev.weights.finalExam : '—' %>%
      <% } %>
    </div>
  </div>

  <div class="table-responsive border rounded shadow-sm bg-white">
    <table class="table table-hover table-sm align-middle mb-0">
      <thead class="table-light">
        <tr>
          <th>Student</th>
          <th class="text-end">Attendance %</th>
          <th class="text-end">Assignments avg %</th>
          <th class="text-end">Suggested %</th>
          <th>Workflow</th>
          <th class="text-end" style="min-width: 7rem;">Official %</th>
          <th style="min-width: 14rem;">Actions</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach((row) => {
          const pid = String(row.personId || '');
          const sug = row.finalPercent;
          const rec = official[pid] || { score: null, phase: 'draft', history: [] };
          const phase = rec.phase || 'draft';
          const scoreVal = rec.score != null && rec.score !== '' ? rec.score : '';
          const canT = !!cap.canTeacher;
          const canD = !!cap.canDeptApprove;
          const canS = !!cap.canSeniorLock;
          const canRel = !!cap.canReleaseLock;
          const teacherEdit = phase === 'draft' && canT;
        %>
        <tr data-person-id="<%= pid %>"
            data-phase="<%= phase %>"
            data-can-teacher="<%= teacherEdit ? '1' : '0' %>">
          <td class="fw-semibold"><%= row.name || pid %></td>
          <td class="text-end fg-num"><%= row.attendancePct != null ? row.attendancePct : '—' %></td>
          <td class="text-end fg-num"><%= row.assignmentsPct != null ? row.assignmentsPct : '—' %></td>
          <td class="text-end fg-num text-muted"><%= sug != null ? sug : '—' %></td>
          <td><span class="badge bg-light text-dark border fg-phase-badge"><%= phaseLabel(phase) %></span></td>
          <td class="text-end">
            <input type="number" min="0" max="100" step="0.01" class="form-control form-control-sm text-end fg-official"
              value="<%= scoreVal === '' ? '' : scoreVal %>"
              placeholder="<%= sug != null ? String(sug) : '' %>"
              <%= teacherEdit ? '' : 'disabled' %>
              aria-label="Official percent for <%= row.name || pid %>">
          </td>
          <td class="fg-actions">
            <% if (teacherEdit) { %>
              <button type="button" class="btn btn-sm btn-outline-primary fg-act" data-act="teacher_draft"><i class="bi bi-save"></i> Save draft</button>
              <button type="button" class="btn btn-sm btn-primary fg-act" data-act="teacher_finalize"><i class="bi bi-send"></i> Submit for approval</button>
            <% } %>
            <% if (phase === 'pending_dept' && canD) { %>
              <button type="button" class="btn btn-sm btn-success fg-act" data-act="dept_approve"><i class="bi bi-check2"></i> Dept approve</button>
            <% } %>
            <% if (phase === 'pending_senior' && canS) { %>
              <button type="button" class="btn btn-sm btn-success fg-act" data-act="senior_lock"><i class="bi bi-lock"></i> Approve &amp; lock</button>
            <% } %>
            <% if (phase === 'locked' && canRel) { %>
              <button type="button" class="btn btn-sm btn-warning fg-act-release" data-bs-toggle="modal" data-bs-target="#fgReleaseModal"><i class="bi bi-unlock"></i> Release lock</button>
            <% } %>
          </td>
          <td class="text-end">
            <button type="button" class="btn btn-sm btn-outline-secondary fg-history-btn" title="History"><i class="bi bi-clock-history"></i></button>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>
  </div>

  <% if (!rows.length) { %>
    <p class="text-muted small mt-3 mb-0">No students in the grades matrix roster for this class. Adjust enrollment or sessions, then return.</p>
  <% } %>

  <p class="small text-muted mt-3 mb-0" id="fgWorkflowStatus"></p>
</div>

<!-- History modal -->
<div class="modal fade" id="fgHistoryModal" tabindex="-1" aria-labelledby="fgHistoryModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="fgHistoryModalLabel">Final grade history</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="small text-muted mb-2" id="fgHistoryStudent"></p>
        <div class="table-responsive">
          <table class="table table-sm fg-history-table">
            <thead><tr><th>When (UTC)</th><th>Who</th><th>Action</th><th>After</th><th>Score</th><th>Reason</th></tr></thead>
            <tbody id="fgHistoryBody"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Release lock modal -->
<div class="modal fade" id="fgReleaseModal" tabindex="-1" aria-labelledby="fgReleaseModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="fgReleaseModalLabel">Release lock</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="small text-muted">A reason is required. The instructor may edit the official % again after release.</p>
        <input type="hidden" id="fgReleasePersonId" value="">
        <label class="form-label" for="fgReleaseReason">Reason</label>
        <textarea id="fgReleaseReason" class="form-control" rows="3" maxlength="2000" placeholder="Why is this lock being released?"></textarea>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-warning" id="fgReleaseConfirm">Release lock</button>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const classId = <%- jsonForScript(c.id || '') %>;
  const actionStateId = <%- jsonForScript(asid) %>;
  const officialMap = <%- jsonForScript(official) %>;
  const statusEl = document.getElementById('fgWorkflowStatus');

  const ACTION_LABELS = {
    teacher_draft: 'Teacher saved draft',
    teacher_finalize: 'Teacher submitted for approval',
    dept_approve: 'Department approved',
    senior_lock: 'Locked (final approval)',
    release_lock: 'Lock released',
    migrated_legacy: 'Imported legacy score'
  };

  function phaseLabel(ph) {
    const x = String(ph || 'draft').trim();
    if (x === 'pending_dept') return 'Awaiting dept approval';
    if (x === 'pending_senior') return 'Awaiting final lock';
    if (x === 'locked') return 'Locked';
    return 'Draft';
  }

  async function postWorkflow(payload) {
    const res = await fetch('/school/classes/api/' + encodeURIComponent(classId) + '/official-final-grades', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'X-Requested-With': 'XMLHttpRequest',
        Accept: 'application/json'
      },
      body: JSON.stringify({ ...payload, actionStateId })
    });
    const data = await res.json().catch(() => ({}));
    if (!res.ok || data.status !== 'success') {
      throw new Error(data.message || 'Request failed.');
    }
    window.location.reload();
  }

  function currentScore(tr) {
    const inp = tr.querySelector('.fg-official');
    const raw = inp ? String(inp.value || '').trim() : '';
    if (raw === '') return null;
    const n = Number(raw);
    return Number.isFinite(n) ? n : null;
  }

  document.querySelectorAll('.fg-act').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const tr = btn.closest('tr[data-person-id]');
      if (!tr) return;
      const personId = tr.getAttribute('data-person-id');
      const act = btn.getAttribute('data-act');
      if (!personId || !act) return;
      const score = currentScore(tr);
      if (act === 'teacher_finalize' && (score === null || score === undefined)) {
        alert('Enter an official % before submitting for approval.');
        return;
      }
      statusEl.textContent = 'Working…';
      btn.disabled = true;
      try {
        await postWorkflow({ action: act, personId, score });
      } catch (e) {
        statusEl.textContent = e.message || 'Failed.';
        statusEl.classList.add('text-danger');
      } finally {
        btn.disabled = false;
      }
    });
  });

  document.querySelectorAll('.fg-history-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tr = btn.closest('tr[data-person-id]');
      if (!tr) return;
      const personId = tr.getAttribute('data-person-id');
      const rec = (officialMap && officialMap[personId]) || { history: [] };
      const hist = Array.isArray(rec.history) ? rec.history.slice().reverse() : [];
      const nameCell = tr.querySelector('td');
      document.getElementById('fgHistoryStudent').textContent = (nameCell && nameCell.textContent) ? nameCell.textContent.trim() : personId;
      const tbody = document.getElementById('fgHistoryBody');
      tbody.innerHTML = '';
      hist.forEach((h) => {
        const trEl = document.createElement('tr');
        trEl.innerHTML = [
          '<td>', (h.at || ''), '</td>',
          '<td>', (h.displayName || h.userId || ''), '</td>',
          '<td>', (ACTION_LABELS[h.action] || h.action || ''), '</td>',
          '<td>', phaseLabel(h.phaseAfter), '</td>',
          '<td>', (h.score != null ? h.score : ''), '</td>',
          '<td>', (h.reason ? String(h.reason).replace(/</g, '&lt;') : ''), '</td>'
        ].join('');
        tbody.appendChild(trEl);
      });
      if (!hist.length) {
        const trEl = document.createElement('tr');
        trEl.innerHTML = '<td colspan="6" class="text-muted">No history yet.</td>';
        tbody.appendChild(trEl);
      }
      const modal = new bootstrap.Modal(document.getElementById('fgHistoryModal'));
      modal.show();
    });
  });

  let releaseTargetTr = null;
  document.querySelectorAll('.fg-act-release').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tr = btn.closest('tr[data-person-id]');
      releaseTargetTr = tr;
      document.getElementById('fgReleasePersonId').value = tr ? tr.getAttribute('data-person-id') : '';
      document.getElementById('fgReleaseReason').value = '';
    });
  });

  const relBtn = document.getElementById('fgReleaseConfirm');
  if (relBtn) {
    relBtn.addEventListener('click', async () => {
      const personId = document.getElementById('fgReleasePersonId').value;
      const reason = document.getElementById('fgReleaseReason').value.trim();
      if (!personId) return;
      statusEl.textContent = 'Working…';
      relBtn.disabled = true;
      try {
        await postWorkflow({ action: 'release_lock', personId, reason });
      } catch (e) {
        statusEl.textContent = e.message || 'Failed.';
        statusEl.classList.add('text-danger');
      } finally {
        relBtn.disabled = false;
      }
    });
  }
})();
</script>
