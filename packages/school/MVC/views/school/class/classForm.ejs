<%
  const c = classData || {};
  const isEdit = !!c.id;
  const initBillingMode = String(c.billingMode || 'chargeable').trim().toLowerCase() === 'no_charge' ? 'no_charge' : 'chargeable';
  const initCredits = Number(c.credits || 0);
  const initCurriculum = JSON.stringify(c.curriculum || { subjects: [], totalHours: 0 });
  const initPricing = JSON.stringify(c.pricing || { mode: 'auto', feeRules: [] });
  const initPostingTemplates = JSON.stringify(c.postingTemplates || []);
  const initAllowedProgramTerms = JSON.stringify(c.allowedProgramTerms || []);
  const initInstructors = JSON.stringify(c.instructors || []);
  const initEnrollment = JSON.stringify(c.enrollment || { maxCapacity: 30, students: [] });
  const initEvaluation = JSON.stringify(c.evaluation || { passingScore: 60, weights: { attendance: 10, assignments: 40, midterm: 20, finalExam: 30 } });
  const initSessions = JSON.stringify(typeof sessionsData !== 'undefined' ? sessionsData : []);
  const sessionStatuses = Array.isArray(sessionStatusMeta) ? sessionStatusMeta : [];
  const activeSessionStatuses = sessionStatuses.filter((row) => row && row.active !== false);
  const availableSessionStatuses = activeSessionStatuses.length ? activeSessionStatuses : sessionStatuses;
  const resolvedDefaultSessionStatusCode = String(
    defaultSessionStatusCode
    || (availableSessionStatuses.find((row) => row.code === 'scheduled')?.code)
    || (availableSessionStatuses[0]?.code)
    || 'scheduled'
  );
  const sessionStatusLabelMap = {};
  availableSessionStatuses.forEach((row) => {
    const key = String(row?.code || '').trim().toLowerCase();
    if (!key) return;
    sessionStatusLabelMap[key] = String(row?.label || key);
  });
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
  const lc = (typeof lifecycleContext !== 'undefined' && lifecycleContext) ? lifecycleContext : {};
%>

<style>
  .session-status-row {
    transition: filter 0.18s ease, box-shadow 0.18s ease;
  }
  .session-status-row:hover {
    filter: brightness(0.985);
  }
  .session-status-row.session-status-row-conflict {
    box-shadow: inset 4px 0 0 #dc3545, inset 0 0 0 1px rgba(220, 53, 69, 0.28);
  }
</style>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
      <h1 class="page-heading size-md m-0"><%= isEdit ? 'Edit Class' : 'New Class' %></h1>
      <div class="d-flex flex-column align-items-end gap-1">
          <% if(isEdit) { %> <span class="badge bg-primary border font-monospace">ID: <%= c.id %></span> <% } %>
          <button type="button" class="btn btn-outline-primary btn-sm" id="btnCopyFromClass"><i class="bi bi-copy me-1"></i>Copy From Class</button>
      </div>
  </div>

  <% if (isEdit) { %>
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-body py-2">
        <div class="d-flex flex-wrap align-items-center gap-2">
          <span class="badge <%= String(c.registrationMode || '').trim().toLowerCase() === 'rolling' ? 'bg-warning-subtle text-warning-emphasis border border-warning-subtle' : 'bg-light text-dark border' %>">
            <%= String(c.registrationMode || '').trim().toLowerCase() === 'rolling' ? 'Rolling' : 'Term-Based' %>
          </span>
          <span class="badge bg-info-subtle text-info border border-info-subtle">Active Periods: <%= Number(lc.activePeriodCount || 0) %></span>
          <span class="badge bg-light text-dark border">Open Periods: <%= Number(lc.openPeriodCount || 0) %></span>
          <% if (String(c.registrationMode || '').trim().toLowerCase() === 'rolling') { %>
            <a href="/school/classes/<%= encodeURIComponent(c.id || '') %>/rolling-enrollment" class="btn btn-outline-primary btn-sm ms-auto"><i class="bi bi-people me-1"></i>Rolling Enrollment</a>
            <a href="/school/classes/<%= encodeURIComponent(c.id || '') %>/cycle-rollover" class="btn btn-outline-warning btn-sm"><i class="bi bi-arrow-repeat me-1"></i>Cycle Rollover</a>
          <% } %>
        </div>
        <% if (lc.previousClass || lc.nextClass) { %>
          <div class="small text-muted mt-2">
            <% if (lc.previousClass) { %>
              Previous:
              <a href="/school/classes/edit/<%= encodeURIComponent(lc.previousClass.id) %>"><%= lc.previousClass.title || lc.previousClass.id %></a>
            <% } %>
            <% if (lc.previousClass && lc.nextClass) { %><span class="mx-2">|</span><% } %>
            <% if (lc.nextClass) { %>
              Next:
              <a href="/school/classes/edit/<%= encodeURIComponent(lc.nextClass.id) %>"><%= lc.nextClass.title || lc.nextClass.id %></a>
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  <% } %>

  <div class="form-container wide" style="max-width: 1400px;">
    <form id="classForm" action="<%= isEdit ? '/school/classes/edit/'+c.id : '/school/classes/new' %>" method="POST">
      
      <input type="hidden" name="curriculum" id="hid_curriculum" value='<%- initCurriculum %>'>
      <input type="hidden" name="billingMode" id="hid_billingMode" value="<%= initBillingMode %>">
      <input type="hidden" name="pricing" id="hid_pricing" value='<%- initPricing %>'>
      <input type="hidden" name="postingTemplates" id="hid_postingTemplates" value='<%- initPostingTemplates %>'>
      <input type="hidden" name="allowedProgramTerms" id="hid_allowedProgramTerms" value='<%- initAllowedProgramTerms %>'>
      <input type="hidden" name="instructors" id="hid_instructors" value='<%- initInstructors %>'>
      <input type="hidden" name="enrollment" id="hid_enrollment" value='<%- initEnrollment %>'>
      <input type="hidden" name="evaluation" id="hid_evaluation" value='<%- initEvaluation %>'>
      <input type="hidden" name="sessions" id="hid_sessions" value='<%- initSessions %>'>
      <input type="hidden" name="actionStateId" id="hid_actionStateId" value="<%= asid %>">

      <ul class="nav nav-tabs mb-4" id="classTabs" role="tablist">
        <li class="nav-item"><button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-general" type="button">General Info</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-eligibility" type="button">Program / terms</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-curriculum" type="button">Curriculum & Team</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-sessions" type="button">Session Builder</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-eval" type="button">Evaluation Rules</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-pricing" type="button">Pricing</button></li>
        <li class="nav-item"><button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-posting" type="button">Posting Policies</button></li>
      </ul>

      <div class="tab-content">
        <div class="tab-pane fade show active" id="tab-general">
           <div class="row">
              <div class="col-md-6 mb-3">
                 <label class="form-label">Class Title *</label>
                 <input type="text" name="title" class="form-control size-md" value="<%= c.title || '' %>" required placeholder="e.g., Fall 2026 - CS Bootcamp">
              </div>
              <div class="col-md-6 mb-3">
                 <label class="form-label">Organization</label>
                 <input type="text" class="form-control size-md bg-light" value="Active Organization Context" readonly>
                 <div class="form-text small">Organization is determined securely from your active organization.</div>
              </div>
           </div>
           <div class="row">
              <div class="col-md-6 mb-3">
                 <label class="form-label">Status</label>
                 <select name="status" class="form-select size-md">
                    <option value="draft" <%= c.status=='draft'?'selected':'' %>>Draft (Planning)</option>
                    <option value="active" <%= c.status=='active'?'selected':'' %>>Active</option>
                    <option value="completed" <%= c.status=='completed'?'selected':'' %>>Completed</option>
                    <option value="cancelled" <%= c.status=='cancelled'?'selected':'' %>>Cancelled</option>
                 </select>
              </div>
              <div class="col-md-6 mb-3">
                 <label class="form-label">Max Student Capacity</label>
                 <input type="number" id="inp_capacity" class="form-control size-md" placeholder="e.g. 30" required>
              </div>
           </div>
           <div class="row">
              <div class="col-md-6 mb-3">
                 <label class="form-label">Delivery Department *</label>
                 <div class="input-group">
                    <input type="hidden" id="inp_deliveryDepartmentId" value="<%= c.deliveryDepartmentId || '' %>">
                    <input type="text" id="inp_deliveryDepartmentName" class="form-control size-md bg-white" value="<%= c.deliveryDepartmentName || '' %>" placeholder="Select delivery department..." readonly required>
                    <button type="button" class="btn btn-outline-primary" id="openDeliveryDepartmentPickerBtn"><i class="bi bi-diagram-3"></i></button>
                 </div>
                 <div class="form-text small">This department is used for timesheet and payroll rate resolution.</div>
              </div>
           </div>
           <div class="card border-0 shadow-sm mb-3">
              <div class="card-body">
                 <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">
                    <h6 class="fw-bold text-primary m-0"><i class="bi bi-arrow-repeat me-1"></i>Lifecycle</h6>
                    <span class="badge bg-light text-dark border" id="lifecycle_modeBadge">TERM-BASED</span>
                 </div>
                 <div class="row">
                    <div class="col-md-4 mb-3">
                       <label class="form-label">Registration Mode</label>
                       <select id="inp_registrationMode" class="form-select size-md">
                          <option value="term_based" <%= String(c.registrationMode || 'term_based') === 'rolling' ? '' : 'selected' %>>Term-Based</option>
                          <option value="rolling" <%= String(c.registrationMode || '') === 'rolling' ? 'selected' : '' %>>Rolling</option>
                       </select>
                       <div class="form-text small">Term-based remains unchanged. Rolling enables enrollment periods/cycles.</div>
                    </div>
                    <div class="col-md-4 mb-3">
                       <label class="form-label">Cycle Group ID</label>
                       <input type="text" id="inp_cycleGroupId" class="form-control size-md" value="<%= c.cycleGroupId || '' %>" placeholder="Optional shared group id">
                       <div class="form-text small">Classes in the same rolling chain can share one cycle group.</div>
                    </div>
                    <div class="col-md-4 mb-3">
                       <label class="form-label">Cycle Number</label>
                       <input type="number" id="inp_cycleNo" class="form-control size-md" min="1" step="1" value="<%= Number(c.cycleNo || 1) > 0 ? Number(c.cycleNo || 1) : 1 %>">
                       <div class="form-text small">Used for sequence tracking in rolling class chains.</div>
                    </div>
                 </div>
                 <div id="rollingLifecycleFields">
                    <div class="row">
                       <div class="col-md-4 mb-3">
                          <label class="form-label">Cycle Start Date</label>
                          <input type="date" id="inp_cycleStartDate" class="form-control size-md" value="<%= c.cycleStartDate || '' %>">
                       </div>
                       <div class="col-md-4 mb-3">
                          <label class="form-label">Cycle End Date</label>
                          <input type="date" id="inp_cycleEndDate" class="form-control size-md" value="<%= c.cycleEndDate || '' %>">
                       </div>
                       <div class="col-md-4 mb-3 d-flex align-items-center">
                          <div class="form-check form-switch mt-4">
                             <input class="form-check-input" type="checkbox" role="switch" id="inp_isClosedForNewEnrollment" <%= c.isClosedForNewEnrollment ? 'checked' : '' %>>
                             <label class="form-check-label" for="inp_isClosedForNewEnrollment">Closed For New Enrollment</label>
                             <div class="form-text small">When enabled, new open enrollment periods are blocked for this rolling class.</div>
                          </div>
                       </div>
                    </div>
                    <% if (isEdit) { %>
                    <div class="row">
                       <div class="col-md-6 mb-2">
                          <label class="form-label">Previous Class ID</label>
                          <input type="text" id="inp_previousClassId" class="form-control size-md bg-light" value="<%= c.previousClassId || '' %>" readonly>
                       </div>
                       <div class="col-md-6 mb-2">
                          <label class="form-label">Next Class ID</label>
                          <input type="text" id="inp_nextClassId" class="form-control size-md bg-light" value="<%= c.nextClassId || '' %>" readonly>
                       </div>
                    </div>
                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">
                       <div class="small text-muted" id="rollingIntegritySummary">Run a quick integrity scan for rolling periods before save.</div>
                       <button type="button" class="btn btn-outline-warning btn-sm" id="btn_checkRollingIntegrity">
                          <i class="bi bi-shield-check me-1"></i>Check Rolling Integrity
                       </button>
                    </div>
                    <hr class="my-3">
                    <div class="row g-3">
                      <div class="col-lg-4">
                        <div class="border rounded p-3 h-100 bg-light-subtle">
                          <div class="fw-bold text-primary mb-2"><i class="bi bi-lock me-1"></i>Close Current Cycle</div>
                          <div class="small text-muted mb-2">Closes the active rolling cycle and blocks new open periods.</div>
                          <div class="mb-2">
                            <label class="form-label small mb-1">Cycle End Date</label>
                            <input type="date" id="cycleAction_closeEndDate" class="form-control form-control-sm" value="<%= c.cycleEndDate || '' %>">
                          </div>
                          <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="cycleAction_closeBlockEnrollment" checked>
                            <label class="form-check-label small" for="cycleAction_closeBlockEnrollment">Block new enrollment immediately</label>
                          </div>
                          <button type="button" class="btn btn-outline-danger btn-sm w-100" id="btn_cycleClose" data-cycle-action="close">
                            <i class="bi bi-lock-fill me-1"></i>Close Cycle
                          </button>
                        </div>
                      </div>
                      <div class="col-lg-4">
                        <div class="border rounded p-3 h-100 bg-light-subtle">
                          <div class="fw-bold text-primary mb-2"><i class="bi bi-node-plus me-1"></i>Create Next Cycle</div>
                          <div class="small text-muted mb-2">Creates the next rolling class cycle from this class template.</div>
                          <div class="mb-2">
                            <label class="form-label small mb-1">Next Cycle Start Date *</label>
                            <input type="date" id="cycleAction_nextStartDate" class="form-control form-control-sm">
                          </div>
                          <div class="mb-2">
                            <label class="form-label small mb-1">Next Cycle End Date</label>
                            <input type="date" id="cycleAction_nextEndDate" class="form-control form-control-sm">
                          </div>
                          <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="cycleAction_closeCurrentOnCreate" checked>
                            <label class="form-check-label small" for="cycleAction_closeCurrentOnCreate">Close current cycle first</label>
                          </div>
                          <div class="form-check form-switch mb-2">
                            <input class="form-check-input" type="checkbox" id="cycleAction_autoCarryForward" checked>
                            <label class="form-check-label small" for="cycleAction_autoCarryForward">Auto carry-forward eligible students</label>
                          </div>
                          <button type="button" class="btn btn-outline-primary btn-sm w-100" id="btn_cycleCreateNext" data-cycle-action="create-next">
                            <i class="bi bi-plus-circle me-1"></i>Create Next Cycle
                          </button>
                        </div>
                      </div>
                      <div class="col-lg-4">
                        <div class="border rounded p-3 h-100 bg-light-subtle">
                          <div class="fw-bold text-primary mb-2"><i class="bi bi-people-fill me-1"></i>Carry-Forward Students</div>
                          <div class="small text-muted mb-2">Moves/splits eligible periods to a target rolling class cycle.</div>
                          <div class="mb-2">
                            <label class="form-label small mb-1">Target Class ID *</label>
                            <input type="text" id="cycleAction_targetClassId" class="form-control form-control-sm" value="<%= c.nextClassId || '' %>" placeholder="e.g. CLS-2000">
                          </div>
                          <div class="mb-2">
                            <label class="form-label small mb-1">Boundary Date *</label>
                            <input type="date" id="cycleAction_boundaryDate" class="form-control form-control-sm">
                          </div>
                          <button type="button" class="btn btn-outline-success btn-sm w-100" id="btn_cycleCarryForward" data-cycle-action="carry-forward">
                            <i class="bi bi-arrow-left-right me-1"></i>Carry-Forward
                          </button>
                        </div>
                      </div>
                    </div>
                    <div class="small text-muted mt-2" id="rollingCycleActionSummary">Run an action to update cycle links and enrollment periods.</div>
                    <% } %>
                 </div>
                 <div id="termLifecycleHint" class="small text-muted mt-2">
                    Term-based classes ignore rolling cycle validation rules.
                 </div>
              </div>
           </div>
        </div>

        <div class="tab-pane fade" id="tab-eligibility">
           <div class="alert alert-light border shadow-sm mb-3" id="eligibility_tab_intro">
              <i class="bi bi-calendar3-range me-2"></i><span id="eligibility_tab_intro_text">Map allowed program and term combinations for this class.</span>
           </div>
           <div class="card border-0 shadow-sm mb-4">
              <div class="card-body">
                 <div class="row g-3 align-items-end">
                    <div class="col-md-6">
                       <label class="form-label fw-bold">Program</label>
                       <div class="input-group">
                          <input type="hidden" id="eligibility_programId">
                          <input type="text" id="eligibility_programName" class="form-control size-md bg-white" placeholder="Select program..." readonly>
                          <button type="button" class="btn btn-outline-primary" id="btnPickEligibilityProgram"><i class="bi bi-journal-text"></i></button>
                       </div>
                    </div>
                    <div class="col-md-4">
                       <label class="form-label fw-bold" id="eligibility_term_label">Program term</label>
                       <select id="eligibility_termId" class="form-select size-md" disabled>
                          <option value="">Select a program first</option>
                       </select>
                    </div>
                    <div class="col-md-2">
                       <button type="button" class="btn btn-filled btn-primary w-100" id="btnAddAllowedProgramTerm"><i class="bi bi-plus-circle me-1"></i>Add</button>
                    </div>
                 </div>
                 <div class="small text-muted mt-2" id="eligibility_programHint">Pick a program to load its defined terms/semesters.</div>
              </div>
           </div>

           <div class="table-responsive border rounded bg-white">
              <table class="table table-sm align-middle mb-0">
                 <thead class="table-light">
                    <tr>
                       <th style="width: 8%;">Order</th>
                       <th style="width: 34%;">Program</th>
                       <th style="width: 28%;">Term</th>
                       <th>Notes</th>
                       <th style="width: 12%;" class="text-end">Actions</th>
                    </tr>
                 </thead>
                 <tbody id="allowedProgramTermsTbody"></tbody>
              </table>
           </div>
        </div>

        <div class="tab-pane fade" id="tab-curriculum">
           <div class="d-flex justify-content-between align-items-center mb-3">
               <h6 class="fw-bold text-primary m-0">Curriculum Subjects</h6>
               <button type="button" class="btn btn-sm btn-outline-primary" id="openSubjectPickerBtn"><i class="bi bi-plus"></i> Add Subject</button>
           </div>
           <div class="table-responsive border rounded bg-white mb-4">
               <table class="table table-hover table-sm mb-0 align-middle">
                   <thead class="table-light">
                       <tr><th>Subject Code & Name</th><th style="width:150px;">Allocated Hrs</th><th style="width:50px;" class="text-center">Action</th></tr>
                   </thead>
                   <tbody id="subjectsTbody"></tbody>
               </table>
           </div>
           <div class="row mb-4">
              <div class="col-md-4">
                 <label class="form-label">Target Total Class Hours</label>
                 <input type="number" id="inp_totalHours" class="form-control size-md" placeholder="e.g. 45" required>
              </div>
              <div class="col-md-4">
                 <label class="form-label">Class Credits</label>
                 <input type="number" id="inp_credits" class="form-control size-md" value="<%= initCredits %>" min="0" step="0.01" placeholder="Auto-calculated from subjects">
                 <div class="form-text small" id="classCreditsHint">Defaults to the selected subjects' total credits. You can edit it.</div>
              </div>
           </div>
           <hr>
           <h6 class="fw-bold text-primary mb-3">Primary Instructor</h6>
           <div class="row">
              <div class="col-md-6 mb-3">
                 <label class="form-label">Default Teacher / User</label>
                 <div class="input-group">
                    <input type="hidden" id="inp_instructorId" required>
                    <input type="text" id="inp_instructorName" class="form-control size-md bg-white" placeholder="Select Instructor..." readonly required>
                    <button type="button" class="btn btn-outline-primary" id="openUserPickerBtn"><i class="bi bi-person"></i></button>
                 </div>
              </div>
              <div class="col-md-6 mb-3">
                 <label class="form-label">Role</label>
                 <input type="text" id="inp_instructorRole" class="form-control size-md" value="Primary">
              </div>
           </div>
        </div>

        <div class="tab-pane fade" id="tab-sessions">
           <div class="card bg-light border-0 mb-4">
             <div class="card-body">
               <h6 class="fw-bold text-dark mb-3"><i class="bi bi-magic me-2"></i>Batch Session Generator</h6>
               <div class="alert alert-info border small py-2 mb-3 d-none" id="rollingSessionWindowHint"></div>
               <div class="row g-2 mb-3">
                  <div class="col-md-2"><label class="form-label x-small">Start Date</label><input type="date" id="bg_start" class="form-control size-sm"></div>
                  <div class="col-md-2"><label class="form-label x-small">End Date</label><input type="date" id="bg_end" class="form-control size-sm"></div>
                  <div class="col-md-2"><label class="form-label x-small">Start Time</label><input type="time" id="bg_start_time" class="form-control size-sm"></div>
                  <div class="col-md-2"><label class="form-label x-small">End Time</label><input type="time" id="bg_end_time" class="form-control size-sm"></div>
                  <div class="col-md-4">
                    <label class="form-label x-small">Assigned Teacher</label>
                    <div class="input-group input-group-sm">
                        <input type="hidden" id="bg_teacherId">
                        <input type="text" id="bg_teacherName" class="form-control bg-white" placeholder="Select..." readonly>
                        <button type="button" class="btn btn-outline-secondary" id="bg_openTeacherPickerBtn" title="Select Teacher"><i class="bi bi-person"></i></button>
                        <button type="button" class="btn btn-outline-info fw-bold" id="bg_viewTeacherScheduleBtn" title="View Master Schedule"><i class="bi bi-calendar3"></i></button>
                    </div>
                   </div>
                </div>
                <div class="row g-2 mb-3">
                  <div class="col-md-3">
                      <label class="form-label x-small">Default Room / Location</label>
                      <input type="text" id="bg_room" class="form-control size-sm" placeholder="e.g. Room 101">
                  </div>
                  <div class="col-md-9">
                     <label class="form-label x-small text-muted">Skip Specific Dates (Comma Separated YYYY-MM-DD)</label>
                     <input type="text" id="bg_exceptions" class="form-control size-sm" placeholder="2026-11-26, 2026-12-25">
                     <div class="form-check form-switch mt-2">
                        <input class="form-check-input" type="checkbox" role="switch" id="bg_skipHolidays">
                        <label class="form-check-label small text-muted" for="bg_skipHolidays">Skip Holidays/Off Days</label>
                        <div class="small text-muted" id="bg_holidayHint" style="display:none;"></div>
                     </div>
                  </div>
               </div>
               <div class="d-flex align-items-center justify-content-between">
                   <div class="btn-group" role="group">
                     <input type="checkbox" class="btn-check bg-day-cb" id="bg_Mon" value="1"><label class="btn btn-sm btn-outline-primary" for="bg_Mon">Mon</label>
                     <input type="checkbox" class="btn-check bg-day-cb" id="bg_Tue" value="2"><label class="btn btn-sm btn-outline-primary" for="bg_Tue">Tue</label>
