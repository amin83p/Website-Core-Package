    function buildSessionsPayloadForValidation() {
        const fallbackTeacherId = String(
            document.getElementById('bg_teacherId')?.value
            || document.getElementById('inp_instructorId')?.value
            || ''
        ).trim();
        const fallbackTeacherName = String(
            document.getElementById('bg_teacherName')?.value
            || document.getElementById('inp_instructorName')?.value
            || fallbackTeacherId
            || ''
        ).trim();

        return (Array.isArray(sessionsState) ? sessionsState : []).map((row) => {
            const normalized = row && typeof row === 'object' ? { ...row } : {};
            normalized.delivery = (normalized.delivery && typeof normalized.delivery === 'object')
                ? { ...normalized.delivery }
                : {};
            if (!String(normalized.delivery.deliveredBy || '').trim() && fallbackTeacherId) {
                normalized.delivery.deliveredBy = fallbackTeacherId;
            }
            if (!String(normalized.delivery.deliveredByName || '').trim() && fallbackTeacherName) {
                normalized.delivery.deliveredByName = fallbackTeacherName;
            }
            return normalized;
        });
    }

    // Conflict Checking Engine
    async function executeConflictCheck() {
        try {
            const sessionsPayload = buildSessionsPayloadForValidation();
            const cycleViolations = findSessionCycleWindowViolations(sessionsPayload);
            if (cycleViolations.length) {
                return {
                    hasConflicts: false,
                    checkFailed: true,
                    hasWarnings: false,
                    message: buildSessionCycleWindowViolationMessage(cycleViolations)
                };
            }
            const defaultTeacherId = String(
                document.getElementById('bg_teacherId')?.value
                || document.getElementById('inp_instructorId')?.value
                || ''
            ).trim();
            const instructorId = String(document.getElementById('inp_instructorId')?.value || '').trim();
            const instructorsPayload = JSON.stringify(getInstructorRowsForSubmit());
            const params = new URLSearchParams();
            params.append('classId', classId);
            if (classId) params.append('id', classId);
            params.append('sessions', JSON.stringify(sessionsPayload));
            params.append('defaultTeacherId', defaultTeacherId);
            params.append('registrationMode', isRollingMode() ? 'rolling' : 'term_based');
            params.append('cycleStartDate', String(cycleStartDateInput?.value || '').trim());
            params.append('cycleEndDate', String(cycleEndDateInput?.value || '').trim());
            params.append('allowedProgramTerms', hidAllowedProgramTerms.value || '[]');
            params.append('instructors', instructorsPayload);
            params.append('actionStateId', document.getElementById('hid_actionStateId')?.value || '');

            const res = await fetch('/school/classes/api/check-conflicts', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-AJAX-Request': 'true' },
                body: params.toString()
            });
            if (!res.ok) {
                const text = await res.text();
                let message = 'Unable to validate schedule conflicts.';
                try {
                    const parsed = JSON.parse(text);
                    message = parsed?.message || message;
                } catch (_) {}
                return { hasConflicts: false, checkFailed: true, message };
            }
            const result = await res.json();
            if (result?.status !== 'success') {
                return {
                    hasConflicts: false,
                    checkFailed: true,
                    message: result?.message || 'Conflict validation failed.'
                };
            }
            
            sessionsState.forEach(s => s.conflictMsg = null);

            if (Array.isArray(result.conflicts) && result.conflicts.length > 0) {
                result.conflicts.forEach(c => {
                    sessionsState[c.sessionIndex].conflictMsg = `Conflict: ${c.conflictClass} (${c.existTime})`;
                });
                renderSessions();
                
                let msg = `<b>Found ${result.conflicts.length} scheduling conflicts!</b><br><br><ul class="text-start mb-0">`;
                result.conflicts.slice(0, 5).forEach(c => {
                    msg += `<li><b>${c.date}</b>: ${c.teacherName} is booked for <i>${c.conflictClass}</i></li>`;
                });
                if(result.conflicts.length > 5) msg += `<li>...and ${result.conflicts.length - 5} more.</li>`;
                msg += `</ul><br>Conflicting sessions are highlighted in red. Resolve conflicts before saving.`;

                return { hasConflicts: true, checkFailed: false, hasWarnings: false, message: msg };
            } else {
                renderSessions();
                const unresolvedCount = Number(result?.diagnostics?.unresolvedTeacherSessions || 0);
                if (unresolvedCount > 0) {
                    return {
                        hasConflicts: false,
                        checkFailed: false,
                        hasWarnings: true,
                        message: `No overlaps detected, but ${unresolvedCount} session(s) have no teacher assignment in session data. Assign teacher(s) to run a complete conflict check.`
                    };
                }
                return { hasConflicts: false, checkFailed: false, hasWarnings: false, message: "Schedule looks perfect! No conflicts found." };
            }
        } catch (e) {
            console.error(e);
            return { hasConflicts: false, checkFailed: true, hasWarnings: false, message: 'Unable to validate schedule conflicts. Please try again.' };
        }
    }
    const btnManualCheck = document.getElementById('btn_manualConflictCheck');
    if(btnManualCheck) {
        btnManualCheck.addEventListener('click', async () => {
            const originalHtml = btnManualCheck.innerHTML;
            btnManualCheck.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Checking...';
            btnManualCheck.disabled = true;

            const check = await executeConflictCheck();
            const modalTitle = check.checkFailed
                ? 'Validation Failed'
                : (check.hasConflicts ? 'Conflicts Found' : (check.hasWarnings ? 'Validation Warning' : 'Schedule Clear'));
            const modalMessage = check.checkFailed
                ? check.message
                : (check.hasConflicts || check.hasWarnings ? check.message : 'No conflicts found.');
            const modalIcon = check.checkFailed
                ? 'error'
                : (check.hasConflicts ? 'error' : (check.hasWarnings ? 'warning' : 'success'));
            if (typeof showMessageModal === 'function') {
                await showMessageModal({
                    title: modalTitle,
                    icon: modalIcon,
                    message: modalMessage,
                    buttons: [{ text: 'OK', class: modalIcon === 'error' ? 'btn-danger' : (modalIcon === 'warning' ? 'btn-warning' : 'btn-success') }]
                });
            } else {
                await uiAlert(modalMessage, modalTitle);
            }

            btnManualCheck.innerHTML = originalHtml;
            btnManualCheck.disabled = false;
        });
    }

    // Submit Logic
// Submit Logic
    const form = document.getElementById('classForm');
    form.addEventListener('invalid', (ev) => {
        const el = ev.target;
        if (!el) return;
        const pane = el.closest('.tab-pane');
        if (pane) {
            const tabBtn = document.querySelector(`button[data-bs-target="#${pane.id}"]`);
            if (tabBtn) tabBtn.click();
        }
        setTimeout(() => { try { el.focus(); form.reportValidity(); } catch (_) {} }, 150);
    }, true);

form.addEventListener('submit', async (e) => {
        e.preventDefault();
        if (!form.checkValidity()) {
            const firstInvalid = form.querySelector(':invalid');
            if (firstInvalid) {
                const pane = firstInvalid.closest('.tab-pane');
                if (pane) {
                    const tabBtn = document.querySelector(`button[data-bs-target="#${pane.id}"]`);
                    if (tabBtn) tabBtn.click(); 
                }
                setTimeout(() => { firstInvalid.focus(); form.reportValidity(); }, 150);
            }
            return;
        }

        const submitBtn = form.querySelector('button[type="submit"]');
        const originalText = submitBtn.innerHTML;
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Validating...';

        try {
            normalizeCurriculumState({ rebalanceIfMissing: false });
            const curriculumWeightTotal = getCurriculumWeightTotal();
            if (curriculumState.length && Math.abs(curriculumWeightTotal - 100) > 0.01) {
                await uiAlert(`Curriculum subject fee weights must total 100%. Current total is ${curriculumWeightTotal.toFixed(2)}%.`, 'Invalid Subject Weights');
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                return;
            }

            normalizePricingState();
            billingModeState = normalizeBillingMode(document.querySelector('input[name="billingMode"]:checked')?.value || billingModeState);
            syncBillingModeHidden();
            normalizePostingTemplateState();
            if (!isChargeableClass()) {
                postingTemplateState = [];
                syncPostingTemplateSelectionUi();
            } else {
                const allCategoriesTemplate = (postingTemplateState || []).find((row) => String(row?.feeCategory || '').trim() === allFeeCategoryKey);
                const missingTemplate = (postingTemplateState || []).find((row) => !String(row?.transactionDefinitionId || '').trim());
                if (missingTemplate) {
                    const postingTabBtn = document.querySelector('button[data-bs-target="#tab-posting"]');
                    if (postingTabBtn) postingTabBtn.click();
                    await uiAlert(`Select a Transaction Template for ${labelFeeCategory(missingTemplate.feeCategory)} before saving the class.`, 'Missing Posting Template');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                    return;
                }
                if (!allCategoriesTemplate) {
                    const postingTabBtn = document.querySelector('button[data-bs-target="#tab-posting"]');
                    if (postingTabBtn) postingTabBtn.click();
                    await uiAlert('Add an All Categories Posting Policy. It is required as the fallback when new fee categories are added later.', 'Missing All Categories Policy');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                    return;
                }
            }

            const lifecycleError = validateLifecycleInputs();
            if (lifecycleError) {
                const generalTabBtn = document.querySelector('button[data-bs-target="#tab-general"]');
                if (generalTabBtn) generalTabBtn.click();
                if (typeof showMessageModal === 'function') {
                    await showMessageModal({
                        title: 'Lifecycle Validation',
                        icon: 'warning',
                        message: lifecycleError,
                        buttons: [{ text: 'OK', class: 'btn-warning' }]
                    });
                } else {
                    await uiAlert(lifecycleError, 'Lifecycle Validation');
                }
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                return;
            }
            if (isRollingMode() && !!isClosedEnrollmentInput?.checked && classId) {
                try {
                    const openRows = await findOpenPeriodsForClosedClassCheck();
                    if (openRows.length) {
                        const sample = openRows.slice(0, 5).map((row) => String(row?.id || '').trim()).filter(Boolean).join(', ');
                        const details = sample ? `<br><span class="small text-muted">Sample period IDs: ${sample}${openRows.length > 5 ? ' ...' : ''}</span>` : '';
                        if (typeof showMessageModal === 'function') {
                            await showMessageModal({
                                title: 'Close Enrollment Blocked',
                                icon: 'warning',
                                message: `This class still has ${openRows.length} open enrollment period(s) (draft/planned/active). Close them before marking the class as Closed For New Enrollment.${details}`,
                                buttons: [{ text: 'OK', class: 'btn-warning' }]
                            });
                        } else {
                            await uiAlert(`This class still has ${openRows.length} open enrollment period(s). Close them first before marking enrollment as closed.`, 'Close Enrollment Blocked');
                        }
                        submitBtn.disabled = false;
                        submitBtn.innerHTML = originalText;
                        return;
                    }
                } catch (error) {
                    if (typeof showMessageModal === 'function') {
                        await showMessageModal({
                            title: 'Lifecycle Precheck Failed',
                            icon: 'error',
                            message: error?.message || 'Unable to verify enrollment periods before save.',
                            buttons: [{ text: 'OK', class: 'btn-danger' }]
                        });
                    } else {
                        await uiAlert(error?.message || 'Unable to verify enrollment periods before save.', 'Lifecycle Precheck Failed');
                    }
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                    return;
                }
            }

            // Pre-flight Conflict Check
            const check = await executeConflictCheck();
            if (check.checkFailed) {
                const failMsg = check.message || 'Unable to validate schedule conflicts. Please try again.';
                if (typeof showMessageModal === 'function') {
                    await showMessageModal({
                        title: 'Conflict Validation Failed',
                        icon: 'error',
                        message: failMsg,
                        buttons: [{ text: 'OK', class: 'btn-danger' }]
                    });
                } else {
                    await uiAlert(failMsg, 'Conflict Validation Failed');
                }
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                return;
            }
            if (check.hasConflicts) {
                if (typeof showMessageModal === 'function') {
                    await showMessageModal({
                        title: 'Scheduling Conflicts Detected',
                        icon: 'error',
                        message: check.message,
                        buttons: [{ text: 'OK', class: 'btn-danger' }]
                    });
                } else {
                    await uiAlert(check.message, 'Scheduling Conflicts Detected');
                }
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                return;
            }
            if (check.hasWarnings) {
                if (typeof showMessageModal === 'function') {
                    await showMessageModal({
                        title: 'Conflict Check Warning',
                        icon: 'warning',
                        message: check.message,
                        buttons: [{ text: 'OK', class: 'btn-warning' }]
                    });
                } else {
                    await uiAlert(check.message, 'Conflict Check Warning');
                }
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                return;
            }

            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Saving...';
            
            // ---------------------------------------------------------
            // FIX: Manually build the payload from memory variables.
            // Do NOT use FormData, as it relies on hidden HTML inputs 
            // that can corrupt large JSON arrays.
            // ---------------------------------------------------------
            const params = new URLSearchParams();
            params.append('title', document.querySelector('input[name="title"]').value);
            params.append('status', document.querySelector('select[name="status"]').value);
            const selectedRegistrationMode = isRollingMode() ? 'rolling' : 'term_based';
            params.append('registrationMode', selectedRegistrationMode);
            params.append('cycleGroupId', String(cycleGroupIdInput?.value || '').trim());
            params.append('cycleNo', String(Number.parseInt(String(cycleNoInput?.value || '1').trim(), 10) || 1));
            params.append('cycleStartDate', selectedRegistrationMode === 'rolling' ? String(cycleStartDateInput?.value || '').trim() : '');
            params.append('cycleEndDate', selectedRegistrationMode === 'rolling' ? String(cycleEndDateInput?.value || '').trim() : '');
            params.append('isClosedForNewEnrollment', selectedRegistrationMode === 'rolling' && !!isClosedEnrollmentInput?.checked ? 'true' : 'false');
            params.append('deliveryDepartmentId', document.getElementById('inp_deliveryDepartmentId').value || '');
            params.append('deliveryDepartmentName', document.getElementById('inp_deliveryDepartmentName').value || '');
            normalizeAllowedProgramTermsState();
            syncAllowedProgramTermsHidden();
            if (selectedRegistrationMode === 'rolling') {
                let aptRows = [];
                try {
                    aptRows = JSON.parse(hidAllowedProgramTerms.value || '[]');
                } catch (e) {
                    aptRows = [];
                }
                const hasProgram = Array.isArray(aptRows) && aptRows.some((r) => String(r.programId || '').trim());
                if (!hasProgram) {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                    await uiAlert('Rolling classes require at least one program on the Program / terms tab. Add a program without a term, or a program–term pair, then save again.', 'Program required');
                    return;
                }
            }
            params.append('allowedProgramTerms', hidAllowedProgramTerms.value || '[]');
            
            const tHours = parseInt(document.getElementById('inp_totalHours').value) || 0;
            params.append('curriculum', JSON.stringify({ subjects: curriculumState, totalHours: tHours }));
            params.append('credits', String(roundWeight(document.getElementById('inp_credits').value)));
            normalizePricingState();
            params.append('pricing', hidPricing.value || '{"feeRules":[]}');
            normalizePostingTemplateState();
            params.append('postingTemplates', hidPostingTemplates.value || '[]');
            params.append('billingMode', hidBillingMode?.value || 'chargeable');
            
            params.append('instructors', JSON.stringify(getInstructorRowsForSubmit()));
            
            const dEnrl = JSON.parse(document.getElementById('hid_enrollment').value || '{}');
            dEnrl.maxCapacity = parseInt(document.getElementById('inp_capacity').value) || 30;
            params.append('enrollment', JSON.stringify(dEnrl));
            
            const rollingSave = isRollingMode();
            params.append('evaluation', JSON.stringify({
                passingScore: parseInt(document.getElementById('inp_passingScore').value) || 60,
                weights: {
                    attendance: parseInt(document.getElementById('inp_wAtt').value) || 0,
                    assignments: parseInt(document.getElementById('inp_wAss').value) || 0,
                    midterm: rollingSave ? 0 : (parseInt(document.getElementById('inp_wMid').value) || 0),
                    finalExam: rollingSave ? 0 : (parseInt(document.getElementById('inp_wFin').value) || 0)
                }
            }));
            
            // Append sessions payload directly from JS memory
            const submitSessionsPayload = buildSessionsPayloadForValidation();
            params.append('sessions', JSON.stringify(submitSessionsPayload));
            params.append('actionStateId', document.getElementById('hid_actionStateId')?.value || '');

            const response = await fetch(form.action, {
                method: 'POST', 
                headers: { 
                    'Content-Type': 'application/x-www-form-urlencoded', 
                    'X-AJAX-Request': 'true' 
                },
                body: params.toString()
            });
            
            // Robust Error Handling to catch backend validation rules
            let result;
            try {
                result = await response.json();
            } catch (err) {
                const text = await response.text();
                throw new Error(`Server rejected the request (Status ${response.status}). Please check your inputs.`);
            }
            const guarded = typeof window.applyGuardedApiResult === 'function'
                ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Processed' })
                : { stop: false };
            if (guarded.stop) {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalText;
                return;
            }
            
            if (result.status !== 'success') {
                throw new Error(result.message || 'Unknown error occurred on save.');
            }

            // Success Redirect
            if (typeof showMessageModal === 'function') {
                await showMessageModal({ title: 'Success', icon: 'success', message: result.message, buttons: [{ text: 'OK', class: 'btn-success' }] });
            }
            window.location.href = '/school/classes';

        } catch (error) {
            console.error('Submission Error:', error);
            submitBtn.disabled = false; 
            submitBtn.innerHTML = originalText;
            
            // Pop the error up so you can actually read it instead of digging in the console
            if (typeof showMessageModal === 'function') {
                showMessageModal({ title: 'Save Failed', icon: 'error', message: error.message, buttons: [{ text: 'OK', class: 'btn-danger' }] });
            } else {
                await uiAlert(error.message, 'Save Failed');
            }
        }
    });
    // Modals & Batch Logic
    const modalEl = document.getElementById('singleSessionModal');
    let sessionModal;
    if (typeof bootstrap !== 'undefined') { sessionModal = new bootstrap.Modal(modalEl); }
    
    document.getElementById('btn_saveSingleSession').addEventListener('click', async () => {
        const date = document.getElementById('mod_date').value;
        const sTime = document.getElementById('mod_startTime').value;
        const eTime = document.getElementById('mod_endTime').value;
        const teacherId = document.getElementById('mod_teacherId').value;
        const teacherName = document.getElementById('mod_teacherName').value;
        const notes = document.getElementById('mod_notes').value;

        if (!date || !sTime || !eTime) { await uiAlert('Date, Start Time, and End Time are required.', 'Single Session'); return; }
        if (isRollingMode()) {
            const bounds = getRollingCycleBounds();
            if (bounds?.error) {
                await uiAlert(bounds.error, 'Single Session');
                return;
            }
            if (date < bounds.startToken || (bounds.endToken && date > bounds.endToken)) {
                await uiAlert(`Session date must be within cycle dates (${bounds.startToken}${bounds.endToken ? ` to ${bounds.endToken}` : ''}).`, 'Single Session');
                return;
            }
        }

        sessionsState.push({
            sessionId: "SES_" + Date.now() + Math.random().toString().slice(2, 6),
            date: date, originalDate: date, startTime: sTime, endTime: eTime, durationHours: getDuration(sTime, eTime),
            room: "", // <--- NEW FIELD
            status: normalizeStatusCode(defaultSessionStatusCode) || 'scheduled', notes: notes, locked: false,
            delivery: { deliveredBy: teacherId, deliveredByName: teacherName, substitute: false }, roster: [],
            _isSaved: false // Tag as explicitly unsaved
        });
        document.getElementById('mod_date').value = ''; document.getElementById('mod_startTime').value = '';
        document.getElementById('mod_endTime').value = ''; document.getElementById('mod_notes').value = '';
        
        renderSessions();
        if (sessionModal) sessionModal.hide();
    });

    document.getElementById('btn_generateBatch').addEventListener('click', async () => {
        const start = document.getElementById('bg_start').value;
        const end = document.getElementById('bg_end').value;
        const sTime = document.getElementById('bg_start_time').value;
        const eTime = document.getElementById('bg_end_time').value;
        const defaultTeacherId = document.getElementById('bg_teacherId').value;
        const defaultTeacherName = document.getElementById('bg_teacherName').value;
        const exceptionsRaw = document.getElementById('bg_exceptions').value;
        const defaultRoom = document.getElementById('bg_room').value;

        const exceptions = new Set(exceptionsRaw.split(',').map(s => s.trim()).filter(Boolean));

        // Optional: skip holidays/off days (Holiday module)
        const skipHolidays = document.getElementById('bg_skipHolidays')?.checked;
        if (skipHolidays) {
            try {
                const holidayHint = document.getElementById('bg_holidayHint');
                if (holidayHint) { holidayHint.style.display = 'none'; holidayHint.textContent = ''; }

                const resp = await fetch(`/school/holidays/api/range?start=${encodeURIComponent(start)}&end=${encodeURIComponent(end)}`, {
                    headers: { 'X-AJAX-Request': 'true' }
                });
                const txt = await resp.text();
                let data;
                try { data = JSON.parse(txt); } catch { data = { status: 'error', message: 'Non-JSON response from holiday API.' }; }

                if (!resp.ok || data.status !== 'success') {
                    await uiAlert(data.message || 'Unable to load holidays. Generation will continue without skipping holidays.', 'Holiday lookup failed');
                } else {
                    const holidays = Array.isArray(data.holidays) ? data.holidays : [];
                    for (const h of holidays) {
                        if (h && h.date) exceptions.add(h.date);
                    }
                    if (holidayHint) {
                        holidayHint.style.display = 'block';
                        holidayHint.textContent = `Holidays in range: ${holidays.length}`;
                    }
                }
            } catch (e) {
                await uiAlert((e && e.message) ? e.message : 'Unable to load holidays. Generation will continue without skipping holidays.', 'Holiday lookup failed');
            }
        }
        const selectedDays = Array.from(document.querySelectorAll('.bg-day-cb:checked')).map(cb => parseInt(cb.value));

        if (!start || !end || selectedDays.length === 0 || !sTime || !eTime) { await uiAlert('Please fill out all batch generator fields.', 'Missing fields'); return; }
        if (isRollingMode()) {
            const bounds = getRollingCycleBounds();
            if (bounds?.error) {
                await uiAlert(bounds.error, 'Batch Session Generator');
                return;
            }
            if (start < bounds.startToken || (bounds.endToken && end > bounds.endToken)) {
                await uiAlert(
                    `Batch date range must stay within cycle dates (${bounds.startToken}${bounds.endToken ? ` to ${bounds.endToken}` : ''}).`,
                    'Batch Session Generator'
                );
                return;
            }
        }

        const hrs = getDuration(sTime, eTime);
        
        // FIX: Create date using local timezone to prevent UTC day-shifting bugs!
        const [startYear, startMonth, startDay] = start.split('-').map(Number);
        let current = new Date(startYear, startMonth - 1, startDay);
        
        const [endYear, endMonth, endDay] = end.split('-').map(Number);
        const endDateObj = new Date(endYear, endMonth - 1, endDay);

        while (current <= endDateObj) {
            // Format strictly as YYYY-MM-DD
            const y = current.getFullYear();
            const m = String(current.getMonth() + 1).padStart(2, '0');
            const d = String(current.getDate()).padStart(2, '0');
            const dateString = `${y}-${m}-${d}`;
            
            if (selectedDays.includes(current.getDay()) && !exceptions.has(dateString)) {
                sessionsState.push({
                    sessionId: "SES_" + Date.now() + Math.random().toString().slice(2, 6),
                    date: dateString, originalDate: dateString, startTime: sTime, endTime: eTime, durationHours: hrs,
                    room: defaultRoom, // <--- NEW FIELD
                    status: normalizeStatusCode(defaultSessionStatusCode) || 'scheduled', notes: "", locked: false,
                    delivery: { deliveredBy: defaultTeacherId, deliveredByName: defaultTeacherName, substitute: false }, roster: [],
                    _isSaved: false 
                });
            }
            current.setDate(current.getDate() + 1);
        }
        renderSessions();
    });


// Bulk Teacher Assignment (in-place update)
const bulkBtn = document.getElementById('btn_bulkTeacherRename');
const bulkModalEl = document.getElementById('bulkTeacherModal');
const bulkOldSel = document.getElementById('bulk_oldTeacher');
const bulkNewTeacherName = document.getElementById('bulk_newTeacherName');
const bulkNewTeacherId = document.getElementById('bulk_newTeacherId');
const bulkPickNewTeacherBtn = document.getElementById('bulk_pickNewTeacher');
const bulkClearNewTeacherBtn = document.getElementById('bulk_clearNewTeacher');
const bulkStatusSel = document.getElementById('bulk_targetStatus');
const bulkIncludeLockedCb = document.getElementById('bulk_includeLocked');
const bulkAddNewInstructorCb = document.getElementById('bulk_addNewInstructor');
const bulkInactivateOldInstructorCb = document.getElementById('bulk_inactivateOldInstructor');
const bulkPreview = document.getElementById('bulk_preview');
const bulkApplyBtn = document.getElementById('bulk_applyBtn');

function getTeacherOptionsFromSessions() {
    const map = new Map(); // key -> {id,name}
    (sessionsState || []).forEach(s => {
        const id = s?.delivery?.deliveredBy || '';
        const name = s?.delivery?.deliveredByName || id || '';
        const key = (id || name || '').trim();
        if (!key) return;
        if (!map.has(key)) map.set(key, { id, name: name || id });
    });
    return Array.from(map.values()).sort((a, b) => (a.name || '').localeCompare(b.name || ''));
}

function fillSelect(sel, options, placeholder) {
    if (!sel) return;
    sel.innerHTML = '';
    const opt0 = document.createElement('option');
    opt0.value = '';
    opt0.textContent = placeholder;
    sel.appendChild(opt0);
    options.forEach(o => {
        const opt = document.createElement('option');
        opt.value = o.id || o.name || '';
        opt.textContent = o.name || o.id;
        opt.dataset.teacherId = o.id || '';
        opt.dataset.teacherName = o.name || '';
        sel.appendChild(opt);
    });
}

function statusMatches(s, target) {
    if (target === 'all') return true;
    return resolveSessionStatusCode(s) === target;
}

function isLocked(s) { return !!s?.locked; }

function getBulkTargetStatus() {
    const raw = String(bulkStatusSel?.value || '').trim();
    if (raw === 'all') return 'all';
    return normalizeStatusCode(raw || defaultSessionStatusCode) || normalizeStatusCode(defaultSessionStatusCode) || 'scheduled';
}

function getBulkAffectedSessions() {
    const oldVal = bulkOldSel?.value || '';
    const target = getBulkTargetStatus();
    const includeLocked = !!bulkIncludeLockedCb?.checked;
    return (sessionsState || []).filter(s => {
        const curId = s?.delivery?.deliveredBy || '';
        const curName = s?.delivery?.deliveredByName || '';
        const match = (curId && curId === oldVal) || (curName === oldVal) || (!curId && curName && curName === oldVal);
        if (!match) return false;
        if (!statusMatches(s, target)) return false;
        if (!includeLocked && isLocked(s)) return false;
        return true;
    });
}

function computeBulkPreview() {
    if (!bulkPreview) return;
    const oldVal = bulkOldSel?.value || '';
    const newVal = (bulkNewTeacherId?.value || bulkNewTeacherName?.value || '').trim();

    if (!oldVal || !newVal) {
        bulkPreview.textContent = 'Select current teacher and new teacher to preview changes.';
        return;
    }

    const affected = getBulkAffectedSessions();

    bulkPreview.innerHTML = `
      <div class="fw-bold">Preview</div>
      <div>Affected sessions: <span class="fw-bold text-primary">${affected.length}</span></div>
      <div>Roster sync: ${bulkAddNewInstructorCb?.checked ? 'new teacher will be added' : 'new teacher will not be added'}; ${bulkInactivateOldInstructorCb?.checked ? 'old teacher can be marked inactive' : 'old teacher stays unchanged'}.</div>
      <div class="text-muted">Changes are in-memory until you click <span class="fw-bold">Save Class & Ledger</span>.</div>
    `;
}

function parseInstructorRowsFromHidden() {
    try {
        const parsed = JSON.parse(document.getElementById('hid_instructors')?.value || '[]');
        return Array.isArray(parsed) ? parsed.filter(Boolean).map((row) => ({ ...row })) : [];
    } catch (e) {
        return [];
    }
}

function writeInstructorRowsToHidden(rows = []) {
    const cleaned = [];
    const seen = new Set();
    (Array.isArray(rows) ? rows : []).forEach((row) => {
        const personId = String(row?.personId || '').trim();
        if (!personId || seen.has(personId)) return;
        seen.add(personId);
        cleaned.push({
            personId,
            name: String(row?.name || personId).trim(),
            role: String(row?.role || 'Instructor').trim(),
            status: String(row?.status || 'active').trim() || 'active',
            assignedAt: row?.assignedAt || null,
            unassignedAt: row?.unassignedAt || null
        });
    });
    const hidden = document.getElementById('hid_instructors');
    if (hidden) hidden.value = JSON.stringify(cleaned);
    return cleaned;
}

function getInstructorRowsForSubmit() {
    const rows = parseInstructorRowsFromHidden();
    const instId = String(document.getElementById('inp_instructorId')?.value || '').trim();
    const instName = String(document.getElementById('inp_instructorName')?.value || '').trim();
    const instRole = String(document.getElementById('inp_instructorRole')?.value || 'Primary').trim();
    if (instId && !rows.some((row) => String(row?.personId || '').trim() === instId)) {
        rows.push({ personId: instId, name: instName || instId, role: instRole || 'Primary', status: 'active' });
    }
    return writeInstructorRowsToHidden(rows);
}

function syncInstructorRosterAfterBulkTeacherChange({ oldTeacherId = '', oldTeacherName = '', newTeacherId = '', newTeacherName = '', changedSessions = [] } = {}) {
    const now = new Date().toISOString();
    const oldId = String(oldTeacherId || '').trim();
    const newId = String(newTeacherId || '').trim();
    let rows = parseInstructorRowsFromHidden();

    if (bulkAddNewInstructorCb?.checked && newId && !rows.some((row) => String(row?.personId || '').trim() === newId)) {
        rows.push({
            personId: newId,
            name: String(newTeacherName || newId).trim(),
            role: 'Instructor',
            status: 'active',
            assignedAt: now,
            unassignedAt: null
        });
    }

    if (bulkInactivateOldInstructorCb?.checked && oldId) {
        const oldStillHasSessions = (sessionsState || []).some((session) => String(session?.delivery?.deliveredBy || '').trim() === oldId);
        if (!oldStillHasSessions) {
            rows = rows.map((row) => {
                if (String(row?.personId || '').trim() !== oldId) return row;
                return {
                    ...row,
                    name: String(row?.name || oldTeacherName || oldId).trim(),
                    status: 'inactive',
                    unassignedAt: row?.unassignedAt || now
                };
            });
        }
    }

    writeInstructorRowsToHidden(rows);

    const primaryId = document.getElementById('inp_instructorId');
    const primaryName = document.getElementById('inp_instructorName');
    const primaryRole = document.getElementById('inp_instructorRole');
    if (primaryId && oldId && primaryId.value === oldId && newId) {
        primaryId.value = newId;
        if (primaryName) primaryName.value = String(newTeacherName || newId).trim();
        if (primaryRole && !String(primaryRole.value || '').trim()) primaryRole.value = 'Primary';
    }
}

function renderImpactSummaryHtml(impact = {}) {
    const summaries = impact?.summaries || {};
    const rows = [
        ['Timesheets', summaries.timesheets],
        ['Report Assignments', summaries.reportAssignments],
        ['Report Instances', summaries.reportInstances],
        ['Student Cases', summaries.sessionCases],
        ['Tasks', summaries.tasks],
        ['Attendance / Gradebook', summaries.attendanceGradebook],
        ['New Teacher Approved Leave', summaries.newTeacherLeaveConflicts]
    ];
    const sessionRows = (impact?.affectedSessions || []).slice(0, 10).map((session) => (
        `<li>${session.date || 'No date'} ${session.startTime || ''}-${session.endTime || ''} | ${session.status || 'status'}${session.locked ? ' | locked' : ''}</li>`
    )).join('');
    const usageRows = rows.map(([label, summary]) => {
        const count = Number(summary?.count || 0);
        const samples = (summary?.samples || []).slice(0, 3).map((sample) => `<div class="text-muted">${sample.id || ''} ${sample.title || ''}</div>`).join('');
        return `<tr><td class="fw-semibold">${label}</td><td>${count}</td><td>${samples || '<span class="text-muted">None found</span>'}</td></tr>`;
    }).join('');
    return `
        <div class="text-start">
          <p class="mb-2">Review these affected sessions and downstream references before applying the teacher change.</p>
          <div class="mb-2"><strong>Affected sessions:</strong> ${Number(impact?.affectedSessions?.length || 0)}</div>
          <ul class="small mb-3">${sessionRows || '<li>No matching saved sessions found.</li>'}</ul>
          <div class="table-responsive">
            <table class="table table-sm align-middle">
              <thead><tr><th>Area</th><th>Count</th><th>Examples</th></tr></thead>
              <tbody>${usageRows}</tbody>
            </table>
          </div>
          <p class="small text-muted mb-0">If you continue, changes remain in-memory until you click Save Class & Ledger.</p>
        </div>
    `;
}

async function fetchBulkTeacherImpactPreview() {
    if (!classId) return null;
    const oldOption = bulkOldSel?.selectedOptions?.[0] || null;
    const oldTeacherId = String(oldOption?.dataset?.teacherId || bulkOldSel?.value || '').trim();
    const oldTeacherName = String(oldOption?.dataset?.teacherName || bulkOldSel?.value || '').trim();
    const affected = getBulkAffectedSessions();
    const params = new URLSearchParams();
    params.append('oldTeacher', bulkOldSel?.value || '');
    params.append('oldTeacherId', oldTeacherId);
    params.append('oldTeacherName', oldTeacherName);
    params.append('newTeacherId', String(bulkNewTeacherId?.value || '').trim());
    params.append('newTeacherName', String(bulkNewTeacherName?.value || '').trim());
    params.append('targetStatus', getBulkTargetStatus());
    params.append('includeLocked', bulkIncludeLockedCb?.checked ? 'true' : 'false');
    params.append('sessionIds', JSON.stringify(affected.map((session) => session?.sessionId || session?.id).filter(Boolean)));
    const response = await fetch(`/school/classes/api/${encodeURIComponent(classId)}/teacher-assignment-impact`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-AJAX-Request': 'true' },
        body: params.toString()
    });
    const result = await response.json().catch(() => null);
    if (!response.ok || !result || result.status !== 'success') {
        throw new Error(result?.message || 'Could not preview teacher assignment impact.');
    }
    return result.impact || null;
}

async function confirmBulkTeacherImpact(impact) {
    const html = renderImpactSummaryHtml(impact || {});
    if (typeof showMessageModal === 'function') {
        const result = await showMessageModal({
            title: 'Teacher Assignment Impact',
            icon: 'warning',
            message: html,
            buttons: [
                { text: 'Cancel', class: 'btn-light border', value: false },
                { text: 'Apply In Form', class: 'btn-warning', value: true }
            ]
        });
        return result === true || result?.value === true || result === 'true' || result === 'Apply In Form';
    }
    return uiConfirm('Teacher assignment has downstream references. Continue applying the change in this form?', 'Teacher Assignment Impact');
}

async function openBulkTeacherModal() {
    if (!bulkModalEl) {
        await uiAlert('Bulk edit modal is not available on this page.', 'Not available');
        return;
    }

    const opts = getTeacherOptionsFromSessions();
    if (opts.length === 0) {
        await uiAlert('No teacher assignments found in sessions yet.', 'Nothing to edit');
        return;
    }

    fillSelect(bulkOldSel, opts, 'Current teacher…');
    if (bulkNewTeacherId) bulkNewTeacherId.value = '';
if (bulkNewTeacherName) bulkNewTeacherName.value = '';

    if (bulkStatusSel && !bulkStatusSel.value) bulkStatusSel.value = normalizeStatusCode(defaultSessionStatusCode) || 'scheduled';
    if (bulkIncludeLockedCb) bulkIncludeLockedCb.checked = false;

    computeBulkPreview();

    // Wire picker for new teacher
    if (bulkPickNewTeacherBtn) {
        bulkPickNewTeacherBtn.onclick = () => {
            try {
                GenericPicker.open(GenericPickerPresets.teacher({
                    title: 'Select New Teacher',
                    icon: 'bi-person',
                    placeholder: 'Search Teachers...',
                    renderer: teacherPickerRenderer,
                    onSelect: (item) => {
                        const teacher = resolveTeacherPickerSelection(item);
                        if (bulkNewTeacherId) bulkNewTeacherId.value = teacher.personId;
                        if (bulkNewTeacherName) bulkNewTeacherName.value = teacher.displayName || teacher.personId || '';
                        computeBulkPreview();
                    }
                }));
            } catch (e) {
                uiAlert('Teacher picker is not available on this page.', 'Picker error');
            }
        };
    }
    if (bulkClearNewTeacherBtn) {
        bulkClearNewTeacherBtn.onclick = () => {
            if (bulkNewTeacherId) bulkNewTeacherId.value = '';
            if (bulkNewTeacherName) bulkNewTeacherName.value = '';
            computeBulkPreview();
        };
    }

    try {
        const modal = bootstrap?.Modal?.getOrCreateInstance(bulkModalEl);
        modal?.show();
    } catch (e) {
        await uiAlert('Bootstrap modal is not available. Please ensure Bootstrap JS is loaded.', 'Modal error');
    }
}

async function applyBulkTeacherChange() {
    const oldVal = bulkOldSel?.value || '';
    const newVal = (bulkNewTeacherId?.value || bulkNewTeacherName?.value || '').trim();
    const target = getBulkTargetStatus();
    const includeLocked = !!bulkIncludeLockedCb?.checked;

    if (!oldVal || !newVal) { await uiAlert('Please select both current and new teacher.', 'Missing fields'); return; }

    const newTeacherId = (bulkNewTeacherId?.value || '').trim();
    const newTeacherName = (bulkNewTeacherName?.value || newTeacherId || '').trim();
    const oldOption = bulkOldSel?.selectedOptions?.[0] || null;
    const oldTeacherId = String(oldOption?.dataset?.teacherId || oldVal || '').trim();
    const oldTeacherName = String(oldOption?.dataset?.teacherName || oldVal || '').trim();
    const isLabelRefreshOnly = Boolean(oldTeacherId && newTeacherId && oldTeacherId === newTeacherId && oldTeacherName !== newTeacherName);
    if (oldVal === newVal && !isLabelRefreshOnly) {
        await uiAlert('Current teacher and new teacher are the same.', 'No change');
        return;
    }
    let impact = null;
    if (!isLabelRefreshOnly) {
        try {
            impact = await fetchBulkTeacherImpactPreview();
        } catch (error) {
            await uiAlert(error.message || 'Could not preview teacher assignment impact.', 'Preview Failed');
            return;
        }
        if (impact) {
            const confirmed = await confirmBulkTeacherImpact(impact);
            if (!confirmed) return;
        }
    }

    let changed = 0;
    const changedSessions = [];
    (sessionsState || []).forEach(s => {
        const curId = s?.delivery?.deliveredBy || '';
        const curName = s?.delivery?.deliveredByName || '';
        const match = (curId && curId === oldVal) || (curName === oldVal) || (!curId && curName && curName === oldVal);
        if (!match) return;
        if (!statusMatches(s, target)) return;
        if (!includeLocked && isLocked(s)) return;

        if (!s.delivery) s.delivery = {};
        s.delivery.deliveredBy = newTeacherId;
        s.delivery.deliveredByName = newTeacherName;
        s.conflictMsg = null;
        s._isSaved = false;
        changedSessions.push(s);
        changed++;
    });

    syncInstructorRosterAfterBulkTeacherChange({
        oldTeacherId,
        oldTeacherName,
        newTeacherId,
        newTeacherName,
        changedSessions
    });
    renderSessions();
    computeBulkPreview();

    await uiAlert(`Updated teacher assignment on ${changed} session(s). Remember to click "Save Class & Ledger" to persist.`, 'Teacher assignments updated');

    try {
        const modal = bootstrap?.Modal?.getOrCreateInstance(bulkModalEl);
        modal?.hide();
    } catch {}
}

if (bulkBtn) bulkBtn.addEventListener('click', openBulkTeacherModal);
if (bulkOldSel) bulkOldSel.addEventListener('change', computeBulkPreview);
if (bulkNewTeacherName) bulkNewTeacherName.addEventListener('change', computeBulkPreview);
if (bulkStatusSel) bulkStatusSel.addEventListener('change', computeBulkPreview);
if (bulkIncludeLockedCb) bulkIncludeLockedCb.addEventListener('change', computeBulkPreview);
if (bulkAddNewInstructorCb) bulkAddNewInstructorCb.addEventListener('change', computeBulkPreview);
if (bulkInactivateOldInstructorCb) bulkInactivateOldInstructorCb.addEventListener('change', computeBulkPreview);
if (bulkApplyBtn) bulkApplyBtn.addEventListener('click', applyBulkTeacherChange);

    // Initial Render
    renderSessions();
});
</script>
