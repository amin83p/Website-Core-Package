    const addDaysYmd = (value, days) => {
        const parsed = parseYmd(value);
        if (!parsed) return '';
        parsed.setUTCDate(parsed.getUTCDate() + Number(days || 0));
        return parsed.toISOString().slice(0, 10);
    };
    const buildSessionRowAppearance = (statusCode, options = {}) => {
