                        <select class="form-select form-select-sm border-0 bg-transparent session-input ${isCancelled ? 'fw-bold text-danger' : ''}" data-index="${index}" data-field="status" ${lockedAttr}>${buildStatusOptionsHtml(statusCode)}</select>
                        ${isLocked ? '<span class="badge bg-dark-subtle text-dark border"><i class="bi bi-lock-fill"></i></span>' : ''}
                    </div>
