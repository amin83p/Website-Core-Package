    function normalizeCopiedSessions(sessionRows) {
        const rows = Array.isArray(sessionRows) ? sessionRows : [];
        return rows.map((session, index) => ({
            sessionId: String(session?.sessionId || `SES_${Date.now()}_${index}_${Math.floor(Math.random() * 1000)}`),
            date: String(session?.date || '').trim(),
            originalDate: String(session?.originalDate || session?.date || '').trim(),
            startTime: String(session?.startTime || '').trim(),
            endTime: String(session?.endTime || '').trim(),
            durationHours: Number(session?.durationHours || 0),
            room: String(session?.room || '').trim(),
            status: normalizeStatusCode(session?.status || defaultSessionStatusCode) || normalizeStatusCode(defaultSessionStatusCode) || 'scheduled',
            notes: String(session?.notes || '').trim(),
            locked: false,
            delivery: {
                deliveredBy: String(session?.delivery?.deliveredBy || '').trim(),
                deliveredByName: String(session?.delivery?.deliveredByName || session?.delivery?.deliveredBy || '').trim(),
                substitute: false
            },
            roster: [],
            _isSaved: false
        }));
    }

    function applyClassTemplate(template) {
        const source = template && typeof template === 'object' ? template : {};

        document.querySelector('input[name="title"]').value = String(source?.title || '').trim();

        const status = String(source?.status || '').trim().toLowerCase();
        const statusSelect = document.querySelector('select[name="status"]');
        if (statusSelect && status) {
            const hasOption = Array.from(statusSelect.options || []).some((opt) => String(opt.value || '').trim().toLowerCase() === status);
            if (hasOption) statusSelect.value = status;
        }

        const deliveryDepartmentId = String(source?.deliveryDepartmentId || '').trim();
        const deliveryDepartmentName = String(source?.deliveryDepartmentName || '').trim();
        document.getElementById('inp_deliveryDepartmentId').value = deliveryDepartmentId;
        document.getElementById('inp_deliveryDepartmentName').value = deliveryDepartmentName;

        const maxCapacity = Number(source?.enrollment?.maxCapacity || source?.maxCapacity || 30);
        document.getElementById('inp_capacity').value = Number.isFinite(maxCapacity) && maxCapacity > 0 ? Math.round(maxCapacity) : 30;

        curriculumState = Array.isArray(source?.curriculum?.subjects)
            ? source.curriculum.subjects.map((subject) => ({
                subjectId: String(subject?.subjectId || '').trim(),
                code: String(subject?.code || subject?.subjectId || '').trim(),
                name: String(subject?.name || '').trim(),
                allocatedHours: Number(subject?.allocatedHours || 0),
                weight: roundWeight(subject?.weight)
            })).filter((subject) => subject.subjectId)
            : [];
        normalizeCurriculumState({ rebalanceIfMissing: false });

        const totalHours = Number(source?.curriculum?.totalHours || 0);
        document.getElementById('inp_totalHours').value = Number.isFinite(totalHours) ? totalHours : 0;
        document.getElementById('lbl_targetHours').innerText = document.getElementById('inp_totalHours').value || 0;

        const copiedCredits = Number(source?.credits || 0);
        if (Number.isFinite(copiedCredits) && copiedCredits > 0) {
            classCreditsTouched = true;
            if (creditsInput) {
                creditsInput.value = roundWeight(copiedCredits).toFixed(2).replace(/\.00$/, '');
            }
        } else {
            classCreditsTouched = false;
        }
        syncClassCreditsField({ force: !classCreditsTouched });

        pricingState = source?.pricing && typeof source.pricing === 'object'
            ? source.pricing
            : { mode: 'auto', feeRules: [] };
        billingModeState = normalizeBillingMode(source?.billingMode || 'chargeable');
        postingTemplateState = billingModeState === 'no_charge'
            ? []
            : (Array.isArray(source?.postingTemplates) ? source.postingTemplates : []);

        allowedProgramTermsState = Array.isArray(source?.allowedProgramTerms)
            ? source.allowedProgramTerms.map((row, index) => ({
                programId: String(row?.programId || '').trim(),
                termId: String(row?.termId || '').trim(),
                order: Number(row?.order || (index + 1)),
                programCode: String(row?.programCode || '').trim().toUpperCase(),
                programName: String(row?.programName || '').trim(),
                termCode: String(row?.termCode || '').trim().toUpperCase(),
                termName: String(row?.termName || '').trim(),
                startDate: String(row?.startDate || '').trim(),
                endDate: String(row?.endDate || '').trim(),
                classesStartDate: String(row?.classesStartDate || '').trim(),
                classesEndDate: String(row?.classesEndDate || '').trim(),
                notes: String(row?.notes || '').trim()
            })).filter((row) => row.programId && (isRollingMode() || row.termId))
            : [];

        const copiedInstructors = Array.isArray(source?.instructors) ? source.instructors : [];
        const primaryInstructor = copiedInstructors.find((inst) => String(inst?.status || '').trim().toLowerCase() === 'active') || copiedInstructors[0] || null;
        if (primaryInstructor) {
            const teacherId = String(primaryInstructor?.personId || '').trim();
            const teacherName = String(primaryInstructor?.name || teacherId).trim();
            document.getElementById('inp_instructorId').value = teacherId;
            document.getElementById('inp_instructorName').value = teacherName;
            document.getElementById('inp_instructorRole').value = String(primaryInstructor?.role || 'Primary').trim();
            document.getElementById('bg_teacherId').value = teacherId;
