              <input class="form-check-input" type="checkbox" role="switch" id="bulk_addNewInstructor" checked>
              <label class="form-check-label small" for="bulk_addNewInstructor">Add new teacher to class instructor roster</label>
            </div>
          </div>
          <div class="col-md-6">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" role="switch" id="bulk_inactivateOldInstructor" checked>
              <label class="form-check-label small" for="bulk_inactivateOldInstructor">Mark old teacher inactive when no sessions remain</label>
            </div>
          </div>
        </div>

        <div class="mt-3 small text-muted" id="bulk_preview"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Close</button>
        <button type="button" class="btn btn-primary" id="bulk_applyBtn">
          <i class="bi bi-check2-circle me-1"></i> Apply Changes
        </button>
      </div>
    </div>
  </div>
</div>


<script>
document.addEventListener('DOMContentLoaded', () => {
    // UI helpers (prefer message modal if available)
    async function uiAlert(message, title = 'Notice') {
        if (typeof showMessageModal === 'function') {
            await showMessageModal({
                title,
                icon: 'info',
                message,
                buttons: [{ text: 'OK', class: 'btn-primary' }]
            });
            return;
        }
        alert(message);
    }

    async function uiConfirm(message, title = 'Confirm') {
        if (typeof showMessageModal === 'function') {
            const result = await showMessageModal({
                title,
                icon: 'warning',
                message,
                buttons: [
                    { text: 'No', class: 'btn-secondary', value: false },
                    { text: 'Yes', class: 'btn-primary', value: true }
                ]
            });
            return result === true || result === 'Yes' || (result && result.value === true);
        }
        return confirm(message);
    }
    // State
    let curriculumState = JSON.parse(document.getElementById('hid_curriculum').value).subjects || [];
    let billingModeState = String(document.getElementById('hid_billingMode')?.value || 'chargeable').trim().toLowerCase() === 'no_charge' ? 'no_charge' : 'chargeable';
    let pricingState = JSON.parse(document.getElementById('hid_pricing').value || '{"mode":"auto","feeRules":[]}') || { mode: 'auto', feeRules: [] };
    let postingTemplateState = JSON.parse(document.getElementById('hid_postingTemplates').value || '[]') || [];
    let allowedProgramTermsState = JSON.parse(document.getElementById('hid_allowedProgramTerms').value || '[]') || [];
    let sessionsState = JSON.parse(document.getElementById('hid_sessions').value) || [];
    let pendingEligibilityProgram = null;
    
    // FIX 1: Mark all initially loaded sessions as saved from the DB, so they are always clickable
    sessionsState.forEach(s => s._isSaved = true);

    const dInst = JSON.parse(document.getElementById('hid_instructors').value);
    const dEnrl = JSON.parse(document.getElementById('hid_enrollment').value);
    const dEval = JSON.parse(document.getElementById('hid_evaluation').value);
    const classId = '<%= c.id || "" %>';
    const registrationModeInput = document.getElementById('inp_registrationMode');
    const cycleGroupIdInput = document.getElementById('inp_cycleGroupId');
    const cycleStartDateInput = document.getElementById('inp_cycleStartDate');
    const cycleEndDateInput = document.getElementById('inp_cycleEndDate');
    const cycleNoInput = document.getElementById('inp_cycleNo');
    const isClosedEnrollmentInput = document.getElementById('inp_isClosedForNewEnrollment');
    const rollingSessionWindowHint = document.getElementById('rollingSessionWindowHint');
    const rollingSessionDateInputs = ['bg_start', 'bg_end', 'mod_date']
        .map((id) => document.getElementById(id))
        .filter(Boolean);
    const rollingFieldsWrap = document.getElementById('rollingLifecycleFields');
    const termLifecycleHint = document.getElementById('termLifecycleHint');
    const lifecycleModeBadge = document.getElementById('lifecycle_modeBadge');
    const rollingIntegritySummary = document.getElementById('rollingIntegritySummary');
    const btnCheckRollingIntegrity = document.getElementById('btn_checkRollingIntegrity');
    const previousClassIdInput = document.getElementById('inp_previousClassId');
    const nextClassIdInput = document.getElementById('inp_nextClassId');
    const cycleActionSummary = document.getElementById('rollingCycleActionSummary');
    const cycleActionCloseEndDateInput = document.getElementById('cycleAction_closeEndDate');
    const cycleActionCloseBlockEnrollmentInput = document.getElementById('cycleAction_closeBlockEnrollment');
    const cycleActionNextStartDateInput = document.getElementById('cycleAction_nextStartDate');
    const cycleActionNextEndDateInput = document.getElementById('cycleAction_nextEndDate');
    const cycleActionCloseCurrentOnCreateInput = document.getElementById('cycleAction_closeCurrentOnCreate');
    const cycleActionAutoCarryForwardInput = document.getElementById('cycleAction_autoCarryForward');
    const cycleActionTargetClassIdInput = document.getElementById('cycleAction_targetClassId');
    const cycleActionBoundaryDateInput = document.getElementById('cycleAction_boundaryDate');
    const btnCycleClose = document.getElementById('btn_cycleClose');
    const btnCycleCreateNext = document.getElementById('btn_cycleCreateNext');
    const btnCycleCarryForward = document.getElementById('btn_cycleCarryForward');
