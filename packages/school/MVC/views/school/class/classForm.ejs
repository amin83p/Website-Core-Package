    function getDuration(sTime, eTime) {
        if (!sTime || !eTime) return 0;
        const [sh, sm] = sTime.split(':').map(Number);
        const [eh, em] = eTime.split(':').map(Number);
        const duration = (eh + em/60) - (sh + sm/60);
        return duration > 0 ? duration : 0;
    }

    const resolveUserName = (item) => {
        if (item.identity && item.identity.displayName) return item.identity.displayName;
        if (item.name && typeof item.name === 'object') return `${item.name.first || ''} ${item.name.last || ''}`.trim();
        if (item.name && typeof item.name === 'string') return item.name;
        return item.username || item.email || item.id;
    };

    function roundWeight(value) {
        const num = Number(value);
        if (!Number.isFinite(num)) return 0;
        return Number(num.toFixed(2));
    }

    function buildEvenWeights(items) {
        if (!Array.isArray(items) || !items.length) return [];
        const evenWeight = Number((100 / items.length).toFixed(2));
        return items.map((item, index) => ({
            ...item,
            weight: index === items.length - 1
                ? Number((100 - evenWeight * (items.length - 1)).toFixed(2))
                : evenWeight
        }));
    }

    function normalizeCurriculumState({ rebalanceIfMissing = true } = {}) {
        curriculumState = (Array.isArray(curriculumState) ? curriculumState : []).map((item) => ({
            subjectId: String(item?.subjectId || '').trim(),
            code: String(item?.code || item?.subjectId || '').trim(),
            name: String(item?.name || '').trim(),
            allocatedHours: Number(item?.allocatedHours || 0),
            weight: roundWeight(item?.weight)
        })).filter((item) => item.subjectId);

        const currentTotal = curriculumState.reduce((sum, item) => sum + Number(item.weight || 0), 0);
        if (rebalanceIfMissing && curriculumState.length && currentTotal <= 0) {
            curriculumState = buildEvenWeights(curriculumState);
        }
    }

    function getCurriculumWeightTotal() {
        return roundWeight(curriculumState.reduce((sum, item) => sum + Number(item.weight || 0), 0));
    }

    function calculateSuggestedClassCredits() {
        return roundWeight(curriculumState.reduce((sum, item) => {
            const subject = subjectFeeCatalog.get(String(item?.subjectId || ''));
            return sum + Number(subject?.credits || 0);
        }, 0));
    }

    function syncClassCreditsField({ force = false } = {}) {
        if (!creditsInput) return;
        const suggestedCredits = calculateSuggestedClassCredits();
        if (force || !classCreditsTouched) {
            creditsInput.value = suggestedCredits.toFixed(2).replace(/\.00$/, '');
        }
        const activeValue = Number(creditsInput.value || 0);
        const hint = document.getElementById('classCreditsHint');
        if (hint) {
            const baseMessage = `Suggested from subjects: ${suggestedCredits.toFixed(2).replace(/\.00$/, '')} credits.`;
            hint.textContent = classCreditsTouched && Math.abs(activeValue - suggestedCredits) > 0.01
                ? `${baseMessage} Current class credit is overridden.`
                : `${baseMessage} You can edit it.`;
        }
    }

    function renderCurriculumWeightSummary() {
        const summary = document.getElementById('subjectWeightSummary');
        const total = getCurriculumWeightTotal();
        if (!curriculumState.length) {
            summary.innerHTML = '<span class="text-muted">No subjects added yet.</span>';
            return;
        }
        const ok = Math.abs(total - 100) <= 0.01;
        summary.innerHTML = '<span class="badge ' + (ok ? 'bg-success' : 'bg-danger') + '">Total Fee Weight: ' + total.toFixed(2) + '%</span>' +
            '<span class="ms-2 ' + (ok ? 'text-success' : 'text-danger') + '">' + (ok ? 'Ready for pricing.' : 'Total must equal 100%.') + '</span>';
    }

    function labelFeeCategory(value) {
        return String(value || '').trim() === allFeeCategoryKey ? allFeeCategoryLabel : String(value || '').trim();
    }

    function getProposalRuleCandidates(subject, feeCategory) {
        const rules = Array.isArray(subject?.feeRules) ? subject.feeRules : [];
        const currentDate = new Date().toISOString().slice(0, 10);
        const isActiveRule = (rule) => rule && rule.active !== false && String(rule.active) !== 'false';
        const isEffectiveRule = (rule) => {
            if (!isActiveRule(rule)) return false;
            const validFrom = String(rule.validFrom || '').trim();
            const validTo = String(rule.validTo || '').trim();
            if (validFrom && currentDate < validFrom) return false;
            if (validTo && currentDate > validTo) return false;
            return true;
        };
        const sortRules = (rows) => rows.sort((a, b) => String(b.validFrom || '').localeCompare(String(a.validFrom || '')));
        const normalizedCategory = String(feeCategory || '').trim();

        const specificEffective = sortRules(rules.filter((rule) => isEffectiveRule(rule) && String(rule.feeCategory || '').trim() === normalizedCategory));
        if (specificEffective[0]) return specificEffective[0];
        const fallbackEffective = sortRules(rules.filter((rule) => isEffectiveRule(rule) && String(rule.feeCategory || '').trim() === allFeeCategoryKey));
        if (fallbackEffective[0]) return fallbackEffective[0];
        const specificActive = sortRules(rules.filter((rule) => isActiveRule(rule) && String(rule.feeCategory || '').trim() === normalizedCategory));
        if (specificActive[0]) return specificActive[0];
        const fallbackActive = sortRules(rules.filter((rule) => isActiveRule(rule) && String(rule.feeCategory || '').trim() === allFeeCategoryKey));
        return fallbackActive[0] || null;
    }

    function buildClassPricingProposalForCategory(feeCategory) {
        const breakdown = [];
        const warnings = [];
        let currency = 'CAD';
        let suggestedAmount = 0;

        curriculumState.forEach((subjectRef) => {
            const subjectId = String(subjectRef?.subjectId || '').trim();
            if (!subjectId) return;
            const subject = subjectFeeCatalog.get(subjectId);
            if (!subject) {
                warnings.push(`Subject ${subjectId} was not found for pricing.`);
                return;
            }
            const matchedRule = getProposalRuleCandidates(subject, feeCategory);
            if (!matchedRule) {
                warnings.push(`No fee rule for ${subject.title || subjectId}.`);
                return;
            }

            const lineCurrency = String(matchedRule.currency || currency || 'CAD').trim().toUpperCase() || 'CAD';
            if (breakdown.length === 0) currency = lineCurrency;
            if (lineCurrency !== currency) {
                warnings.push(`Skipped ${subject.title || subjectId} because currency ${lineCurrency} does not match ${currency}.`);
                return;
            }

            const weight = roundWeight(subjectRef?.weight);
            const baseAmount = roundWeight(matchedRule.amount);
            const amount = roundWeight(baseAmount * (weight / 100));
            suggestedAmount += amount;
            breakdown.push({
                subjectId,
                subjectCode: subject.code || subjectRef.code || subjectId,
                subjectTitle: subject.title || subjectRef.name || subjectId,
                weight,
                baseAmount,
                amount,
                currency
            });
        });

        return {
            feeCategory,
            suggestedAmount: roundWeight(suggestedAmount),
            amount: roundWeight(suggestedAmount),
            currency,
            notes: '',
            active: breakdown.length > 0,
            manualOverride: false,
            warnings,
            breakdown
        };
    }

    function normalizePricingState() {
        pricingState = pricingState && typeof pricingState === 'object' && !Array.isArray(pricingState)
            ? pricingState
            : { mode: 'auto', feeRules: Array.isArray(pricingState) ? pricingState : [] };
        pricingState.mode = String(pricingState.mode || 'auto').trim().toLowerCase() === 'manual' ? 'manual' : 'auto';
        let existing = Array.isArray(pricingState?.feeRules) ? pricingState.feeRules : [];
        if (pricingState.mode === 'auto') {
            const hasAllCategoriesRow = existing.some((row) => String(row?.feeCategory || '').trim() === allFeeCategoryKey);
            if (!hasAllCategoriesRow) {
                existing = [{
                    feeCategory: allFeeCategoryKey,
                    suggestedAmount: 0,
                    amount: 0,
                    currency: 'CAD',
                    transactionDefinitionId: '',
                    transactionDefinitionCode: '',
                    transactionDefinitionName: '',
                    notes: '',
                    active: true,
                    manualOverride: false
                }].concat(existing);
            }
            const seen = new Set();
            pricingState.feeRules = existing.map((row) => {
                const feeCategory = String(row?.feeCategory || '').trim();
                const proposal = buildClassPricingProposalForCategory(feeCategory);
                const existingRow = row || null;
                const manualOverride = existingRow?.manualOverride === true || String(existingRow?.manualOverride) === 'true';
                if (!feeCategory || seen.has(feeCategory)) return null;
                seen.add(feeCategory);
                return {
                    feeCategory,
                    suggestedAmount: proposal.suggestedAmount,
                    amount: manualOverride ? roundWeight(existingRow?.amount) : proposal.suggestedAmount,
                    currency: String(existingRow?.currency || proposal.currency || 'CAD').trim().toUpperCase() || 'CAD',
                    transactionDefinitionId: String(existingRow?.transactionDefinitionId || '').trim(),
                    transactionDefinitionCode: String(existingRow?.transactionDefinitionCode || '').trim().toUpperCase(),
                    transactionDefinitionName: String(existingRow?.transactionDefinitionName || '').trim(),
                    notes: String(existingRow?.notes || '').trim(),
                    active: existingRow ? (existingRow.active !== false && String(existingRow.active) !== 'false') : proposal.active,
                    manualOverride,
                    warnings: proposal.warnings || [],
                    breakdown: proposal.breakdown || []
                };
            }).filter(Boolean);
        } else {
            const seen = new Set();
            pricingState.feeRules = existing.map((row) => ({
                feeCategory: String(row?.feeCategory || '').trim(),
                suggestedAmount: roundWeight(row?.suggestedAmount),
                amount: roundWeight(row?.amount),
                currency: String(row?.currency || 'CAD').trim().toUpperCase() || 'CAD',
                transactionDefinitionId: String(row?.transactionDefinitionId || '').trim(),
                transactionDefinitionCode: String(row?.transactionDefinitionCode || '').trim().toUpperCase(),
                transactionDefinitionName: String(row?.transactionDefinitionName || '').trim(),
                notes: String(row?.notes || '').trim(),
                active: row?.active !== false && String(row?.active) !== 'false',
                manualOverride: true
            })).filter((row) => {
                if (!row.feeCategory || seen.has(row.feeCategory)) return false;
                seen.add(row.feeCategory);
                return true;
            });
        }
        syncPricingHidden();
    }

    function syncPricingHidden() {
        hidPricing.value = JSON.stringify({ mode: pricingState.mode, feeRules: pricingState.feeRules.map((row) => ({
            feeCategory: row.feeCategory,
            suggestedAmount: row.suggestedAmount,
            amount: row.amount,
            currency: row.currency,
            transactionDefinitionId: row.transactionDefinitionId || '',
            transactionDefinitionCode: row.transactionDefinitionCode || '',
            transactionDefinitionName: row.transactionDefinitionName || '',
            notes: row.notes,
            active: row.active,
            manualOverride: row.manualOverride
        })) });
    }

    function normalizePostingTemplateState() {
        const seen = new Set();
        postingTemplateState = (Array.isArray(postingTemplateState) ? postingTemplateState : []).map((row) => ({
            feeCategory: String(row?.feeCategory || '').trim(),
            transactionDefinitionId: String(row?.transactionDefinitionId || '').trim(),
            transactionDefinitionCode: String(row?.transactionDefinitionCode || '').trim().toUpperCase(),
            transactionDefinitionName: String(row?.transactionDefinitionName || '').trim(),
            notes: String(row?.notes || '').trim(),
            active: row?.active !== false && String(row?.active) !== 'false'
        })).filter((row) => {
            if (!row.feeCategory || seen.has(row.feeCategory)) return false;
            seen.add(row.feeCategory);
            return true;
        });
        syncPostingTemplatesHidden();
    }

    function syncPostingTemplatesHidden() {
        hidPostingTemplates.value = JSON.stringify(postingTemplateState.map((row) => ({
            feeCategory: row.feeCategory,
            transactionDefinitionId: row.transactionDefinitionId || '',
            transactionDefinitionCode: row.transactionDefinitionCode || '',
            transactionDefinitionName: row.transactionDefinitionName || '',
            notes: row.notes || '',
            active: row.active
        })));
    }

    function formatTransactionDefinitionLabel(row) {
        const code = String(row?.transactionDefinitionCode || '').trim();
        const name = String(row?.transactionDefinitionName || '').trim();
        return [code, name].filter(Boolean).join(' - ') || 'Select definition';
    }

    function getTransactionDefinitionById(id) {
        const lookupId = String(id || '').trim();
        if (!lookupId) return null;
        if (typeof transactionDefinitions !== 'undefined' && Array.isArray(transactionDefinitions)) {
            return transactionDefinitions.find((item) => String(item?.id || '').trim() === lookupId) || null;
        }
        return null;
    }

    function syncPostingTemplateSelectionUi() {
        const idInput = document.getElementById('postingTemplateDefinitionId');
        const labelInput = document.getElementById('postingTemplateDefinitionLabel');
        const viewBtn = document.getElementById('btnViewPostingTemplateDefinition');
        const notice = document.getElementById('selectedPostingTemplateNotice');
        const definitionId = String(idInput?.value || '').trim();
        const definition = getTransactionDefinitionById(definitionId);

        if (labelInput && definitionId && !String(labelInput.value || '').trim() && definition) {
            labelInput.value = [definition.code || '', definition.name || ''].filter(Boolean).join(' - ');
        }

        if (viewBtn) {
            if (definitionId) {
                viewBtn.href = '/school/transactionTemplates/edit/' + encodeURIComponent(definitionId);
                viewBtn.classList.remove('d-none');
            } else {
                viewBtn.href = '#';
                viewBtn.classList.add('d-none');
            }
        }

        if (notice) {
            if (definition) {
                const validFrom = String(definition.validFrom || '').trim();
                const validTo = String(definition.validTo || '').trim();
                const validity = (validFrom || validTo)
                    ? ((validFrom || 'Open') + ' to ' + (validTo || 'Open'))
                    : 'Unlimited validity';
                notice.innerHTML =
                    '<div class="fw-bold mb-1">Transaction Template Driven</div>' +
                    '<div class="small text-muted">' +
                    safeHtml([definition.code || '', definition.name || ''].filter(Boolean).join(' - ')) +
                    ' | ' + safeHtml(validity) +
                    '. Accounts, roles, and validity come from the template. The class fee amount comes from Pricing.' +
                    '</div>';
            } else {
                notice.innerHTML =
                    '<div class="fw-bold mb-1">Transaction Template Driven</div>' +
                    '<div class="small text-muted">Accounts, roles, and validity are taken from the linked Transaction Template. The class fee amount itself is read from the Pricing tab.</div>';
            }
        }
    }

    function renderPricingMode() {
        document.getElementById('pricingModeAuto').checked = pricingState.mode === 'auto';
        document.getElementById('pricingModeManual').checked = pricingState.mode === 'manual';
        document.getElementById('autoPricingSection').classList.toggle('d-none', pricingState.mode !== 'auto');
        document.getElementById('manualPricingSection').classList.toggle('d-none', pricingState.mode !== 'manual');
    }

    function normalizeBillingMode(value) {
        return String(value || '').trim().toLowerCase() === 'no_charge' ? 'no_charge' : 'chargeable';
    }

    function isChargeableClass() {
        return billingModeState === 'chargeable';
    }

    function syncBillingModeHidden() {
        if (hidBillingMode) hidBillingMode.value = normalizeBillingMode(billingModeState);
    }

    function renderBillingMode() {
        billingModeState = normalizeBillingMode(billingModeState);
        if (!isChargeableClass() && postingTemplateState.length) {
            postingTemplateState = [];
            syncPostingTemplateSelectionUi();
        }
        syncBillingModeHidden();

        const chargeableRadio = document.getElementById('billingModeChargeable');
        const noChargeRadio = document.getElementById('billingModeNoCharge');
        if (chargeableRadio) chargeableRadio.checked = billingModeState === 'chargeable';
        if (noChargeRadio) noChargeRadio.checked = billingModeState === 'no_charge';

        const noChargeNotice = document.getElementById('noChargePostingNotice');
        if (noChargeNotice) noChargeNotice.classList.toggle('d-none', isChargeableClass());

        const postingInfoAlert = document.querySelector('#tab-posting .alert.alert-warning');
        if (postingInfoAlert) postingInfoAlert.classList.toggle('d-none', !isChargeableClass());
        const postingTemplateNotice = document.getElementById('selectedPostingTemplateNotice');
        if (postingTemplateNotice) postingTemplateNotice.classList.toggle('d-none', !isChargeableClass());

        const postingCategory = document.getElementById('postingTemplateCategory');
        const postingDefinitionLabel = document.getElementById('postingTemplateDefinitionLabel');
        const postingNotes = document.getElementById('postingTemplateNotes');
        const btnPickPostingTemplateDefinition = document.getElementById('btnPickPostingTemplateDefinition');
        const btnClearPostingTemplateDefinition = document.getElementById('btnClearPostingTemplateDefinition');
        const btnAddPostingTemplateRow = document.getElementById('btnAddPostingTemplateRow');

        [postingCategory, postingDefinitionLabel, postingNotes, btnPickPostingTemplateDefinition, btnClearPostingTemplateDefinition, btnAddPostingTemplateRow].forEach((el) => {
            if (el) el.disabled = !isChargeableClass();
        });
    }

    function renderPricingRows() {
        normalizePricingState();
        renderPricingMode();
        const tbody = document.getElementById('classPricingTbody');
        if (!tbody) return;
        if (!pricingState.feeRules.length) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted small py-3">No fee rows yet. Add the fee categories this class should use.</td></tr>';
