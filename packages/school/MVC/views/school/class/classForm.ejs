            tbody.appendChild(tr);
        });

        lblScheduled.innerText = total.toFixed(2);
    }

    tbody.addEventListener('change', (e) => {
        const index = e.target.getAttribute('data-index');
        if (e.target.classList.contains('session-lock-cb')) {
            sessionsState[index].locked = e.target.checked;
            renderSessions(); return;
        }

        if (e.target.classList.contains('session-input')) {
            const field = e.target.getAttribute('data-field');
            const val = e.target.value;

            if (field === 'startTime' || field === 'endTime') {
                sessionsState[index][field] = val;
                sessionsState[index].durationHours = getDuration(sessionsState[index].startTime, sessionsState[index].endTime);
            } else if (field === 'status') {
                const normalizedStatus = normalizeStatusCode(val) || normalizeStatusCode(defaultSessionStatusCode) || 'scheduled';
                sessionsState[index][field] = normalizedStatus;
                if (shouldForceZeroHours(normalizedStatus)) {
                    sessionsState[index].durationHours = 0;
                }
            } else {
                sessionsState[index][field] = field === 'durationHours' ? (parseFloat(val) || 0) : val;
            }
            sessionsState[index].conflictMsg = null; 
            renderSessions(); 
        }
    });

    tbody.addEventListener('click', (e) => {
        const removeBtn = e.target.closest('.btn-remove-session');
        if (removeBtn && !removeBtn.disabled) {
            sessionsState.splice(removeBtn.getAttribute('data-index'), 1);
            renderSessions();
        }

        const pickBtn = e.target.closest('.btn-pick-teacher');
        if (pickBtn && !pickBtn.disabled) {
            const index = pickBtn.getAttribute('data-index');
            GenericPicker.open(GenericPickerPresets.teacher({
                title: 'Select Teacher',
                icon: 'bi-person',
                placeholder: 'Search Teachers...',
                renderer: teacherPickerRenderer,
                onSelect: (item) => {
                    const teacher = resolveTeacherPickerSelection(item);
                    if(!sessionsState[index].delivery) sessionsState[index].delivery = {};
                    sessionsState[index].delivery.deliveredBy = teacher.personId;
                    sessionsState[index].delivery.deliveredByName = teacher.displayName;
                    sessionsState[index].conflictMsg = null; 
                    renderSessions();
                }
            }));
        }
    });

    const btnDeleteAllSessions = document.getElementById('btn_deleteAllSessions');
    if (btnDeleteAllSessions) {
        btnDeleteAllSessions.addEventListener('click', async () => {
            if (!Array.isArray(sessionsState) || sessionsState.length === 0) {
                await uiAlert('There are no sessions to delete.', 'Session Ledger');
                return;
            }
            const confirmed = await uiConfirm(
                `Delete all ${sessionsState.length} session(s) from this ledger? This only affects the in-memory class form until you save.`,
                'Delete All Sessions'
            );
            if (!confirmed) return;

            sessionsState = [];
            renderSessions();
        });
