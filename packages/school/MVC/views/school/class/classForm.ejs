        }
        const groupedRows = [allFeeCategoryKey].concat(feeCategories || []).map((cat) => ({
            category: cat,
            rows: postingTemplateState.map((row, index) => ({
                ...row,
                index
            })).filter((row) => String(row.feeCategory || '').trim() === String(cat || '').trim())
        })).filter((group) => group.rows.length > 0);

        tbody.innerHTML = groupedRows.map((group) => {
            const header = '<tr class="table-light">' +
                '<td colspan="4"><span class="fw-bold">' + escapeHtml(labelFeeCategory(group.category)) + '</span></td>' +
            '</tr>';
            const rowsHtml = group.rows.map((row) => {
                const definition = getTransactionDefinitionById(row.transactionDefinitionId);
                const validity = definition
                    ? ((definition.validFrom || definition.validTo)
                        ? ('Valid: ' + escapeHtml(definition.validFrom || 'Open') + ' to ' + escapeHtml(definition.validTo || 'Open'))
                        : 'Unlimited validity')
                    : 'Validity unavailable';
                const viewBtn = row.transactionDefinitionId
                    ? '<a href="/school/transactionTemplates/edit/' + encodeURIComponent(row.transactionDefinitionId) + '" class="btn btn-outline-info btn-sm" target="_blank" rel="noopener"><i class="bi bi-box-arrow-up-right me-1"></i>View</a>'
                    : '';
                return '<tr>' +
                    '<td><div class="fw-bold">' + escapeHtml(formatTransactionDefinitionLabel(row)) + '</div><div class="small text-muted">Linked Transaction Template for this Posting Policy.</div></td>' +
                    '<td><div class="fw-bold font-monospace">' + escapeHtml(row.transactionDefinitionCode || row.transactionDefinitionId || '-') + '</div><div class="small text-muted">' + escapeHtml(row.notes || '') + '</div></td>' +
                    '<td><span class="small text-dark">' + validity + '</span></td>' +
                    '<td class="text-end"><div class="d-flex gap-2 justify-content-end">' + viewBtn + '<button type="button" class="btn btn-outline-danger btn-sm btn-remove-posting-template" data-index="' + row.index + '" ' + (isChargeableClass() ? '' : 'disabled') + '><i class="bi bi-trash me-1"></i>Delete</button></div></td>' +
                '</tr>';
            }).join('');
            return header + rowsHtml;
        }).join('');
