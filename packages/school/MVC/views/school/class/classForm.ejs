    async function confirmCycleAction({
        title = 'Confirm Action',
        message = 'Proceed with this cycle action?',
        confirmLabel = 'Proceed',
        cancelLabel = 'Cancel'
    } = {}) {
        if (typeof showMessageModal === 'function') {
            const result = await showMessageModal({
                title,
                icon: 'warning',
                message,
                size: 'sm',
                buttons: [
                    { text: cancelLabel, class: 'btn-secondary' },
                    { text: confirmLabel, class: 'btn-primary' }
                ]
            });
            return String(result || '') === String(confirmLabel);
        }
        return confirm(String(message || '').replace(/<[^>]+>/g, ' '));
    }

    async function postCycleAction(endpoint, payload, options = {}) {
        const {
            triggerButton = null,
            busyTitle = 'Operation In Progress',
            replayTitle = 'Operation Already Processed',
            successTitle = 'Completed',
            successMessageFactory = null
        } = options || {};
        const originalBtnHtml = triggerButton ? triggerButton.innerHTML : '';

        try {
            setCycleActionsLocked(true);
            if (triggerButton) {
                triggerButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Processing...';
            }
            if (typeof window.showLoading === 'function') window.showLoading();

            const params = new URLSearchParams();
            const token = getActionStateId();
            if (token) params.append('actionStateId', token);
            Object.entries(payload || {}).forEach(([key, value]) => {
                if (value === undefined || value === null) return;
                params.append(key, String(value));
            });

            const resp = await fetch(endpoint, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'X-AJAX-Request': 'true',
                    Accept: 'application/json'
                },
                body: params.toString()
            });

            let result = null;
            try {
                result = await resp.json();
            } catch (_) {
                throw new Error(`Server returned a non-JSON response (HTTP ${resp.status}).`);
            }

            const guarded = typeof window.applyGuardedApiResult === 'function'
                ? await window.applyGuardedApiResult(result, { busyTitle, replayTitle })
                : { stop: false };
            if (guarded.stop) return null;

            if (!resp.ok || String(result?.status || '').toLowerCase() !== 'success') {
                throw new Error(result?.message || `Operation failed (HTTP ${resp.status}).`);
            }

            const successMessage = typeof successMessageFactory === 'function'
                ? successMessageFactory(result)
                : String(result?.message || 'Operation completed successfully.');

            if (typeof showMessageModal === 'function') {
                await showMessageModal({
                    title: successTitle,
                    icon: 'success',
                    message: successMessage,
                    buttons: [{ text: 'OK', class: 'btn-success' }]
                });
            } else {
                await uiAlert(successMessage, successTitle);
            }

            return result;
        } catch (error) {
            if (typeof showMessageModal === 'function') {
                await showMessageModal({
                    title: 'Action Failed',
                    icon: 'error',
                    message: error?.message || 'Unexpected error during cycle action.',
                    buttons: [{ text: 'OK', class: 'btn-danger' }]
                });
            } else {
                await uiAlert(error?.message || 'Unexpected error during cycle action.', 'Action Failed');
            }
            return null;
        } finally {
            if (typeof window.hideLoading === 'function') window.hideLoading();
            setCycleActionsLocked(false);
            if (triggerButton) {
                triggerButton.innerHTML = originalBtnHtml;
            }
        }
    }

    async function handleCloseCycleAction() {
        if (!classId) return uiAlert('Save the class first, then close the cycle.', 'Cycle Action');
        if (!isRollingMode()) return uiAlert('Cycle actions apply only to Rolling classes.', 'Cycle Action');

        const closeEndDate = String(cycleActionCloseEndDateInput?.value || cycleEndDateInput?.value || '').trim();
        if (!closeEndDate) return uiAlert('Cycle End Date is required to close the current cycle.', 'Cycle Action');
        const start = String(cycleStartDateInput?.value || '').trim();
        if (start && closeEndDate < start) return uiAlert('Cycle End Date cannot be before Cycle Start Date.', 'Cycle Action');

        const confirmed = await confirmCycleAction({
            title: 'Close Current Cycle?',
            message: `This will close the current cycle at <b>${closeEndDate}</b> and can block new open enrollment periods.`,
            confirmLabel: 'Close Cycle'
        });
        if (!confirmed) return;

        const result = await postCycleAction(`/school/classes/api/${encodeURIComponent(classId)}/cycles/close`, {
            classId,
            cycleEndDate: closeEndDate,
            isClosedForNewEnrollment: cycleActionCloseBlockEnrollmentInput?.checked ? 'true' : 'false'
        }, {
            triggerButton: btnCycleClose,
            busyTitle: 'Cycle Close In Progress',
            replayTitle: 'Cycle Already Closed',
            successTitle: 'Cycle Closed',
            successMessageFactory: (res) => String(res?.message || 'Cycle closed.')
        });

        if (!result) return;
        if (cycleEndDateInput) cycleEndDateInput.value = closeEndDate;
        if (isClosedEnrollmentInput) isClosedEnrollmentInput.checked = !!cycleActionCloseBlockEnrollmentInput?.checked;
        setCycleActionSummaryText(`Cycle closed at ${closeEndDate}. New enrollment is ${isClosedEnrollmentInput?.checked ? 'blocked' : 'still open'}.`, 'success');
        notifyCycleChainUpdated();
    }

    async function handleCreateNextCycleAction() {
        if (!classId) return uiAlert('Save the class first, then create the next cycle.', 'Cycle Action');
        if (!isRollingMode()) return uiAlert('Cycle actions apply only to Rolling classes.', 'Cycle Action');

        const nextStartDate = String(cycleActionNextStartDateInput?.value || '').trim();
        const nextEndDate = String(cycleActionNextEndDateInput?.value || '').trim();
        const closeCurrent = !!cycleActionCloseCurrentOnCreateInput?.checked;
        const carryForward = !!cycleActionAutoCarryForwardInput?.checked;
        if (!nextStartDate) return uiAlert('Next Cycle Start Date is required.', 'Cycle Action');
        if (nextEndDate && nextEndDate < nextStartDate) return uiAlert('Next Cycle End Date cannot be before Next Cycle Start Date.', 'Cycle Action');

        const confirmed = await confirmCycleAction({
            title: 'Create Next Cycle?',
            message: [
                `A new cycle class will be created starting <b>${nextStartDate}</b>${nextEndDate ? ` and ending <b>${nextEndDate}</b>` : ''}.`,
                closeCurrent ? 'Current cycle will also be closed.' : 'Current cycle will remain open.',
                carryForward ? 'Eligible students will be auto carry-forwarded.' : 'Carry-forward is disabled for this action.'
            ].join('<br>'),
            confirmLabel: 'Create Next'
        });
        if (!confirmed) return;

        const currentCycleEndDate = String(cycleActionCloseEndDateInput?.value || cycleEndDateInput?.value || addDaysYmd(nextStartDate, -1) || '').trim();
        const payload = {
            classId,
            cycleStartDate: nextStartDate,
            cycleEndDate: nextEndDate,
            currentCycleEndDate,
            closeCurrentCycle: closeCurrent ? 'true' : 'false',
            carryForwardEligibleStudents: carryForward ? 'true' : 'false',
            nextCycleStatus: String(document.querySelector('select[name="status"]')?.value || 'active').trim()
        };

        const result = await postCycleAction(`/school/classes/api/${encodeURIComponent(classId)}/cycles/create-next`, payload, {
            triggerButton: btnCycleCreateNext,
            busyTitle: 'Next Cycle Creation In Progress',
            replayTitle: 'Next Cycle Already Created',
            successTitle: 'Next Cycle Created',
            successMessageFactory: (res) => {
                const createdId = String(res?.data?.createdClass?.id || '').trim();
                const carried = Number(res?.data?.carryForwardResult?.targetCreated || 0) + Number(res?.data?.carryForwardResult?.wholeMovedCount || 0);
                const boundary = res?.data?.cycleBoundary;
                const parts = [String(res?.message || 'Next cycle created.')];
                if (createdId) parts.push(`Created Class ID: <b>${createdId}</b>`);
                if (boundary && Number.isFinite(boundary.gapDays)) {
                    parts.push(`Boundary gap days: <b>${boundary.gapDays}</b>`);
                }
                if (carryForward) parts.push(`Carry-forward moved/split rows: <b>${carried}</b>`);
                return parts.join('<br>');
            }
        });

        if (!result) return;
        const createdClassId = String(result?.data?.createdClass?.id || '').trim();
        if (createdClassId && nextClassIdInput) nextClassIdInput.value = createdClassId;
        if (createdClassId && cycleActionTargetClassIdInput && !String(cycleActionTargetClassIdInput.value || '').trim()) {
            cycleActionTargetClassIdInput.value = createdClassId;
        }
        if (closeCurrent && isClosedEnrollmentInput) isClosedEnrollmentInput.checked = true;
        if (closeCurrent && currentCycleEndDate && cycleEndDateInput) cycleEndDateInput.value = currentCycleEndDate;
        if (closeCurrent && currentCycleEndDate && cycleActionCloseEndDateInput) cycleActionCloseEndDateInput.value = currentCycleEndDate;
        setCycleActionSummaryText(
            createdClassId
                ? `Next cycle created (${createdClassId}). ${carryForward ? 'Carry-forward executed automatically.' : 'Carry-forward was skipped.'}`
                : 'Next cycle created successfully.',
            'success'
        );
        notifyCycleChainUpdated();
    }

