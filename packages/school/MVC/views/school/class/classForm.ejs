            <tr>
                <td>
                    <div class="fw-bold">${escapeHtml(labelFeeCategory(row.feeCategory))}</div>
                    <div class="small text-muted">${row.manualOverride ? 'Manual fee kept' : 'Using proposal'}</div>
                </td>
                <td>
                    <div class="fw-bold">${Number(row.suggestedAmount || 0).toFixed(2)}</div>
                    <div class="small text-muted">${escapeHtml(row.currency || 'CAD')}</div>
                </td>
                <td><input type="number" min="0" step="0.01" class="form-control form-control-sm class-fee-amount" data-index="${index}" value="${row.amount ?? 0}"></td>
                <td><input type="text" maxlength="3" class="form-control form-control-sm text-uppercase class-fee-currency" data-index="${index}" value="${escapeHtml(row.currency || 'CAD')}"></td>
                <td><input type="text" class="form-control form-control-sm class-fee-notes" data-index="${index}" value="${escapeHtml(row.notes || '')}" placeholder="Optional note"></td>
