    function normalizeAllowedProgramTermsState() {
        allowedProgramTermsState = (Array.isArray(allowedProgramTermsState) ? allowedProgramTermsState : []).map((item, idx) => ({
            programId: String(item?.programId || '').trim(),
            termId: String(item?.termId || '').trim(),
            order: Number(item?.order || (idx + 1)),
            programCode: String(item?.programCode || '').trim().toUpperCase(),
            programName: String(item?.programName || item?.programId || '').trim(),
            termCode: String(item?.termCode || '').trim().toUpperCase(),
            termName: String(item?.termName || item?.termId || '').trim(),
            startDate: String(item?.startDate || '').trim(),
            endDate: String(item?.endDate || '').trim(),
            classesStartDate: String(item?.classesStartDate || '').trim(),
            classesEndDate: String(item?.classesEndDate || '').trim(),
            notes: String(item?.notes || '').trim()
        })).filter((item) => {
            if (!item.programId) return false;
            if (isRollingMode()) return true;
            return Boolean(item.termId);
        });

        allowedProgramTermsState.sort((a, b) => a.order - b.order);
        allowedProgramTermsState = allowedProgramTermsState
            .filter((item, index, arr) => arr.findIndex((row) => row.programId === item.programId && row.termId === item.termId) === index)
            .map((item, index) => ({ ...item, order: index + 1 }));
    }

    function syncAllowedProgramTermsHidden() {
        hidAllowedProgramTerms.value = JSON.stringify(allowedProgramTermsState.map((item) => ({
            programId: item.programId,
            termId: item.termId,
            order: item.order,
            programCode: item.programCode,
            programName: item.programName,
            termCode: item.termCode,
            termName: item.termName,
            startDate: item.startDate,
            endDate: item.endDate,
            classesStartDate: item.classesStartDate,
            classesEndDate: item.classesEndDate,
            notes: item.notes
        })));
    }

    window.__classFormSyncAllowedProgramTermsForWizard = function () {
        normalizeAllowedProgramTermsState();
        syncAllowedProgramTermsHidden();
    };

    function renderPendingEligibilityProgram() {
        const programNameInput = document.getElementById('eligibility_programName');
        const programIdInput = document.getElementById('eligibility_programId');
        const termSelect = document.getElementById('eligibility_termId');
        const hint = document.getElementById('eligibility_programHint');

        if (!pendingEligibilityProgram) {
            programIdInput.value = '';
            programNameInput.value = '';
            termSelect.innerHTML = '<option value="">Select a program first</option>';
            termSelect.disabled = true;
            hint.textContent = 'Pick a program to load its defined terms/semesters.';
            return;
        }

        programIdInput.value = pendingEligibilityProgram.programId;
        programNameInput.value = pendingEligibilityProgram.programName;

        const programTerms = Array.isArray(pendingEligibilityProgram.terms) ? pendingEligibilityProgram.terms : [];
        const rolling = isRollingMode();
        if (!programTerms.length) {
            if (rolling) {
                termSelect.innerHTML = '<option value="">No term (program only)</option>';
                termSelect.disabled = false;
                hint.textContent = 'This program has no terms defined yet. You can still add the program for rolling enrollment; add terms on the Program form if you need a specific term here.';
            } else {
                termSelect.innerHTML = '<option value="">No terms defined on this program</option>';
                termSelect.disabled = true;
                hint.textContent = 'This program has no assigned terms yet. Add terms on the Program form first.';
            }
            return;
        }

        termSelect.disabled = false;
        const anyOpt = rolling
            ? '<option value="">No term (program only — rolling)</option>'
            : '<option value="">Select term</option>';
        termSelect.innerHTML = anyOpt + programTerms.map((term) => {
            const labelParts = [];
            if (term.termCode || term.code) labelParts.push(String(term.termCode || term.code).trim().toUpperCase());
            if (term.termName || term.name) labelParts.push(String(term.termName || term.name).trim());
            return `<option value="${escapeHtml(term.termId || term.id || '')}">${escapeHtml(labelParts.join(' - ') || (term.termId || term.id || 'Term'))}</option>`;
        }).join('');
        hint.textContent = rolling
            ? 'Leave the term empty to allow any term for this program, or pick a specific term.'
            : 'Only the terms already attached to this program can be added to the class.';
    }

    function renderAllowedProgramTerms() {
        if (!allowedProgramTermsState.length) {
            const rolling = isRollingMode();
            const emptyMsg = rolling
                ? 'No programs added yet. <strong>Rolling classes require at least one program</strong> (with or without a term). Use Add after selecting a program.'
                : 'No program–term rows yet. Add program–term pairs to restrict which registrations can use this class.';
            allowedProgramTermsTbody.innerHTML = `<tr><td colspan="5" class="text-center text-muted small py-3">${emptyMsg}</td></tr>`;
            syncAllowedProgramTermsHidden();
            return;
        }

        allowedProgramTermsTbody.innerHTML = allowedProgramTermsState.map((item, idx) => {
            const hasTerm = Boolean(String(item.termId || '').trim());
            const termTitleHtml = hasTerm
                ? `<div class="fw-bold">${escapeHtml(item.termName || item.termId)}</div><div class="small text-muted font-monospace">${escapeHtml(item.termCode || item.termId)}</div>`
                : '<div class="fw-bold text-muted">— Any term</div>';
            return `
            <tr>
                <td><span class="badge bg-primary">${item.order}</span></td>
                <td>
                    <div class="fw-bold">${escapeHtml(item.programName || item.programId)}</div>
                    <div class="small text-muted font-monospace">${escapeHtml(item.programCode || item.programId)}</div>
                </td>
                <td>${termTitleHtml}</td>
                <td><input type="text" class="form-control form-control-sm eligibility-note-input" data-index="${idx}" value="${escapeHtml(item.notes || '')}" placeholder="Optional note"></td>
                <td class="text-end">
                    <button type="button" class="btn btn-outline-danger btn-sm btn-remove-eligibility" data-index="${idx}">Remove</button>
                </td>
            </tr>
        `;
        }).join('');

        allowedProgramTermsTbody.querySelectorAll('.eligibility-note-input').forEach((input) => {
            input.addEventListener('input', () => {
                const idx = Number(input.getAttribute('data-index'));
                if (Number.isNaN(idx) || idx < 0 || idx >= allowedProgramTermsState.length) return;
                allowedProgramTermsState[idx].notes = input.value.trim();
                syncAllowedProgramTermsHidden();
            });
        });

        allowedProgramTermsTbody.querySelectorAll('.btn-remove-eligibility').forEach((btn) => {
            btn.addEventListener('click', () => {
                const idx = Number(btn.getAttribute('data-index'));
                if (Number.isNaN(idx) || idx < 0 || idx >= allowedProgramTermsState.length) return;
                allowedProgramTermsState.splice(idx, 1);
                normalizeAllowedProgramTermsState();
                renderAllowedProgramTerms();
                refreshRollingSessionDateBounds();
            });
        });

        syncAllowedProgramTermsHidden();
    }

    // Pickers
