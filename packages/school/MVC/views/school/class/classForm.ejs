<div class="modal fade" id="bulkTeacherModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-people me-2"></i>Edit Teacher Assignments</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div class="alert alert-light border small">
          This tool updates the teacher assignment on matching sessions <strong>in-place</strong> (no deletion/re-adding).
          After applying, click <strong>Save Class &amp; Ledger</strong> to persist.
        </div>

        <div class="row g-3">
          <div class="col-md-6">
            <label class="form-label small">Current Teacher (to replace)</label>
            <select class="form-select form-select-sm" id="bulk_oldTeacher"></select>
          </div>
          <div class="col-md-6">
            <label class="form-label small">New Teacher</label>
            <div class="input-group input-group-sm">
              <input type="text" class="form-control" id="bulk_newTeacherName" placeholder="Pick a teacher..." readonly>
              <button class="btn btn-outline-secondary" type="button" id="bulk_pickNewTeacher" title="Pick teacher"><i class="bi bi-person"></i></button>
              <button class="btn btn-outline-secondary" type="button" id="bulk_clearNewTeacher" title="Clear"><i class="bi bi-x-lg"></i></button>
            </div>
            <input type="hidden" id="bulk_newTeacherId">
          </div>
          <div class="col-md-6">
            <label class="form-label small">Target Sessions</label>
            <select class="form-select form-select-sm" id="bulk_targetStatus">
              <% (availableSessionStatuses || []).forEach((row) => { %>
                <option value="<%= row.code %>" <%= row.code === resolvedDefaultSessionStatusCode ? 'selected' : '' %>><%= row.label || row.code %></option>
              <% }) %>
              <option value="all">All</option>
            </select>
          </div>
          <div class="col-md-6 d-flex align-items-end">
            <div class="form-check form-switch">
              <input class="form-check-input" type="checkbox" role="switch" id="bulk_includeLocked">
              <label class="form-check-label small" for="bulk_includeLocked">Include locked sessions</label>
            </div>
          </div>
          <div class="col-md-6">
