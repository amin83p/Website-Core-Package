    const tbody = document.getElementById('sessionsTbody');
    const lblScheduled = document.getElementById('lbl_scheduledHours');

    function renderSessions() {
        tbody.innerHTML = '';
        let total = 0;

        sessionsState.sort((a, b) => {
            const dateA = new Date(`${a.date}T${a.startTime || '00:00'}`);
            const dateB = new Date(`${b.date}T${b.startTime || '00:00'}`);
            return dateA - dateB;
        });

        if (sessionsState.length === 0) {
            document.getElementById('noSessionsMsg').classList.remove('d-none');
            lblScheduled.innerText = '0';
            return;
        }
        document.getElementById('noSessionsMsg').classList.add('d-none');

        sessionsState.forEach((ses, index) => {
            total += parseFloat(ses.durationHours) || 0;
            
            const statusCode = resolveSessionStatusCode(ses);
            const statusMeta = resolveSessionStatusMeta(statusCode);
            const isCompleted = statusMeta ? statusMeta.isFinal === true : statusCode === 'completed';
            const isCancelled = statusMeta ? statusMeta.excludeFromTeacherIndex === true : statusCode === 'cancelled';
            const isLocked = !!ses.locked;
            const rowAppearance = buildSessionRowAppearance(statusCode, { locked: isLocked, conflict: Boolean(ses.conflictMsg) });
            
            let conflictHtml = '';

            if (ses.conflictMsg) {
                const currentTid = ses.delivery?.deliveredBy || document.getElementById('bg_teacherId').value;
                const currentTname = ses.delivery?.deliveredByName || 'Teacher';
                
                conflictHtml = `
                    <div class="text-danger mt-1 x-small fw-bold d-flex align-items-center justify-content-between">
                        <span><i class="bi bi-exclamation-triangle-fill"></i> ${ses.conflictMsg}</span>
                        <a href="/school/schedules/viewer?personId=${currentTid}&personName=${encodeURIComponent(currentTname)}&date=${ses.date}" 
                           target="_blank" 
                           class="btn btn-sm btn-danger py-0 px-1" 
                           style="font-size: 0.65rem;"
                           title="Open Master Schedule">
                           <i class="bi bi-box-arrow-up-right"></i> View
                        </a>
                    </div>
                `;
            }

            const lockedAttr = isLocked ? 'disabled' : '';
            const tName = ses.delivery?.deliveredByName || ses.delivery?.deliveredBy || '';
            
            const isUnsaved = !ses._isSaved;
