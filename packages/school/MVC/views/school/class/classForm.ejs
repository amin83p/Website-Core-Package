        tbody.innerHTML = pricingState.feeRules.map((row, index) => `
            <tr>
                <td>${escapeHtml(labelFeeCategory(row.feeCategory))}</td>
                <td><input type="number" min="0" step="0.01" class="form-control form-control-sm manual-fee-amount" data-index="${index}" value="${row.amount ?? 0}"></td>
                <td><input type="text" maxlength="3" class="form-control form-control-sm text-uppercase manual-fee-currency" data-index="${index}" value="${escapeHtml(row.currency || 'CAD')}"></td>
                <td><input type="text" class="form-control form-control-sm manual-fee-notes" data-index="${index}" value="${escapeHtml(row.notes || '')}" placeholder="Optional note"></td>
