    function normalizeDateToken(value) {
        const token = String(value || '').trim();
        return /^\d{4}-\d{2}-\d{2}$/.test(token) ? token : '';
    }

    function validateLifecycleInputs() {
        const rolling = isRollingMode();
        const cycleNo = Number.parseInt(String(cycleNoInput?.value || '').trim(), 10);
        if (!Number.isFinite(cycleNo) || cycleNo <= 0) {
            return 'Cycle Number must be a positive number.';
        }

        if (!rolling) return '';

        const start = String(cycleStartDateInput?.value || '').trim();
        const end = String(cycleEndDateInput?.value || '').trim();
        const startDate = parseYmd(start);
        const endDate = parseYmd(end);

        if (!start) return 'Cycle Start Date is required for rolling classes.';
        if (start && !startDate) return 'Cycle Start Date must use YYYY-MM-DD.';
        if (end && !endDate) return 'Cycle End Date must use YYYY-MM-DD.';
        if (startDate && endDate && endDate < startDate) {
            return 'Cycle End Date cannot be before Cycle Start Date.';
        }
        return '';
    }

    function getRollingCycleBounds() {
        if (!isRollingMode()) return null;
        const startToken = String(cycleStartDateInput?.value || '').trim();
        const endToken = String(cycleEndDateInput?.value || '').trim();
        const startDate = parseYmd(startToken);
        const endDate = parseYmd(endToken);
        if (!startToken || !startDate) {
            return { error: 'Cycle Start Date is required for rolling classes before generating sessions.' };
        }
        if (endToken && !endDate) {
            return { error: 'Cycle End Date must use YYYY-MM-DD.' };
        }
        if (startDate && endDate && endDate < startDate) {
            return { error: 'Cycle End Date cannot be before Cycle Start Date.' };
        }
        return {
            startToken,
            endToken
        };
    }

    function getTermInstructionBoundsFromRow(row) {
        return {
            startToken: normalizeDateToken(row?.classesStartDate) || normalizeDateToken(row?.startDate),
            endToken: normalizeDateToken(row?.classesEndDate) || normalizeDateToken(row?.endDate)
        };
    }

    function getTermBasedSessionBounds() {
        if (isRollingMode()) return null;
        const rows = (Array.isArray(allowedProgramTermsState) ? allowedProgramTermsState : [])
            .filter((row) => String(row?.termId || '').trim());
        if (!rows.length) {
            return { error: 'Add at least one program-term row before generating sessions for a term-based class.' };
        }

        const windows = [];
        const missing = [];
        rows.forEach((row) => {
            const bounds = getTermInstructionBoundsFromRow(row);
            if (!bounds.startToken || !bounds.endToken) {
                missing.push(row.termName || row.termCode || row.termId);
            } else {
                windows.push(bounds);
            }
        });

        if (missing.length) {
            return {
                warning: 'Term date details are not available on this form for ' + missing.slice(0, 3).join(', ') + (missing.length > 3 ? ` (+${missing.length - 3} more)` : '') + '. The server will validate current term dates when saving.'
            };
        }

        const startToken = windows.reduce((max, row) => (!max || row.startToken > max ? row.startToken : max), '');
        const endToken = windows.reduce((min, row) => (!min || row.endToken < min ? row.endToken : min), '');
        if (startToken && endToken && startToken > endToken) {
            return { error: 'The selected program-term rows have no overlapping instructional date window.' };
        }
        return { startToken, endToken };
    }

    function refreshRollingSessionDateBounds() {
        const rolling = isRollingMode();
        const bounds = rolling ? getRollingCycleBounds() : getTermBasedSessionBounds();
        if (!bounds || bounds.error) {
            rollingSessionDateInputs.forEach((input) => {
                input.removeAttribute('min');
                input.removeAttribute('max');
            });
            if (rollingSessionWindowHint) {
                rollingSessionWindowHint.className = 'alert alert-warning border small py-2 mb-3';
                rollingSessionWindowHint.textContent = bounds?.error || '';
            }
            return;
        }
        if (bounds.warning) {
            rollingSessionDateInputs.forEach((input) => {
                input.removeAttribute('min');
                input.removeAttribute('max');
            });
            if (rollingSessionWindowHint) {
                rollingSessionWindowHint.className = 'alert alert-warning border small py-2 mb-3';
                rollingSessionWindowHint.textContent = bounds.warning;
            }
            return;
        }
        rollingSessionDateInputs.forEach((input) => {
            input.min = bounds.startToken;
            if (bounds.endToken) input.max = bounds.endToken;
            else input.removeAttribute('max');
        });
        if (rollingSessionWindowHint) {
            rollingSessionWindowHint.className = 'alert alert-info border small py-2 mb-3';
            rollingSessionWindowHint.textContent = rolling
                ? `Rolling sessions must be scheduled from ${bounds.startToken}${bounds.endToken ? ` to ${bounds.endToken}` : ' onward'}.`
                : `Term-based sessions must be scheduled from ${bounds.startToken} to ${bounds.endToken}.`;
        }
    }
    function findSessionCycleWindowViolations(sessionRows = []) {
        const rolling = isRollingMode();
        const bounds = rolling ? getRollingCycleBounds() : getTermBasedSessionBounds();
        if (bounds?.error) {
            return [{ type: rolling ? 'cycle_error' : 'term_error', message: bounds.error }];
        }
        if (!bounds || bounds.warning) return [];

        const rows = Array.isArray(sessionRows) ? sessionRows : [];
        const violations = [];
        rows.forEach((row, index) => {
            const dateToken = String(row?.date || '').trim();
            if (!dateToken) return;
            const parsed = parseYmd(dateToken);
            if (!parsed) {
                violations.push({ type: 'invalid_date', index, date: dateToken, sessionId: String(row?.sessionId || '').trim() });
                return;
            }
            if (dateToken < bounds.startToken || (bounds.endToken && dateToken > bounds.endToken)) {
                violations.push({ type: rolling ? 'outside_cycle' : 'outside_term', index, date: dateToken, sessionId: String(row?.sessionId || '').trim() });
            }
        });
        return violations;
    }

    function buildSessionCycleWindowViolationMessage(violations = []) {
        if (!Array.isArray(violations) || !violations.length) return '';
        const cycleError = violations.find((row) => row.type === 'cycle_error');
        if (cycleError) return String(cycleError.message || 'Rolling cycle dates are invalid.');
        const termError = violations.find((row) => row.type === 'term_error');
        if (termError) return String(termError.message || 'Term instructional dates are invalid.');

        const invalidCount = violations.filter((row) => row.type === 'invalid_date').length;
        const outside = violations.filter((row) => row.type === 'outside_cycle' || row.type === 'outside_term');
        const isTermViolation = outside.some((row) => row.type === 'outside_term');
        const sample = outside.slice(0, 5).map((row) => {
            const sid = String(row?.sessionId || '').trim();
            return sid ? `${row.date} (${sid})` : row.date;
        }).join(', ');
        const suffix = outside.length > 5 ? ` (+${outside.length - 5} more)` : '';
        const parts = [isTermViolation ? 'Term-based class sessions must stay within the selected term instructional window.' : 'Rolling class sessions must stay within cycle dates.'];
        if (invalidCount > 0) parts.push(`${invalidCount} session(s) have invalid date format.`);
        if (outside.length > 0) parts.push(`Out-of-window session date(s): ${sample}${suffix}.`);
        return parts.join(' ');
    }

    async function runRollingIntegrityCheckFromApi() {
        if (!classId) {
            await uiAlert('Save the class first, then run integrity checks on rolling enrollment periods.', 'Rolling Integrity');
            return;
        }
        if (!isRollingMode()) {
            await uiAlert('Rolling integrity checks are only applicable when Registration Mode is Rolling.', 'Rolling Integrity');
            return;
        }

        const actionBtn = btnCheckRollingIntegrity;
        const originalText = actionBtn ? actionBtn.innerHTML : '';
        if (actionBtn) {
            actionBtn.disabled = true;
            actionBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Checking...';
        }

        try {
            const resp = await fetch(`/school/classes/api/${encodeURIComponent(classId)}/enrollment-periods`, {
                headers: { 'X-AJAX-Request': 'true' }
            });
            const result = await resp.json();
            if (!resp.ok || result?.status !== 'success') {
                throw new Error(result?.message || 'Unable to load enrollment periods.');
            }

            const rows = Array.isArray(result.items) ? result.items : [];
            const invalidDateRows = rows.filter((row) => {
                const start = parseYmd(row?.startDate);
                const end = parseYmd(row?.endDate);
                return Boolean(start && end && end < start);
            });

            const grouped = new Map();
            rows.forEach((row) => {
                const sid = String(row?.studentId || '').trim();
                if (!sid) return;
                if (!grouped.has(sid)) grouped.set(sid, []);
                grouped.get(sid).push(row);
            });

            const overlaps = [];
            grouped.forEach((studentRows, studentId) => {
                const normalized = studentRows.slice().sort((a, b) => String(a?.startDate || '').localeCompare(String(b?.startDate || '')));
                for (let i = 0; i < normalized.length; i += 1) {
                    const left = normalized[i];
                    const leftStart = parseYmd(left?.startDate);
                    const leftEnd = parseYmd(left?.endDate) || new Date('9999-12-31T00:00:00.000Z');
                    if (!leftStart) continue;
                    for (let j = i + 1; j < normalized.length; j += 1) {
                        const right = normalized[j];
                        const rightStart = parseYmd(right?.startDate);
                        const rightEnd = parseYmd(right?.endDate) || new Date('9999-12-31T00:00:00.000Z');
                        if (!rightStart) continue;
                        if (rightStart > leftEnd) break;
                        if (leftStart <= rightEnd && rightStart <= leftEnd) {
                            overlaps.push({ studentId, leftId: left?.id || '', rightId: right?.id || '' });
                        }
                    }
                }
            });

            const classClosed = !!isClosedEnrollmentInput?.checked;
            const closedViolations = classClosed
                ? rows.filter((row) => openEnrollmentStatuses.has(toStatusToken(row?.status)))
                : [];

            const issues = [];
            if (invalidDateRows.length) issues.push(`${invalidDateRows.length} period(s) have endDate before startDate.`);
            if (overlaps.length) issues.push(`${overlaps.length} overlapping period pair(s) found for same student/class.`);
            if (closedViolations.length) issues.push(`${closedViolations.length} open period(s) exist while class is marked closed for new enrollment.`);

            const formatPeriodRef = (row) => {
                const pid = String(row?.id || '').trim() || '(no-id)';
                const sid = String(row?.studentId || '').trim() || '(no-student)';
                const start = String(row?.startDate || '').trim() || '?';
                const end = String(row?.endDate || '').trim() || 'Open';
                const st = String(row?.status || '').trim() || '-';
                return `${pid} | Student: ${sid} | ${start} -> ${end} | ${st}`;
            };

            const overlapRowsById = new Map(rows.map((row) => [String(row?.id || '').trim(), row]));
            const overlapDetails = overlaps.map((entry) => {
                const left = overlapRowsById.get(String(entry.leftId || '').trim()) || null;
                const right = overlapRowsById.get(String(entry.rightId || '').trim()) || null;
                return {
                    studentId: String(entry.studentId || '').trim() || '(no-student)',
                    left: left ? formatPeriodRef(left) : String(entry.leftId || '(unknown-left)'),
                    right: right ? formatPeriodRef(right) : String(entry.rightId || '(unknown-right)')
                };
            });

            const topInvalid = invalidDateRows.slice(0, 10);
            const topOverlap = overlapDetails.slice(0, 10);
            const topClosed = closedViolations.slice(0, 10);

            const sections = [];
            sections.push(`<div><b>Total periods checked:</b> ${rows.length}</div>`);
            sections.push(`<div><b>Students involved:</b> ${grouped.size}</div>`);
            sections.push('<hr class="my-2">');

            if (invalidDateRows.length) {
                sections.push(`<div class="fw-bold text-danger mb-1">End Date Before Start Date (${invalidDateRows.length})</div>`);
                sections.push('<ul class="mb-2 ps-3">');
                topInvalid.forEach((row) => sections.push(`<li>${formatPeriodRef(row)}</li>`));
                sections.push('</ul>');
                if (invalidDateRows.length > topInvalid.length) {
                    sections.push(`<div class="small text-muted mb-2">+${invalidDateRows.length - topInvalid.length} more row(s)</div>`);
                }
            }

            if (overlapDetails.length) {
                sections.push(`<div class="fw-bold text-danger mb-1">Overlapping Periods (${overlapDetails.length})</div>`);
                sections.push('<ul class="mb-2 ps-3">');
                topOverlap.forEach((item) => {
                    sections.push(`<li><div><b>Student:</b> ${item.studentId}</div><div class="small">${item.left}</div><div class="small">${item.right}</div></li>`);
                });
                sections.push('</ul>');
                if (overlapDetails.length > topOverlap.length) {
                    sections.push(`<div class="small text-muted mb-2">+${overlapDetails.length - topOverlap.length} more overlap pair(s)</div>`);
                }
            }

            if (closedViolations.length) {
                sections.push(`<div class="fw-bold text-warning-emphasis mb-1">Open Periods While Class Is Closed (${closedViolations.length})</div>`);
                sections.push('<ul class="mb-2 ps-3">');
                topClosed.forEach((row) => sections.push(`<li>${formatPeriodRef(row)}</li>`));
                sections.push('</ul>');
                if (closedViolations.length > topClosed.length) {
                    sections.push(`<div class="small text-muted mb-2">+${closedViolations.length - topClosed.length} more row(s)</div>`);
                }
            }

            if (!issues.length) {
                sections.push('<div class="text-success fw-semibold">No rolling integrity issues were found. Current enrollment periods are consistent.</div>');
            } else {
                sections.push('<div class="small text-muted mt-2">Suggested fix: edit affected periods (dates/status), then run the check again.</div>');
            }

            const summary = issues.length
                ? `Rolling integrity check found issues:<br>${issues.map((row) => `- ${row}`).join('<br>')}`
                : 'No rolling integrity issues were found in current enrollment periods.';
            const detailedHtml = sections.join('');

            if (rollingIntegritySummary) {
                rollingIntegritySummary.textContent = issues.length
                    ? `${issues.join(' | ')}`
                    : 'No issues found. Rolling periods are consistent.';
                rollingIntegritySummary.className = issues.length ? 'small text-danger fw-semibold' : 'small text-success fw-semibold';
            }

            if (typeof showMessageModal === 'function') {
                await showMessageModal({
                    title: issues.length ? 'Rolling Integrity Issues' : 'Rolling Integrity Passed',
                    icon: issues.length ? 'warning' : 'success',
                    message: detailedHtml || summary,
                    buttons: [{ text: 'OK', class: issues.length ? 'btn-warning' : 'btn-success' }]
                });
            } else {
                await uiAlert(detailedHtml || summary, issues.length ? 'Rolling Integrity Issues' : 'Rolling Integrity Passed');
            }
        } catch (error) {
            if (rollingIntegritySummary) {
                rollingIntegritySummary.textContent = error?.message || 'Rolling integrity check failed.';
                rollingIntegritySummary.className = 'small text-danger fw-semibold';
            }
            await uiAlert(error?.message || 'Rolling integrity check failed.', 'Rolling Integrity');
        } finally {
            if (actionBtn) {
                actionBtn.disabled = false;
                actionBtn.innerHTML = originalText || '<i class="bi bi-shield-check me-1"></i>Check Rolling Integrity';
            }
        }
    }

    async function findOpenPeriodsForClosedClassCheck() {
        if (!classId) return [];
        const resp = await fetch(`/school/classes/api/${encodeURIComponent(classId)}/enrollment-periods`, {
            headers: { 'X-AJAX-Request': 'true' }
        });
        const result = await resp.json();
        if (!resp.ok || result?.status !== 'success') {
            throw new Error(result?.message || 'Unable to verify existing enrollment periods.');
        }
        const rows = Array.isArray(result.items) ? result.items : [];
        return rows.filter((row) => openEnrollmentStatuses.has(toStatusToken(row?.status)));
    }

