    function renderPostingTemplateRows() {
        normalizePostingTemplateState();
        const tbody = document.getElementById('postingTemplateTbody');
        if (!tbody) return;
        if (!postingTemplateState.length) {
            tbody.innerHTML = isChargeableClass()
                ? '<tr><td colspan="4" class="text-center text-muted small py-3">No Posting Policies added yet. Add at least an All Categories policy.</td></tr>'
                : '<tr><td colspan="4" class="text-center text-muted small py-3">No-Charge class: posting policies are optional and not used.</td></tr>';
