        const hasConflict = options.conflict === true;
        const colorBg = normalizeHexColor(meta?.colorBg, statusCode === 'holiday' ? '#fff3cd' : '#e2e3e5');
        const colorBorder = normalizeHexColor(meta?.colorBorder, statusCode === 'holiday' ? '#ffe69c' : '#c6c8ca');
        const baseLayer = `linear-gradient(${colorToRgba(colorBg, 0.22, colorBg)}, ${colorToRgba(colorBg, 0.22, colorBg)})`;
        const lockLayer = isLocked
            ? `, repeating-linear-gradient(-45deg, ${colorToRgba('#6c757d', 0.08, '#6c757d')} 0 10px, ${colorToRgba('#adb5bd', 0.18, '#adb5bd')} 10px 20px)`
            : '';
        return {
            className: [
                'session-status-row',
                isLocked ? 'session-status-row-locked' : '',
                hasConflict ? 'session-status-row-conflict' : ''
            ].filter(Boolean).join(' '),
            style: [
                `background-color:${colorToRgba(colorBg, isLocked ? 0.16 : 0.22, colorBg)}`,
                `background-image:${baseLayer}${lockLayer}`,
                `border-left:4px solid ${isLocked ? '#6c757d' : colorBorder}`
