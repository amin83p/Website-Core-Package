                    throw new Error('Select a program first.');
                }
                const rolling = isRollingMode();
                const selectedTermId = String(document.getElementById('eligibility_termId').value || '').trim();
                if (!selectedTermId && !rolling) {
                    throw new Error('Select a term from the chosen program.');
                }
                let programTerm = null;
                if (selectedTermId) {
                    programTerm = (pendingEligibilityProgram.terms || []).find((term) => String(term?.termId || term?.id || '').trim() === selectedTermId);
                    if (!programTerm) {
                        throw new Error('Selected term is not defined on the chosen program.');
                    }
                }
                const duplicate = allowedProgramTermsState.some((row) => {
                    if (row.programId !== pendingEligibilityProgram.programId) return false;
                    const rowTerm = String(row.termId || '').trim();
                    return rowTerm === selectedTermId;
                });
                if (duplicate) {
                    throw new Error('This program and term combination is already in the list.');
                }
                allowedProgramTermsState.push({
                    programId: pendingEligibilityProgram.programId,
                    termId: selectedTermId,
                    order: allowedProgramTermsState.length + 1,
                    programCode: pendingEligibilityProgram.programCode,
                    programName: pendingEligibilityProgram.programName,
                    termCode: programTerm ? String(programTerm.termCode || programTerm.code || '').trim().toUpperCase() : '',
                    termName: programTerm ? String(programTerm.termName || programTerm.name || selectedTermId).trim() : '',
