            GenericPicker.open(GenericPickerPresets.class({
                title: 'Copy From Class',
                icon: 'bi-copy',
                placeholder: 'Search classes to copy...',
                context: GenericPickerContexts.activeOrganizationScope({ label: 'Active Organization' }),
                renderer: classTemplateRenderer,
                onSelect: async (item) => {
                    const sourceClassId = String(item?.id || '').trim();
                    if (!sourceClassId) return;
                    if (classId && String(classId) === sourceClassId) {
                        await uiAlert('Select a different class to copy from.', 'Copy From Class');
                        return;
                    }
                    try {
                        const response = await fetch(`/school/classes/api/template/${encodeURIComponent(sourceClassId)}`, {
                            headers: { 'X-AJAX-Request': 'true' }
                        });
                        const result = await response.json();
                        if (!response.ok || result?.status === 'error') {
                            throw new Error(result?.message || 'Failed to load class template.');
                        }
                        applyClassTemplate(result.template || {});
                        await uiAlert(`Class data was copied from ${sourceClassId}. Sessions were not copied, so you can generate a new session plan.`, 'Template Applied');
                    } catch (error) {
                        await uiAlert(error.message || 'Failed to copy class data.', 'Copy Failed');
                    }
                }
            }));
        });
    }

