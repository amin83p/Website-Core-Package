<%
  const c = classData || {};
  const lifecycle = lifecycleContext || {};
  const isRolling = String(c.registrationMode || '').trim().toLowerCase() === 'rolling';
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
%>

<style>
  .cycle-rollover-page .card-body {
    padding: 0.9rem 1rem;
  }
  .cycle-rollover-page .form-label {
    margin-bottom: 0.2rem;
    font-size: 0.82rem;
    font-weight: 600;
  }
  .cycle-rollover-page .compact-help {
    font-size: 0.74rem;
  }
  .cycle-rollover-page .table-sm thead th {
    font-size: 0.78rem;
    white-space: nowrap;
  }
  .cycle-rollover-page kbd {
    background: #f1f3f5;
    color: #495057;
    border: 1px solid #dee2e6;
    font-size: 0.7rem;
    padding: 0.08rem 0.3rem;
    border-radius: 0.25rem;
  }
</style>

<div class="sections-page cycle-rollover-page">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
      <h1 class="page-heading size-md m-0">Cycle Rollover Wizard</h1>
      <div class="text-muted">
        <span class="fw-semibold"><%= c.title || c.id %></span>
        <span class="font-monospace ms-2"><%= c.id || '' %></span>
      </div>
      <div class="d-flex flex-wrap gap-2 mt-2">
        <span class="badge <%= isRolling ? 'bg-warning-subtle text-warning-emphasis border border-warning-subtle' : 'bg-light text-dark border' %>">
          <%= isRolling ? 'Rolling' : 'Term-Based' %>
        </span>
        <span class="badge bg-info-subtle text-info border border-info-subtle">Active Periods: <%= Number(lifecycle.activePeriodCount || 0) %></span>
        <span class="badge bg-light text-dark border">Open Periods: <%= Number(lifecycle.openPeriodCount || 0) %></span>
      </div>
      <% if (lifecycle.previousClass || lifecycle.nextClass) { %>
        <div class="small text-muted mt-2">
          <% if (lifecycle.previousClass) { %>
            Previous:
            <a href="/school/classes/edit/<%= encodeURIComponent(lifecycle.previousClass.id) %>"><%= lifecycle.previousClass.title || lifecycle.previousClass.id %></a>
          <% } %>
          <% if (lifecycle.previousClass && lifecycle.nextClass) { %><span class="mx-2">|</span><% } %>
          <% if (lifecycle.nextClass) { %>
            Next:
            <a href="/school/classes/edit/<%= encodeURIComponent(lifecycle.nextClass.id) %>"><%= lifecycle.nextClass.title || lifecycle.nextClass.id %></a>
          <% } %>
        </div>
      <% } %>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <a href="/school/classes/<%= encodeURIComponent(c.id || '') %>/rolling-enrollment" class="btn btn-outline-primary btn-sm"><i class="bi bi-people me-1"></i>Rolling Enrollment</a>
      <a href="/school/classes/edit/<%= encodeURIComponent(c.id || '') %>" class="btn btn-outline-secondary btn-sm"><i class="bi bi-pencil-square me-1"></i>Class Form</a>
      <a href="/school/classes" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left me-1"></i>Classes</a>
    </div>
  </div>

  <% if (!isRolling) { %>
    <div class="alert alert-warning border shadow-sm mb-3">
      This class is not in <b>Rolling</b> mode. Switch Registration Mode in Class Form before using cycle rollover.
    </div>
  <% } %>

  <div class="row g-3">
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <h6 class="fw-bold text-primary mb-2"><i class="bi bi-sliders2 me-1"></i>Rollover Inputs</h6>
          <input type="hidden" id="hid_actionStateId" value="<%= asid %>">
          <div class="mb-2">
            <label class="form-label">Next Cycle Start Date *</label>
            <input type="date" id="inp_cycleStartDate" class="form-control" <%= isRolling ? '' : 'disabled' %>>
          </div>
          <div class="mb-2">
            <label class="form-label">Next Cycle End Date</label>
            <input type="date" id="inp_cycleEndDate" class="form-control" <%= isRolling ? '' : 'disabled' %>>
          </div>
          <div class="mb-2">
            <label class="form-label">Current Cycle End Date</label>
            <input type="date" id="inp_currentCycleEndDate" class="form-control" value="<%= c.cycleEndDate || '' %>" <%= isRolling ? '' : 'disabled' %>>
          </div>
          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="inp_closeCurrentCycle" checked <%= isRolling ? '' : 'disabled' %>>
            <label class="form-check-label" for="inp_closeCurrentCycle">Close current cycle during execution</label>
          </div>
          <div class="form-check form-switch mb-2">
            <input class="form-check-input" type="checkbox" id="inp_carryForward" checked <%= isRolling ? '' : 'disabled' %>>
            <label class="form-check-label" for="inp_carryForward">Carry-forward eligible students</label>
          </div>
          <div class="mb-3">
            <label class="form-label">Next Cycle Status</label>
            <select id="inp_nextCycleStatus" class="form-select" <%= isRolling ? '' : 'disabled' %>>
              <option value="active" selected>Active</option>
              <option value="draft">Draft</option>
              <option value="cancelled">Cancelled</option>
            </select>
          </div>
          <div class="d-grid gap-2">
            <button type="button" class="btn btn-outline-primary btn-sm" id="btn_previewRollover" <%= isRolling ? '' : 'disabled' %>>
              <i class="bi bi-search me-1"></i>Preview Rollover
            </button>
            <button type="button" class="btn btn-filled btn-warning btn-sm" id="btn_executeRollover" disabled>
              <i class="bi bi-play-circle me-1"></i>Execute Create + Carry-Forward
            </button>
          </div>
          <div class="compact-help text-muted mt-2">
            Execution is enabled after a valid preview.
            <span class="ms-1"><kbd>Alt</kbd>+<kbd>P</kbd> preview, <kbd>Alt</kbd>+<kbd>E</kbd> execute, <kbd>Enter</kbd> preview from date fields.</span>
          </div>
        </div>
      </div>
    </div>
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <h6 class="fw-bold text-primary mb-2"><i class="bi bi-eye me-1"></i>Preview Summary</h6>
          <div id="previewSummary" class="text-muted small">Run preview to load next-cycle, carry-forward, and issue details.</div>
        </div>
      </div>
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-body">
          <h6 class="fw-bold text-primary mb-2"><i class="bi bi-exclamation-triangle me-1"></i>Preview Issues</h6>
          <div id="previewIssues" class="small text-muted">No preview yet.</div>
        </div>
      </div>
      <div class="card border-0 shadow-sm">
        <div class="card-body">
          <h6 class="fw-bold text-primary mb-2"><i class="bi bi-people me-1"></i>Carry-Forward Student Preview</h6>
          <div class="table-responsive border rounded">
            <table class="table table-sm mb-0 align-middle">
              <thead class="table-light">
                <tr>
                  <th>Student / ID</th>
                  <th>Open Periods</th>
                  <th>Split Across Boundary</th>
                  <th>Move Whole</th>
                  <th>Ineligible</th>
                </tr>
              </thead>
              <tbody id="tbody_studentPreview">
                <tr><td colspan="5" class="text-center py-3 text-muted">No preview yet.</td></tr>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
(() => {
  const classId = <%- JSON.stringify(String(c.id || '')) %>;
  const isRolling = <%- JSON.stringify(Boolean(isRolling)) %>;
  const actionStateId = <%- JSON.stringify(String(asid || '')) %>;
  let latestPreview = null;

  const qs = (id) => document.getElementById(id);
  const btnPreview = qs('btn_previewRollover');
  const btnExecute = qs('btn_executeRollover');

  function htmlEscape(value) {
    return String(value == null ? '' : value)
      .replaceAll('&', '&amp;')
      .replaceAll('<', '&lt;')
      .replaceAll('>', '&gt;')
      .replaceAll('"', '&quot;')
      .replaceAll("'", '&#39;');
  }

  function getInputPayload() {
    return {
      cycleStartDate: String(qs('inp_cycleStartDate')?.value || '').trim(),
      cycleEndDate: String(qs('inp_cycleEndDate')?.value || '').trim(),
      currentCycleEndDate: String(qs('inp_currentCycleEndDate')?.value || '').trim(),
      closeCurrentCycle: Boolean(qs('inp_closeCurrentCycle')?.checked),
      carryForwardEligibleStudents: Boolean(qs('inp_carryForward')?.checked),
      nextCycleStatus: String(qs('inp_nextCycleStatus')?.value || 'active').trim()
    };
  }

  function oneDayAfter(dateText) {
    const raw = String(dateText || '').trim();
    if (!raw || !/^\d{4}-\d{2}-\d{2}$/.test(raw)) return '';
    const d = new Date(raw + 'T00:00:00');
    if (Number.isNaN(d.getTime())) return '';
    d.setDate(d.getDate() + 1);
    return d.toISOString().slice(0, 10);
  }

  function showBusy(message = 'Please wait...') {
    if (typeof window.showLoading === 'function') window.showLoading(message);
  }

  function hideBusy() {
    if (typeof window.hideLoading === 'function') window.hideLoading();
  }

  async function showMsg(title, icon, message) {
    if (typeof window.showMessageModal === 'function') {
      await window.showMessageModal({ title, icon, message });
      return;
    }
    console.log(title + ': ' + message);
  }

  async function requestJson(url, method = 'POST', payload = null) {
    const upperMethod = String(method || 'POST').toUpperCase();
    const isMutating = ['POST', 'PUT', 'PATCH', 'DELETE'].includes(upperMethod);
    const normalizedPayload = (payload && typeof payload === 'object') ? { ...payload } : payload;
    if (isMutating && actionStateId && normalizedPayload && typeof normalizedPayload === 'object' && !normalizedPayload.actionStateId) {
      normalizedPayload.actionStateId = actionStateId;
    }
    const urlWithActionState = (!isMutating && actionStateId)
      ? `${url}${url.includes('?') ? '&' : '?'}actionStateId=${encodeURIComponent(actionStateId)}`
      : url;
    const headers = { 'X-AJAX-Request': 'true', 'Content-Type': 'application/json' };
    if (actionStateId) headers['X-Action-State-Id'] = actionStateId;
    const response = await fetch(urlWithActionState, {
      method: upperMethod,
      headers,
      body: normalizedPayload ? JSON.stringify(normalizedPayload) : undefined
    });
    const result = await response.json().catch(() => ({}));
    if (window.applyGuardedApiResult) {
      const wrapped = await window.applyGuardedApiResult(result, {
        busyTitle: 'Operation In Progress',
        replayTitle: 'Already Processed'
      });
      if (wrapped.stop) return null;
    }
    if (!response.ok || String(result.status || '').toLowerCase() === 'error') {
      throw new Error(result?.message || 'Request failed.');
    }
    return result;
  }

  function renderPreview(preview) {
    latestPreview = preview || null;
    const summaryEl = qs('previewSummary');
    const issuesEl = qs('previewIssues');
    const studentTbody = qs('tbody_studentPreview');
    const carry = preview?.carryForwardPreview || {};
    const boundary = preview?.boundary || {};
    const issueRows = Array.isArray(preview?.issues) ? preview.issues : [];
    const studentRows = Array.isArray(carry.students) ? carry.students : [];
    const hasBlockingIssues = issueRows.some((row) => String(row?.level || 'error').toLowerCase() === 'error');

    summaryEl.innerHTML = `
      <div class="row g-2">
        <div class="col-md-6">
          <div><b>Next Title:</b> ${htmlEscape(preview?.nextCycle?.titleSuggestion || '-')}</div>
          <div><b>Cycle #:</b> ${htmlEscape(String(preview?.nextCycle?.cycleNo || '-'))}</div>
          <div><b>Group:</b> ${htmlEscape(preview?.nextCycle?.cycleGroupId || '-')}</div>
        </div>
        <div class="col-md-6">
          <div><b>Boundary:</b> ${htmlEscape(boundary?.currentCycleEndDate || '-')} -> ${htmlEscape(boundary?.cycleStartDate || '-')}</div>
          <div><b>Open Periods:</b> ${htmlEscape(String(carry.openPeriodCount || 0))}</div>
          <div><b>Split:</b> ${htmlEscape(String(carry.splitCount || 0))} | <b>Move:</b> ${htmlEscape(String(carry.moveWholeCount || 0))} | <b>Ineligible:</b> ${htmlEscape(String(carry.ineligibleCount || 0))}</div>
        </div>
      </div>
    `;

    if (!issueRows.length) {
      issuesEl.innerHTML = '<span class="text-success">No blocking issues detected in preview.</span>';
    } else {
      issuesEl.innerHTML = issueRows.map((row) => `
        <div class="mb-1 ${String(row?.level || '').toLowerCase() === 'error' ? 'text-danger' : 'text-warning'}">
          <i class="bi ${String(row?.level || '').toLowerCase() === 'error' ? 'bi-x-circle' : 'bi-exclamation-circle'} me-1"></i>
          ${htmlEscape(String(row?.message || 'Issue'))}
          ${row?.periodId ? `<span class="font-monospace ms-1">(${htmlEscape(String(row.periodId))})</span>` : ''}
        </div>
      `).join('');
    }

    if (!studentRows.length) {
      studentTbody.innerHTML = '<tr><td colspan="5" class="text-center py-3 text-muted">No candidate students found.</td></tr>';
    } else {
      studentTbody.innerHTML = studentRows.map((row) => `
        <tr>
          <td class="font-monospace">${htmlEscape(String(row.studentId || '-'))}</td>
          <td>${htmlEscape(String(row.periodCount || 0))}</td>
          <td>${htmlEscape(String(row.splitCount || 0))}</td>
          <td>${htmlEscape(String(row.moveWholeCount || 0))}</td>
          <td>${htmlEscape(String(row.ineligibleCount || 0))}</td>
        </tr>
      `).join('');
    }

    btnExecute.disabled = !isRolling || !preview || hasBlockingIssues;
    if (!btnExecute.disabled) btnExecute.focus();
  }

  async function runPreview() {
    if (!isRolling) return;
    const payload = getInputPayload();
    if (!payload.cycleStartDate) {
      await showMsg('Missing Input', 'warning', 'Next Cycle Start Date is required.');
      return;
    }
    try {
      showBusy('Generating rollover preview...');
      const result = await requestJson(`/school/classes/api/${encodeURIComponent(classId)}/cycles/preview-rollover`, 'POST', payload);
      if (!result) return;
      renderPreview(result.data || null);
      await showMsg('Preview Ready', 'success', result.message || 'Rollover preview generated.');
    } catch (error) {
      await showMsg('Preview Failed', 'error', error.message || 'Unable to preview rollover.');
    } finally {
      hideBusy();
    }
  }

  async function executeRollover() {
    if (!isRolling) return;
    const payload = getInputPayload();
    if (!payload.cycleStartDate) {
      await showMsg('Missing Input', 'warning', 'Next Cycle Start Date is required.');
      return;
    }
    try {
      showBusy('Executing cycle rollover...');
      const result = await requestJson(`/school/classes/api/${encodeURIComponent(classId)}/cycles/create-next`, 'POST', payload);
      if (!result) return;
      const createdClassId = String(result?.data?.createdClass?.id || '').trim();
      const msg = [
        htmlEscape(String(result.message || 'Cycle rollover completed.')),
        createdClassId ? `<br><br><a class="btn btn-sm btn-outline-primary" href="/school/classes/edit/${encodeURIComponent(createdClassId)}">Open New Cycle Class</a>` : ''
      ].join('');
      await showMsg('Rollover Completed', 'success', msg);
      await runPreview();
    } catch (error) {
      await showMsg('Execute Failed', 'error', error.message || 'Unable to execute rollover.');
    } finally {
      hideBusy();
    }
  }

  function bindKeyboardFlow() {
    const previewOnEnterIds = ['inp_cycleStartDate', 'inp_cycleEndDate', 'inp_currentCycleEndDate', 'inp_nextCycleStatus'];
    previewOnEnterIds.forEach((id) => {
      const el = qs(id);
      if (!el) return;
      el.addEventListener('keydown', (event) => {
        if (event.key !== 'Enter' || event.shiftKey || event.ctrlKey || event.altKey || event.metaKey) return;
        event.preventDefault();
        btnPreview?.click();
      });
    });

    document.addEventListener('keydown', (event) => {
      const key = String(event.key || '').toLowerCase();
      if (event.altKey && key === 'p') {
        event.preventDefault();
        btnPreview?.click();
        return;
      }
      if (event.altKey && key === 'e') {
        event.preventDefault();
        if (!btnExecute?.disabled) btnExecute.click();
        return;
      }
      if (event.key === 'Enter' && event.ctrlKey) {
        if (!btnExecute?.disabled) {
          event.preventDefault();
          btnExecute.click();
        }
      }
    });
  }

  function primeDefaultCycleStartDate() {
    const startEl = qs('inp_cycleStartDate');
    const currentEnd = String(qs('inp_currentCycleEndDate')?.value || '').trim();
    if (!startEl || String(startEl.value || '').trim()) return;
    const suggested = oneDayAfter(currentEnd);
    if (suggested) startEl.value = suggested;
  }

  btnPreview?.addEventListener('click', runPreview);
  btnExecute?.addEventListener('click', executeRollover);
  primeDefaultCycleStartDate();
  bindKeyboardFlow();
})();
</script>
