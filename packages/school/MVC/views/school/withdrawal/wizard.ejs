<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-heading size-md m-0">
      New Withdrawal
    </h1>
  </div>

  <div class="form-container wide" style="max-width: 1400px;">
  <input type="hidden" id="withdrawalActionStateId" value="<%= typeof actionStateId !== 'undefined' ? actionStateId : '' %>">
  <div id="withdrawalWizardGuideMount" class="mb-3"></div>

  <div class="row" id="wizardLayoutRow">
    <div class="col-lg-4 mb-4" id="wizardStepsColumn">
      <div class="card border-0 shadow-sm sticky-top" style="top: 80px;">
        <div class="card-header bg-white py-3">
          <h5 class="fw-bold mb-0"><i class="bi bi-list-ol me-2"></i>Steps</h5>
        </div>
        <div class="card-body p-0">
          <ul class="list-group list-group-flush" id="stepsList">
            <li class="list-group-item d-flex align-items-center step-item active" data-step="1">
              <span class="step-number me-3">1</span>
              <div>
                <div class="fw-bold">Select Student</div>
                <div class="small text-muted">Choose the student to withdraw</div>
              </div>
            </li>
            <li class="list-group-item d-flex align-items-center step-item" data-step="2">
              <span class="step-number me-3">2</span>
              <div>
                <div class="fw-bold">Select Registration</div>
                <div class="small text-muted">Choose class, term, or program</div>
              </div>
            </li>
            <li class="list-group-item d-flex align-items-center step-item" data-step="3">
              <span class="step-number me-3">3</span>
              <div>
                <div class="fw-bold">Review Impact</div>
                <div class="small text-muted">Financial and academic impact</div>
              </div>
            </li>
            <li class="list-group-item d-flex align-items-center step-item" data-step="4">
              <span class="step-number me-3">4</span>
              <div>
                <div class="fw-bold">Confirm</div>
                <div class="small text-muted">Execute withdrawal</div>
              </div>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="col-lg-8" id="wizardContentColumn">
      <!-- Step 1: Select Student -->
      <div class="step-content" data-step="1">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white py-3">
            <h5 class="fw-bold mb-0"><i class="bi bi-person-circle me-2"></i>Select Student</h5>
          </div>
          <div class="card-body">
            <div class="mb-3">
              <label class="form-label fw-bold">Student <span class="text-danger">*</span></label>
              <div class="input-group">
                <input type="text" id="selectedStudentDisplay" class="form-control" placeholder="Click to select a student..." readonly>
                <input type="hidden" id="selectedStudentId">
                <button type="button" class="btn btn-primary" id="btnPickStudent">
                  <i class="bi bi-search me-1"></i>Pick
                </button>
                <button type="button" class="btn btn-outline-secondary d-none" id="btnClearStudent">
                  <i class="bi bi-x-lg"></i>
                </button>
              </div>
            </div>
            <div id="studentStatus" class="d-none">
              <div class="alert alert-info mb-3">
                <i class="bi bi-info-circle me-2"></i>Loading student enrollment status...
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 2: Select Registration -->
      <div class="step-content d-none" data-step="2">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white py-3">
            <h5 class="fw-bold mb-0"><i class="bi bi-card-checklist me-2"></i>Select What to Withdraw</h5>
          </div>
          <div class="card-body">
            <ul class="nav nav-pills mb-4" id="withdrawalTypeNav">
              <li class="nav-item">
                <button class="nav-link active" data-type="class">
                  <i class="bi bi-easel2 me-1"></i>Class
                </button>
              </li>
              <li class="nav-item">
                <button class="nav-link" data-type="term">
                  <i class="bi bi-calendar3 me-1"></i>Term
                </button>
              </li>
              <li class="nav-item">
                <button class="nav-link" data-type="program">
                  <i class="bi bi-journal-text me-1"></i>Program
                </button>
              </li>
            </ul>

            <div class="mb-4">
              <label class="form-label fw-bold">Select <span id="typeLabel">Class</span> <span class="text-danger">*</span></label>
              <div id="registrationOptions" class="border rounded p-2" style="max-height: 300px; overflow-y: auto;">
                <div class="text-center text-muted py-4">
                  <i class="bi bi-hourglass-split fs-2"></i>
                  <p class="mb-0">Loading registrations...</p>
                </div>
              </div>
            </div>

            <hr class="my-4">

            <div class="mb-3">
              <label class="form-label fw-bold">Withdrawal Reason <span class="text-danger">*</span></label>
              <select id="reasonSelect" class="form-select">
                <option value="">-- Select Reason --</option>
                <% reasons.forEach(r => { %>
                  <option value="<%= r.value %>"><%= r.label %></option>
                <% }) %>
              </select>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold">Reason Details</label>
              <textarea id="reasonDetail" class="form-control" rows="3" placeholder="Provide additional details..."></textarea>
            </div>

            <div class="mb-3">
              <label class="form-label fw-bold">Effective Date</label>
              <input type="date" id="effectiveDate" class="form-control" value="<%= new Date().toISOString().slice(0, 10) %>">
            </div>
          </div>
        </div>
      </div>

      <!-- Step 3: Review Impact -->
      <div class="step-content d-none" data-step="3">
        <div class="card border-0 shadow-sm">
          <div class="card-header bg-white py-3">
            <h5 class="fw-bold mb-0"><i class="bi bi-search me-2"></i>Review Withdrawal Impact</h5>
          </div>
          <div class="card-body">
            <div id="previewLoading" class="text-center py-5">
              <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
              </div>
              <p class="text-muted mt-2">Calculating impact...</p>
            </div>
            <div id="previewContent" class="d-none"></div>
            <div id="previewError" class="d-none">
              <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle me-2"></i>
                <span id="previewErrorMessage"></span>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Step 4: Confirm -->
      <div class="step-content d-none" data-step="4">
        <div class="card border-0 shadow-sm">
          <div class="card-body text-center py-5">
            <div id="executeConfirm">
              <div class="rounded-circle bg-danger-subtle text-danger d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="bi bi-shield-check fs-1"></i>
              </div>
              <h4>Confirm Withdrawal</h4>
              <p class="text-muted">Review the final summary and execute only when you are ready.</p>
              <div class="alert alert-light border text-start mx-auto mb-4" style="max-width: 760px;" id="executeConfirmSummary"></div>
              <div class="d-flex justify-content-center gap-2 flex-wrap">
                <button type="button" class="btn btn-filled btn-primary btn-md" id="btnExecuteWithdrawal">
                  Submit / Execute
                </button>
              </div>
            </div>
            <div id="executeLoading" class="d-none">
              <div class="spinner-border text-danger mb-3" style="width: 3rem; height: 3rem;" role="status">
                <span class="visually-hidden">Processing...</span>
              </div>
              <h4>Processing Withdrawal</h4>
              <p class="text-muted">Please wait while the withdrawal is being processed...</p>
            </div>
            <div id="executeSuccess" class="d-none">
              <div class="rounded-circle bg-success-subtle text-success d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="bi bi-check-lg fs-1"></i>
              </div>
              <h4>Withdrawal Completed</h4>
              <p class="text-muted" id="successMessage">The withdrawal has been successfully processed.</p>
              <div class="mt-4">
                <a href="/school/withdrawal" class="btn btn-primary me-2">
                  <i class="bi bi-speedometer2 me-1"></i>Dashboard
                </a>
                <a href="#" id="viewWithdrawalLink" class="btn btn-outline-primary">
                  <i class="bi bi-eye me-1"></i>View Details
                </a>
              </div>
            </div>
            <div id="executeError" class="d-none">
              <div class="rounded-circle bg-danger-subtle text-danger d-inline-flex align-items-center justify-content-center mb-3" style="width: 80px; height: 80px;">
                <i class="bi bi-x-lg fs-1"></i>
              </div>
              <h4>Withdrawal Failed</h4>
              <p class="text-danger" id="errorMessage">An error occurred during the withdrawal process.</p>
              <div id="duplicateRequestActions" class="d-none mb-3"></div>
              <div class="mt-4">
                <button type="button" class="btn btn-danger" id="btnRetry">
                  <i class="bi bi-arrow-repeat me-1"></i>Retry
                </button>
                <a href="/school/withdrawal" class="btn btn-outline-secondary ms-2">
                  <i class="bi bi-x me-1"></i>Cancel
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  <div class="withdrawal-wizard-controls d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
    <div class="wizard-step-label" id="wizardCurrentLabel"></div>
    <div class="d-flex gap-2">
      <button type="button" class="btn btn-outline-secondary btn-sm" id="wizardPrevBtn"><i class="bi bi-arrow-left me-1"></i>Previous</button>
      <button type="button" class="btn btn-primary btn-sm" id="wizardNextBtn">Next<i class="bi bi-arrow-right ms-1"></i></button>
    </div>
  </div>
  <hr>
  <div class="button-row d-flex justify-content-end">
    <a href="/school/withdrawal" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction">Cancel</a>
  </div>
  </div>
</div>

<%- include('../../partials/modal_GenericPicker', { user }) %>

<style>
  #withdrawalWizardGuide {
    font-size: 1rem;
  }
  #withdrawalWizardGuide .small {
    font-size: 1rem !important;
  }
  .wizard-step-rail {
    display: flex;
    gap: 0.5rem;
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    padding-bottom: 0.25rem;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .wizard-step-rail::-webkit-scrollbar {
    display: none;
  }
  #withdrawalWizardGuide .wizard-step-pill {
    flex: 0 0 auto;
    white-space: nowrap;
    border: 1px solid #c8d1dc;
    background: #f8fafc;
    color: #17324d;
    font-weight: 600;
    font-size: 1rem;
    border-radius: 999px;
    padding: 0.35rem 0.8rem;
    transition: all 0.2s ease;
  }
  #withdrawalWizardGuide .wizard-step-pill.active {
    background: #17324d;
    color: #fff;
    border-color: #17324d;
  }
  #withdrawalWizardGuide .wizard-step-pill.completed {
    background: #e8f5ee;
    border-color: #95d5b2;
    color: #1b6f4a;
  }
  #withdrawalWizardGuide .wizard-progress {
    height: 0.35rem;
    background: #e8edf3;
    border-radius: 999px;
    overflow: hidden;
  }
  #withdrawalWizardGuide .wizard-progress-bar {
    height: 100%;
    background: linear-gradient(90deg, #17324d 0%, #2f5d8a 100%);
    width: 0;
    transition: width 0.25s ease;
  }
  .withdrawal-wizard-controls {
    background: #f8fafc;
    border: 1px solid #d5dee8;
    border-radius: 0.75rem;
    font-size: 1rem;
    padding: 0.75rem 1rem;
  }
  .withdrawal-wizard-controls .wizard-step-label {
    color: #17324d;
    font-weight: 600;
  }
  #wizardPrevBtn,
  #wizardNextBtn {
    font-size: 1rem;
    padding: 0.45rem 0.85rem;
  }
  #wizardLayoutRow.wizard-layout-modern #wizardStepsColumn {
    display: none;
  }
  #wizardLayoutRow.wizard-layout-modern #wizardContentColumn {
    flex: 0 0 100%;
    max-width: 100%;
  }
  .step-number {
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background-color: #e9ecef;
    color: #6c757d;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 0.875rem;
  }
  .step-item.active .step-number {
    background-color: #0d6efd;
    color: white;
  }
  .step-item.completed .step-number {
    background-color: #198754;
    color: white;
  }
  .registration-option {
    cursor: pointer;
    transition: all 0.2s;
    border: 2px solid transparent;
  }
  .registration-option:hover {
    background-color: #f8f9fa;
  }
  .registration-option.selected {
    border-color: #0d6efd !important;
    background-color: #e7f1ff;
  }
  .registration-option .meta-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    background: #f3f6f9;
    border: 1px solid #d7e0ea;
    color: #33485f;
    border-radius: 999px;
    padding: 0.15rem 0.55rem;
    font-size: 0.78rem;
    margin-right: 0.35rem;
    margin-top: 0.2rem;
  }
  .bg-success-subtle { background-color: #d1e7dd !important; }
  .bg-danger-subtle { background-color: #f8d7da !important; }
  .bg-info-subtle { background-color: #cff4fc !important; }
  .bg-warning-subtle { background-color: #fff3cd !important; }
</style>

<script src="/scripts/wizardStepRail.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {
  let currentStep = 1;
  let selectedStudent = null;
  let selectedStudentData = null;
  const requestedType = new URLSearchParams(window.location.search).get('type');
  let selectedType = ['class', 'term', 'program'].includes(String(requestedType || '').toLowerCase())
    ? String(requestedType).toLowerCase()
    : 'class';
  let selectedRegistration = null;
  let currentPreview = null;
  let studentEnrollments = null;
  let canContinueFromStep3 = false;

  const wizardPrevBtn = document.getElementById('wizardPrevBtn');
  const wizardNextBtn = document.getElementById('wizardNextBtn');
  const wizardCurrentLabel = document.getElementById('wizardCurrentLabel');
  const btnExecuteWithdrawal = document.getElementById('btnExecuteWithdrawal');
  const reasonSelect = document.getElementById('reasonSelect');
  const typeLabel = document.getElementById('typeLabel');
  const actionStateId = document.getElementById('withdrawalActionStateId')?.value || '';
  const steps = [
    { step: 1, title: 'Select Student', hint: 'Choose the student to withdraw.' },
    { step: 2, title: 'Select Registration', hint: 'Pick class, term, or program registration.' },
    { step: 3, title: 'Review Impact', hint: 'Review financial and academic effect.' },
    { step: 4, title: 'Confirm', hint: 'Submit the withdrawal or request.' }
  ];

  function escapeHtml(value) {
    return String(value || '').replace(/[&<>"']/g, function (m) {
      return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[m];
    });
  }

  function renderWizardGuide() {
    const mount = document.getElementById('withdrawalWizardGuideMount');
    if (!mount) return;

    mount.innerHTML = [
      '<div class="card border-0 shadow-sm" id="withdrawalWizardGuide">',
        '<div class="card-body">',
          '<div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-2">',
            '<div>',
              '<div class="fw-bold text-primary">Withdrawal Request Wizard</div>',
              '<div class="text-muted">Follow each step to create a clean, review-ready withdrawal request.</div>',
            '</div>',
            '<div class="d-flex align-items-center gap-2">',
              '<span class="badge bg-light text-dark border" id="withdrawalWizardStepBadge">Step 1 of ' + steps.length + '</span>',
              '<span class="badge bg-primary-subtle text-primary border border-primary-subtle" id="withdrawalWizardProgressPct">0%</span>',
            '</div>',
          '</div>',
          '<div class="wizard-progress mb-3"><div class="wizard-progress-bar" id="withdrawalWizardProgressBar"></div></div>',
          '<div class="wizard-step-rail mb-3" id="withdrawalWizardStepPills"></div>',
          '<div class="withdrawal-wizard-controls d-flex justify-content-between align-items-center flex-wrap gap-2">',
            '<div class="wizard-step-label" id="withdrawalWizardCurrentLabel"></div>',
            '<div class="small text-muted" id="withdrawalWizardStepHint"></div>',
          '</div>',
        '</div>',
      '</div>'
    ].join('');
  }

  function updateWizardGuide() {
    const pills = document.getElementById('withdrawalWizardStepPills');
    const badge = document.getElementById('withdrawalWizardStepBadge');
    const progressPct = document.getElementById('withdrawalWizardProgressPct');
    const progressBar = document.getElementById('withdrawalWizardProgressBar');
    const currentLabel = document.getElementById('withdrawalWizardCurrentLabel');
    const hint = document.getElementById('withdrawalWizardStepHint');
    if (!pills || !badge || !progressBar || !currentLabel || !hint) return;

    const progress = ((currentStep) / steps.length) * 100;
    badge.textContent = `Step ${currentStep} of ${steps.length}`;
    if (progressPct) progressPct.textContent = `${Math.round(progress)}%`;
    progressBar.style.width = `${progress.toFixed(2)}%`;

    const active = steps.find((row) => row.step === currentStep) || steps[0];
    currentLabel.textContent = active.title;
    hint.textContent = active.hint;

    pills.innerHTML = steps.map((row) => {
      const cls = row.step === currentStep ? 'active' : (row.step < currentStep ? 'completed' : '');
      return `<button type="button" class="wizard-step-pill ${cls}" data-step="${row.step}">${row.step}. ${escapeHtml(row.title)}</button>`;
    }).join('');
    pills.querySelectorAll('[data-step]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const step = Number(btn.getAttribute('data-step') || 1);
        showStep(step);
      });
    });

    if (window.WizardStepRail && typeof window.WizardStepRail.sync === 'function') {
      window.WizardStepRail.sync(pills);
    }
  }

  function updateWizardNavState() {
    if (!wizardPrevBtn || !wizardNextBtn) return;

    wizardPrevBtn.disabled = currentStep <= 1;
    if (wizardCurrentLabel) {
      const active = steps.find((row) => row.step === currentStep) || steps[0];
      wizardCurrentLabel.textContent = active.title;
    }

    if (currentStep === 1) {
      wizardNextBtn.disabled = !selectedStudent;
      wizardNextBtn.innerHTML = 'Next<i class="bi bi-arrow-right ms-1"></i>';
      return;
    }
    if (currentStep === 2) {
      wizardNextBtn.disabled = !(selectedRegistration && reasonSelect.value);
      wizardNextBtn.innerHTML = 'Next<i class="bi bi-arrow-right ms-1"></i>';
      return;
    }
    if (currentStep === 3) {
      wizardNextBtn.disabled = !canContinueFromStep3;
      wizardNextBtn.innerHTML = (!canContinueFromStep3 && selectedType === 'program')
        ? 'Next (Submit For Review)<i class="bi bi-arrow-right ms-1"></i>'
        : 'Next<i class="bi bi-arrow-right ms-1"></i>';
      return;
    }

    wizardNextBtn.disabled = true;
    wizardNextBtn.innerHTML = 'Next<i class="bi bi-arrow-right ms-1"></i>';
  }

  function showStep(step) {
    currentStep = step;
    document.querySelectorAll('.step-content').forEach(el => el.classList.add('d-none'));
    document.querySelector(`.step-content[data-step="${step}"]`).classList.remove('d-none');
    
    document.querySelectorAll('.step-item').forEach(el => {
      const itemStep = parseInt(el.dataset.step);
      el.classList.remove('active', 'completed');
      if (itemStep < step) el.classList.add('completed');
      if (itemStep === step) el.classList.add('active');
    });
    updateWizardGuide();
    updateWizardNavState();
  }

  function getStudentDisplayName(item) {
    if (!item) return '';
    const directName = String(item.identity?.displayName || item.name || item.displayName || '').trim();
    if (directName) return directName;

    const first = String(item.name?.first || item.firstName || '').trim();
    const last = String(item.name?.last || item.lastName || '').trim();
    const full = `${first} ${last}`.trim();
    if (full) return full;

    return String(item.studentNumber || item.id || '').trim();
  }

  async function loadStudentStatus(studentId) {
    const statusDiv = document.getElementById('studentStatus');
    statusDiv.classList.remove('d-none');
    statusDiv.innerHTML = '<div class="alert alert-info"><i class="bi bi-hourglass-split me-2"></i>Loading enrollment status...</div>';

    try {
      const response = await fetch(`/school/withdrawal/api/student/${studentId}/enrollments`, {
        headers: { 'X-AJAX-Request': 'true' }
      });
      const result = await response.json();
      const guarded = typeof window.applyGuardedApiResult === 'function'
        ? await window.applyGuardedApiResult(result, { busyTitle: 'Load In Progress', replayTitle: 'Load Already Completed' })
        : { stop: false };
      if (guarded.stop) return;
      if (!response.ok || result.status !== 'success') {
        throw new Error(result.message || 'Failed to load enrollments.');
      }
      studentEnrollments = result.result || {};
      selectedRegistration = null;
      updateStep2Button();
      
      let html = '<div class="row g-3">';
      html += `<div class="col-md-4">
        <div class="card border-0 bg-light">
          <div class="card-body text-center">
            <i class="bi bi-journal-text fs-3 text-danger"></i>
            <h4 class="mb-0">${studentEnrollments.programs?.length || 0}</h4>
            <div class="small text-muted">Active Programs</div>
          </div>
        </div>
      </div>`;
      html += `<div class="col-md-4">
        <div class="card border-0 bg-light">
          <div class="card-body text-center">
            <i class="bi bi-calendar3 fs-3 text-warning"></i>
            <h4 class="mb-0">${studentEnrollments.terms?.length || 0}</h4>
            <div class="small text-muted">Active Terms</div>
          </div>
        </div>
      </div>`;
      html += `<div class="col-md-4">
        <div class="card border-0 bg-light">
          <div class="card-body text-center">
            <i class="bi bi-easel2 fs-3 text-info"></i>
            <h4 class="mb-0">${studentEnrollments.classes?.length || 0}</h4>
            <div class="small text-muted">Active Classes</div>
          </div>
        </div>
      </div>`;
      html += '</div>';

      const warnings = Array.isArray(studentEnrollments.warnings) ? studentEnrollments.warnings : [];
      if (warnings.length) {
        html += '<div class="alert alert-warning mt-3 mb-0"><div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle me-2"></i>Review Required</div><ul class="mb-0">';
        warnings.forEach((warning) => { html += `<li>${warning}</li>`; });
        html += '</ul></div>';
      }

      statusDiv.innerHTML = html;
      updateWizardNavState();
    } catch (error) {
      statusDiv.innerHTML = `<div class="alert alert-danger"><i class="bi bi-exclamation-triangle me-2"></i>Failed to load student status: ${error.message}</div>`;
      updateWizardNavState();
    }
  }

  function getCurrentRegistrations() {
    if (!studentEnrollments) return [];
    if (selectedType === 'class') return Array.isArray(studentEnrollments.classes) ? studentEnrollments.classes : [];
    if (selectedType === 'term') return Array.isArray(studentEnrollments.terms) ? studentEnrollments.terms : [];
    return Array.isArray(studentEnrollments.programs) ? studentEnrollments.programs : [];
  }

  function getRegistrationMeta(item) {
    if (selectedType === 'class') {
      return {
        id: item.enrollmentId || item.classId || item.id || '',
        title: item.classTitle || item.className || item.classId || item.id || '',
        chips: [
          item.programName ? `<span class="meta-chip"><i class="bi bi-journal-text"></i>${escapeHtml(item.programName)}</span>` : '',
          item.termName ? `<span class="meta-chip"><i class="bi bi-calendar3"></i>${escapeHtml(item.termName)}</span>` : ''
        ].filter(Boolean).join(''),
        status: item.status || '',
        date: item.enrolledAt || ''
      };
    }
    if (selectedType === 'term') {
      return {
        id: item.registrationId || item.id || '',
        title: item.termName || item.termId || item.registrationId || item.id || '',
        chips: [
          item.programName ? `<span class="meta-chip"><i class="bi bi-journal-text"></i>${escapeHtml(item.programName)}</span>` : ''
        ].filter(Boolean).join(''),
        status: item.status || '',
        date: item.registeredAt || item.effectiveDate || ''
      };
    }
    return {
      id: item.registrationId || item.id || '',
      title: item.programName || item.programId || item.registrationId || item.id || '',
      chips: '',
      status: item.status || '',
      date: item.registeredAt || item.registrationDate || ''
    };
  }

  function renderRegistrationOptions() {
    const container = document.getElementById('registrationOptions');
    if (!studentEnrollments) {
      container.innerHTML = '<div class="text-center text-muted py-4">Select a student first.</div>';
      return;
    }

    const items = getCurrentRegistrations();

    if (items.length === 0) {
      container.innerHTML = `<div class="alert alert-warning mb-0"><i class="bi bi-exclamation-triangle me-2"></i>No active ${selectedType} registrations found for this student. Only the student's own registrations are shown.</div>`;
      return;
    }

    let html = '';
    items.forEach((item, idx) => {
      const meta = getRegistrationMeta(item);
      
      const iconClass = selectedType === 'class' ? 'bi-easel-fill text-info' : 
                        selectedType === 'term' ? 'bi-calendar3-fill text-warning' : 
                        'bi-journal-bookmark-fill text-danger';
      const bgClass = selectedType === 'class' ? 'bg-info-subtle' : 
                      selectedType === 'term' ? 'bg-warning-subtle' : 
                      'bg-danger-subtle';

      html += `
        <div class="registration-option d-flex align-items-center p-3 mb-2 rounded border" data-index="${idx}">
          <div class="form-check me-3">
            <input type="radio" name="registration" class="form-check-input" value="${idx}" id="reg_${idx}">
          </div>
          <div class="rounded-circle ${bgClass} d-flex align-items-center justify-content-center me-3" style="width:45px;height:45px;min-width:45px;">
            <i class="bi ${iconClass} fs-5"></i>
          </div>
          <div class="flex-grow-1">
            <div class="fw-bold text-dark">${escapeHtml(meta.title)}</div>
            <div class="mb-1">${meta.chips}</div>
            <div class="small text-muted">
              ID: ${escapeHtml(meta.id)}
              ${meta.status ? ' | Status: ' + escapeHtml(meta.status) : ''}
              ${meta.date ? ' | Date: ' + escapeHtml(meta.date) : ''}
            </div>
          </div>
          <i class="bi bi-check-circle-fill text-primary fs-4 selection-check d-none"></i>
        </div>
      `;
    });
    container.innerHTML = html;

    document.querySelectorAll('.registration-option').forEach(el => {
      el.addEventListener('click', function() {
        document.querySelectorAll('.registration-option').forEach(o => {
          o.classList.remove('selected');
          o.querySelector('.selection-check').classList.add('d-none');
        });
        this.classList.add('selected');
        this.querySelector('.selection-check').classList.remove('d-none');
        this.querySelector('input[type="radio"]').checked = true;
        
        const idx = parseInt(this.dataset.index);
        selectedRegistration = getCurrentRegistrations()[idx] || null;
        updateStep2Button();
      });
    });
  }

  function updateStep2Button() {
    updateWizardNavState();
  }

  async function loadPreview() {
    const previewLoading = document.getElementById('previewLoading');
    const previewContent = document.getElementById('previewContent');
    const previewError = document.getElementById('previewError');
    
    previewLoading.classList.remove('d-none');
    previewContent.classList.add('d-none');
    previewError.classList.add('d-none');

    try {
      const body = {
        reason: reasonSelect.value,
        effectiveDate: document.getElementById('effectiveDate').value
      };

      let endpoint = '';
      if (selectedType === 'class') {
        endpoint = '/school/withdrawal/api/class/preview';
        body.classId = selectedRegistration.classId;
        body.studentId = selectedStudent;
        body.termRegistrationId = selectedRegistration.termRegistrationId || '';
      } else if (selectedType === 'term') {
        endpoint = '/school/withdrawal/api/term/preview';
        body.termRegistrationId = selectedRegistration.registrationId || selectedRegistration.id;
      } else {
        endpoint = '/school/withdrawal/api/program/preview';
        body.programRegistrationId = selectedRegistration.registrationId || selectedRegistration.id;
      }

      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-AJAX-Request': 'true'
        },
        body: JSON.stringify(body)
      });

      const result = await response.json();
      const guarded = typeof window.applyGuardedApiResult === 'function'
        ? await window.applyGuardedApiResult(result, { busyTitle: 'Preview In Progress', replayTitle: 'Preview Already Completed' })
        : { stop: false };
      if (guarded.stop) {
        previewLoading.classList.add('d-none');
        return;
      }
      if (!response.ok || result.status !== 'success') {
        throw new Error(result.message || 'Failed to build withdrawal preview.');
      }
      currentPreview = result.result;
      previewLoading.classList.add('d-none');

      renderPreview(currentPreview);
      previewContent.classList.remove('d-none');
      const canContinueToConfirm = Boolean(currentPreview.canProceed) || selectedType === 'program';
      canContinueFromStep3 = canContinueToConfirm;
      updateWizardNavState();
    } catch (error) {
      previewLoading.classList.add('d-none');
      previewError.classList.remove('d-none');
      document.getElementById('previewErrorMessage').textContent = error.message;
      canContinueFromStep3 = false;
      updateWizardNavState();
    }
  }

  function renderPreview(preview) {
    let html = '';
    const isProgramFlow = selectedType === 'program';

    if (preview.issues && preview.issues.length) {
      html += '<div class="alert alert-danger mb-3"><strong><i class="bi bi-exclamation-triangle me-2"></i>Issues:</strong><ul class="mb-0 mt-2">';
      preview.issues.forEach(i => { html += `<li>${i}</li>`; });
      html += '</ul></div>';
    }

    if (preview.warnings && preview.warnings.length) {
      html += '<div class="alert alert-warning mb-3"><strong><i class="bi bi-exclamation-circle me-2"></i>Warnings:</strong><ul class="mb-0 mt-2">';
      preview.warnings.forEach(w => { html += `<li>${w}</li>`; });
      html += '</ul></div>';
    }

    html += '<div class="row g-3">';

    html += '<div class="col-md-6"><div class="card border-0 bg-light h-100"><div class="card-body">';
    html += '<h6 class="fw-bold mb-3"><i class="bi bi-cash-coin text-success me-2"></i>Financial Impact</h6>';
    if (isProgramFlow) {
      html += `<div class="d-flex justify-content-between mb-2"><span>Program Fee (Charged):</span><span class="fw-bold">$${Number(preview.financialImpact?.programFeeOriginal || 0).toFixed(2)}</span></div>`;
      html += `<div class="d-flex justify-content-between mb-2"><span>Amount Paid:</span><span class="fw-bold text-primary">$${Number(preview.financialImpact?.programFeePaid || 0).toFixed(2)}</span></div>`;
      html += `<div class="d-flex justify-content-between mb-2"><span>Outstanding Debt:</span><span class="fw-bold text-danger">$${Number(preview.financialImpact?.programFeeOutstandingDebt || 0).toFixed(2)}</span></div>`;
      html += '<div class="d-flex justify-content-between mb-2"><span>Refund Status:</span><span class="fw-bold text-warning">Pending Policy Review</span></div>';
      html += `<div class="d-flex justify-content-between mb-2"><span>Refundable Paid Base:</span><span class="fw-bold text-success">$${Number(preview.financialImpact?.refundablePaymentBase || 0).toFixed(2)}</span></div>`;
      html += '<div class="small text-muted mt-2">Final refund is calculated during review based on policy and posted payments only.</div>';
    } else {
      html += `<div class="d-flex justify-content-between mb-2"><span>Refund Amount:</span><span class="fw-bold text-success">$${(preview.financialImpact?.refundAmount || preview.financialImpact?.totalRefund || 0).toFixed(2)}</span></div>`;
      html += `<div class="d-flex justify-content-between mb-2"><span>Penalty Amount:</span><span class="fw-bold text-danger">$${(preview.financialImpact?.penaltyAmount || preview.financialImpact?.totalPenalty || 0).toFixed(2)}</span></div>`;
      if (preview.financialImpact?.refundPolicyLabel) {
        html += `<div class="small text-muted mt-2">Policy: ${preview.financialImpact.refundPolicyLabel}</div>`;
      }
    }
    html += '</div></div></div>';

    html += '<div class="col-md-6"><div class="card border-0 bg-light h-100"><div class="card-body">';
    html += '<h6 class="fw-bold mb-3"><i class="bi bi-mortarboard text-primary me-2"></i>Academic Impact</h6>';
    html += `<div class="d-flex justify-content-between mb-2"><span>Grade Assigned:</span><span class="fw-bold">${preview.academicImpact?.gradeAssigned || 'None'}</span></div>`;
    html += `<div class="d-flex justify-content-between mb-2"><span>On Transcript:</span><span>${preview.academicImpact?.appearsOnTranscript ? '<i class="bi bi-check-circle text-success"></i> Yes' : '<i class="bi bi-x-circle text-muted"></i> No'}</span></div>`;
    html += '</div></div></div>';

    html += '</div>';

    if (preview.classWithdrawals && preview.classWithdrawals.length) {
      html += '<div class="mt-4"><h6 class="fw-bold mb-2"><i class="bi bi-collection me-2"></i>Affected Classes (' + preview.classWithdrawals.length + ')</h6>';
      html += '<ul class="list-group">';
      preview.classWithdrawals.forEach(cw => {
        html += `<li class="list-group-item d-flex justify-content-between align-items-center">
          <span>${cw.classTitle}</span>
          <span class="badge ${cw.status === 'error' ? 'bg-danger' : 'bg-info'}">${cw.status}</span>
        </li>`;
      });
      html += '</ul></div>';
    }

    if (preview.termWithdrawals && preview.termWithdrawals.length) {
      html += '<div class="mt-4"><h6 class="fw-bold mb-2"><i class="bi bi-collection me-2"></i>Affected Terms (' + preview.termWithdrawals.length + ')</h6>';
      html += '<ul class="list-group">';
      preview.termWithdrawals.forEach(tw => {
        html += `<li class="list-group-item d-flex justify-content-between align-items-center">
          <span>${tw.termName}</span>
          <span class="badge ${tw.status === 'error' ? 'bg-danger' : 'bg-warning text-dark'}">${tw.status}</span>
        </li>`;
      });
      html += '</ul></div>';
    }

    if (isProgramFlow) {
      html += '<div class="alert alert-info mt-3 mb-0"><i class="bi bi-info-circle me-2"></i>Please review the withdrawal policy. If eligible, the approved refund will be calculated and applied to the student account during final review.</div>';
    }

    document.getElementById('previewContent').innerHTML = html;
  }

  function renderExecuteConfirm() {
    const summary = document.getElementById('executeConfirmSummary');
    const title = selectedRegistration
      ? (selectedRegistration.classTitle || selectedRegistration.termName || selectedRegistration.programName || selectedRegistration.termId || selectedRegistration.programId || selectedRegistration.registrationId || selectedRegistration.classId || '')
      : '-';
    const preview = currentPreview || {};
    const isProgramFlow = selectedType === 'program';
    const chargedAmount = Number(preview.financialImpact?.programFeeOriginal || 0).toFixed(2);
    const paidAmount = Number(preview.financialImpact?.programFeePaid || 0).toFixed(2);
    const outstandingDebt = Number(preview.financialImpact?.programFeeOutstandingDebt || 0).toFixed(2);
    const refundAmount = Number(preview.financialImpact?.refundAmount || preview.financialImpact?.totalRefund || 0).toFixed(2);
    const penaltyAmount = Number(preview.financialImpact?.penaltyAmount || preview.financialImpact?.totalPenalty || 0).toFixed(2);
    const studentName = selectedStudentData
      ? (selectedStudentData.identity?.displayName || `${selectedStudentData.name?.first || ''} ${selectedStudentData.name?.last || ''}`.trim() || selectedStudentData.studentNumber || selectedStudentData.id)
      : (preview.studentName || selectedStudent || '-');
    const rows = [
      '<div class="row g-3 text-start">',
      '<div class="col-md-6"><div class="small text-muted">Student</div><div class="fw-bold">' + studentName + '</div></div>',
      '<div class="col-md-6"><div class="small text-muted">Withdrawal Type</div><div class="fw-bold text-capitalize">' + selectedType + '</div></div>',
      '<div class="col-md-6"><div class="small text-muted">Target</div><div class="fw-bold">' + title + '</div></div>',
      '<div class="col-md-6"><div class="small text-muted">Effective Date</div><div class="fw-bold">' + (document.getElementById('effectiveDate').value || '-') + '</div></div>',
      '<div class="col-md-6"><div class="small text-muted">Reason</div><div class="fw-bold">' + (reasonSelect.options[reasonSelect.selectedIndex]?.text || '-') + '</div></div>'
    ];
    if (isProgramFlow) {
      rows.push('<div class="col-md-3"><div class="small text-muted">Program Fee</div><div class="fw-bold">$' + chargedAmount + '</div></div>');
      rows.push('<div class="col-md-3"><div class="small text-muted">Amount Paid</div><div class="fw-bold text-primary">$' + paidAmount + '</div></div>');
      rows.push('<div class="col-md-3"><div class="small text-muted">Outstanding Debt</div><div class="fw-bold text-danger">$' + outstandingDebt + '</div></div>');
      rows.push('<div class="col-md-3"><div class="small text-muted">Refund</div><div class="fw-bold text-warning">Pending Policy Review</div></div>');
      rows.push('<div class="col-12 small text-muted">Final refund will be calculated from posted payments and applied to the student account if eligible based on policy.</div>');
    } else {
      rows.push('<div class="col-md-3"><div class="small text-muted">Refund</div><div class="fw-bold text-success">$' + refundAmount + '</div></div>');
      rows.push('<div class="col-md-3"><div class="small text-muted">Penalty</div><div class="fw-bold text-danger">$' + penaltyAmount + '</div></div>');
    }
    rows.push('</div>');
    summary.innerHTML = rows.join('');
  }

  async function executeWithdrawal() {
    const executeConfirm = document.getElementById('executeConfirm');
    const executeLoading = document.getElementById('executeLoading');
    const executeSuccess = document.getElementById('executeSuccess');
    const executeError = document.getElementById('executeError');
    const duplicateActions = document.getElementById('duplicateRequestActions');

    executeConfirm.classList.add('d-none');
    executeLoading.classList.remove('d-none');
    executeSuccess.classList.add('d-none');
    executeError.classList.add('d-none');
    if (duplicateActions) {
      duplicateActions.classList.add('d-none');
      duplicateActions.innerHTML = '';
    }

    function renderDuplicateRequestActions(details) {
      if (!duplicateActions) return;
      const existingId = String(details?.existingRequestId || '').trim();
      const detailUrl = String(details?.detailUrl || '').trim();
      const listUrl = String(details?.listUrl || '/school/withdrawal/list').trim() || '/school/withdrawal/list';
      if (!existingId || !detailUrl) {
        duplicateActions.classList.add('d-none');
        duplicateActions.innerHTML = '';
        return;
      }
      duplicateActions.innerHTML = [
        '<div class="alert alert-warning text-start mx-auto" style="max-width:760px;">',
          '<div class="fw-bold mb-2"><i class="bi bi-info-circle me-1"></i>Existing Request Found</div>',
          '<div class="small mb-2">Request ID: <span class="font-monospace">' + existingId + '</span></div>',
          '<div class="d-flex flex-wrap gap-2 justify-content-center justify-content-md-start">',
            '<a class="btn btn-outline-primary btn-sm" href="' + detailUrl + '"><i class="bi bi-eye me-1"></i>Open Existing Request</a>',
            '<a class="btn btn-outline-secondary btn-sm" href="' + listUrl + '"><i class="bi bi-list-ul me-1"></i>Go To Request List</a>',
          '</div>',
        '</div>'
      ].join('');
      duplicateActions.classList.remove('d-none');
    }

    try {
      const body = {
        reason: reasonSelect.value,
        reasonDetail: document.getElementById('reasonDetail').value,
        effectiveDate: document.getElementById('effectiveDate').value,
        actionStateId
      };

      let endpoint = '';
      if (selectedType === 'class') {
        endpoint = '/school/withdrawal/api/class/execute';
        body.classId = selectedRegistration.classId;
        body.studentId = selectedStudent;
        body.termRegistrationId = selectedRegistration.termRegistrationId || '';
      } else if (selectedType === 'term') {
        endpoint = '/school/withdrawal/api/term/execute';
        body.termRegistrationId = selectedRegistration.registrationId || selectedRegistration.id;
        body.withdrawClasses = true;
      } else {
        endpoint = '/school/withdrawal/api/program/execute';
        body.programRegistrationId = selectedRegistration.registrationId || selectedRegistration.id;
        body.withdrawTerms = true;
        body.withdrawClasses = true;
      }

      const response = await fetch(endpoint, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'X-AJAX-Request': 'true'
        },
        body: JSON.stringify(body)
      });

      const result = await response.json();
      const guarded = typeof window.applyGuardedApiResult === 'function'
        ? await window.applyGuardedApiResult(result, { busyTitle: 'Execution In Progress', replayTitle: 'Execution Already Processed' })
        : { stop: false };
      if (guarded.stop) {
        executeLoading.classList.add('d-none');
        return;
      }
      executeLoading.classList.add('d-none');

      if (response.ok && result.status === 'success' && result.result?.success) {
        executeSuccess.classList.remove('d-none');
        const isQueued = Boolean(result.result?.queued);
        const successMessage = document.getElementById('successMessage');
        if (successMessage) {
          successMessage.textContent = isQueued
            ? (result.message || 'Withdrawal request submitted for administrator review.')
            : 'The withdrawal has been successfully processed.';
        }
        if (result.result?.withdrawal?.id) {
          document.getElementById('viewWithdrawalLink').href = `/school/withdrawal/detail/${result.result.withdrawal.id}`;
        }
      } else {
        executeError.classList.remove('d-none');
        document.getElementById('errorMessage').textContent =
          result.message ||
          result.result?.errors?.join(', ') ||
          'An unknown error occurred.';
        if (String(result?.code || '') === 'DUPLICATE_ACTIVE_WITHDRAWAL_REQUEST') {
          renderDuplicateRequestActions(result?.details || {});
        }
      }
    } catch (error) {
      executeLoading.classList.add('d-none');
      executeError.classList.remove('d-none');
      document.getElementById('errorMessage').textContent = error.message;
    }
  }

  // Student Picker
  document.getElementById('btnPickStudent').addEventListener('click', () => {
    GenericPicker.open(GenericPickerPresets.student({
      title: 'Select Student',
      placeholder: 'Search by name, student number...',
      onSelect: (item) => {
        selectedStudent = item.id;
        selectedStudentData = item;
        const displayName = getStudentDisplayName(item);
        document.getElementById('selectedStudentDisplay').value = displayName;
        document.getElementById('selectedStudentId').value = item.id;
        document.getElementById('btnClearStudent').classList.remove('d-none');
        
        loadStudentStatus(item.id);
      }
    }));
  });

  document.getElementById('btnClearStudent').addEventListener('click', () => {
    selectedStudent = null;
    selectedStudentData = null;
    studentEnrollments = null;
    selectedRegistration = null;
    document.getElementById('selectedStudentDisplay').value = '';
    document.getElementById('selectedStudentId').value = '';
    document.getElementById('btnClearStudent').classList.add('d-none');
    document.getElementById('studentStatus').classList.add('d-none');
    renderRegistrationOptions();
    updateStep2Button();
    canContinueFromStep3 = false;
    updateWizardNavState();
  });

  function applySelectedType(type) {
    const normalized = ['class', 'term', 'program'].includes(String(type || '').toLowerCase())
      ? String(type).toLowerCase()
      : 'class';
    selectedType = normalized;
    typeLabel.textContent = selectedType.charAt(0).toUpperCase() + selectedType.slice(1);
    document.querySelectorAll('#withdrawalTypeNav .nav-link').forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.type === selectedType);
    });
    selectedRegistration = null;
    renderRegistrationOptions();
    updateStep2Button();
  }

  // Type Navigation
  document.querySelectorAll('#withdrawalTypeNav .nav-link').forEach(btn => {
    btn.addEventListener('click', function() {
      applySelectedType(this.dataset.type);
    });
  });

  reasonSelect.addEventListener('change', updateStep2Button);

  function goToPreviousStep() {
    if (currentStep <= 1) return;
    if (currentStep === 2) {
      showStep(1);
      return;
    }
    if (currentStep === 3) {
      showStep(2);
      return;
    }
    showStep(3);
  }

  function goToNextStep() {
    if (currentStep === 1) {
      if (!selectedStudent) return;
      showStep(2);
      renderRegistrationOptions();
      return;
    }
    if (currentStep === 2) {
      if (!(selectedRegistration && reasonSelect.value)) return;
      canContinueFromStep3 = false;
      showStep(3);
      loadPreview();
      return;
    }
    if (currentStep === 3) {
      if (!canContinueFromStep3) return;
      showStep(4);
      renderExecuteConfirm();
    }
  }

  wizardPrevBtn?.addEventListener('click', goToPreviousStep);
  wizardNextBtn?.addEventListener('click', goToNextStep);
  btnExecuteWithdrawal.addEventListener('click', () => executeWithdrawal());

  document.getElementById('btnRetry').addEventListener('click', () => {
    document.getElementById('executeConfirm').classList.remove('d-none');
    document.getElementById('executeLoading').classList.add('d-none');
    document.getElementById('executeSuccess').classList.add('d-none');
    document.getElementById('executeError').classList.add('d-none');
    const duplicateActions = document.getElementById('duplicateRequestActions');
    if (duplicateActions) {
      duplicateActions.classList.add('d-none');
      duplicateActions.innerHTML = '';
    }
  });

  document.getElementById('wizardLayoutRow')?.classList.add('wizard-layout-modern');
  renderWizardGuide();
  applySelectedType(selectedType);
  showStep(1);
  updateWizardNavState();
});
</script>
