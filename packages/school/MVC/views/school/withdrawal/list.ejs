<%- include('partials/tablePages-start', {
  title,
  newUrl: 'school/withdrawal',
  newLabel: 'New Withdrawal',
  newHref: '/school/withdrawal/new',
  user,
  tableName: 'school_withdrawals',
  btn_export: true,
  print: false,
  manageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>',
    `<a href="/school/withdrawal/new?type=class" class="btn btn-filled btn-primary btn-md mb-2"><i class="bi bi-signpost-split me-1"></i> Wizard</a>`
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search withdrawal records...',
  fields: [
    { name: 'type', label: 'Type', type: 'select', options: ['class', 'term', 'program'] },
    { name: 'status', label: 'Status', type: 'select', options: ['draft', 'submitted', 'pending_approval', 'pending_program_admin_approval', 'processing', 'completed', 'rejected', 'error'] }
  ]
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Withdrawal</th>
        <th>Type</th>
        <th>Student</th>
        <th>Reason</th>
        <th>Refund</th>
        <th>Status</th>
        <th>Dates</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if (withdrawals.length === 0) { %>
        <tr><td colspan="8" class="text-center py-4 text-muted">No withdrawal records found.</td></tr>
      <% } %>

      <% withdrawals.forEach(w => { %>
        <% const listRefundAmount = Number(w.financialImpact?.refundAmount || w.financialImpact?.totalRefund || 0); %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-primary"><a href="/school/withdrawal/detail/<%= w.id %>"><%= w.id %></a></div>
            <div class="small text-muted">Requested: <%= w.requestDate || '-' %></div>
            <div class="x-small text-muted">Effective: <%= w.effectiveDate || '-' %></div>
          </td>
          <td>
            <% if (w.type === 'class') { %>
              <span class="badge bg-info-subtle text-info"><i class="bi bi-easel2 me-1"></i>Class</span>
            <% } else if (w.type === 'term') { %>
              <span class="badge bg-warning-subtle text-warning"><i class="bi bi-calendar3 me-1"></i>Term</span>
            <% } else { %>
              <span class="badge bg-danger-subtle text-danger"><i class="bi bi-journal-text me-1"></i>Program</span>
            <% } %>
          </td>
          <td>
            <div class="fw-bold"><%- include('../partials/studentNameLink', { name: w.studentName || w.studentId, studentRecordId: w.studentId, canOpenStudentProfile: typeof canOpenStudentProfile !== 'undefined' ? canOpenStudentProfile : false, linkClass: 'text-decoration-none' }) %></div>
            <div class="small text-muted font-monospace"><%= w.studentId || '-' %></div>
          </td>
          <td class="small"><%= reasons[w.reason] || w.reason || '-' %></td>
          <td class="small">
            <% if (listRefundAmount > 0) { %>
              <span class="fw-bold text-success">$<%= listRefundAmount.toFixed(2) %></span>
            <% } else { %>
              <span class="text-muted">-</span>
            <% } %>
          </td>
          <td>
            <% if (w.status === 'completed') { %>
              <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Completed</span>
            <% } else if (w.status === 'error') { %>
              <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Error</span>
            <% } else if (w.status === 'processing') { %>
              <span class="badge bg-primary"><i class="bi bi-arrow-repeat me-1"></i>Processing</span>
            <% } else if (w.status === 'pending_program_admin_approval') { %>
              <span class="badge bg-warning text-dark"><i class="bi bi-person-check me-1"></i>Program Admin</span>
            <% } else if (w.status === 'pending_approval' || w.status === 'submitted' || w.status === 'draft') { %>
              <span class="badge bg-warning text-dark"><i class="bi bi-hourglass me-1"></i>Pending</span>
            <% } else if (w.status === 'rejected') { %>
              <span class="badge bg-secondary"><i class="bi bi-x-octagon me-1"></i>Rejected</span>
            <% } else { %>
              <span class="badge bg-secondary"><%= w.status %></span>
            <% } %>
          </td>
          <td class="small">
            <div>Request: <%= w.requestDate || '-' %></div>
            <div class="text-muted">Effective: <%= w.effectiveDate || '-' %></div>
          </td>
          <td class="table-actions text-end pe-4">
            <a href="/school/withdrawal/detail/<%= w.id %>" class="btn btn-sm btn-outline-secondary">Details</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<div class="row align-items-center mt-3 bg-white p-3 border rounded shadow-sm g-0">
  <div class="col-md-12 text-center text-md-start">
    <span class="text-muted small" style="font-weight: 500;">
      Showing <span class="text-dark"><%= withdrawals.length %></span> record(s)
    </span>
  </div>
</div>

<span id="urlRef" data-id="school/withdrawal" hidden></span>
<%- include('partials/tablePages-end') %>

<style>
  .bg-info-subtle { background-color: #cff4fc !important; }
  .bg-warning-subtle { background-color: #fff3cd !important; }
  .bg-danger-subtle { background-color: #f8d7da !important; }
</style>
