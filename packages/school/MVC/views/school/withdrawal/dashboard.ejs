<div class="sections-page">
  <div class="mx-auto" style="max-width: 1400px;">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div>
      <h2 class="page-heading size-md m-0">
        <i class="bi bi-box-arrow-left me-2 text-danger"></i>Withdrawal Management
      </h2>
      <div class="text-muted small mt-1">Process and manage student withdrawals from classes, terms, and programs.</div>
    </div>
    <div class="d-flex gap-2">
      <a href="<%= schoolSectionDashboardHref %>" class="school-navigator-dashboard btn btn-outline-secondary btn-sm">
        <i class="bi bi-speedometer2 me-1"></i>School Dashboard
      </a>
      <a href="/school/withdrawal/new" class="btn btn-danger btn-sm">
        <i class="bi bi-plus-lg me-1"></i>New Withdrawal
      </a>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body text-center">
          <div class="rounded-circle bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center mb-2" style="width: 50px; height: 50px;">
            <i class="bi bi-file-earmark-text fs-4"></i>
          </div>
          <h3 class="fw-bold mb-0"><%= stats.total %></h3>
          <div class="text-muted small">Total Withdrawals</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body text-center">
          <div class="rounded-circle bg-warning-subtle text-warning d-inline-flex align-items-center justify-content-center mb-2" style="width: 50px; height: 50px;">
            <i class="bi bi-hourglass-split fs-4"></i>
          </div>
          <h3 class="fw-bold mb-0"><%= stats.pending %></h3>
          <div class="text-muted small">Pending</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body text-center">
          <div class="rounded-circle bg-success-subtle text-success d-inline-flex align-items-center justify-content-center mb-2" style="width: 50px; height: 50px;">
            <i class="bi bi-check-circle fs-4"></i>
          </div>
          <h3 class="fw-bold mb-0"><%= stats.completed %></h3>
          <div class="text-muted small">Completed</div>
        </div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-body">
          <div class="d-flex justify-content-between mb-2">
            <span class="small text-muted">By Type</span>
          </div>
          <div class="d-flex align-items-center gap-3">
            <div class="text-center">
              <span class="badge bg-info-subtle text-info px-2 py-1" title="Class Withdrawals">
                <i class="bi bi-easel2 me-1"></i><%= stats.byType.class %>
              </span>
              <div class="small text-muted mt-1">Class</div>
            </div>
            <div class="text-center">
              <span class="badge bg-warning-subtle text-warning px-2 py-1" title="Term Withdrawals">
                <i class="bi bi-calendar3 me-1"></i><%= stats.byType.term %>
              </span>
              <div class="small text-muted mt-1">Term</div>
            </div>
            <div class="text-center">
              <span class="badge bg-danger-subtle text-danger px-2 py-1" title="Program Withdrawals">
                <i class="bi bi-journal-text me-1"></i><%= stats.byType.program %>
              </span>
              <div class="small text-muted mt-1">Program</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-4">
    <div class="col-md-4">
      <a href="/school/withdrawal/new?type=class" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100 withdrawal-hover-card">
          <div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-circle bg-info-subtle text-info d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
              <i class="bi bi-easel2-fill fs-3"></i>
            </div>
            <div>
              <h5 class="fw-bold mb-1 text-dark">Class Withdrawal</h5>
              <p class="text-muted small mb-0">Drop a student from individual class(es)</p>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-4">
      <a href="/school/withdrawal/new?type=term" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100 withdrawal-hover-card">
          <div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-circle bg-warning-subtle text-warning d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
              <i class="bi bi-calendar3-fill fs-3"></i>
            </div>
            <div>
              <h5 class="fw-bold mb-1 text-dark">Term Withdrawal</h5>
              <p class="text-muted small mb-0">Withdraw from a term (includes all classes)</p>
            </div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-md-4">
      <a href="/school/withdrawal/new?type=program" class="text-decoration-none">
        <div class="card border-0 shadow-sm h-100 withdrawal-hover-card">
          <div class="card-body d-flex align-items-center gap-3">
            <div class="rounded-circle bg-danger-subtle text-danger d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
              <i class="bi bi-journal-x fs-3"></i>
            </div>
            <div>
              <h5 class="fw-bold mb-1 text-dark">Program Withdrawal</h5>
              <p class="text-muted small mb-0">Full program exit (includes all terms & classes)</p>
            </div>
          </div>
        </div>
      </a>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
      <h5 class="fw-bold mb-0"><i class="bi bi-clock-history me-2"></i>Recent Withdrawals</h5>
      <a href="/school/withdrawal/list" class="btn btn-outline-primary btn-sm">View All</a>
    </div>
    <div class="card-body p-0">
      <% if (withdrawals.length === 0) { %>
        <div class="text-center text-muted py-5">
          <i class="bi bi-inbox fs-1 d-block mb-2"></i>
          No withdrawal records found.
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover mb-0">
            <thead class="table-light">
              <tr>
                <th>ID</th>
                <th>Type</th>
                <th>Student</th>
                <th>Reason</th>
                <th>Status</th>
                <th>Date</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% withdrawals.forEach(w => { %>
                <tr>
                  <td><code class="small"><%= w.id %></code></td>
                  <td>
                    <% if (w.type === 'class') { %>
                      <span class="badge bg-info-subtle text-info"><i class="bi bi-easel2 me-1"></i>Class</span>
                    <% } else if (w.type === 'term') { %>
                      <span class="badge bg-warning-subtle text-warning"><i class="bi bi-calendar3 me-1"></i>Term</span>
                    <% } else { %>
                      <span class="badge bg-danger-subtle text-danger"><i class="bi bi-journal-text me-1"></i>Program</span>
                    <% } %>
                  </td>
                  <td><%= w.studentId %></td>
                  <td><%= reasons.find(r => r.value === w.reason)?.label || w.reason || '-' %></td>
                  <td>
                    <% if (w.status === 'completed') { %>
                      <span class="badge bg-success">Completed</span>
                    <% } else if (w.status === 'error') { %>
                      <span class="badge bg-danger">Error</span>
                    <% } else if (w.status === 'processing') { %>
                      <span class="badge bg-primary">Processing</span>
                    <% } else if (w.status === 'pending_program_admin_approval') { %>
                      <span class="badge bg-warning text-dark">Pending Program Admin</span>
                    <% } else if (w.status === 'pending_approval' || w.status === 'submitted' || w.status === 'draft') { %>
                      <span class="badge bg-warning text-dark">Pending Review</span>
                    <% } else if (w.status === 'rejected') { %>
                      <span class="badge bg-secondary">Rejected</span>
                    <% } else { %>
                      <span class="badge bg-secondary"><%= w.status %></span>
                    <% } %>
                  </td>
                  <td class="small text-muted"><%= new Date(w.audit?.createDateTime || w.requestDate).toLocaleDateString() %></td>
                  <td class="text-end">
                    <a href="/school/withdrawal/detail/<%= w.id %>" class="btn btn-outline-primary btn-sm">
                      <i class="bi bi-eye"></i>
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
  </div>
</div>

<style>
  .withdrawal-hover-card {
    transition: all 0.2s ease;
  }
  .withdrawal-hover-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 .5rem 1rem rgba(0,0,0,.12) !important;
  }
  .bg-primary-subtle { background-color: #cfe2ff !important; }
  .bg-success-subtle { background-color: #d1e7dd !important; }
  .bg-info-subtle { background-color: #cff4fc !important; }
  .bg-warning-subtle { background-color: #fff3cd !important; }
  .bg-danger-subtle { background-color: #f8d7da !important; }
</style>
