<style>
  .gm-cell-effective .gm-score { color: #0f5132; font-weight: 600; }
  .gm-cell-excluded .gm-score { color: #6c757d; }
  .gm-cell-excluded .gm-pct { text-decoration: line-through; opacity: 0.85; }
  .matrix-wrapper.gm-matrix { max-height: min(70vh, 720px); overflow: auto; border: 1px solid #dee2e6; border-radius: 12px; box-shadow: 0 0.15rem 0.5rem rgba(15, 23, 42, 0.05); }
  .gm-matrix-table th { position: sticky; top: 0; z-index: 2; background-color: #f8f9fa; box-shadow: 0 2px 2px -1px rgba(0, 0, 0, 0.08); vertical-align: bottom; font-size: 0.78rem; }
  .gm-matrix-table th.gm-sticky-final,
  .gm-matrix-table td.gm-sticky-final {
    position: sticky; left: 0; z-index: 3; min-width: 72px; max-width: 88px; width: 80px;
    border-right: 1px solid #dee2e6; background-color: #fff;
  }
  .gm-matrix-table th.gm-sticky-final { background-color: #f8f9fa; z-index: 4; }
  .gm-matrix-table th.gm-sticky-name,
  .gm-matrix-table td.gm-sticky-name {
    position: sticky; left: 80px; z-index: 3; width: 140px; min-width: 140px; max-width: 140px; border-right: 1px solid #dee2e6;
    box-shadow: 2px 0 2px -1px rgba(0, 0, 0, 0.06); background-color: #fff;
  }
  .gm-matrix-table th.gm-sticky-name { background-color: #f8f9fa; z-index: 4; }
  .gm-matrix-table td.gm-sticky-name { font-weight: 600; }
  .gm-matrix-table th.gm-sticky-att,
  .gm-matrix-table td.gm-sticky-att {
    position: sticky; left: 220px; z-index: 3; width: 88px; min-width: 88px; max-width: 88px;
    border-right: 2px solid #dee2e6; background-color: #fff;
    box-shadow: 2px 0 2px -1px rgba(0, 0, 0, 0.06);
    text-align: center; vertical-align: middle;
  }
  .gm-matrix-table th.gm-sticky-att { background-color: #f8f9fa; z-index: 4; font-size: 0.75rem; }
  .gm-matrix-table td.gm-sticky-att { font-variant-numeric: tabular-nums; }
  .gm-band-0 { background-color: #eef6ff !important; }
  .gm-band-1 { background-color: #f3edff !important; }
  .gm-band-2 { background-color: #ecfdf3 !important; }
  .gm-band-3 { background-color: #fff4e6 !important; }
  .gm-matrix-table th.gm-date-group { text-align: center; font-weight: 700; color: #334155; }
  .gm-matrix-table .gm-col-head { white-space: nowrap; max-width: 140px; }
  .gm-eval-card { font-size: 0.85rem; }
  .schedule-shell .filter-panel {
    background: linear-gradient(145deg, #edf5ff 0%, #f8fbff 100%);
    border: 1px solid #dce9ff;
    border-radius: 14px;
  }
  .schedule-shell .range-chip.active {
    box-shadow: 0 0 0 2px rgba(13, 110, 253, 0.15);
  }
</style>

<%
  const dashHref = typeof schoolSectionDashboardHref === 'string' && schoolSectionDashboardHref
    ? schoolSectionDashboardHref
    : '/dashboard/section-nav/SCHOOL';
%>

<%- include('partials/tablePages-start', {
  title,
  newUrl: null,
  newLabel: null,
  user,
  tableName: typeof tableName !== 'undefined' ? tableName : 'Grades_Matrix',
  btn_export: false,
  print: false,
  optionalBtnsBeforePrint: [
    '<button type="button" id="btn_printGradesMatrix" class="btn btn-filled btn-edit btn-md me-2 mb-2" disabled title="Load the matrix first">🖨 Print</button>'
  ],
  headerManageBtns: [
    '<a href="' + dashHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> School Dashboard</a>',
    '<a href="/dashboard/section-nav/SCHOOL_ACADEMIA" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-journal-bookmark me-1"></i> School Academia</a>'
  ],
  manageBtns: [
    '<a href="/school/attendances" class="btn btn-outline-primary btn-md mb-2"><i class="bi bi-grid-3x3 me-1"></i> Attendance Matrix</a>'
  ]
}) %>

<div class="schedule-shell">
  <p class="text-muted small mb-3">Session gradebooks, quizzes, and assignments aligned with class <strong>Evaluation Rules</strong>. Rolling classes use attendance and assignments weights only.</p>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white d-flex align-items-center justify-content-between py-2 px-3">
      <div class="fw-bold text-dark"><i class="bi bi-funnel me-2"></i>Filter Grades Matrix</div>
      <button
        id="gmFilterToggleBtn"
        type="button"
        class="btn btn-outline-secondary btn-sm px-2"
        data-bs-toggle="collapse"
        data-bs-target="#gmFilterCollapse"
        aria-expanded="true"
        aria-controls="gmFilterCollapse"
        aria-label="Close filters">
        <i id="gmFilterToggleIcon" class="bi bi-chevron-up"></i>
      </button>
    </div>
    <div class="collapse show" id="gmFilterCollapse">
      <div class="card-body filter-panel p-3" id="gmFilterForm">
        <div class="row g-3 align-items-end">
          <div class="col-lg-4 col-md-6">
            <label class="form-label" for="gm_className">Class</label>
            <div class="input-group">
              <input type="hidden" id="gm_classId">
              <input type="text" id="gm_className" class="form-control bg-white" placeholder="All classes" readonly>
              <button type="button" class="btn btn-outline-primary" id="gm_btnClassPicker" title="Select class">
                <i class="bi bi-book"></i>
              </button>
              <button type="button" class="btn btn-outline-secondary" id="gm_btnClearClass" title="Clear class">
                <i class="bi bi-x-lg"></i>
              </button>
            </div>
          </div>
          <div class="col-lg-2 col-md-3">
            <label class="form-label" for="gm_startDate">Start Date</label>
            <input type="date" id="gm_startDate" class="form-control size-md">
          </div>
          <div class="col-lg-2 col-md-3">
            <label class="form-label" for="gm_endDate">End Date</label>
            <input type="date" id="gm_endDate" class="form-control size-md">
          </div>
          <div class="col-12 col-lg-4 d-flex justify-content-lg-end gap-2 pt-lg-2">
            <button type="button" id="gm_btnReset" class="btn btn-outline-secondary btn-md">Reset</button>
            <button type="button" id="gm_btnLoad" class="btn btn-filled btn-primary btn-md">
              <i class="bi bi-funnel me-1"></i> Apply
            </button>
          </div>
        </div>
        <div class="border rounded-3 bg-white bg-opacity-75 p-2 mt-3">
          <div class="small fw-bold text-uppercase text-muted mb-2">Quick Ranges</div>
          <div class="d-flex flex-wrap gap-2">
            <button type="button" class="btn btn-outline-secondary btn-sm gm-range range-chip" data-range="today">Today</button>
            <button type="button" class="btn btn-outline-secondary btn-sm gm-range range-chip" data-range="twoWeeks">Two Weeks</button>
            <button type="button" class="btn btn-outline-secondary btn-sm gm-range range-chip" data-range="thisWeek">This Week</button>
            <button type="button" class="btn btn-outline-secondary btn-sm gm-range range-chip" data-range="thisMonth">This Month</button>
            <button type="button" class="btn btn-outline-secondary btn-sm gm-range range-chip" data-range="allTime">All Dates</button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3 d-none" id="gm_evalCard">
    <div class="card-body py-2 gm-eval-card">
      <span class="fw-bold text-primary me-2"><i class="bi bi-sliders me-1"></i>Evaluation rules</span>
      <span class="text-muted me-2">Passing:</span><span id="gm_passing" class="me-3">—</span>
      <span class="text-muted">Weights</span>
      <span id="gm_weights" class="ms-1">—</span>
    </div>
  </div>

  <div class="card border-0 shadow-sm d-none" id="gm_results">
    <div class="card-header bg-white border-bottom py-3">
      <h5 class="m-0 fw-bold text-primary" id="gm_classTitle">Class</h5>
      <div class="small text-muted mt-1" id="gm_matrixBlurb">
        <span class="me-3" id="gm_matrixBlurbMain"><strong>Final</strong> blends weights using attendance % and the average of <em>included</em> assignment-category items (gradebooks, quizzes, assignments).</span>
        <span class="me-2"><span class="badge bg-light text-success border">Included</span> counts toward category average</span>
        <span><span class="badge bg-secondary">excl.</span> scored but excluded from average</span>
      </div>
    </div>
    <div class="card-body p-0">
      <div class="matrix-wrapper gm-matrix">
        <table class="table table-hover table-bordered mb-0 gm-matrix-table" id="gm_table">
          <thead id="gm_thead"></thead>
          <tbody id="gm_tbody"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<%- include('partials/modal_GenericPicker') %>
<%- include('partials/tablePages-end') %>

<script>
document.addEventListener('DOMContentLoaded', () => {
  function bindCollapseToggle(options = {}) {
    const collapseEl = document.getElementById(String(options.collapseId || ''));
    const buttonEl = document.getElementById(String(options.buttonId || ''));
    const iconEl = document.getElementById(String(options.iconId || ''));
    if (!collapseEl || !buttonEl || !iconEl) return;
    const setState = (open) => {
      iconEl.className = open ? 'bi bi-chevron-up' : 'bi bi-chevron-down';
      buttonEl.setAttribute('aria-expanded', open ? 'true' : 'false');
      buttonEl.setAttribute('aria-label', open ? 'Close filters' : 'Open filters');
    };
    setState(collapseEl.classList.contains('show'));
    collapseEl.addEventListener('shown.bs.collapse', () => setState(true));
    collapseEl.addEventListener('hidden.bs.collapse', () => setState(false));
  }
  bindCollapseToggle({
    collapseId: 'gmFilterCollapse',
    buttonId: 'gmFilterToggleBtn',
    iconId: 'gmFilterToggleIcon'
  });

  const INITIAL = <%- JSON.stringify({
    classId: typeof initialClassId !== 'undefined' ? initialClassId : '',
    className: typeof initialClassName !== 'undefined' ? initialClassName : '',
    startDate: typeof initialStartDate !== 'undefined' ? initialStartDate : '',
    endDate: typeof initialEndDate !== 'undefined' ? initialEndDate : '',
    range: typeof initialRange !== 'undefined' ? initialRange : ''
  }).replace(/</g, '\\u003c').replace(/&/g, '\\u0026') %>;

  window.currentGradesMatrixData = null;

  function setGradesPrintEnabled(enabled) {
    const btn = document.getElementById('btn_printGradesMatrix');
    if (!btn) return;
    btn.disabled = !enabled;
    btn.title = enabled ? 'Print grades matrix for the loaded range' : 'Load the matrix first';
  }

  const toYmd = (d) => {
    if (!d) return '';
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${y}-${m}-${day}`;
  };
  const startOfLocalDay = (d) => new Date(d.getFullYear(), d.getMonth(), d.getDate());

  function setActiveRangeChip(range) {
    document.querySelectorAll('.gm-range.range-chip').forEach((btn) => {
      btn.classList.toggle('active', btn.getAttribute('data-range') === range);
    });
  }

  function setRange(range) {
    const today = new Date();
    let start; let end;
    if (range === 'today') {
      start = startOfLocalDay(today);
      end = new Date(start);
    } else if (range === 'twoWeeks') {
      const day = today.getDay() || 7;
      start = startOfLocalDay(today);
      start.setDate(today.getDate() - (day - 1));
      end = new Date(start);
      end.setDate(start.getDate() + 13);
    } else if (range === 'thisWeek') {
      const day = today.getDay() || 7;
      start = startOfLocalDay(today);
      start.setDate(today.getDate() - (day - 1));
      end = new Date(start);
      end.setDate(start.getDate() + 6);
    } else if (range === 'thisMonth') {
      start = new Date(today.getFullYear(), today.getMonth(), 1);
      end = new Date(today.getFullYear(), today.getMonth() + 1, 0);
    } else if (range === 'allTime') {
      document.getElementById('gm_startDate').value = '';
      document.getElementById('gm_endDate').value = '';
      setActiveRangeChip(range);
      return;
    } else return;
    document.getElementById('gm_startDate').value = toYmd(start);
    document.getElementById('gm_endDate').value = toYmd(end);
    setActiveRangeChip(range);
  }

  document.querySelectorAll('.gm-range').forEach((btn) => {
    btn.addEventListener('click', () => {
      setRange(btn.getAttribute('data-range'));
      if (document.getElementById('gm_classId').value) document.getElementById('gm_btnLoad').click();
    });
  });

  document.getElementById('gm_btnClearClass')?.addEventListener('click', () => {
    document.getElementById('gm_classId').value = '';
    document.getElementById('gm_className').value = '';
    document.getElementById('gm_results').classList.add('d-none');
    document.getElementById('gm_evalCard').classList.add('d-none');
    window.currentGradesMatrixData = null;
    setGradesPrintEnabled(false);
  });

  document.getElementById('gm_btnReset')?.addEventListener('click', () => {
    document.getElementById('gm_classId').value = '';
    document.getElementById('gm_className').value = '';
    document.getElementById('gm_startDate').value = '';
    document.getElementById('gm_endDate').value = '';
    document.getElementById('gm_results').classList.add('d-none');
    document.getElementById('gm_evalCard').classList.add('d-none');
    window.currentGradesMatrixData = null;
    setGradesPrintEnabled(false);
    setActiveRangeChip('');
  });

  if (INITIAL.classId) {
    document.getElementById('gm_classId').value = INITIAL.classId;
    document.getElementById('gm_className').value = INITIAL.className || '';
    document.getElementById('gm_startDate').value = INITIAL.startDate || '';
    document.getElementById('gm_endDate').value = INITIAL.endDate || '';
    if (INITIAL.range) setActiveRangeChip(INITIAL.range);
  }

  document.getElementById('gm_btnClassPicker').addEventListener('click', () => {
    if (!window.GenericPicker || !window.GenericPickerPresets) return;
    GenericPicker.open(GenericPickerPresets.class({
      title: 'Select class',
      icon: 'bi-book',
      onSelect: (item) => {
        document.getElementById('gm_classId').value = item.id;
        document.getElementById('gm_className').value = item.title || item.id;
        document.getElementById('gm_btnLoad').click();
      }
    }));
  });

  function renderCellHtml(c) {
    if (!c) return '—';
    if (c.absent) {
      const label = c.attendanceStatus === 'not_applicable' ? 'N/A' : 'Absent';
      return `<span class="text-muted small">${label}</span>`;
    }
    if (c.score == null || c.score === '') return '—';
    const pct = c.percent != null ? `<span class="gm-pct small ms-1">${c.percent}%</span>` : '';
    const incl = c.includeInGradeCalculation !== false;
    const eff = !!c.effective;
    const wrapCls = eff ? 'gm-cell-effective' : 'gm-cell-excluded';
    const badge = !incl ? '<span class="badge bg-secondary ms-1" title="Excluded in session activity">excl.</span>' : '';
    return `<div class="${wrapCls}"><span class="gm-score">${c.score}</span>${pct}${badge}</div>`;
  }

  function bandClass(band) {
    const b = Number(band) || 0;
    return `gm-band-${Math.abs(b) % 4}`;
  }

  /** Attendance / final % display — one decimal, trim trailing .0 */
  function formatGmPercent(val) {
    if (val == null || val === '' || Number.isNaN(Number(val))) return '—';
    const n = Number(val);
    const t = Math.round(n * 10) / 10;
    const s = t % 1 === 0 ? String(t) : t.toFixed(1);
    return `${s}%`;
  }

  let gmLoadSeq = 0;
  let gmLoadAbort = null;

  document.getElementById('gm_btnLoad').addEventListener('click', async () => {
    const classId = document.getElementById('gm_classId').value;
    const startDate = document.getElementById('gm_startDate').value;
    const endDate = document.getElementById('gm_endDate').value;
    if (!classId) return;

    if (gmLoadAbort) gmLoadAbort.abort();
    gmLoadAbort = new AbortController();
    const seq = (gmLoadSeq += 1);
    const requestedClassId = classId;

    const thead = document.getElementById('gm_thead');
    const tbody = document.getElementById('gm_tbody');
    thead.innerHTML = '';
    tbody.innerHTML = '';
    document.getElementById('gm_results').classList.add('d-none');

    const btn = document.getElementById('gm_btnLoad');
    const orig = btn.innerHTML;
    btn.disabled = true;
    btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span>';

    try {
      const url = `/school/grades-matrix/api/data?classId=${encodeURIComponent(classId)}&startDate=${encodeURIComponent(startDate)}&endDate=${encodeURIComponent(endDate)}`;
      const res = await fetch(url, {
        headers: { 'X-AJAX-Request': 'true' },
        signal: gmLoadAbort.signal,
        cache: 'no-store'
      });
      const result = await res.json();
      const guarded = typeof window.applyGuardedApiResult === 'function'
        ? await window.applyGuardedApiResult(result, { busyTitle: 'Load In Progress', replayTitle: 'Load Already Completed' })
        : { stop: false };
      if (guarded.stop) return;
      if (result.status !== 'success') throw new Error(result.message || 'Load failed');
      if (seq !== gmLoadSeq) return;
      if (String(result.classId || '') !== String(requestedClassId)) return;

      window.currentGradesMatrixData = result;
      setGradesPrintEnabled(true);

      const { evaluation, columns, matrix, className, dateOrder, registrationMode } = result;
      const isRollingClass = String(registrationMode || '').trim().toLowerCase() === 'rolling';
      document.getElementById('gm_classTitle').textContent = className || 'Class';
      document.getElementById('gm_passing').textContent = (evaluation && evaluation.passingScore != null) ? `${evaluation.passingScore}%` : '—';
      const w = evaluation && evaluation.weights ? evaluation.weights : {};
      const weightParts = [
        w.attendance != null ? `Attendance ${w.attendance}%` : null,
        w.assignments != null ? `Assignments ${w.assignments}%` : null
      ];
      if (!isRollingClass) {
        weightParts.push(w.midterm != null ? `Midterm ${w.midterm}%` : null);
        weightParts.push(w.finalExam != null ? `Final exam ${w.finalExam}%` : null);
      }
      document.getElementById('gm_weights').innerHTML = weightParts.filter(Boolean).join(' · ') || '—';
      const blurbMain = document.getElementById('gm_matrixBlurbMain');
      if (blurbMain) {
        blurbMain.innerHTML = isRollingClass
          ? '<strong>Final</strong> uses only <strong>attendance</strong> and <strong>assignments</strong> weights (rolling classes). Assignments = average of <em>included</em> session items (gradebooks, quizzes, assignments). Midterm and final exam weights do not apply.'
          : '<strong>Final</strong> blends weights using attendance % and the average of <em>included</em> assignment-category items (gradebooks, quizzes, assignments). Session items map to the assignments bucket; midterm/final exam weights on the class apply when those components are wired into this view.';
      }
      document.getElementById('gm_evalCard').classList.remove('d-none');

      if (!columns || !columns.length) {
        thead.innerHTML = '<tr><th class="gm-sticky-final">Final</th><th class="gm-sticky-name">Student</th><th class="gm-sticky-att" title="Attendance performance % for the selected period">Attend.</th><th>No graded items in this date range</th></tr>';
        matrix.forEach((row) => {
          const tr = document.createElement('tr');
          const fp = formatGmPercent(row.finalPercent);
          const att = formatGmPercent(row.attendancePct);
          tr.innerHTML = `<td class="gm-sticky-final text-center small">${fp}</td><td class="gm-sticky-name ps-3">${typeof schoolRenderStudentNameHtml === 'function' ? schoolRenderStudentNameHtml(row.name, row.studentRecordId) : row.name}</td><td class="gm-sticky-att small">${att}</td><td class="text-muted">—</td>`;
          tbody.appendChild(tr);
        });
        document.getElementById('gm_results').classList.remove('d-none');
        return;
      }

      const groups = [];
      let i = 0;
      while (i < columns.length) {
        const d = columns[i].date;
        let j = i;
        while (j < columns.length && columns[j].date === d) j += 1;
        groups.push({ date: d, start: i, len: j - i });
        i = j;
      }

      const trDate = document.createElement('tr');
      trDate.innerHTML = `<th class="gm-sticky-final gm-date-group" rowspan="2">Final</th>
        <th class="gm-sticky-name gm-date-group" rowspan="2">Student</th>
        <th class="gm-sticky-att gm-date-group" rowspan="2" title="Attendance performance % for sessions in the selected date range (same credit rules as the attendance matrix)">Attend.</th>`;
      groups.forEach((g) => {
        const th = document.createElement('th');
        th.colSpan = g.len;
        th.className = `gm-date-group ${bandClass(columns[g.start].dateBand)}`;
        th.textContent = g.date || '—';
        trDate.appendChild(th);
      });
      const trCols = document.createElement('tr');
      columns.forEach((col) => {
        const th = document.createElement('th');
        th.className = `gm-col-head text-center ${bandClass(col.dateBand)}`;
        th.innerHTML = `<div class="small text-muted">${col.kindLabel || ''}</div><div class="text-dark text-truncate" title="${col.label}">${col.label}</div>`;
        trCols.appendChild(th);
      });
      thead.appendChild(trDate);
      thead.appendChild(trCols);

      matrix.forEach((row) => {
        const tr = document.createElement('tr');
        const fp = row.finalPercent != null ? `<span class="fw-bold">${formatGmPercent(row.finalPercent)}</span>` : '—';
        const attStr = formatGmPercent(row.attendancePct);
        const attCell = attStr === '—'
          ? '<span class="text-muted">—</span>'
          : `<span class="fw-semibold text-primary">${attStr}</span>`;
        let html = `<td class="gm-sticky-final text-center small">${fp}</td><td class="gm-sticky-name ps-3">${typeof schoolRenderStudentNameHtml === 'function' ? schoolRenderStudentNameHtml(row.name, row.studentRecordId) : row.name}</td><td class="gm-sticky-att small">${attCell}</td>`;
        row.cells.forEach((cell, idx) => {
          const col = columns[idx];
          html += `<td class="text-center small ${bandClass(col.dateBand)}">${renderCellHtml(cell)}</td>`;
        });
        tr.innerHTML = html;
        tbody.appendChild(tr);
      });

      document.getElementById('gm_results').classList.remove('d-none');
    } catch (e) {
      if (e && e.name === 'AbortError') return;
      window.currentGradesMatrixData = null;
      setGradesPrintEnabled(false);
      if (typeof showMessageModal === 'function') {
        showMessageModal({ title: 'Error', icon: 'error', message: e.message, buttons: [{ text: 'OK', class: 'btn-secondary' }] });
      } else {
        alert(e.message);
      }
    } finally {
      btn.disabled = false;
      btn.innerHTML = orig;
    }
  });

  // --- Grades Matrix Print ---
  function gmPrintEscapeHtml(value) {
    return String(value == null ? '' : value)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function gmPrintFormatDateShort(ymd) {
    const raw = String(ymd || '').trim();
    if (!/^\d{4}-\d{2}-\d{2}$/.test(raw)) return raw || '—';
    const d = new Date(`${raw}T00:00:00`);
    if (Number.isNaN(d.getTime())) return raw;
    return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
  }

  function gmPrintFormatRangeLabel(startDate, endDate) {
    const start = String(startDate || '').trim();
    const end = String(endDate || '').trim();
    if (!start && !end) return 'All sessions';
    if (start && end) return `${gmPrintFormatDateShort(start)} – ${gmPrintFormatDateShort(end)}`;
    if (start) return `From ${gmPrintFormatDateShort(start)}`;
    return `Through ${gmPrintFormatDateShort(end)}`;
  }

  function gmPrintFormatPercent(val) {
    if (val == null || val === '' || Number.isNaN(Number(val))) return '—';
    const n = Number(val);
    const t = Math.round(n * 10) / 10;
    const s = t % 1 === 0 ? String(t) : t.toFixed(1);
    return `${s}%`;
  }

  function gmPrintTruncate(text, maxLen) {
    const s = String(text || '').trim();
    if (s.length <= maxLen) return s;
    return `${s.slice(0, Math.max(0, maxLen - 1))}…`;
  }

  function gmPrintCellText(cell, col) {
    if (!cell) return { text: '—', cls: 'st-empty' };
    if (cell.absent) {
      const label = cell.attendanceStatus === 'not_applicable' ? 'N/A' : 'Absent';
      return { text: label, cls: 'st-absent' };
    }
    if (cell.score == null || cell.score === '') return { text: '—', cls: 'st-empty' };
    const total = Number(col?.totalScore) || 0;
    const score = cell.score;
    const pct = cell.percent != null ? `${cell.percent}%` : '';
    const scorePart = total > 0 ? `${score}/${total}` : String(score);
    const text = pct ? `${scorePart} · ${pct}` : scorePart;
    const excl = cell.includeInGradeCalculation === false;
    const eff = !!cell.effective;
    let cls = 'st-score';
    if (excl) cls += ' st-excl';
    else if (eff) cls += ' st-eff';
    return { text, cls };
  }

  function gmPrintBuildSummary(matrixData) {
    const students = Array.isArray(matrixData?.matrix) ? matrixData.matrix : [];
    const sessions = Array.isArray(matrixData?.sessions) ? matrixData.sessions : [];
    const columns = Array.isArray(matrixData?.columns) ? matrixData.columns : [];
    let finalSum = 0;
    let finalCount = 0;
    let attSum = 0;
    let attCount = 0;
    students.forEach((row) => {
      if (row?.finalPercent != null && Number.isFinite(Number(row.finalPercent))) {
        finalSum += Number(row.finalPercent);
        finalCount += 1;
      }
      if (row?.attendancePct != null && Number.isFinite(Number(row.attendancePct))) {
        attSum += Number(row.attendancePct);
        attCount += 1;
      }
    });
    return {
      studentCount: students.length,
      sessionCount: sessions.length,
      columnCount: columns.length,
      avgFinal: finalCount ? Math.round((finalSum / finalCount) * 10) / 10 : null,
      avgAttend: attCount ? Math.round((attSum / attCount) * 10) / 10 : null
    };
  }

  function buildGradesPrintDocument(matrixData, meta = {}) {
    const data = matrixData && typeof matrixData === 'object' ? matrixData : {};
    const columns = Array.isArray(data.columns) ? data.columns : [];
    const students = Array.isArray(data.matrix) ? data.matrix : [];
    const summary = gmPrintBuildSummary(data);
    const className = String(data.className || meta.className || 'Class').trim() || 'Class';
    const orgName = String(meta.orgName || '').trim();
    const rangeLabel = gmPrintFormatRangeLabel(meta.startDate, meta.endDate);
    const printedAt = meta.printedAt instanceof Date ? meta.printedAt : new Date();
    const printedAtLabel = printedAt.toLocaleString('en-US', {
      year: 'numeric', month: 'short', day: 'numeric',
      hour: 'numeric', minute: '2-digit'
    });
    const evaluation = data.evaluation || {};
    const weights = evaluation.weights || {};
    const isRolling = String(data.registrationMode || '').trim().toLowerCase() === 'rolling';
    const passing = evaluation.passingScore != null ? `${evaluation.passingScore}%` : '—';
    const weightParts = [
      weights.attendance != null ? `Attendance ${weights.attendance}%` : null,
      weights.assignments != null ? `Assignments ${weights.assignments}%` : null
    ];
    if (!isRolling) {
      weightParts.push(weights.midterm != null ? `Midterm ${weights.midterm}%` : null);
      weightParts.push(weights.finalExam != null ? `Final exam ${weights.finalExam}%` : null);
    }
    const weightsLabel = weightParts.filter(Boolean).join(' · ') || '—';

    const groups = [];
    let gi = 0;
    while (gi < columns.length) {
      const d = columns[gi].date;
      let gj = gi;
      while (gj < columns.length && columns[gj].date === d) gj += 1;
      groups.push({ date: d, start: gi, len: gj - gi });
      gi = gj;
    }

    const dateHeaderCells = groups.map((g) => {
      const shortDate = gmPrintFormatDateShort(g.date);
      return `<th class="day-group" colspan="${g.len}">${gmPrintEscapeHtml(shortDate)}</th>`;
    }).join('');

    const activityHeaderCells = columns.map((col) => {
      const kind = String(col.kindLabel || '').trim();
      const label = gmPrintTruncate(col.label, 28);
      const excl = col.includeInGradeCalculation === false ? ' <span class="excl-tag">excl.</span>' : '';
      return `<th class="act-col"><div class="act-kind">${gmPrintEscapeHtml(kind)}</div><div class="act-label">${gmPrintEscapeHtml(label)}${excl}</div></th>`;
    }).join('');

    const bodyRows = students.map((row, index) => {
      const name = String(row.name || 'Student');
      const fp = gmPrintFormatPercent(row.finalPercent);
      const att = gmPrintFormatPercent(row.attendancePct);
      const cells = (Array.isArray(row.cells) ? row.cells : []).map((cell, idx) => {
        const col = columns[idx] || {};
        const rendered = gmPrintCellText(cell, col);
        return `<td class="gm-print-cell ${rendered.cls}">${gmPrintEscapeHtml(rendered.text)}</td>`;
      }).join('');
      const emptyCols = !columns.length
        ? '<td class="gm-print-cell st-empty">—</td>'
        : cells;
      return `<tr>
        <td class="num-col">${index + 1}</td>
        <td class="final-col">${gmPrintEscapeHtml(fp)}</td>
        <td class="name-col">${gmPrintEscapeHtml(name)}</td>
        <td class="att-col">${gmPrintEscapeHtml(att)}</td>
        ${emptyCols}
      </tr>`;
    }).join('');

    const emptyRow = !students.length
      ? `<tr><td colspan="${Math.max(4, columns.length + 4)}" class="empty-msg">No students found for this range.</td></tr>`
      : '';

    const avgFinalLabel = summary.avgFinal == null ? '—' : gmPrintFormatPercent(summary.avgFinal);
    const avgAttendLabel = summary.avgAttend == null ? '—' : gmPrintFormatPercent(summary.avgAttend);

    return `<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <title>${gmPrintEscapeHtml(`Grades Matrix — ${className}`)}</title>
  <style>
    @page { size: letter landscape; margin: 10mm; }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Segoe UI", Arial, sans-serif;
      font-size: 10px;
      color: #111;
      line-height: 1.25;
    }
    .sheet { padding: 0; }
    .doc-header { margin-bottom: 8px; }
    .doc-header h1 {
      margin: 0 0 2px 0;
      font-size: 16px;
      font-weight: 700;
    }
    .org-name {
      font-size: 13px;
      font-weight: 700;
      margin: 0 0 4px 0;
    }
    .meta-row {
      display: flex;
      flex-wrap: wrap;
      gap: 8px 18px;
      color: #333;
      margin-bottom: 4px;
    }
    .meta-row span strong { font-weight: 600; }
    .eval-line {
      color: #444;
      margin-bottom: 6px;
      font-size: 9.5px;
    }
    .summary {
      display: flex;
      flex-wrap: wrap;
      gap: 6px 14px;
      border: 1px solid #ccc;
      background: #f8f9fa;
      padding: 6px 8px;
      margin-bottom: 8px;
      border-radius: 2px;
    }
    .summary .stat { white-space: nowrap; }
    .summary .stat b { font-weight: 700; }
    .legend {
      margin: 0 0 8px 0;
      color: #444;
      font-size: 9.5px;
    }
    table.matrix {
      width: 100%;
      border-collapse: collapse;
      table-layout: auto;
    }
    table.matrix th,
    table.matrix td {
      border: 1px solid #bbb;
      padding: 3px 4px;
      vertical-align: middle;
    }
    table.matrix thead th {
      background: #eef1f4;
      font-weight: 700;
      text-align: center;
    }
    table.matrix thead { display: table-header-group; }
    table.matrix tbody tr { page-break-inside: avoid; }
    .num-col { width: 28px; text-align: center; color: #555; }
    .final-col { text-align: center; min-width: 48px; font-weight: 700; white-space: nowrap; }
    .name-col { text-align: left; min-width: 110px; max-width: 160px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .att-col { text-align: center; min-width: 48px; white-space: nowrap; color: #0d6efd; font-weight: 600; }
    .day-group { font-size: 9.5px; }
    .act-col { min-width: 56px; max-width: 90px; }
    .act-kind { font-size: 8px; color: #666; font-weight: 500; }
    .act-label { font-size: 9px; }
    .excl-tag { font-size: 7.5px; color: #6c757d; font-weight: 600; }
    .gm-print-cell {
      text-align: center;
      white-space: nowrap;
      font-size: 9px;
    }
    .st-score { font-weight: 600; }
    .st-eff { color: #0f5132; }
    .st-excl { color: #6c757d; font-weight: 500; }
    .st-absent { color: #842029; font-weight: 500; }
    .st-empty { color: #6c757d; }
    .empty-msg { text-align: center; color: #666; padding: 16px !important; }
    .doc-footer {
      margin-top: 10px;
      padding-top: 4px;
      border-top: 1px solid #ddd;
      color: #666;
      font-size: 9px;
      display: flex;
      justify-content: space-between;
      gap: 12px;
    }
    @media print {
      body { margin: 0; }
      .no-print { display: none !important; }
      a { color: inherit; text-decoration: none; }
    }
    @media screen {
      body { background: #e9ecef; padding: 16px; }
      .sheet {
        background: #fff;
        padding: 14px 16px;
        box-shadow: 0 1px 6px rgba(0,0,0,0.12);
        max-width: 100%;
      }
      .screen-actions {
        margin-bottom: 10px;
        display: flex;
        gap: 8px;
      }
      .screen-actions button {
        font: inherit;
        padding: 6px 12px;
        cursor: pointer;
      }
    }
  </style>
</head>
<body>
  <div class="screen-actions no-print">
    <button type="button" onclick="window.print()">Print</button>
    <button type="button" onclick="window.close()">Close</button>
  </div>
  <div class="sheet">
    <header class="doc-header">
      ${orgName ? `<div class="org-name">${gmPrintEscapeHtml(orgName)}</div>` : ''}
      <h1>Grades Matrix</h1>
      <div class="meta-row">
        <span><strong>Class:</strong> ${gmPrintEscapeHtml(className)}</span>
        <span><strong>Range:</strong> ${gmPrintEscapeHtml(rangeLabel)}</span>
        <span><strong>Printed:</strong> ${gmPrintEscapeHtml(printedAtLabel)}</span>
      </div>
      <div class="eval-line"><strong>Passing:</strong> ${gmPrintEscapeHtml(passing)} · <strong>Weights:</strong> ${gmPrintEscapeHtml(weightsLabel)}</div>
    </header>

    <div class="summary">
      <span class="stat"><b>${summary.studentCount}</b> students</span>
      <span class="stat"><b>${summary.sessionCount}</b> sessions</span>
      <span class="stat"><b>${summary.columnCount}</b> activities</span>
      <span class="stat">Avg Final <b>${gmPrintEscapeHtml(avgFinalLabel)}</b></span>
      <span class="stat">Avg Attend. <b>${gmPrintEscapeHtml(avgAttendLabel)}</b></span>
    </div>
    <div class="legend">Legend: score/total · percent% · excl. = scored but excluded from category average · Absent / N/A = no score due to attendance · — = no score</div>

    <table class="matrix">
      <thead>
        ${columns.length ? `<tr>
          <th class="num-col" rowspan="2">#</th>
          <th class="final-col" rowspan="2">Final %</th>
          <th class="name-col" rowspan="2">Student</th>
          <th class="att-col" rowspan="2">Attend. %</th>
          ${dateHeaderCells}
        </tr>
        <tr>
          ${activityHeaderCells}
        </tr>` : `<tr>
          <th class="num-col">#</th>
          <th class="final-col">Final %</th>
          <th class="name-col">Student</th>
          <th class="att-col">Attend. %</th>
          <th>No graded items in this date range</th>
        </tr>`}
      </thead>
      <tbody>
        ${bodyRows || emptyRow}
      </tbody>
    </table>

    <footer class="doc-footer">
      <span>Generated from Grades Matrix</span>
      <span>${gmPrintEscapeHtml(className)} · ${gmPrintEscapeHtml(rangeLabel)}</span>
    </footer>
  </div>
</body>
</html>`;
  }

  function openGradesPrint() {
    if (!window.currentGradesMatrixData || window.currentGradesMatrixData.status !== 'success') {
      if (typeof showMessageModal === 'function') {
        showMessageModal({
          title: 'Nothing to print',
          icon: 'warning',
          message: 'Load a grades matrix for a class first.',
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
      } else {
        alert('Load a grades matrix for a class first.');
      }
      return;
    }

    const orgName = String(document.getElementById('activeOrgNameRef')?.getAttribute('data-name') || '').trim();
    const startDate = document.getElementById('gm_startDate')?.value || '';
    const endDate = document.getElementById('gm_endDate')?.value || '';
    const html = buildGradesPrintDocument(window.currentGradesMatrixData, {
      orgName,
      startDate,
      endDate,
      className: window.currentGradesMatrixData.className,
      printedAt: new Date()
    });

    // Do not pass noopener/noreferrer in features: browsers return null and we cannot write the print HTML.
    const printWindow = window.open('', '_blank', 'height=720,width=1100');
    if (!printWindow) {
      if (typeof showMessageModal === 'function') {
        showMessageModal({
          title: 'Popup blocked',
          icon: 'warning',
          message: 'Allow pop-ups for this site to open the print page.',
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
      } else {
        alert('Allow pop-ups for this site to open the print page.');
      }
      return;
    }

    try {
      printWindow.opener = null;
    } catch (_) { /* ignore */ }

    try {
      const byLabel = String(document.getElementById('activeOrgIdRef')?.getAttribute('data-id') || '').trim();
      const qsParts = ['print=1', 'view=grades-matrix'];
      if (byLabel) qsParts.push(`org=${encodeURIComponent(byLabel)}`);
      printWindow.history.replaceState({}, '', `${location.pathname}?${qsParts.join('&')}`);
    } catch (_) { /* ignore */ }

    printWindow.document.open();
    printWindow.document.write(html);
    printWindow.document.close();
    printWindow.focus();
    setTimeout(() => {
      try { printWindow.print(); } catch (_) { /* ignore */ }
    }, 250);
  }

  document.getElementById('btn_printGradesMatrix')?.addEventListener('click', () => openGradesPrint());

  if (INITIAL.classId) {
    setTimeout(() => document.getElementById('gm_btnLoad').click(), 100);
  }
});
</script>
