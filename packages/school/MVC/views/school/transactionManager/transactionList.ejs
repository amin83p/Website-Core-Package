<%- include('partials/tablePages-start', {
  title, newUrl, newLabel, user, tableName, btn_export: true, print,
  manageBtns: [
    '<a href="' + schoolSectionDashboardHref + '" class="school-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> Dashboard</a>',
    `<a href="/school/transactions/statement" class="btn btn-outline-primary btn-md mb-2"><i class="bi bi-clipboard-data me-1"></i> Statement</a>`
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search transaction journals...',
  fields: [
    { name: 'status', label: 'Status', type: 'select', options: ['draft', 'posted', 'voided'] },
    { name: 'transactionType', label: 'Type', type: 'select', options: ['charge', 'payment', 'refund', 'waiver', 'adjustment'] }
  ]
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="ps-4">Journal</th>
        <th>Effective Date</th>
        <th>Description</th>
        <th class="text-center">Lines</th>
        <th>Total Debit</th>
        <th>Total Credit</th>
        <th>Difference</th>
        <th class="text-center">Status</th>
        <th class="text-end pe-4">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% if(data.length === 0) { %>
        <tr><td colspan="9" class="text-center py-4 text-muted">No transaction journals found.</td></tr>
      <% } %>

      <% data.forEach(item => { %>
        <% const totals = item.totals || {}; %>
        <tr>
          <td class="ps-4">
            <div class="fw-bold text-primary"><%= item.journalNumber || item.id %></div>
            <div class="x-small text-muted font-monospace"><%= item.id %></div>
            <div class="small text-muted"><%= (item.transactionType || 'adjustment').toUpperCase() %></div>
          </td>
          <td><%= item.effectiveDate || '-' %></td>
          <td>
            <div class="small fw-bold text-dark"><%= item.description || '-' %></div>
            <div class="x-small text-muted"><%= item.referenceNo || '-' %></div>
          </td>
          <td class="text-center fw-bold"><%= item.lineCount || 0 %></td>
          <td class="fw-bold text-success"><%= Number(totals.debit || 0).toFixed(2) %> <%= item.currency || 'CAD' %></td>
          <td class="fw-bold text-danger"><%= Number(totals.credit || 0).toFixed(2) %> <%= item.currency || 'CAD' %></td>
          <td>
            <% const diff = Number(totals.difference || 0); %>
            <% if (diff === 0) { %>
              <span class="badge bg-success">Balanced</span>
            <% } else { %>
              <span class="badge bg-warning text-dark"><%= diff.toFixed(2) %></span>
            <% } %>
          </td>
          <td class="text-center">
            <%
              let badge = 'bg-secondary';
              if (item.status === 'posted') badge = 'bg-success';
              if (item.status === 'draft') badge = 'bg-warning text-dark';
              if (item.status === 'voided') badge = 'bg-danger';
            %>
            <span class="badge <%= badge %>"><%= (item.status || 'unknown').toUpperCase() %></span>
          </td>
          <td class="table-actions text-end pe-4">
            <% if (item.status === 'draft') { %>
              <a href="/school/transactions/edit/<%= item.id %>" class="btn btn-sm btn-filled btn-edit">Edit</a>
              <button class="btn btn-sm btn-filled btn-delete delete-btn" data-id="<%= item.id %>">Delete</button>
            <% } else { %>
              <a href="/school/transactions/edit/<%= item.id %>" class="btn btn-sm btn-outline-secondary">View</a>
            <% } %>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<span id="urlRef" data-id="school/transactions" hidden></span>
<%- include('partials/pagination', { pagination, filters, baseUrlPath: 'school/transactions' }) %>
<%- include('partials/tablePages-end') %>
