<%
  const j = journal || {};
  const isEdit = !!j.id;
  const routeId = (j.id || '');
  const asid = (typeof actionStateId !== 'undefined' && actionStateId) ? actionStateId : '';
  const initLines = JSON.stringify(Array.isArray(j.lines) ? j.lines : []).replace(/</g, '\\u003c');
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-heading size-md m-0"><i class="bi bi-arrow-left-right me-2"></i><%= title %></h1>
    <a href="/school/transactions" class="btn btn-outline-secondary btn-sm"><i class="bi bi-arrow-left"></i> Back to List</a>
  </div>

  <div class="form-container wide" style="max-width: 1450px;">
    <form id="transactionJournalForm" action="<%= isEdit ? '/school/transactions/edit/'+routeId : '/school/transactions/new' %>" method="POST">
      <input type="hidden" name="actionStateId" id="hid_actionStateId" value="<%= asid %>">
      <input type="hidden" name="lines" id="hid_lines" value="[]">
      <input type="hidden" name="saveAction" id="hid_saveAction" value="auto">

      <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-4">
          <% if (isReadOnly) { %>
            <div class="alert alert-success border-success shadow-sm mb-3">
              <i class="bi bi-check-circle me-2"></i>This journal is posted and read-only.
            </div>
          <% } else { %>
            <div class="alert alert-info border-info shadow-sm mb-3">
              <i class="bi bi-info-circle me-2"></i>Balanced journals can be posted. Unbalanced journals are automatically saved as draft.
            </div>
          <% } %>

          <div class="row">
            <div class="col-md-2 mb-3">
              <label class="form-label fw-bold">Journal ID</label>
              <input type="text" name="journalId" class="form-control size-md font-monospace" value="<%= j.id || '' %>" placeholder="Auto-generated if blank" <%= isEdit ? 'readonly' : '' %>>
            </div>
            <div class="col-md-2 mb-3">
              <label class="form-label fw-bold">Journal No.</label>
              <input type="text" class="form-control size-md font-monospace" value="<%= j.journalNumber || 'Auto-generated' %>" readonly>
            </div>
            <div class="col-md-2 mb-3">
              <label class="form-label fw-bold">Effective Date *</label>
              <input type="date" name="effectiveDate" class="form-control size-md" value="<%= j.effectiveDate || '' %>" required <%= isReadOnly ? 'readonly' : '' %>>
            </div>
            <div class="col-md-2 mb-3">
              <label class="form-label fw-bold">Type *</label>
              <select name="transactionType" class="form-select size-md" <%= isReadOnly ? 'disabled' : '' %>>
                <% (transactionTypes || []).forEach(tp => { %>
                  <option value="<%= tp %>" <%= (j.transactionType || 'adjustment') === tp ? 'selected' : '' %>><%= tp %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-md-2 mb-3">
              <label class="form-label fw-bold">Status</label>
              <input type="text" class="form-control size-md fw-bold" value="<%= (j.status || 'draft').toUpperCase() %>" readonly>
            </div>
            <div class="col-md-2 mb-3">
              <label class="form-label fw-bold">Reference No.</label>
              <input type="text" name="referenceNo" class="form-control size-md" value="<%= j.referenceNo || '' %>" placeholder="Optional" <%= isReadOnly ? 'readonly' : '' %>>
            </div>
          </div>

          <div class="row">
            <div class="col-md-8 mb-3">
              <label class="form-label fw-bold">Description *</label>
              <input type="text" name="description" class="form-control size-md" value="<%= j.description || '' %>" placeholder="Describe this journal..." required <%= isReadOnly ? 'readonly' : '' %>>
            </div>
            <div class="col-md-4 mb-3">
              <label class="form-label fw-bold">External Reference</label>
              <input type="text" name="externalReference" class="form-control size-md" value="<%= j.externalReference || '' %>" placeholder="Optional" <%= isReadOnly ? 'readonly' : '' %>>
            </div>
          </div>

          <div class="row">
            <div class="col-md-12 mb-3">
              <label class="form-label fw-bold">Internal Note</label>
              <textarea name="internalNote" class="form-control size-md" rows="2" placeholder="Optional internal note..." <%= isReadOnly ? 'readonly' : '' %>><%= j.internalNote || '' %></textarea>
            </div>
          </div>

          <div class="border rounded-3 p-3 mb-3 bg-light-subtle <%= isReadOnly ? 'd-none' : '' %>">
            <div class="row align-items-end">
              <div class="col-md-4 mb-3">
                <label class="form-label fw-bold">Account *</label>
                <div class="input-group">
                  <input type="hidden" id="inp_lineAccountId">
                  <input type="text" id="inp_lineAccountLabel" class="form-control size-md bg-white" placeholder="Pick active + postable account..." readonly>
                  <button type="button" class="btn btn-outline-primary" id="btnPickLineAccount"><i class="bi bi-search"></i></button>
                  <button type="button" class="btn btn-outline-secondary" id="btnClearLineAccount"><i class="bi bi-x-lg"></i></button>
                </div>
              </div>
              <div class="col-md-2 mb-3">
                <label class="form-label fw-bold">Direction *</label>
                <select id="inp_lineDirection" class="form-select size-md">
                  <% (lineDirections || []).forEach(dir => { %>
                    <option value="<%= dir %>"><%= dir %></option>
                  <% }) %>
                </select>
              </div>
              <div class="col-md-2 mb-3">
                <label class="form-label fw-bold">Amount *</label>
                <input type="number" id="inp_lineAmount" class="form-control size-md" min="0.01" step="0.01">
              </div>
              <div class="col-md-1 mb-3">
                <label class="form-label fw-bold">CCY</label>
                <input type="text" id="inp_lineCurrency" class="form-control size-md font-monospace" maxlength="3" value="CAD">
              </div>
              <div class="col-md-3 mb-3">
                <button type="button" class="btn btn-filled btn-primary btn-sm w-100" id="btnAddLine">
                  <i class="bi bi-plus-circle me-1"></i>Add Line
                </button>
              </div>
            </div>
            <div class="row align-items-end">
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Line Memo</label>
                <input type="text" id="inp_lineMemo" class="form-control size-md" placeholder="Optional">
              </div>
              <div class="col-md-6 mb-3">
                <label class="form-label fw-bold">Line Note</label>
                <input type="text" id="inp_lineNote" class="form-control size-md" placeholder="Optional">
              </div>
            </div>
          </div>

          <div class="table-responsive mb-3">
            <table class="table table-sm align-middle">
              <thead>
                <tr>
                  <th>#</th>
                  <th>Account</th>
                  <th>Direction</th>
                  <th>Amount</th>
                  <th>Currency</th>
                  <th>Memo</th>
                  <th>Note</th>
                  <th class="text-end <%= isReadOnly ? 'd-none' : '' %>">Actions</th>
                </tr>
              </thead>
              <tbody id="journalLinesTbody"></tbody>
              <tfoot>
                <tr>
                  <th colspan="3" class="text-end">Totals</th>
                  <th id="txt_totalDebit" class="text-success">0.00</th>
                  <th id="txt_totalCredit" class="text-danger">0.00</th>
                  <th colspan="3"></th>
                </tr>
              </tfoot>
            </table>
          </div>

          <div id="balancePanel" class="alert mb-0"></div>
        </div>
      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <% if (!isReadOnly) { %>
          <button type="submit" class="btn btn-filled btn-primary btn-md fw-bold px-4 js-save-btn" data-save-action="auto">Save (Auto)</button>
          <button type="submit" class="btn btn-filled btn-secondary btn-md js-save-btn" data-save-action="draft">Save Draft</button>
          <button type="submit" class="btn btn-filled btn-success btn-md js-save-btn" data-save-action="post" id="btnPostNow">Post Now</button>
        <% } %>
        <a href="/school/transactions" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction" data-return-url="/school/transactions">Cancel</a>
      </div>
    </form>
  </div>
</div>

<%- include('partials/modal_GenericPicker') %>

<script>
  window.__INIT_JOURNAL_LINES__ = <%- initLines %>;
  window.__INIT_LINE_ACCOUNT_REFS__ = <%- JSON.stringify(lineAccountRefs || []).replace(/</g, '\\u003c') %>;
  window.__READ_ONLY_JOURNAL__ = <%- JSON.stringify(!!isReadOnly) %>;
</script>

<script>
(function () {
  const form = document.getElementById('transactionJournalForm');
  const hidLines = document.getElementById('hid_lines');
  const hidSaveAction = document.getElementById('hid_saveAction');
  const linesTbody = document.getElementById('journalLinesTbody');
  const totalDebitEl = document.getElementById('txt_totalDebit');
  const totalCreditEl = document.getElementById('txt_totalCredit');
  const balancePanel = document.getElementById('balancePanel');
  const readOnly = Boolean(window.__READ_ONLY_JOURNAL__);

  const lineAccountRefs = Array.isArray(window.__INIT_LINE_ACCOUNT_REFS__) ? window.__INIT_LINE_ACCOUNT_REFS__ : [];
  const accountsMap = new Map(lineAccountRefs.map(function (a) { return [String(a.id), a]; }));
  const lineAccountIdField = document.getElementById('inp_lineAccountId');
  const lineAccountLabelField = document.getElementById('inp_lineAccountLabel');
  let lines = Array.isArray(window.__INIT_JOURNAL_LINES__) ? window.__INIT_JOURNAL_LINES__ : [];
  let selectedSaveAction = 'auto';
  let actionInProgress = false;

  function showMsg(opts) {
    if (typeof showMessageModal === 'function') return showMessageModal(opts);
    alert(opts?.message || 'Done');
    return Promise.resolve();
  }

  function safeHtml(s) {
    return String(s ?? '').replace(/[&<>"']/g, function (m) {
      return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[m];
    });
  }

  function roundMoney(n) {
    return Math.round(Number(n || 0) * 100) / 100;
  }

  function formatAccountLabel(account) {
    const code = String(account?.code || '').trim();
    const name = String(account?.name || '').trim();
    const id = String(account?.id || '').trim();
    if (code && name) return code + ' - ' + name;
    return name || code || id;
  }

  function applyLineAccountSelection(account) {
    const accountId = String(account?.id || '').trim();
    if (!accountId) {
      if (lineAccountIdField) lineAccountIdField.value = '';
      if (lineAccountLabelField) lineAccountLabelField.value = '';
      return;
    }

    accountsMap.set(accountId, {
      id: accountId,
      code: String(account?.code || '').trim(),
      name: String(account?.name || '').trim(),
      status: String(account?.status || '').trim().toLowerCase(),
      allowPost: Boolean(account?.allowPost)
    });
    if (lineAccountIdField) lineAccountIdField.value = accountId;
    if (lineAccountLabelField) lineAccountLabelField.value = formatAccountLabel(account);
  }

  function normalizeLines() {
    lines = (lines || []).map(function (line, idx) {
      return {
        lineNo: Number(idx + 1),
        accountId: String(line?.accountId || '').trim(),
        direction: String(line?.direction || 'debit').trim().toLowerCase(),
        amount: roundMoney(Number(line?.amount || 0)),
        currency: String(line?.currency || 'CAD').trim().toUpperCase() || 'CAD',
        memo: String(line?.memo || '').trim(),
        note: String(line?.note || '').trim()
      };
    }).filter(function (line) {
      return line.accountId && (line.direction === 'debit' || line.direction === 'credit') && Number.isFinite(line.amount) && line.amount > 0;
    });
  }

  function computeTotals() {
    let debit = 0;
    let credit = 0;
    lines.forEach(function (line) {
      if (line.direction === 'debit') debit = roundMoney(debit + Number(line.amount || 0));
      if (line.direction === 'credit') credit = roundMoney(credit + Number(line.amount || 0));
    });
    const difference = roundMoney(debit - credit);
    return {
      debit: roundMoney(debit),
      credit: roundMoney(credit),
      difference,
      isBalanced: lines.length >= 2 && difference === 0
    };
  }

  function syncHidden() {
    hidLines.value = JSON.stringify(lines);
    hidSaveAction.value = selectedSaveAction;
  }

  function setSubmitLock(isLocked, activeButton, loadingLabel) {
    const saveButtons = Array.from(form.querySelectorAll('.js-save-btn'));
    const cancelButton = document.getElementById('btnCancelAction');

    saveButtons.forEach(function (btn) {
      if (!btn) return;
      if (!btn.dataset.originalHtml) btn.dataset.originalHtml = btn.innerHTML;
      btn.disabled = isLocked;
    });

    if (cancelButton) {
      cancelButton.classList.toggle('disabled', isLocked);
      if (isLocked) cancelButton.setAttribute('aria-disabled', 'true');
      else cancelButton.removeAttribute('aria-disabled');
    }

    if (activeButton) {
      if (!activeButton.dataset.originalHtml) activeButton.dataset.originalHtml = activeButton.innerHTML;
      if (isLocked) {
        activeButton.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>' + String(loadingLabel || 'Saving...');
      } else if (activeButton.dataset.originalHtml) {
        activeButton.innerHTML = activeButton.dataset.originalHtml;
      }
    }

    if (typeof showLoading === 'function') {
      if (isLocked) showLoading();
      else if (typeof hideLoading === 'function') hideLoading();
    }
  }

  function renderBalance() {
    const totals = computeTotals();
    totalDebitEl.textContent = totals.debit.toFixed(2);
    totalCreditEl.textContent = totals.credit.toFixed(2);

    if (totals.isBalanced) {
      balancePanel.className = 'alert alert-success mb-0';
      balancePanel.innerHTML = '<i class="bi bi-check-circle me-2"></i><b>Balanced.</b> This journal can be posted.';
    } else {
      balancePanel.className = 'alert alert-warning mb-0';
      balancePanel.innerHTML = '<i class="bi bi-exclamation-triangle me-2"></i><b>Not Balanced.</b> Difference: <b>' + totals.difference.toFixed(2) + '</b>. It will be saved as draft.';
    }

    const postBtn = document.getElementById('btnPostNow');
    if (postBtn) postBtn.disabled = !totals.isBalanced;
  }

  function renderLines() {
    if (!lines.length) {
      linesTbody.innerHTML = '<tr><td colspan="' + (readOnly ? 7 : 8) + '" class="text-center text-muted py-3">No lines added yet.</td></tr>';
      syncHidden();
      renderBalance();
      return;
    }

    linesTbody.innerHTML = lines.map(function (line, idx) {
      const account = accountsMap.get(String(line.accountId));
      const accountLabel = account
        ? (String(account.code || '') + ' - ' + String(account.name || ''))
        : String(line.accountId);
      const dirBadge = line.direction === 'debit'
        ? '<span class="badge bg-success">DEBIT</span>'
        : '<span class="badge bg-danger">CREDIT</span>';

      return '<tr>' +
        '<td>' + (idx + 1) + '</td>' +
        '<td><div class="fw-bold">' + safeHtml(accountLabel) + '</div><div class="x-small text-muted font-monospace">' + safeHtml(line.accountId) + '</div></td>' +
        '<td>' + dirBadge + '</td>' +
        '<td class="fw-bold">' + Number(line.amount || 0).toFixed(2) + '</td>' +
        '<td>' + safeHtml(line.currency || 'CAD') + '</td>' +
        '<td><span class="small text-muted">' + safeHtml(line.memo || '-') + '</span></td>' +
        '<td><span class="small text-muted">' + safeHtml(line.note || '-') + '</span></td>' +
        (readOnly ? '' : '<td class="text-end"><button type="button" class="btn btn-outline-danger btn-sm" data-del-line="' + idx + '">Remove</button></td>') +
      '</tr>';
    }).join('');

    if (!readOnly) {
      linesTbody.querySelectorAll('button[data-del-line]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          const idx = Number(btn.getAttribute('data-del-line'));
          if (Number.isNaN(idx) || idx < 0 || idx >= lines.length) return;
          lines.splice(idx, 1);
          normalizeLines();
          renderLines();
        });
      });
    }

    syncHidden();
    renderBalance();
  }

  function bindActions() {
    if (!readOnly) {
      document.getElementById('btnAddLine').addEventListener('click', async function () {
        try {
          const accountId = String(lineAccountIdField?.value || '').trim();
          const direction = String(document.getElementById('inp_lineDirection').value || '').trim().toLowerCase();
          const amount = Number(document.getElementById('inp_lineAmount').value);
          const currency = String(document.getElementById('inp_lineCurrency').value || '').trim().toUpperCase() || 'CAD';
          const memo = String(document.getElementById('inp_lineMemo').value || '').trim();
          const note = String(document.getElementById('inp_lineNote').value || '').trim();

          if (!accountId) throw new Error('Please select an account.');
          if (!accountsMap.has(accountId)) throw new Error('Selected account is not valid for posting.');
          if (direction !== 'debit' && direction !== 'credit') throw new Error('Direction must be debit or credit.');
          if (!Number.isFinite(amount) || amount <= 0) throw new Error('Amount must be a positive number.');
          if (!/^[A-Z]{3}$/.test(currency)) throw new Error('Currency must be ISO code (e.g. CAD).');

          lines.push({
            accountId: accountId,
            direction: direction,
            amount: amount,
            currency: currency,
            memo: memo,
            note: note
          });

          document.getElementById('inp_lineAccountId').value = '';
          document.getElementById('inp_lineDirection').value = 'debit';
          document.getElementById('inp_lineAmount').value = '';
          document.getElementById('inp_lineCurrency').value = 'CAD';
          document.getElementById('inp_lineMemo').value = '';
          document.getElementById('inp_lineNote').value = '';
          applyLineAccountSelection(null);

          normalizeLines();
          renderLines();
        } catch (err) {
          await showMsg({
            title: 'Validation',
            icon: 'warning',
            message: err.message || 'Invalid line input.',
            buttons: [{ text: 'OK', class: 'btn-warning' }]
          });
        }
      });

      document.querySelectorAll('.js-save-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          selectedSaveAction = String(btn.getAttribute('data-save-action') || 'auto').toLowerCase();
          syncHidden();
        });
      });

      const pickLineAccountBtn = document.getElementById('btnPickLineAccount');
      const clearLineAccountBtn = document.getElementById('btnClearLineAccount');
      if (pickLineAccountBtn) {
        pickLineAccountBtn.addEventListener('click', async function () {
          if (typeof GenericPicker === 'undefined' || !GenericPicker || !GenericPicker.open) {
            await showMsg({
              title: 'Picker Unavailable',
              icon: 'warning',
              message: 'Account picker is not available on this page.',
              buttons: [{ text: 'OK', class: 'btn-warning' }]
            });
            return;
          }

          GenericPicker.open(GenericPickerPresets.account({
            title: 'Select Posting Account',
            icon: 'bi-wallet2',
            placeholder: 'Search active + postable accounts...',
            apiEndpoint: '/school/accounts?allowPost=true&status=active',
            onSelect: async function (item) {
              if (!item) return;
              const isActive = String(item.status || '').trim().toLowerCase() === 'active';
              if (!item.allowPost || !isActive) {
                await showMsg({
                  title: 'Invalid Account',
                  icon: 'warning',
                  message: 'Only Active + Postable accounts can be used for transaction journal lines.',
                  buttons: [{ text: 'OK', class: 'btn-warning' }]
                });
                return;
              }
              applyLineAccountSelection(item);
            }
          }));
        });
      }
      if (clearLineAccountBtn) {
        clearLineAccountBtn.addEventListener('click', function () {
          applyLineAccountSelection(null);
        });
      }
    }

    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      if (readOnly) return;
      if (actionInProgress) return;

      const submitBtn = e.submitter || form.querySelector('.js-save-btn');
      actionInProgress = true;
      setSubmitLock(true, submitBtn, 'Saving...');

      try {
        const submitActionFromButton = String(e?.submitter?.getAttribute('data-save-action') || '').trim().toLowerCase();
        if (submitActionFromButton === 'auto' || submitActionFromButton === 'draft' || submitActionFromButton === 'post') {
          selectedSaveAction = submitActionFromButton;
        } else {
          const hiddenAction = String(hidSaveAction?.value || '').trim().toLowerCase();
          selectedSaveAction = (hiddenAction === 'auto' || hiddenAction === 'draft' || hiddenAction === 'post')
            ? hiddenAction
            : selectedSaveAction;
        }

        normalizeLines();
        if (!lines.length) throw new Error('Please add at least one journal line.');

        const totals = computeTotals();
        if (selectedSaveAction === 'post' && !totals.isBalanced) {
          throw new Error('Journal is not balanced and cannot be posted.');
        }

        syncHidden();
        const formData = new FormData(form);
        const data = new URLSearchParams(formData);

        const response = await fetch(form.action, {
          method: 'POST',
          headers: { 'Content-Type': 'application/x-www-form-urlencoded', 'X-AJAX-Request': 'true' },
          body: data.toString()
        });

        const contentType = response.headers.get('content-type') || '';
        if (!contentType.includes('application/json')) {
          throw new Error('Server returned non-JSON response (Status ' + response.status + ')');
        }

        const result = await response.json();
        const guarded = typeof window.applyGuardedApiResult === 'function'
          ? await window.applyGuardedApiResult(result, { busyTitle: 'Save In Progress', replayTitle: 'Save Already Processed' })
          : { stop: false };
        if (guarded.stop) {
          actionInProgress = false;
          setSubmitLock(false, submitBtn);
          return;
        }
        await showMsg({
          title: result.status === 'success' ? 'Success' : 'Error',
          icon: result.status === 'success' ? 'success' : 'error',
          message: result.message || 'Operation completed.',
          buttons: [{ text: 'OK', class: result.status === 'success' ? 'btn-success' : 'btn-danger' }]
        });

        if (result.status === 'success') {
          window.location.href = '/school/transactions';
        } else {
          actionInProgress = false;
          setSubmitLock(false, submitBtn);
        }
      } catch (error) {
        actionInProgress = false;
        setSubmitLock(false, submitBtn);
        await showMsg({
          title: 'System Error',
          icon: 'error',
          message: error.message || 'An unexpected network error occurred.',
          buttons: [{ text: 'Close', class: 'btn-secondary' }]
        });
      }
    });
  }

  document.addEventListener('DOMContentLoaded', function () {
    normalizeLines();
    renderLines();
    bindActions();
    syncHidden();
    applyLineAccountSelection(null);
  });
})();
</script>
