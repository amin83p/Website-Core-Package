<div class="modal fade" id="schoolPersonProfileEditModal" tabindex="-1" aria-labelledby="schoolPersonProfileEditModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title fw-bold" id="schoolPersonProfileEditModalLabel">
          <i class="bi bi-person-vcard me-2"></i>Edit Person Profile
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <div id="schoolPersonProfileEditAlert" class="alert alert-danger d-none" role="alert"></div>
        <div id="schoolPersonProfileEditLoading" class="text-center py-5 text-muted d-none">
          <div class="spinner-border text-primary mb-3" role="status"></div>
          <div>Loading person profile...</div>
        </div>

        <form id="schoolPersonProfileEditForm" class="d-none">
          <input type="hidden" id="schoolPersonProfileEmailsHidden" name="emails" value="[]">
          <input type="hidden" id="schoolPersonProfilePhonesHidden" name="phones" value="[]">
          <input type="hidden" id="schoolPersonProfileAddressesHidden" name="addresses" value="[]">
          <input type="hidden" id="schoolPersonProfileType" name="personProfileType" value="individual">

          <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
              <h6 class="fw-bold text-uppercase text-muted mb-3"><i class="bi bi-person-bounding-box me-2"></i>Profile & Identity</h6>

              <div class="row g-3 mb-3 school-person-organization-fields" style="display: none;">
                <div class="col-md-12">
                  <label class="form-label fw-bold" for="schoolPersonProfileOrganizationLegalName">Organization Legal Name *</label>
                  <input type="text" class="form-control size-md" id="schoolPersonProfileOrganizationLegalName" name="organizationLegalName">
                </div>
              </div>

              <div class="school-person-individual-fields">
                <div class="row g-3 mb-3">
                  <div class="col-md-3">
                    <label class="form-label fw-bold" for="schoolPersonProfileFirstName">First Name *</label>
                    <input type="text" class="form-control size-md" id="schoolPersonProfileFirstName" name="firstName" required>
                  </div>
                  <div class="col-md-3">
                    <label class="form-label fw-bold" for="schoolPersonProfileMiddleName">Middle Name</label>
                    <input type="text" class="form-control size-md" id="schoolPersonProfileMiddleName" name="middleName">
                  </div>
                  <div class="col-md-3">
                    <label class="form-label fw-bold" for="schoolPersonProfileLastName">Last Name *</label>
                    <input type="text" class="form-control size-md" id="schoolPersonProfileLastName" name="lastName" required>
                  </div>
                  <div class="col-md-3">
                    <label class="form-label fw-bold" for="schoolPersonProfilePreferredName">Preferred Name</label>
                    <input type="text" class="form-control size-md" id="schoolPersonProfilePreferredName" name="preferredName">
                  </div>
                </div>
                <div class="row g-3 mb-3">
                  <div class="col-md-6">
                    <label class="form-label fw-bold" for="schoolPersonProfileGender">Gender *</label>
                    <select class="form-select size-md" id="schoolPersonProfileGender" name="gender" required>
                      <option value="">-- Select Gender --</option>
                      <option value="male">Male</option>
                      <option value="female">Female</option>
                      <option value="nonbinary">Non-binary</option>
                      <option value="other">Other</option>
                    </select>
                  </div>
                  <div class="col-md-6">
                    <label class="form-label fw-bold" for="schoolPersonProfileDateOfBirth">Date of Birth *</label>
                    <input type="date" class="form-control size-md" id="schoolPersonProfileDateOfBirth" name="dateOfBirth" required>
                  </div>
                </div>
              </div>

              <div class="row g-3">
                <div class="col-md-4">
                  <div class="form-check form-switch mt-1">
                    <input class="form-check-input" type="checkbox" id="schoolPersonProfileActive" name="active" checked>
                    <label class="form-check-label fw-bold" for="schoolPersonProfileActive">Active Person Profile</label>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-lg-6">
              <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-light fw-bold text-uppercase small text-muted">
                  <i class="bi bi-envelope-paper me-2"></i>Communication
                </div>
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="form-label mb-0 fw-bold">Email Addresses *</label>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="schoolPersonProfileBtnAddEmail"><i class="bi bi-plus-lg"></i> Add</button>
                  </div>
                  <div id="schoolPersonProfileEmailsList" class="mb-4"></div>
                  <hr class="text-muted opacity-25">
                  <div class="d-flex justify-content-between align-items-center mb-2">
                    <label class="form-label mb-0 fw-bold">Phone Numbers</label>
                    <button type="button" class="btn btn-sm btn-outline-primary" id="schoolPersonProfileBtnAddPhone"><i class="bi bi-plus-lg"></i> Add</button>
                  </div>
                  <div id="schoolPersonProfilePhonesList"></div>
                </div>
              </div>
            </div>
            <div class="col-lg-6">
              <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-light fw-bold text-uppercase small text-muted">
                  <i class="bi bi-geo-alt me-2"></i>Addresses
                </div>
                <div class="card-body bg-light-subtle">
                  <div class="mb-3 position-relative">
                    <label class="form-label small fw-bold text-primary" for="schoolPersonProfileAddressSearch">
                      <i class="bi bi-search me-1"></i>Find Address (Canada)
                    </label>
                    <div class="input-group">
                      <input type="text" id="schoolPersonProfileAddressSearch" class="form-control size-md" placeholder="Type street name..." autocomplete="off">
                      <button class="btn btn-outline-secondary" type="button" id="schoolPersonProfileBtnAddAddressManual">Manual</button>
                    </div>
                    <div id="schoolPersonProfileAddressSuggestions" class="list-group position-absolute w-100 shadow-lg" style="z-index: 1055; top: 100%; display: none;"></div>
                  </div>
                  <div id="schoolPersonProfileAddressesList"></div>
                </div>
              </div>
            </div>
          </div>

          <div class="card shadow-sm border-0 mb-3">
            <div class="card-body">
              <label class="form-label fw-bold" for="schoolPersonProfileNotes">Person Notes</label>
              <textarea class="form-control" id="schoolPersonProfileNotes" name="notes" rows="3" placeholder="Optional notes about this person"></textarea>
            </div>
          </div>

          <div class="card border shadow-sm bg-light-subtle mb-0">
            <div class="card-header bg-light fw-bold">
              <i class="bi bi-diagram-3 me-2"></i>Current Person Role Composition
            </div>
            <div class="card-body" id="schoolPersonProfileRoleSummary"></div>
          </div>
        </form>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary" id="schoolPersonProfileSaveBtn">
          <i class="bi bi-save me-1"></i>Save Person Profile
        </button>
      </div>
    </div>
  </div>
</div>

<script src="/scripts/schoolRoleDisplayUtils.js"></script>
<script src="/scripts/schoolPersonProfileModal.js"></script>
