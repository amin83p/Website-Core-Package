<div class="d-flex align-items-center justify-content-between mb-4">
  <h1 class="page-heading size-md m-0">            
  <%= (isEditMode ? 'Edit ' : 'Create ') +name  %>
  </h1>
  <% if (isEditMode) { %>
      <span class="badge bg-primary border">Editing: <%= id %></span>
  <% } else { %>
      <span class="badge bg-success border"><%=name%> Reg.</span>
  <% } %>
</div>
