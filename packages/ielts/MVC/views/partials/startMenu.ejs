<div class="modal fade start-menu-modal" id="startMenuModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog start-menu-dialog">
    <div class="modal-content start-menu-modal-content border-0">
      <div class="modal-body p-0">
        <div class="start-menu-shell">
          <section id="startMenuBranchPanel" class="start-menu-branch-panel d-none">
            <div class="start-menu-branch-header">
              <div class="start-menu-branch-title-wrap">
                <h6 id="startMenuBranchTitle" class="start-menu-branch-title mb-0">Section</h6>
                <small id="startMenuBranchPath" class="start-menu-branch-path">Browse subsections</small>
              </div>
              <a href="#" id="startMenuBranchOpenRoot" class="btn btn-info btn-sm disabled" aria-disabled="true" tabindex="-1" data-no-wait="true">
                <i class="bi bi-box-arrow-up-right me-1"></i>Open
              </a>
            </div>

            <div id="startMenuBranchList" class="start-menu-branch-list" role="tree" aria-label="Section menu tree"></div>
            <div id="startMenuBranchEmpty" class="start-menu-branch-empty d-none">No items found.</div>
          </section>

          <section id="startMenuSubBranchPanel" class="start-menu-sub-branch-panel d-none">
            <div id="startMenuSubBranchList" class="start-menu-sub-branch-list" role="tree" aria-label="Subsection menu tree"></div>
            <div id="startMenuSubBranchEmpty" class="start-menu-sub-branch-empty d-none">No submenu items found.</div>
          </section>

          <section class="start-menu-dock-wrap">
            <div id="startMenuDockLoading" class="start-menu-dock-loading">
              <div class="spinner-border spinner-border-sm text-info me-2" role="status"></div>
              Loading modules...
            </div>
            <div id="startMenuDockEmpty" class="start-menu-dock-empty d-none">No modules available.</div>
            <div id="startMenuDock" class="start-menu-dock d-none" role="list" aria-label="Main dashboard sections"></div>
          </section>
        </div>
      </div>
    </div>
  </div>
</div>
