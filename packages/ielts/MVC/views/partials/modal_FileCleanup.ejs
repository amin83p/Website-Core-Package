<div class="modal fade" id="fileSettingsModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered" style="max-width: 500px;">
    <div class="modal-content border-0 shadow-lg" style="border-radius: 16px; overflow: hidden;">
      
      <div class="modal-header border-bottom-0 pb-0 bg-white">
        <h5 class="modal-title fw-bold text-primary">
          <i class="bi bi-hdd-rack-fill me-2"></i>Storage Settings
        </h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>

      <div class="modal-body pt-2">
        
        <div class="alert alert-light border shadow-sm d-flex align-items-center p-3 mb-4 rounded-3">
          <div class="rounded-circle bg-danger-subtle text-danger d-flex align-items-center justify-content-center me-3" 
               style="width: 48px; height: 48px; min-width: 48px;">
            <i class="bi bi-trash3 fs-4"></i>
          </div>
          <div>
            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem; letter-spacing: 0.5px;">
                Maintenance Scope
            </div>
            <div class="fw-bold fs-5 text-dark">Bulk File Cleanup</div>
          </div>
        </div>

        <form id="cleanupForm">
            <div class="mb-2">
                <label class="form-label fw-bold text-secondary small">Old File Threshold</label>
                <div class="input-group input-group-lg">
                    <span class="input-group-text bg-light border-end-0 text-muted">
                        <i class="bi bi-calendar-minus"></i>
                    </span>
                    <input type="number" class="form-control border-start-0 ps-0" name="days" value="30" min="1" placeholder="30">
                    <span class="input-group-text bg-light text-muted">days</span>
                </div>
                <div class="form-text mt-2 text-muted fst-italic">
                    <i class="bi bi-info-circle me-1"></i> Files older than this will be permanently removed.
                </div>
            </div>
        </form>

      </div>
      
      <div class="modal-footer bg-light border-top-0 py-3">
        <button type="button" class="btn btn-secondary btn-sm rounded-pill px-4" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-danger btn-sm rounded-pill px-4 shadow-sm" id="runCleanupBtn">
            <i class="bi bi-trash me-1"></i> Run Cleanup
        </button>
      </div>

    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
    // Handle Cleanup Settings Logic
    const runCleanupBtn = document.getElementById('runCleanupBtn');
    const cleanupForm = document.getElementById('cleanupForm');
    const fileSettingsModalElement = document.getElementById('fileSettingsModal');
    
    if(runCleanupBtn && cleanupForm) {
        runCleanupBtn.addEventListener('click', () => {
            const formData = new FormData(cleanupForm);
            const days = formData.get('days');

            // Using existing showMessageModal if available
            if (typeof showMessageModal === 'function') {
                showMessageModal({
                    title: 'Confirm Delete',
                    icon: 'warning',
                    message: `Are you sure you want to permanently delete files older than <b>${days} days</b>?<br><br><span class="text-danger fw-bold">This operation is irreversible!</span>`,
                    buttons: [
                        { text: 'Cancel', class: 'btn-secondary btn-md' },
                        { text: 'Delete', class: 'btn-danger btn-md' }
                    ]
                }).then(async (result) => {
                    if (result !== 'Delete') return;
                    if (typeof window.requestProtectedAction === 'function') {
                        await window.requestProtectedAction();
                    } else {
                        showMessageModal({
                            title: 'Verification Code',
                            icon: 'error',
                            message: 'Admin Verification System not loaded. Proceeding...',
                            buttons: [ { text: 'Ok', class: 'btn-danger btn-md' } ]
                        });
                        return;
                    }             
                    executeCleanup(days);
                });
            } else {
                // Fallback if modal helper isn't loaded
                if(confirm(`Irreversibly delete files older than ${days} days?`)) {
                    executeCleanup(days);
                }
            }
        });
    }

    function executeCleanup(days) {
        fetch('/files/cleanup', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/json' 
            },
            body: JSON.stringify({ days: days })
        })
        .then(res => res.json())
        .then(data => {
            // Hide the settings modal
            const modalInstance = bootstrap.Modal.getInstance(fileSettingsModalElement) || new bootstrap.Modal(fileSettingsModalElement); 
            modalInstance.hide();
            
            if(data.status === 'success') {
                showMessageModal({
                    title: 'Success',
                    icon: 'success', // changed from warning to success for positive feedback
                    message: data.message,
                    buttons: [
                        { text: 'Close', class: 'btn-success btn-md' }
                    ]
                }).then(() => {
                    window.location.reload(); 
                });
            } else {
                showMessageModal({
                    title: 'Error',
                    icon: 'error',
                    message: data.message || 'Error deleting file(s).',
                    buttons: [ { text: 'Close', class: 'btn-danger btn-md' }]
                });
            }
        })
        .catch(err => {
            console.error(err);
            alert('An unexpected error occurred.');
        });
    }
});
</script>