<%
  const isEdit = !!(prompt && prompt.id);
  const config = (prompt && prompt.config) || {};
  const varText = Array.isArray(prompt?.variables) ? prompt.variables.join(', ') : '';
  const pageSamples = Array.isArray(samples) ? samples : [];
  const pageAssessments = Array.isArray(assessments) ? assessments : [];
  const selectedOrgId = isEdit ? String(prompt.orgId || prompt.org || prompt.organizationId || '').trim() : '';
  const orgChoices = Array.isArray(user?.allowedOrgs) ? user.allowedOrgs : [];
  const matchedOrg = isEdit ? orgChoices.find((org) => String(org?.orgId || '').trim() === selectedOrgId) : null;
  const selectedOrgName = String(
    matchedOrg?.name ||
    matchedOrg?.orgName ||
    ''
  ).trim();
%>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-heading size-md m-0">
      <%= isEdit ? 'Edit Prompt Template' : 'Create New Prompt Template' %>
    </h1>
    <div class="d-flex align-items-center gap-2">
      <% if (isEdit) { %>
        <div class="d-flex flex-column align-items-end gap-1">
          <span class="badge bg-primary border">ID: <%= prompt.id %></span>
          <span class="badge bg-light text-dark border">
            Organization: <%= selectedOrgName || 'N/A' %><%= selectedOrgId ? ` (#${selectedOrgId})` : '' %>
          </span>
        </div>
      <% } else { %>
        <span class="badge bg-success border">New Prompt</span>
      <% } %>
    </div>
  </div>

  <div class="form-container" style="width: 100%; max-width: 100%;">
    <form
      id="promptForm"
      action="<%= isEdit ? '/ielts/prompts/edit/' + prompt.id : '/ielts/prompts/new' %>"
      method="POST"
    >
      <input type="hidden" name="actionStateId" value="<%= typeof actionStateId !== 'undefined' ? actionStateId : '' %>">

      <div class="row">
        <div class="col-md-5 mb-4">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light fw-bold text-primary">
              <i class="bi bi-sliders me-2"></i>Configuration
            </div>
            <div class="card-body">
              <div class="mb-3">
                <label class="form-label fw-bold small text-muted text-uppercase">Prompt ID <span class="text-danger">*</span></label>
                <input
                  type="text"
                  name="id"
                  class="form-control"
                  value="<%= prompt ? prompt.id : '' %>"
                  placeholder="e.g. step4_grading_v1"
                  <%= isEdit ? 'readonly' : '' %>
                  required
                >
                <div class="form-text small">Unique key used by pipeline and prompt lookup.</div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-bold small text-muted text-uppercase">Display Name <span class="text-danger">*</span></label>
                <input
                  type="text"
                  name="name"
                  class="form-control"
                  value="<%= prompt ? (prompt.name || '') : '' %>"
                  placeholder="Step 4 Grading Prompt"
                  required
                >
              </div>

              <div class="row g-2 mb-3">
                <div class="col-12">
                  <label class="form-label fw-bold small text-muted text-uppercase">Category</label>
                  <% const category = prompt ? (prompt.category || 'NO_CATEGORY') : 'NO_CATEGORY'; %>
                  <select name="category" class="form-select">
                    <% [
                      { value: 'NO_CATEGORY', label: 'No Category' },
                      { value: 'step3extract', label: 'step3extract' },
                      { value: 'step4grade', label: 'step4grade' },
                      { value: 'step5feedback', label: 'step5feedback' }
                    ].forEach(c => { %>
                      <option value="<%= c.value %>" <%= category === c.value ? 'selected' : '' %>><%= c.label %></option>
                    <% }) %>
                  </select>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-bold small text-muted text-uppercase">Tested Model (Recommended)</label>
                <input type="text" name="modelHint" class="form-control" value="<%= config.modelHint || '' %>" placeholder="gemini-2.0-flash">
              </div>

              <div class="row g-2 mb-3">
                <div class="col-4">
                  <label class="form-label small text-muted">Temp</label>
                  <input type="number" name="temperature" class="form-control" value="<%= Number.isFinite(Number(config.temperature)) ? Number(config.temperature) : 0 %>" min="0" max="2" step="0.1">
                  <div class="form-text">Creativity/randomness. Lower = more deterministic.</div>
                </div>
                <div class="col-4">
                  <label class="form-label small text-muted">TopP</label>
                  <input type="number" name="topP" class="form-control" value="<%= Number.isFinite(Number(config.topP)) ? Number(config.topP) : 1 %>" min="0" max="1" step="0.1">
                  <div class="form-text">Nucleus sampling range. Lower = tighter token choice.</div>
                </div>
                <div class="col-4">
                  <label class="form-label small text-muted">TopK</label>
                  <input type="number" name="topK" class="form-control" value="<%= Number.isFinite(Number(config.topK)) ? Number(config.topK) : 1 %>" min="0" max="100" step="1">
                  <div class="form-text">Candidate token pool size per step. Lower = stricter output.</div>
                </div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-bold small text-muted text-uppercase">Variables</label>
                <textarea name="variables" class="form-control" rows="4" placeholder="essay_text&#10;question&#10;criteria"><%= varText %></textarea>
                <div class="form-text small">Comma-separated placeholders used by this template.</div>
              </div>

              <div class="mb-3">
                <label class="form-label fw-bold small text-muted text-uppercase">Description</label>
                <textarea name="description" class="form-control" rows="3" placeholder="What this prompt is used for..."><%= prompt ? (prompt.description || '') : '' %></textarea>
              </div>

              <div class="pt-3 border-top mt-3 d-flex align-items-center gap-4">
                <div class="form-check form-switch">
                  <input class="form-check-input" type="checkbox" id="isActiveSwitch" name="isActive" <%= (!prompt || prompt.isActive !== false) ? 'checked' : '' %>>
                  <label class="form-check-label fw-bold small" for="isActiveSwitch">Is Active?</label>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-md-7 mb-4">
          <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-light fw-bold text-primary">
              <i class="bi bi-file-text me-2"></i>Template
            </div>
            <div class="card-body">
              <ul class="nav nav-tabs mb-3" id="promptEditorTabs" role="tablist">
                <li class="nav-item" role="presentation">
                  <button class="nav-link active" id="content-tab" data-bs-toggle="tab" data-bs-target="#content-pane" type="button" role="tab">Content</button>
                </li>
                <li class="nav-item" role="presentation">
                  <button class="nav-link" id="preview-tab" data-bs-toggle="tab" data-bs-target="#preview-pane" type="button" role="tab">Preview</button>
                </li>
              </ul>

              <div class="tab-content">
                <div class="tab-pane fade show active" id="content-pane" role="tabpanel">
                  <div class="mb-3">
                    <label class="form-label fw-bold">Prompt Body <span class="text-danger">*</span></label>
                    <textarea name="content" id="promptContent" class="form-control font-monospace bg-light" rows="15" style="font-size: 0.9rem;" placeholder="Write your parameterized prompt here..." required><%= prompt ? (prompt.content || '') : '' %></textarea>
                  </div>

                  <div class="alert alert-info small mb-0">
                    <div class="fw-bold mb-2"><i class="bi bi-code-square me-1"></i>Useful placeholders</div>
                    <div class="d-flex flex-wrap gap-2">
                      <% [
                        '{{essay_text}}','{{question}}','{{criteria}}','{{feedback}}','{{score}}','{{type}}','{{order}}',
                        '{{task_prompt}}','{{stance}}','{{analysis_context}}','{{sentence_block}}','{{criterion}}',
                        '{{questions_text}}','{{few_shot_examples}}','{{profile_prompt_block}}',
                        '{{current_band}}','{{target_band}}','{{allowed_refs}}','{{weakness_lines}}','{{strength_lines}}',
                        '{{task_definition_json}}','{{paragraph_roles_map}}','{{essay_sentences_block}}',
                        '{{subquestion_keys_template}}','{{topic_sentence_template}}','{{max_sentence_index}}',
                        '{{assessment_title}}'
                      ].forEach(v => { %>
                        <code class="token-pill" data-token="<%= v %>"><%= v %></code>
                      <% }) %>
                    </div>
                    <div class="form-text mt-2">Click a placeholder to choose <b>Copy</b> or <b>Info</b>.</div>
                  </div>
                </div>

                <div class="tab-pane fade" id="preview-pane" role="tabpanel">
                  <div class="d-flex justify-content-end mb-2">
                    <button type="button" class="btn btn-sm btn-outline-primary" id="btnRefreshPreview">Refresh</button>
                  </div>
                  <div class="row g-2 mb-3">
                    <div class="col-md-6">
                      <label class="form-label small text-muted">Sample</label>
                      <select class="form-select form-select-sm" id="previewSampleSelect">
                        <% if (pageSamples.length) { %>
                          <% pageSamples.forEach(s => { %>
                            <option value="<%= s.id %>"><%= s.refName || s.id %></option>
                          <% }) %>
                        <% } else { %>
                          <option value="">No sample data</option>
                        <% } %>
                      </select>
                    </div>
                    <div class="col-md-6">
                      <label class="form-label small text-muted">Assessment</label>
                      <select class="form-select form-select-sm" id="previewAssessmentSelect">
                        <% if (pageAssessments.length) { %>
                          <% pageAssessments.forEach(a => { %>
                            <option value="<%= a.id %>"><%= a.title || a.question_key || a.id %></option>
                          <% }) %>
                        <% } else { %>
                          <option value="">No assessment data</option>
                        <% } %>
                      </select>
                    </div>
                  </div>
                  <pre id="promptPreviewOutput" class="bg-light border rounded p-3 small mb-0" style="min-height: 220px; white-space: pre-wrap;"></pre>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md">
          <i class="bi bi-save me-1"></i> Save Prompt
        </button>
        <a href="/ielts/prompts" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction"> Cancel </a>
      </div>
    </form>
  </div>
</div>

<script type="application/json" id="previewSamplesData"><%- JSON.stringify(pageSamples) %></script>
<script type="application/json" id="previewAssessmentsData"><%- JSON.stringify(pageAssessments) %></script>

<script>
  const previewSamples = JSON.parse(document.getElementById('previewSamplesData').textContent || '[]');
  const previewAssessments = JSON.parse(document.getElementById('previewAssessmentsData').textContent || '[]');
  const PLACEHOLDER_INFO = {
    '{{essay_text}}': 'Full essay text. Use when the model needs direct textual evidence.',
    '{{question}}': 'Main prompt/question text. Useful for relevance checks.',
    '{{criteria}}': 'Rubric criteria for scoring decisions.',
    '{{feedback}}': 'Existing human feedback. Useful for tutor-style or delta prompts.',
    '{{score}}': 'Known score/band value for context.',
    '{{type}}': 'Essay/sample type metadata.',
    '{{order}}': 'Question order or key ordering in batch flows.',
    '{{task_prompt}}': 'Resolved IELTS task prompt for step-based pipelines.',
    '{{stance}}': 'Detected stance signal (agree/disagree/partial/unclear).',
    '{{analysis_context}}': 'Computed metrics summary (word count, structure, cohesion).',
    '{{sentence_block}}': 'Sentence-indexed essay block (P#/S#) for evidence grounding.',
    '{{criterion}}': 'Current criterion context (TR/CC/LR/GRA).',
    '{{questions_text}}': 'Batch question payload for step 4 scoring.',
    '{{few_shot_examples}}': 'Criterion-specific examples to stabilize outputs.',
    '{{profile_prompt_block}}': 'Stability profile guidance block (standard/strict).',
    '{{current_band}}': 'Current estimated overall band.',
    '{{target_band}}': 'Target revision band.',
    '{{allowed_refs}}': 'Permitted evidence references for feedback.',
    '{{weakness_lines}}': 'Prioritized weaknesses extracted from scoring.',
    '{{strength_lines}}': 'Strength highlights for balanced feedback.',
    '{{task_definition_json}}': 'Structured Task 2 definition (prompt + subquestions).',
    '{{paragraph_roles_map}}': 'Paragraph role mapping (intro/body/conclusion).',
    '{{essay_sentences_block}}': 'Sentence-indexed essay listing used by extraction.',
    '{{subquestion_keys_template}}': 'JSON template rows for answersBySubquestion.',
    '{{topic_sentence_template}}': 'JSON template rows for topicSentenceByParagraph.',
    '{{max_sentence_index}}': 'Upper bound for valid sentence indices.',
    '{{assessment_title}}': 'Assessment title/name context variable.'
  };

  document.querySelectorAll('.token-pill').forEach((el) => {
    el.addEventListener('click', async () => {
      const token = el.getAttribute('data-token');
      if (!token) return;

      if (typeof showMessageModal === 'function') {
        const action = await showMessageModal({
          title: 'Placeholder Action',
          icon: 'info',
          message: `<b>${token}</b><br><span class="text-muted">Choose what you want to do.</span>`,
          buttons: [
            { text: 'Close', class: 'btn-secondary' },
            { text: 'Copy', class: 'btn-primary' },
            { text: 'Info', class: 'btn-info text-white' }
          ]
        });

        if (action === 'Copy') {
          await navigator.clipboard.writeText(token);
          return;
        }

        if (action === 'Info') {
          await showMessageModal({
            title: token,
            icon: 'info',
            message: `${PLACEHOLDER_INFO[token] || 'No description available.'}<br><br><b>Where/Why:</b> Use this placeholder in prompt templates so values are injected dynamically at runtime or preview time.`,
            buttons: [{ text: 'Close', class: 'btn-secondary' }]
          });
        }
      } else {
        const doCopy = confirm(`${token}\n\nPress OK to copy.\nPress Cancel for info.`);
        if (doCopy) {
          await navigator.clipboard.writeText(token);
        } else {
          alert(`${token}\n\n${PLACEHOLDER_INFO[token] || 'No description available.'}\n\nWhere/Why: use it for runtime placeholder substitution.`);
        }
      }
    });
  });

  function getPreviewContext() {
    const sampleId = document.getElementById('previewSampleSelect')?.value;
    const assessmentId = document.getElementById('previewAssessmentSelect')?.value;
    const sample = previewSamples.find((s) => String(s.id) === String(sampleId)) || {};
    const assessment = previewAssessments.find((a) => String(a.id) === String(assessmentId)) || {};

    const cleanEssay = String(sample.text || '').replace(/<[^>]*>?/gm, '').trim();
    const sampleQuestion = sample.question || assessment.atomic_question || assessment.question || 'Sample question';
    const sampleCriteria = assessment.rubric_anchor || assessment.criteria || 'Sample rubric criteria';
    const order = assessment.question_key || assessment.order || '1';

    return {
      essay_text: cleanEssay || 'Sample essay text...',
      question: sampleQuestion,
      assessment_title: assessment.title || assessment.question_key || 'Assessment Title',
      criteria: sampleCriteria,
      feedback: sample.feedback || 'Sample examiner feedback.',
      score: sample.bandScore || '6.5',
      type: sample.type || 'TASK2',
      order: String(order),
      task_prompt: sampleQuestion,
      stance: 'partial',
      analysis_context: '- Word Count: 280\n- Paragraphs: 4\n- Cohesion density: 6.2',
      sentence_block: 'P0 S0: Introduction sentence.\nP1 S3: Main argument evidence.',
      criterion: assessment.criterion || 'TR',
      questions_text: `ID: ${assessment.question_key || 'TR6-1'}\nQuestion: ${sampleQuestion}\nBand Criteria: "${sampleCriteria}"`,
      few_shot_examples: 'Q: Is argument clear?\nA: Yes (clear thesis sentence).',
      profile_prompt_block: 'STABILITY PROFILE: STANDARD\n- Use explicit evidence and reasonable examiner interpretation.',
      current_band: '6.0',
      target_band: '6.5',
      allowed_refs: 'S1, S3, S5',
      weakness_lines: '1) [TR] Response underdeveloped in body paragraph 2.',
      strength_lines: '- [CC] Clear paragraph progression.',
      task_definition_json: JSON.stringify({
        task: 'IELTS_Writing_Task_2',
        prompt_verbatim: sampleQuestion,
        subquestion_keys: ['q1_task_response', 'q2_position']
      }, null, 2),
      paragraph_roles_map: 'P0=intro, P1=body, P2=body, P3=conclusion',
      essay_sentences_block: 'P0 S0: Intro...\nP1 S3: Evidence...\nP3 S9: Conclusion...',
      subquestion_keys_template: '    "q1_task_response": [],\n    "q2_position": []',
      topic_sentence_template: '    { "paragraphIndex": 0, "topicSentenceIndex": 0 },\n    { "paragraphIndex": 1, "topicSentenceIndex": 3 }',
      max_sentence_index: '12'
    };
  }

  function renderPromptPreview() {
    const input = document.getElementById('promptContent');
    const output = document.getElementById('promptPreviewOutput');
    if (!input || !output) return;

    let text = String(input.value || '');
    const ctx = getPreviewContext();
    Object.keys(ctx).forEach((key) => {
      const re = new RegExp(`\\{\\{${key}\\}\\}`, 'g');
      text = text.replace(re, String(ctx[key] ?? ''));
    });
    output.textContent = text || '(Preview will appear here.)';
  }

  document.getElementById('btnRefreshPreview')?.addEventListener('click', renderPromptPreview);
  document.getElementById('previewSampleSelect')?.addEventListener('change', renderPromptPreview);
  document.getElementById('previewAssessmentSelect')?.addEventListener('change', renderPromptPreview);
  document.getElementById('promptContent')?.addEventListener('input', renderPromptPreview);

  async function showSaveResultModal({ title, icon, message }) {
    if (typeof showMessageModal === 'function') {
      await showMessageModal({
        title,
        icon,
        message,
        buttons: [{ text: 'OK', class: 'btn-primary' }]
      });
      return;
    }
    alert(message);
  }

  const promptForm = document.getElementById('promptForm');
  const promptSaveBtn = promptForm ? promptForm.querySelector('button[type="submit"]') : null;
  const promptCancelBtn = document.getElementById('btnCancelAction');
  let isSubmitting = false;

  function cacheButtonHtml(button) {
    if (!button) return;
    if (!button.dataset.defaultHtml) button.dataset.defaultHtml = button.innerHTML;
  }

  function setButtonBusy(button, label) {
    if (!button) return;
    cacheButtonHtml(button);
    button.disabled = true;
    button.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>' + (label || 'Working...');
    if (button.tagName === 'A') {
      button.classList.add('disabled');
      button.setAttribute('aria-disabled', 'true');
      button.style.pointerEvents = 'none';
    }
  }

  function restoreButton(button) {
    if (!button) return;
    if (button.dataset.defaultHtml) button.innerHTML = button.dataset.defaultHtml;
    button.disabled = false;
    if (button.tagName === 'A') {
      button.classList.remove('disabled');
      button.removeAttribute('aria-disabled');
      button.style.pointerEvents = '';
    }
  }

  cacheButtonHtml(promptSaveBtn);
  cacheButtonHtml(promptCancelBtn);

  if (promptCancelBtn) {
    promptCancelBtn.addEventListener('click', (event) => {
      if (isSubmitting) {
        event.preventDefault();
        return;
      }
      setButtonBusy(promptCancelBtn, 'Cancelling...');
      if (promptSaveBtn) promptSaveBtn.disabled = true;
    });
  }

  promptForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (isSubmitting) return;
    isSubmitting = true;
    const form = e.currentTarget;

    try {
      setButtonBusy(promptSaveBtn, 'Saving...');
      if (promptCancelBtn) promptCancelBtn.disabled = true;

      const formData = new FormData(form);
      const payload = new URLSearchParams();
      for (const [key, value] of formData.entries()) {
        payload.append(key, value);
      }

      const response = await fetch(form.action, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8',
          'x-ajax-request': 'true'
        },
        body: payload.toString()
      });

      let result = null;
      try {
        result = await response.json();
      } catch (_) {
        result = { status: 'error', message: 'Unexpected response while saving prompt.' };
      }

      if (!response.ok || result.status !== 'success') {
        throw new Error(result.message || 'Failed to save prompt.');
      }

      await showSaveResultModal({
        title: 'Saved',
        icon: 'success',
        message: result.message || 'Prompt saved successfully.'
      });
      window.location.href = '/ielts/prompts';
    } catch (error) {
      await showSaveResultModal({
        title: 'Save Failed',
        icon: 'error',
        message: error.message || 'Unable to save prompt.'
      });
      isSubmitting = false;
      restoreButton(promptSaveBtn);
      restoreButton(promptCancelBtn);
    }
  });

  renderPromptPreview();
</script>

<style>
  .token-pill {
    cursor: pointer;
    background: #f8f9fa;
    border: 1px solid #dee2e6;
    padding: 4px 8px;
    border-radius: 4px;
    color: #d63384;
  }
  .token-pill:hover {
    background: #fff;
    border-color: #0d6efd;
    color: #0d6efd;
  }
</style>
