<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
    <h1 class="page-heading size-md m-0"><%= title %></h1>
    <a href="/ielts/ai-token-usage" class="btn btn-filled btn-secondary btn-md">
      <i class="bi bi-arrow-left me-1"></i> Back to Usage List
    </a>
  </div>

  <div class="card-container">
    <div class="card mb-3 shadow-sm border-0">
      <div class="card-body">
        <form id="usageAnalyticsFilters" method="GET" action="/ielts/ai-token-usage/analytics">
          <div class="row g-2 align-items-end">
            <div class="col-md-2">
              <label class="form-label small fw-bold text-muted text-uppercase">Start Date</label>
              <input type="date" class="form-control" name="startDate" id="startDate" value="<%= filters.startDate %>">
            </div>
            <div class="col-md-2">
              <label class="form-label small fw-bold text-muted text-uppercase">End Date</label>
              <input type="date" class="form-control" name="endDate" id="endDate" value="<%= filters.endDate %>">
            </div>
            <% if (analyticsAccess && analyticsAccess.allowTargetSelect) { %>
              <div class="col-md-2">
                <label class="form-label small fw-bold text-muted text-uppercase">View Usage By</label>
                <select class="form-select" name="scope" id="scope">
                  <option value="user" <%= filters.scope === 'user' ? 'selected' : '' %>>Users</option>
                  <option value="org" <%= filters.scope === 'org' ? 'selected' : '' %>>Organizations</option>
                </select>
              </div>
              <div class="col-md-2">
                <label class="form-label small fw-bold text-muted text-uppercase">Filter Type</label>
                <select class="form-select" name="targetType" id="targetType">
                  <option value="all" <%= filters.targetType === 'all' ? 'selected' : '' %>>All</option>
                  <option value="org" <%= filters.targetType === 'org' ? 'selected' : '' %>>Organization</option>
                  <option value="user" <%= filters.targetType === 'user' ? 'selected' : '' %>>User</option>
                </select>
              </div>
              <div class="col-md-2">
                <label class="form-label small fw-bold text-muted text-uppercase">Filter Value</label>
                <select class="form-select" name="targetId" id="targetId">
                  <option value="">All</option>
                </select>
              </div>
            <% } else { %>
              <input type="hidden" name="scope" value="user">
              <input type="hidden" name="targetType" value="user">
              <input type="hidden" name="targetId" value="<%= analyticsAccess?.activeUserId || '' %>">
            <% } %>
            <div class="col-md-2">
              <input type="hidden" name="shortcut" id="shortcut" value="<%= filters.shortcut %>">
              <button type="submit" class="btn btn-filled btn-primary btn-md w-100">
                <i class="bi bi-filter-circle me-1"></i> Apply
              </button>
            </div>
            <div class="col-md-4">
              <div class="small text-muted">
                Showing <b><%= filteredRowsCount %></b> AI call records in the selected range.
                <% if (timeline.singleDay) { %>
                  (Hourly breakdown enabled)
                <% } %>
              </div>
            </div>
          </div>

          <% if (!(analyticsAccess && analyticsAccess.allowTargetSelect)) { %>
            <div class="alert alert-info py-2 mt-2 mb-0">
              <i class="bi bi-person-circle me-1"></i>
              Showing usage for active user only:
              <b><%= analyticsAccess?.activeUserLabel || 'Active User' %></b>
            </div>
          <% } %>

          <div class="d-flex flex-wrap gap-2 mt-3">
            <% (shortcutOptions || []).forEach((option) => { %>
              <button
                type="button"
                class="btn btn-sm <%= filters.shortcut === option.id ? 'btn-primary' : 'btn-outline-primary' %> shortcut-btn"
                data-shortcut="<%= option.id %>">
                <%= option.label %>
              </button>
            <% }) %>
          </div>
        </form>
      </div>
    </div>

    <div class="row g-3 mb-3">
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <div class="small text-muted">Calls</div>
            <div class="h4 m-0"><%= totals.callCount %></div>
          </div>
        </div>
      </div>
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <div class="small text-muted">Total Tokens</div>
            <div class="h4 m-0"><%= totals.totalTokens %></div>
          </div>
        </div>
      </div>
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <div class="small text-muted">Prompt Tokens</div>
            <div class="h4 m-0"><%= totals.promptTokens %></div>
          </div>
        </div>
      </div>
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <div class="small text-muted">Output Tokens</div>
            <div class="h4 m-0"><%= totals.outputTokens %></div>
          </div>
        </div>
      </div>
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <div class="small text-muted">Success</div>
            <div class="h4 m-0 text-success"><%= totals.successCount %></div>
          </div>
        </div>
      </div>
      <div class="col-md-2 col-6">
        <div class="card shadow-sm border-0 h-100">
          <div class="card-body">
            <div class="small text-muted">Failed</div>
            <div class="h4 m-0 text-danger"><%= totals.failedCount %></div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3">
      <div class="col-lg-8">
        <div class="card shadow-sm border-0">
          <div class="card-header fw-bold">
            <i class="bi bi-bar-chart-line-fill me-2"></i>
            Token Usage Over Time
            <% if (timeline.singleDay) { %>
              <span class="badge bg-info-subtle text-info-emphasis border ms-2">Hourly</span>
            <% } else { %>
              <span class="badge bg-secondary-subtle text-secondary-emphasis border ms-2">Daily</span>
            <% } %>
          </div>
          <div class="card-body">
            <div class="chart-shell">
              <canvas id="timelineChart" width="1200" height="380"></canvas>
            </div>
            <div class="small text-muted mt-2">Bars represent total tokens in each time bucket.</div>
          </div>
        </div>
      </div>

      <div class="col-lg-4">
        <div class="card shadow-sm border-0">
          <div class="card-header fw-bold">
            <i class="bi bi-people-fill me-2"></i>
            Usage Breakdown by <%= filters.scope === 'org' ? 'Organization' : 'User' %>
          </div>
          <div class="card-body">
            <div class="chart-shell chart-shell-small">
              <canvas id="breakdownChart" width="700" height="380"></canvas>
            </div>
            <div class="small text-muted mt-2">Top 10 by total tokens.</div>
          </div>
        </div>
      </div>
    </div>

    <div class="row g-3 mt-1">
      <div class="col-lg-7">
        <div class="card shadow-sm border-0">
          <div class="card-header fw-bold">
            <i class="bi bi-table me-2"></i>
            <%= filters.scope === 'org' ? 'Organization' : 'User' %> Usage Table
          </div>
          <div class="card-body p-0">
            <div class="table-scroll-wrapper">
              <table class="table-responsive size-md mb-0">
                <thead>
                  <tr>
                    <th><%= filters.scope === 'org' ? 'Organization' : 'User' %></th>
                    <th>Calls</th>
                    <th>Prompt</th>
                    <th>Output</th>
                    <th>Total</th>
                    <th>Success</th>
                    <th>Failed</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!breakdownRows.length) { %>
                    <tr><td colspan="7" class="text-center text-muted py-3">No data in selected range.</td></tr>
                  <% } %>
                  <% breakdownRows.forEach((row) => { %>
                    <tr>
                      <td><span class="badge bg-light text-dark border"><%= row.key %></span></td>
                      <td><%= row.callCount %></td>
                      <td><%= row.promptTokens %></td>
                      <td><%= row.outputTokens %></td>
                      <td class="fw-semibold"><%= row.totalTokens %></td>
                      <td class="text-success"><%= row.successCount %></td>
                      <td class="text-danger"><%= row.failedCount %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="col-lg-5">
        <div class="card shadow-sm border-0">
          <div class="card-header fw-bold">
            <i class="bi bi-hdd-network me-2"></i>
            Provider Usage
          </div>
          <div class="card-body p-0">
            <div class="table-scroll-wrapper">
              <table class="table-responsive size-md mb-0">
                <thead>
                  <tr>
                    <th>Provider</th>
                    <th>Calls</th>
                    <th>Total</th>
                    <th>Success</th>
                    <th>Failed</th>
                  </tr>
                </thead>
                <tbody>
                  <% if (!providerRows.length) { %>
                    <tr><td colspan="5" class="text-center text-muted py-3">No data in selected range.</td></tr>
                  <% } %>
                  <% providerRows.forEach((row) => { %>
                    <tr>
                      <td><span class="badge bg-info text-dark"><%= row.key %></span></td>
                      <td><%= row.callCount %></td>
                      <td class="fw-semibold"><%= row.totalTokens %></td>
                      <td class="text-success"><%= row.successCount %></td>
                      <td class="text-danger"><%= row.failedCount %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/modal') %>

<script>
  const timelineRows = <%- JSON.stringify(timeline.rows || []) %>;
  const breakdownRows = <%- JSON.stringify((breakdownRows || []).slice(0, 10)) %>;
  const selectableOptions = <%- JSON.stringify(selectableOptions || { userOptions: [], orgOptions: [] }) %>;
  const selectedTargetType = <%- JSON.stringify(filters.targetType || 'all') %>;
  const selectedTargetId = <%- JSON.stringify(filters.targetId || '') %>;

  function drawBarChart(canvas, rows, options = {}) {
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const cssWidth = canvas.clientWidth || canvas.width;
    const cssHeight = canvas.clientHeight || canvas.height;
    canvas.width = Math.floor(cssWidth * dpr);
    canvas.height = Math.floor(cssHeight * dpr);
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    ctx.clearRect(0, 0, cssWidth, cssHeight);
    if (!Array.isArray(rows) || !rows.length) {
      ctx.fillStyle = '#6c757d';
      ctx.font = '14px sans-serif';
      ctx.fillText('No data available for selected range.', 12, 24);
      return;
    }

    const leftPad = 54;
    const topPad = 10;
    const rightPad = 8;
    const bottomPad = 62;
    const chartWidth = Math.max(120, cssWidth - leftPad - rightPad);
    const chartHeight = Math.max(120, cssHeight - topPad - bottomPad);

    const values = rows.map((row) => Number(row?.totalTokens || 0));
    const maxValue = Math.max(1, ...values);

    ctx.strokeStyle = '#dee2e6';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(leftPad, topPad);
    ctx.lineTo(leftPad, topPad + chartHeight);
    ctx.lineTo(cssWidth - rightPad, topPad + chartHeight);
    ctx.stroke();

    ctx.fillStyle = '#6c757d';
    ctx.font = '11px sans-serif';
    const yTicks = 4;
    for (let i = 0; i <= yTicks; i += 1) {
      const v = (maxValue * i) / yTicks;
      const y = topPad + chartHeight - ((chartHeight * i) / yTicks);
      ctx.fillText(String(Math.round(v)), 4, y + 3);
      ctx.strokeStyle = 'rgba(0,0,0,0.06)';
      ctx.beginPath();
      ctx.moveTo(leftPad, y);
      ctx.lineTo(cssWidth - rightPad, y);
      ctx.stroke();
    }

    const barGap = rows.length > 18 ? 2 : 4;
    const barWidth = Math.max(8, Math.floor((chartWidth - (barGap * (rows.length - 1))) / Math.max(1, rows.length)));
    const stepX = barWidth + barGap;
    const colors = options.colors || ['#0d6efd', '#20c997', '#fd7e14', '#dc3545', '#6f42c1', '#198754'];

    rows.forEach((row, idx) => {
      const value = Number(row?.totalTokens || 0);
      const barHeight = Math.max(1, (value / maxValue) * chartHeight);
      const x = leftPad + (idx * stepX);
      const y = topPad + chartHeight - barHeight;

      ctx.fillStyle = colors[idx % colors.length];
      ctx.fillRect(x, y, barWidth, barHeight);

      if (idx % Math.ceil(rows.length / 8 || 1) === 0 || rows.length <= 10) {
        const label = String(row?.label || row?.key || '');
        ctx.save();
        ctx.translate(x + (barWidth / 2), topPad + chartHeight + 14);
        ctx.rotate(-Math.PI / 3);
        ctx.fillStyle = '#495057';
        ctx.font = '10px sans-serif';
        ctx.textAlign = 'left';
        ctx.fillText(label, 0, 0);
        ctx.restore();
      }
    });
  }

  function renderCharts() {
    drawBarChart(document.getElementById('timelineChart'), timelineRows, {
      colors: ['#0d6efd', '#6f42c1', '#198754', '#fd7e14']
    });
    drawBarChart(document.getElementById('breakdownChart'), breakdownRows, {
      colors: ['#20c997', '#0dcaf0', '#ffc107', '#6610f2']
    });
  }

  renderCharts();
  window.addEventListener('resize', () => {
    clearTimeout(window.__usageChartResizeTimer);
    window.__usageChartResizeTimer = setTimeout(renderCharts, 180);
  });

  const form = document.getElementById('usageAnalyticsFilters');
  const shortcutInput = document.getElementById('shortcut');
  const startDateInput = document.getElementById('startDate');
  const endDateInput = document.getElementById('endDate');
  const targetTypeInput = document.getElementById('targetType');
  const targetIdInput = document.getElementById('targetId');

  function hydrateTargetOptions() {
    if (!targetTypeInput || !targetIdInput) return;
    const type = String(targetTypeInput.value || 'all').toLowerCase();
    const options = type === 'org'
      ? (selectableOptions.orgOptions || [])
      : type === 'user'
        ? (selectableOptions.userOptions || [])
        : [];

    const selectedBefore = String(targetIdInput.value || '');
    targetIdInput.innerHTML = '<option value="">All</option>';
    options.forEach((row) => {
      const opt = document.createElement('option');
      opt.value = String(row.id || '');
      opt.textContent = String(row.label || row.id || '');
      targetIdInput.appendChild(opt);
    });

    if (type === 'all') {
      targetIdInput.value = '';
      targetIdInput.disabled = true;
      return;
    }

    targetIdInput.disabled = false;
    const useSelected = selectedBefore || selectedTargetId;
    if (useSelected && Array.from(targetIdInput.options).some((opt) => opt.value === useSelected)) {
      targetIdInput.value = useSelected;
    } else {
      targetIdInput.value = '';
    }
  }
  document.querySelectorAll('.shortcut-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      shortcutInput.value = btn.dataset.shortcut || 'today';
      if (startDateInput) startDateInput.value = '';
      if (endDateInput) endDateInput.value = '';
      form.submit();
    });
  });

  if (targetTypeInput && targetIdInput) {
    targetTypeInput.value = selectedTargetType || 'all';
    hydrateTargetOptions();
    targetTypeInput.addEventListener('change', hydrateTargetOptions);
  }
</script>

<style>
  .chart-shell {
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 10px;
    background: linear-gradient(180deg, #fff 0%, #f8f9fa 100%);
    padding: 8px;
    overflow-x: auto;
    overflow-y: hidden;
  }
  .chart-shell canvas {
    width: 100%;
    height: 340px;
    display: block;
  }
  .chart-shell-small canvas {
    height: 340px;
  }
</style>
