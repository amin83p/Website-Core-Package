<%- include('partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print,
  manageBtns: [
    '<a href="' + ieltsSectionDashboardHref + '" class="ielts-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> IELTS Dashboard</a>'
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search by ID, name, category, or content...',
  fields: ['id', 'name', 'category', 'content']
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="draggable" data-column="id">Prompt ID <span class="sort-icon"></span></th>
        <th class="draggable" data-column="name">Name <span class="sort-icon"></span></th>
        <th class="draggable" data-column="category">Category <span class="sort-icon"></span></th>
        <th class="draggable" data-column="updatedAt">Updated <span class="sort-icon"></span></th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% data.forEach(item => { %>
        <tr>
          <td><span class="badge bg-light text-primary border"><%= item.id %></span></td>
          <td class="fw-bold"><%= item.name || item.id %></td>
          <td><span class="badge bg-info text-dark"><%= (item.category === 'NO_CATEGORY' || !item.category) ? 'No Category' : item.category %></span></td>
          <td>
            <% if (item.updatedAt) { %>
              <%= new Date(item.updatedAt).toLocaleDateString() %>
            <% } else { %> — <% } %>
          </td>
          <td>
            <% if (item.isActive === false) { %>
              <span class="badge bg-secondary">Inactive</span>
            <% } else { %>
              <span class="badge bg-success">Active</span>
            <% } %>
          </td>
          <td class="table-actions">
            <a href="/<%= newUrl %>/edit/<%= item.id %>" class="btn btn-sm btn-filled btn-edit">Edit</a>
            <button class="btn btn-sm btn-filled btn-delete delete-btn" data-id="<%= item.id %>">Delete</button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/pagination', {
  pagination: pagination,
  filters: filters,
  baseUrlPath: newUrl
}) %>

<%- include('partials/tablePages-end') %>
<%- include('partials/modal') %>

<script>
  document.querySelectorAll('.delete-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-id');
      if (!id) return;

      let allowDelete = false;
      if (typeof showMessageModal === 'function') {
        const result = await showMessageModal({
          title: 'Delete Prompt',
          icon: 'warning',
          message: `Are you sure you want to delete <b>"${id}"</b>?`,
          buttons: [
            { text: 'Cancel', class: 'btn-secondary' },
            { text: 'Delete', class: 'btn-warning' }
          ]
        });
        allowDelete = result === 'Delete';
      } else {
        allowDelete = confirm(`Delete "${id}"?`);
      }

      if (!allowDelete) return;

      try {
        const res = await fetch(`/ielts/prompts/delete/${encodeURIComponent(id)}`, {
          method: 'POST',
          headers: { 'x-ajax-request': 'true' }
        });
        const json = await res.json();
        if (json.status === 'success') {
          window.location.reload();
        } else {
          throw new Error(json.message || 'Delete failed.');
        }
      } catch (error) {
        if (typeof showMessageModal === 'function') {
          showMessageModal({
            title: 'Error',
            icon: 'error',
            message: error.message || 'Unable to delete prompt.',
            buttons: [{ text: 'Close', class: 'btn-secondary' }]
          });
        } else {
          alert(error.message || 'Unable to delete prompt.');
        }
      }
    });
  });
</script>

