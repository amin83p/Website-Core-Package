<%- include('../partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print,
  manageBtns: [
    '<a href="' + ieltsSectionDashboardHref + '" class="ielts-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> IELTS Dashboard</a>'
  ]
}) %>

  <%- include('../partials/tablePages-search', {
    placeholder: 'Search by Key, Title, or Question...',
    fields: ['question_key', 'title', 'atomic_question', 'criterion', 'prompt_group', 'signal_kind']
  }) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="draggable" data-column="question_key">Key <span class="sort-icon"></span></th>
        <th class="draggable" data-column="title">Group/Title <span class="sort-icon"></span></th>
        <th class="draggable" data-column="band">Band <span class="sort-icon"></span></th>
        <th class="draggable" data-column="criterion">Crit <span class="sort-icon"></span></th>
        <th class="draggable" data-column="prompt_group">Route <span class="sort-icon"></span></th>
        <th class="draggable" data-column="signal_kind">Signals <span class="sort-icon"></span></th>
        <th class="draggable" data-column="atomic_question">Question Text <span class="sort-icon"></span></th>
        <th class="draggable" data-column="updatedAt">Updated <span class="sort-icon"></span></th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% data.forEach(item => { %>
        <tr>
          <td>
            <span class="badge bg-light text-primary border"><%= item.question_key %></span>
          </td>
          <td>
             <span class="fw-bold text-dark"><%= item.title %></span>
          </td>
          <td><span class="badge bg-secondary"><%= item.band %></span></td>
          <td><span class="fw-bold"><%= item.criterion %></span></td>
          <td>
            <span class="badge bg-light text-dark border"><%= item.prompt_group || '—' %></span>
          </td>
          <td>
            <% const sk = item.signal_kind || (item.signal_source && item.signal_source.kind) || '—'; %>
            <% const sigs = item.signal_signals || (item.signal_source && item.signal_source.signals) || []; %>
            <% const sigArr = Array.isArray(sigs) ? sigs : []; %>
            <span class="badge bg-info text-dark" title="<%= sigArr.join('\n') %>"><%= sk %></span>
            <% if (sigArr.length) { %>
              <span class="badge bg-secondary" title="<%= sigArr.join('\n') %>"><%= sigArr.length %></span>
            <% } %>
          </td>
          <td>
            <div class="text-truncate" style="max-width: 350px;" title="<%= item.atomic_question %>">
                <%= item.atomic_question %>
            </div>
          </td>
          <td>
            <% if (item.updatedAt) { %>
              <%= new Date(item.updatedAt).toLocaleDateString() %>
            <% } else { %> — <% } %>
          </td>
          <td class="table-actions">
            <a href="/<%=newUrl%>/edit/<%= item.id %>" class="btn btn-sm btn-filled btn-edit">Edit</a>
            <a href="/<%=newUrl%>/copy/<%= item.id %>" class="btn btn-sm btn-filled btn-secondary">Copy</a>
            <button class="btn btn-sm btn-filled btn-delete delete-btn" data-id="<%= item.id %>">Delete</button>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('../partials/pagination', { 
    pagination: pagination, 
    filters: filters, 
    baseUrlPath: newUrl
}) %>

<%- include('../partials/tablePages-end') %>

<%- include('../partials/modal') %>

<div class="modal fade" id="importModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="bi bi-file-earmark-spreadsheet me-2"></i>Import Micro Assessments</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        
        <div id="importStep1">
            <div class="mb-4">
                <label class="form-label fw-bold">1. Select CSV File</label>
                <input type="file" id="fileImportInput" class="form-control" accept=".csv">
                <div class="form-text text-muted">
                    Supports CSV files. You will be able to preview and select rows before saving.
                </div>
            </div>
        </div>

        <div id="importStep2" style="display:none;">
            <div class="alert alert-info py-2 small mb-3">
                <i class="bi bi-info-circle me-1"></i> <strong>2. Map Columns:</strong> Match your CSV headers to the System Fields.
            </div>
            <div class="table-responsive border rounded" style="max-height: 300px; overflow-y: auto;">
                <table class="table table-sm table-striped mb-0 align-middle">
                    <thead class="table-light sticky-top">
                        <tr><th style="width: 40%;">System Field</th><th style="width: 60%;">CSV Column</th></tr>
                    </thead>
                    <tbody id="mappingTableBody"></tbody>
                </table>
            </div>
        </div>

        <div id="importStep3" style="display:none;">
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div class="alert alert-warning py-2 px-3 small mb-0 flex-grow-1 me-3">
                    <i class="bi bi-check-circle me-1"></i> <strong>3. Select Data:</strong> Uncheck any rows you want to exclude.
                </div>
                <div class="text-end">
                    <span class="badge bg-primary fs-6" id="selectionCountBadge">0 selected</span>
                </div>
            </div>
            
            <div class="table-responsive border rounded" style="max-height: 500px; overflow-y: auto;">
                <table class="table table-sm table-bordered table-hover mb-0 small">
                    <thead class="table-light sticky-top">
                        <tr id="previewTableHeader">
                            </tr>
                    </thead>
                    <tbody id="previewTableBody">
                        </tbody>
                </table>
            </div>
        </div>

      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary btn_filled" id="btnCancelImport" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-secondary btn_filled" id="btnBack" style="display:none;">Back</button>
        
        <button type="button" class="btn btn-primary" id="btnToMapping" disabled>Next: Map Fields</button>
        <button type="button" class="btn btn-primary" id="btnToPreview" style="display:none;">Next: Preview Data</button>
        
        <button type="button" class="btn btn-success btn_filled" id="btnConfirmImport" style="display:none;">
            <i class="bi bi-cloud-upload me-1"></i> Import Selected
        </button>
      </div>
    </div>
  </div>
</div>

<script>
    // --- CONFIGURATION ---
    const SYSTEM_FIELDS = <%- JSON.stringify(systemFields) %>;

    let csvHeaders = [];
    let csvData = []; 
    let currentMapping = {};

    // --- UI NAVIGATION ---
    document.getElementById('openBatchModalBtn').onclick = () => {
      // function openLocalImportModal() {
        const modalEl = document.getElementById('importModal');
        if(!modalEl) {
          if(typeof showMessageModal === 'function') {
              await showMessageModal({ 
                  title: 'Modal', 
                  icon: 'error', 
                  message: `Modal is not found.`,
                  buttons: [{ text: 'Close', class: 'btn-secondary' },
                            { text: 'Reload Page', class: 'btn-primary', handler: () => window.location.reload() },
                            { text: 'Ok', class: 'btn-danger'}]
              });
          } else {
            return alert('Modal missing.');
          }
        }
        
        // Reset State
        document.getElementById('fileImportInput').value = '';
        switchStep(1);
        
        // Listeners
        document.getElementById('fileImportInput').onchange = (e) => {
            if(e.target.files.length) document.getElementById('btnToMapping').disabled = false;
        };

        // Navigation
        document.getElementById('btnToMapping').onclick = () => {
             const file = document.getElementById('fileImportInput').files[0];
             const reader = new FileReader();
             reader.onload = (e) => {
                 parseCSV(e.target.result);
                 renderMappingTable();
                 switchStep(2);
             };
             reader.readAsText(file);
        };

        document.getElementById('btnToPreview').onclick = () => {
            if(validateMapping()) {
                generatePreview();
                switchStep(3);
            }
        };

        document.getElementById('btnBack').onclick = () => {
            if(document.getElementById('importStep3').style.display === 'block') switchStep(2);
            else if(document.getElementById('importStep2').style.display === 'block') switchStep(1);
        };

        document.getElementById('btnConfirmImport').onclick = runImport;

        if (typeof bootstrap !== 'undefined') bootstrap.Modal.getOrCreateInstance(modalEl).show();
        else new bootstrap.Modal(modalEl).show();
    }

    function switchStep(step) {
        document.getElementById('importStep1').style.display = 'none';
        document.getElementById('importStep2').style.display = 'none';
        document.getElementById('importStep3').style.display = 'none';
        
        const btnBack = document.getElementById('btnBack');
        const btnToMap = document.getElementById('btnToMapping');
        const btnToPrev = document.getElementById('btnToPreview');
        const btnImport = document.getElementById('btnConfirmImport');

        btnBack.style.display = 'none';
        btnToMap.style.display = 'none';
        btnToPrev.style.display = 'none';
        btnImport.style.display = 'none';

        if(step === 1) {
            document.getElementById('importStep1').style.display = 'block';
            btnToMap.style.display = 'inline-block';
        } else if(step === 2) {
            document.getElementById('importStep2').style.display = 'block';
            btnBack.style.display = 'inline-block';
            btnToPrev.style.display = 'inline-block';
        } else if(step === 3) {
            document.getElementById('importStep3').style.display = 'block';
            btnBack.style.display = 'inline-block';
            btnImport.style.display = 'inline-block';
        }
    }

    // --- CSV PARSING ---
    function parseCSV(text) {
        const re = /(?!\s*$)\s*(?:'([^']*(?:''[^']*)*)'|"([^"]*(?:""[^"]*)*)"|([^,'"\r\n]*))(?:\s*(?:,|$))?/g;
        const lines = text.split(/\r\n|\n|\r/).filter(l => l.trim().length > 0);
        if(lines.length < 1){ 
            if(typeof showMessageModal === 'function') {
                showMessageModal({ 
                    title: 'File Content', 
                    icon: 'warning', 
                    message:`Selected file is empty.`,
                    buttons: [{ text: 'Ok', class: 'btn-warning'}]
                });
            } else {
              alert(`Selected file is empty.`);
            }
        }

        const parseLine = (line) => {
            const row = [];
            let cursor = 0;
            while(cursor < line.length) {
                if(line[cursor] === '"') {
                    let endQuote = line.indexOf('"', cursor + 1);
                    while(endQuote !== -1 && line[endQuote+1] === '"') {
                        endQuote = line.indexOf('"', endQuote + 2);
                    }
                    if(endQuote === -1) endQuote = line.length;
                    let val = line.substring(cursor + 1, endQuote).replace(/""/g, '"');
                    row.push(val);
                    cursor = endQuote + 1;
                    if(line[cursor] === ',') cursor++;
                } else {
                    let nextComma = line.indexOf(',', cursor);
                    if(nextComma === -1) nextComma = line.length;
                    row.push(line.substring(cursor, nextComma).trim());
                    cursor = nextComma + 1;
                }
            }
            return row;
        };

        csvHeaders = parseLine(lines[0]).map(h => h.replace(/^\ufeff/, '').trim());
        csvData = [];
        for(let i=1; i<lines.length; i++) {
            const row = parseLine(lines[i]);
            if(row.length > 0 && (row.length > 1 || row[0] !== '')) {
                csvData.push(row);
            }
        }
    }

    // --- MAPPING LOGIC ---
    function renderMappingTable() {
        const tbody = document.getElementById('mappingTableBody');
        tbody.innerHTML = '';
        SYSTEM_FIELDS.forEach(field => {
            const cleanKey = field.key.replace(/_/g, '').toLowerCase();
            const bestMatch = csvHeaders.find(h => {
                const cleanH = h.toLowerCase().replace(/_/g, '').replace(/ /g, '');
                return cleanH === cleanKey || cleanH === field.label.toLowerCase().replace(/ /g, '');
            }) || '';
            
            let opts = `<option value="">-- Ignore --</option>` + 
                csvHeaders.map((h,i) => `<option value="${i}" ${h===bestMatch?'selected':''}>${h}</option>`).join('');
            
            const tr = document.createElement('tr');
            tr.innerHTML = `<td><strong>${field.label}</strong> ${field.required?'<span class="text-danger">*</span>':''}</td>
                            <td><select class="form-select form-select-sm map-select" data-key="${field.key}">${opts}</select></td>`;
            tbody.appendChild(tr);
        });
    }

    function validateMapping() {
        currentMapping = {};
        let missing = false;
        document.querySelectorAll('.map-select').forEach(s => {
            const k = s.getAttribute('data-key');
            if(SYSTEM_FIELDS.find(f=>f.key===k).required && s.value === '') {
                s.classList.add('is-invalid');
                missing = true;
            } else {
                s.classList.remove('is-invalid');
                if(s.value !== '') currentMapping[k] = parseInt(s.value);
            }
        });
        if(missing){ 
          if(typeof showMessageModal === 'function') {
              await showMessageModal({ 
                  title: 'Import Settings', 
                  icon: 'warning', 
                  message:`Please map all required fields.`,
                  buttons: [{ text: 'Ok', class: 'btn-warning'}]
              });
          } else {
            alert(`Please map all required fields.`);
          }
        }
        return !missing;
    }

    // --- PREVIEW & SELECTION LOGIC ---
    function generatePreview() {
        const thead = document.getElementById('previewTableHeader');
        const tbody = document.getElementById('previewTableBody');
        
        // 1. Header (Check All + Fields)
        thead.innerHTML = `
            <th class="text-center" style="width: 40px;">
                <input type="checkbox" class="form-check-input" id="selectAllRows" checked>
            </th>
        `;
        const activeKeys = Object.keys(currentMapping);
        activeKeys.forEach(key => {
            const field = SYSTEM_FIELDS.find(f => f.key === key);
            const th = document.createElement('th');
            th.innerText = field ? field.label : key;
            thead.appendChild(th);
        });

        // 2. Body (Rows)
        tbody.innerHTML = '';
        csvData.forEach((row, index) => {
            const tr = document.createElement('tr');
            
            // Checkbox Cell
            const tdCheck = document.createElement('td');
            tdCheck.className = 'text-center';
            tdCheck.innerHTML = `<input type="checkbox" class="form-check-input row-select" data-index="${index}" checked>`;
            tr.appendChild(tdCheck);

            // Data Cells
            activeKeys.forEach(key => {
                const colIdx = currentMapping[key];
                const val = (row[colIdx] !== undefined) ? row[colIdx] : '';
                const td = document.createElement('td');
                if(val.length > 80) {
                    td.innerHTML = `<span title="${val.replace(/"/g, '&quot;')}">${val.substring(0,80)}...</span>`;
                } else {
                    td.innerText = val;
                }
                tr.appendChild(td);
            });
            tbody.appendChild(tr);
        });

        // 3. Attach Event Listeners
        document.getElementById('selectAllRows').addEventListener('change', function() {
            const isChecked = this.checked;
            document.querySelectorAll('.row-select').forEach(cb => cb.checked = isChecked);
            updateSelectionCount();
        });

        document.querySelectorAll('.row-select').forEach(cb => {
            cb.addEventListener('change', updateSelectionCount);
        });

        updateSelectionCount();
    }

    function updateSelectionCount() {
        const count = document.querySelectorAll('.row-select:checked').length;
        const btn = document.getElementById('btnConfirmImport');
        const badge = document.getElementById('selectionCountBadge');
        
        btn.innerHTML = `<i class="bi bi-cloud-upload me-1"></i> Import ${count} Items`;
        btn.disabled = count === 0;
        
        badge.innerText = `${count} selected`;
        badge.className = count > 0 ? 'badge bg-primary fs-6' : 'badge bg-secondary fs-6';
    }

    // --- IMPORT LOGIC ---
    async function runImport() {
        const btn = document.getElementById('btnConfirmImport');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Importing...';

        let success = 0;
        let errors = [];
        
        // 1. Get Selected Indices
        const selectedIndices = Array.from(document.querySelectorAll('.row-select:checked'))
                                     .map(cb => parseInt(cb.getAttribute('data-index')));

        // 2. Iterate Selected Rows
        for(const idx of selectedIndices) {
            const row = csvData[idx];
            const payload = {};
            
            // Apply Mapping
            for(const [key, colIdx] of Object.entries(currentMapping)) {
                payload[key] = row[colIdx];
            }
            if(!payload.title) payload.title = 'Imported';
            
            try {
                const res = await fetch('/ielts/microAssessments/new', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'x-ajax-request': 'true' },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                if(res.ok && data.status === 'success') success++;
                else errors.push(`${payload.question_key || 'Row ' + (idx+1)}: ${data.message || 'Error'}`);
            } catch(e) { errors.push("Network Error"); }
        }

        btn.disabled = false;
        btn.innerHTML = 'Import Selected';
        
        bootstrap.Modal.getOrCreateInstance(document.getElementById('importModal')).hide();
        
        if(typeof showMessageModal === 'function') {
            if(errors.length) {
                await showMessageModal({ 
                    title: 'Import Completed', 
                    icon: 'warning', 
                    message: `Imported: ${success} items.<br>Failed: ${errors.length} items.<br><br>First few errors:<br>${errors.slice(0,5).join('<br>')}`,
                    buttons: [{ text: 'Reload Page', class: 'btn-primary', handler: () => window.location.reload() }]
                });
            } else {
                await showMessageModal({ 
                    title: 'Success', 
                    icon: 'success', 
                    message: `Successfully imported ${success} items.`, 
                    buttons: [{ text: 'OK', class: 'btn-success', handler: () => window.location.reload() }]
                });
            }
        } else {          
            alert(`Imported: ${success}\nErrors: ${errors.length}`);
        }
        window.location.reload();
    }
</script>

