<script>
    const currentAssessmentId = <%- JSON.stringify(isEdit ? assessment.id : '') %>;

    // --- Helpers: lightweight client-side cleanup & signal suggestions ---
    function cleanSpacing(text) {
        if (!text) return '';
        let t = String(text);
        // Fix common OCR/import artifacts
        const reps = [
            [/\bpositi\s+on\b/ig, 'position'],
            [/\bconclusi\s+on\b/ig, 'conclusion'],
            [/\bprogressi\s+on\b/ig, 'progression'],
            [/\bpunctuati\s+on\b/ig, 'punctuation'],
            [/\bcommunicati\s+on\b/ig, 'communication'],
            [/\bformati\s+on\b/ig, 'formation'],
            [/\bsubordinati\s+on\b/ig, 'subordination'],
            [/\bexplanati\s+on\b/ig, 'explanation'],
            [/\bthereno\b/ig, 'there no'],
            [/\btheresome\b/ig, 'there some'],
            [/\bideasnot\b/ig, 'ideas not'],
            [/\bonlypartially\b/ig, 'only partially'],
            [/\berrorsnoticeable\b/ig, 'errors noticeable'],
            [/\berrorspredominate\b/ig, 'errors predominate'],
        ];
        reps.forEach(([re, rep]) => t = t.replace(re, rep));
        // Ensure space after punctuation
        t = t.replace(/\?([A-Za-z])/g, '? $1').replace(/\.([A-Za-z])/g, '. $1');
        // Collapse whitespace
        t = t.replace(/\s{2,}/g, ' ').trim();
        // Add '?' if it looks like a question and doesn't end with one
        const starts = ['is ', 'are ', 'do ', 'does ', 'can ', 'may ', 'has ', 'have '];
        if (t && !t.endsWith('?') && starts.some(s => t.toLowerCase().startsWith(s))) t += '?';
        return t;
    }

    function inferPromptGroup(criterion) {
        return (criterion === 'TR' || criterion === 'CC') ? 'PROMPT_A_TR_CC' : 'PROMPT_B_LR_GRA';
    }

    const scoringContractState = { scored: [], notScored: [] };

    function normalizeAnswerToken(value) {
        return String(value ?? '').trim().toLowerCase();
    }

    function dedupeAnswerTokens(tokens) {
        const out = [];
        const seen = new Set();
        (tokens || []).forEach((token) => {
            const normalized = normalizeAnswerToken(token);
            if (!normalized || seen.has(normalized)) return;
            seen.add(normalized);
            out.push(normalized);
        });
        return out;
    }

    function parseAnswerTokensFromRaw(raw) {
        if (raw === undefined || raw === null) return [];
        const text = Array.isArray(raw) ? raw.join('\n') : String(raw);
        return dedupeAnswerTokens(text.split(/[\n,]+/));
    }

    function parseAnswerTypeOptions(answerTypeRaw) {
        const answerType = String(answerTypeRaw || '').trim();
        if (!answerType) return [];
        if (/^boolean$/i.test(answerType)) return ['yes', 'no'];

        const parenMatch = answerType.match(/\(([^)]+)\)/);
        if (parenMatch && parenMatch[1]) {
            return dedupeAnswerTokens(parenMatch[1].split(/[\/|,]+/));
        }
        return [];
    }

    function renderAnswerTypeOptionsPreview() {
        const answerTypeInput = document.querySelector('input[name="answer_type"]');
        const preview = document.getElementById('answerTypeOptionsPreview');
        if (!answerTypeInput || !preview) return [];
        const options = parseAnswerTypeOptions(answerTypeInput.value);
        if (!options.length) {
            preview.textContent = 'No explicit options detected from answer type.';
            return [];
        }
        preview.innerHTML = '';
        options.forEach((option) => {
            const chip = document.createElement('span');
            chip.className = 'badge bg-white text-dark border me-1 mb-1';
            chip.textContent = option;
            preview.appendChild(chip);
        });
        return options;
    }

    function syncScoringContractHiddenInputs() {
        const scoredInput = document.getElementById('scoredAnswersInput');
        const notScoredInput = document.getElementById('notScoredAnswersInput');
        if (scoredInput) scoredInput.value = scoringContractState.scored.join('\n');
        if (notScoredInput) notScoredInput.value = scoringContractState.notScored.join('\n');
    }

    function renderTokenList(kind) {
        const listId = kind === 'scored' ? 'scoredAnswersTokenList' : 'notScoredAnswersTokenList';
        const container = document.getElementById(listId);
        if (!container) return;
        const tokens = kind === 'scored' ? scoringContractState.scored : scoringContractState.notScored;
        container.innerHTML = '';
        if (!tokens.length) {
            const empty = document.createElement('div');
            empty.className = 'answer-token-empty';
            empty.textContent = 'No answers added yet.';
            container.appendChild(empty);
            return;
        }
        tokens.forEach((token, index) => {
            const badge = document.createElement('span');
            badge.className = 'answer-token';
            badge.textContent = token;

            const remove = document.createElement('button');
            remove.type = 'button';
            remove.innerHTML = '<i class="bi bi-x-lg"></i>';
            remove.setAttribute('aria-label', `Remove ${token}`);
            remove.dataset.kind = kind;
            remove.dataset.index = String(index);
            remove.className = 'token-remove';

            badge.appendChild(remove);
            container.appendChild(badge);
        });
    }

    function renderScoringContract() {
        renderTokenList('scored');
        renderTokenList('notScored');
        syncScoringContractHiddenInputs();
    }

    function setScoringContract(scored, notScored) {
        const nextScored = dedupeAnswerTokens(scored);
        const scoredSet = new Set(nextScored);
        const nextNotScored = dedupeAnswerTokens(notScored).filter((token) => !scoredSet.has(token));
        scoringContractState.scored = nextScored;
        scoringContractState.notScored = nextNotScored;
        renderScoringContract();
    }

    function addTokenToContract(kind, rawToken) {
        const token = normalizeAnswerToken(rawToken);
        if (!token) return;
        if (kind === 'scored') {
            scoringContractState.notScored = scoringContractState.notScored.filter((item) => item !== token);
            scoringContractState.scored = dedupeAnswerTokens([...scoringContractState.scored, token]);
        } else {
            scoringContractState.scored = scoringContractState.scored.filter((item) => item !== token);
            scoringContractState.notScored = dedupeAnswerTokens([...scoringContractState.notScored, token]);
        }
        renderScoringContract();
    }

    function removeTokenFromContract(kind, index) {
        const idx = Number(index);
        if (Number.isNaN(idx) || idx < 0) return;
        if (kind === 'scored') {
            scoringContractState.scored = scoringContractState.scored.filter((_, i) => i !== idx);
        } else {
            scoringContractState.notScored = scoringContractState.notScored.filter((_, i) => i !== idx);
        }
        renderScoringContract();
    }

    function bindTokenInput(inputId, addButtonId, kind) {
        const input = document.getElementById(inputId);
        const addButton = document.getElementById(addButtonId);
        if (!input || !addButton) return;

        const submitToken = () => {
            const normalized = normalizeAnswerToken(input.value);
            if (!normalized) return;
            addTokenToContract(kind, normalized);
            input.value = '';
        };

        input.addEventListener('blur', () => {
            input.value = normalizeAnswerToken(input.value);
        });
        input.addEventListener('keydown', (event) => {
            if (event.key !== 'Enter') return;
            event.preventDefault();
            submitToken();
        });
        addButton.addEventListener('click', submitToken);
    }

    function initScoringContractUI() {
        const answerTypeInput = document.querySelector('input[name="answer_type"]');
        const btnFeature = document.getElementById('btnSetFeatureContract');
        const btnFault = document.getElementById('btnSetFaultContract');
        const btnDerived = document.getElementById('btnSetDerivedContract');
        const scoredInput = document.getElementById('scoredAnswersInput');
        const notScoredInput = document.getElementById('notScoredAnswersInput');

        const getDerivedOptions = () => renderAnswerTypeOptionsPreview();

        if (answerTypeInput) {
            answerTypeInput.addEventListener('input', renderAnswerTypeOptionsPreview);
            answerTypeInput.addEventListener('change', renderAnswerTypeOptionsPreview);
            renderAnswerTypeOptionsPreview();
        }

        bindTokenInput('scoredAnswersTokenInput', 'btnAddScoredAnswer', 'scored');
        bindTokenInput('notScoredAnswersTokenInput', 'btnAddNotScoredAnswer', 'notScored');

        if (btnFeature) {
            btnFeature.addEventListener('click', () => {
                const options = getDerivedOptions();
                if (options.length === 2 && options.includes('yes') && options.includes('no')) {
                    return setScoringContract(['yes'], ['no']);
                }
                if (options.length > 1) return setScoringContract([options[options.length - 1]], options.slice(0, options.length - 1));
                return setScoringContract(['yes'], ['no']);
            });
        }

        if (btnFault) {
            btnFault.addEventListener('click', () => {
                const options = getDerivedOptions();
                if (options.length === 2 && options.includes('yes') && options.includes('no')) {
                    return setScoringContract(['no'], ['yes']);
                }
                if (options.length > 1) return setScoringContract([options[0]], options.slice(1));
                return setScoringContract(['no'], ['yes']);
            });
        }

        if (btnDerived) {
            btnDerived.addEventListener('click', () => {
                const options = getDerivedOptions();
                if (!options.length) return;
                setScoringContract([options[0]], options.slice(1));
            });
        }

        const seedScored = parseAnswerTokensFromRaw(scoredInput ? scoredInput.value : '');
        const seedNotScored = parseAnswerTokensFromRaw(notScoredInput ? notScoredInput.value : '');
        setScoringContract(seedScored, seedNotScored);

        document.addEventListener('click', (event) => {
            const target = event.target.closest('.token-remove');
            if (!target) return;
            removeTokenFromContract(target.dataset.kind, target.dataset.index);
        });
    }

    function suggestSignals({ criterion, questionText }) {
        const q = (questionText || '').toLowerCase();
        let kind = 'hybrid';
        let signals = [];

        if (criterion === 'TR') {
            // stance / coverage
            if (q.includes('position') || q.includes('opinion') || q.includes('agree') || q.includes('disagree')) {
                kind = 'deterministic';
                signals = ['position.stance', 'position.stanceSentenceIndex', 'position.contradictionSentenceIndices'];
            } else if (q.includes('address') || q.includes('parts of the task') || q.includes('all parts')) {
                kind = 'deterministic';
                signals = ['answersBySubquestion'];
            } else {
                kind = 'hybrid';
                signals = ['bodySupport[*].hasExplanation', 'bodySupport[*].hasExample', 'bodySupport[*].evidenceSentenceIndices'];
            }
        } else if (criterion === 'CC') {
            if (q.includes('paragraph')) {
                kind = 'deterministic';
                signals = ['structure.paragraphCount', 'structure.paragraphRoles', 'structure.paragraphSentenceCounts'];
            } else if (q.includes('inaccurate') && q.includes('cohesive')) {
                kind = 'ai';
                signals = ['ai_cohesion_misuse.issueSentenceIndices'];
            } else {
                kind = 'hybrid';
                signals = [
                    'cohesion.densityPer100ExcludingBasic',
                    'cohesion.distinctConnectorsExcludingBasic',
                    'cohesion.usageMapExcludingBasic',
                    'topicSentenceByParagraph[*].topicSentenceIndex'
                ];
            }
        } else if (criterion === 'LR') {
            if (q.includes('spelling') || q.includes('word formation')) {
                kind = 'external';
                signals = ['spellcheck.errorCount', 'spellcheck.errorRate'];
            } else if (q.includes('repetit')) {
                kind = 'deterministic';
                signals = ['lexical.topRepeatedWords', 'lexical.referencingDensity'];
            } else {
                kind = 'hybrid';
                signals = ['lexical.sophisticationProfile', 'lexical_error_profile.frequency'];
            }
        } else if (criterion === 'GRA') {
            kind = 'external';
            if (q.includes('punctuation')) {
                signals = ['grammarcheck.punctuationErrorCount', 'grammarcheck.punctuationErrorRate'];
            } else if (q.includes('complex') || q.includes('subordination') || q.includes('structures')) {
                signals = ['syntax.complexStructureCounts', 'syntax.complexStructureVariety'];
            } else {
                signals = ['grammarcheck.grammarErrorCount', 'grammarcheck.errorFreeSentenceRatio'];
            }
        }

        return { kind, signals };
    }

    // Wire up UI buttons (non-blocking if elements missing)
    (function initRoutingUI() {
        const btn = document.getElementById('btnSuggestSignals');
        const btnClean = document.getElementById('btnCleanText');
        const btnCopyFromAssessment = document.getElementById('btnCopyFromAssessment');
        if (btnClean) {
            btnClean.addEventListener('click', () => {
                const qTa = document.querySelector('textarea[name="atomic_question"]');
                const rTa = document.querySelector('textarea[name="rubric_anchor"]');
                if (qTa) qTa.value = cleanSpacing(qTa.value);
                if (rTa) rTa.value = cleanSpacing(rTa.value);
            });
        }
        if (btnCopyFromAssessment) {
            btnCopyFromAssessment.addEventListener('click', async () => {
                if (!window.GenericPicker) {
                    if (typeof showMessageModal === 'function') {
                        await showMessageModal({
                            title: 'Unavailable',
                            icon: 'warning',
                            message: 'Assessment picker is not available on this page.',
                            buttons: [{ text: 'Close', class: 'btn-warning' }]
                        });
                    } else {
                        alert('Assessment picker is not available.');
                    }
                    return;
                }

                const onSelect = async (selectedItem) => {
                        const sourceId = String(selectedItem?.id || '').trim();
                        if (!sourceId) return;
                        if (currentAssessmentId && sourceId === String(currentAssessmentId)) {
                            if (typeof showMessageModal === 'function') {
                                await showMessageModal({
                                    title: 'Invalid Selection',
                                    icon: 'warning',
                                    message: 'Select a different assessment to copy from.',
                                    buttons: [{ text: 'Close', class: 'btn-warning' }]
                                });
                            } else {
                                alert('Select a different assessment to copy from.');
                            }
                            return;
                        }
                        window.location.href = `/ielts/microAssessments/copy/${encodeURIComponent(sourceId)}`;
                };

                const pickerConfig = (typeof window.GenericPickerPresets?.microAssessment === 'function')
                    ? window.GenericPickerPresets.microAssessment({
                        title: 'Copy From Assessment',
                        placeholder: 'Search by question key, title, or text...',
                        onSelect
                    })
                    : {
                        title: 'Copy From Assessment',
                        icon: 'bi-card-checklist',
                        apiEndpoint: '/ielts/microAssessments',
                        placeholder: 'Search by question key, title, or text...',
                        searchFields: 'question_key,title,atomic_question,criterion,prompt_group,signal_kind',
                        onSelect
                    };

                GenericPicker.open(pickerConfig);
            });
        }
        if (btn) {
            btn.addEventListener('click', () => {
                const crit = document.querySelector('select[name="criterion"]')?.value;
                const qText = document.querySelector('textarea[name="atomic_question"]')?.value;
                const rec = suggestSignals({ criterion: crit, questionText: qText });

                // Auto set prompt group if empty
                const pgSel = document.querySelector('select[name="prompt_group"]');
                if (pgSel && !pgSel.value) pgSel.value = inferPromptGroup(crit);

                const kindSel = document.querySelector('select[name="signal_kind"]');
                if (kindSel) kindSel.value = rec.kind;

                const sigTa = document.querySelector('textarea[name="signal_signals"]');
                if (sigTa) sigTa.value = (rec.signals || []).join('\n');
            });
        }
    })();

    initScoringContractUI();

    const assessmentForm = document.getElementById('assessmentForm');
    const assessmentSaveBtn = assessmentForm ? assessmentForm.querySelector('button[type="submit"]') : null;
    const assessmentCancelBtn = document.getElementById('btnCancelAction');
    let isSubmitting = false;

    function cacheButtonHtml(button) {
        if (!button) return;
        if (!button.dataset.defaultHtml) button.dataset.defaultHtml = button.innerHTML;
    }

    function setButtonBusy(button, label) {
        if (!button) return;
        cacheButtonHtml(button);
        button.disabled = true;
        button.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>' + (label || 'Working...');
        if (button.tagName === 'A') {
            button.classList.add('disabled');
            button.setAttribute('aria-disabled', 'true');
            button.style.pointerEvents = 'none';
        }
    }

    function restoreButton(button) {
        if (!button) return;
        if (button.dataset.defaultHtml) button.innerHTML = button.dataset.defaultHtml;
        button.disabled = false;
        if (button.tagName === 'A') {
            button.classList.remove('disabled');
            button.removeAttribute('aria-disabled');
            button.style.pointerEvents = '';
        }
    }

    cacheButtonHtml(assessmentSaveBtn);
    cacheButtonHtml(assessmentCancelBtn);

    if (assessmentCancelBtn) {
        assessmentCancelBtn.addEventListener('click', (event) => {
            if (isSubmitting) {
                event.preventDefault();
                return;
            }
            setButtonBusy(assessmentCancelBtn, 'Cancelling...');
            if (assessmentSaveBtn) assessmentSaveBtn.disabled = true;
        });
    }

    assessmentForm.addEventListener('submit', async function(e) {
        e.preventDefault();
        if (isSubmitting) return;
        isSubmitting = true;
        
        const form = this;
        const btn = assessmentSaveBtn;
        
        // 1. Prepare Data
        const formData = new FormData(form);
        const payload = Object.fromEntries(formData.entries());
        
        // Handle Checkbox manually
        payload.is_active = form.querySelector('#isActiveSwitch').checked;

        // 2. Loading State
        setButtonBusy(btn, 'Saving...');
        if (assessmentCancelBtn) assessmentCancelBtn.disabled = true;

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'X-AJAX-Request': 'true' 
                },
                body: JSON.stringify(payload)
            });

            const result = await response.json();
            
            if (result.status === 'success') {
                if(typeof showMessageModal === 'function') {
                    await showMessageModal({ 
                        title: 'Success', 
                        icon: 'success', 
                        message: result.message || 'Saved successfully.', 
                        buttons: [{ 
                            text: 'OK', 
                            class: 'btn-success',
                            handler: () => window.location.href = '/ielts/microAssessments'
                        }] 
                    });
                    // Fallback in case handler isn't immediate
                    setTimeout(() => window.location.href = '/ielts/microAssessments', 1500);
                } else {
                    alert('Success: ' + (result.message || 'Saved successfully.'));
                    window.location.href = '/ielts/microAssessments';
                }
            } else {
                const msg = result.message || 'Failed to save.';
                if(typeof showMessageModal === 'function') {
                    showMessageModal({ title: 'Error', icon: 'error', message: msg, buttons: [{ text: 'Close', class: 'btn-danger' }] });
                } else { 
                    alert('Error: ' + msg); 
                }
                isSubmitting = false;
                restoreButton(assessmentSaveBtn);
                restoreButton(assessmentCancelBtn);
            }
        } catch (error) {
            console.error(error);
            if(typeof showMessageModal === 'function') {
                showMessageModal({ title: 'System Error', icon: 'error', message: 'Unexpected network error.', buttons: [{ text: 'Close', class: 'btn-danger' }] });
            } else { 
                alert('Network Error'); 
            }
            isSubmitting = false;
            restoreButton(assessmentSaveBtn);
            restoreButton(assessmentCancelBtn);
        }
    });
</script>
