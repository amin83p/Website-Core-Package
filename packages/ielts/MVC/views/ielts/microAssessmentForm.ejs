                                <div class="form-text">This text appears in scoring prompts and result rows.</div>
                            </div>

                            <div class="mb-1">
                                <label class="form-label fw-bold">Rubric Anchor <span class="text-danger">*</span></label>
                                <textarea name="rubric_anchor" class="form-control bg-light" rows="2"
                                          placeholder="Standard from the IELTS Rubric..." required><%= assessment ? assessment.rubric_anchor : '' %></textarea>
                                <div class="form-text">Reference rubric statement that justifies this check.</div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="content-meta-pane" role="tabpanel" aria-labelledby="content-meta-tab" tabindex="0">
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label class="form-label small text-muted">Tags</label>
                                    <input type="text" name="tags" class="form-control form-control-sm"
                                           value="<%= assessment ? assessment.tags : '' %>" placeholder="comma, separated">
                                    <div class="form-text">For filtering and bulk maintenance.</div>
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small text-muted">Internal Notes</label>
                                    <input type="text" name="notes" class="form-control form-control-sm"
                                           value="<%= assessment ? assessment.notes : '' %>" placeholder="Private notes...">
                                    <div class="form-text">Visible to maintainers only.</div>
                                </div>
                            </div>
                            <div class="alert alert-info mt-3 mb-0 py-2 small">
                                Tip: keep <strong>question_key</strong>, <strong>answer_type</strong>, and scoring lists aligned to avoid ambiguous scoring.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

      </div>

      <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md">
            <i class="bi bi-save me-1"></i> Save Item
        </button>
        <a href="/ielts/microAssessments" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction"> Cancel </a>
      </div>

    </form>
  </div>
</div>

