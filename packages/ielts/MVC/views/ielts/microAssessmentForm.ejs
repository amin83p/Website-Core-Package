                                <label class="form-label fw-bold small text-muted text-uppercase m-0">Step 3 Routing & Signals</label>
                                <button type="button" class="btn btn-sm btn-outline-primary" id="btnSuggestSignals">
                                    <i class="bi bi-magic me-1"></i>Suggest
                                </button>
                            </div>
                            <div class="form-text small mb-3">
                                Choose how this question should be answered in Step 3. Deterministic/hybrid routes reduce AI usage.
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="form-label small text-muted">Prompt Group</label>
                                    <% const pg = assessment ? (assessment.prompt_group || '') : ''; %>
                                    <select name="prompt_group" class="form-select">
                                        <option value="" <%= !pg ? 'selected' : '' %>>Auto (by criterion)</option>
                                        <option value="PROMPT_A_TR_CC" <%= pg==='PROMPT_A_TR_CC'?'selected':'' %>>PROMPT_A_TR_CC (TR + CC)</option>
                                        <option value="PROMPT_B_LR_GRA" <%= pg==='PROMPT_B_LR_GRA'?'selected':'' %>>PROMPT_B_LR_GRA (LR + GRA)</option>
                                    </select>
                                </div>
                                <div class="col-6">
                                    <label class="form-label small text-muted">Signal Kind</label>
                                    <% const sk = assessment ? (assessment.signal_kind || (assessment.signal_source && assessment.signal_source.kind) || '') : ''; %>
                                    <select name="signal_kind" class="form-select">
                                        <option value="" <%= !sk ? 'selected' : '' %>>Auto (recommended)</option>
                                        <option value="deterministic" <%= sk==='deterministic'?'selected':'' %>>deterministic</option>
                                        <option value="hybrid" <%= sk==='hybrid'?'selected':'' %>>hybrid</option>
                                        <option value="ai" <%= sk==='ai'?'selected':'' %>>ai</option>
                                        <option value="external" <%= sk==='external'?'selected':'' %>>external</option>
                                    </select>
                                </div>
                            </div>
                            <div class="mb-2">
                                <label class="form-label small text-muted">Signals (one per line or comma-separated)</label>
                                <% const sigArr = assessment ? (assessment.signal_signals || (assessment.signal_source && assessment.signal_source.signals) || []) : []; %>
                                <% const sigText = Array.isArray(sigArr) ? sigArr.join('\n') : (sigArr || ''); %>
                                <textarea name="signal_signals" class="form-control" rows="4" placeholder="e.g. position.stance\ncohesion.densityPer100ExcludingBasic"><%= sigText %></textarea>
                                <div class="form-text small">
                                    These are extraction paths (for example <code>position.stance</code>, <code>answersBySubquestion</code>, <code>cohesion.distinctConnectorsExcludingBasic</code>).
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-7 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-light fw-bold text-primary">
                    <i class="bi bi-file-text me-2"></i>Content & Metadata
                </div>
                <div class="card-body">
                    <ul class="nav nav-tabs micro-form-tabs" id="contentTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="content-main-tab" data-bs-toggle="tab" data-bs-target="#content-main-pane" type="button" role="tab" aria-controls="content-main-pane" aria-selected="true">
                                Question Content
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="content-meta-tab" data-bs-toggle="tab" data-bs-target="#content-meta-pane" type="button" role="tab" aria-controls="content-meta-pane" aria-selected="false">
