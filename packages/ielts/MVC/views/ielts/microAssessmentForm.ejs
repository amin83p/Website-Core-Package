                    </ul>
                    <div class="tab-content micro-tab-content border border-top-0 rounded-bottom p-3">
                        <div class="tab-pane fade show active" id="content-main-pane" role="tabpanel" aria-labelledby="content-main-tab" tabindex="0">
                            <div class="mb-3">
                                <label class="form-label fw-bold">Title / Group Name <span class="text-danger">*</span></label>
                                <input type="text" name="title" class="form-control"
                                       value="<%= assessment ? assessment.title : '' %>"
                                       placeholder="e.g. Coherence & Cohesion - Band 7" required>
                                <div class="form-text">Used to group related micro-questions in listing/report views.</div>
