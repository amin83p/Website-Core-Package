                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted text-uppercase">Possible Options (Derived)</label>
                                <div id="answerTypeOptionsPreview" class="border rounded bg-light p-2 small text-muted">
                                    No explicit options detected from answer type.
                                </div>
                                <div class="form-text small">
                                    Parsed from <code>answer_type</code>. For boolean, options default to <code>yes</code>/<code>no</code>.
                                </div>
                            </div>

                            <% const scoredSeed = assessment ? (assessment.scoredAnswers || assessment.scored_answers || '') : ''; %>
                            <% const notScoredSeed = assessment ? (assessment.notScoredAnswers || assessment.not_scored_answers || '') : ''; %>
                            <% const scoredText = toAnswerText(scoredSeed); %>
                            <% const notScoredText = toAnswerText(notScoredSeed); %>

                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted text-uppercase">Scoring Contract Presets</label>
                                <div class="row g-2">
                                    <div class="col-12 col-md-4">
                                        <button type="button" class="btn contract-preset-btn contract-feature w-100" id="btnSetFeatureContract">
                                            <i class="bi bi-check2-circle me-1"></i> Feature Check
                                            <small>yes is scored</small>
                                        </button>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <button type="button" class="btn contract-preset-btn contract-fault w-100" id="btnSetFaultContract">
                                            <i class="bi bi-shield-exclamation me-1"></i> Fault Check
                                            <small>no is scored</small>
                                        </button>
                                    </div>
                                    <div class="col-12 col-md-4">
                                        <button type="button" class="btn contract-preset-btn contract-derived w-100" id="btnSetDerivedContract">
                                            <i class="bi bi-magic me-1"></i> Derived
                                            <small>first option scored</small>
                                        </button>
                                    </div>
                                </div>
                                <div class="form-text small mt-2">
                                    These buttons quickly populate lists below. You can still edit tokens manually.
                                </div>
                            </div>

                            <div class="row g-3">
                                <div class="col-12 col-lg-6">
                                    <label class="form-label fw-bold small text-muted text-uppercase">Scored Answers</label>
                                    <div class="input-group mb-2">
                                        <input type="text" id="scoredAnswersTokenInput" class="form-control" placeholder="Type answer then Add (e.g. yes)">
                                        <button type="button" class="btn btn-outline-success" id="btnAddScoredAnswer"><i class="bi bi-plus-lg me-1"></i>Add</button>
                                    </div>
                                    <div id="scoredAnswersTokenList" class="answer-token-list"></div>
                                    <textarea name="scoredAnswers" id="scoredAnswersInput" class="d-none"><%= scoredText %></textarea>
                                    <div class="form-text small">Any answer in this list counts as a pass. Saved in lowercase.</div>
                                </div>
                                <div class="col-12 col-lg-6">
                                    <label class="form-label fw-bold small text-muted text-uppercase">Not Scored Answers</label>
                                    <div class="input-group mb-2">
                                        <input type="text" id="notScoredAnswersTokenInput" class="form-control" placeholder="Type answer then Add (e.g. no)">
                                        <button type="button" class="btn btn-outline-danger" id="btnAddNotScoredAnswer"><i class="bi bi-plus-lg me-1"></i>Add</button>
                                    </div>
                                    <div id="notScoredAnswersTokenList" class="answer-token-list"></div>
                                    <textarea name="notScoredAnswers" id="notScoredAnswersInput" class="d-none"><%= notScoredText %></textarea>
                                    <div class="form-text small">Any answer in this list counts as fail/weak. Saved in lowercase.</div>
                                </div>
                            </div>
