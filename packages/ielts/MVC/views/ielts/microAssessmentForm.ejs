<%
  const isEdit = !!(assessment && assessment.id);
  const selectedOrgId = isEdit ? String(assessment.orgId || assessment.org || assessment.organizationId || '').trim() : '';
  const orgChoices = Array.isArray(user?.allowedOrgs) ? user.allowedOrgs : [];
  const matchedOrg = isEdit ? orgChoices.find((org) => String(org?.orgId || '').trim() === selectedOrgId) : null;
  const selectedOrgName = String(
    matchedOrg?.name ||
    matchedOrg?.orgName ||
    ''
  ).trim();
  const toAnswerText = (seed) => {
    if (Array.isArray(seed)) return seed.join('\n');
    const raw = String(seed || '').trim();
    if (!raw) return '';
    if (raw.startsWith('[') && raw.endsWith(']')) {
      try {
        const parsed = JSON.parse(raw);
        if (Array.isArray(parsed)) return parsed.map((v) => String(v || '').trim()).filter(Boolean).join('\n');
      } catch (e) {}
    }
    return raw.split(/[\n,]+/).map((v) => String(v || '').trim()).filter(Boolean).join('\n');
  };
%>

<style>
  .micro-form-tabs .nav-link {
    font-weight: 600;
    color: #495057;
  }
  .micro-form-tabs .nav-link.active {
    color: #0b5ed7;
    background: #eef5ff;
    border-color: #cfe2ff #cfe2ff #fff;
  }
  .micro-tab-content {
    background: #fff;
  }
  .contract-preset-btn {
    text-align: left;
    border-width: 2px;
    font-weight: 600;
  }
  .contract-preset-btn small {
    display: block;
    font-weight: 500;
    opacity: 0.8;
    margin-top: 2px;
  }
  .contract-feature {
    border-color: #198754;
    color: #146c43;
    background: #f4fff8;
  }
  .contract-fault {
    border-color: #fd7e14;
    color: #a34b00;
    background: #fff7ee;
  }
  .contract-derived {
    border-color: #6c757d;
    color: #495057;
    background: #f8f9fa;
  }
  .answer-token-list {
    min-height: 44px;
    border: 1px dashed #c7ced6;
    border-radius: 8px;
    padding: 8px;
    background: #fbfcfe;
  }
  .answer-token-empty {
    color: #6c757d;
    font-size: 0.85rem;
  }
  .answer-token {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: #ffffff;
    border: 1px solid #ced4da;
    border-radius: 999px;
    padding: 4px 10px;
    margin: 3px;
    font-size: 0.82rem;
  }
  .answer-token button {
    border: 0;
    background: transparent;
    color: #dc3545;
    line-height: 1;
    padding: 0;
  }
</style>

<div class="sections-page">
  
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-heading size-md m-0">            
      <%= isEdit ? 'Edit Assessment Item' : 'Create New Assessment Item' %>
    </h1>
    <div class="d-flex flex-column align-items-end gap-1">
      <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
        <% if (isEdit) { %>
          <span class="badge bg-primary border">ID: <%= assessment.id %></span>
          <span class="badge bg-light text-dark border">
            Organization: <%= selectedOrgName || 'N/A' %><%= selectedOrgId ? ` (#${selectedOrgId})` : '' %>
          </span>
        <% } else { %>
          <span class="badge bg-success border">New Item</span>
        <% } %>
        <% if (typeof copySourceId !== 'undefined' && copySourceId) { %>
            <span class="badge bg-light text-dark border">Copied from: <%= copySourceId %></span>
        <% } %>
      </div>
      <button type="button" class="btn btn-outline-primary btn-sm" id="btnCopyFromAssessment">
        <i class="bi bi-copy me-1"></i> Copy From Assessment
      </button>
    </div>
  </div>

  <div class="form-container" style="width: 100%; max-width: 100%;">
    <form id="assessmentForm" action="<%= isEdit ? '/ielts/microAssessments/edit/' + assessment.id  : '/ielts/microAssessments/new' %>" method="POST">
      
      <input type="hidden" name="actionStateId" value="<%= typeof actionStateId !== 'undefined' ? actionStateId : '' %>">

      <div class="row">
        
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-light fw-bold text-primary">
                    <i class="bi bi-sliders me-2"></i>Configuration
                </div>
                <div class="card-body">
                    <ul class="nav nav-tabs micro-form-tabs" id="configTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="config-core-tab" data-bs-toggle="tab" data-bs-target="#config-core-pane" type="button" role="tab" aria-controls="config-core-pane" aria-selected="true">
                                Core
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="config-scoring-tab" data-bs-toggle="tab" data-bs-target="#config-scoring-pane" type="button" role="tab" aria-controls="config-scoring-pane" aria-selected="false">
                                Scoring Contract
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="config-routing-tab" data-bs-toggle="tab" data-bs-target="#config-routing-pane" type="button" role="tab" aria-controls="config-routing-pane" aria-selected="false">
                                Routing
                            </button>
                        </li>
                    </ul>
                    <div class="tab-content micro-tab-content border border-top-0 rounded-bottom p-3">
                        <div class="tab-pane fade show active" id="config-core-pane" role="tabpanel" aria-labelledby="config-core-tab" tabindex="0">
                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted text-uppercase">Question Key <span class="text-danger">*</span></label>
                                <input type="text" name="question_key" class="form-control"
                                       value="<%= assessment ? assessment.question_key : '' %>"
                                       placeholder="e.g. TR7-3" required>
                                <div class="form-text small">Unique key for this micro-question. Keep it stable once used in reports.</div>
                            </div>
                            <div class="row g-2 mb-3">
                                <div class="col-6">
                                    <label class="form-label fw-bold small text-muted text-uppercase">Band <span class="text-danger">*</span></label>
                                    <select name="band" class="form-select" required>
                                        <option value="" disabled <%= !assessment ? 'selected' : '' %>>Select...</option>
                                        <% for(let i=0; i<=9; i++) { %>
                                            <option value="<%= i %>" <%= (assessment && assessment.band == i) ? 'selected' : '' %>><%= i %></option>
                                        <% } %>
                                    </select>
                                    <div class="form-text small">Target IELTS band gate for this item.</div>
                                </div>
                                <div class="col-6">
                                    <label class="form-label fw-bold small text-muted text-uppercase">Criterion <span class="text-danger">*</span></label>
                                    <select name="criterion" class="form-select" required>
                                        <% ['TR','CC','LR','GRA'].forEach(c => { %>
                                            <option value="<%= c %>" <%= (assessment && assessment.criterion === c) ? 'selected' : '' %>><%= c %></option>
                                        <% }) %>
                                    </select>
                                    <div class="form-text small">Criterion this item contributes to.</div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted text-uppercase">Weight</label>
                                <input type="number" step="0.1" name="weight" class="form-control"
                                       value="<%= assessment ? assessment.weight : '1' %>">
                                <div class="form-text small">Relative contribution at the same band gate.</div>
                            </div>
                            <div class="pt-2 border-top mt-3">
                                <div class="form-check form-switch">
                                    <input class="form-check-input" type="checkbox" id="isActiveSwitch" name="is_active"
                                           <%= (!assessment || assessment.is_active !== false) ? 'checked' : '' %>>
                                    <label class="form-check-label fw-bold small" for="isActiveSwitch">Is Active?</label>
                                </div>
                                <div class="form-text small">Inactive items remain stored but are skipped in scoring runs.</div>
                            </div>
                        </div>

                        <div class="tab-pane fade" id="config-scoring-pane" role="tabpanel" aria-labelledby="config-scoring-tab" tabindex="0">
                            <div class="mb-3">
                                <label class="form-label fw-bold small text-muted text-uppercase">Answer Type</label>
                                <% const t = assessment ? assessment.answer_type : 'Boolean'; %>
                                <input list="answerTypeOptions" name="answer_type" class="form-control" value="<%= t %>" placeholder="e.g. Boolean, Count, Ordinal (none/some/...)">
                                <datalist id="answerTypeOptions">
                                    <option value="Boolean"></option>
                                    <option value="Count"></option>
                                    <option value="Ordinal (none/some/most)"></option>
                                    <option value="Categorical (absent/confusing/ok)"></option>
                                    <option value="Text"></option>
                                </datalist>
