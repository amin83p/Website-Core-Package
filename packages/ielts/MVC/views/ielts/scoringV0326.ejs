function getSelectedStep3ProviderId() {
  const selected = getSelectedProviderOption("step3ProviderSelect");
  return normalizeProviderToken(selected?.providerId || "");
}

function getSelectedStep3ApiProviderId() {
  const selected = getSelectedProviderOption("step3ProviderSelect");
  return String(selected?.apiProviderId || "").trim();
}

function normalizeStep3TuningModelId(modelId) {
  const value = String(modelId || "").trim();
  if (!value) return "";
  const providerSelectionId = getSelectedStep3ProviderSelectionId();
  const options = getTuningModelsForProvider(providerSelectionId);
  return options.some((m) => String(m?.id || "").trim() === value) ? value : "";
}

function normalizeStep3TuningProviderId(providerId) {
  const value = normalizeProviderChoiceId(providerId);
  if (!value) return "";
  const providers = getTuningProviderOptions();
  if (providers.some((row) => row.id === value)) return value;
  const legacyMatch = providers.find((row) => normalizeProviderToken(row?.providerId) === normalizeProviderToken(value));
  return legacyMatch?.id || "";
}

function onStep3ProviderChange(providerId, { preferredModelId = null, persistModel = true } = {}) {
  const normalizedProviderId = normalizeStep3TuningProviderId(providerId);
  const select = document.getElementById("step3ProviderSelect");
  if (select) select.value = normalizedProviderId;
  localStorage.setItem(STEP3_TUNING_PROVIDER_STORAGE_KEY, normalizedProviderId);

  const currentModel = preferredModelId !== null ? String(preferredModelId || "").trim() : getSelectedStep3ModelId();
  let normalizedModel = populateModelSelectForProvider("step3ModelSelect", normalizedProviderId, currentModel);
  if (!normalizedModel && currentModel) {
    normalizedModel = "";
  }

  if (persistModel) {
    localStorage.setItem(STEP3_TUNING_MODEL_STORAGE_KEY, normalizedModel);
  }
  renderProviderModelWarning("step3ProviderModelWarning", normalizedProviderId);
  return normalizedModel;
}

function onStep3ModelChange(modelId) {
  const normalized = normalizeStep3TuningModelId(modelId);
  const select = document.getElementById("step3ModelSelect");
  if (select) select.value = normalized;
  localStorage.setItem(STEP3_TUNING_MODEL_STORAGE_KEY, normalized);
}

function initializeStep3TuningModelSelector() {
  populateProviderSelect("step3ProviderSelect");
  const providers = getTuningProviderOptions();
  const savedProvider = localStorage.getItem(STEP3_TUNING_PROVIDER_STORAGE_KEY) || "";
  const fallbackProvider = providers.find((row) => row.isDefaultProvider)?.id || providers[0]?.id || "";
  const normalizedProvider = normalizeStep3TuningProviderId(savedProvider) || normalizeStep3TuningProviderId(fallbackProvider);
  const providerSelect = document.getElementById("step3ProviderSelect");
  if (providerSelect) providerSelect.value = normalizedProvider;
  localStorage.setItem(STEP3_TUNING_PROVIDER_STORAGE_KEY, normalizedProvider);

  const select = document.getElementById("step3ModelSelect");
  if (!select) return;
  const saved = localStorage.getItem(STEP3_TUNING_MODEL_STORAGE_KEY) || "";
  const fallbackModel = getProviderDefaultCandidate(normalizedProvider);
  const normalized = onStep3ProviderChange(normalizedProvider, {
    preferredModelId: saved || fallbackModel,
    persistModel: false
  });
  select.value = normalized;
  if (saved !== normalized) {
    localStorage.setItem(STEP3_TUNING_MODEL_STORAGE_KEY, normalized);
  }
}

