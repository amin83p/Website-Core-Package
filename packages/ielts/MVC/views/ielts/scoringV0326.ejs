function copyJson(elementId) {
  const text = document.getElementById(elementId)?.textContent || "";
  navigator.clipboard.writeText(text).then(() => safeShowMessage({
    title: "Copied",
    icon: "check",
    message: "JSON copied to clipboard!",
    buttons: [{ text: "OK", class: "btn-success" }]
  }));
}

function escapeHtml(s) {
  return String(s ?? "")
    .replace(/&/g, "&amp;").replace(/</g, "&lt;")
    .replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
}

function getParagraphDisplayId(paragraphIndex) {
  if (!Number.isInteger(paragraphIndex)) return "-";
  const paragraph = (GLOBALESSAYOBJECT?.paragraphs || []).find((p) => p.index === paragraphIndex);
  return paragraph?.displayParagraphId || `P${paragraphIndex + 1}`;
}

function getSentenceDisplayId(sentenceIndex) {
  if (!Number.isInteger(sentenceIndex)) return "-";
  const sentence = (GLOBALESSAYOBJECT?.sentences || []).find((s) => s.index === sentenceIndex);
  return sentence?.displaySentenceId || `S${sentenceIndex + 1}`;
}

function getSentenceByIndex(sentenceIndex) {
  if (!Number.isInteger(sentenceIndex)) return null;
  return (GLOBALESSAYOBJECT?.sentences || []).find((s) => s.index === sentenceIndex) || null;
}

function getSentenceIndexFromRefToken(refToken) {
  const raw = String(refToken ?? "").trim();
  if (!raw) return null;

  const upperRaw = raw.toUpperCase();
  const byDisplay = (GLOBALESSAYOBJECT?.sentences || []).find(
    (s) => String(s?.displaySentenceId || "").trim().toUpperCase() === upperRaw
  );
  if (byDisplay && Number.isInteger(byDisplay.index)) return byDisplay.index;

  const displayMatch = upperRaw.match(/^S(\d+)$/);
  if (displayMatch) {
    const oneBased = Number(displayMatch[1]);
    if (Number.isInteger(oneBased) && oneBased > 0) return oneBased - 1;
  }

  if (/^\d+$/.test(raw)) {
    const numeric = Number(raw);
    if (Number.isInteger(numeric) && numeric >= 0) return numeric;
  }
  return null;
}

function buildSentenceRefClickableHtml(sentenceIndex, labelOverride = null) {
  if (!Number.isInteger(sentenceIndex) || sentenceIndex < 0) {
    return `<span class="text-muted">-</span>`;
  }
  const sentence = getSentenceByIndex(sentenceIndex);
  const paragraphIndex = Number.isInteger(sentence?.paragraphIndex) ? sentence.paragraphIndex : null;
  const label = String(labelOverride || sentence?.displaySentenceId || `S${sentenceIndex + 1}`);
  if (!Number.isInteger(paragraphIndex)) {
    return `<span class="font-monospace">${escapeHtml(label)}</span>`;
  }
  return `<button type="button" class="btn btn-link p-0 align-baseline evidence-ref-link font-monospace" onclick="openCanonicalViewerByIndex(${paragraphIndex}, ${sentenceIndex})">${escapeHtml(label)}</button>`;
}

function buildSentenceRefListClickableHtml(indices, { emptyText = "-" } = {}) {
  const normalized = (Array.isArray(indices) ? indices : []).filter((n) => Number.isInteger(n) && n >= 0);
  if (!normalized.length) return `<span class="text-muted">${escapeHtml(emptyText)}</span>`;
  return normalized.map((n) => buildSentenceRefClickableHtml(n)).join(`<span class="text-muted">, </span>`);
}

function renderStep3SignalValueHtml(signalKey, rawValue) {
  const value = String(rawValue ?? "").trim();
  if (!value || value === "-" || value.toLowerCase() === "null") {
    return `<span class="text-muted">-</span>`;
  }

  const isScalarSentenceSignal = signalKey === "position.stanceSentenceIndex" || /^topic\.P\d+$/.test(signalKey);
  if (isScalarSentenceSignal) {
    const index = getSentenceIndexFromRefToken(value);
    if (Number.isInteger(index)) return buildSentenceRefClickableHtml(index, /^S\d+$/i.test(value) ? value : null);
    return `<span class="font-monospace">${escapeHtml(value)}</span>`;
  }

  if (isStep3ListSignalKey(signalKey)) {
    const parsed = parseIntListString(value);
    if (parsed.length) return buildSentenceRefListClickableHtml(parsed);
    return `<span class="text-muted">-</span>`;
  }

  if (/^\d+(?:\s*,\s*\d+)+$/.test(value)) {
    const parsed = parseIntListString(value);
    if (parsed.length) return buildSentenceRefListClickableHtml(parsed);
  }

  const displayRefs = value.match(/\bS\d+\b/gi);
  if (Array.isArray(displayRefs) && displayRefs.length) {
    const clickable = displayRefs.map((ref) => {
      const idx = getSentenceIndexFromRefToken(ref);
      return Number.isInteger(idx)
        ? buildSentenceRefClickableHtml(idx, ref.toUpperCase())
        : `<span class="font-monospace">${escapeHtml(ref.toUpperCase())}</span>`;
    });
    return clickable.join(`<span class="text-muted">, </span>`);
  }

  return `<span class="font-monospace">${escapeHtml(value)}</span>`;
}

function formatSentenceDisplayIds(indices) {
  const normalized = (Array.isArray(indices) ? indices : []).filter((n) => Number.isInteger(n));
  if (!normalized.length) return "-";
  return normalized.map((n) => getSentenceDisplayId(n)).join(", ");
}

function formatMs(ms) {
  if (ms == null || Number.isNaN(ms)) return "-";
  return `${(ms / 1000).toFixed(2)}s`;
}

function stepMs(stepKey) {
  const t = SESSION_BUNDLE?.steps?.[stepKey]?.timing;
  if (!t?.startedAt || !t?.endedAt) return null;
  return Math.max(0, t.endedAt - t.startedAt);
}

function totalMs() {
  const keys = ["step1freeze", "step2analyze", "step3extract", "step4grade", "step5feedback"];
  return keys.reduce((sum, k) => sum + (stepMs(k) ?? 0), 0);
}

function renderReport() {
  const c = document.getElementById("reportContainer");
  if (!c) return;

  if (!GLOBALESSAYOBJECT || !GLOBALGRADING || !GLOBALFEEDBACK) {
    c.innerHTML = `
      <div class="alert alert-warning">
        Report is not ready yet. Complete Steps 1-5 first.
      </div>
    `;
    return;
  }

  const sampleName = SESSION_BUNDLE?.metadata?.sampleName || "";
  const sampleId = SESSION_BUNDLE?.metadata?.sampleId || GLOBALSAMPLEID || "";
  const savedAt = SESSION_BUNDLE?.savedAt || "";

  const metaLine = document.getElementById("reportMetaLine");
  if (metaLine) {
    metaLine.textContent = `${sampleName ? sampleName + "  |  " : ""}${sampleId ? "ID: " + sampleId + "  |  " : ""}${savedAt ? "Saved: " + savedAt + "  |  " : ""}Total time: ${formatMs(totalMs())}`;
  }
  const examinerBand = parseBandScoreOrNull(
    SESSION_BUNDLE?.metadata?.examinerBandScore ??
      SESSION_BUNDLE?.steps?.step1freeze?.response?.json?.meta?.sampleBandScore ??
      GLOBALSAMPLEBANDSCORE
  );
  const systemBand = parseBandScoreOrNull(GLOBALGRADING?.overallBand);
  const examinerBandValue = examinerBand == null ? "-" : String(examinerBand);
  const reportDeltaValue =
    examinerBand == null || systemBand == null
      ? "-"
      : `${systemBand - examinerBand > 0 ? "+" : ""}${Number((systemBand - examinerBand).toFixed(1))}`;
  const reportDeltaClass =
    examinerBand == null || systemBand == null
      ? "text-muted"
      : (systemBand === examinerBand ? "text-success" : "text-warning");
  const examinerBandHtml = `
    <div class="row g-2 mt-2">
      <div class="col-6">
        <div class="p-2 bg-light rounded border text-center">
          <div class="small text-muted fw-bold">Examiner Ref</div>
          <div class="h6 m-0">${escapeHtml(examinerBandValue)}</div>
        </div>
      </div>
      <div class="col-6">
        <div class="p-2 bg-light rounded border text-center">
          <div class="small text-muted fw-bold">Delta</div>
          <div class="h6 m-0 fw-bold ${reportDeltaClass}">${escapeHtml(reportDeltaValue)}</div>
        </div>
      </div>
    </div>
  `;
  const freezePoints =
    SESSION_BUNDLE?.freezePoints && typeof SESSION_BUNDLE.freezePoints === "object"
      ? SESSION_BUNDLE.freezePoints
      : {};
  const freezePointKeys = Object.keys(freezePoints);
  const freezePointRows = freezePointKeys.length
    ? freezePointKeys.map((k) => `
        <tr>
          <td class="font-monospace">${escapeHtml(k)}</td>
          <td class="text-end small text-muted">${escapeHtml(freezePoints[k]?.at || "-")}</td>
        </tr>
      `).join("")
    : `<tr><td colspan="2" class="text-muted small">No freeze points recorded.</td></tr>`;
  const tweakLog = Array.isArray(SESSION_BUNDLE?.tweakLog) ? SESSION_BUNDLE.tweakLog : [];
  const tweakPreviewRows = tweakLog.slice(-5).reverse().map((item) => `
      <tr>
        <td class="font-monospace">${escapeHtml(item?.action || "unknown")}</td>
        <td class="text-end small text-muted">${escapeHtml(item?.at || "-")}</td>
      </tr>
    `).join("") || `<tr><td colspan="2" class="text-muted small">No tweaks logged.</td></tr>`;
  const step3Stability =
    GLOBALSTEP3STABILITY ||
    SESSION_BUNDLE?.steps?.step3extract?.response?.json?.meta?.stabilityGate ||
    SESSION_BUNDLE?.steps?.step3stability?.response?.json?.data ||
    null;
  const step4Stability = GLOBALGRADING?.meta?.stabilityGate || GLOBALSTABILITY || null;

  const step3UnstableRows = Array.isArray(step3Stability?.topUnstable) ? step3Stability.topUnstable : [];
  const step3UnstableTableRows = step3UnstableRows.length
    ? step3UnstableRows.slice(0, 10).map((row) => {
        const runValues = Array.isArray(row?.runValues)
          ? row.runValues.map((v, idx) => `<span class="badge bg-light text-dark border me-1">R${idx + 1}: ${escapeHtml(String(v))}</span>`).join("")
          : "-";
        const status = row?.tie
          ? `<span class="badge bg-danger-subtle text-danger border">Tie fallback</span>`
          : (row?.changed
            ? `<span class="badge bg-warning text-dark">Consensus changed</span>`
            : `<span class="badge bg-light text-dark border">Consensus matched</span>`);
        return `
          <tr>
            <td class="font-monospace">${escapeHtml(String(row?.key || "-"))}</td>
            <td>${runValues}</td>
            <td class="text-center fw-bold">${escapeHtml(String(row?.consensusValue || "-"))}</td>
            <td class="text-center">${status}</td>
          </tr>
        `;
      }).join("")
    : `<tr><td colspan="4" class="text-muted small text-center py-2">No unstable Step 3 signals detected across 3 runs.</td></tr>`;

  const step3StabilityCardHtml = step3Stability ? `
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-bold small">Step 3 Stability + Consensus (3x)</div>
      <div class="card-body">
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="badge ${step3Stability?.metrics?.gatePassed ? "bg-success" : "bg-warning text-dark"}">${step3Stability?.metrics?.gatePassed ? "PASS" : "REVIEW"}</span>
          <span class="small text-muted">Evidence extraction variation across 3 runs.</span>
        </div>
        <div class="small text-muted mb-2">
          Agreement: <span class="fw-bold">${escapeHtml(Number.isFinite(Number(step3Stability?.metrics?.meanAgreement)) ? `${(Number(step3Stability.metrics.meanAgreement) * 100).toFixed(1)}%` : "-")}</span>
          <span class="mx-2">|</span>
          Flip rate: <span class="fw-bold">${escapeHtml(Number.isFinite(Number(step3Stability?.metrics?.flipRate)) ? `${(Number(step3Stability.metrics.flipRate) * 100).toFixed(1)}%` : "-")}</span>
          <span class="mx-2">|</span>
          Unstable: <span class="fw-bold">${escapeHtml(String(step3Stability?.metrics?.unstableCount ?? "-"))}</span> / ${escapeHtml(String(step3Stability?.metrics?.totalSignals ?? "-"))}
          <span class="mx-2">|</span>
          Runs: <span class="fw-bold">${escapeHtml(String(step3Stability?.metrics?.runCount ?? "-"))}</span>
        </div>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Signal Key</th>
                <th>Run Values</th>
                <th class="text-center">Consensus</th>
                <th class="text-center">Status</th>
              </tr>
            </thead>
            <tbody>${step3UnstableTableRows}</tbody>
          </table>
        </div>
      </div>
    </div>
  ` : "";

  const step4StabilityCardHtml = step4Stability ? `
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-bold small">Stability Gate + Auto-Consensus</div>
      <div class="card-body">
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="badge ${step4Stability?.metrics?.gatePassed ? "bg-success" : "bg-warning text-dark"}">${step4Stability?.metrics?.gatePassed ? "PASS" : "REVIEW"}</span>
          <span class="small text-muted">3-run majority vote for unstable items.</span>
        </div>
        <div class="small text-muted">
          Agreement: <span class="fw-bold">${escapeHtml(Number.isFinite(Number(step4Stability?.metrics?.meanAgreement)) ? `${(Number(step4Stability.metrics.meanAgreement) * 100).toFixed(1)}%` : "-")}</span>
          <span class="mx-2">|</span>
          Flip rate: <span class="fw-bold">${escapeHtml(Number.isFinite(Number(step4Stability?.metrics?.flipRate)) ? `${(Number(step4Stability.metrics.flipRate) * 100).toFixed(1)}%` : "-")}</span>
          <span class="mx-2">|</span>
          Unstable: <span class="fw-bold">${escapeHtml(String(step4Stability?.metrics?.unstableCount ?? "-"))}</span> / ${escapeHtml(String(step4Stability?.metrics?.totalItems ?? "-"))}
        </div>
      </div>
    </div>
  ` : "";

  // Timings table
  const timingRows = [
    ["Step 1 (Freeze)", "step1freeze"],
    ["Step 2 (Analysis)", "step2analyze"],
    ["Step 3 (Extraction)", "step3extract"],
    ["Step 4 (Grading)", "step4grade"],
    ["Step 5 (Feedback)", "step5feedback"]
  ].map(([label, key]) => `
    <tr>
      <td>${escapeHtml(label)}</td>
      <td class="text-end font-monospace">${escapeHtml(formatMs(stepMs(key)))}</td>
    </tr>
  `).join("");

  const selectedModels =
    (SESSION_BUNDLE?.uiState?.selectedModels && typeof SESSION_BUNDLE.uiState.selectedModels === "object")
      ? SESSION_BUNDLE.uiState.selectedModels
      : ((SESSION_BUNDLE?.researchConfig?.selectedModels && typeof SESSION_BUNDLE.researchConfig.selectedModels === "object")
        ? SESSION_BUNDLE.researchConfig.selectedModels
        : {});

  const modelRows = [
    {
      step: "Step 3 (Extraction)",
      selected: String(selectedModels?.step3 || "").trim(),
      used: String(SESSION_BUNDLE?.steps?.step3extract?.response?.json?.meta?.modelUsed || "").trim()
    },
    {
      step: "Step 4 (Grading)",
      selected: String(selectedModels?.step4 || "").trim(),
      used: String(
        GLOBALGRADING?.meta?.modelUsed ||
        SESSION_BUNDLE?.steps?.step4grade?.response?.json?.data?.meta?.modelUsed ||
        ""
      ).trim()
    },
    {
      step: "Step 5 (Feedback)",
      selected: String(selectedModels?.step5 || "").trim(),
      used: String(
        GLOBALFEEDBACK?.meta?.modelUsed ||
        SESSION_BUNDLE?.steps?.step5feedback?.response?.json?.data?.meta?.modelUsed ||
        ""
      ).trim()
    }
  ];

  const modelUsageRows = modelRows.map((row) => {
    const selected = row.selected || "-";
    const used = row.used || "-";
    return `
      <tr>
        <td>${escapeHtml(row.step)}</td>
        <td class="font-monospace">${escapeHtml(selected)}</td>
        <td class="font-monospace">${escapeHtml(used)}</td>
      </tr>
    `;
  }).join("");

  const modelUsageCardHtml = `
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-bold small">AI Models Used (Step 3 to Step 5)</div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead class="table-light">
            <tr>
              <th>Step</th>
              <th>Selected Model</th>
              <th>Used Model</th>
            </tr>
          </thead>
          <tbody>
            ${modelUsageRows}
          </tbody>
        </table>
      </div>
    </div>
  `;

  const normalizeTokenUsage = (usage, fallbackCallCount = 1) => {
    if (!usage || typeof usage !== "object") return null;
    const promptTokenCount = Number(usage.promptTokenCount);
    const candidatesTokenCount = Number(usage.candidatesTokenCount);
    const totalTokenCount = Number(usage.totalTokenCount);
    const callCountRaw = Number(usage.callCount);
    const callCount = Number.isFinite(callCountRaw) && callCountRaw > 0
      ? Math.floor(callCountRaw)
      : Math.max(1, Number(fallbackCallCount) || 1);
    const hasTokenData =
      Number.isFinite(promptTokenCount) ||
      Number.isFinite(candidatesTokenCount) ||
      Number.isFinite(totalTokenCount);
    if (!hasTokenData) return null;
    return {
      callCount,
      promptTokenCount: Number.isFinite(promptTokenCount) ? promptTokenCount : 0,
      candidatesTokenCount: Number.isFinite(candidatesTokenCount) ? candidatesTokenCount : 0,
      totalTokenCount: Number.isFinite(totalTokenCount) ? totalTokenCount : 0
    };
  };

  const formatTokenCount = (value) => {
    const n = Number(value);
    if (!Number.isFinite(n)) return "0";
    return n.toLocaleString();
  };

  const step3TokenUsage = normalizeTokenUsage(
    SESSION_BUNDLE?.steps?.step3extract?.response?.json?.meta?.usage || null,
    1
  );
  const step4TokenUsage = normalizeTokenUsage(
    GLOBALGRADING?.meta?.aiUsageSummary ||
      SESSION_BUNDLE?.steps?.step4grade?.response?.json?.data?.meta?.aiUsageSummary ||
      null,
    1
  );
  const step5TokenUsage = normalizeTokenUsage(
    GLOBALFEEDBACK?.meta?.aiUsage ||
      SESSION_BUNDLE?.steps?.step5feedback?.response?.json?.data?.meta?.aiUsage ||
      null,
    1
  );

  const tokenUsageRows = [
    { label: "Step 3 (Extraction)", usage: step3TokenUsage },
    { label: "Step 4 (Grading)", usage: step4TokenUsage },
    { label: "Step 5 (Feedback)", usage: step5TokenUsage }
  ].filter((row) => row.usage);

  const tokenUsageTotals = tokenUsageRows.reduce(
    (acc, row) => {
      acc.callCount += Number(row?.usage?.callCount || 0);
      acc.promptTokenCount += Number(row?.usage?.promptTokenCount || 0);
      acc.candidatesTokenCount += Number(row?.usage?.candidatesTokenCount || 0);
      acc.totalTokenCount += Number(row?.usage?.totalTokenCount || 0);
      return acc;
    },
    { callCount: 0, promptTokenCount: 0, candidatesTokenCount: 0, totalTokenCount: 0 }
  );

  const tokenUsageTableRows = tokenUsageRows.length
    ? tokenUsageRows.map((row) => `
      <tr>
        <td>${escapeHtml(row.label)}</td>
        <td class="text-end font-monospace">${escapeHtml(formatTokenCount(row.usage.callCount))}</td>
        <td class="text-end font-monospace">${escapeHtml(formatTokenCount(row.usage.promptTokenCount))}</td>
        <td class="text-end font-monospace">${escapeHtml(formatTokenCount(row.usage.candidatesTokenCount))}</td>
        <td class="text-end font-monospace">${escapeHtml(formatTokenCount(row.usage.totalTokenCount))}</td>
      </tr>
    `).join("")
    : `<tr><td colspan="5" class="text-muted small">No token usage was captured for this session.</td></tr>`;

  const tokenUsageCardHtml = `
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-bold small">AI Token Usage</div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead class="table-light">
            <tr>
              <th>Step</th>
              <th class="text-end">Calls</th>
              <th class="text-end">Prompt Tokens</th>
              <th class="text-end">Output Tokens</th>
              <th class="text-end">Total Tokens</th>
            </tr>
          </thead>
          <tbody>
            ${tokenUsageTableRows}
            <tr class="table-light">
              <td class="fw-bold">Total</td>
              <td class="text-end fw-bold font-monospace">${escapeHtml(formatTokenCount(tokenUsageTotals.callCount))}</td>
              <td class="text-end fw-bold font-monospace">${escapeHtml(formatTokenCount(tokenUsageTotals.promptTokenCount))}</td>
              <td class="text-end fw-bold font-monospace">${escapeHtml(formatTokenCount(tokenUsageTotals.candidatesTokenCount))}</td>
              <td class="text-end fw-bold font-monospace">${escapeHtml(formatTokenCount(tokenUsageTotals.totalTokenCount))}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  `;

  const reportTelemetry = GLOBALGRADING?.meta?.telemetry && typeof GLOBALGRADING.meta.telemetry === "object"
    ? GLOBALGRADING.meta.telemetry
    : null;
  const reportLowBandCoverage = GLOBALGRADING?.meta?.lowBandCoverage && typeof GLOBALGRADING.meta.lowBandCoverage === "object"
    ? GLOBALGRADING.meta.lowBandCoverage
    : null;
  const reportGateTrace = GLOBALGRADING?.meta?.gateTrace && typeof GLOBALGRADING.meta.gateTrace === "object"
    ? GLOBALGRADING.meta.gateTrace
    : (GLOBALGRADING?.meta?.scoreTrace && typeof GLOBALGRADING.meta.scoreTrace === "object"
      ? GLOBALGRADING.meta.scoreTrace
      : null);

  const telemetryCardHtml = reportTelemetry ? `
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-bold small">Step 4 Source Telemetry</div>
      <div class="card-body">
        <div class="row g-2 small">
          <div class="col-md-3"><span class="text-muted">Deterministic</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.sourceCounts?.deterministic || 0))}</div></div>
          <div class="col-md-3"><span class="text-muted">AI</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.sourceCounts?.ai || 0))}</div></div>
          <div class="col-md-3"><span class="text-muted">Aggregate</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.sourceCounts?.aggregate || 0))}</div></div>
          <div class="col-md-3"><span class="text-muted">Paragraph Rows</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.paragraph?.totalRows || 0))}</div></div>
        </div>
        <hr class="my-2">
        <div class="row g-2 small">
          <div class="col-md-3"><span class="text-muted">Low-band Rows</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.lowBand?.totalRows || 0))}</div></div>
          <div class="col-md-3"><span class="text-muted">No-rule Fallback</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.lowBand?.aiFallbackNoRule || 0))}</div></div>
          <div class="col-md-3"><span class="text-muted">Null-rule Fallback</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.lowBand?.aiFallbackRuleReturnedNull || 0))}</div></div>
          <div class="col-md-3"><span class="text-muted">Rule Error Fallback</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.lowBand?.aiFallbackRuleError || 0))}</div></div>
        </div>
        <hr class="my-2">
        <div class="row g-2 small">
          <div class="col-md-3"><span class="text-muted">AI Error Rows</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.aiReliability?.aiErrorRows || 0))}</div></div>
          <div class="col-md-3"><span class="text-muted">Retry Attempts</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.aiReliability?.retryAttempts || 0))}</div></div>
          <div class="col-md-3"><span class="text-muted">Fallback Used</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.aiReliability?.fallbackUsedRows || 0))}</div></div>
          <div class="col-md-3"><span class="text-muted">Rescued (Fallback)</span><div class="fw-bold">${escapeHtml(Number(reportTelemetry?.aiReliability?.rescuedByFallbackRows || 0))}</div></div>
        </div>
      </div>
    </div>
  ` : "";

  const gateTraceReportRows = reportGateTrace
    ? ["TR", "CC", "LR", "GRA"].map((criterion) => {
      const item = reportGateTrace?.[criterion] || {};
      const available = Array.isArray(item?.availableBandGates) ? item.availableBandGates.join(", ") : "-";
      const fallback = item?.fallbackApplied?.type
        ? `${item.fallbackApplied.type} => ${item.fallbackApplied.resultingBand}`
        : "none";
      return `
        <tr>
          <td class="fw-bold">${escapeHtml(criterion)}</td>
          <td class="font-monospace">${escapeHtml(available || "-")}</td>
          <td class="font-monospace">${escapeHtml(item?.resultingCriterionScore ?? "-")}</td>
          <td class="font-monospace">${escapeHtml(fallback)}</td>
        </tr>
      `;
    }).join("")
    : "";

  const gateTraceReportCardHtml = gateTraceReportRows ? `
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-bold small">Criterion Gate Trace (Summary)</div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead class="table-light">
            <tr>
              <th>Criterion</th>
              <th>Available Gates</th>
              <th>Result Score</th>
              <th>Fallback</th>
            </tr>
          </thead>
          <tbody>${gateTraceReportRows}</tbody>
        </table>
      </div>
    </div>
  ` : "";

  const recurringFailurePatterns = (() => {
    const weakRows = (Array.isArray(GLOBALGRADING?.aggregatedResults) ? GLOBALGRADING.aggregatedResults : [])
      .filter((row) => !isSupportiveMicroAnswer(row))
      .map((row) => `${String(row?.criterion || "General").toUpperCase()}:${String(row?.baseKey || row?.question_key || row?.instanceKey || "").trim()}`)
      .filter(Boolean);
    const counter = new Map();
    weakRows.forEach((key) => counter.set(key, (counter.get(key) || 0) + 1));
    return Array.from(counter.entries())
      .map(([pattern, count]) => ({ pattern, count }))
      .sort((a, b) => b.count - a.count || a.pattern.localeCompare(b.pattern))
      .slice(0, 6);
  })();
  const recurringFailureText = recurringFailurePatterns.length
    ? recurringFailurePatterns.map((item) => `${item.pattern} (${item.count})`).join("; ")
    : "none";

  const tweakLogSummaryBlock = `
Evaluation Date/Time: ${escapeHtml(new Date().toISOString())}
Scoring Version: ${escapeHtml(String(SESSION_BUNDLE?.metadata?.scoringView || "scoringV0326"))}
Prompt Sources: ${escapeHtml([
  `step3:${String(SESSION_BUNDLE?.uiState?.step3PromptSource || "-")}`,
  `step4:${String(SESSION_BUNDLE?.uiState?.step4PromptSource || "-")}`,
  `step5:${String(SESSION_BUNDLE?.uiState?.step5PromptSource || "-")}`
].join(", "))}
Essays Evaluated: 1
Agreement Metrics: exact=${escapeHtml(systemBand != null && examinerBand != null && systemBand === examinerBand ? "1.0000" : (systemBand != null && examinerBand != null ? "0.0000" : "n/a"))}, within0.5=${escapeHtml(systemBand != null && examinerBand != null && Math.abs(systemBand - examinerBand) <= 0.5 ? "1.0000" : (systemBand != null && examinerBand != null ? "0.0000" : "n/a"))}, within1.0=${escapeHtml(systemBand != null && examinerBand != null && Math.abs(systemBand - examinerBand) <= 1.0 ? "1.0000" : (systemBand != null && examinerBand != null ? "0.0000" : "n/a"))}
Stability Metrics: meanAgreement=${escapeHtml(Number.isFinite(Number(step4Stability?.metrics?.meanAgreement)) ? Number(step4Stability.metrics.meanAgreement).toFixed(4) : "n/a")}, flipRate=${escapeHtml(Number.isFinite(Number(step4Stability?.metrics?.flipRate)) ? Number(step4Stability.metrics.flipRate).toFixed(4) : "n/a")}
Low-band Source Mix: deterministic=${escapeHtml(Number(reportTelemetry?.sourceCounts?.deterministic || 0))}, ai=${escapeHtml(Number(reportTelemetry?.sourceCounts?.ai || 0))}, aggregate=${escapeHtml(Number(reportTelemetry?.sourceCounts?.aggregate || 0))}
Top Recurring Failure Patterns: ${escapeHtml(recurringFailureText)}
`;

  const lowBandCoverageCardHtml = reportLowBandCoverage ? `
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-bold small">Low-band Weakness Coverage</div>
      <div class="card-body">
        <div class="small mb-2">Triggered items: <span class="fw-bold">${escapeHtml(Array.isArray(reportLowBandCoverage?.triggeredItems) ? reportLowBandCoverage.triggeredItems.length : 0)}</span></div>
        <div class="small mb-2">AI-only low-band items: <span class="fw-bold">${escapeHtml(Array.isArray(reportLowBandCoverage?.aiOnlyItems) ? reportLowBandCoverage.aiOnlyItems.length : 0)}</span></div>
        <div class="small mb-2">Criteria with no low-band evidence: <span class="fw-bold">${escapeHtml((Array.isArray(reportLowBandCoverage?.criteriaWithoutLowBandEvidence) ? reportLowBandCoverage.criteriaWithoutLowBandEvidence.join(", ") : "") || "None")}</span></div>
        <div class="small">Paragraph contributors: <span class="fw-bold">${escapeHtml(Array.isArray(reportLowBandCoverage?.paragraphContributions) ? reportLowBandCoverage.paragraphContributions.length : 0)}</span></div>
      </div>
    </div>
  ` : "";

  // Evidence snapshot
  const stance = GLOBALEXTRACTION?.position?.stance ?? "-";
  const stanceIdx = getSentenceDisplayId(GLOBALEXTRACTION?.position?.stanceSentenceIndex);

  const evidenceRows = (GLOBALEXTRACTION?.bodySupport || []).map(p => {
    const paragraphIndex = Number.isInteger(p.paragraphIndex) ? p.paragraphIndex : null;
    const topic = (GLOBALEXTRACTION?.topicSentenceByParagraph || []).find(t => t.paragraphIndex === paragraphIndex)?.topicSentenceIndex;
    const paragraphRef = getParagraphDisplayId(paragraphIndex);
    const topicRefHtml = Number.isInteger(topic)
      ? buildSentenceRefClickableHtml(topic)
      : `<span class="text-muted">-</span>`;
    const evidenceHtml = buildSentenceRefListClickableHtml(p.evidenceSentenceIndices);
    const flags = [
      p.hasExplanation ? "Exp" : null,
      p.hasExample ? "Ex" : null
    ].filter(Boolean).join(", ") || "-";

    return `
      <tr>
        <td class="text-center fw-bold">${escapeHtml(paragraphRef)}</td>
        <td class="text-center font-monospace">${topicRefHtml}</td>
        <td class="text-center font-monospace">${evidenceHtml}</td>
        <td>${escapeHtml(flags)}</td>
      </tr>
    `;
  }).join("");

  const criterionOrder = ["TR", "CC", "LR", "GRA", "General"];
  const normalizeFeedbackCriterion = (value) => {
    const v = String(value || "").trim().toUpperCase();
    return criterionOrder.includes(v) ? v : "General";
  };
  const normalizeFeedbackEvidenceRefs = (value) => {
    let refs = [];
    if (Array.isArray(value)) refs = value;
    else if (typeof value === "string") refs = value.split(/[,\s;]+/g);
    const joined = Array.isArray(value) ? value.join(" ") : String(value || "");
    const matches = joined.toUpperCase().match(/S\d+/g);
    if (matches) refs = refs.concat(matches);

    const out = [];
    const seen = new Set();
    for (const item of refs) {
      const ref = String(item || "").trim().toUpperCase();
      if (!/^S\d+$/.test(ref)) continue;
      if (seen.has(ref)) continue;
      seen.add(ref);
      out.push(ref);
    }
    return out.slice(0, 8);
  };
  const renderFeedbackRefBadges = (refs) => {
    const list = normalizeFeedbackEvidenceRefs(refs);
    if (!list.length) return `<span class="text-muted small">No direct evidence refs.</span>`;
    return list.map((ref) => `<span class="badge bg-light text-dark border font-monospace me-1">${escapeHtml(ref)}</span>`).join("");
  };

  // By-criterion summary
  const byCriterionCards = (Array.isArray(GLOBALFEEDBACK?.byCriterion) ? GLOBALFEEDBACK.byCriterion : [])
    .map((item) => ({
      criterion: normalizeFeedbackCriterion(item?.criterion),
      summary: String(item?.summary || item?.issue || "").trim(),
      evidenceRefs: normalizeFeedbackEvidenceRefs(item?.evidenceRefs || item?.evidence),
      fix: String(item?.fix || "").trim()
