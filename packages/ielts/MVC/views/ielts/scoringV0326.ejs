  `).join("");

  const strengthsHtml = (Array.isArray(fb?.strengths) ? fb.strengths : []).map((s) => `
    <li class="list-group-item small">
      <i class="bi bi-check-circle-fill text-success me-2"></i> ${escapeHtml(s)}
    </li>
  `).join("") || `<li class="list-group-item text-muted small">No specific strengths listed.</li>`;

  const modelBadge = fb?.meta?.modelUsed
    ? `<span class="badge bg-light text-dark border"><i class="bi bi-cpu me-1"></i>${escapeHtml(fb.meta.modelUsed)}</span>`
    : "";
  const schemaBadge = `<span class="badge bg-light text-dark border"><i class="bi bi-diagram-3 me-1"></i>${escapeHtml(fb?.meta?.schemaVersion || "step5-feedback.v0225")}</span>`;

  const html = `
