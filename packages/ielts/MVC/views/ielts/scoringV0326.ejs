async function postJsonAndRecord(stepKey, url, payload, requestOptions = {}) {
    const stepMeta = TIMED_STEPS.find(s => s.key === stepKey);
    startRunningTimer(stepKey, stepMeta?.label || stepKey);
  
    const startedAt = Date.now();
  try {
        const signal = requestOptions?.signal;

        const res = await fetch(url, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "Accept": "application/json",
              "X-AJAX-Request": "true"
            },
            body: JSON.stringify(payload),
            signal
        });

        const contentType = res.headers.get("content-type") || "";
        let json = null;
        let text = null;

        try {
            text = await res.text();
            if (contentType.includes("application/json")) {
              json = text ? JSON.parse(text) : null;
            } else if (text) {
              try {
                json = JSON.parse(text);
              } catch (_) {
                json = null;
              }
            }
        } catch (e) {
            text = `<<failed to parse response>> ${String(e?.message || e)}`;
        }

        SESSION_BUNDLE.steps[stepKey] = {
            request: { url, payload },
            response: { contentType, json, text },
            timing: { startedAt, endedAt: Date.now() }
        };
        SESSION_BUNDLE.dirty = true;
        if (stepKey !== "step6report" && SESSION_BUNDLE.steps?.step6report) {
          delete SESSION_BUNDLE.steps.step6report;
        }
        updateStepLocks();
        
        if (!json) {
          const snippet = String(text || "").replace(/\s+/g, " ").trim().slice(0, 220);
          throw new Error(`Non-JSON response for ${stepKey} (content-type: ${contentType || "unknown"}). ${snippet}`);
        }
        return json;
    } finally {
    stopRunningTimer();
    refreshTimingUI();
    updateStepLocks();
  }
}

