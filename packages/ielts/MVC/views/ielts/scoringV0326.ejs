async function runExtractionStabilityConsensus() {
  if (blockIfStepLocked("step3extract")) return;
  if (!GLOBALESSAYOBJECT) {
    return safeShowMessage({
      title: "Step 1 Missing",
      icon: "warning",
      message: "Complete Step 1 first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }
  if (!GLOBALPARAGRAPHROLES) {
    return safeShowMessage({
      title: "Step 2 Missing",
      icon: "warning",
      message: "Run Step 2 Analysis first to determine paragraph roles.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }
  const proceed = await confirmStep3RerunResetIfNeeded();
  if (!proceed) return;

  reviewModalInstance?.hide();
  const runCount = enforceStep3ConsensusRunCount();
  const btnReview = document.getElementById("btnPrepareExtract");
  const btnConsensus = document.getElementById("btnExtractConsensus");
  const customPrompt = getStep3CustomPromptForExecution();
  if (customPrompt === STEP3_MISSING) {
    return safeShowMessage({
      title: "Template Required",
      icon: "warning",
      message: "Pick a Step 3 prompt template first, or switch to built-in prompt.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }
  const payload = buildStep3Payload(customPrompt, { disableCache: true });
  const controller = beginAbortableStep("step3extract");
  if (!controller) return;
  const cancelToken = getActiveStepCancelToken("step3extract");
  payload.cancelToken = cancelToken;
  payload.options = payload.options && typeof payload.options === "object" ? payload.options : {};
  payload.options.cancelToken = cancelToken;
  payload.options.mode = "stability_gate_auto_consensus";
  payload.options.runCount = runCount;
  payload.options.parallel = true;

  const startedAt = Date.now();
  startRunningTimer("step3extract", "Step 3 Stability Gate");
  if (btnReview) btnReview.disabled = true;
  if (btnConsensus) {
    btnConsensus.disabled = true;
    btnConsensus.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Running ${runCount}x (parallel)...`;
  }

  try {
    if (controller.signal.aborted) {
      throw createAbortError("Step 3 stability run was stopped.");
    }
    const stabilityResponse = await postJsonNoRecord(
      "/ielts/scoring/step3/extract",
      payload,
      { signal: controller.signal }
    );
    const runs = Array.isArray(stabilityResponse?.meta?.stabilityRuns) && stabilityResponse.meta.stabilityRuns.length
      ? stabilityResponse.meta.stabilityRuns
      : [stabilityResponse];

    const extractionRuns = runs.map((r) => r.data).filter(Boolean);
    if (extractionRuns.length < runCount) {
      throw new Error("Could not complete all Step 3 stability runs.");
    }

    const consensus = computeStep3Consensus(extractionRuns);
    const consensusExtraction = extractionFromConsensusMap(consensus.consensusMap, extractionRuns[0]);

    const generatedKeys = Array.from(new Set(
      runs.flatMap((r) => (Array.isArray(r?.meta?.generatedKeys) ? r.meta.generatedKeys : []))
    ));
    const modelList = Array.from(new Set(
      runs.map((r) => String(r?.meta?.modelUsed || "").trim()).filter(Boolean)
    ));
    const promptHashes = Array.from(new Set(
      runs.map((r) => String(r?.meta?.promptHash || "").trim()).filter(Boolean)
    ));
    const schemaVersion = runs.find((r) => r?.meta?.schemaVersion)?.meta?.schemaVersion || "unknown";

    const stabilityMeta = {
      enabled: true,
      autoConsensus: true,
      runCount,
      generatedAt: new Date().toISOString(),
      thresholds: {
        minMeanAgreement: STEP3_STABILITY_CONFIG.minMeanAgreement,
        maxFlipRate: STEP3_STABILITY_CONFIG.maxFlipRate,
        maxUnstableShare: STEP3_STABILITY_CONFIG.maxUnstableShare
      },
      metrics: {
        ...consensus.metrics,
        meanAgreement: Number.isFinite(Number(consensus.metrics.meanAgreement))
          ? Number(Number(consensus.metrics.meanAgreement).toFixed(4))
          : null,
        flipRate: Number.isFinite(Number(consensus.metrics.flipRate))
          ? Number(Number(consensus.metrics.flipRate).toFixed(4))
          : null,
        unstableShare: Number.isFinite(Number(consensus.metrics.unstableShare))
          ? Number(Number(consensus.metrics.unstableShare).toFixed(4))
          : null
      },
      topUnstable: consensus.unstableRows,
      allSignals: consensus.allRows,
      promptHashes
    };

    const mergedMeta = {
      generatedKeys,
      executedPrompt:
        String(runs.find((r) => String(r?.meta?.executedPrompt || "").trim())?.meta?.executedPrompt || "").trim() ||
        String(customPrompt || "").trim() ||
        "",
      promptHash: promptHashes[0] || "",
      schemaVersion,
      fromCache: runs.every((r) => Boolean(r?.meta?.fromCache)),
      modelUsed: modelList.length <= 1
        ? `${modelList[0] || "unknown"} + consensus`
        : `multi-model + consensus`,
      stabilityGate: stabilityMeta
    };

    GLOBALEXTRACTION = consensusExtraction;
    GLOBALSTEP3STABILITY = stabilityMeta;

    const endedAt = Date.now();
    SESSION_BUNDLE.steps.step3extract = {
      request: {
        url: "/ielts/scoring/step3/extract",
        payload,
        mode: "stability_gate_auto_consensus",
        runCount
      },
      response: {
        contentType: "application/json",
        json: {
          status: "success",
          data: consensusExtraction,
          meta: mergedMeta
        }
      },
      timing: { startedAt, endedAt }
    };
    SESSION_BUNDLE.steps.step3stability = {
      request: {
        mode: "stability_gate_auto_consensus",
        runCount
      },
      response: {
        contentType: "application/json",
        json: {
          status: "success",
          data: stabilityMeta
        }
      },
      timing: { startedAt, endedAt }
    };
    if (SESSION_BUNDLE.steps?.step6report) {
      delete SESSION_BUNDLE.steps.step6report;
    }
    syncStepExecutionRequestMeta("step3extract", {
      fallbackMode: "stability_gate_auto_consensus",
      fallbackRunCount: runCount,
      stabilityMeta,
      stabilityStepKey: "step3stability"
    });
    SESSION_BUNDLE.dirty = true;

    renderExtractionResults(consensusExtraction, generatedKeys, mergedMeta);
    setFreezePoint("step3_extraction_frozen", {
      promptHash: mergedMeta.promptHash,
      schemaVersion: mergedMeta.schemaVersion,
      fromCache: Boolean(mergedMeta.fromCache),
      modelUsed: mergedMeta.modelUsed,
      stabilityGate: true
    });
    setFreezePoint("step3_stability_gate_frozen", {
      gatePassed: Boolean(stabilityMeta?.metrics?.gatePassed),
      meanAgreement: stabilityMeta?.metrics?.meanAgreement ?? null,
      flipRate: stabilityMeta?.metrics?.flipRate ?? null,
      unstableCount: stabilityMeta?.metrics?.unstableCount ?? null,
      unstableShare: stabilityMeta?.metrics?.unstableShare ?? null
    });
    addTweakLog("step3_stability_gate_completed", {
      runCount,
      gatePassed: Boolean(stabilityMeta?.metrics?.gatePassed),
      meanAgreement: stabilityMeta?.metrics?.meanAgreement ?? null,
      flipRate: stabilityMeta?.metrics?.flipRate ?? null,
      unstableCount: stabilityMeta?.metrics?.unstableCount ?? null
    });
    syncStep3ResearchFingerprint({ preferCurrentInputs: false });

    document.getElementById("step3Placeholder")?.classList.add("d-none");
    document.getElementById("step3Result")?.classList.remove("d-none");

    const pass = Boolean(stabilityMeta?.metrics?.gatePassed);
    const meanAgreement = Number.isFinite(Number(stabilityMeta?.metrics?.meanAgreement))
      ? `${(Number(stabilityMeta.metrics.meanAgreement) * 100).toFixed(1)}%`
      : "-";
    const flipRate = Number.isFinite(Number(stabilityMeta?.metrics?.flipRate))
      ? `${(Number(stabilityMeta.metrics.flipRate) * 100).toFixed(1)}%`
      : "-";
    await safeShowMessage({
      title: pass ? "Step 3 Stability Passed" : "Step 3 Stability Needs Review",
      icon: pass ? "check" : "warning",
      message: `Consensus extraction applied from ${runCount} runs.\nMean agreement: ${meanAgreement}\nFlip rate: ${flipRate}`,
      buttons: [{ text: "OK", class: pass ? "btn-success" : "btn-warning" }]
    });
  } catch (e) {
    if (isAbortError(e)) {
      await safeShowMessage({
        title: "Step 3 Stopped",
        icon: "warning",
        message: "Step 3 stability run was stopped before completion.",
        buttons: [{ text: "OK", class: "btn-warning" }]
      });
    } else {
      console.error(e);
      safeShowMessage({
        title: "Step 3 Stability Error",
        icon: "error",
        message: e.message || "Failed to run Step 3 stability consensus.",
        buttons: [{ text: "OK", class: "btn-danger" }]
      });
    }
  } finally {
    finishAbortableStep("step3extract", controller);
    stopRunningTimer();
    refreshTimingUI();
    if (btnReview) btnReview.disabled = false;
    if (btnConsensus) {
      btnConsensus.disabled = false;
      updateStep3ConsensusButtonLabel();
    }
    updateStepLocks();
  }
}

