  // Strengths (compatibility)
  const strengths = (Array.isArray(GLOBALFEEDBACK?.strengths) ? GLOBALFEEDBACK.strengths : [])
    .map((s) => `<li class="list-group-item small">${escapeHtml(s)}</li>`)
    .join("") || `<li class="list-group-item small text-muted">No strengths listed.</li>`;

  // Report HTML
  c.innerHTML = `
