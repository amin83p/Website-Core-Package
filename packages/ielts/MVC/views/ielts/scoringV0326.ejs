function renderStep1CanonicalOutput(data) {
  const stats = data?.stats || {};
  const paragraphs = Array.isArray(data?.paragraphs) ? data.paragraphs : [];
  const sentences = Array.isArray(data?.sentences) ? data.sentences : [];

  const setText = (id, value) => {
    const el = document.getElementById(id);
    if (el) el.textContent = value;
  };

  setText("s1CanonicalWords", stats.wordCount ?? "-");
  setText("s1CanonicalSentences", stats.sentenceCount ?? "-");
  setText("s1CanonicalParagraphs", stats.paragraphCount ?? "-");
  setText("s1CanonicalChars", stats.charCount ?? "-");

  const paragraphSentenceCount = new Map();
  sentences.forEach((s) => {
    const p = Number.isInteger(s?.paragraphIndex) ? s.paragraphIndex : null;
    if (p == null) return;
    paragraphSentenceCount.set(p, (paragraphSentenceCount.get(p) || 0) + 1);
  });

  const paragraphRows = paragraphs.map((p) => {
    const paragraphLabel = escapeHtml(p?.displayParagraphId || `P${(Number(p?.paragraphNumber) || Number(p?.index) + 1 || 1)}`);
    const sentenceCount = paragraphSentenceCount.get(p?.index) || 0;
    const preview = escapeHtml(String(p?.text || "").slice(0, 180));
    return `
      <tr>
        <td class="fw-bold">${paragraphLabel}</td>
        <td class="text-center">${escapeHtml(sentenceCount)}</td>
        <td><span title="${escapeHtml(String(p?.text || ""))}">${preview}${String(p?.text || "").length > 180 ? "..." : ""}</span></td>
      </tr>
    `;
  }).join("") || `<tr><td colspan="3" class="text-muted text-center py-3">No paragraph data found.</td></tr>`;

  const sentenceRows = sentences.map((s) => {
    const sentenceLabel = escapeHtml(s?.displaySentenceId || `S${(Number(s?.sentenceNumber) || Number(s?.index) + 1 || 1)}`);
    const paragraphLabel = escapeHtml(s?.displayParagraphId || `P${(Number(s?.paragraphNumber) || Number(s?.paragraphIndex) + 1 || 1)}`);
    return `
      <tr>
        <td class="fw-bold font-monospace">${sentenceLabel}</td>
        <td class="font-monospace">${paragraphLabel}</td>
        <td>${escapeHtml(String(s?.text || ""))}</td>
      </tr>
    `;
  }).join("") || `<tr><td colspan="3" class="text-muted text-center py-3">No sentence data found.</td></tr>`;

  const pRows = document.getElementById("s1CanonicalParagraphRows");
  const sRows = document.getElementById("s1CanonicalSentenceRows");
  const jsonMirror = document.getElementById("s1CanonicalJsonMirror");
  if (pRows) pRows.innerHTML = paragraphRows;
  if (sRows) sRows.innerHTML = sentenceRows;
  if (jsonMirror) jsonMirror.textContent = JSON.stringify(data, null, 2);
}

function setCanonicalHoverInfo(paragraphIndex = null, sentenceIndex = null) {
  const infoEl = document.getElementById("canonicalViewerHoverInfo");
  if (!infoEl) return;
  if (!Number.isInteger(paragraphIndex) || !Number.isInteger(sentenceIndex)) {
    if (CANONICAL_PINNED_SENTENCE && Number.isInteger(CANONICAL_PINNED_SENTENCE.paragraphIndex) && Number.isInteger(CANONICAL_PINNED_SENTENCE.sentenceIndex)) {
      const pinnedParaLabel = getParagraphDisplayId(CANONICAL_PINNED_SENTENCE.paragraphIndex);
      const pinnedSentLabel = getSentenceDisplayId(CANONICAL_PINNED_SENTENCE.sentenceIndex);
      infoEl.innerHTML = `Pinned: <span class="fw-bold">${escapeHtml(pinnedParaLabel)}</span> • <span class="fw-bold">${escapeHtml(pinnedSentLabel)}</span> (paragraphIndex=${escapeHtml(CANONICAL_PINNED_SENTENCE.paragraphIndex)}, sentenceIndex=${escapeHtml(CANONICAL_PINNED_SENTENCE.sentenceIndex)})`;
    } else {
      infoEl.innerHTML = "Move your cursor over any sentence to inspect its indexes.";
    }
    return;
  }

  const paraLabel = getParagraphDisplayId(paragraphIndex);
  const sentLabel = getSentenceDisplayId(sentenceIndex);
  const pinned = CANONICAL_PINNED_SENTENCE;
  const hasPinned = pinned && Number.isInteger(pinned.paragraphIndex) && Number.isInteger(pinned.sentenceIndex);
  const isPinnedTarget = hasPinned && pinned.paragraphIndex === paragraphIndex && pinned.sentenceIndex === sentenceIndex;
  if (!hasPinned || isPinnedTarget) {
    infoEl.innerHTML = `<span class="fw-bold">${escapeHtml(paraLabel)}</span> • <span class="fw-bold">${escapeHtml(sentLabel)}</span> (paragraphIndex=${escapeHtml(paragraphIndex)}, sentenceIndex=${escapeHtml(sentenceIndex)})`;
    return;
  }

  const pinnedParaLabel = getParagraphDisplayId(pinned.paragraphIndex);
  const pinnedSentLabel = getSentenceDisplayId(pinned.sentenceIndex);
  infoEl.innerHTML = `Hover: <span class="fw-bold">${escapeHtml(paraLabel)}</span> • <span class="fw-bold">${escapeHtml(sentLabel)}</span> (paragraphIndex=${escapeHtml(paragraphIndex)}, sentenceIndex=${escapeHtml(sentenceIndex)})<span class="mx-2 text-muted">|</span>Pinned: <span class="fw-bold">${escapeHtml(pinnedParaLabel)}</span> • <span class="fw-bold">${escapeHtml(pinnedSentLabel)}</span>`;
}

function clearCanonicalPinnedSentence() {
  CANONICAL_PINNED_SENTENCE = null;
  const allSentences = document.querySelectorAll("#canonicalViewerBody .canonical-sentence");
  allSentences.forEach((el) => el.classList.remove("is-pinned"));
}

function setCanonicalPinnedSentence(paragraphIndex = null, sentenceIndex = null, { scroll = true } = {}) {
  const allSentences = document.querySelectorAll("#canonicalViewerBody .canonical-sentence");
  allSentences.forEach((el) => el.classList.remove("is-pinned"));
  if (!Number.isInteger(paragraphIndex) || !Number.isInteger(sentenceIndex)) {
    CANONICAL_PINNED_SENTENCE = null;
    return;
  }

  const selector = `#canonicalViewerBody .canonical-sentence[data-paragraph-index="${paragraphIndex}"][data-sentence-index="${sentenceIndex}"]`;
  const target = document.querySelector(selector);
  if (!target) {
    CANONICAL_PINNED_SENTENCE = null;
    return;
  }

  CANONICAL_PINNED_SENTENCE = { paragraphIndex, sentenceIndex };
  target.classList.add("is-pinned");
  if (scroll) target.scrollIntoView({ block: "center", behavior: "smooth" });
}

function focusCanonicalSentence(paragraphIndex = null, sentenceIndex = null, { scroll = true } = {}) {
  const allSentences = document.querySelectorAll("#canonicalViewerBody .canonical-sentence");
  allSentences.forEach((el) => el.classList.remove("is-focus"));
  if (!Number.isInteger(paragraphIndex) || !Number.isInteger(sentenceIndex)) {
    setCanonicalHoverInfo(null, null);
    return;
  }

  const selector = `#canonicalViewerBody .canonical-sentence[data-paragraph-index="${paragraphIndex}"][data-sentence-index="${sentenceIndex}"]`;
  const target = document.querySelector(selector);
  if (!target) {
    setCanonicalHoverInfo(paragraphIndex, sentenceIndex);
    return;
  }

  target.classList.add("is-focus");
  if (scroll) target.scrollIntoView({ block: "center", behavior: "smooth" });
  setCanonicalHoverInfo(paragraphIndex, sentenceIndex);
}

function renderCanonicalViewerBody(essayObject) {
  const container = document.getElementById("canonicalViewerBody");
  if (!container) return;

  const paragraphs = Array.isArray(essayObject?.paragraphs) ? essayObject.paragraphs : [];
  const sentences = Array.isArray(essayObject?.sentences) ? essayObject.sentences : [];
  if (!paragraphs.length || !sentences.length) {
    container.innerHTML = `<div class="text-muted small">No canonical paragraph/sentence data is available.</div>`;
    return;
  }

  const sentenceByParagraph = new Map();
  sentences.forEach((s) => {
    const p = Number.isInteger(s?.paragraphIndex) ? s.paragraphIndex : null;
    if (p == null) return;
    if (!sentenceByParagraph.has(p)) sentenceByParagraph.set(p, []);
    sentenceByParagraph.get(p).push(s);
  });

  const html = paragraphs.map((p) => {
    const paraIndex = Number.isInteger(p?.index) ? p.index : 0;
    const paraLabel = escapeHtml(p?.displayParagraphId || `P${paraIndex + 1}`);
    const paraSentences = sentenceByParagraph.get(paraIndex) || [];
    const sentenceHtml = paraSentences.map((s) => {
      const sentenceIndex = Number.isInteger(s?.index) ? s.index : 0;
      const sentenceLabel = escapeHtml(s?.displaySentenceId || `S${sentenceIndex + 1}`);
      return `
        <span
          class="canonical-sentence"
          data-paragraph-index="${paraIndex}"
          data-sentence-index="${sentenceIndex}"
          data-sentence-label="${sentenceLabel}"
          data-paragraph-label="${paraLabel}"
          title="${paraLabel}  |  ${sentenceLabel}"
        >${escapeHtml(s?.text || "")}</span>
      `;
    }).join(" ");

    return `
      <div class="canonical-paragraph mb-3 p-3 border rounded bg-white">
        <div class="small text-muted fw-bold mb-2">${paraLabel}</div>
        <div class="canonical-paragraph-text">${sentenceHtml || '<span class="text-muted small">No sentence detected.</span>'}</div>
      </div>
    `;
  }).join("");

  container.innerHTML = html;

  container.querySelectorAll(".canonical-sentence").forEach((el) => {
    const p = Number(el.getAttribute("data-paragraph-index"));
    const s = Number(el.getAttribute("data-sentence-index"));
    el.addEventListener("mouseenter", () => {
      focusCanonicalSentence(p, s);
    });
    el.addEventListener("click", () => {
      setCanonicalPinnedSentence(p, s, { scroll: false });
      setCanonicalHoverInfo(p, s);
    });
  });
  container.addEventListener("mouseleave", () => {
    if (CANONICAL_PINNED_SENTENCE) {
      focusCanonicalSentence(
        CANONICAL_PINNED_SENTENCE.paragraphIndex,
        CANONICAL_PINNED_SENTENCE.sentenceIndex,
        { scroll: false }
      );
      setCanonicalHoverInfo(
        CANONICAL_PINNED_SENTENCE.paragraphIndex,
        CANONICAL_PINNED_SENTENCE.sentenceIndex
      );
    } else {
      setCanonicalHoverInfo(null, null);
    }
  });
}

function openCanonicalViewer(options = {}) {
  if (!GLOBALESSAYOBJECT) {
    safeShowMessage({
      title: "Step 1 Missing",
      icon: "warning",
      message: "Run Step 1 first to build canonical paragraph/sentence mapping.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
    return;
  }

  renderCanonicalViewerBody(GLOBALESSAYOBJECT);
  const modalEl = document.getElementById("canonicalTextViewerModal");
  if (!modalEl) return;
  if (!modalEl.dataset.boundPinnedReset) {
    modalEl.addEventListener("hidden.bs.modal", () => {
      clearCanonicalPinnedSentence();
      const allSentences = document.querySelectorAll("#canonicalViewerBody .canonical-sentence");
      allSentences.forEach((el) => el.classList.remove("is-focus"));
      setCanonicalHoverInfo(null, null);
    });
    modalEl.dataset.boundPinnedReset = "1";
  }
  const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
  modal.show();

  const paragraphIndex = Number.isInteger(options?.paragraphIndex) ? options.paragraphIndex : null;
  const sentenceIndex = Number.isInteger(options?.sentenceIndex) ? options.sentenceIndex : null;
  if (paragraphIndex != null && sentenceIndex != null) {
    setTimeout(() => {
      setCanonicalPinnedSentence(paragraphIndex, sentenceIndex, { scroll: true });
      focusCanonicalSentence(paragraphIndex, sentenceIndex, { scroll: false });
    }, 120);
  } else {
    clearCanonicalPinnedSentence();
    setCanonicalHoverInfo(null, null);
  }
}

function openCanonicalViewerByIndex(paragraphIndex, sentenceIndex) {
  openCanonicalViewer({
    paragraphIndex: Number.isInteger(paragraphIndex) ? paragraphIndex : null,
    sentenceIndex: Number.isInteger(sentenceIndex) ? sentenceIndex : null
  });
}

