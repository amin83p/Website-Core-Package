function toPositiveInt(value, fallback = 1) {
  const n = Number.parseInt(value, 10);
  if (!Number.isFinite(n) || n <= 0) return fallback;
  return n;
}

function normalizeExecutionModeToken(value) {
  const token = String(value || "").trim().toLowerCase();
  if (token === "single_run" || token === "stability_gate_auto_consensus") return token;
  return "";
}

function deriveStepExecutionMeta(requestMeta = {}, stabilityMeta = null, fallbackMode = "single_run", fallbackRunCount = 1) {
  const metrics = stabilityMeta?.metrics || {};
  const stabilityRunCount = toPositiveInt(metrics?.runCount ?? stabilityMeta?.runCount, 1);
  const stabilityEnabled = Boolean(stabilityMeta && (
    stabilityMeta?.enabled === true ||
    stabilityMeta?.autoConsensus === true ||
    stabilityRunCount >= 2
  ));
  if (stabilityEnabled) {
    return {
      mode: "stability_gate_auto_consensus",
      runCount: Math.max(2, stabilityRunCount),
      stabilityEnabled: true
    };
  }

  const requestMode = normalizeExecutionModeToken(requestMeta?.mode);
  if (requestMode === "single_run") {
    return { mode: "single_run", runCount: 1, stabilityEnabled: false };
  }
  if (requestMode === "stability_gate_auto_consensus") {
    return {
      mode: "stability_gate_auto_consensus",
      runCount: Math.max(2, toPositiveInt(requestMeta?.runCount, fallbackRunCount)),
      stabilityEnabled: true
    };
  }

  const fallbackToken = normalizeExecutionModeToken(fallbackMode)
    || (toPositiveInt(fallbackRunCount, 1) >= 3 ? "stability_gate_auto_consensus" : "single_run");
  if (fallbackToken === "single_run") {
    return { mode: "single_run", runCount: 1, stabilityEnabled: false };
  }
  return {
    mode: "stability_gate_auto_consensus",
    runCount: Math.max(2, toPositiveInt(fallbackRunCount, 2)),
    stabilityEnabled: true
  };
}

function syncStepExecutionRequestMeta(stepKey, {
  fallbackMode = "single_run",
  fallbackRunCount = 1,
  stabilityMeta = null,
  stabilityStepKey = "",
  clearStabilityOnSingleRun = false
} = {}) {
  const requestMeta = SESSION_BUNDLE?.steps?.[stepKey]?.request;
  if (!requestMeta) return null;
  const resolved = deriveStepExecutionMeta(requestMeta, stabilityMeta, fallbackMode, fallbackRunCount);
  requestMeta.mode = resolved.mode;
  requestMeta.runCount = resolved.runCount;
  if (
    clearStabilityOnSingleRun &&
    resolved.mode === "single_run" &&
    stabilityStepKey &&
    SESSION_BUNDLE?.steps?.[stabilityStepKey]
  ) {
    delete SESSION_BUNDLE.steps[stabilityStepKey];
  }
  return resolved;
}

function getStepStabilityMeta(stepKey) {
  if (stepKey === "step3extract") {
    return (
      GLOBALSTEP3STABILITY ||
      SESSION_BUNDLE?.steps?.step3stability?.response?.json?.data ||
      SESSION_BUNDLE?.steps?.step3extract?.response?.json?.meta?.stabilityGate ||
      null
    );
  }
  if (stepKey === "step4grade") {
    return (
      GLOBALSTABILITY ||
      SESSION_BUNDLE?.steps?.step4stability?.response?.json?.data ||
      SESSION_BUNDLE?.steps?.step4grade?.response?.json?.data?.meta?.stabilityGate ||
      null
    );
  }
  return null;
}

function getStepExecutionProfile(stepKey) {
  const request = SESSION_BUNDLE?.steps?.[stepKey]?.request || {};
  const stabilityMeta = getStepStabilityMeta(stepKey) || null;
  const metrics = stabilityMeta?.metrics || {};
  const resolved = deriveStepExecutionMeta(request, stabilityMeta, request?.mode, request?.runCount);
  return {
    mode: resolved.mode,
    runCount: resolved.runCount,
    usedThreeRuns: resolved.runCount >= 3,
    stabilityGate: Boolean(stabilityMeta && Object.keys(stabilityMeta).length),
    gatePassed: typeof metrics?.gatePassed === "boolean" ? metrics.gatePassed : null
  };
}

function inferPipelineExecutionProfile() {
  const step3 = getStepExecutionProfile("step3extract");
  const step4 = getStepExecutionProfile("step4grade");
  const usedThreeRuns = step3.usedThreeRuns || step4.usedThreeRuns;
  return {
    strategy: usedThreeRuns ? "three_run_consensus" : "single_run",
    step3,
    step4,
    updatedAt: new Date().toISOString()
  };
}

