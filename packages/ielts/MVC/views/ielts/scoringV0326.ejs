    .filter((item) => item.summary || item.fix)
    .sort((a, b) => criterionOrder.indexOf(a.criterion) - criterionOrder.indexOf(b.criterion))
    .map((item) => `
      <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
