<%- include('partials/modal_GenericPicker', { user }) %>

<span id="tuningModelsRef" data-models="<%= encodeURIComponent(JSON.stringify(aiModels || [])) %>" hidden></span>

<script>
/* =========================================================
   Global Stores (same intent as your original)
   ========================================================= */
let GLOBALESSAYOBJECT = null;
let GLOBALSAMPLEID = null;
let GLOBALSAMPLEBANDSCORE = null;

let GLOBALEXTRACTION = null;
let GLOBALPARAGRAPHROLES = null;
let GLOBALANALYSIS = null;
let GLOBALGRADING = null;
let GLOBALFEEDBACK = null;
let GLOBALSTABILITY = null;
let GLOBALSTEP3STABILITY = null;
let GLOBALSTEP4AGGREGATEDROWS = [];
let CANONICAL_PINNED_SENTENCE = null;
const PIPELINE_MODE = "<%= (pipelineMode || 'full') %>";
const TUNING_MODEL_OPTIONS = (() => {
  try {
    const encoded = document.getElementById("tuningModelsRef")?.dataset?.models || "";
    return JSON.parse(decodeURIComponent(encoded || "%5B%5D"));
  } catch (_) {
    return [];
  }
})();
const STEP3_TUNING_MODEL_STORAGE_KEY = "ielts_step3_tuning_model_id";
const STEP4_TUNING_MODEL_STORAGE_KEY = "ielts_step4_tuning_model_id";
const STEP5_TUNING_MODEL_STORAGE_KEY = "ielts_step5_tuning_model_id";
const STEP3_TUNING_PROVIDER_STORAGE_KEY = "ielts_step3_tuning_provider_id";
const STEP4_TUNING_PROVIDER_STORAGE_KEY = "ielts_step4_tuning_provider_id";
const STEP5_TUNING_PROVIDER_STORAGE_KEY = "ielts_step5_tuning_provider_id";
const PROVIDER_LABEL_FALLBACK = {
  "google-gemini": "Google Gemini",
  "google-vertex": "Google Vertex AI",
  openai: "OpenAI",
  anthropic: "Anthropic",
  "azure-openai": "Azure OpenAI"
};
const STEP3_PROMPT_SOURCE_BUILTIN = "builtin";
const STEP3_PROMPT_SOURCE_TEMPLATE = "template";
let STEP3_PROMPT_SOURCE = STEP3_PROMPT_SOURCE_BUILTIN;
let STEP3_SELECTED_TEMPLATE = null;
const STEP4_PROMPT_SOURCE_BUILTIN = "builtin";
const STEP4_PROMPT_SOURCE_TEMPLATE = "template";
let STEP4_PROMPT_SOURCE = STEP4_PROMPT_SOURCE_BUILTIN;
let STEP4_SELECTED_TEMPLATE = null;
const STEP5_PROMPT_SOURCE_BUILTIN = "builtin";
const STEP5_PROMPT_SOURCE_TEMPLATE = "template";
let STEP5_PROMPT_SOURCE = STEP5_PROMPT_SOURCE_BUILTIN;
let STEP5_SELECTED_TEMPLATE = null;
const STEP_STOP_BUTTON_IDS = {
  step3extract: "btnStopStep3",
  step4grade: "btnStopStep4",
  step5feedback: "btnStopStep5"
};
const STEP_ACTIVE_REQUESTS = {
  step3extract: null,
  step4grade: null,
  step5feedback: null
};
const STEP_ACTIVE_CANCEL_TOKENS = {
  step3extract: null,
  step4grade: null,
  step5feedback: null
};
const STEP_CANCEL_REQUESTED = {
  step3extract: false,
  step4grade: false,
  step5feedback: false
};

function createAbortError(message = "The operation was aborted.") {
  const err = new Error(message);
  err.name = "AbortError";
  return err;
}

function isAbortError(error) {
  const name = String(error?.name || "").toLowerCase();
  const message = String(error?.message || "").toLowerCase();
  return name === "aborterror" || message.includes("aborted");
}

function getStopButtonDefaultHtml() {
  return `<i class="bi bi-stop-circle me-1"></i> Stop`;
}

function createRunCancelToken(stepKey) {
  const prefix = String(stepKey || 'run').trim() || 'run';
  if (window.crypto && typeof window.crypto.randomUUID === "function") {
    return `${prefix}:${window.crypto.randomUUID()}`;
  }
  return `${prefix}:${Date.now().toString(36)}:${Math.random().toString(36).slice(2, 10)}`;
}

function getActiveStepCancelToken(stepKey) {
  return String(STEP_ACTIVE_CANCEL_TOKENS[stepKey] || "").trim();
}

function setStepStopButtonState(stepKey, { visible = false, stopping = false } = {}) {
  const btn = document.getElementById(STEP_STOP_BUTTON_IDS[stepKey]);
  if (!btn) return;
  if (!visible) {
    btn.classList.add("d-none");
    btn.disabled = true;
    btn.innerHTML = getStopButtonDefaultHtml();
    return;
  }
  btn.classList.remove("d-none");
  btn.disabled = Boolean(stopping);
  btn.innerHTML = stopping
    ? `<span class="spinner-border spinner-border-sm me-2"></span>Stopping...`
    : getStopButtonDefaultHtml();
}

function syncStepStopButtons() {
  Object.keys(STEP_STOP_BUTTON_IDS).forEach((stepKey) => {
    const controller = STEP_ACTIVE_REQUESTS[stepKey];
    const isRunning = Boolean(controller && !controller.signal?.aborted);
    setStepStopButtonState(stepKey, { visible: isRunning, stopping: false });
  });
}

function beginAbortableStep(stepKey) {
  const existing = STEP_ACTIVE_REQUESTS[stepKey];
  if (existing && !existing.signal?.aborted) return null;
  const controller = new AbortController();
  STEP_ACTIVE_CANCEL_TOKENS[stepKey] = createRunCancelToken(stepKey);
  STEP_CANCEL_REQUESTED[stepKey] = false;
  STEP_ACTIVE_REQUESTS[stepKey] = controller;
  setStepStopButtonState(stepKey, { visible: true, stopping: false });
  return controller;
}

function finishAbortableStep(stepKey, controller) {
  if (STEP_ACTIVE_REQUESTS[stepKey] !== controller) return;
  STEP_ACTIVE_REQUESTS[stepKey] = null;
  STEP_ACTIVE_CANCEL_TOKENS[stepKey] = null;
  STEP_CANCEL_REQUESTED[stepKey] = false;
  setStepStopButtonState(stepKey, { visible: false, stopping: false });
}

function stopRunningStep(stepKey) {
  const controller = STEP_ACTIVE_REQUESTS[stepKey];
  if (!controller || controller.signal?.aborted) return;
  const cancelToken = getActiveStepCancelToken(stepKey);
  if (cancelToken && !STEP_CANCEL_REQUESTED[stepKey]) {
    STEP_CANCEL_REQUESTED[stepKey] = true;
    const notifyBackend = () => {
      fetch("/ielts/scoring/cancel", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Accept": "application/json",
          "X-AJAX-Request": "true"
        },
        body: JSON.stringify({ cancelToken }),
        keepalive: true
      }).catch(() => {});
    };
    notifyBackend();
    // Small second ping to reduce race window if the run is still being registered server-side.
    setTimeout(notifyBackend, 350);
  }
  controller.abort();
  setStepStopButtonState(stepKey, { visible: true, stopping: true });
}

function normalizeProviderToken(value) {
  return String(value || "").trim().toLowerCase();
}

function normalizeProviderChoiceId(value) {
  return String(value || "").trim();
}

function resolveProviderChoiceId(row) {
  return normalizeProviderChoiceId(row?.providerChoiceId || row?.providerRecordId || row?.apiProviderId || normalizeProviderToken(row?.provider || row?.providerId));
}

function getProviderLabel(providerId) {
  const normalized = normalizeProviderToken(providerId);
  if (!normalized) return "Unknown Provider";
  const fromModels = (Array.isArray(TUNING_MODEL_OPTIONS) ? TUNING_MODEL_OPTIONS : []).find((row) => {
    return normalizeProviderToken(row?.provider || row?.providerId) === normalized
      && (String(row?.providerDisplayLabel || row?.providerRecordName || row?.providerLabel || "").trim());
  });
  return String(
    fromModels?.providerDisplayLabel ||
    fromModels?.providerRecordName ||
    fromModels?.providerLabel ||
    PROVIDER_LABEL_FALLBACK[normalized] ||
    normalized
  );
}

function getTuningProviderOptions() {
  const options = Array.isArray(TUNING_MODEL_OPTIONS) ? TUNING_MODEL_OPTIONS : [];
  const byProviderChoice = new Map();
  for (const row of options) {
    const providerId = normalizeProviderToken(row?.provider || row?.providerId);
    const providerChoiceId = resolveProviderChoiceId(row);
    if (!providerId || !providerChoiceId) continue;
    const providerLabel = String(row?.providerLabel || getProviderLabel(providerId)).trim();
    const providerRecordLabel = String(row?.providerRecordName || "").trim();
    const providerDisplayLabel = String(row?.providerDisplayLabel || providerRecordLabel || providerLabel).trim();
    const optionLabel = providerRecordLabel
      ? `${providerDisplayLabel}${providerLabel && providerDisplayLabel.toLowerCase() !== providerLabel.toLowerCase() ? ` (${providerLabel})` : ""}`
      : providerDisplayLabel;
    const existing = byProviderChoice.get(providerChoiceId) || {
      id: providerChoiceId,
      providerId,
      apiProviderId: String(row?.providerRecordId || row?.apiProviderId || "").trim(),
      label: optionLabel || providerLabel || providerId,
      isDefaultProvider: false
    };
    existing.isDefaultProvider = existing.isDefaultProvider || row?.providerIsDefault === true;
    byProviderChoice.set(providerChoiceId, existing);
  }
  return Array.from(byProviderChoice.values()).sort((a, b) => {
    const aDefault = a?.isDefaultProvider ? 1 : 0;
    const bDefault = b?.isDefaultProvider ? 1 : 0;
    if (aDefault !== bDefault) return bDefault - aDefault;
    return String(a?.label || a?.id).localeCompare(String(b?.label || b?.id));
  });
}

function getProviderOptionBySelectionId(selectionId) {
  const normalizedSelectionId = normalizeProviderChoiceId(selectionId);
  if (!normalizedSelectionId) return null;
  const providers = getTuningProviderOptions();
  return providers.find((row) => row.id === normalizedSelectionId) || null;
}

function getTuningModelsForProvider(providerSelectionId) {
  const normalizedProviderSelectionId = normalizeProviderChoiceId(providerSelectionId);
  const options = Array.isArray(TUNING_MODEL_OPTIONS) ? TUNING_MODEL_OPTIONS : [];
  if (!normalizedProviderSelectionId) return [];
  return options.filter((row) => resolveProviderChoiceId(row) === normalizedProviderSelectionId);
}

function getProviderModelListDiagnostic(providerSelectionId) {
  const models = getTuningModelsForProvider(providerSelectionId);
  if (!models.length) return null;
  const warningRow = models.find((row) => String(row?.modelListWarning || "").trim())
    || models.find((row) => String(row?.modelListSource || "").trim().toLowerCase() === "fallback");
  if (!warningRow) return null;

  const source = String(warningRow?.modelListSource || "").trim().toLowerCase();
  const status = String(warningRow?.modelListStatus || "").trim().toLowerCase();
  const routeUsed = String(warningRow?.modelListRouteUsed || "").trim();
  const warningText = String(warningRow?.modelListWarning || "").trim();
  const errorSummary = String(warningRow?.modelListErrorSummary || "").trim();

  let text = warningText;
  if (!text && source === "fallback") {
    text = "Vertex model listing fallback list is currently in use.";
  }
  if (!text && status === "partial") {
    text = "Vertex model listing is partially degraded.";
  }
  if (!text) return null;

  if (routeUsed) {
    text += ` Route: ${routeUsed}.`;
  }
  if (!warningText && errorSummary) {
    text += ` Details: ${errorSummary}`;
  }

  return {
    text,
    source,
    status
  };
}

function renderProviderModelWarning(targetId, providerSelectionId) {
  const el = document.getElementById(targetId);
  if (!el) return;
  const diagnostic = getProviderModelListDiagnostic(providerSelectionId);
  if (!diagnostic?.text) {
    el.textContent = "";
    el.classList.add("d-none");
    return;
  }
  el.textContent = diagnostic.text;
  el.classList.remove("d-none");
}

function getProviderDefaultCandidate(providerSelectionId) {
  const models = getTuningModelsForProvider(providerSelectionId);
  if (!models.length) return "";
  const explicitDefault = models.find((row) => row?.isDefaultCandidate === true);
  return String(explicitDefault?.id || models[0]?.id || "").trim();
}

function populateProviderSelect(selectId, selectedProviderId = "") {
  const select = document.getElementById(selectId);
  if (!select) return;
  const providers = getTuningProviderOptions();
  const normalizedSelected = normalizeProviderChoiceId(selectedProviderId);
  const providerExists = providers.some((row) => row.id === normalizedSelected);

  const optionsHtml = [
    `<option value="">Auto (default provider)</option>`,
    ...providers.map((row) => `<option value="${escapeHtml(row.id)}">${escapeHtml(row.label)}</option>`)
  ].join("");
  select.innerHTML = optionsHtml;
  select.value = providerExists ? normalizedSelected : "";
}

function populateModelSelectForProvider(selectId, providerSelectionId, selectedModelId = "") {
  const select = document.getElementById(selectId);
  if (!select) return "";
  const normalizedProviderSelection = normalizeProviderChoiceId(providerSelectionId);
  const normalizedSelectedModel = String(selectedModelId || "").trim();
  const models = getTuningModelsForProvider(normalizedProviderSelection);

  const optionRows = [`<option value="">Auto (default model)</option>`];
  models.forEach((model) => {
    const modelId = String(model?.id || "").trim();
    if (!modelId) return;
    const modelName = String(model?.name || modelId).trim();
    optionRows.push(
      `<option value="${escapeHtml(modelId)}">${escapeHtml(modelName)} (${escapeHtml(modelId)})</option>`
    );
  });
  select.innerHTML = optionRows.join("");

  const validSelected = models.some((row) => String(row?.id || "").trim() === normalizedSelectedModel)
    ? normalizedSelectedModel
    : "";
  select.value = validSelected;
  return validSelected;
}

// ------------------------------
// Grading (Step 4) runtime settings
// ------------------------------
const GRADING_LIMITS = {
  batchSize: { min: 1, max: 20, criticalMax: 12 },      // criticalMax: warning threshold
  concurrency: { min: 1, max: 10, criticalMax: 6 }      // criticalMax: warning threshold
};

let GRADING_SETTINGS = {
  batchSize: 5,
  concurrency: 2,
  mode: "hybrid_extension"
};

const STABILITY_PROFILES = {
  standard: {
    step3: { runCount: 3, minMeanAgreement: 0.9, maxFlipRate: 0.1, maxUnstableShare: 0.2 },
    step4: { runCount: 3, minMeanAgreement: 0.9, maxFlipRate: 0.1, maxUnstableShare: 0.2 }
  },
  strict: {
    step3: { runCount: 3, minMeanAgreement: 0.95, maxFlipRate: 0.05, maxUnstableShare: 0.1 },
    step4: { runCount: 3, minMeanAgreement: 0.95, maxFlipRate: 0.05, maxUnstableShare: 0.1 }
  }
};
let STABILITY_PROFILE = "standard";
let STABILITY_GATE_CONFIG = { ...STABILITY_PROFILES.standard.step4 };
let STEP3_STABILITY_CONFIG = { ...STABILITY_PROFILES.standard.step3 };
const STEP3_CONSENSUS_ENFORCED_RUN_COUNT = 3;

function normalizeStabilityProfile(profile) {
  return String(profile || "").trim().toLowerCase() === "strict" ? "strict" : "standard";
}

function enforceStep3ConsensusRunCount() {
  const enforced = Number(STEP3_CONSENSUS_ENFORCED_RUN_COUNT || 3);
  STEP3_STABILITY_CONFIG.runCount = enforced;
  const input = document.getElementById("step3RunCountInput");
  if (input) input.value = String(enforced);
  return enforced;
}

function applyStabilityProfile(profile, { logChange = false } = {}) {
  const normalized = normalizeStabilityProfile(profile);
  const previous = STABILITY_PROFILE;
  const currentStep4RunCount = Number(STABILITY_GATE_CONFIG?.runCount || STABILITY_PROFILES.standard.step4.runCount || 3);
  STABILITY_PROFILE = normalized;

  STABILITY_GATE_CONFIG = { ...STABILITY_PROFILES[normalized].step4 };
  STEP3_STABILITY_CONFIG = { ...STABILITY_PROFILES[normalized].step3 };
  STEP3_STABILITY_CONFIG.runCount = Number(STEP3_CONSENSUS_ENFORCED_RUN_COUNT || 3);
  STABILITY_GATE_CONFIG.runCount = clampInt(currentStep4RunCount, 2, 10, STABILITY_GATE_CONFIG.runCount);
  enforceStep3ConsensusRunCount();

  updateStabilityProfileLabels();
  renderStep3Stability(GLOBALSTEP3STABILITY);
  renderStabilityGateDisplay(GLOBALSTABILITY);
  if (logChange && previous !== normalized) {
    addTweakLog("stability_profile_changed", {
      from: previous,
      to: normalized,
      step3: { ...STEP3_STABILITY_CONFIG },
      step4: { ...STABILITY_GATE_CONFIG }
    });
  }
}

function updateStep3ConsensusButtonLabel() {
  const btn = document.getElementById("btnExtractConsensus");
  const runCount = Number(STEP3_CONSENSUS_ENFORCED_RUN_COUNT || 3);
  if (btn) {
    btn.innerHTML = `<i class="bi bi-shield-check me-1"></i> Stability + Consensus (${runCount}x)`;
  }
}

function onStep3RunCountChange(nextValue) {
  if (isStepLocked("step3extract")) {
    const input = document.getElementById("step3RunCountInput");
    if (input) input.value = String(STEP3_STABILITY_CONFIG.runCount);
    return safeShowMessage({
      title: "Step Locked",
      icon: "lock",
      message: "Step 3 is locked for this session. Start a new session to change run count.",
      buttons: [{ text: "OK", class: "btn-secondary" }]
    });
  }
  const previous = Number(STEP3_STABILITY_CONFIG.runCount || STEP3_CONSENSUS_ENFORCED_RUN_COUNT || 3);
  const next = clampInt(nextValue, 2, 10, previous);
  // v0326 runtime policy: Step 3 uses fixed 3-run consensus for consistency.
  STEP3_STABILITY_CONFIG.runCount = Number(STEP3_CONSENSUS_ENFORCED_RUN_COUNT || 3);
  const input = document.getElementById("step3RunCountInput");
  if (input) input.value = String(STEP3_STABILITY_CONFIG.runCount);
  updateStep3ConsensusButtonLabel();
  saveGradingSettings();
  if (next !== previous || STEP3_STABILITY_CONFIG.runCount !== next) {
    addTweakLog("step3_run_count_enforced", {
      requested: next,
      enforced: STEP3_STABILITY_CONFIG.runCount,
      reason: "v0326_step3_consensus_fixed_3x"
    });
  }
}

function clampInt(v, min, max, fallback) {
  const n = Number.parseInt(v, 10);
  if (Number.isNaN(n)) return fallback;
  return Math.max(min, Math.min(max, n));
}

function normalizeRunMode(mode) {
  return String(mode || "").trim().toLowerCase() === "operationalized_only"
    ? "operationalized_only"
    : "hybrid_extension";
}

function parseBandScoreOrNull(value) {
  const txt = String(value ?? "").trim();
  if (!txt) return null;
  const num = Number(txt);
  if (!Number.isFinite(num)) return null;
  if (num < 0 || num > 9) return null;
  return Number(num.toFixed(1));
}

function getSelectedSampleOption() {
  const select = document.getElementById("sampleSelect");
  return select?.selectedOptions?.[0] || null;
}

function syncSamplePickerDisplayFromSelection() {
  const displayEl = document.getElementById("sampleSelectDisplay");
  if (!displayEl) return;
  const option = getSelectedSampleOption();
  if (!option || !option.value) {
    displayEl.value = "";
    displayEl.placeholder = "Pick an essay sample...";
    return;
  }
  const refName = String(option?.dataset?.refName || option.text || option.value || "").trim();
  const type = String(option?.dataset?.type || "").trim();
  const band = parseBandScoreOrNull(option?.dataset?.bandScore);
  const parts = [refName || option.value];
  if (type) parts.push(type);
  if (band != null) parts.push(`Band ${band}`);
  parts.push(`ID ${option.value}`);
  displayEl.value = parts.join(" | ");
}

function updateActiveSampleHeaderMeta() {
  const wrap = document.getElementById("activeSampleHeaderMeta");
  const nameEl = document.getElementById("activeSampleHeaderName");
  const idEl = document.getElementById("activeSampleHeaderId");
  if (!wrap || !nameEl || !idEl) return;

  const option = getSelectedSampleOption();
  const sampleId = String(
    option?.value ||
    SESSION_BUNDLE?.metadata?.sampleId ||
    GLOBALSAMPLEID ||
    ""
  ).trim();
  const sampleName = String(
    option?.dataset?.refName ||
    option?.text ||
    SESSION_BUNDLE?.metadata?.sampleRefName ||
    SESSION_BUNDLE?.metadata?.sampleName ||
    ""
  ).trim();

  if (!sampleId && !sampleName) {
    wrap.classList.add("d-none");
    nameEl.textContent = "-";
    idEl.textContent = "-";
    return;
  }

  nameEl.textContent = sampleName || sampleId || "-";
  idEl.textContent = sampleId || "-";
  wrap.classList.remove("d-none");
}

function upsertSampleOptionFromPicker(item) {
  const select = document.getElementById("sampleSelect");
  if (!select) return null;
  const sampleId = String(item?.id || "").trim();
  if (!sampleId) return null;
  let option = Array.from(select.options || []).find((opt) => String(opt?.value || "").trim() === sampleId) || null;
  const refName = String(item?.refName || item?.name || item?.title || sampleId).trim();
  const sampleType = String(item?.type || "").trim();
  const sampleBand = String(item?.bandScore ?? "").trim();
  const label = sampleType ? `${refName} (${sampleType})` : refName;
  if (!option) {
    option = new Option(label, sampleId, false, false);
    select.add(option);
  } else {
    option.text = label;
  }
  option.dataset.refName = refName;
  option.dataset.type = sampleType;
  option.dataset.bandScore = sampleBand;
  return option;
}

function selectSampleFromPicker(item) {
  const select = document.getElementById("sampleSelect");
  if (!select) return;
  const option = upsertSampleOptionFromPicker(item);
  if (!option?.value) return;
  select.value = option.value;
  select.dispatchEvent(new Event("change", { bubbles: true }));
}

function clearSelectedSampleEssay() {
  if (blockIfStepLocked("step1freeze")) return;
  const select = document.getElementById("sampleSelect");
  if (!select) return;
  if (!select.value) return;
  select.value = "";
  select.dispatchEvent(new Event("change", { bubbles: true }));
}

function openSampleEssayPicker() {
  if (blockIfStepLocked("step1freeze")) return;
  if (!window.GenericPicker || typeof window.GenericPicker.open !== "function") {
    return safeShowMessage({
      title: "Picker Unavailable",
      icon: "warning",
      message: "Essay picker is not available right now.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }

  window.GenericPicker.open({
    title: "Select Essay Sample",
    icon: "bi-journal-richtext",
    apiEndpoint: "/ielts/task2samples",
    placeholder: "Search by reference, type, band, or ID...",
    searchFields: "id,refName,type,bandScore,feedback",
    limit: 20,
    renderer: (item) => {
      const sampleId = escapeHtml(String(item?.id || "").trim() || "-");
      const refName = escapeHtml(String(item?.refName || item?.name || item?.title || sampleId).trim());
      const sampleType = escapeHtml(String(item?.type || "-").trim() || "-");
      const bandScore = parseBandScoreOrNull(item?.bandScore);
      const bandLabel = escapeHtml(bandScore == null ? "-" : String(bandScore));
      return `
        <div class="d-flex justify-content-between align-items-center w-100 gap-3">
          <div class="overflow-hidden">
            <div class="fw-bold text-dark text-truncate">${refName}</div>
            <div class="small text-muted text-truncate">Type: ${sampleType} | Band: ${bandLabel}</div>
          </div>
          <span class="badge bg-light text-secondary border font-monospace">${sampleId}</span>
        </div>
      `;
    },
    onSelect: (item) => selectSampleFromPicker(item)
  });
}

