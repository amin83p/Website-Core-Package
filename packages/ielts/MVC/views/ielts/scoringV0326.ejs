    const p = safeShowMessage({
    title: "Start a new report?",
    icon: "warning",
    message,
    buttons: [
      { text: "Cancel", class: "btn-secondary" },
      { text: "Start New", class: "btn-warning" }
    ]
  });

  // safeShowMessage() returns a Promise when showMessageModal exists [file:8]
  if (p && typeof p.then === "function") {
    p.then((choice) => {
      if (choice === "Start New") doHardReset();
    });
  }
}

async function confirmPageChangeNavigation(targetUrl) {
  if (!targetUrl) return;

  if (!hasActiveSessionData()) {
    window.location = targetUrl;
    return;
  }

  const dirty = !!SESSION_BUNDLE?.dirty;
  const message = dirty
    ? "You have data on this page, including unsaved changes. If you leave now, your current work may be lost."
    : "You have data on this page. If you leave now, your current work may be lost.";

  if (typeof showMessageModal === "function") {
    const choice = await showMessageModal({
      title: "Leave this page?",
      icon: "warning",
      message,
      buttons: [
        { text: "Cancel", class: "btn-secondary" },
        { text: "Leave Page", class: "btn-warning" }
      ]
    });
    if (choice === "Leave Page") {
      window.location = targetUrl;
    }
    return;
  }

  const accepted = window.confirm(`${message}\n\nDo you want to leave this page?`);
  if (accepted) window.location = targetUrl;
}

