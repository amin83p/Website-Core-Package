});



/* =========================================================
   RAW SESSION BUNDLE (no HTML)
   ========================================================= */
const SCORING_VIEW_ID = "scoringV0326";
const SESSION_BUNDLE = {
  schema: "ielts-scoring-session",
  version: 1,
  id: null,
  sessionId: null,
  savedAt: null,
  metadata: {},
  researchConfig: {},
  uiState: {},
  tweakLog: [],
  freezePoints: {},
  steps: {}, // stepKey -> { request, response, timing }
  dirty: false //if we have data on page

};
ensureStep11Scaffold(SESSION_BUNDLE);

function ensureStep11Scaffold(bundle = SESSION_BUNDLE) {
  if (!bundle || typeof bundle !== "object") return;
  if (!Array.isArray(bundle.tweakLog)) bundle.tweakLog = [];
  if (!bundle.freezePoints || typeof bundle.freezePoints !== "object" || Array.isArray(bundle.freezePoints)) {
    bundle.freezePoints = {};
  }
}

function resolveBundleSessionId(bundle = SESSION_BUNDLE) {
  const id = String(bundle?.sessionId || bundle?.id || "").trim();
  return id || null;
}

function syncBundleSessionId(bundle = SESSION_BUNDLE, id = null) {
  if (!bundle || typeof bundle !== "object") return null;
  const nextId = String(id || resolveBundleSessionId(bundle) || "").trim() || null;
  bundle.sessionId = nextId;
  bundle.id = nextId;
  return nextId;
}

function addTweakLog(action, details = {}) {
  ensureStep11Scaffold(SESSION_BUNDLE);
  SESSION_BUNDLE.tweakLog.push({
    id: `twk_${Date.now()}_${Math.floor(Math.random() * 1000)}`,
    at: new Date().toISOString(),
    action: String(action || "unknown").trim() || "unknown",
    details: (details && typeof details === "object") ? details : { value: String(details ?? "") }
  });
  if (SESSION_BUNDLE.tweakLog.length > 500) {
    SESSION_BUNDLE.tweakLog = SESSION_BUNDLE.tweakLog.slice(-500);
  }
  SESSION_BUNDLE.dirty = true;
}

function setFreezePoint(key, payload = {}) {
  ensureStep11Scaffold(SESSION_BUNDLE);
  const freezeKey = String(key || "").trim();
  if (!freezeKey) return;
  SESSION_BUNDLE.freezePoints[freezeKey] = {
    at: new Date().toISOString(),
    ...(payload && typeof payload === "object" ? payload : {})
  };
  SESSION_BUNDLE.dirty = true;
}

const STEP_ORDER = ["step1freeze", "step2analyze", "step3extract", "step4grade", "step5feedback"];
const NON_RERUN_STEPS = new Set(["step1freeze", "step2analyze"]);
const STEP_LABELS = {
  step1freeze: "Step 1 Freeze",
  step2analyze: "Step 2 Analysis",
  step3extract: "Step 3 Extraction",
  step4grade: "Step 4 Grading",
  step5feedback: "Step 5 Feedback"
};

let SESSION_READONLY = false;

function isSuccessfulStep(stepKey, bundle = SESSION_BUNDLE) {
  return bundle?.steps?.[stepKey]?.response?.json?.status === "success";
}

function isPipelineComplete(bundle = SESSION_BUNDLE) {
  return STEP_ORDER.every((k) => isSuccessfulStep(k, bundle));
}

function ensureCompletionMarker(bundle = SESSION_BUNDLE) {
  if (!isPipelineComplete(bundle)) return;
  if (!bundle.steps) bundle.steps = {};
  if (!bundle.steps.step6report) {
    const now = Date.now();
    bundle.steps.step6report = {
      request: { source: "client", action: "report-ready" },
      response: { contentType: "application/json", json: { status: "success" } },
      timing: { startedAt: now, endedAt: now }
    };
  }
}

function updateSessionLockBanner(message = "") {
  const el = document.getElementById("sessionLockBanner");
  if (!el) return;
  if (!SESSION_READONLY) {
    el.classList.add("d-none");
    el.textContent = "";
    return;
  }
  el.textContent = message || "This completed session is read-only. Start New to run the pipeline again.";
  el.classList.remove("d-none");
}

function setSessionReadOnly(value, reason = "") {
  SESSION_READONLY = !!value;
  updateSessionLockBanner(reason);
  updateStepLocks();
}

function isStepLocked(stepKey) {
  if (SESSION_READONLY) return true;
  if (NON_RERUN_STEPS.has(String(stepKey || "").trim())) {
    return isSuccessfulStep(stepKey);
  }
  return false;
}

function updateStepLocks() {
  const freezeLocked = isStepLocked("step1freeze");
  const analyzeLocked = isStepLocked("step2analyze");
  const extractLocked = isStepLocked("step3extract");
  const gradeLocked = isStepLocked("step4grade");
