    if (isAbortError(e)) {
      await safeShowMessage({
        title: "Step 5 Stopped",
        icon: "warning",
        message: "Step 5 feedback generation was stopped before completion.",
        buttons: [{ text: "OK", class: "btn-warning" }]
      });
    } else {
      console.error(e);
      safeShowMessage({
        title: "Error",
        icon: "error",
        message: e.message || "Feedback generation failed.",
        buttons: [{ text: "OK", class: "btn-danger" }]
      });
    }
  } finally {
    finishAbortableStep("step5feedback", controller);
    btn.disabled = false;
    btn.innerHTML = `<i class="bi bi-magic me-1"></i> Generate`;
    updateStepLocks();
  }
}

/* NOTE: keep your original full implementation if present */
function renderFeedbackResults(fb) {
  const criterionOrder = ["TR", "CC", "LR", "GRA", "General"];
  const normalizeCriterion = (value) => {
    const v = String(value || "").trim().toUpperCase();
    return criterionOrder.includes(v) ? v : "General";
  };
  const normalizeEvidenceRefs = (value) => {
    let refs = [];
    if (Array.isArray(value)) refs = value;
    else if (typeof value === "string") refs = value.split(/[,\s;]+/g);
    const joined = Array.isArray(value) ? value.join(" ") : String(value || "");
    const matches = joined.toUpperCase().match(/S\d+/g);
    if (matches) refs = refs.concat(matches);
    const out = [];
    const seen = new Set();
    for (const refRaw of refs) {
      const ref = String(refRaw || "").trim().toUpperCase();
      if (!/^S\d+$/.test(ref)) continue;
      if (seen.has(ref)) continue;
      seen.add(ref);
      out.push(ref);
    }
    return out.slice(0, 8);
  };
  const renderEvidenceRefBadges = (refs) => {
    const list = normalizeEvidenceRefs(refs);
    if (!list.length) return `<span class="text-muted small">No direct evidence refs.</span>`;
    return list.map((ref) => {
      const index = getSentenceIndexFromRefToken(ref);
      if (!Number.isInteger(index)) {
        return `<span class="badge bg-light text-dark border font-monospace me-1">${escapeHtml(ref)}</span>`;
      }
      return `<span class="badge bg-light text-dark border font-monospace me-1">${buildSentenceRefClickableHtml(index, ref)}</span>`;
    }).join("");
  };

  const byCriterion = (Array.isArray(fb?.byCriterion) ? fb.byCriterion : [])
    .map((item) => ({
      criterion: normalizeCriterion(item?.criterion),
      summary: String(item?.summary || item?.issue || "").trim(),
      evidenceRefs: normalizeEvidenceRefs(item?.evidenceRefs || item?.evidence),
      fix: String(item?.fix || "").trim()
    }))
    .filter((item) => item.summary || item.fix)
    .sort((a, b) => criterionOrder.indexOf(a.criterion) - criterionOrder.indexOf(b.criterion));

  const improvements = (Array.isArray(fb?.improvements) ? fb.improvements : [])
    .map((item) => ({
      criterion: normalizeCriterion(item?.criterion),
      issue: String(item?.issue || "").trim(),
      evidenceRefs: normalizeEvidenceRefs(item?.evidenceRefs || item?.evidence),
      fix: String(item?.fix || "").trim()
    }))
    .filter((item) => item.issue || item.fix);

  const byCriterionHtml = byCriterion.map((item) => `
    <div class="col-md-6">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
