}


function computeGradingSettingsWarnings(batchSize, concurrency) {
  const warnings = [];
  if (batchSize > GRADING_LIMITS.batchSize.criticalMax) {
    warnings.push(`Batch size ${batchSize} is high. Large prompts may reduce reliability and can trigger truncation.`);
  }
  if (concurrency > GRADING_LIMITS.concurrency.criticalMax) {
    warnings.push(`Concurrency ${concurrency} is high. This can trigger rate limits, increase cost, and make runs less stable.`);
  }
  if (batchSize * concurrency > 60) {
    warnings.push(`BatchSize أ— Concurrency = ${batchSize * concurrency} (very high). Consider lowering one of them.`);
  }
  return warnings;
}

function openGradingSettings() {
  if (isStepLocked("step4grade")) {
    safeShowMessage({
      title: "Step Locked",
      icon: "lock",
      message: "Step 4 settings are locked for this session.",
      buttons: [{ text: "OK", class: "btn-secondary" }]
    });
    return;
  }
  loadGradingSettings();
  const overlay = document.getElementById("gradingSettingsOverlay");
  const b = document.getElementById("gradingBatchSizeInput");
  const c = document.getElementById("gradingConcurrencyInput");
  const m = document.getElementById("gradingModeInput");
  const p = document.getElementById("stabilityProfileInput");
  if (!overlay || !b || !c || !m || !p) return;

  b.value = GRADING_SETTINGS.batchSize;
  c.value = GRADING_SETTINGS.concurrency;
  m.value = normalizeRunMode(GRADING_SETTINGS.mode);
  p.value = STABILITY_PROFILE;
  updateRunModeInfoPreview(m.value);
  updateStabilityProfileInfoPreview(p.value);

  overlay.classList.remove("d-none");
  document.body.classList.add("gs-no-scroll");

  setTimeout(() => b.focus(), 0);

  // Close on outside click
  overlay.addEventListener("click", gradingOverlayClickClose);
  // Close on Esc
  window.addEventListener("keydown", gradingEscClose);
  updateGradingSettingsModalWarning();
}

function closeGradingSettings() {
  const overlay = document.getElementById("gradingSettingsOverlay");
  if (!overlay) return;
  overlay.classList.add("d-none");
  document.body.classList.remove("gs-no-scroll");

  overlay.removeEventListener("click", gradingOverlayClickClose);
  window.removeEventListener("keydown", gradingEscClose);
}

function gradingOverlayClickClose(e) {
  if (e.target && e.target.id === "gradingSettingsOverlay") {
    closeGradingSettings();
  }
}
function gradingEscClose(e) {
  if (e.key === "Escape") closeGradingSettings();
}

function updateGradingSettingsModalWarning() {
  const warnEl = document.getElementById("gradingSettingsWarning");
  const b = document.getElementById("gradingBatchSizeInput");
  const c = document.getElementById("gradingConcurrencyInput");
  if (!warnEl || !b || !c) return;

  const bs = clampInt(b.value, GRADING_LIMITS.batchSize.min, GRADING_LIMITS.batchSize.max, GRADING_SETTINGS.batchSize);
  const cc = clampInt(c.value, GRADING_LIMITS.concurrency.min, GRADING_LIMITS.concurrency.max, GRADING_SETTINGS.concurrency);

  const warnings = computeGradingSettingsWarnings(bs, cc);
  if (warnings.length === 0) {
    warnEl.classList.add("d-none");
    warnEl.innerHTML = "";
  } else {
    warnEl.classList.remove("d-none");
    warnEl.innerHTML = `<div class="fw-bold mb-1"><i class="bi bi-exclamation-triangle me-1"></i>Warning</div><ul class="mb-0">${warnings.map(w => `<li>${escapeHtml(w)}</li>`).join("")}</ul>`;
  }
}

function applyGradingSettings() {
  const b = document.getElementById("gradingBatchSizeInput");
  const c = document.getElementById("gradingConcurrencyInput");
  const m = document.getElementById("gradingModeInput");
  const p = document.getElementById("stabilityProfileInput");
  if (!b || !c || !m || !p) return;

  const previous = {
    batchSize: GRADING_SETTINGS.batchSize,
    concurrency: GRADING_SETTINGS.concurrency,
    mode: GRADING_SETTINGS.mode,
    stabilityProfile: STABILITY_PROFILE
  };
  const newBatch = clampInt(b.value, GRADING_LIMITS.batchSize.min, GRADING_LIMITS.batchSize.max, GRADING_SETTINGS.batchSize);
  const newConc = clampInt(c.value, GRADING_LIMITS.concurrency.min, GRADING_LIMITS.concurrency.max, GRADING_SETTINGS.concurrency);
  const newMode = normalizeRunMode(m.value);
  const newProfile = normalizeStabilityProfile(p.value);

  GRADING_SETTINGS.batchSize = newBatch;
  GRADING_SETTINGS.concurrency = newConc;
  GRADING_SETTINGS.mode = newMode;
  applyStabilityProfile(newProfile, { logChange: false });
  updateRunModeInfoPreview(newMode);

  if (
    previous.batchSize !== GRADING_SETTINGS.batchSize ||
    previous.concurrency !== GRADING_SETTINGS.concurrency ||
    previous.mode !== GRADING_SETTINGS.mode ||
    previous.stabilityProfile !== STABILITY_PROFILE
  ) {
    addTweakLog("grading_settings_updated", {
      before: previous,
      after: {
        batchSize: GRADING_SETTINGS.batchSize,
        concurrency: GRADING_SETTINGS.concurrency,
        mode: GRADING_SETTINGS.mode,
        stabilityProfile: STABILITY_PROFILE
      }
    });
  }

  saveGradingSettings();
  closeGradingSettings();
}

function resetGradingSettings() {
  const previous = {
    batchSize: GRADING_SETTINGS.batchSize,
    concurrency: GRADING_SETTINGS.concurrency,
    mode: GRADING_SETTINGS.mode,
    stabilityProfile: STABILITY_PROFILE
  };
  GRADING_SETTINGS = { batchSize: 5, concurrency: 2, mode: "hybrid_extension" };
  applyStabilityProfile("standard", { logChange: false });
  addTweakLog("grading_settings_reset", {
    before: previous,
    after: {
      ...GRADING_SETTINGS,
      stabilityProfile: STABILITY_PROFILE
    }
  });
  saveGradingSettings();
  const b = document.getElementById("gradingBatchSizeInput");
  const c = document.getElementById("gradingConcurrencyInput");
  const m = document.getElementById("gradingModeInput");
  const p = document.getElementById("stabilityProfileInput");
  if (b) b.value = GRADING_SETTINGS.batchSize;
  if (c) c.value = GRADING_SETTINGS.concurrency;
  if (m) m.value = GRADING_SETTINGS.mode;
  if (p) p.value = STABILITY_PROFILE;
  updateRunModeInfoPreview(GRADING_SETTINGS.mode);
  updateStabilityProfileInfoPreview(STABILITY_PROFILE);
  updateGradingSettingsModalWarning();
}

// Live warning update while user types
document.addEventListener("input", (e) => {
  if (e.target && (e.target.id === "gradingBatchSizeInput" || e.target.id === "gradingConcurrencyInput")) {
