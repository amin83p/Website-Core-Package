function buildStep3StabilityEntryFromMeta(stabilityMeta, sourceStep3Entry, sourceSessionId) {
  const runCount = Math.max(
    2,
    toPositiveInt(
      stabilityMeta?.metrics?.runCount ??
      stabilityMeta?.runCount ??
      sourceStep3Entry?.request?.runCount,
      2
    )
  );
  const sourceTiming = sourceStep3Entry?.timing || {};
  const startedAt = toPositiveInt(sourceTiming?.startedAt, Date.now());
  const endedAt = toPositiveInt(sourceTiming?.endedAt, startedAt);
  return {
    request: {
      mode: "stability_gate_auto_consensus",
      runCount,
      loadedFromSavedSession: true,
      loadedFromSessionId: sourceSessionId
    },
    response: {
      contentType: "application/json",
      json: {
        status: "success",
        data: deepCloneJson(stabilityMeta)
      }
    },
    timing: { startedAt, endedAt }
  };
}

async function loadStep3FromSavedSession(item) {
  if (blockIfStepLocked("step3extract")) return;

  if (!GLOBALESSAYOBJECT || !GLOBALANALYSIS) {
    return safeShowMessage({
      title: "Step 1/2 Required",
      icon: "warning",
      message: "Complete Step 1 and Step 2 first, then load Step 3 from a saved session.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }

  const { sampleId, sampleName } = getStep3SavedSessionSampleContext();
  if (!sampleId) {
    return safeShowMessage({
      title: "Sample Required",
      icon: "warning",
      message: "Select the essay sample first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }

  const sourceSessionId = String(item?.id || item?.sessionId || "").trim();
  if (!sourceSessionId) {
    return safeShowMessage({
      title: "Invalid Session",
      icon: "error",
      message: "The selected saved session is missing an ID.",
      buttons: [{ text: "OK", class: "btn-danger" }]
    });
  }

  const hasDownstreamWork = Boolean(
    SESSION_BUNDLE?.steps?.step4grade ||
    SESSION_BUNDLE?.steps?.step5feedback ||
    SESSION_BUNDLE?.steps?.step6report
  );
  if (hasDownstreamWork) {
    const choice = await safeShowMessage({
      title: "Replace Step 3?",
      icon: "warning",
      message: "Loading Step 3 from history will clear current Step 4 and Step 5 results in this session. Continue?",
      buttons: [
        { text: "Cancel", class: "btn-secondary" },
        { text: "Replace Step 3", class: "btn-warning" }
      ]
    });
    if (choice !== "Replace Step 3") return;
  }

  const btnLoad = document.getElementById("btnLoadStep3FromSession");
  const btnReview = document.getElementById("btnPrepareExtract");
  const btnConsensus = document.getElementById("btnExtractConsensus");
  const originalLabel = btnLoad?.innerHTML || `<i class="bi bi-clock-history me-1"></i> Load From a Saved Session`;

  if (btnLoad) {
    btnLoad.disabled = true;
    btnLoad.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Loading...`;
  }
  if (btnReview) btnReview.disabled = true;
  if (btnConsensus) btnConsensus.disabled = true;

  try {
    const res = await fetch(`/ielts/data/scoringHistory/${encodeURIComponent(sourceSessionId)}`, {
      headers: {
        "Accept": "application/json",
        "X-AJAX-Request": "true"
      }
    });
    const contentType = String(res.headers.get("content-type") || "").toLowerCase();
    let payload = null;
    if (contentType.includes("application/json")) {
      payload = await res.json();
    } else {
      const text = await res.text();
      throw new Error(`Server returned a non-JSON response (HTTP ${res.status}). ${String(text || "").slice(0, 180)}`);
    }
    if (!res.ok) {
      throw new Error(String(payload?.message || `Failed to load session (HTTP ${res.status}).`));
    }

    const loadedSampleId = resolveSessionSampleId(payload);
    if (!loadedSampleId || loadedSampleId !== sampleId) {
      throw new Error(
        `Sample mismatch. Current sample is ${sampleId}, but the selected session uses ${loadedSampleId || "unknown"}.`
      );
    }

    const currentStep3Fingerprint = buildStep3ResearchFingerprint(SESSION_BUNDLE, { preferCurrentInputs: true });
    const sourceStep3Fingerprint = readStep3ResearchFingerprintFromSession(payload);
    const fingerprintComparison = compareStep3ResearchFingerprints(
      currentStep3Fingerprint,
      sourceStep3Fingerprint
    );
    let fingerprintOverrideAccepted = false;
    if (fingerprintComparison.hasBlockingMismatch) {
      const choice = await safeShowMessage({
        title: "Step 3 Fingerprint Mismatch",
        icon: "warning",
        message: buildStep3FingerprintMismatchMessage(fingerprintComparison),
        buttons: [
          { text: "Cancel", class: "btn-secondary" },
          { text: "Continue Anyway", class: "btn-warning" }
        ]
      });
      if (choice !== "Continue Anyway") return;
      fingerprintOverrideAccepted = true;
    }

    const sourceStep3Entry = payload?.steps?.step3extract;
    const sourceStep3Json = sourceStep3Entry?.response?.json;
    if (sourceStep3Json?.status !== "success" || !sourceStep3Json?.data) {
      throw new Error("The selected session does not contain a successful Step 3 extraction.");
    }

    clearDownstreamAfterStep3Reuse();

    const now = Date.now();
    const clonedStep3Entry = deepCloneJson(sourceStep3Entry) || {};
    if (!clonedStep3Entry.request || typeof clonedStep3Entry.request !== "object") {
      clonedStep3Entry.request = {};
    }
    clonedStep3Entry.request.loadedFromSavedSession = true;
    clonedStep3Entry.request.loadedFromSessionId = sourceSessionId;
    clonedStep3Entry.request.loadedAt = new Date().toISOString();
    if (!clonedStep3Entry.timing || typeof clonedStep3Entry.timing !== "object") {
      clonedStep3Entry.timing = { startedAt: now, endedAt: now };
    } else {
      clonedStep3Entry.timing.startedAt = toPositiveInt(clonedStep3Entry.timing.startedAt, now);
      clonedStep3Entry.timing.endedAt = toPositiveInt(clonedStep3Entry.timing.endedAt, clonedStep3Entry.timing.startedAt);
    }
    if (!clonedStep3Entry.response || typeof clonedStep3Entry.response !== "object") {
      clonedStep3Entry.response = { contentType: "application/json", json: {} };
    }
    const clonedStep3Json = clonedStep3Entry.response.json && typeof clonedStep3Entry.response.json === "object"
      ? clonedStep3Entry.response.json
      : {};
    clonedStep3Json.status = "success";
    clonedStep3Json.data = deepCloneJson(sourceStep3Json.data);
    clonedStep3Json.meta = clonedStep3Json.meta && typeof clonedStep3Json.meta === "object"
      ? clonedStep3Json.meta
      : {};
    clonedStep3Json.meta.loadedFromSavedSession = true;
    clonedStep3Json.meta.loadedFromSessionId = sourceSessionId;
    clonedStep3Json.meta.loadedFromSampleId = sampleId;
    clonedStep3Json.meta.loadedFromSampleName = sampleName;
    clonedStep3Json.meta.loadedFromSessionSavedAt = String(payload?.savedAt || payload?.metadata?.savedAt || "").trim();
    clonedStep3Json.meta.step3Fingerprint = deepCloneJson(sourceStep3Fingerprint);
    clonedStep3Json.meta.step3FingerprintComparison = {
      comparedAt: new Date().toISOString(),
      hasAnyMismatch: Boolean(fingerprintComparison.hasAnyMismatch),
      hasBlockingMismatch: Boolean(fingerprintComparison.hasBlockingMismatch),
      mismatchKeys: Array.isArray(fingerprintComparison.mismatches)
        ? fingerprintComparison.mismatches.map((row) => row.key)
        : [],
      overrideAccepted: Boolean(fingerprintOverrideAccepted),
      mismatches: deepCloneJson(fingerprintComparison.mismatches || []),
      currentFingerprint: deepCloneJson(currentStep3Fingerprint),
      sourceFingerprint: deepCloneJson(sourceStep3Fingerprint)
    };
    clonedStep3Entry.response.json = clonedStep3Json;

    SESSION_BUNDLE.steps = SESSION_BUNDLE.steps || {};
    SESSION_BUNDLE.steps.step3extract = clonedStep3Entry;

    const sourceStabilityEntry = payload?.steps?.step3stability;
    const sourceStabilityMeta = deepCloneJson(
      sourceStabilityEntry?.response?.json?.data ||
      clonedStep3Json?.meta?.stabilityGate ||
      null
    );
    if (sourceStabilityMeta && typeof sourceStabilityMeta === "object") {
      SESSION_BUNDLE.steps.step3stability = sourceStabilityEntry
        ? deepCloneJson(sourceStabilityEntry)
        : buildStep3StabilityEntryFromMeta(sourceStabilityMeta, clonedStep3Entry, sourceSessionId);
      clonedStep3Json.meta.stabilityGate = sourceStabilityMeta;
    } else {
      delete SESSION_BUNDLE.steps.step3stability;
      if (clonedStep3Json.meta?.stabilityGate) delete clonedStep3Json.meta.stabilityGate;
    }

    const resolvedExecution = syncStepExecutionRequestMeta("step3extract", {
      fallbackMode: clonedStep3Entry?.request?.mode || (sourceStabilityMeta ? "stability_gate_auto_consensus" : "single_run"),
      fallbackRunCount: clonedStep3Entry?.request?.runCount || (sourceStabilityMeta ? 3 : 1),
      stabilityMeta: sourceStabilityMeta,
      stabilityStepKey: "step3stability",
      clearStabilityOnSingleRun: true
    });

    GLOBALEXTRACTION = deepCloneJson(clonedStep3Json.data);
    GLOBALSTEP3STABILITY = sourceStabilityMeta || null;
    renderExtractionResults(GLOBALEXTRACTION, clonedStep3Json?.meta?.generatedKeys, clonedStep3Json.meta);
    document.getElementById("step3Placeholder")?.classList.add("d-none");
    document.getElementById("step3Result")?.classList.remove("d-none");

    setFreezePoint("step3_extraction_frozen", {
      promptHash: clonedStep3Json?.meta?.promptHash || "",
      schemaVersion: clonedStep3Json?.meta?.schemaVersion || "",
      fromCache: Boolean(clonedStep3Json?.meta?.fromCache),
      modelUsed: clonedStep3Json?.meta?.modelUsed || "",
      stabilityGate: Boolean(sourceStabilityMeta),
      loadedFromSavedSession: true,
      loadedFromSessionId: sourceSessionId,
      fingerprintMismatch: Boolean(fingerprintComparison.hasAnyMismatch),
      fingerprintMismatchKeys: Array.isArray(fingerprintComparison.mismatches)
        ? fingerprintComparison.mismatches.map((row) => row.key)
        : [],
      fingerprintOverrideAccepted: Boolean(fingerprintOverrideAccepted)
    });
    addTweakLog("step3_extraction_loaded_from_saved_session", {
      sourceSessionId,
      sampleId,
      executionMode: resolvedExecution?.mode || "single_run",
      runCount: resolvedExecution?.runCount || 1,
      fingerprintMismatch: Boolean(fingerprintComparison.hasAnyMismatch),
      fingerprintMismatchKeys: Array.isArray(fingerprintComparison.mismatches)
        ? fingerprintComparison.mismatches.map((row) => row.key)
        : [],
      fingerprintOverrideAccepted: Boolean(fingerprintOverrideAccepted),
      sourceStep3Fingerprint,
      currentStep3Fingerprint
    });
    SESSION_BUNDLE.researchConfig = SESSION_BUNDLE.researchConfig && typeof SESSION_BUNDLE.researchConfig === "object"
      ? SESSION_BUNDLE.researchConfig
      : {};
    SESSION_BUNDLE.researchConfig.step3Fingerprint = deepCloneJson(sourceStep3Fingerprint);
    SESSION_BUNDLE.researchConfig.step3FingerprintComparison = {
      comparedAt: new Date().toISOString(),
      hasAnyMismatch: Boolean(fingerprintComparison.hasAnyMismatch),
      hasBlockingMismatch: Boolean(fingerprintComparison.hasBlockingMismatch),
      mismatchKeys: Array.isArray(fingerprintComparison.mismatches)
        ? fingerprintComparison.mismatches.map((row) => row.key)
        : [],
      overrideAccepted: Boolean(fingerprintOverrideAccepted)
    };

    SESSION_BUNDLE.uiState = SESSION_BUNDLE.uiState || {};
    SESSION_BUNDLE.uiState.readOnlyOnLoad = false;
    SESSION_BUNDLE.dirty = true;
    renderReport();

    safeShowMessage({
      title: "Step 3 Loaded",
      icon: "check",
      message: fingerprintComparison.hasAnyMismatch
        ? `Step 3 was loaded from saved session ${sourceSessionId}. AI extraction was skipped.\n\nFingerprint differences were recorded in the session tweak log.`
        : `Step 3 was loaded from saved session ${sourceSessionId}. AI extraction was skipped.`,
      buttons: [{ text: "OK", class: "btn-success" }]
    });
  } catch (error) {
    safeShowMessage({
      title: "Load Failed",
      icon: "error",
      message: error?.message || "Could not load Step 3 from the selected session.",
      buttons: [{ text: "OK", class: "btn-danger" }]
    });
  } finally {
    if (btnLoad) {
      btnLoad.disabled = false;
      btnLoad.innerHTML = originalLabel;
    }
    if (btnReview) btnReview.disabled = false;
    if (btnConsensus) btnConsensus.disabled = false;
    updateStepLocks();
  }
}

function openStep3SavedSessionPicker() {
  if (blockIfStepLocked("step3extract")) return;
  if (!GLOBALESSAYOBJECT || !GLOBALANALYSIS) {
    return safeShowMessage({
      title: "Step 1/2 Required",
      icon: "warning",
      message: "Complete Step 1 and Step 2 first, then load Step 3 from a saved session.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }
  if (!window.GenericPicker || typeof window.GenericPicker.open !== "function") {
    return safeShowMessage({
      title: "Picker Unavailable",
      icon: "warning",
      message: "Saved session picker is not available right now.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }

  const { sampleId, sampleName } = getStep3SavedSessionSampleContext();
  if (!sampleId) {
    return safeShowMessage({
      title: "Sample Required",
      icon: "warning",
      message: "Select the essay sample first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }

  const endpoint = `/ielts/data/scoringHistory?sort=savedAt&order=desc&pickerMode=step3copy&sampleId=${encodeURIComponent(sampleId)}`;
  window.GenericPicker.open({
    title: "Load Step 3 From Saved Session",
    icon: "bi-clock-history",
    apiEndpoint: endpoint,
    placeholder: "Type to filter same-sample sessions by ID, date, model, or band...",
    searchFields: "id,sampleName,sampleId,status,pipelineMode,scoringView,savedAt,overallBand,step3ModelUsed",
    itemFilter: (session) => {
      const rowSampleId = resolveSessionSampleId(session);
      return Boolean(rowSampleId && rowSampleId === sampleId);
    },
    context: {
      label: "Current Sample",
      value: `${sampleName || sampleId} (${sampleId})`,
      icon: "bi-journal-text"
    },
    renderer: (session) => {
      const id = escapeHtml(String(session?.id || session?.sessionId || "-").trim() || "-");
      const status = String(session?.status || "In Progress").trim() || "In Progress";
      const statusClass = status === "Complete"
        ? "bg-success-subtle text-success border"
        : "bg-warning-subtle text-warning border";
      const rowSampleId = resolveSessionSampleId(session);
      const savedAt = escapeHtml(formatSavedAtLabel(session?.savedAt || session?.metadata?.savedAt));
      const overallBand = parseBandScoreOrNull(session?.overallBand);
      const overallLabel = overallBand == null ? "-" : String(overallBand);
      const pipelineLabel = escapeHtml(String(session?.pipelineLabel || session?.pipelineMode || "full").trim());
      const step3ModelLabel = escapeHtml(resolveSessionStep3ModelLabel(session) || "Unknown");
      return `
        <div class="d-flex justify-content-between align-items-center w-100 gap-3">
          <div class="overflow-hidden">
            <div class="fw-bold text-dark text-truncate">Session ${id}</div>
            <div class="small text-muted text-truncate">Saved: ${savedAt} | Mode: ${pipelineLabel} | Overall: ${escapeHtml(overallLabel)} | Step 3 Model: ${step3ModelLabel}</div>
          </div>
          <div class="d-flex flex-column align-items-end gap-1">
            <span class="badge ${statusClass}">${escapeHtml(status)}</span>
            <span class="badge bg-success-subtle text-success border">${escapeHtml(rowSampleId || sampleId)}</span>
          </div>
        </div>
      `;
    },
    onSelect: async (session) => {
      try {
        const selectedSampleId = resolveSessionSampleId(session);
        if (selectedSampleId && selectedSampleId !== sampleId) {
          return safeShowMessage({
            title: "Sample Mismatch",
            icon: "warning",
            message: `This session is for sample ${selectedSampleId}. Please pick one for sample ${sampleId}.`,
            buttons: [{ text: "OK", class: "btn-warning" }]
          });
        }
        await loadStep3FromSavedSession(session);
      } catch (error) {
        safeShowMessage({
          title: "Load Failed",
          icon: "error",
          message: error?.message || "Could not load Step 3 from this session.",
          buttons: [{ text: "OK", class: "btn-danger" }]
        });
      }
    }
  });

  // Trigger an initial fetch so users immediately see recent same-sample sessions.
  setTimeout(() => {
    const input = document.getElementById("gp-search-input");
    if (!input) return;
    input.value = "---";
    input.dispatchEvent(new Event("input", { bubbles: true }));
  }, 20);
}

function getSelectedSampleBandScore() {
  const option = getSelectedSampleOption();
  return parseBandScoreOrNull(option?.dataset?.bandScore);
}

function updateSampleBandPreview() {
  const preview = document.getElementById("sampleBandPreview");
  if (!preview) return;
  const score = getSelectedSampleBandScore();
  preview.textContent = score == null ? "-" : String(score);
}

function syncSampleReferenceMetaFromSelection(logTweak = false) {
  const option = getSelectedSampleOption();
  if (!option || !option.value) {
    GLOBALSAMPLEBANDSCORE = null;
    SESSION_BUNDLE.metadata = SESSION_BUNDLE.metadata || {};
    SESSION_BUNDLE.metadata.sampleId = null;
    SESSION_BUNDLE.metadata.sampleName = "";
    SESSION_BUNDLE.metadata.sampleRefName = "";
    SESSION_BUNDLE.metadata.sampleType = "";
    SESSION_BUNDLE.metadata.examinerBandScore = null;
    updateSampleBandPreview();
    syncSamplePickerDisplayFromSelection();
    updateActiveSampleHeaderMeta();
    return;
  }

  const previousBand = GLOBALSAMPLEBANDSCORE;
  GLOBALSAMPLEBANDSCORE = parseBandScoreOrNull(option?.dataset?.bandScore);
  SESSION_BUNDLE.metadata = SESSION_BUNDLE.metadata || {};
  SESSION_BUNDLE.metadata.sampleId = option.value;
  SESSION_BUNDLE.metadata.sampleName = option.text || "";
  SESSION_BUNDLE.metadata.sampleRefName = option?.dataset?.refName || "";
  SESSION_BUNDLE.metadata.sampleType = option?.dataset?.type || "";
  SESSION_BUNDLE.metadata.examinerBandScore = GLOBALSAMPLEBANDSCORE;

  updateSampleBandPreview();
  syncSamplePickerDisplayFromSelection();
  updateActiveSampleHeaderMeta();

  if (logTweak && (previousBand !== GLOBALSAMPLEBANDSCORE)) {
    addTweakLog("sample_reference_band_changed", {
      sampleId: option.value,
      previousBandScore: previousBand,
      nextBandScore: GLOBALSAMPLEBANDSCORE
    });
  }
}

function loadGradingSettings() {
  try {
    const raw = localStorage.getItem("ielts_grading_settings");
    if (raw) {
      const parsed = JSON.parse(raw);
      GRADING_SETTINGS.batchSize = clampInt(parsed.batchSize, GRADING_LIMITS.batchSize.min, GRADING_LIMITS.batchSize.max, GRADING_SETTINGS.batchSize);
      GRADING_SETTINGS.concurrency = clampInt(parsed.concurrency, GRADING_LIMITS.concurrency.min, GRADING_LIMITS.concurrency.max, GRADING_SETTINGS.concurrency);
      GRADING_SETTINGS.mode = normalizeRunMode(parsed.mode || GRADING_SETTINGS.mode);
      applyStabilityProfile(parsed.stabilityProfile, { logChange: false });
      STEP3_STABILITY_CONFIG.runCount = clampInt(parsed.step3RunCount, 2, 10, STEP3_STABILITY_CONFIG.runCount);
      enforceStep3ConsensusRunCount();
      STABILITY_GATE_CONFIG.runCount = clampInt(parsed.step4RunCount, 2, 10, STABILITY_GATE_CONFIG.runCount);
    }
  } catch (_) {}
  updateGradingSettingsLabels();
}

function saveGradingSettings() {
  localStorage.setItem("ielts_grading_settings", JSON.stringify({
    ...GRADING_SETTINGS,
    stabilityProfile: STABILITY_PROFILE,
    step3RunCount: STEP3_STABILITY_CONFIG.runCount,
    step4RunCount: STABILITY_GATE_CONFIG.runCount
  }));
  updateGradingSettingsLabels();
}

function updateGradingSettingsLabels() {
  const b = document.getElementById("gradingBatchSizeLabel");
  const c = document.getElementById("gradingConcurrencyLabel");
  const m = document.getElementById("gradingModeLabel");
  const p = document.getElementById("stabilityProfileLabel");
  if (b) b.textContent = String(GRADING_SETTINGS.batchSize);
  if (c) c.textContent = String(GRADING_SETTINGS.concurrency);
  if (m) m.textContent = String(GRADING_SETTINGS.mode);
  if (p) p.textContent = STABILITY_PROFILE;
  updateStabilityProfileLabels();
  updateStep4ConsensusButtonLabel();
}

function getStabilityProfileInfoText(profile) {
  const normalized = normalizeStabilityProfile(profile);
  if (normalized === "strict") {
    return "Strict: more conservative scoring; requires stronger explicit evidence and tighter consistency thresholds (Agreement >= 95%, Flip <= 5%, Unstable share <= 10%).";
  }
  return "Standard: balanced coverage and interpretation with normal stability thresholds (Agreement >= 90%, Flip <= 10%, Unstable share <= 20%).";
}

function updateStabilityProfileInfoPreview(profile, infoElementId = "stabilityProfileInfo") {
  const info = document.getElementById(infoElementId);
  if (!info) return;
  info.textContent = getStabilityProfileInfoText(profile);
}

function getRunModeInfoText(mode) {
  const normalized = normalizeRunMode(mode);
  if (normalized === "operationalized_only") {
    return "operationalized_only: only operationalized deterministic checks are used. This is stricter and often more repeatable, but may miss nuanced coverage.";
  }
  return "hybrid_extension: combines deterministic operationalized checks with AI-extended checks for broader coverage and richer interpretation.";
}

function updateRunModeInfoPreview(mode) {
  const info = document.getElementById("gradingModeInfo");
  if (!info) return;
  info.textContent = getRunModeInfoText(mode);
}

