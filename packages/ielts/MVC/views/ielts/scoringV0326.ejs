function formatSavedAtLabel(value) {
  const txt = String(value || "").trim();
  if (!txt) return "-";
  const date = new Date(txt);
  if (Number.isNaN(date.getTime())) return txt;
  return date.toLocaleString();
}

const STEP3_FINGERPRINT_MISSING_TOKENS = new Set([
  "",
  "unknown",
  "unspecified",
  "n/a",
  "na",
  "none",
  "null",
  "undefined"
]);

function normalizeFingerprintToken(value) {
  return String(value ?? "").trim();
}

function normalizeFingerprintCompareToken(value) {
  return normalizeFingerprintToken(value).toLowerCase();
}

function isMissingFingerprintToken(value) {
  return STEP3_FINGERPRINT_MISSING_TOKENS.has(normalizeFingerprintCompareToken(value));
}

function toFingerprintDisplay(value) {
  const token = normalizeFingerprintToken(value);
  return token || "unspecified";
}

function buildStep3ResearchFingerprint(bundle = SESSION_BUNDLE, { preferCurrentInputs = false } = {}) {
  const srcBundle = bundle && typeof bundle === "object" ? bundle : {};
  const researchConfig = srcBundle.researchConfig && typeof srcBundle.researchConfig === "object"
    ? srcBundle.researchConfig
    : {};
  const metadata = srcBundle.metadata && typeof srcBundle.metadata === "object"
    ? srcBundle.metadata
    : {};
  const uiState = srcBundle.uiState && typeof srcBundle.uiState === "object"
    ? srcBundle.uiState
    : {};
  const step3RequestPayload = srcBundle?.steps?.step3extract?.request?.payload || {};
  const step3Meta = srcBundle?.steps?.step3extract?.response?.json?.meta || {};

  const savedModels = (
    uiState?.selectedModels && typeof uiState.selectedModels === "object"
      ? uiState.selectedModels
      : researchConfig?.selectedModels && typeof researchConfig.selectedModels === "object"
        ? researchConfig.selectedModels
        : {}
  );
  const savedProviders = (
    uiState?.selectedProviders && typeof uiState.selectedProviders === "object"
      ? uiState.selectedProviders
      : researchConfig?.selectedProviders && typeof researchConfig.selectedProviders === "object"
        ? researchConfig.selectedProviders
        : {}
  );

  const sourcePrompt = sanitizeStep3PromptSource(
    uiState?.step3PromptSource ||
      researchConfig?.promptSources?.step3 ||
      step3RequestPayload?.promptSource ||
      STEP3_PROMPT_SOURCE_BUILTIN
  );
  const sourceTemplateId = normalizeFingerprintToken(
    uiState?.step3PromptTemplate?.id ||
      step3RequestPayload?.promptTemplateId ||
      ""
  );
  const sourceModelId = normalizeFingerprintToken(
    savedModels?.step3 ||
      step3RequestPayload?.options?.modelId ||
      step3RequestPayload?.modelId ||
      step3Meta?.selectedModel ||
      ""
  );
  const sourceProviderId = normalizeFingerprintToken(
    savedProviders?.step3 ||
      step3RequestPayload?.options?.providerId ||
      step3RequestPayload?.providerId ||
      ""
  );

  const promptSource = preferCurrentInputs
    ? sanitizeStep3PromptSource(STEP3_PROMPT_SOURCE)
    : sourcePrompt;
  const promptTemplateId = preferCurrentInputs
    ? normalizeFingerprintToken(STEP3_SELECTED_TEMPLATE?.id || "")
    : sourceTemplateId;
  const step3ModelId = preferCurrentInputs
    ? normalizeFingerprintToken(getSelectedStep3ModelId() || "")
    : sourceModelId;
  const step3ProviderId = preferCurrentInputs
    ? normalizeFingerprintToken(getSelectedStep3ProviderId() || "")
    : sourceProviderId;

  const schemaVersion = normalizeFingerprintToken(
    step3Meta?.schemaVersion ||
      researchConfig?.schemaVersion ||
      `${srcBundle?.schema || SESSION_BUNDLE?.schema || "scoring_session"}@v${srcBundle?.version || SESSION_BUNDLE?.version || "1"}`
  );
  const microBankVersion = normalizeFingerprintToken(
    researchConfig?.microBankVersion ||
      metadata?.microBankVersion ||
      "unspecified"
  );
  const rulesVersion = normalizeFingerprintToken(
    researchConfig?.rulesVersion ||
      metadata?.rulesVersion ||
      "unspecified"
  );
  const promptHash = normalizeFingerprintToken(step3Meta?.promptHash || "");

  return {
    schemaVersion,
    microBankVersion,
    rulesVersion,
    step3PromptSource: promptSource,
    step3PromptTemplateId: promptTemplateId,
    step3ModelId,
    step3ProviderId,
    step3PromptHash: promptHash
  };
}

function readStep3ResearchFingerprintFromSession(sessionLike) {
  const session = sessionLike && typeof sessionLike === "object" ? sessionLike : {};
  const savedFingerprint = session?.researchConfig?.step3Fingerprint;
  if (savedFingerprint && typeof savedFingerprint === "object") {
    return {
      schemaVersion: normalizeFingerprintToken(savedFingerprint.schemaVersion || ""),
      microBankVersion: normalizeFingerprintToken(savedFingerprint.microBankVersion || ""),
      rulesVersion: normalizeFingerprintToken(savedFingerprint.rulesVersion || ""),
      step3PromptSource: sanitizeStep3PromptSource(savedFingerprint.step3PromptSource || STEP3_PROMPT_SOURCE_BUILTIN),
      step3PromptTemplateId: normalizeFingerprintToken(savedFingerprint.step3PromptTemplateId || ""),
      step3ModelId: normalizeFingerprintToken(savedFingerprint.step3ModelId || ""),
      step3ProviderId: normalizeFingerprintToken(savedFingerprint.step3ProviderId || ""),
      step3PromptHash: normalizeFingerprintToken(savedFingerprint.step3PromptHash || "")
    };
  }
  return buildStep3ResearchFingerprint(session, { preferCurrentInputs: false });
}

function compareStep3ResearchFingerprints(currentFingerprint, sourceFingerprint) {
  const current = currentFingerprint && typeof currentFingerprint === "object"
    ? currentFingerprint
    : {};
  const source = sourceFingerprint && typeof sourceFingerprint === "object"
    ? sourceFingerprint
    : {};
  const mismatches = [];

  function maybeAddMismatch({ key, label, blocking, currentValue, sourceValue, reason }) {
    mismatches.push({
      key,
      label,
      blocking: Boolean(blocking),
      reason,
      currentValue: normalizeFingerprintToken(currentValue),
      sourceValue: normalizeFingerprintToken(sourceValue),
      currentDisplay: toFingerprintDisplay(currentValue),
      sourceDisplay: toFingerprintDisplay(sourceValue)
    });
  }

  function compareStrict(key, label) {
    const currentValue = normalizeFingerprintToken(current[key] || "");
    const sourceValue = normalizeFingerprintToken(source[key] || "");
    const currentMissing = isMissingFingerprintToken(currentValue);
    const sourceMissing = isMissingFingerprintToken(sourceValue);
    if (currentMissing && sourceMissing) return;
    if (currentMissing !== sourceMissing) {
      maybeAddMismatch({
        key,
        label,
        blocking: true,
        currentValue,
        sourceValue,
        reason: "missing"
      });
      return;
    }
    if (normalizeFingerprintCompareToken(currentValue) !== normalizeFingerprintCompareToken(sourceValue)) {
      maybeAddMismatch({
        key,
        label,
        blocking: true,
        currentValue,
        sourceValue,
        reason: "different"
      });
    }
  }

  function compareOptional(key, label) {
    const currentValue = normalizeFingerprintToken(current[key] || "");
    const sourceValue = normalizeFingerprintToken(source[key] || "");
    if (isMissingFingerprintToken(currentValue) || isMissingFingerprintToken(sourceValue)) return;
    if (normalizeFingerprintCompareToken(currentValue) !== normalizeFingerprintCompareToken(sourceValue)) {
      maybeAddMismatch({
        key,
        label,
        blocking: false,
        currentValue,
        sourceValue,
        reason: "different"
      });
    }
  }

  compareStrict("schemaVersion", "Schema Version");
  compareStrict("microBankVersion", "Micro Bank Version");
  compareStrict("rulesVersion", "Rules Version");
  compareStrict("step3PromptSource", "Step 3 Prompt Source");

  const sourcePromptSource = sanitizeStep3PromptSource(source.step3PromptSource || STEP3_PROMPT_SOURCE_BUILTIN);
  const currentPromptSource = sanitizeStep3PromptSource(current.step3PromptSource || STEP3_PROMPT_SOURCE_BUILTIN);
  if (sourcePromptSource === STEP3_PROMPT_SOURCE_TEMPLATE || currentPromptSource === STEP3_PROMPT_SOURCE_TEMPLATE) {
    compareStrict("step3PromptTemplateId", "Step 3 Prompt Template");
  }

  compareOptional("step3ModelId", "Step 3 Model");
  compareOptional("step3ProviderId", "Step 3 Provider");
  compareOptional("step3PromptHash", "Step 3 Prompt Hash");

  const blockingMismatches = mismatches.filter((m) => m.blocking);
  return {
    mismatches,
    blockingMismatches,
    hasAnyMismatch: mismatches.length > 0,
    hasBlockingMismatch: blockingMismatches.length > 0
  };
}

function buildStep3FingerprintMismatchMessage(comparison) {
  const list = Array.isArray(comparison?.mismatches) ? comparison.mismatches : [];
  if (!list.length) return "";
  const lines = list
    .slice(0, 8)
    .map((row) => `- ${row.label}: current "${row.currentDisplay}" vs source "${row.sourceDisplay}"`);
  const extra = list.length > 8 ? `\n- ... and ${list.length - 8} more mismatch(es)` : "";
  return `Step 3 fingerprint mismatch detected.\n\n${lines.join("\n")}${extra}\n\nContinue anyway?`;
}

function syncStep3ResearchFingerprint({ preferCurrentInputs = false } = {}) {
  SESSION_BUNDLE.researchConfig = SESSION_BUNDLE.researchConfig && typeof SESSION_BUNDLE.researchConfig === "object"
    ? SESSION_BUNDLE.researchConfig
    : {};
  SESSION_BUNDLE.researchConfig.step3Fingerprint = buildStep3ResearchFingerprint(SESSION_BUNDLE, {
    preferCurrentInputs
  });
}

