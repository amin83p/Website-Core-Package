<div class="sections-page">
  <div class="d-flex justify-content-end align-items-center gap-2 flex-wrap mb-2">
    <a id="btnDashboard" href="<%= ieltsSectionDashboardHref %>" class="ielts-navigator-dashboard btn btn-secondary btn-filled text-white btn-sm d-inline-flex align-items-center gap-1">
      <i class="bi bi-speedometer2"></i>
      <span>IELTS Dashboard</span>
    </a>
    <a href="/ielts/scoring/dashboard" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1">
      <i class="bi bi-graph-up-arrow"></i>
      <span>Scoring Dashboard</span>
    </a>
  </div>
  <div class="score-header-wrap mb-4">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-2">
      <div>
        <h2 class="page-heading size-md m-0"><%= (pipelineMode === 'step3_tuning') ? 'Step 3 Tuning Lab' : ((pipelineMode === 'step4_tuning') ? 'Step 4 Tuning Lab' : 'Scoring Pipeline V0326') %></h2>
        <div class="text-muted small mt-1"><%= (pipelineMode === 'step3_tuning') ? 'Run Step 1-3 repeatedly and compare Step 3 extraction differences.' : ((pipelineMode === 'step4_tuning') ? 'Run Step 1-4 with model and run tuning for Step 3 and Step 4.' : 'Deterministic & AI-Assisted Evaluation.') %></div>
        <div id="activeSampleHeaderMeta" class="d-flex align-items-center gap-2 flex-wrap mt-2 d-none">
          <span class="badge bg-light text-dark border">
            <i class="bi bi-journal-text me-1"></i><span id="activeSampleHeaderName">-</span>
          </span>
          <span class="badge bg-light text-secondary border font-monospace">
            ID: <span id="activeSampleHeaderId">-</span>
          </span>
        </div>
      </div>
    </div>

    <!-- Timing Row -->
    <div id="timingBar" class="score-timing-bar mt-3">
      <div class="timing-pill timing-total">
        <span class="timing-label">Total</span>
        <span id="timerTotal" class="timing-value">-</span>
      </div>
      <div class="timing-pill">
        <span class="timing-label">S1</span>
        <span id="timerStep1" class="timing-value">-</span>
      </div>
      <div class="timing-pill">
        <span class="timing-label">S2</span>
        <span id="timerStep2" class="timing-value">-</span>
      </div>
      <div class="timing-pill">
        <span class="timing-label">S3</span>
        <span id="timerStep3" class="timing-value">-</span>
      </div>
      <div class="timing-pill">
        <span class="timing-label">S4</span>
        <span id="timerStep4" class="timing-value">-</span>
      </div>
      <div class="timing-pill">
        <span class="timing-label">S5</span>
        <span id="timerStep5" class="timing-value">-</span>
      </div>
      <div id="timerRunningBadge" class="timing-pill timing-running d-none">
        <span class="timing-label">Running</span>
        <span class="timing-value"><span id="timerRunningLabel">-</span> (<span id="timerRunningValue">0.00s</span>)</span>
      </div>
    </div>

    <!-- Action Row -->
    <div class="score-action-row d-flex flex-wrap gap-2 mt-3">
      <button id="btnSaveServer" onclick="saveToServer()" class="btn btn-primary btn-filled btn-sm">
        <i class="bi bi-cloud-upload me-1"></i> Save to Cloud
      </button>

      <button id="btnSaveFile" onclick="saveProgress()" class="btn btn-filled btn-primary btn-sm">
        <i class="bi bi-download me-1"></i> Save to File
      </button>

      <button id="btnLoadFileTrigger" onclick="document.getElementById('loadProgressInput').click()" class="btn btn-filled btn-success btn-sm">
        <i class="bi bi-upload me-1"></i> Load from File
      </button>
      <input type="file" id="loadProgressInput" accept=".json" style="display:none;" onchange="loadProgress(event)">

      <button id="btnStartNew" onclick="startNewReport()" class="btn btn-filled btn-warning btn-sm">
        <i class="bi bi-plus-circle me-1"></i> New / Start
      </button>
    </div>
  </div>

  <div id="sessionLockBanner" class="alert alert-warning py-2 px-3 mt-2 mb-0 d-none small" role="alert"></div>

    <div class="card border-0 shadow-sm mb-4">
        <div class="card-body p-0">
            <div class="d-flex justify-content-between text-center" id="stepperContainer">
                
                <div class="step-item flex-fill p-3 border-bottom border-primary border-3 bg-light active" data-step="1">
                    <div class="fw-bold text-primary">Step 1</div>
                    <div class="small text-muted">Freeze Inputs</div>
                </div>

                <div class="step-item flex-fill p-3 border-bottom text-muted" data-step="2">
                    <div class="fw-bold">Step 2</div>
                    <div class="small opacity-75">Analysis</div>
                </div>

                <div class="step-item flex-fill p-3 border-bottom text-muted" data-step="3">
                    <div class="fw-bold">Step 3</div>
                    <div class="small opacity-75">AI Extraction</div>
                </div>

                <div class="step-item flex-fill p-3 border-bottom text-muted" data-step="4">
                    <div class="fw-bold">Step 4</div>
                    <div class="small opacity-75">Grading</div>
                </div>

                <div class="step-item flex-fill p-3 border-bottom text-muted" data-step="5">
                    <div class="fw-bold">Step 5</div>
                    <div class="small opacity-75">Feedback</div>
                </div>
                
                <div class="step-item flex-fill p-3 border-bottom text-muted" data-step="6">
                    <div class="fw-bold">Step 6</div>
                    <div class="small opacity-75">Report</div>
                </div>

            </div>
        </div>
    </div>

    <div class="tab-content" id="pipelineStepsContent">
        
        <div class="tab-pane fade show active" id="step1">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-dark mb-3"><i class="bi bi-snow2 me-2"></i>Select Sample</h6>
                            <p class="small text-muted">Select an essay to create a canonical "frozen" object for grading.</p>
                            
                            <div class="input-group mb-2">
                                <input id="sampleSelectDisplay" type="text" class="form-control" placeholder="Pick an essay sample..." readonly>
                                <button id="btnPickSample" type="button" class="btn btn-outline-primary" onclick="openSampleEssayPicker()">
                                    <i class="bi bi-search me-1"></i> Pick
                                </button>
                                <button id="btnClearSample" type="button" class="btn btn-outline-secondary" onclick="clearSelectedSampleEssay()" title="Clear selection">
                                    <i class="bi bi-x-lg"></i>
                                </button>
                            </div>
                            <div class="form-text mb-2">Use picker search by reference, type, band, or ID.</div>

                            <select id="sampleSelect" class="form-select mb-3 d-none">
                                <option value="">-- Select Essay --</option>
                                <% if(samples && samples.length > 0) { %>
                                    <% samples.forEach(s => { %>
                                        <option
                                          value="<%= s.id %>"
                                          data-band-score="<%= (s.bandScore !== undefined && s.bandScore !== null && s.bandScore !== '') ? s.bandScore : '' %>"
                                          data-ref-name="<%= s.refName || '' %>"
                                          data-type="<%= s.type || '' %>"
                                        ><%= s.refName %> (<%= s.type %>)</option>
                                    <% }) %>
                                <% } %>
                            </select>
                            <div class="small text-muted mb-3">
                                Examiner Reference Band:
                                <span id="sampleBandPreview" class="badge bg-light text-dark border font-monospace">-</span>
                            </div>

                            <button id="btnFreeze" class="btn btn-primary w-100 fw-bold" onclick="runFreezeStep()" data-no-wait="true">
                                <i class="bi bi-snow2 me-1"></i> Freeze Inputs
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-md-8">
                     <div id="step1Placeholder" class="text-center py-5 text-muted border rounded bg-light">
                        <i class="bi bi-box-seam fs-1 d-block mb-2 opacity-50"></i>
                        Select an essay and click Freeze to generate the object.
                    </div>

                     <div id="step1Result" class="d-none">
                        
                        <ul class="nav nav-tabs mb-3" id="step1Tabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active small fw-bold" id="s1-visual-tab" data-bs-toggle="tab" data-bs-target="#s1-visual-pane" type="button">Visual Summary</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link small fw-bold text-muted" id="s1-canonical-tab" data-bs-toggle="tab" data-bs-target="#s1-canonical-pane" type="button">Canonical Output</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link small fw-bold text-muted" id="s1-json-tab" data-bs-toggle="tab" data-bs-target="#s1-json-pane" type="button">Raw Object (JSON)</button>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="s1-visual-pane">
                                <div class="row g-3 mb-3">
                                    <div class="col-3">
                                        <div class="p-3 border rounded bg-white text-center shadow-sm">
                                            <div class="display-6 fw-bold text-primary" id="resWordCount">-</div>
                                            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Words</div>
                                        </div>
                                    </div>
                                    <div class="col-3">
                                        <div class="p-3 border rounded bg-white text-center shadow-sm">
                                            <div class="display-6 fw-bold text-success" id="resSentCount">-</div>
                                            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Sentences</div>
                                        </div>
                                    </div>
                                    <div class="col-3">
                                        <div class="p-3 border rounded bg-white text-center shadow-sm">
                                            <div class="display-6 fw-bold text-info" id="resParaCount">-</div>
                                            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Paragraphs</div>
                                        </div>
                                    </div>
                                    <div class="col-3">
                                        <div class="p-3 border rounded bg-white text-center shadow-sm">
                                            <div class="display-6 fw-bold text-dark" id="resCharCount">-</div>
                                            <div class="small text-muted text-uppercase fw-bold" style="font-size: 0.7rem;">Chars</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="mb-3 small text-muted">
                                  Examiner Reference Band:
                                  <span id="step1ExaminerBand" class="badge bg-light text-dark border font-monospace">-</span>
                                </div>

                                <div class="card shadow-sm border-0 mb-3">
                                    <div class="card-header bg-white fw-bold small text-muted">Canonical Text</div>
                                    <div class="card-body bg-light p-2">
                                        <div id="resNormalizedText" class="p-2 bg-white border rounded small font-monospace" style="max-height:350px; overflow:auto; white-space: pre-wrap;"></div>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="s1-canonical-pane">
                                <div class="card shadow-sm border-0 mb-3">
                                    <div class="card-header bg-white fw-bold small text-muted d-flex justify-content-between align-items-center">
                                      <span>Step 1 Canonical Summary</span>
                                      <button type="button" class="btn btn-outline-primary btn-sm" onclick="openCanonicalViewer()">
                                        <i class="bi bi-layout-text-window-reverse me-1"></i> Open Responsive Viewer
                                      </button>
                                    </div>
                                    <div class="card-body">
                                      <div class="row g-3 mb-3">
                                        <div class="col-md-3">
                                          <div class="small text-muted fw-bold text-uppercase">Words</div>
                                          <div id="s1CanonicalWords" class="h5 m-0">-</div>
                                        </div>
                                        <div class="col-md-3">
                                          <div class="small text-muted fw-bold text-uppercase">Sentences</div>
                                          <div id="s1CanonicalSentences" class="h5 m-0">-</div>
                                        </div>
                                        <div class="col-md-3">
                                          <div class="small text-muted fw-bold text-uppercase">Paragraphs</div>
                                          <div id="s1CanonicalParagraphs" class="h5 m-0">-</div>
                                        </div>
                                        <div class="col-md-3">
                                          <div class="small text-muted fw-bold text-uppercase">Chars</div>
                                          <div id="s1CanonicalChars" class="h5 m-0">-</div>
                                        </div>
                                      </div>

                                      <div class="card border-0 shadow-sm mb-3">
                                        <div class="card-header bg-light fw-bold small">Paragraph Map</div>
                                        <div class="card-body p-0">
                                          <div class="table-responsive">
                                            <table class="table table-sm align-middle mb-0 small">
                                              <thead class="table-light">
                                                <tr>
                                                  <th>Paragraph</th>
                                                  <th class="text-center">Sentence Count</th>
                                                  <th>Text Preview</th>
                                                </tr>
                                              </thead>
                                              <tbody id="s1CanonicalParagraphRows">
                                                <tr><td colspan="3" class="text-muted text-center py-3">Run Step 1 to view canonical paragraph mapping.</td></tr>
                                              </tbody>
                                            </table>
                                          </div>
                                        </div>
                                      </div>

                                      <div class="card border-0 shadow-sm">
                                        <div class="card-header bg-light fw-bold small">Sentence Map</div>
                                        <div class="card-body p-0">
                                          <div class="table-responsive">
                                            <table class="table table-sm align-middle mb-0 small">
                                              <thead class="table-light">
                                                <tr>
                                                  <th>Sentence</th>
                                                  <th>Paragraph</th>
                                                  <th>Text</th>
                                                </tr>
                                              </thead>
                                              <tbody id="s1CanonicalSentenceRows">
                                                <tr><td colspan="3" class="text-muted text-center py-3">Run Step 1 to view canonical sentence mapping.</td></tr>
                                              </tbody>
                                            </table>
                                          </div>
                                        </div>
                                      </div>

                                      <details class="card border-0 shadow-sm mt-3">
                                        <summary class="card-header bg-light fw-bold small" style="cursor:pointer;">Complete Canonical Object (Structured)</summary>
                                        <div class="card-body bg-dark rounded-bottom p-0">
                                          <pre id="s1CanonicalJsonMirror" class="text-success m-0 p-3 small font-monospace" style="max-height: 320px; overflow-y: auto;"></pre>
                                        </div>
                                      </details>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="s1-json-pane">
                                <div class="card shadow-sm border-0">
                                    <div class="card-body bg-dark rounded p-0">
                                        <div class="d-flex justify-content-between align-items-center bg-secondary px-3 py-1 rounded-top">
                                            <span class="text-white small font-monospace">essayObject.json</span>
                                            <button class="btn btn-sm btn-link text-decoration-none" onclick="copyJson('resJsonStruct')">
                                                <i class="bi bi-clipboard"></i> Copy
                                            </button>
                                        </div>
                                        <pre id="resJsonStruct" class="text-success m-0 p-3 small font-monospace" style="max-height: 400px; overflow-y: auto;"></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-end mt-3 d-flex justify-content-between align-items-center">
                            <button class="btn btn-outline-secondary" onclick="activateStep(1)" style="visibility: hidden;">
                                <i class="bi bi-arrow-left"></i> Previous
                            </button>
                            <button id="btnNextToStep2" class="btn btn-primary" onclick="activateStep(2)">
                                Next: Analysis <i class="bi bi-arrow-right"></i>
                            </button>
                        </div>
                     </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="step2">
            <div class="row g-4">
                <div class="col-md-3">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-dark mb-3">Feature Extraction</h6>
                            <ul class="small text-muted ps-3 mb-4">
                                <li>Structure Analysis</li>
                                <li>Cohesion Density</li>
                                <li>Lexical Repetition</li>
                            </ul>
                            <button id="btnAnalyze" class="btn btn-secondary w-100 fw-bold" onclick="runAnalysisStep()" data-no-wait="true">
                                <i class="bi bi-bar-chart-fill me-1"></i> Run Analysis
                            </button>
                        </div>
                    </div>
                </div>

                <div class="col-md-9">
                     <div id="step2Placeholder" class="text-center py-5 text-muted border rounded bg-light">
                        <i class="bi bi-search fs-1 d-block mb-2 opacity-50"></i>
                        Waiting for analysis...
                    </div>

                     <div id="step2Result" class="d-none">
                        
                        <ul class="nav nav-tabs mb-3" id="step2Tabs" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active small fw-bold" id="s2-visual-tab" data-bs-toggle="tab" data-bs-target="#s2-visual-pane" type="button">Visual Report</button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link small fw-bold text-muted" id="s2-json-tab" data-bs-toggle="tab" data-bs-target="#s2-json-pane" type="button">Raw Features (JSON)</button>
                            </li>
                        </ul>

                        <div class="tab-content">
                            <div class="tab-pane fade show active" id="s2-visual-pane">
                                <div class="card shadow-sm border-0 mb-3">
                                    <div class="card-header bg-white fw-bold text-primary"><i class="bi bi-layout-text-window-reverse me-2"></i>Structure</div>
                                    <div class="card-body">
                                        <div class="row text-center" id="structureViz"></div>
                                        <div class="mt-2 text-muted small d-flex justify-content-center gap-3">
                                            <span id="flagIntro"></span>
                                            <span id="flagConclusion"></span>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="card shadow-sm border-0 h-100">
                                            <div class="card-header bg-white fw-bold text-info small">Cohesion</div>
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between mb-1 small"><span>Density:</span><span class="fw-bold" id="connDensity">-</span></div>
                                                <div class="d-flex justify-content-between mb-2 small"><span>Variety:</span><span class="fw-bold" id="connVariety">-</span></div>
                                                <div id="connTags" class="d-flex flex-wrap gap-1"></div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="card shadow-sm border-0 h-100">
                                            <div class="card-header bg-white fw-bold text-warning small">Lexical</div>
                                            <div class="card-body">
                                                <div class="d-flex justify-content-between mb-2 small"><span>Ref. Density:</span><span class="fw-bold" id="refDensity">-</span></div>
                                                <ul class="list-unstyled small m-0" id="repWordsList"></ul>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="card shadow-sm border-0 mt-3">
                                    <div class="card-header bg-white fw-bold text-dark small">Per Paragraph Features</div>
                                    <div class="card-body p-0">
                                        <div class="table-responsive">
                                            <table class="table table-sm align-middle mb-0 small">
                                                <thead class="table-light">
                                                    <tr>
                                                        <th>Para</th>
                                                        <th>Role</th>
                                                        <th class="text-center">Sentences</th>
                                                        <th class="text-center">Conn Density</th>
                                                        <th class="text-center">Conn Density (No Basic)</th>
                                                        <th class="text-center">Ref Density</th>
                                                        <th>Repeated Words</th>
                                                        <th class="text-center">Conclusion Signpost</th>
                                                    </tr>
                                                </thead>
                                                <tbody id="perParagraphFeatureRows">
                                                    <tr><td colspan="8" class="text-muted text-center py-3">Run Step 2 to generate per-paragraph features.</td></tr>
                                                </tbody>
                                            </table>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="tab-pane fade" id="s2-json-pane">
                                <div class="card shadow-sm border-0">
                                    <div class="card-body bg-dark rounded p-0">
                                        <div class="d-flex justify-content-between align-items-center bg-secondary px-3 py-1 rounded-top">
                                            <span class="text-white small font-monospace">analysisFeatures.json</span>
                                            <button class="btn btn-sm btn-link text-decoration-none" onclick="copyJson('resJsonFeatures')">
                                                <i class="bi bi-clipboard"></i> Copy
                                            </button>
                                        </div>
                                        <pre id="resJsonFeatures" class="text-success m-0 p-3 small font-monospace" style="max-height: 450px; overflow-y: auto;"></pre>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="text-end mt-3">
                            <button class="btn btn-primary" onclick="activateStep(3)">Next: AI Extraction <i class="bi bi-arrow-right"></i></button>
                        </div>
                     </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="step3">
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body">
                            <h6 class="fw-bold text-purple mb-3" style="color: #6f42c1;"><i class="bi bi-robot me-2"></i>Evidence Locator</h6>
                            <p class="small text-muted">Locate evidence refs (S#) for stance, topic sentences, and support.</p>
                            
                            <div class="d-none">
                                <input type="text" id="subQKeys">
                            </div>

                            <div class="mt-2 mb-3 p-2 border rounded bg-light">
                                <label class="form-label small fw-bold mb-1">Step 3 Prompt Source</label>
                                <div class="d-flex flex-column gap-1">
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="step3PromptSource" id="step3PromptSourceBuiltIn" value="builtin" checked onchange="onStep3PromptSourceChange(this.value)">
                                        <label class="form-check-label small" for="step3PromptSourceBuiltIn">Use built-in prompt</label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="step3PromptSource" id="step3PromptSourceTemplate" value="template" onchange="onStep3PromptSourceChange(this.value)">
                                        <label class="form-check-label small" for="step3PromptSourceTemplate">Pick prompt template</label>
                                    </div>
                                </div>
                                <div id="step3TemplatePickerWrap" class="mt-2 d-none">
                                    <div class="d-flex flex-wrap gap-2 mb-2">
                                        <button type="button" id="btnStep3PickTemplate" class="btn btn-outline-primary btn-sm" onclick="openStep3PromptTemplatePicker()">
                                            <i class="bi bi-search me-1"></i> Pick Template
                                        </button>
                                        <button type="button" id="btnStep3ClearTemplate" class="btn btn-outline-secondary btn-sm" onclick="clearStep3PromptTemplate()">
                                            <i class="bi bi-x-circle me-1"></i> Clear
                                        </button>
                                    </div>
                                    <div id="step3TemplateSelectedText" class="small text-muted">No template selected.</div>
                                </div>
                            </div>

                            <button id="btnPrepareExtract" class="btn text-white w-100 fw-bold" style="background-color: #6f42c1;" onclick="prepareExtraction()" data-no-wait="true">
                                <i class="bi bi-eye me-1"></i> Review & Extract (Single Run)
                            </button>
                            <button id="btnLoadStep3FromSession" type="button" class="btn btn-outline-primary w-100 fw-bold mt-2" onclick="openStep3SavedSessionPicker()">
                                <i class="bi bi-clock-history me-1"></i> Load From a Saved Session
                            </button>
