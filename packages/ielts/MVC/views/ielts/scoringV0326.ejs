  const btnClearSample = document.getElementById("btnClearSample");
  if (btnClearSample) btnClearSample.disabled = freezeLocked;

  const btnFreeze = document.getElementById("btnFreeze");
  if (btnFreeze) {
    btnFreeze.disabled = freezeLocked;
    btnFreeze.title = freezeLocked ? "Step 1 is locked for this session." : "";
  }

  const btnAnalyze = document.getElementById("btnAnalyze");
  if (btnAnalyze) {
    btnAnalyze.disabled = analyzeLocked;
    btnAnalyze.title = analyzeLocked ? "Step 2 is locked for this session." : "";
  }

  const btnExtract = document.getElementById("btnPrepareExtract");
  if (btnExtract) {
    btnExtract.disabled = extractLocked;
    btnExtract.title = extractLocked ? "Step 3 is locked for this session." : "";
