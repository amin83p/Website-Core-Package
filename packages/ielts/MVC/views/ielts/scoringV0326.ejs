    delete SESSION_BUNDLE.freezePoints.step4_scoring_frozen;
    delete SESSION_BUNDLE.freezePoints.step4_stability_gate_frozen;
    delete SESSION_BUNDLE.freezePoints.step5_feedback_frozen;
  }

  GLOBALGRADING = null;
  GLOBALFEEDBACK = null;
  GLOBALSTABILITY = null;

  renderStabilityGateDisplay(null);

  const step4Result = document.getElementById("step4Result");
  if (step4Result) step4Result.classList.add("d-none");
  const step4Placeholder = document.getElementById("step4Placeholder");
