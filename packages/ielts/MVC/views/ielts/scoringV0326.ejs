  const step5Placeholder = document.getElementById("step5Placeholder");
  if (step5Placeholder) step5Placeholder.classList.remove("d-none");

  SESSION_BUNDLE.dirty = true;
  refreshTimingUI();
  renderReport();
}

function hasStepEntry(stepKey) {
  const entry = SESSION_BUNDLE?.steps?.[stepKey];
  return Boolean(entry && (entry.request || entry.response || entry.timing));
}

