  const btnLoadStep3FromSession = document.getElementById("btnLoadStep3FromSession");
  if (btnLoadStep3FromSession) {
    btnLoadStep3FromSession.disabled = extractLocked;
    btnLoadStep3FromSession.title = extractLocked ? "Step 3 is locked for this session." : "";
  }
  const btnExtractConsensus = document.getElementById("btnExtractConsensus");
  if (btnExtractConsensus) {
    btnExtractConsensus.disabled = extractLocked;
    btnExtractConsensus.title = extractLocked ? "Step 3 is locked for this session." : "";
  }

  const btnGrade = document.getElementById("btnGrade");
  if (btnGrade) {
    btnGrade.disabled = gradeLocked;
    btnGrade.title = gradeLocked ? "Step 4 is locked for this session." : "";
  }

  const btnStabilityGate = document.getElementById("btnStabilityGate");
  if (btnStabilityGate) {
    btnStabilityGate.disabled = gradeLocked;
    btnStabilityGate.title = gradeLocked ? "Step 4 is locked for this session." : "";
  }

  const btnFeedback = document.getElementById("btnFeedback");
  if (btnFeedback) {
    btnFeedback.disabled = feedbackLocked;
    btnFeedback.title = feedbackLocked ? "Step 5 is locked for this session." : "";
  }

  const reviewPrompt = document.getElementById("reviewPromptText");
  if (reviewPrompt) reviewPrompt.readOnly = extractLocked || SESSION_READONLY;
  const step3PromptSourceBuiltIn = document.getElementById("step3PromptSourceBuiltIn");
  const step3PromptSourceTemplate = document.getElementById("step3PromptSourceTemplate");
  const btnStep3PickTemplate = document.getElementById("btnStep3PickTemplate");
  const btnStep3ClearTemplate = document.getElementById("btnStep3ClearTemplate");
  if (step3PromptSourceBuiltIn) step3PromptSourceBuiltIn.disabled = extractLocked || SESSION_READONLY;
  if (step3PromptSourceTemplate) step3PromptSourceTemplate.disabled = extractLocked || SESSION_READONLY;
  if (btnStep3PickTemplate) btnStep3PickTemplate.disabled = extractLocked || SESSION_READONLY;
  if (btnStep3ClearTemplate) btnStep3ClearTemplate.disabled = extractLocked || SESSION_READONLY;
  const step4PromptSourceBuiltIn = document.getElementById("step4PromptSourceBuiltIn");
