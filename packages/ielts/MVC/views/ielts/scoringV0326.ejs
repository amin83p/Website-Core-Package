function renderReportResponsiveEssayPreview() {
  const body = document.getElementById("reportResponsiveEssayBody");
  if (!body) return;
  const paragraphs = Array.isArray(GLOBALESSAYOBJECT?.paragraphs) ? GLOBALESSAYOBJECT.paragraphs : [];
  const sentences = Array.isArray(GLOBALESSAYOBJECT?.sentences) ? GLOBALESSAYOBJECT.sentences : [];
  if (!paragraphs.length || !sentences.length) {
    body.innerHTML = `<div class="text-muted small">No canonical sample content found.</div>`;
    return;
  }

  const sentenceByParagraph = new Map();
  sentences.forEach((s) => {
    const p = Number.isInteger(s?.paragraphIndex) ? s.paragraphIndex : null;
    if (p == null) return;
    if (!sentenceByParagraph.has(p)) sentenceByParagraph.set(p, []);
    sentenceByParagraph.get(p).push(s);
  });

  const html = paragraphs.map((p) => {
    const pIdx = Number.isInteger(p?.index) ? p.index : 0;
    const pLabel = escapeHtml(p?.displayParagraphId || `P${pIdx + 1}`);
    const pSentences = sentenceByParagraph.get(pIdx) || [];
    const sentenceHtml = pSentences.map((s) => {
      const sIdx = Number.isInteger(s?.index) ? s.index : 0;
      const sLabel = escapeHtml(s?.displaySentenceId || `S${sIdx + 1}`);
      const onclick = `openCanonicalViewerByIndex(${pIdx}, ${sIdx})`;
      return `<span class="report-responsive-sentence" title="${pLabel}  |  ${sLabel}" onclick="${onclick}">${escapeHtml(String(s?.text || ""))}</span>`;
    }).join(" ");

    return `
      <div class="border rounded bg-light p-3 mb-2">
        <div class="small text-muted fw-bold mb-1">${pLabel}</div>
        <div class="small">${sentenceHtml || '<span class="text-muted small">No sentence detected.</span>'}</div>
      </div>
    `;
  }).join("");

  body.innerHTML = html;
}

function printReport() {
  const printable = document.getElementById("reportPrintable");
  if (!printable) return;
  const w = window.open("", "_blank");
  w.document.write(`
    <html><head>
      <title>IELTS Report</title>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    </head>
    <body class="p-3">
      ${printable.innerHTML}
    </body></html>
  `);
  w.document.close();
  w.focus();
  w.print();
}

function downloadReportHtml() {
  const printable = document.getElementById("reportPrintable");
  if (!printable) return;

  const html = `
<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>IELTS Session Report</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="p-3">
${printable.innerHTML}
</body>
</html>
  `.trim();

  const stamp = new Date().toISOString().slice(0,19).replace(/[:T]/g,"-");
  const blob = new Blob([html], { type: "text/html" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = `scoring-report-${stamp}.html`;
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
}

/* =========================================================
   Step 1: Freeze
   ========================================================= */
async function runFreezeStep() {
  if (blockIfStepLocked("step1freeze")) return;
  syncSampleReferenceMetaFromSelection(false);
  const sampleSelectEl = document.getElementById("sampleSelect");
  GLOBALSAMPLEID = sampleSelectEl?.value;
  const btn = document.getElementById("btnFreeze");

  if (!GLOBALSAMPLEID) {
    return safeShowMessage({
      title: "Validation",
      icon: "warning",
      message: "Please select an essay first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }

  btn.disabled = true;
  btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Processing...`;

  try {
    const r = await postJsonAndRecord("step1freeze", "/ielts/scoring/step1/freeze", { sampleId: GLOBALSAMPLEID });
    if (r.status !== "success") throw new Error(r.message || "Freeze failed.");

    GLOBALESSAYOBJECT = r.data;
    const responseBandScore = parseBandScoreOrNull(r?.meta?.sampleBandScore);
    if (responseBandScore != null) GLOBALSAMPLEBANDSCORE = responseBandScore;

    // Also store metadata for exports
    SESSION_BUNDLE.metadata.sampleId = GLOBALSAMPLEID;
    SESSION_BUNDLE.metadata.sampleName = sampleSelectEl?.selectedOptions?.[0]?.text || "";
    SESSION_BUNDLE.metadata.examinerBandScore = GLOBALSAMPLEBANDSCORE;
    SESSION_BUNDLE.metadata.sampleFeedback = String(r?.meta?.sampleFeedback || "");
    SESSION_BUNDLE.metadata.sampleType = String(r?.meta?.type || sampleSelectEl?.selectedOptions?.[0]?.dataset?.type || "");
    SESSION_BUNDLE.metadata.sampleRefName = String(r?.meta?.refName || sampleSelectEl?.selectedOptions?.[0]?.dataset?.refName || "");

    setFreezePoint("step1_input_frozen", {
      sampleId: GLOBALSAMPLEID,
      sampleName: SESSION_BUNDLE.metadata.sampleName || "",
      examinerBandScore: GLOBALSAMPLEBANDSCORE,
      wordCount: r?.data?.stats?.wordCount ?? null,
      sentenceCount: r?.data?.stats?.sentenceCount ?? null,
      paragraphCount: r?.data?.stats?.paragraphCount ?? null
    });
    addTweakLog("step1_freeze_completed", {
      sampleId: GLOBALSAMPLEID,
      examinerBandScore: GLOBALSAMPLEBANDSCORE
    });
    updateSampleBandPreview();

    renderFreezeFromData(r.data);
  } catch (e) {
    console.error(e);
    safeShowMessage({
      title: "Network/Error",
      icon: "error",
      message: e.message || "Failed to connect to server.",
      buttons: [{ text: "OK", class: "btn-danger" }]
    });
  } finally {
    btn.disabled = false;
    btn.innerHTML = `<i class="bi bi-snow2 me-1"></i> Freeze Inputs`;
    updateStepLocks();
  }
}

/* =========================================================
   Step 2: Analysis (FIXED: sets GLOBALANALYSIS, not GLOBALGRADING)
   ========================================================= */
async function runAnalysisStep() {
  if (blockIfStepLocked("step2analyze")) return;
  if (!GLOBALESSAYOBJECT) {
    return safeShowMessage({
      title: "Step 1 Missing",
      icon: "warning",
      message: "Complete Step 1 first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }

  const btn = document.getElementById("btnAnalyze");
  btn.disabled = true;
  btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Analyzing...`;

  try {
    const r = await postJsonAndRecord("step2analyze", "/ielts/scoring/step2/analyze", { essayObject: GLOBALESSAYOBJECT });
    if (r.status !== "success") throw new Error(r.message || "Analysis failed.");

    const d = r.data;
    GLOBALANALYSIS = d; // <-- correct
    GLOBALPARAGRAPHROLES = d?.structure?.paragraphRoles ?? null;
    setFreezePoint("step2_features_frozen", {
      paragraphCount: d?.structure?.paragraphCount ?? null,
      hasIntro: d?.structure?.hasIntro ?? null,
      hasConclusion: d?.structure?.hasConclusion ?? null,
      cohesionDensity: d?.cohesion?.densityPer100 ?? null
    });

    renderAnalysisFromData(d);
  } catch (e) {
    console.error(e);
    safeShowMessage({
      title: "Analysis Error",
      icon: "error",
      message: e.message || "Failed to analyze.",
      buttons: [{ text: "OK", class: "btn-danger" }]
    });
  } finally {
    btn.disabled = false;
    btn.innerHTML = `<i class="bi bi-bar-chart-fill me-1"></i> Run Analysis`;
    updateStepLocks();
  }
}

/* =========================================================
   Step 3: Prompt Preview + Extraction
   ========================================================= */
const STEP3_MISSING = "__MISSING__";
const STEP4_MISSING = "__MISSING_STEP4__";
const STEP5_MISSING = "__MISSING_STEP5__";

function buildStep3Payload(customPrompt = "", options = null) {
  const payload = {
    sampleId: GLOBALSAMPLEID,
    essayObject: GLOBALESSAYOBJECT,
    promptSource: sanitizeStep3PromptSource(STEP3_PROMPT_SOURCE),
    promptTemplateId: String(STEP3_SELECTED_TEMPLATE?.id || "").trim()
  };
  const selectedModelId = getSelectedStep3ModelId();
  const selectedProviderId = getSelectedStep3ProviderId();
  const selectedApiProviderId = getSelectedStep3ApiProviderId();
  if (selectedModelId) payload.modelId = selectedModelId;
  if (selectedProviderId) payload.providerId = selectedProviderId;
  if (selectedApiProviderId) payload.apiProviderId = selectedApiProviderId;
  const prompt = String(customPrompt || "").trim();
  if (prompt) payload.customPrompt = prompt;
  const mergedOptions = {
    stabilityProfile: STABILITY_PROFILE,
    ...(options && typeof options === "object" ? options : {})
  };
  const cancelToken = String(mergedOptions.cancelToken || "").trim();
  if (cancelToken) {
    payload.cancelToken = cancelToken;
  }
  if (selectedProviderId) {
    mergedOptions.providerId = selectedProviderId;
  }
  if (selectedApiProviderId) {
    mergedOptions.apiProviderId = selectedApiProviderId;
  }
  if (selectedModelId) {
    mergedOptions.disableCache = true;
  }
  payload.options = mergedOptions;
  return payload;
}

function normalizeIntList(list) {
  const out = [];
  const seen = new Set();
  for (const v of (Array.isArray(list) ? list : [])) {
    const n = Number(v);
    if (!Number.isInteger(n) || n < 0) continue;
    if (seen.has(n)) continue;
    seen.add(n);
    out.push(n);
  }
  out.sort((a, b) => a - b);
  return out;
}

function parseIntListString(value) {
  const txt = String(value ?? "").trim();
  if (!txt) return [];
  return normalizeIntList(txt.split(",").map((s) => s.trim()).filter(Boolean).map((s) => Number(s)));
}

function intListToString(list) {
  return normalizeIntList(list).join(",");
}

function getBodySupportMap(extraction) {
  const map = new Map();
  for (const row of (Array.isArray(extraction?.bodySupport) ? extraction.bodySupport : [])) {
    const p = Number(row?.paragraphIndex);
    if (!Number.isInteger(p) || p < 0) continue;
    map.set(p, {
      paragraphIndex: p,
      hasExplanation: Boolean(row?.hasExplanation),
      hasExample: Boolean(row?.hasExample),
      evidenceSentenceIndices: normalizeIntList(row?.evidenceSentenceIndices)
    });
  }
  return map;
}

function getTopicMap(extraction) {
  const map = new Map();
  for (const row of (Array.isArray(extraction?.topicSentenceByParagraph) ? extraction.topicSentenceByParagraph : [])) {
    const p = Number(row?.paragraphIndex);
    const s = row?.topicSentenceIndex;
    if (!Number.isInteger(p) || p < 0) continue;
    map.set(p, Number.isInteger(s) ? s : null);
  }
  return map;
}

function buildStep3SignalMap(extraction) {
  const map = new Map();
  const pos = extraction?.position || {};
  map.set("position.stance", String(pos?.stance || "unclear"));
  map.set(
    "position.stanceSentenceIndex",
    Number.isInteger(pos?.stanceSentenceIndex) ? String(pos.stanceSentenceIndex) : "null"
  );
  map.set("position.contradictions", intListToString(pos?.contradictionSentenceIndices));

  const answers = extraction?.answersBySubquestion || {};
  Object.keys(answers).sort().forEach((key) => {
    map.set(`answers.${key}`, intListToString(answers[key]));
  });

  const bodyMap = getBodySupportMap(extraction);
  Array.from(bodyMap.keys()).sort((a, b) => a - b).forEach((p) => {
    const row = bodyMap.get(p);
    map.set(`body.P${p}.hasExplanation`, row?.hasExplanation ? "true" : "false");
    map.set(`body.P${p}.hasExample`, row?.hasExample ? "true" : "false");
    map.set(`body.P${p}.evidence`, intListToString(row?.evidenceSentenceIndices));
  });

  const topicMap = getTopicMap(extraction);
  Array.from(topicMap.keys()).sort((a, b) => a - b).forEach((p) => {
    const idx = topicMap.get(p);
    map.set(`topic.P${p}`, Number.isInteger(idx) ? String(idx) : "null");
  });

  const lq = extraction?.lexicalQuality || {};
  if (lq?.range) map.set("lexicalQuality.range", String(lq.range));
  if (lq?.precision) map.set("lexicalQuality.precision", String(lq.precision));
  if (lq?.uncommonSkill) map.set("lexicalQuality.uncommonSkill", String(lq.uncommonSkill));

  const ep = extraction?.errorProfiles || {};
  if (ep?.grammar) map.set("errorProfiles.grammar", String(ep.grammar));
  if (ep?.lexical) map.set("errorProfiles.lexical", String(ep.lexical));
  if (ep?.punctuation) map.set("errorProfiles.punctuation", String(ep.punctuation));

  const lc = extraction?.lexicalControl || {};
  if (lc?.rangeBand) map.set("lexicalControl.rangeBand", String(lc.rangeBand));
  if (lc?.precisionBand) map.set("lexicalControl.precisionBand", String(lc.precisionBand));
  if (lc?.collocationControl) map.set("lexicalControl.collocationControl", String(lc.collocationControl));
  if (lc?.awkwardExpressionCountBand) map.set("lexicalControl.awkwardExpressionCountBand", String(lc.awkwardExpressionCountBand));
  if (lc?.spellingImpact) map.set("lexicalControl.spellingImpact", String(lc.spellingImpact));
  if (lc?.wordFormationImpact) map.set("lexicalControl.wordFormationImpact", String(lc.wordFormationImpact));
  if (lc?.repetitionImpact) map.set("lexicalControl.repetitionImpact", String(lc.repetitionImpact));
  if (lc?.clarityImpactFromLexis) map.set("lexicalControl.clarityImpactFromLexis", String(lc.clarityImpactFromLexis));

  const gc = extraction?.grammarControl || {};
  if (gc?.structureRange) map.set("grammarControl.structureRange", String(gc.structureRange));
  if (gc?.complexSentenceControl) map.set("grammarControl.complexSentenceControl", String(gc.complexSentenceControl));
  if (gc?.errorFrequency) map.set("grammarControl.errorFrequency", String(gc.errorFrequency));
  if (gc?.subjectVerbAgreement) map.set("grammarControl.subjectVerbAgreement", String(gc.subjectVerbAgreement));
  if (gc?.articleControl) map.set("grammarControl.articleControl", String(gc.articleControl));
  if (gc?.prepositionControl) map.set("grammarControl.prepositionControl", String(gc.prepositionControl));
  if (gc?.punctuationControl) map.set("grammarControl.punctuationControl", String(gc.punctuationControl));
  if (gc?.sentenceBoundaryControl) map.set("grammarControl.sentenceBoundaryControl", String(gc.sentenceBoundaryControl));
  if (gc?.clarityImpactFromGrammar) map.set("grammarControl.clarityImpactFromGrammar", String(gc.clarityImpactFromGrammar));
  if (gc?.errorFreeSentenceShareBand) map.set("grammarControl.errorFreeSentenceShareBand", String(gc.errorFreeSentenceShareBand));

  return map;
}

function isStep3ListSignalKey(key) {
  return key === "position.contradictions" || key.startsWith("answers.") || /body\.P\d+\.evidence$/.test(key);
}

function voteScalarSignal(values) {
  const present = values.filter((v) => v !== STEP3_MISSING);
  const fallback = present.length ? present[0] : values[0];
  const freq = new Map();
  present.forEach((v) => freq.set(v, (freq.get(v) || 0) + 1));
  const ranked = Array.from(freq.entries()).sort((a, b) => b[1] - a[1] || String(a[0]).localeCompare(String(b[0])));
  const topCount = ranked[0]?.[1] || 0;
  const winners = ranked.filter(([, count]) => count === topCount);
  const hasMajority = topCount >= 2 && winners.length === 1;
  const selected = hasMajority ? winners[0][0] : fallback;
  const tie = !hasMajority && new Set(present).size > 1;
  return { selected, tie };
}

function voteListSignal(values) {
  const parsed = values.map((v) => (v === STEP3_MISSING ? null : parseIntListString(v)));
  const nonMissing = parsed.filter((arr) => Array.isArray(arr));
  const fallback = nonMissing.length ? nonMissing[0] : [];
  const counts = new Map();
  nonMissing.forEach((arr) => {
    arr.forEach((idx) => counts.set(idx, (counts.get(idx) || 0) + 1));
  });
  const voted = Array.from(counts.entries())
    .filter(([, count]) => count >= 2)
    .map(([idx]) => idx)
    .sort((a, b) => a - b);
  const allEmpty = nonMissing.every((arr) => arr.length === 0);
  if (voted.length || allEmpty) {
    return { selected: intListToString(voted), tie: false };
  }
  return { selected: intListToString(fallback), tie: true };
}

function computeStep3Consensus(extractions) {
  const runMaps = extractions.map((e) => buildStep3SignalMap(e));
  const allKeys = new Set();
  runMaps.forEach((m) => m.forEach((_, key) => allKeys.add(key)));
  const keys = Array.from(allKeys).sort();

  const consensusMap = new Map();
  const unstableRows = [];
  const allRows = [];
  let changedCount = 0;
  let tieCount = 0;
  let adjacentComparisons = 0;
  let adjacentFlips = 0;

  keys.forEach((key) => {
    const values = runMaps.map((m) => (m.has(key) ? m.get(key) : STEP3_MISSING));
    const presentValues = values.filter((v) => v !== STEP3_MISSING);
    if (!presentValues.length) return;

    const uniqueValues = new Set(presentValues);
    const unstable = uniqueValues.size > 1;

    for (let i = 1; i < values.length; i += 1) {
      const prev = values[i - 1];
      const curr = values[i];
      if (prev === STEP3_MISSING || curr === STEP3_MISSING) continue;
      adjacentComparisons += 1;
      if (prev !== curr) adjacentFlips += 1;
    }

    const vote = isStep3ListSignalKey(key) ? voteListSignal(values) : voteScalarSignal(values);
    const selected = vote.selected;
    consensusMap.set(key, selected);

    const baseline = values[0] === STEP3_MISSING ? presentValues[0] : values[0];
    const changed = baseline !== selected;
    if (changed) changedCount += 1;
    if (vote.tie) tieCount += 1;

    if (unstable) {
      unstableRows.push({
        key,
        runValues: values.map((v) => (v === STEP3_MISSING ? "-" : v)),
        consensusValue: selected,
        changed,
        tie: vote.tie
      });
    }
    allRows.push({
      key,
      runValues: values.map((v) => (v === STEP3_MISSING ? "-" : v)),
      consensusValue: selected,
      changed,
      tie: vote.tie
    });
  });

  const pairwise = [];
  for (let i = 0; i < runMaps.length; i += 1) {
    for (let j = i + 1; j < runMaps.length; j += 1) {
      let comparisons = 0;
      let agreements = 0;
      keys.forEach((key) => {
        const a = runMaps[i].has(key) ? runMaps[i].get(key) : STEP3_MISSING;
        const b = runMaps[j].has(key) ? runMaps[j].get(key) : STEP3_MISSING;
        if (a === STEP3_MISSING || b === STEP3_MISSING) return;
        comparisons += 1;
        if (a === b) agreements += 1;
      });
      pairwise.push({
        runA: i + 1,
        runB: j + 1,
        comparisons,
        agreements,
        agreementRate: comparisons > 0 ? agreements / comparisons : null
      });
    }
  }

  const agreementValues = pairwise.map((p) => p.agreementRate).filter((v) => Number.isFinite(v));
  const meanAgreement = agreementValues.length
    ? agreementValues.reduce((a, b) => a + b, 0) / agreementValues.length
    : null;
  const flipRate = adjacentComparisons > 0 ? adjacentFlips / adjacentComparisons : 0;
  const unstableShare = keys.length ? unstableRows.length / keys.length : 0;
  const gatePassed =
    Number.isFinite(meanAgreement) &&
    meanAgreement >= STEP3_STABILITY_CONFIG.minMeanAgreement &&
    flipRate <= STEP3_STABILITY_CONFIG.maxFlipRate &&
    unstableShare <= STEP3_STABILITY_CONFIG.maxUnstableShare;

  unstableRows.sort((a, b) => {
    if (a.tie !== b.tie) return a.tie ? -1 : 1;
    if (a.changed !== b.changed) return a.changed ? -1 : 1;
    return String(a.key).localeCompare(String(b.key));
  });

  return {
    consensusMap,
    unstableRows,
    allRows,
    metrics: {
      runCount: extractions.length,
      totalSignals: keys.length,
      unstableCount: unstableRows.length,
      unstableShare,
      changedCount,
      tieCount,
      adjacentComparisons,
      adjacentFlips,
      flipRate,
      meanAgreement,
      pairwise,
      gatePassed
    }
  };
}

function buildStep3SingleRunStability(extraction) {
  const signalMap = buildStep3SignalMap(extraction);
  const allRows = Array.from(signalMap.entries())
    .map(([key, value]) => ({
      key,
      runValues: [String(value)],
      consensusValue: String(value),
      changed: false,
      tie: false
    }))
    .sort((a, b) => String(a.key).localeCompare(String(b.key)));

  return {
    topUnstable: [],
    allSignals: allRows,
    metrics: {
      runCount: 1,
      totalSignals: allRows.length,
      unstableCount: 0,
      unstableShare: 0,
      changedCount: 0,
      tieCount: 0,
      adjacentComparisons: 0,
      adjacentFlips: 0,
      flipRate: 0,
      meanAgreement: 1,
      pairwise: [],
      gatePassed: true
    }
  };
}

function extractionFromConsensusMap(consensusMap, baseExtraction) {
  const base = deepCloneJson(baseExtraction || {});
  const out = (base && typeof base === "object" && !Array.isArray(base))
    ? deepCloneJson(base)
    : {};
  out.position = {
    stance: "unclear",
    stanceSentenceIndex: null,
    contradictionSentenceIndices: []
  };
  out.answersBySubquestion = {};
  out.bodySupport = [];
  out.topicSentenceByParagraph = [];

  const getSignal = (key, fallback) => (consensusMap.has(key) ? consensusMap.get(key) : fallback);

  const basePos = base?.position || {};
  out.position.stance = String(getSignal("position.stance", basePos?.stance || "unclear"));
  const stanceIdxRaw = String(getSignal(
    "position.stanceSentenceIndex",
    Number.isInteger(basePos?.stanceSentenceIndex) ? String(basePos.stanceSentenceIndex) : "null"
  ));
  out.position.stanceSentenceIndex = /^\d+$/.test(stanceIdxRaw) ? Number(stanceIdxRaw) : null;
  out.position.contradictionSentenceIndices = parseIntListString(getSignal(
    "position.contradictions",
    intListToString(basePos?.contradictionSentenceIndices)
  ));

  const answerKeys = new Set([
    ...Object.keys(base?.answersBySubquestion || {}),
    ...Array.from(consensusMap.keys())
      .filter((k) => k.startsWith("answers."))
      .map((k) => k.slice("answers.".length))
  ]);
  Array.from(answerKeys).sort().forEach((k) => {
    const fallback = intListToString(base?.answersBySubquestion?.[k]);
    out.answersBySubquestion[k] = parseIntListString(getSignal(`answers.${k}`, fallback));
  });

  const baseBody = getBodySupportMap(base);
  const bodyParagraphs = new Set([
    ...Array.from(baseBody.keys()),
    ...Array.from(consensusMap.keys())
      .map((k) => {
        const m = k.match(/^body\.P(\d+)\./);
        return m ? Number(m[1]) : null;
      })
      .filter((n) => Number.isInteger(n))
  ]);
  out.bodySupport = Array.from(bodyParagraphs).sort((a, b) => a - b).map((p) => {
    const row = baseBody.get(p);
    const hasExplanationRaw = getSignal(`body.P${p}.hasExplanation`, row?.hasExplanation ? "true" : "false");
    const hasExampleRaw = getSignal(`body.P${p}.hasExample`, row?.hasExample ? "true" : "false");
    const evidenceRaw = getSignal(`body.P${p}.evidence`, intListToString(row?.evidenceSentenceIndices));
    return {
      paragraphIndex: p,
      hasExplanation: String(hasExplanationRaw) === "true",
      hasExample: String(hasExampleRaw) === "true",
      evidenceSentenceIndices: parseIntListString(evidenceRaw)
    };
  });

  const baseTopic = getTopicMap(base);
  const topicParagraphs = new Set([
    ...Array.from(baseTopic.keys()),
    ...Array.from(bodyParagraphs),
    ...Array.from(consensusMap.keys())
      .map((k) => {
        const m = k.match(/^topic\.P(\d+)$/);
        return m ? Number(m[1]) : null;
      })
      .filter((n) => Number.isInteger(n))
  ]);
  out.topicSentenceByParagraph = Array.from(topicParagraphs).sort((a, b) => a - b).map((p) => {
    const baseValue = baseTopic.has(p) ? baseTopic.get(p) : null;
    const raw = String(getSignal(`topic.P${p}`, Number.isInteger(baseValue) ? String(baseValue) : "null"));
    return {
      paragraphIndex: p,
      topicSentenceIndex: /^\d+$/.test(raw) ? Number(raw) : null
    };
  });

  const lexical = base?.lexicalQuality || {};
  const range = getSignal("lexicalQuality.range", lexical?.range || "");
  const precision = getSignal("lexicalQuality.precision", lexical?.precision || "");
  const uncommonSkill = getSignal("lexicalQuality.uncommonSkill", lexical?.uncommonSkill || "");
  if (range || precision || uncommonSkill) {
    out.lexicalQuality = {
      range: String(range || lexical?.range || "basic"),
      precision: String(precision || lexical?.precision || "low"),
      uncommonSkill: String(uncommonSkill || lexical?.uncommonSkill || "none")
    };
  }

  const errors = base?.errorProfiles || {};
  const grammar = getSignal("errorProfiles.grammar", errors?.grammar || "");
  const lexicalErr = getSignal("errorProfiles.lexical", errors?.lexical || "");
  const punctuation = getSignal("errorProfiles.punctuation", errors?.punctuation || "");
  if (grammar || lexicalErr || punctuation) {
    out.errorProfiles = {
      grammar: String(grammar || errors?.grammar || "frequent"),
      lexical: String(lexicalErr || errors?.lexical || "frequent"),
      punctuation: String(punctuation || errors?.punctuation || "frequent")
    };
  }

  const lexicalControlBase = base?.lexicalControl || {};
  const lexicalControl = {
    rangeBand: String(getSignal("lexicalControl.rangeBand", lexicalControlBase?.rangeBand || "")),
    precisionBand: String(getSignal("lexicalControl.precisionBand", lexicalControlBase?.precisionBand || "")),
    collocationControl: String(getSignal("lexicalControl.collocationControl", lexicalControlBase?.collocationControl || "")),
    awkwardExpressionCountBand: String(getSignal("lexicalControl.awkwardExpressionCountBand", lexicalControlBase?.awkwardExpressionCountBand || "")),
    spellingImpact: String(getSignal("lexicalControl.spellingImpact", lexicalControlBase?.spellingImpact || "")),
    wordFormationImpact: String(getSignal("lexicalControl.wordFormationImpact", lexicalControlBase?.wordFormationImpact || "")),
    repetitionImpact: String(getSignal("lexicalControl.repetitionImpact", lexicalControlBase?.repetitionImpact || "")),
    clarityImpactFromLexis: String(getSignal("lexicalControl.clarityImpactFromLexis", lexicalControlBase?.clarityImpactFromLexis || ""))
  };
  if (Object.values(lexicalControl).some((v) => String(v || "").trim() !== "")) {
    out.lexicalControl = lexicalControl;
  }

  const grammarControlBase = base?.grammarControl || {};
  const grammarControl = {
    structureRange: String(getSignal("grammarControl.structureRange", grammarControlBase?.structureRange || "")),
    complexSentenceControl: String(getSignal("grammarControl.complexSentenceControl", grammarControlBase?.complexSentenceControl || "")),
    errorFrequency: String(getSignal("grammarControl.errorFrequency", grammarControlBase?.errorFrequency || "")),
    subjectVerbAgreement: String(getSignal("grammarControl.subjectVerbAgreement", grammarControlBase?.subjectVerbAgreement || "")),
    articleControl: String(getSignal("grammarControl.articleControl", grammarControlBase?.articleControl || "")),
    prepositionControl: String(getSignal("grammarControl.prepositionControl", grammarControlBase?.prepositionControl || "")),
    punctuationControl: String(getSignal("grammarControl.punctuationControl", grammarControlBase?.punctuationControl || "")),
    sentenceBoundaryControl: String(getSignal("grammarControl.sentenceBoundaryControl", grammarControlBase?.sentenceBoundaryControl || "")),
    clarityImpactFromGrammar: String(getSignal("grammarControl.clarityImpactFromGrammar", grammarControlBase?.clarityImpactFromGrammar || "")),
    errorFreeSentenceShareBand: String(getSignal("grammarControl.errorFreeSentenceShareBand", grammarControlBase?.errorFreeSentenceShareBand || ""))
  };
  if (Object.values(grammarControl).some((v) => String(v || "").trim() !== "")) {
    out.grammarControl = grammarControl;
  }

  return out;
}

function updateStep3StabilityTabEmptyState() {
  const empty = document.getElementById("step3StabilityEmpty");
  const stabilityPanel = document.getElementById("step3StabilityPanel");
  const runDiffPanel = document.getElementById("step3RunDiffPanel");
  if (!empty || !stabilityPanel || !runDiffPanel) return;
  const hasVisibleCard = !stabilityPanel.classList.contains("d-none") || !runDiffPanel.classList.contains("d-none");
  empty.classList.toggle("d-none", hasVisibleCard);
}

function renderStep3RunDiffPanel(stabilityMeta) {
  const panel = document.getElementById("step3RunDiffPanel");
  const metaEl = document.getElementById("step3RunDiffMeta");
  const headEl = document.getElementById("step3RunDiffHead");
  const bodyEl = document.getElementById("step3RunDiffRows");
  if (!panel || !metaEl || !headEl || !bodyEl) return;

  const rows = Array.isArray(stabilityMeta?.allSignals) ? stabilityMeta.allSignals : [];
  if (!rows.length) {
    panel.classList.add("d-none");
    metaEl.innerHTML = "";
    headEl.innerHTML = "";
    bodyEl.innerHTML = "";
    updateStep3StabilityTabEmptyState();
    return;
  }

  const inferredFromRows = (rows[0] && Array.isArray(rows[0].runValues)) ? rows[0].runValues.length : 0;
  const runCount = Math.max(1, Number(stabilityMeta?.metrics?.runCount || inferredFromRows || 1));
  const changedCount = rows.filter((row) => row?.changed).length;
  const runLabel = runCount + (runCount === 1 ? " run" : " runs");
  metaEl.innerHTML = "Compared <span class=\"fw-bold\">" + rows.length + "</span> signals across <span class=\"fw-bold\">" + runLabel + "</span>. Differences detected in <span class=\"fw-bold\">" + changedCount + "</span> signals.";

  const headCols = ['<th class="step3-signal-col">Signal</th>'];
  for (let i = 1; i <= runCount; i += 1) headCols.push(`<th class="text-center">R${i}</th>`);
  headCols.push('<th class="text-center">Consensus</th><th class="text-center">Status</th>');
  headEl.innerHTML = headCols.join("");

  const ordered = rows.slice().sort((a, b) => {
    if (Boolean(a?.changed) !== Boolean(b?.changed)) return a?.changed ? -1 : 1;
    return String(a?.key || "").localeCompare(String(b?.key || ""));
  });

  bodyEl.innerHTML = ordered.map((row) => {
    const runValues = Array.isArray(row?.runValues) ? row.runValues : [];
    const runCells = [];
    for (let i = 0; i < runCount; i += 1) {
      runCells.push(`<td class="text-center">${renderStep3SignalValueHtml(String(row?.key || ""), runValues[i] ?? "-")}</td>`);
    }
    const status = row?.changed
      ? `<span class="badge bg-warning text-dark">Different</span>`
      : `<span class="badge bg-light text-dark border">Stable</span>`;
    return `
      <tr>
        <td class="font-monospace step3-signal-col">${escapeHtml(String(row?.key || "-"))}</td>
        ${runCells.join("")}
        <td class="text-center fw-bold">${renderStep3SignalValueHtml(String(row?.key || ""), row?.consensusValue || "-")}</td>
        <td class="text-center">${status}</td>
      </tr>
    `;
  }).join("");

  panel.classList.remove("d-none");
  updateStep3StabilityTabEmptyState();
}

function renderStep3Stability(stabilityMeta) {
  const sidebar = document.getElementById("step3StabilitySidebar");
  const panel = document.getElementById("step3StabilityPanel");
  const metaEl = document.getElementById("step3StabilityMeta");
  const rowsEl = document.getElementById("step3StabilityRows");
  const thresholdSummary = formatStabilityThresholdSummary(STEP3_STABILITY_CONFIG);

  if (!stabilityMeta) {
    if (sidebar) {
      sidebar.innerHTML = `
        <div class="small text-muted">Step 3 stability has not been run.</div>
        <div class="small text-muted">Profile: <span class="fw-bold">${escapeHtml(STABILITY_PROFILE)}</span></div>
        <div class="small text-muted">${escapeHtml(thresholdSummary)}</div>
      `;
    }
    if (panel) panel.classList.add("d-none");
    if (metaEl) metaEl.innerHTML = "";
    if (rowsEl) rowsEl.innerHTML = "";
    renderStep3RunDiffPanel(null);
    updateStep3StabilityTabEmptyState();
    return;
  }

  const m = stabilityMeta.metrics || {};
  const meanAgreement = Number.isFinite(Number(m.meanAgreement)) ? `${(Number(m.meanAgreement) * 100).toFixed(1)}%` : "-";
  const flipRate = Number.isFinite(Number(m.flipRate)) ? `${(Number(m.flipRate) * 100).toFixed(1)}%` : "-";
  const unstableShare = Number.isFinite(Number(m.unstableShare)) ? `${(Number(m.unstableShare) * 100).toFixed(1)}%` : "-";
  const gateBadge = m.gatePassed
    ? `<span class="badge bg-success">PASS</span>`
    : `<span class="badge bg-warning text-dark">REVIEW</span>`;

  if (sidebar) {
    sidebar.innerHTML = `
      <div class="d-flex align-items-center gap-2 mb-1">${gateBadge}<span class="small text-muted">Step 3 gate</span></div>
      <div class="small text-muted">Profile: <span class="fw-bold">${escapeHtml(STABILITY_PROFILE)}</span></div>
      <div class="small text-muted">${escapeHtml(thresholdSummary)}</div>
      <div class="small text-muted">Agreement: <span class="fw-bold">${escapeHtml(meanAgreement)}</span></div>
      <div class="small text-muted">Flip rate: <span class="fw-bold">${escapeHtml(flipRate)}</span></div>
      <div class="small text-muted">Unstable: <span class="fw-bold">${escapeHtml(String(m.unstableCount ?? "-"))}</span> / ${escapeHtml(String(m.totalSignals ?? "-"))}</div>
    `;
  }

  if (!panel || !metaEl || !rowsEl) return;
  panel.classList.remove("d-none");
  metaEl.innerHTML = `
    ${gateBadge}
    <span class="ms-2">Runs: <span class="fw-bold">${escapeHtml(String(m.runCount ?? "-"))}</span></span>
    <span class="ms-2">Mean agreement: <span class="fw-bold">${escapeHtml(meanAgreement)}</span></span>
    <span class="ms-2">Flip rate: <span class="fw-bold">${escapeHtml(flipRate)}</span></span>
    <span class="ms-2">Unstable share: <span class="fw-bold">${escapeHtml(unstableShare)}</span></span>
  `;

  const rows = Array.isArray(stabilityMeta.topUnstable) ? stabilityMeta.topUnstable : [];
  if (!rows.length) {
    rowsEl.innerHTML = `<tr><td colspan="4" class="text-muted small text-center py-2">No unstable Step 3 signals detected across ${escapeHtml(String(m.runCount || STEP3_STABILITY_CONFIG.runCount || 3))} runs.</td></tr>`;
  } else {
    rowsEl.innerHTML = rows.slice(0, 12).map((row) => {
      const runValues = Array.isArray(row?.runValues)
        ? row.runValues.map((v, idx) => `
            <span class="me-2">
              <span class="badge bg-light text-dark border">R${idx + 1}</span>
              <span class="ms-1">${renderStep3SignalValueHtml(String(row?.key || ""), v)}</span>
            </span>
          `).join("")
        : "-";
      const status = row?.tie
        ? `<span class="badge bg-danger-subtle text-danger border">Tie fallback</span>`
        : (row?.changed
          ? `<span class="badge bg-warning text-dark">Consensus changed</span>`
          : `<span class="badge bg-light text-dark border">Consensus matched</span>`);
      return `
        <tr>
          <td class="font-monospace">${escapeHtml(String(row?.key || "-"))}</td>
          <td>${runValues}</td>
          <td class="text-center fw-bold">${renderStep3SignalValueHtml(String(row?.key || ""), row?.consensusValue || "-")}</td>
          <td class="text-center">${status}</td>
        </tr>
      `;
    }).join("");
  }
  renderStep3RunDiffPanel(stabilityMeta);
  updateStep3StabilityTabEmptyState();
}

let reviewModalInstance = null;

async function prepareExtraction() {
  if (blockIfStepLocked("step3extract")) return;
  if (!GLOBALESSAYOBJECT) {
    return safeShowMessage({
      title: "Step 1 Missing",
      icon: "warning",
      message: "Complete Step 1 first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }
  if (!GLOBALPARAGRAPHROLES) {
    return safeShowMessage({
      title: "Step 2 Missing",
      icon: "warning",
      message: "Run Step 2 Analysis first to determine paragraph roles.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }

  const btn = document.getElementById("btnPrepareExtract");
  btn.disabled = true;
  btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Generating Prompt...`;

  try {
    const previewPayload = buildStep3Payload("", { stabilityProfile: STABILITY_PROFILE });
    const r = await postJsonAndRecord(
      "step3preview",
      "/ielts/scoring/step3/extract?preview=true",
      previewPayload
    );
    if (r.status !== "success") throw new Error(r.message || "Preview failed.");
    const promptToReview = String(r.data?.promptPreview || "").trim();

    document.getElementById("reviewPromptText").value = promptToReview;

    if (!reviewModalInstance && window.bootstrap) {
      const el = document.getElementById("promptReviewModal");
      if (el) reviewModalInstance = new bootstrap.Modal(el);
    }
    reviewModalInstance?.show();
  } catch (e) {
    console.error(e);
    safeShowMessage({
      title: "Error",
      icon: "error",
      message: e.message || "Could not generate prompt preview.",
      buttons: [{ text: "OK", class: "btn-danger" }]
    });
  } finally {
    btn.disabled = false;
    btn.innerHTML = `<i class="bi bi-eye me-1"></i> Review & Extract (Single Run)`;
    updateStepLocks();
  }
}

async function executeExtraction() {
  if (blockIfStepLocked("step3extract")) return;
  const proceed = await confirmStep3RerunResetIfNeeded();
  if (!proceed) return;
  reviewModalInstance?.hide();
  const btn = document.getElementById("btnPrepareExtract");
  const btnConsensus = document.getElementById("btnExtractConsensus");
  btn.disabled = true;
  if (btnConsensus) btnConsensus.disabled = true;
