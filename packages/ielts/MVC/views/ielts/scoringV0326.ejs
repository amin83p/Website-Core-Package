const TIMED_STEPS = [
  { key: "step1freeze", label: "Step 1 Freeze", el: "timerStep1" },
  { key: "step2analyze", label: "Step 2 Analysis", el: "timerStep2" },
  { key: "step3extract", label: "Step 3 Extraction", el: "timerStep3" },
  { key: "step4grade", label: "Step 4 Grading", el: "timerStep4" },
  { key: "step5feedback", label: "Step 5 Feedback", el: "timerStep5" }
];

let RUNNING_TIMER = { intervalId: null, startedAtMs: null, stepKey: null };

function formatMs(ms) {
  if (ms == null || Number.isNaN(ms)) return "-";
  return `${(ms / 1000).toFixed(2)}s`;
}

function getStepDurationMs(stepKey) {
  const step = SESSION_BUNDLE?.steps?.[stepKey]; // if your constant is SESSIONBUNDLE, rename here
  const t = step?.timing;
  if (!t?.startedAt || !t?.endedAt) return null;
  return Math.max(0, t.endedAt - t.startedAt);
}

function computeTotalMs() {
  return TIMED_STEPS.reduce((sum, s) => {
    const d = getStepDurationMs(s.key);
    return sum + (d ?? 0);
  }, 0);
}

function refreshTimingUI() {
  const totalEl = document.getElementById("timerTotal");
  if (totalEl) totalEl.textContent = formatMs(computeTotalMs());

  TIMED_STEPS.forEach(s => {
    const el = document.getElementById(s.el);
    if (!el) return;
    el.textContent = formatMs(getStepDurationMs(s.key));
  });
}

function startRunningTimer(stepKey, label) {
  const badge = document.getElementById("timerRunningBadge");
  const labelEl = document.getElementById("timerRunningLabel");
  const valEl = document.getElementById("timerRunningValue");

  RUNNING_TIMER.stepKey = stepKey;
  RUNNING_TIMER.startedAtMs = Date.now();

  if (labelEl) labelEl.textContent = label || stepKey;
  if (badge) badge.classList.remove("d-none");

  if (RUNNING_TIMER.intervalId) clearInterval(RUNNING_TIMER.intervalId);
  RUNNING_TIMER.intervalId = setInterval(() => {
    if (!valEl) return;
    valEl.textContent = formatMs(Date.now() - RUNNING_TIMER.startedAtMs);
  }, 100);
}

function stopRunningTimer() {
  const badge = document.getElementById("timerRunningBadge");
  if (RUNNING_TIMER.intervalId) clearInterval(RUNNING_TIMER.intervalId);
  RUNNING_TIMER.intervalId = null;
  RUNNING_TIMER.startedAtMs = null;
  RUNNING_TIMER.stepKey = null;
  if (badge) badge.classList.add("d-none");
}


function getCurrentStepNumber() {
  const active = document.querySelector(".step-item.active");
  return active ? String(active.dataset.step) : "1";
