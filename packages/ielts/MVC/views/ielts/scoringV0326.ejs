}

/* =========================================================
   Save / Export / Load (RAW bundle)
   ========================================================= */
function sanitizeFilenamePart(value, fallback = "unknown-sample") {
  const raw = String(value || "").trim();
  if (!raw) return fallback;

  const normalized = raw
    .normalize("NFKD")
    .replace(/[\u0300-\u036f]/g, "")
    .replace(/['"`]/g, "")
    .replace(/[^A-Za-z0-9._-]+/g, "-")
    .replace(/-+/g, "-")
    .replace(/^[-_.]+|[-_.]+$/g, "")
    .slice(0, 80);

  return normalized || fallback;
}

function getSampleFilenamePart() {
  const option = getSelectedSampleOption();
  const sampleName = String(
    option?.dataset?.refName ||
    option?.text ||
    SESSION_BUNDLE?.metadata?.sampleRefName ||
    SESSION_BUNDLE?.metadata?.sampleName ||
    SESSION_BUNDLE?.metadata?.sampleId ||
    ""
  ).trim();
  return sanitizeFilenamePart(sampleName);
}

function saveProgress(options = {}) {
  const allowReadOnlyExport = options && options.allowReadOnlyExport === true;
  if (SESSION_READONLY && !allowReadOnlyExport) {
    return safeShowMessage({
      title: "Read-only Session",
      icon: "lock",
      message: "Completed sessions loaded from history are locked. Use New / Start to create a new run.",
      buttons: [{ text: "OK", class: "btn-secondary" }]
    });
  }

  if (!SESSION_READONLY) {
    prepareBundleForSave();
  }

  const exportBundle = (SESSION_READONLY && allowReadOnlyExport)
    ? deepCloneJson(SESSION_BUNDLE)
    : SESSION_BUNDLE;
  if (SESSION_READONLY && allowReadOnlyExport) {
    ensureStep11Scaffold(exportBundle);
    exportBundle.savedAt = exportBundle.savedAt || new Date().toISOString();
    exportBundle.uiState = {
      ...(exportBundle.uiState || {}),
      readOnlyOnLoad: true,
      forceReadOnlyOnLoad: true
    };
  }

  const stamp = new Date().toISOString().slice(0, 19).replace(/[:T]/g, "-");
  const samplePart = getSampleFilenamePart();
  downloadJson(`scoring-session-${samplePart}-${stamp}.json`, exportBundle);
  if (!SESSION_READONLY) {
    SESSION_BUNDLE.dirty = true;
  }

  safeShowMessage({
    title: "Saved",
    icon: "check",
    message: (SESSION_READONLY && allowReadOnlyExport)
      ? "Loaded session exported as raw JSON (no HTML)."
      : "Session saved as raw JSON (no HTML).",
    buttons: [{ text: "OK", class: "btn-success" }]
  });
}

function exportStepFiles() {
  const stamp = new Date().toISOString().slice(0, 19).replace(/[:T]/g, "-");
  const samplePart = getSampleFilenamePart();
  const keys = Object.keys(SESSION_BUNDLE.steps || {});
  let count = 0;

  keys.forEach((k, idx) => {
    const step = SESSION_BUNDLE.steps[k];
    const json = step?.response?.json;
    if (!json) return;

    setTimeout(() => {
      downloadJson(`${k}-${samplePart}-${stamp}.json`, json);
    }, idx * 200);

    count += 1;
  });

  safeShowMessage({
    title: count ? "Exported" : "No Data",
    icon: count ? "check" : "info",
    message: count ? `${count} step JSON files exported.` : "No completed steps recorded yet.",
    buttons: [{ text: "OK", class: count ? "btn-success" : "btn-secondary" }]
  });
}

function restoreFromBundle(bundle) {
  ensureStep11Scaffold(bundle);
  ensureStep11Scaffold(SESSION_BUNDLE);
  syncBundleSessionId(SESSION_BUNDLE, bundle?.sessionId || bundle?.id || null);
  // 0. Restore grading settings (Step 4 runtime parameters) early so subsequent
  // runs and UI labels reflect the session's configuration.
  const gs = bundle?.uiState?.gradingSettings;
  const stabilityCfg = (
    (bundle?.uiState?.stabilityConfig && typeof bundle.uiState.stabilityConfig === "object")
      ? bundle.uiState.stabilityConfig
      : (bundle?.researchConfig?.stabilityConfig && typeof bundle.researchConfig.stabilityConfig === "object")
        ? bundle.researchConfig.stabilityConfig
        : null
  );
  if (gs && typeof gs === 'object') {
    GRADING_SETTINGS.batchSize = clampInt(gs.batchSize, GRADING_LIMITS.batchSize.min, GRADING_LIMITS.batchSize.max, GRADING_SETTINGS.batchSize);
    GRADING_SETTINGS.concurrency = clampInt(gs.concurrency, GRADING_LIMITS.concurrency.min, GRADING_LIMITS.concurrency.max, GRADING_SETTINGS.concurrency);
    GRADING_SETTINGS.mode = normalizeRunMode(gs.mode || bundle?.researchConfig?.mode || GRADING_SETTINGS.mode);
    applyStabilityProfile(
      stabilityCfg?.profile ||
        gs.stabilityProfile ||
        bundle?.researchConfig?.stabilityProfile ||
        STABILITY_PROFILE,
      { logChange: false }
    );
    STEP3_STABILITY_CONFIG.runCount = clampInt(
      gs.step3RunCount ?? stabilityCfg?.step3?.runCount ?? bundle?.researchConfig?.step3RunCount,
      2,
      10,
      STEP3_STABILITY_CONFIG.runCount
    );
    enforceStep3ConsensusRunCount();
    STABILITY_GATE_CONFIG.runCount = clampInt(
      gs.step4RunCount ?? stabilityCfg?.step4?.runCount ?? bundle?.researchConfig?.step4RunCount,
      2,
      10,
      STABILITY_GATE_CONFIG.runCount
    );
    if (stabilityCfg?.step3 && typeof stabilityCfg.step3 === "object") {
      STEP3_STABILITY_CONFIG.minMeanAgreement = Number(stabilityCfg.step3.minMeanAgreement ?? STEP3_STABILITY_CONFIG.minMeanAgreement);
      STEP3_STABILITY_CONFIG.maxFlipRate = Number(stabilityCfg.step3.maxFlipRate ?? STEP3_STABILITY_CONFIG.maxFlipRate);
      STEP3_STABILITY_CONFIG.maxUnstableShare = Number(stabilityCfg.step3.maxUnstableShare ?? STEP3_STABILITY_CONFIG.maxUnstableShare);
    }
    if (stabilityCfg?.step4 && typeof stabilityCfg.step4 === "object") {
      STABILITY_GATE_CONFIG.minMeanAgreement = Number(stabilityCfg.step4.minMeanAgreement ?? STABILITY_GATE_CONFIG.minMeanAgreement);
      STABILITY_GATE_CONFIG.maxFlipRate = Number(stabilityCfg.step4.maxFlipRate ?? STABILITY_GATE_CONFIG.maxFlipRate);
      STABILITY_GATE_CONFIG.maxUnstableShare = Number(stabilityCfg.step4.maxUnstableShare ?? STABILITY_GATE_CONFIG.maxUnstableShare);
    }
    // Persist to localStorage so a reload keeps the same values.
    saveGradingSettings();
  } else {
    GRADING_SETTINGS.mode = normalizeRunMode(bundle?.researchConfig?.mode || GRADING_SETTINGS.mode);
    applyStabilityProfile(
      stabilityCfg?.profile || bundle?.researchConfig?.stabilityProfile || STABILITY_PROFILE,
      { logChange: false }
    );
    STEP3_STABILITY_CONFIG.runCount = clampInt(
      stabilityCfg?.step3?.runCount ?? bundle?.researchConfig?.step3RunCount,
      2,
      10,
      STEP3_STABILITY_CONFIG.runCount
    );
    enforceStep3ConsensusRunCount();
    STABILITY_GATE_CONFIG.runCount = clampInt(
      stabilityCfg?.step4?.runCount ?? bundle?.researchConfig?.step4RunCount,
      2,
      10,
      STABILITY_GATE_CONFIG.runCount
    );
    if (stabilityCfg?.step3 && typeof stabilityCfg.step3 === "object") {
      STEP3_STABILITY_CONFIG.minMeanAgreement = Number(stabilityCfg.step3.minMeanAgreement ?? STEP3_STABILITY_CONFIG.minMeanAgreement);
      STEP3_STABILITY_CONFIG.maxFlipRate = Number(stabilityCfg.step3.maxFlipRate ?? STEP3_STABILITY_CONFIG.maxFlipRate);
      STEP3_STABILITY_CONFIG.maxUnstableShare = Number(stabilityCfg.step3.maxUnstableShare ?? STEP3_STABILITY_CONFIG.maxUnstableShare);
    }
    if (stabilityCfg?.step4 && typeof stabilityCfg.step4 === "object") {
      STABILITY_GATE_CONFIG.minMeanAgreement = Number(stabilityCfg.step4.minMeanAgreement ?? STABILITY_GATE_CONFIG.minMeanAgreement);
      STABILITY_GATE_CONFIG.maxFlipRate = Number(stabilityCfg.step4.maxFlipRate ?? STABILITY_GATE_CONFIG.maxFlipRate);
      STABILITY_GATE_CONFIG.maxUnstableShare = Number(stabilityCfg.step4.maxUnstableShare ?? STABILITY_GATE_CONFIG.maxUnstableShare);
    }
    // Ensure labels are always in sync even if the session predates this feature.
    updateGradingSettingsLabels();
  }

  // 1. Restore metadata/UI inputs
  GLOBALSAMPLEID = bundle?.metadata?.sampleId ?? bundle?.metadata?.sampleSelect ?? null;
  GLOBALSAMPLEBANDSCORE = parseBandScoreOrNull(
    bundle?.metadata?.examinerBandScore ??
      bundle?.steps?.step1freeze?.response?.json?.meta?.sampleBandScore
  );
  const sampleSelect = document.getElementById("sampleSelect");
  if (sampleSelect && GLOBALSAMPLEID) sampleSelect.value = GLOBALSAMPLEID;
  syncSampleReferenceMetaFromSelection(false);
  if (GLOBALSAMPLEBANDSCORE == null) {
    GLOBALSAMPLEBANDSCORE = parseBandScoreOrNull(
      bundle?.steps?.step1freeze?.response?.json?.meta?.sampleBandScore ??
        bundle?.metadata?.examinerBandScore
    );
  }
  if (GLOBALSAMPLEBANDSCORE != null) {
    SESSION_BUNDLE.metadata = SESSION_BUNDLE.metadata || {};
    SESSION_BUNDLE.metadata.examinerBandScore = GLOBALSAMPLEBANDSCORE;
  }
  updateSampleBandPreview();

  const subQKeysEl = document.getElementById("subQKeys");
  if (subQKeysEl) subQKeysEl.value = bundle?.uiState?.subQKeys ?? "";
  const reviewPromptEl = document.getElementById("reviewPromptText");
  if (reviewPromptEl) reviewPromptEl.value = bundle?.uiState?.reviewPromptText ?? "";
  const step4PromptEl = document.getElementById("step4PromptText");
  if (step4PromptEl) step4PromptEl.value = bundle?.uiState?.step4PromptText ?? "";
  const step5PromptEl = document.getElementById("step5PromptText");
  if (step5PromptEl) step5PromptEl.value = bundle?.uiState?.step5PromptText ?? "";
  STEP3_SELECTED_TEMPLATE = (() => {
    const t = bundle?.uiState?.step3PromptTemplate;
    if (!t || typeof t !== "object") return null;
    const id = String(t.id || "").trim();
    if (!id) return null;
    return {
      id,
      name: String(t.name || id).trim(),
      content: String(t.content || "")
    };
  })();
  setStep3PromptSource(bundle?.uiState?.step3PromptSource, { logChange: false });
  updateStep3PromptSourceUi();
  STEP4_SELECTED_TEMPLATE = (() => {
    const t = bundle?.uiState?.step4PromptTemplate;
    if (!t || typeof t !== "object") return null;
    const id = String(t.id || "").trim();
    if (!id) return null;
    return {
      id,
      name: String(t.name || id).trim(),
      content: String(t.content || "")
    };
  })();
  setStep4PromptSource(bundle?.uiState?.step4PromptSource, { logChange: false });
  updateStep4PromptSourceUi();
  STEP5_SELECTED_TEMPLATE = (() => {
    const t = bundle?.uiState?.step5PromptTemplate;
    if (!t || typeof t !== "object") return null;
    const id = String(t.id || "").trim();
    if (!id) return null;
    return {
      id,
      name: String(t.name || id).trim(),
      content: String(t.content || "")
    };
  })();
  setStep5PromptSource(bundle?.uiState?.step5PromptSource, { logChange: false });
  updateStep5PromptSourceUi();
  const savedModels = (
    bundle?.uiState?.selectedModels && typeof bundle.uiState.selectedModels === "object"
      ? bundle.uiState.selectedModels
      : (bundle?.researchConfig?.selectedModels && typeof bundle.researchConfig.selectedModels === "object")
        ? bundle.researchConfig.selectedModels
        : {}
  );
  const savedProviders = (
    bundle?.uiState?.selectedProviders && typeof bundle.uiState.selectedProviders === "object"
      ? bundle.uiState.selectedProviders
      : (bundle?.researchConfig?.selectedProviders && typeof bundle.researchConfig.selectedProviders === "object")
        ? bundle.researchConfig.selectedProviders
        : {}
  );
  const restoredStep3Model = onStep3ProviderChange(savedProviders?.step3 || "", {
    preferredModelId: savedModels?.step3 || "",
    persistModel: false
  });
  const restoredStep4Model = onStep4ProviderChange(savedProviders?.step4 || "", {
    preferredModelId: savedModels?.step4 || "",
    persistModel: false
  });
  const restoredStep5Model = onStep5ProviderChange(savedProviders?.step5 || "", {
    preferredModelId: savedModels?.step5 || "",
    persistModel: false
  });
  onStep3ModelChange(restoredStep3Model || "");
  onStep4ModelChange(restoredStep4Model || "");
  onStep5ModelChange(restoredStep5Model || "");

  // 2. Restore steps -> globals -> re-render
  const s = bundle.steps || {};
  GLOBALSTABILITY = null;
  renderStabilityGateDisplay(null);
  GLOBALSTEP3STABILITY = null;
  renderStep3Stability(null);

  // --- Step 1: Freeze ---
  const step1 = s.step1freeze?.response?.json;
  if (step1?.status === "success") {
    GLOBALESSAYOBJECT = step1.data;
    renderFreezeFromData(step1.data);
  }

  // --- Step 2: Analysis ---
  const step2 = s.step2analyze?.response?.json;
  if (step2?.status === "success") {
    GLOBALANALYSIS = step2.data;
    GLOBALPARAGRAPHROLES = step2.data?.structure?.paragraphRoles ?? null;
    renderAnalysisFromData(step2.data);
  }

  // --- Step 3: Extraction ---
  const step3 = s.step3extract?.response?.json;
  if (step3?.status === "success") {
    GLOBALEXTRACTION = step3.data;
    
    //  FIX: Pass the 'meta' object as the 3rd argument
    // This allows the renderer to find 'meta.modelUsed'
    renderExtractionResults(step3.data, step3.meta?.generatedKeys, step3.meta);

    document.getElementById("step3Placeholder")?.classList.add("d-none");
    document.getElementById("step3Result")?.classList.remove("d-none");
  }

  // --- Step 4: Grading ---
  const step4 = s.step4grade?.response?.json;
  if (step4?.status === "success") {
    GLOBALGRADING = step4.data;
    // Step 4 data object already contains 'meta' inside it, so passing 'data' is sufficient
    renderGradingFromData(step4.data);
  }

  // --- Step 5: Feedback ---
  const step5 = s.step5feedback?.response?.json;
  if (step5?.status === "success") {
    GLOBALFEEDBACK = step5.data;
    renderFeedbackResults(step5.data);
  }

  const shouldLockReadOnly = Boolean(bundle?.uiState?.forceReadOnlyOnLoad);
  setSessionReadOnly(shouldLockReadOnly, shouldLockReadOnly ? "Session loaded in read-only mode." : "");

  // 3. Finalize
  renderReport();
  
  // Jump to last viewed step
  const target = bundle?.uiState?.currentStep;
  if (target) navigateToStep(target);

  refreshTimingUI();
  updateStepLocks();
}

function loadProgress(event) {
  const file = event.target.files?.[0];
  if (!file) return;

  const reader = new FileReader();
  reader.onload = function (e) {
    try {
      const bundle = JSON.parse(e.target.result);

      if (bundle?.schema !== "ielts-scoring-session") {
        throw new Error("Unsupported file format (expected ielts-scoring-session).");
      }
      if (bundle?.version !== 1) {
        throw new Error(`Unsupported session version: ${bundle.version}`);
      }

      // replace in-memory bundle
      SESSION_BUNDLE.savedAt = bundle.savedAt ?? null;
      SESSION_BUNDLE.metadata = bundle.metadata ?? {};
      SESSION_BUNDLE.uiState = bundle.uiState ?? {};
      SESSION_BUNDLE.researchConfig = bundle.researchConfig ?? {};
      SESSION_BUNDLE.tweakLog = bundle.tweakLog ?? [];
      SESSION_BUNDLE.freezePoints = bundle.freezePoints ?? {};
      SESSION_BUNDLE.steps = bundle.steps ?? {};
      syncBundleSessionId(SESSION_BUNDLE, bundle?.sessionId || bundle?.id || null);
      ensureStep11Scaffold(SESSION_BUNDLE);

      SESSION_BUNDLE.dirty = true;

      refreshTimingUI();

      restoreFromBundle(bundle);

      safeShowMessage({
        title: "Loaded",
        icon: "check",
        message: "Session restored from raw JSON bundle.",
        buttons: [{ text: "OK", class: "btn-success" }]
      });
    } catch (error) {
      safeShowMessage({
        title: "Failed",
        icon: "error",
        message: `Load error: ${error.message}`,
        buttons: [{ text: "OK", class: "btn-danger" }]
      });
    }
  };

  reader.readAsText(file);
  event.target.value = "";
}
/* =========================================================
   SERVER SAVE / LOAD INTEGRATION
   ========================================================= */

// 1. SAVE TO SERVER FUNCTION
async function saveToServer() {
    if (SESSION_READONLY) {
      return safeShowMessage({
        title: "Read-only Session",
        icon: "lock",
        message: "Completed sessions loaded from history are locked. Use New / Start to create a new run.",
        buttons: [{ text: "OK", class: "btn-secondary" }]
      });
    }

    const btn = document.getElementById('btnSaveServer'); // You need to add this button ID to your HTML
    if(btn) { btn.disabled = true; btn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Saving...'; }

    // Prepare Bundle
    prepareBundleForSave();

    try {
        const res = await fetch('/ielts/data/scoringHistory', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(SESSION_BUNDLE)
        });
        
        const json = await res.json();
        if(json.success || json.id) {
            const savedId = String(json.id || "").trim();
            if (savedId) syncBundleSessionId(SESSION_BUNDLE, savedId);
            safeShowMessage({
                title: "Saved",
                icon: "cloud-upload",
                message: String(json.mode || "").toLowerCase() === "updated"
                  ? "Session updated in cloud (overwrote current record)."
                  : "Session saved to cloud.",
                buttons: [{ text: "OK", class: "btn-success" }]
            });
        } else {
            throw new Error("Server responded with failure.");
        }
    } catch(e) {
        console.error(e);
        safeShowMessage({ title: "Error", icon: "error", message: "Failed to save to server." });
    } finally {
        if(btn) { btn.disabled = false; btn.innerHTML = '<i class="bi bi-cloud-upload me-1"></i> Save to Cloud'; }
        updateStepLocks();
    }
}

// 2. AUTO-LOAD ON STARTUP
document.addEventListener('DOMContentLoaded', async () => {
    loadGradingSettings();
    applyTuningModeUi();
    initializeStep3TuningModelSelector();
    initializeStep4TuningModelSelector();
    initializeStep5TuningModelSelector();
    setStep3PromptSource(STEP3_PROMPT_SOURCE_BUILTIN, { logChange: false });
    updateStep3PromptSourceUi();
    setStep4PromptSource(STEP4_PROMPT_SOURCE_BUILTIN, { logChange: false });
    updateStep4PromptSourceUi();
    setStep5PromptSource(STEP5_PROMPT_SOURCE_BUILTIN, { logChange: false });
    updateStep5PromptSourceUi();
    syncSampleReferenceMetaFromSelection(false);
    updateSampleBandPreview();
    syncSamplePickerDisplayFromSelection();
    setSessionReadOnly(false);
    updateStepLocks();
    const sampleDisplay = document.getElementById("sampleSelectDisplay");
    if (sampleDisplay) {
      sampleDisplay.addEventListener("click", () => openSampleEssayPicker());
      sampleDisplay.addEventListener("keydown", (event) => {
        if (event.key === "Enter" || event.key === " ") {
          event.preventDefault();
          openSampleEssayPicker();
        }
      });
    }
    const params = new URLSearchParams(window.location.search);
    const loadId = params.get('loadId');

    if(loadId) {
        // Show loading overlay or message
        safeShowMessage({ title: "Loading", message: "Fetching session data from server...", icon: "hourglass" });
        
        try {
            const res = await fetch(`/ielts/data/scoringHistory/${encodeURIComponent(loadId)}`, {
              headers: {
                "Accept": "application/json",
                "X-AJAX-Request": "true"
              }
            });
            if (!res.ok) {
              const contentType = res.headers.get("content-type") || "";
              let serverMessage = `Failed to load session (HTTP ${res.status})`;
              try {
                if (contentType.includes("application/json")) {
                  const errJson = await res.json();
                  serverMessage = String(errJson?.message || serverMessage);
                } else {
                  const errText = await res.text();
                  if (String(errText || "").trim()) serverMessage = String(errText).trim();
                }
              } catch (_) {}
              throw new Error(serverMessage);
            }

            const bundle = await res.json();
            
            // Close the "Loading" message (if your modal supports close)
            // Or just restore immediately:
            
            // VALIDATE AND RESTORE
            if (bundle?.schema !== "ielts-scoring-session") throw new Error("Invalid schema");
            
            SESSION_BUNDLE.savedAt = bundle.savedAt;
            SESSION_BUNDLE.metadata = bundle.metadata || {};
            SESSION_BUNDLE.uiState = bundle.uiState || {};
            SESSION_BUNDLE.researchConfig = bundle.researchConfig || {};
            SESSION_BUNDLE.tweakLog = bundle.tweakLog || [];
            SESSION_BUNDLE.freezePoints = bundle.freezePoints || {};
            SESSION_BUNDLE.steps = bundle.steps || {};
            syncBundleSessionId(SESSION_BUNDLE, bundle.sessionId || bundle.id || loadId); // Important for future updates
            ensureStep11Scaffold(SESSION_BUNDLE);

            restoreFromBundle(bundle); // Calls your existing restore logic
            
            safeShowMessage({ title: "Restored", icon: "check", message: "Session loaded successfully.", buttons: [{text:"OK", class:"btn-success"}]});

        } catch(e) {
            safeShowMessage({ title: "Load Error", icon: "error", message: e.message });
        }
    }
});

