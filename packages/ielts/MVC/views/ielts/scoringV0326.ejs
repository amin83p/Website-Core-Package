  ).trim();
}

function resolveSessionStep3ModelLabel(session) {
  return String(
    session?.step3ModelUsed ||
    session?.steps?.step3extract?.response?.json?.meta?.modelUsed ||
    session?.steps?.step3extract?.response?.json?.meta?.selectedModel ||
    session?.steps?.step3extract?.response?.json?.meta?.providerModel ||
