}

function getStep4RowKey(row) {
  const criterion = String(row?.criterion || "GEN").trim().toUpperCase();
  const band = Number.isFinite(Number(row?.band)) ? Number(row.band) : "";
  const baseKey = String(row?.baseKey || row?.question_key || row?.instanceKey || "").trim();
  if (baseKey) return `${criterion}::${band}::${baseKey}`;
  const atomic = String(row?.atomic_question || "").trim().toLowerCase();
  return `${criterion}::${band}::${atomic || "unknown"}`;
}

function normalizeVoteValue(value) {
  const txt = String(value ?? "").trim().toLowerCase();
  return txt || null;
}

function isEvaluableMicroAnswer(row) {
  const val = normalizeVoteValue(row?.value);
  return Boolean(val && val !== "error" && val !== "n/a" && val !== "na");
}

function deepCloneJson(value) {
  return JSON.parse(JSON.stringify(value ?? null));
}

function isSupportiveMicroAnswer(row) {
  const normalizeScoringAnswerToken = (value) => String(value ?? "")
    .trim()
    .toLowerCase()
    .replace(/[\s-]+/g, "_");
  const normalizeScoringAnswerList = (raw) => {
    let values = [];
    if (Array.isArray(raw)) values = raw;
    else if (typeof raw === "string") {
      values = raw
        .split(/[,;\n|]+/g)
        .map((v) => v.trim())
        .filter(Boolean);
    } else if (raw !== undefined && raw !== null) {
      values = [raw];
    }
    const out = [];
    const seen = new Set();
    for (const value of values) {
      const normalized = normalizeScoringAnswerToken(value);
      if (!normalized || seen.has(normalized)) continue;
      seen.add(normalized);
      out.push(normalized);
    }
    return out;
  };

  const passFeature = new Set([
    "yes", "true", "clear", "adequate", "wide", "logical", "well_managed",
    "sufficient", "skilful", "relevant", "high", "ok"
  ]);
  const passFault = new Set([
    "no", "false", "none", "rare", "rarely", "never", "few", "minimal", "minor", "ok"
  ]);
  const val = normalizeVoteValue(row?.value);
  if (!val || val === "error" || val === "n/a" || val === "na") return false;

  const normalizedValue = normalizeScoringAnswerToken(val);
  const scoredAnswers = normalizeScoringAnswerList(row?.scoredAnswers);
  const notScoredAnswers = normalizeScoringAnswerList(row?.notScoredAnswers);
  const hasExplicitContract = scoredAnswers.length > 0 || notScoredAnswers.length > 0;
  if (hasExplicitContract) {
    if (scoredAnswers.length > 0 && scoredAnswers.includes(normalizedValue)) return true;
    if (notScoredAnswers.length > 0 && notScoredAnswers.includes(normalizedValue)) return false;
    if (scoredAnswers.length > 0 && notScoredAnswers.length === 0) return false;
    if (scoredAnswers.length === 0 && notScoredAnswers.length > 0) return true;
    return false;
  }

  const polarity = String(row?.polarity || "FEATURE_CHECK").toUpperCase();
  if (polarity === "FAULT_CHECK") {
    return passFault.has(normalizedValue) || normalizedValue.includes("rare") || normalizedValue.includes("few") || normalizedValue.includes("minor");
  }
  return passFeature.has(normalizedValue) || normalizedValue === "yes";
}

function normalizeGateBandValue(value) {
  const n = Number(value);
  if (!Number.isFinite(n)) return null;
  const i = Math.round(n);
  if (i < 1 || i > 9) return null;
  return i;
}

function detectMinBandFromRows(rows) {
  const bands = (rows || [])
    .map((r) => normalizeGateBandValue(r?.band))
    .filter((n) => Number.isInteger(n));
  if (!bands.length) return 4;
  return Math.min(...bands);
}

function getAvailableBandGates(rows) {
  const seen = new Set();
  const out = [];
  for (const row of (rows || [])) {
    const band = normalizeGateBandValue(row?.band);
    if (!Number.isInteger(band)) continue;
    if (seen.has(band)) continue;
    seen.add(band);
    out.push(band);
  }
  out.sort((a, b) => a - b);
  return out;
}

function calculateBandScoresClient(rows) {
  const criteria = ["TR", "CC", "LR", "GRA"];

  const scores = {};
  const gateTrace = {};
  for (const criterion of criteria) {
    const criterionRows = (rows || []).filter((r) => String(r?.criterion || "").toUpperCase() === criterion);
    const trace = {
      criterion,
      availableBandGates: [],
      evaluatedGates: [],
      fallbackApplied: null,
      resultingCriterionScore: 0
    };
    if (!criterionRows.length) {
      scores[criterion] = 0;
      gateTrace[criterion] = trace;
      continue;
    }

    const bandGates = getAvailableBandGates(criterionRows);
    if (!bandGates.length) {
      scores[criterion] = 0;
      gateTrace[criterion] = trace;
      continue;
    }
    trace.availableBandGates = bandGates.slice();

    // Sparse-band-safe progression:
    // evaluate only real gate bands present in current rows.
    let currentBand = bandGates[0];
    trace.evaluatedGates.push({
      band: bandGates[0],
      totalWeight: null,
      passedWeight: null,
      passRatio: null,
      status: "baseline",
      resultingBandAfterGate: currentBand
    });
    for (let gateIdx = 1; gateIdx < bandGates.length; gateIdx += 1) {
      const b = bandGates[gateIdx];
      const bandRows = criterionRows.filter((r) => normalizeGateBandValue(r?.band) === b);
      if (!bandRows.length) continue;

      let totalWeight = 0;
      let passedWeight = 0;
      let evaluatedWeight = 0;
      let excludedUnevaluableWeight = 0;

      for (const row of bandRows) {
        const wRaw = Number(row?.weight);
        const weight = Number.isFinite(wRaw) && wRaw > 0 ? wRaw : 1;
        const evaluable = isEvaluableMicroAnswer(row);
        if (!evaluable) {
          excludedUnevaluableWeight += weight;
          continue;
        }
        totalWeight += weight;
        evaluatedWeight += weight;

        const pass = isSupportiveMicroAnswer(row);
        if (pass) passedWeight += weight;
      }

      if (totalWeight === 0) {
        trace.evaluatedGates.push({
          band: b,
          totalWeight: Number(totalWeight.toFixed(4)),
          passedWeight: Number(passedWeight.toFixed(4)),
          evaluatedWeight: Number(evaluatedWeight.toFixed(4)),
          excludedUnevaluableWeight: Number(excludedUnevaluableWeight.toFixed(4)),
          passRatio: null,
          status: "not_evaluable",
          resultingBandAfterGate: currentBand
        });
        continue;
      }
      const ratio = passedWeight / totalWeight;
      if (ratio >= 0.5) {
        currentBand = b;
        trace.evaluatedGates.push({
          band: b,
          totalWeight: Number(totalWeight.toFixed(4)),
          passedWeight: Number(passedWeight.toFixed(4)),
          evaluatedWeight: Number(evaluatedWeight.toFixed(4)),
          excludedUnevaluableWeight: Number(excludedUnevaluableWeight.toFixed(4)),
          passRatio: Number(ratio.toFixed(4)),
          status: "passed",
          resultingBandAfterGate: currentBand
        });
      } else {
        const fallback = ratio >= 0.35
          ? { type: "minus_0_5", fromBand: b, resultingBand: b - 0.5 }
          : { type: "minus_1_0", fromBand: b, resultingBand: b - 1 };
        currentBand = fallback.resultingBand;
        trace.fallbackApplied = fallback;
        trace.evaluatedGates.push({
          band: b,
          totalWeight: Number(totalWeight.toFixed(4)),
          passedWeight: Number(passedWeight.toFixed(4)),
          evaluatedWeight: Number(evaluatedWeight.toFixed(4)),
          excludedUnevaluableWeight: Number(excludedUnevaluableWeight.toFixed(4)),
          passRatio: Number(ratio.toFixed(4)),
          status: ratio >= 0.35 ? "partial" : "failed",
          resultingBandAfterGate: currentBand,
          fallbackApplied: fallback
        });
        break;
      }
    }

    const criterionScore = Math.max(1, Math.min(9, currentBand));
    scores[criterion] = criterionScore;
    trace.resultingCriterionScore = criterionScore;
    gateTrace[criterion] = trace;
  }

  const avg = (scores.TR + scores.CC + scores.LR + scores.GRA) / 4;
  return {
    overall: Math.round(avg * 2) / 2,
    criteria: scores,
    gateTrace
  };
}

function buildStabilityConsensus(gradingRuns) {
  const runCount = Array.isArray(gradingRuns) ? gradingRuns.length : 0;
  if (runCount < 2) throw new Error("Stability consensus requires at least 2 runs.");

  const runRows = gradingRuns.map((run) => getStep4BaseRows(run));
  const runMaps = runRows.map((rows) => {
    const map = new Map();
    (rows || []).forEach((row) => map.set(getStep4RowKey(row), row));
    return map;
  });

  const allKeys = new Set();
  runMaps.forEach((m) => m.forEach((_, k) => allKeys.add(k)));
  const keys = Array.from(allKeys).sort();

  const consensusRows = [];
  const unstableRows = [];
  let changedCount = 0;
  let tieCount = 0;

  let adjacentComparisons = 0;
  let adjacentFlips = 0;

  keys.forEach((key) => {
    const rowsByRun = runMaps.map((map) => map.get(key) || null);
    const available = rowsByRun.filter(Boolean);
    if (!available.length) return;

    const baselineRow = deepCloneJson(rowsByRun[0] || available[0]);
    const normValues = rowsByRun.map((row) => normalizeVoteValue(row?.value));
    const presentNormValues = normValues.filter((v) => v != null);
    const uniqueCount = new Set(presentNormValues).size;
    const isUnstable = uniqueCount > 1;

    for (let i = 1; i < normValues.length; i += 1) {
      const prev = normValues[i - 1];
      const curr = normValues[i];
      if (prev == null || curr == null) continue;
      adjacentComparisons += 1;
      if (prev !== curr) adjacentFlips += 1;
    }

    const votes = new Map();
    presentNormValues.forEach((v) => votes.set(v, (votes.get(v) || 0) + 1));
    const rankedVotes = Array.from(votes.entries()).sort((a, b) => b[1] - a[1] || String(a[0]).localeCompare(String(b[0])));

    const topCount = rankedVotes[0]?.[1] || 0;
    const winners = rankedVotes.filter(([, c]) => c === topCount);
    const hasMajority = topCount >= 2 && winners.length === 1;
    const isTie = !hasMajority && presentNormValues.length > 1;
    if (isTie) tieCount += 1;

    const selectedNorm = hasMajority
      ? winners[0][0]
      : (normValues[0] || rankedVotes[0]?.[0] || null);
    let selectedRunIndex = normValues.findIndex((v) => v === selectedNorm);
    if (selectedRunIndex < 0) selectedRunIndex = rowsByRun.findIndex(Boolean);
    const selectedRow = rowsByRun[selectedRunIndex] || baselineRow;
    const selectedValue = selectedRow?.value ?? baselineRow?.value ?? "n/a";

    const baselineNorm = normalizeVoteValue(baselineRow?.value);
    const changed = selectedNorm != null && baselineNorm !== selectedNorm;
    if (changed) changedCount += 1;

    const consensusRow = deepCloneJson(baselineRow);
    consensusRow.value = selectedValue;
    consensusRow.source = isUnstable
      ? (isTie ? "consensus_tie_fallback" : "consensus_majority_vote")
      : (consensusRow.source || "consensus_stable");
    if (Array.isArray(selectedRow?.evidenceSentenceIndices)) {
      consensusRow.evidenceSentenceIndices = selectedRow.evidenceSentenceIndices.slice();
    }
    consensusRows.push(consensusRow);

    if (isUnstable) {
      unstableRows.push({
        key: String(consensusRow?.baseKey || consensusRow?.question_key || consensusRow?.instanceKey || key),
        criterion: String(consensusRow?.criterion || "-"),
        runValues: rowsByRun.map((row) => String(row?.value ?? "-")),
        majorityValue: String(selectedValue ?? "-"),
        changed,
        tie: isTie,
        votes: rankedVotes.map(([v, c]) => `${v}:${c}`).join(", ")
      });
    }
  });

  const pairwise = [];
  for (let i = 0; i < runCount; i += 1) {
    for (let j = i + 1; j < runCount; j += 1) {
      let comparisons = 0;
      let agreements = 0;
      keys.forEach((key) => {
        const va = normalizeVoteValue(runMaps[i].get(key)?.value);
        const vb = normalizeVoteValue(runMaps[j].get(key)?.value);
        if (va == null || vb == null) return;
        comparisons += 1;
        if (va === vb) agreements += 1;
      });
      pairwise.push({
        runA: i + 1,
        runB: j + 1,
        comparisons,
        agreements,
        agreementRate: comparisons > 0 ? agreements / comparisons : null
      });
    }
  }

  const validPairRates = pairwise
    .map((p) => p.agreementRate)
    .filter((v) => Number.isFinite(v));
  const meanAgreement = validPairRates.length
    ? validPairRates.reduce((a, b) => a + b, 0) / validPairRates.length
    : null;
  const flipRate = adjacentComparisons > 0 ? (adjacentFlips / adjacentComparisons) : 0;
  const unstableShare = keys.length > 0 ? unstableRows.length / keys.length : 0;

  const gatePassed =
    Number.isFinite(meanAgreement) &&
    meanAgreement >= STABILITY_GATE_CONFIG.minMeanAgreement &&
    flipRate <= STABILITY_GATE_CONFIG.maxFlipRate &&
    unstableShare <= STABILITY_GATE_CONFIG.maxUnstableShare;

  unstableRows.sort((a, b) => {
    if (a.tie !== b.tie) return a.tie ? -1 : 1;
    if (a.changed !== b.changed) return a.changed ? -1 : 1;
    return String(a.key).localeCompare(String(b.key));
  });

  return {
    consensusRows,
    unstableRows,
    metrics: {
      runCount,
      totalItems: keys.length,
      unstableCount: unstableRows.length,
      unstableShare,
      changedCount,
      tieCount,
      adjacentComparisons,
      adjacentFlips,
      flipRate,
      meanAgreement,
      pairwise,
      gatePassed
    }
  };
}

function renderStabilityGateDisplay(stabilityMeta) {
  const sidebar = document.getElementById("stabilityGateSidebar");
  const panel = document.getElementById("stabilityGatePanel");
  const metaEl = document.getElementById("stabilityGateMeta");
  const rowsEl = document.getElementById("stabilityGateRows");

  if (!stabilityMeta) {
    if (sidebar) sidebar.textContent = "Stability gate has not been run.";
    if (panel) panel.classList.add("d-none");
    if (metaEl) metaEl.innerHTML = "";
    if (rowsEl) rowsEl.innerHTML = "";
    return;
  }

  const m = stabilityMeta.metrics || {};
  const meanAgreement = Number.isFinite(Number(m.meanAgreement)) ? `${(Number(m.meanAgreement) * 100).toFixed(1)}%` : "-";
  const flipRate = Number.isFinite(Number(m.flipRate)) ? `${(Number(m.flipRate) * 100).toFixed(1)}%` : "-";
  const unstableShare = Number.isFinite(Number(m.unstableShare)) ? `${(Number(m.unstableShare) * 100).toFixed(1)}%` : "-";
  const statusBadge = m.gatePassed
    ? `<span class="badge bg-success">PASS</span>`
    : `<span class="badge bg-warning text-dark">REVIEW</span>`;

  if (sidebar) {
    sidebar.innerHTML = `
      <div class="d-flex align-items-center gap-2 mb-1">${statusBadge}<span class="small text-muted">3-run gate</span></div>
      <div class="small text-muted">Agreement: <span class="fw-bold">${escapeHtml(meanAgreement)}</span></div>
      <div class="small text-muted">Flip rate: <span class="fw-bold">${escapeHtml(flipRate)}</span></div>
      <div class="small text-muted">Unstable: <span class="fw-bold">${escapeHtml(String(m.unstableCount ?? "-"))}</span> / ${escapeHtml(String(m.totalItems ?? "-"))}</div>
    `;
  }

  if (!panel || !metaEl || !rowsEl) return;
  panel.classList.remove("d-none");
  metaEl.innerHTML = `
    ${statusBadge}
    <span class="ms-2">Run count: <span class="fw-bold">${escapeHtml(String(m.runCount ?? "-"))}</span></span>
    <span class="ms-2">Mean agreement: <span class="fw-bold">${escapeHtml(meanAgreement)}</span></span>
    <span class="ms-2">Flip rate: <span class="fw-bold">${escapeHtml(flipRate)}</span></span>
    <span class="ms-2">Unstable share: <span class="fw-bold">${escapeHtml(unstableShare)}</span></span>
  `;

  const rows = Array.isArray(stabilityMeta.topUnstable) ? stabilityMeta.topUnstable : [];
  if (!rows.length) {
    rowsEl.innerHTML = `<tr><td colspan="5" class="text-muted small text-center py-2">No unstable rows detected across the 3 runs.</td></tr>`;
    return;
  }
  rowsEl.innerHTML = rows.slice(0, 12).map((row) => {
    const status = row?.tie
      ? `<span class="badge bg-danger-subtle text-danger border">Tie fallback</span>`
      : (row?.changed
        ? `<span class="badge bg-warning text-dark">Consensus changed</span>`
        : `<span class="badge bg-light text-dark border">Consensus matched</span>`);
    const runValues = Array.isArray(row?.runValues)
      ? row.runValues.map((v, idx) => `<span class="badge bg-light text-dark border me-1">R${idx + 1}: ${escapeHtml(v)}</span>`).join("")
      : "-";
    return `
      <tr>
        <td class="font-monospace">${escapeHtml(row?.key || "-")}</td>
        <td>${escapeHtml(row?.criterion || "-")}</td>
        <td>${runValues}</td>
        <td class="text-center fw-bold">${escapeHtml(row?.majorityValue || "-")}</td>
        <td class="text-center">${status}</td>
      </tr>
    `;
  }).join("");
}

function buildBandCalculationTableRows(rows = []) {
  if (!rows.length) {
    return `<tr><td colspan="9" class="text-muted small text-center py-3">No micro assessments available for this band.</td></tr>`;
  }
  return rows.map((row) => {
    const baseKey = escapeHtml(String(row?.baseKey || row?.question_key || row?.instanceKey || "-"));
    const criterion = escapeHtml(String(row?.criterion || "-"));
    const question = escapeHtml(String(row?.atomic_question || "-"));
    const polarity = escapeHtml(String(row?.polarity || "FEATURE_CHECK"));
    const value = escapeHtml(String(row?.value ?? "-"));
    const weightRaw = Number(row?.weight);
    const weight = Number.isFinite(weightRaw) && weightRaw > 0 ? weightRaw : 1;
    const supportive = isSupportiveMicroAnswer(row);
    const evidenceHtml = buildSentenceRefListClickableHtml(row?.evidenceSentenceIndices);
    const supportiveBadge = supportive
      ? `<span class="badge bg-success">Supportive</span>`
      : `<span class="badge bg-danger-subtle text-danger border">Not supportive</span>`;

    return `
      <tr>
        <td class="font-monospace small">${baseKey}</td>
        <td><span class="badge bg-light text-dark border">${criterion}</span></td>
        <td class="small">${question}</td>
        <td class="small font-monospace">${polarity}</td>
        <td class="small font-monospace">${value}</td>
        <td class="font-monospace">${evidenceHtml}</td>
        <td class="text-end font-monospace">${escapeHtml(weight)}</td>
        <td class="text-center">${supportiveBadge}</td>
        <td class="text-end font-monospace">${supportive ? escapeHtml(weight) : "0"}</td>
      </tr>
    `;
  }).join("");
}

function renderBandCalculationDiagram(gradingData, aggregatedRows = []) {
  const tabsEl = document.getElementById("bandCalcTabs");
  const contentEl = document.getElementById("bandCalcTabContent");
  const metaEl = document.getElementById("bandCalcMeta");
  if (!tabsEl || !contentEl || !metaEl) return;

  const rows = Array.isArray(aggregatedRows) ? aggregatedRows : [];
  const availableBandGates = getAvailableBandGates(rows);
  const minBand = availableBandGates.length ? availableBandGates[0] : detectMinBandFromRows(rows);
  const nextGateBand = availableBandGates.length > 1 ? availableBandGates[1] : null;
  const overall = parseBandScoreOrNull(gradingData?.overallBand);
  const tr = parseBandScoreOrNull(gradingData?.scores?.TR);
  const cc = parseBandScoreOrNull(gradingData?.scores?.CC);
  const lr = parseBandScoreOrNull(gradingData?.scores?.LR);
  const gra = parseBandScoreOrNull(gradingData?.scores?.GRA);
  metaEl.innerHTML = `
    <span class="badge bg-light text-dark border me-1">Overall: ${escapeHtml(overall == null ? "-" : overall)}</span>
    <span class="badge bg-light text-dark border me-1">TR: ${escapeHtml(tr == null ? "-" : tr)}</span>
    <span class="badge bg-light text-dark border me-1">CC: ${escapeHtml(cc == null ? "-" : cc)}</span>
    <span class="badge bg-light text-dark border me-1">LR: ${escapeHtml(lr == null ? "-" : lr)}</span>
    <span class="badge bg-light text-dark border me-1">GRA: ${escapeHtml(gra == null ? "-" : gra)}</span>
    <span class="badge bg-warning-subtle text-dark border">
      ${nextGateBand == null
        ? `Only Band ${escapeHtml(minBand)} rows were available for this run.`
        : `Band ${escapeHtml(minBand)} is baseline in this run; next evaluated gate is Band ${escapeHtml(nextGateBand)}.`}
    </span>
  `;

  const bands = availableBandGates.length ? availableBandGates : [minBand];
  let progressionOpen = true;
  const tabsHtml = [];
  const panesHtml = [];
  const criteria = ["TR", "CC", "LR", "GRA"];

  bands.forEach((band, idx) => {
    const rowsAtBand = rows.filter((r) => normalizeGateBandValue(r?.band) === band);
    const totalWeight = rowsAtBand.reduce((sum, row) => {
      if (!isEvaluableMicroAnswer(row)) return sum;
      const w = Number(row?.weight);
      return sum + (Number.isFinite(w) && w > 0 ? w : 1);
    }, 0);
    const excludedUnevaluableWeight = rowsAtBand.reduce((sum, row) => {
      if (isEvaluableMicroAnswer(row)) return sum;
      const w = Number(row?.weight);
      return sum + (Number.isFinite(w) && w > 0 ? w : 1);
    }, 0);
    const supportiveWeight = rowsAtBand.reduce((sum, row) => {
      if (!isEvaluableMicroAnswer(row)) return sum;
      const w = Number(row?.weight);
      const weight = Number.isFinite(w) && w > 0 ? w : 1;
      return sum + (isSupportiveMicroAnswer(row) ? weight : 0);
    }, 0);
    const supportPct = totalWeight > 0 ? (supportiveWeight / totalWeight) : 0;
    const criterionGates = criteria.map((criterion) => {
      const cRows = rowsAtBand.filter((r) => String(r?.criterion || "").toUpperCase() === criterion);
      const cTotal = cRows.reduce((sum, row) => {
        if (!isEvaluableMicroAnswer(row)) return sum;
        const w = Number(row?.weight);
        return sum + (Number.isFinite(w) && w > 0 ? w : 1);
      }, 0);
      const cSupport = cRows.reduce((sum, row) => {
        if (!isEvaluableMicroAnswer(row)) return sum;
        const w = Number(row?.weight);
        const weight = Number.isFinite(w) && w > 0 ? w : 1;
        return sum + (isSupportiveMicroAnswer(row) ? weight : 0);
      }, 0);
      const cExcluded = cRows.reduce((sum, row) => {
        if (isEvaluableMicroAnswer(row)) return sum;
        const w = Number(row?.weight);
        return sum + (Number.isFinite(w) && w > 0 ? w : 1);
      }, 0);
      const cPct = cTotal > 0 ? cSupport / cTotal : 1; // no rows => auto-pass at this band for that criterion
      const pass = cPct >= 0.5;
      return { criterion, total: cTotal, support: cSupport, excluded: cExcluded, pct: cPct, pass, hasRows: cRows.length > 0 };
    });
    const allCriteriaPass = criterionGates.every((g) => g.pass);

    let canMoveNext = false;
    let decisionText = "";
    let decisionBadge = "";
    if (band === minBand) {
      canMoveNext = progressionOpen;
      decisionText = nextGateBand == null
        ? "Baseline band in this run (no higher evaluated gate available)."
        : `Baseline band (not a progression gate). Next evaluated gate is Band ${nextGateBand}.`;
      decisionBadge = `<span class="badge bg-info-subtle text-info border">Band ${escapeHtml(minBand)} baseline</span>`;
    } else if (idx === bands.length - 1) {
      canMoveNext = false;
      decisionText = "Highest evaluated gate in this run.";
      decisionBadge = `<span class="badge bg-info-subtle text-info border">Final evaluated gate</span>`;
    } else {
      canMoveNext = progressionOpen && allCriteriaPass;
      decisionText = canMoveNext
        ? "Eligible to test next band threshold."
        : "Stop progression at this band threshold.";
      decisionBadge = canMoveNext
        ? `<span class="badge bg-success">Move to next band: YES</span>`
        : `<span class="badge bg-warning text-dark">Move to next band: NO</span>`;
    }
    const chainBadge = progressionOpen
      ? `<span class="badge bg-light text-dark border">Progression state: open</span>`
      : `<span class="badge bg-danger-subtle text-danger border">Progression state: already stopped at lower band</span>`;
    const criterionGateSummary = criterionGates.map((g) => {
      const pct = `${(g.pct * 100).toFixed(1)}%`;
      const tag = g.pass
        ? `<span class="badge bg-success-subtle text-success border">${escapeHtml(g.criterion)} ${escapeHtml(pct)}</span>`
        : `<span class="badge bg-danger-subtle text-danger border">${escapeHtml(g.criterion)} ${escapeHtml(pct)}</span>`;
      const mode = g.hasRows
        ? (g.total > 0 ? "" : `<span class="text-muted small ms-1">(unevaluable only)</span>`)
        : `<span class="text-muted small ms-1">(not evaluated at this gate)</span>`;
      return `<span class="me-2">${tag}${mode}</span>`;
    }).join("");

    tabsHtml.push(`
      <li class="nav-item" role="presentation">
        <button class="nav-link ${idx === 0 ? "active" : ""}" id="bandCalcTab-${band}" data-bs-toggle="tab" data-bs-target="#bandCalcPane-${band}" type="button" role="tab" aria-controls="bandCalcPane-${band}" aria-selected="${idx === 0 ? "true" : "false"}">Band ${band}</button>
      </li>
    `);

    panesHtml.push(`
      <div class="tab-pane fade ${idx === 0 ? "show active" : ""}" id="bandCalcPane-${band}" role="tabpanel" aria-labelledby="bandCalcTab-${band}">
        <div class="table-responsive">
          <table class="table table-sm align-middle small">
            <thead class="table-light">
              <tr>
                <th>Micro ID</th>
                <th>Criterion</th>
                <th>Question</th>
                <th>Polarity</th>
                <th>Answer</th>
                <th>Evidence</th>
                <th class="text-end">Weight</th>
                <th class="text-center">Effective Answer</th>
                <th class="text-end">Supportive Weight</th>
              </tr>
            </thead>
            <tbody>
              ${buildBandCalculationTableRows(rowsAtBand)}
              <tr class="table-light">
                <td colspan="6" class="fw-bold">Total Available Weight</td>
                <td class="text-end fw-bold font-monospace">${escapeHtml(totalWeight)}</td>
                <td></td>
                <td class="text-end fw-bold font-monospace">${escapeHtml(supportiveWeight)}</td>
              </tr>
              <tr class="table-light">
                <td colspan="6" class="fw-bold">Excluded Unevaluable Weight</td>
                <td colspan="3" class="fw-bold font-monospace">${escapeHtml(excludedUnevaluableWeight)}</td>
              </tr>
              <tr class="table-light">
                <td colspan="6" class="fw-bold">Supportive Percentage</td>
                <td colspan="3" class="fw-bold font-monospace">${escapeHtml((supportPct * 100).toFixed(1))}%</td>
              </tr>
              <tr class="table-light">
                <td colspan="6" class="fw-bold">Decision</td>
                <td colspan="3">
                  <div class="d-flex flex-wrap gap-2 align-items-center">
                    ${decisionBadge}
                    ${chainBadge}
                    <span class="small text-muted">${escapeHtml(decisionText)}</span>
                  </div>
                </td>
              </tr>
              <tr class="table-light">
                <td colspan="6" class="fw-bold">Criterion Gate Summary</td>
                <td colspan="3">${criterionGateSummary}</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>
    `);

    if (idx > 0 && idx < bands.length - 1) progressionOpen = progressionOpen && canMoveNext;
  });

  tabsEl.innerHTML = tabsHtml.join("");
  contentEl.innerHTML = panesHtml.join("");
}

function openBandCalculationDiagramModal() {
  if (!GLOBALGRADING) {
    safeShowMessage({
      title: "Step 4 Missing",
      icon: "warning",
      message: "Run Step 4 first to generate grading details.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
    return;
  }
  renderBandCalculationDiagram(GLOBALGRADING, GLOBALSTEP4AGGREGATEDROWS);
  const modalEl = document.getElementById("bandCalculationDiagramModal");
  if (!modalEl) return;
  const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
  modal.show();
}

function renderGradingFromData(d) {
  const scores = d?.scores || {};
  document.getElementById("resOverallBand").textContent = d?.overallBand ?? "-";
  document.getElementById("resBandTR").textContent = scores.TR ?? "-";
  document.getElementById("resBandCC").textContent = scores.CC ?? "-";
  document.getElementById("resBandLR").textContent = scores.LR ?? "-";
  document.getElementById("resBandGRA").textContent = scores.GRA ?? "-";
  const examinerBandLine = document.getElementById("resExaminerBandLine");
  const examinerBandValueEl = document.getElementById("resExaminerBandValue");
  const bandDeltaValueEl = document.getElementById("resBandDeltaValue");
  const examinerBand = parseBandScoreOrNull(
    SESSION_BUNDLE?.metadata?.examinerBandScore ??
      SESSION_BUNDLE?.steps?.step1freeze?.response?.json?.meta?.sampleBandScore ??
      GLOBALSAMPLEBANDSCORE
  );
  if (examinerBand != null) {
    SESSION_BUNDLE.metadata = SESSION_BUNDLE.metadata || {};
    if (SESSION_BUNDLE.metadata.examinerBandScore == null) {
      SESSION_BUNDLE.metadata.examinerBandScore = examinerBand;
    }
  }
  const systemBand = parseBandScoreOrNull(d?.overallBand);
  if (examinerBandValueEl) {
    examinerBandValueEl.textContent = examinerBand == null ? "-" : String(examinerBand);
  }

  if (bandDeltaValueEl) {
    bandDeltaValueEl.classList.remove("text-success", "text-warning", "text-muted");
    if (examinerBand == null || systemBand == null) {
      bandDeltaValueEl.textContent = "-";
      bandDeltaValueEl.classList.add("text-muted");
    } else {
      const delta = Number((systemBand - examinerBand).toFixed(1));
      const deltaSign = delta > 0 ? `+${delta}` : String(delta);
      bandDeltaValueEl.textContent = deltaSign;
      bandDeltaValueEl.classList.add(delta === 0 ? "text-success" : "text-warning");
    }
  }

  if (examinerBandLine) {
    if (examinerBand == null) {
      examinerBandLine.innerHTML = `<span class="text-muted">Examiner reference band: -</span>`;
    } else if (systemBand == null) {
      examinerBandLine.innerHTML = `<span class="badge bg-light text-dark border">Examiner Ref: ${escapeHtml(examinerBand)}</span>`;
    } else {
      const delta = Number((systemBand - examinerBand).toFixed(1));
      const deltaSign = delta > 0 ? `+${delta}` : String(delta);
      const deltaClass = delta === 0 ? "text-success" : "text-warning";
      examinerBandLine.innerHTML = `
        <span class="badge bg-light text-dark border me-1">Examiner Ref: ${escapeHtml(examinerBand)}</span>
        <span class="${deltaClass} fw-bold">Delta ${escapeHtml(deltaSign)}</span>
      `;
    }
  }

  document.getElementById("scoreSummary")?.classList.remove("d-none");
  GLOBALSTABILITY = d?.meta?.stabilityGate || null;
  renderStabilityGateDisplay(GLOBALSTABILITY);

  const modelName = escapeHtml(d?.meta?.modelUsed || "Unknown Model");
  const scoreSummaryEl = document.getElementById("scoreSummary");
  const existingBadge = scoreSummaryEl?.querySelector(".badge-model");
  if (existingBadge) existingBadge.remove();
  scoreSummaryEl?.insertAdjacentHTML(
    "afterbegin",
    `<div class="text-center mb-2 badge-model"><span class="badge bg-purple-subtle text-purple border border-purple" style="color: #6f42c1; background-color: #e0cffc;"><i class="bi bi-cpu-fill me-1"></i> Graded by: ${modelName}</span></div>`
  );

  const critOrder = { TR: 1, CC: 2, LR: 3, GRA: 4 };
  const aggregatedRows = (Array.isArray(d?.aggregatedResults) && d.aggregatedResults.length > 0
    ? d.aggregatedResults
    : (Array.isArray(d?.results) ? d.results : [])
  ).slice().sort((a, b) => {
    const ca = critOrder[a?.criterion] || 99;
    const cb = critOrder[b?.criterion] || 99;
    if (ca !== cb) return ca - cb;
    if ((a?.band || 0) !== (b?.band || 0)) return (a?.band || 0) - (b?.band || 0);
    return String(a?.baseKey || a?.question_key || a?.instanceKey || "").localeCompare(
      String(b?.baseKey || b?.question_key || b?.instanceKey || "")
    );
  });
  GLOBALSTEP4AGGREGATEDROWS = aggregatedRows.slice();

  const getValueBadge = (value) => {
    const val = String(value || "NA");
    const lower = val.toLowerCase();
    const positives = ["yes", "clear", "positive", "adequate", "well-managed", "logical", "wide", "good"];
    const negatives = ["no", "unclear", "limited", "weak", "error", "none", "few", "rare"];
    const isPositive = positives.some((x) => lower.includes(x));
    const isNegative = negatives.some((x) => lower.includes(x));
    if (isPositive) {
      return { klass: "bg-success text-white", icon: `<i class="bi bi-check-lg"></i>`, safeVal: escapeHtml(val) };
    }
    if (isNegative) {
      return { klass: "bg-danger bg-opacity-10 text-danger border", icon: `<i class="bi bi-x"></i>`, safeVal: escapeHtml(val) };
    }
    return { klass: "bg-light text-muted border", icon: "", safeVal: escapeHtml(val) };
  };

  const getSourceIcon = (sourceRaw) => {
    const source = String(sourceRaw || "").toLowerCase();
    if (source === "aggregate") {
      return `<i class="bi bi-diagram-3-fill text-info" title="Aggregated from paragraph instances"></i>`;
    }
    if (source === "deterministic") {
      return `<i class="bi bi-lightning-charge-fill text-warning" title="Deterministic rule"></i>`;
    }
    if (source.includes("ai")) {
      return `<i class="bi bi-stars" style="color:#6f42c1" title="AI"></i>`;
    }
    return `<i class="bi bi-dot text-muted" title="${escapeHtml(source || "unknown")}"></i>`;
  };

  const gradingMetaEl = document.getElementById("gradingRunMeta");
  if (gradingMetaEl) {
    const mode = escapeHtml(d?.meta?.runMode || normalizeRunMode(GRADING_SETTINGS.mode));
    const totalQuestions = Number.isFinite(Number(d?.meta?.totalQuestions)) ? Number(d.meta.totalQuestions) : aggregatedRows.length;
    const totalBaseItems = Number.isFinite(Number(d?.meta?.totalBaseItems)) ? Number(d.meta.totalBaseItems) : aggregatedRows.length;
    const skipped = Number.isFinite(Number(d?.meta?.skippedNonOperationalized)) ? Number(d.meta.skippedNonOperationalized) : 0;
    const telemetry = d?.meta?.telemetry && typeof d.meta.telemetry === "object" ? d.meta.telemetry : null;
    const deterministicCount = Number.isFinite(Number(telemetry?.sourceCounts?.deterministic))
      ? Number(telemetry.sourceCounts.deterministic)
      : (Number.isFinite(Number(d?.meta?.deterministicCount)) ? Number(d.meta.deterministicCount) : 0);
    const aiCount = Number.isFinite(Number(telemetry?.sourceCounts?.ai))
      ? Number(telemetry.sourceCounts.ai)
      : (Number.isFinite(Number(d?.meta?.aiCount)) ? Number(d.meta.aiCount) : 0);
    const aggregateCount = Number.isFinite(Number(telemetry?.sourceCounts?.aggregate))
      ? Number(telemetry.sourceCounts.aggregate)
      : (Number.isFinite(Number(d?.meta?.aggregateCount)) ? Number(d.meta.aggregateCount) : 0);
    const paragraphRowsCount = Number.isFinite(Number(telemetry?.paragraph?.totalRows))
      ? Number(telemetry.paragraph.totalRows)
      : (Number.isFinite(Number(d?.meta?.paragraphRowsCount)) ? Number(d.meta.paragraphRowsCount) : 0);
    const lowBandRowsCount = Number.isFinite(Number(telemetry?.lowBand?.totalRows))
      ? Number(telemetry.lowBand.totalRows)
      : 0;
    const stability = d?.meta?.stabilityGate || null;
    const gateBadge = stability
      ? `<span class="badge ${stability?.metrics?.gatePassed ? "bg-success" : "bg-warning text-dark"} me-1">Stability Gate: ${stability?.metrics?.gatePassed ? "PASS" : "REVIEW"}</span>`
      : "";
    const agreementBadge = stability && Number.isFinite(Number(stability?.metrics?.meanAgreement))
      ? `<span class="badge bg-light text-dark border me-1">Agreement: ${escapeHtml((Number(stability.metrics.meanAgreement) * 100).toFixed(1))}%</span>`
      : "";
    const flipBadge = stability && Number.isFinite(Number(stability?.metrics?.flipRate))
      ? `<span class="badge bg-light text-dark border me-1">Flip: ${escapeHtml((Number(stability.metrics.flipRate) * 100).toFixed(1))}%</span>`
      : "";
    gradingMetaEl.innerHTML = `
      ${gateBadge}
      ${agreementBadge}
      ${flipBadge}
      <span class="badge bg-light text-dark border me-1">Mode: ${mode}</span>
      <span class="badge bg-light text-dark border me-1">Instances: ${escapeHtml(totalQuestions)}</span>
      <span class="badge bg-light text-dark border me-1">Base Items: ${escapeHtml(totalBaseItems)}</span>
      <span class="badge bg-light text-dark border me-1">Deterministic: ${escapeHtml(deterministicCount)}</span>
      <span class="badge bg-light text-dark border me-1">AI: ${escapeHtml(aiCount)}</span>
      <span class="badge bg-light text-dark border me-1">Aggregate: ${escapeHtml(aggregateCount)}</span>
      <span class="badge bg-light text-dark border me-1">Paragraph Rows: ${escapeHtml(paragraphRowsCount)}</span>
      <span class="badge bg-light text-dark border me-1">Low-band Rows: ${escapeHtml(lowBandRowsCount)}</span>
      <span class="badge ${skipped > 0 ? "bg-warning text-dark" : "bg-light text-dark border"}">Skipped(non-operationalized): ${escapeHtml(skipped)}</span>
    `;
  }

  const tbody = document.getElementById("gradingTableBody");
  if (tbody) {
    tbody.innerHTML = "";
    aggregatedRows.forEach((item) => {
      const baseKey = escapeHtml(item?.baseKey || item?.question_key || item?.instanceKey || "");
      const criterion = escapeHtml(item?.criterion || "");
      const band = escapeHtml(item?.band ?? "");
      const atomicQuestion = escapeHtml(item?.atomic_question || "");
      const evidenceRefsHtml = buildSentenceRefListClickableHtml(item?.evidenceSentenceIndices);
      const badge = getValueBadge(item?.value);
      const sourceIcon = getSourceIcon(item?.source);
      const tr = `
        <tr>
          <td class="font-monospace text-muted">${baseKey}</td>
          <td><span class="badge bg-light text-dark border">${criterion}</span></td>
          <td class="fw-bold">${band}</td>
          <td><div class="text-truncate" style="max-width:350px;" title="${atomicQuestion}">${atomicQuestion}</div></td>
          <td class="font-monospace">${evidenceRefsHtml}</td>
          <td class="text-center"><span class="badge ${badge.klass} rounded-pill px-3">${badge.icon} ${badge.safeVal}</span></td>
          <td class="text-end text-muted x-small">${sourceIcon}</td>
        </tr>
      `;
      tbody.insertAdjacentHTML("beforeend", tr);
    });
  }

  const rawRows = Array.isArray(d?.results) ? d.results : [];
  const instanceRows = rawRows.filter((row) => {
    const scope = String(row?.scope || "").toLowerCase();
    const hasDistinctInstance = String(row?.instanceKey || "") !== "" &&
      String(row?.instanceKey || "") !== String(row?.baseKey || row?.question_key || "");
    return scope === "paragraph" || hasDistinctInstance;
  }).slice().sort((a, b) => {
    const pa = Number.isInteger(a?.paragraphNumber) ? a.paragraphNumber : 999;
    const pb = Number.isInteger(b?.paragraphNumber) ? b.paragraphNumber : 999;
    if (pa !== pb) return pa - pb;
    return String(a?.instanceKey || "").localeCompare(String(b?.instanceKey || ""));
  });

  const instanceCard = document.getElementById("instanceResultsCard");
  const instanceBody = document.getElementById("gradingInstanceTableBody");
  if (instanceCard && instanceBody) {
    if (instanceRows.length === 0) {
      instanceCard.classList.add("d-none");
      instanceBody.innerHTML = "";
    } else {
      instanceCard.classList.remove("d-none");
      instanceBody.innerHTML = "";
      instanceRows.forEach((item) => {
        const instanceKey = escapeHtml(item?.instanceKey || item?.baseKey || item?.question_key || "");
        const baseKey = escapeHtml(item?.baseKey || item?.question_key || "");
        const criterion = escapeHtml(item?.criterion || "");
        const band = escapeHtml(item?.band ?? "");
        const scope = escapeHtml(item?.scope || "essay");
        const paragraphRef = Number.isInteger(item?.paragraphIndex)
          ? escapeHtml(getParagraphDisplayId(item.paragraphIndex))
          : (Number.isInteger(item?.paragraphNumber) ? escapeHtml(`P${item.paragraphNumber}`) : "-");
        const evidenceRefsHtml = buildSentenceRefListClickableHtml(item?.evidenceSentenceIndices);
        const badge = getValueBadge(item?.value);
        const sourceIcon = getSourceIcon(item?.source);
        const rowHtml = `
          <tr>
            <td class="font-monospace text-muted">${instanceKey}</td>
            <td class="font-monospace text-muted">${baseKey}</td>
            <td><span class="badge bg-light text-dark border">${criterion}</span></td>
            <td class="fw-bold">${band}</td>
            <td class="text-capitalize">${scope}</td>
            <td class="fw-bold">${paragraphRef}</td>
            <td class="font-monospace">${evidenceRefsHtml}</td>
            <td class="text-center"><span class="badge ${badge.klass} rounded-pill px-3">${badge.icon} ${badge.safeVal}</span></td>
            <td class="text-end text-muted x-small">${sourceIcon}</td>
          </tr>
        `;
        instanceBody.insertAdjacentHTML("beforeend", rowHtml);
      });
    }
  }

  const traceCard = document.getElementById("aggregationTraceCard");
  const traceContainer = document.getElementById("aggregationTraceContainer");
  const trace = d?.meta?.aggregationTrace && typeof d.meta.aggregationTrace === "object"
    ? d.meta.aggregationTrace
    : null;
  if (traceCard && traceContainer) {
    const criteria = ["TR", "CC", "LR", "GRA"];
    const hasAnyTrace = !!criteria.find((c) => Array.isArray(trace?.[c]) && trace[c].length > 0);
    if (!hasAnyTrace) {
      traceCard.classList.add("d-none");
      traceContainer.innerHTML = "";
    } else {
      traceCard.classList.remove("d-none");
      const sections = criteria.map((criterion) => {
        const rows = (trace?.[criterion] || []).map((entry) => {
          const baseKey = escapeHtml(entry?.baseKey || "");
          const mode = escapeHtml(entry?.mode || "majority_pass");
          const instanceCount = escapeHtml(entry?.instanceCount ?? 0);
          const evaluatedCount = escapeHtml(entry?.evaluatedCount ?? 0);
          const passCount = escapeHtml(entry?.passCount ?? 0);
          const passRatio = escapeHtml(
            Number.isFinite(Number(entry?.passRatio))
              ? Number(entry.passRatio).toFixed(2)
              : "0.00"
          );
          const aggregatedValue = escapeHtml(entry?.aggregatedValue || "NA");
          const paraRefs = (Array.isArray(entry?.paragraphIndices) ? entry.paragraphIndices : [])
            .filter((n) => Number.isInteger(n))
            .map((idx) => getParagraphDisplayId(idx))
            .join(", ") || "-";
          return `
            <tr>
              <td class="font-monospace text-muted">${baseKey}</td>
              <td>${mode}</td>
              <td class="text-center">${instanceCount}</td>
              <td class="text-center">${evaluatedCount}</td>
              <td class="text-center">${passCount}</td>
              <td class="text-center">${passRatio}</td>
              <td class="text-center fw-bold">${aggregatedValue}</td>
              <td class="font-monospace">${escapeHtml(paraRefs)}</td>
            </tr>
          `;
        }).join("");
        if (!rows) {
          return `
            <div class="mb-3">
              <div class="fw-bold mb-1">${escapeHtml(criterion)}</div>
              <div class="small text-muted">No paragraph aggregation rows.</div>
            </div>
          `;
        }
        return `
          <div class="mb-3">
            <div class="fw-bold mb-1">${escapeHtml(criterion)}</div>
            <div class="table-responsive">
              <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Base Key</th>
                    <th>Mode</th>
                    <th class="text-center">Instances</th>
                    <th class="text-center">Evaluated</th>
                    <th class="text-center">Pass</th>
                    <th class="text-center">Pass Ratio</th>
                    <th class="text-center">Aggregated</th>
                    <th>Paragraphs</th>
                  </tr>
                </thead>
                <tbody>${rows}</tbody>
              </table>
            </div>
          </div>
        `;
      }).join("");
      traceContainer.innerHTML = sections;
    }
  }

  const telemetryCard = document.getElementById("decisionTelemetryCard");
  const telemetryContainer = document.getElementById("decisionTelemetryContainer");
  const telemetry = d?.meta?.telemetry && typeof d.meta.telemetry === "object"
    ? d.meta.telemetry
    : null;
  const lowBandCoverage = d?.meta?.lowBandCoverage && typeof d.meta.lowBandCoverage === "object"
    ? d.meta.lowBandCoverage
    : null;
  if (telemetryCard && telemetryContainer) {
    const hasTelemetryData = Boolean(telemetry || lowBandCoverage);
    if (!hasTelemetryData) {
      telemetryCard.classList.add("d-none");
      telemetryContainer.innerHTML = "";
    } else {
      telemetryCard.classList.remove("d-none");
      const sourceCounts = telemetry?.sourceCounts || {};
      const paragraph = telemetry?.paragraph || {};
      const lowBand = telemetry?.lowBand || {};
      const aiReliability = telemetry?.aiReliability || {};
      const lowBandRowsByCriterion = lowBand?.rowsByCriterion || {};
      const lowBandByCriterionBadges = ["TR", "CC", "LR", "GRA", "General"]
        .map((criterion) => {
          const count = Number(lowBandRowsByCriterion?.[criterion] || 0);
          if (count <= 0) return "";
          return `<span class="badge bg-light text-dark border me-1">${escapeHtml(criterion)}: ${escapeHtml(count)}</span>`;
        })
        .filter(Boolean)
        .join("");
      const runtimeFailureBadges = Object.entries(aiReliability?.runtimeFailureClassCounts || {})
        .map(([failureClass, count]) => {
          const n = Number(count || 0);
          if (n <= 0) return "";
          return `<span class="badge bg-light text-dark border me-1">${escapeHtml(String(failureClass || "unknown"))}: ${escapeHtml(n)}</span>`;
        })
        .filter(Boolean)
        .join("");
      const noEvidenceCriteria = Array.isArray(lowBandCoverage?.criteriaWithoutLowBandEvidence)
        ? lowBandCoverage.criteriaWithoutLowBandEvidence
        : [];
      const paragraphContribCount = Array.isArray(lowBandCoverage?.paragraphContributions)
        ? lowBandCoverage.paragraphContributions.length
        : 0;
      telemetryContainer.innerHTML = `
        <div class="row g-3">
          <div class="col-md-4">
            <div class="border rounded p-2 bg-light h-100">
              <div class="fw-bold small mb-2">Source Mix</div>
              <div class="small mb-1">Deterministic: <span class="fw-bold">${escapeHtml(Number(sourceCounts?.deterministic || 0))}</span></div>
              <div class="small mb-1">AI: <span class="fw-bold">${escapeHtml(Number(sourceCounts?.ai || 0))}</span></div>
              <div class="small mb-1">Aggregate: <span class="fw-bold">${escapeHtml(Number(sourceCounts?.aggregate || 0))}</span></div>
              <div class="small mb-1">Paragraph Rows: <span class="fw-bold">${escapeHtml(Number(paragraph?.totalRows || 0))}</span></div>
              <div class="small mb-1">Paragraph Deterministic: <span class="fw-bold">${escapeHtml(Number(paragraph?.deterministicRows || 0))}</span></div>
              <div class="small mb-1">Paragraph AI: <span class="fw-bold">${escapeHtml(Number(paragraph?.aiRows || 0))}</span></div>
              <div class="small">Paragraph AI Error: <span class="fw-bold">${escapeHtml(Number(paragraph?.aiErrorRows || 0))}</span></div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded p-2 bg-light h-100">
              <div class="fw-bold small mb-2">AI Reliability</div>
              <div class="small mb-1">AI rows: <span class="fw-bold">${escapeHtml(Number(aiReliability?.totalAiRows || 0))}</span></div>
              <div class="small mb-1">AI error rows: <span class="fw-bold">${escapeHtml(Number(aiReliability?.aiErrorRows || 0))}</span></div>
              <div class="small mb-1">Recoverable failures: <span class="fw-bold">${escapeHtml(Number(aiReliability?.recoverableFailureRows || 0))}</span></div>
              <div class="small mb-1">Non-recoverable failures: <span class="fw-bold">${escapeHtml(Number(aiReliability?.nonRecoverableFailureRows || 0))}</span></div>
              <div class="small mb-1">Retry attempts: <span class="fw-bold">${escapeHtml(Number(aiReliability?.retryAttempts || 0))}</span></div>
              <div class="small mb-1">Fallback used rows: <span class="fw-bold">${escapeHtml(Number(aiReliability?.fallbackUsedRows || 0))}</span></div>
              <div class="small mb-1">Rescued by retry: <span class="fw-bold">${escapeHtml(Number(aiReliability?.rescuedByRetryRows || 0))}</span></div>
              <div class="small mb-2">Rescued by fallback: <span class="fw-bold">${escapeHtml(Number(aiReliability?.rescuedByFallbackRows || 0))}</span></div>
              <div class="small mb-1">Still unevaluable: <span class="fw-bold">${escapeHtml(Number(aiReliability?.stillUnevaluableRows || 0))}</span></div>
              <div class="small">${runtimeFailureBadges || `<span class="text-muted">No runtime failure classes.</span>`}</div>
            </div>
          </div>
          <div class="col-md-4">
            <div class="border rounded p-2 bg-light h-100">
              <div class="fw-bold small mb-2">Low-band Coverage</div>
              <div class="small mb-1">Low-band rows: <span class="fw-bold">${escapeHtml(Number(lowBand?.totalRows || 0))}</span></div>
              <div class="small mb-1">AI fallback (no rule): <span class="fw-bold">${escapeHtml(Number(lowBand?.aiFallbackNoRule || 0))}</span></div>
              <div class="small mb-1">AI fallback (rule returned null): <span class="fw-bold">${escapeHtml(Number(lowBand?.aiFallbackRuleReturnedNull || 0))}</span></div>
              <div class="small mb-1">AI fallback (rule error): <span class="fw-bold">${escapeHtml(Number(lowBand?.aiFallbackRuleError || 0))}</span></div>
              <div class="small mb-2">Low-band rows with Error: <span class="fw-bold">${escapeHtml(Number(lowBand?.errorRows || 0))}</span></div>
              <div class="small mb-2">${lowBandByCriterionBadges || `<span class="text-muted">No low-band rows by criterion.</span>`}</div>
              <div class="small mb-1">Triggered low-band items: <span class="fw-bold">${escapeHtml(Array.isArray(lowBandCoverage?.triggeredItems) ? lowBandCoverage.triggeredItems.length : 0)}</span></div>
              <div class="small mb-1">AI-only low-band items: <span class="fw-bold">${escapeHtml(Array.isArray(lowBandCoverage?.aiOnlyItems) ? lowBandCoverage.aiOnlyItems.length : 0)}</span></div>
              <div class="small mb-1">Paragraph contributors: <span class="fw-bold">${escapeHtml(paragraphContribCount)}</span></div>
              <div class="small">Criteria with no low-band evidence: <span class="fw-bold">${escapeHtml(noEvidenceCriteria.join(", ") || "None")}</span></div>
            </div>
          </div>
        </div>
      `;
    }
  }

  const gateTraceCard = document.getElementById("gateTraceCard");
  const gateTraceContainer = document.getElementById("gateTraceContainer");
  const gateTrace = d?.meta?.gateTrace && typeof d.meta.gateTrace === "object"
    ? d.meta.gateTrace
    : (d?.meta?.scoreTrace && typeof d.meta.scoreTrace === "object" ? d.meta.scoreTrace : null);
  if (gateTraceCard && gateTraceContainer) {
    const criteria = ["TR", "CC", "LR", "GRA"];
    const hasGateTrace = Boolean(criteria.find((criterion) => gateTrace?.[criterion]));
    if (!hasGateTrace) {
      gateTraceCard.classList.add("d-none");
      gateTraceContainer.innerHTML = "";
    } else {
      gateTraceCard.classList.remove("d-none");
      gateTraceContainer.innerHTML = criteria.map((criterion) => {
        const item = gateTrace?.[criterion] || {};
        const gates = Array.isArray(item?.evaluatedGates) ? item.evaluatedGates : [];
        const rows = gates.map((gate) => {
          const status = String(gate?.status || "").toLowerCase();
          let statusBadge = `<span class="badge bg-light text-dark border">Unknown</span>`;
          if (status === "baseline") statusBadge = `<span class="badge bg-info-subtle text-info border">Baseline</span>`;
          else if (status === "passed") statusBadge = `<span class="badge bg-success">Passed</span>`;
          else if (status === "partial") statusBadge = `<span class="badge bg-warning text-dark">Partial</span>`;
          else if (status === "failed") statusBadge = `<span class="badge bg-danger">Failed</span>`;
          else if (status === "not_evaluable") statusBadge = `<span class="badge bg-secondary">Not Evaluable</span>`;
          const passRatio = Number.isFinite(Number(gate?.passRatio))
            ? `${(Number(gate.passRatio) * 100).toFixed(1)}%`
            : "-";
          const fallbackLabel = gate?.fallbackApplied?.type
            ? `${gate.fallbackApplied.type} => ${gate.fallbackApplied.resultingBand}`
            : "-";
          return `
            <tr>
              <td class="fw-bold">${escapeHtml(gate?.band ?? "-")}</td>
              <td class="text-end font-monospace">${escapeHtml(gate?.passedWeight ?? "-")}</td>
              <td class="text-end font-monospace">${escapeHtml(gate?.totalWeight ?? "-")}</td>
              <td class="text-end font-monospace">${escapeHtml(passRatio)}</td>
              <td>${statusBadge}</td>
              <td class="font-monospace">${escapeHtml(gate?.resultingBandAfterGate ?? "-")}</td>
              <td class="font-monospace">${escapeHtml(fallbackLabel)}</td>
            </tr>
          `;
        }).join("");
        const availableBands = Array.isArray(item?.availableBandGates) ? item.availableBandGates.join(", ") : "-";
        const fallbackSummary = item?.fallbackApplied?.type
          ? `${item.fallbackApplied.type} => ${item.fallbackApplied.resultingBand}`
          : "none";
        return `
          <div class="mb-3">
            <div class="d-flex flex-wrap gap-2 align-items-center mb-1">
              <span class="badge bg-light text-dark border">${escapeHtml(criterion)}</span>
              <span class="small text-muted">Available gates: ${escapeHtml(availableBands || "-")}</span>
              <span class="small text-muted">Final score: <span class="fw-bold">${escapeHtml(item?.resultingCriterionScore ?? "-")}</span></span>
              <span class="small text-muted">Fallback: <span class="fw-bold">${escapeHtml(fallbackSummary)}</span></span>
            </div>
            <div class="table-responsive">
              <table class="table table-sm align-middle mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Band Gate</th>
                    <th class="text-end">Passed W</th>
                    <th class="text-end">Total W</th>
                    <th class="text-end">Pass Ratio</th>
                    <th>Status</th>
                    <th>Resulting Band</th>
                    <th>Fallback</th>
                  </tr>
                </thead>
                <tbody>${rows || `<tr><td colspan="7" class="text-muted small">No gate evaluations.</td></tr>`}</tbody>
              </table>
            </div>
          </div>
        `;
      }).join("");
    }
  }

  const promptContainer = document.getElementById("gradingPrompts");
  if (promptContainer) {
    promptContainer.innerHTML = "";
    const prompts = d?.meta?.aiPrompts || d?.meta?.allAiPrompts;
    if (prompts && Array.isArray(prompts) && prompts.length > 0) {
      const promptsHtml = prompts.map((p, idx) => `
        <div class="border-bottom border-secondary p-3">
          <div class="text-white-50 small mb-2 text-uppercase fw-bold">Batch ${idx + 1}</div>
          <pre class="text-success small font-monospace m-0" style="white-space: pre-wrap;">${escapeHtml(p)}</pre>
        </div>
      `).join("");
      promptContainer.innerHTML = `
        <details class="card border-0 shadow-sm">
          <summary class="card-header bg-white fw-bold small text-muted" style="cursor:pointer;">
            <i class="bi bi-code-square me-2"></i>View Grading Engine Prompts (${prompts.length} Batches)
          </summary>
          <div class="card-body bg-dark p-0">
            ${promptsHtml}
          </div>
        </details>
      `;
    }
  }

  document.getElementById("step4Placeholder")?.classList.add("d-none");
  document.getElementById("step4Result")?.classList.remove("d-none");
}

async function runGradingStep() {
  if (blockIfStepLocked("step4grade")) return;
  if (!GLOBALESSAYOBJECT || !GLOBALANALYSIS || !GLOBALEXTRACTION) {
    return safeShowMessage({
      title: "Data Missing",
      icon: "warning",
      message: "Steps 1, 2, and 3 must be completed first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }
  const proceed = await confirmStep4RerunResetIfNeeded();
  if (!proceed) return;

  const btn = document.getElementById("btnGrade");
  btn.disabled = true;
  btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Calculating...`;
  const controller = beginAbortableStep("step4grade");
  if (!controller) {
    btn.disabled = false;
    btn.innerHTML = `<i class="bi bi-play-circle-fill me-1"></i> Calculate Score`;
    updateStepLocks();
    return;
  }
  const cancelToken = getActiveStepCancelToken("step4grade");

  try {
    if (getStep4CustomPromptForExecution() === STEP4_MISSING) {
      throw new Error("Pick a Step 4 prompt template first, or switch to built-in prompt.");
    }
    const payload = buildStep4Payload({ disableCache: true, cancelToken });
    const r = await postJsonAndRecord(
      "step4grade",
      "/ielts/scoring/step4/grade",
      payload,
      { signal: controller.signal }
    );

    if (r.status !== "success") throw new Error(r.message || "Grading failed.");

    GLOBALGRADING = r.data;
    const responseStability = r?.data?.meta?.stabilityGate || null;
    const executionMeta = syncStepExecutionRequestMeta("step4grade", {
      fallbackMode: "single_run",
      fallbackRunCount: 1,
      stabilityMeta: responseStability,
      stabilityStepKey: "step4stability",
      clearStabilityOnSingleRun: true
    });
    GLOBALSTABILITY = responseStability || null;
    if (
      executionMeta?.mode === "stability_gate_auto_consensus" &&
      responseStability &&
      SESSION_BUNDLE?.steps?.step4grade
    ) {
      const gradeTiming = SESSION_BUNDLE.steps.step4grade?.timing || {};
      SESSION_BUNDLE.steps.step4stability = {
        request: {
          mode: "stability_gate_auto_consensus",
          runCount: executionMeta.runCount
        },
        response: {
          contentType: "application/json",
          json: { status: "success", data: responseStability }
        },
        timing: {
          startedAt: toPositiveInt(gradeTiming?.startedAt, Date.now()),
          endedAt: toPositiveInt(gradeTiming?.endedAt, Date.now())
        }
      };
    }
    setFreezePoint("step4_scoring_frozen", {
      overallBand: r?.data?.overallBand ?? null,
      scores: r?.data?.scores || {},
      runMode: r?.data?.meta?.runMode || normalizeRunMode(GRADING_SETTINGS.mode),
      totalQuestions: r?.data?.meta?.totalQuestions ?? null,
      totalBaseItems: r?.data?.meta?.totalBaseItems ?? null,
      stabilityGate: Boolean(r?.data?.meta?.stabilityGate)
    });
    addTweakLog("step4_grading_completed", {
      overallBand: r?.data?.overallBand ?? null,
      runMode: r?.data?.meta?.runMode || normalizeRunMode(GRADING_SETTINGS.mode),
      stabilityGate: Boolean(r?.data?.meta?.stabilityGate)
    });
    renderGradingFromData(r.data);

  } catch (e) {
    if (isAbortError(e)) {
      await safeShowMessage({
        title: "Step 4 Stopped",
        icon: "warning",
        message: "Step 4 grading was stopped before completion.",
        buttons: [{ text: "OK", class: "btn-warning" }]
      });
    } else {
      console.error(e);
      safeShowMessage({
        title: "Grading Error",
        icon: "error",
        message: e.message || "Grading failed.",
        buttons: [{ text: "OK", class: "btn-danger" }]
      });
    }
  } finally {
    finishAbortableStep("step4grade", controller);
    btn.disabled = false;
    btn.innerHTML = `<i class="bi bi-play-circle-fill me-1"></i> Calculate Score`;
    updateStepLocks();
  }
}

async function runStabilityGateConsensus() {
  if (blockIfStepLocked("step4grade")) return;
  if (!GLOBALESSAYOBJECT || !GLOBALANALYSIS || !GLOBALEXTRACTION) {
    return safeShowMessage({
      title: "Data Missing",
      icon: "warning",
      message: "Steps 1, 2, and 3 must be completed first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }
  const proceed = await confirmStep4RerunResetIfNeeded();
  if (!proceed) return;

  const btnGate = document.getElementById("btnStabilityGate");
  const btnGrade = document.getElementById("btnGrade");
  const controller = beginAbortableStep("step4grade");
  if (!controller) return;
  const cancelToken = getActiveStepCancelToken("step4grade");
  const startedAt = Date.now();
  startRunningTimer("step4grade", "Step 4 Stability Gate");

  if (btnGate) {
    btnGate.disabled = true;
    btnGate.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Running 1/${STABILITY_GATE_CONFIG.runCount}...`;
  }
  if (btnGrade) btnGrade.disabled = true;

  try {
    if (getStep4CustomPromptForExecution() === STEP4_MISSING) {
      throw new Error("Pick a Step 4 prompt template first, or switch to built-in prompt.");
    }
    const payload = buildStep4Payload({ disableCache: true, cancelToken });
    const gradeRuns = [];

    for (let i = 0; i < STABILITY_GATE_CONFIG.runCount; i += 1) {
      if (controller.signal.aborted) {
        throw createAbortError("Step 4 stability gate was stopped.");
      }
      if (btnGate) {
        btnGate.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Running ${i + 1}/${STABILITY_GATE_CONFIG.runCount}...`;
      }
      const response = await postJsonNoRecord(
        "/ielts/scoring/step4/grade",
        payload,
        { signal: controller.signal }
      );
      gradeRuns.push(response.data);
    }

    const consensusResult = buildStabilityConsensus(gradeRuns);
    const scoreResult = calculateBandScoresClient(consensusResult.consensusRows);
    const consensusData = deepCloneJson(gradeRuns[gradeRuns.length - 1] || {});
    consensusData.aggregatedResults = consensusResult.consensusRows;
    consensusData.scores = scoreResult.criteria;
    consensusData.overallBand = scoreResult.overall;
    consensusData.meta = {
      ...(consensusData.meta || {}),
      modelUsed: consensusData?.meta?.modelUsed
        ? `${consensusData.meta.modelUsed} + consensus`
        : "consensus_majority_vote",
      gateTrace: scoreResult?.gateTrace || {},
      scoreTrace: scoreResult?.gateTrace || {},
      stabilityGate: {
        enabled: true,
        autoConsensus: true,
        runCount: STABILITY_GATE_CONFIG.runCount,
        generatedAt: new Date().toISOString(),
        thresholds: {
          minMeanAgreement: STABILITY_GATE_CONFIG.minMeanAgreement,
          maxFlipRate: STABILITY_GATE_CONFIG.maxFlipRate,
          maxUnstableShare: STABILITY_GATE_CONFIG.maxUnstableShare
        },
        metrics: {
          ...consensusResult.metrics,
          meanAgreement: Number.isFinite(Number(consensusResult.metrics.meanAgreement))
            ? Number(Number(consensusResult.metrics.meanAgreement).toFixed(4))
            : null,
          flipRate: Number.isFinite(Number(consensusResult.metrics.flipRate))
            ? Number(Number(consensusResult.metrics.flipRate).toFixed(4))
            : null,
          unstableShare: Number.isFinite(Number(consensusResult.metrics.unstableShare))
            ? Number(Number(consensusResult.metrics.unstableShare).toFixed(4))
            : null,
          pairwise: (consensusResult.metrics.pairwise || []).map((p) => ({
            ...p,
            agreementRate: Number.isFinite(Number(p.agreementRate))
              ? Number(Number(p.agreementRate).toFixed(4))
              : null
          }))
        },
        topUnstable: consensusResult.unstableRows
      }
    };

    GLOBALGRADING = consensusData;
    GLOBALSTABILITY = consensusData?.meta?.stabilityGate || null;

    const endedAt = Date.now();
    SESSION_BUNDLE.steps.step4grade = {
      request: {
        url: "/ielts/scoring/step4/grade",
        payload,
        mode: "stability_gate_auto_consensus",
        runCount: STABILITY_GATE_CONFIG.runCount
      },
      response: {
        contentType: "application/json",
        json: { status: "success", data: consensusData }
      },
      timing: { startedAt, endedAt }
    };
    SESSION_BUNDLE.steps.step4stability = {
      request: {
        mode: "stability_gate_auto_consensus",
        runCount: STABILITY_GATE_CONFIG.runCount
      },
      response: {
        contentType: "application/json",
        json: { status: "success", data: GLOBALSTABILITY }
      },
      timing: { startedAt, endedAt }
    };
    if (SESSION_BUNDLE.steps?.step6report) {
      delete SESSION_BUNDLE.steps.step6report;
    }
    syncStepExecutionRequestMeta("step4grade", {
      fallbackMode: "stability_gate_auto_consensus",
      fallbackRunCount: STABILITY_GATE_CONFIG.runCount,
      stabilityMeta: GLOBALSTABILITY,
      stabilityStepKey: "step4stability"
    });
    SESSION_BUNDLE.dirty = true;

    setFreezePoint("step4_scoring_frozen", {
      overallBand: consensusData?.overallBand ?? null,
      scores: consensusData?.scores || {},
      runMode: consensusData?.meta?.runMode || normalizeRunMode(GRADING_SETTINGS.mode),
      totalQuestions: consensusData?.meta?.totalQuestions ?? null,
      totalBaseItems: consensusData?.meta?.totalBaseItems ?? null,
      stabilityGate: true
    });
    setFreezePoint("step4_stability_gate_frozen", {
      gatePassed: Boolean(GLOBALSTABILITY?.metrics?.gatePassed),
      meanAgreement: GLOBALSTABILITY?.metrics?.meanAgreement ?? null,
      flipRate: GLOBALSTABILITY?.metrics?.flipRate ?? null,
      unstableCount: GLOBALSTABILITY?.metrics?.unstableCount ?? null,
      unstableShare: GLOBALSTABILITY?.metrics?.unstableShare ?? null
    });
    addTweakLog("step4_stability_gate_completed", {
      runCount: STABILITY_GATE_CONFIG.runCount,
      gatePassed: Boolean(GLOBALSTABILITY?.metrics?.gatePassed),
      meanAgreement: GLOBALSTABILITY?.metrics?.meanAgreement ?? null,
      flipRate: GLOBALSTABILITY?.metrics?.flipRate ?? null,
      unstableCount: GLOBALSTABILITY?.metrics?.unstableCount ?? null,
      changedCount: GLOBALSTABILITY?.metrics?.changedCount ?? null
    });

    renderGradingFromData(consensusData);

    const pass = Boolean(GLOBALSTABILITY?.metrics?.gatePassed);
    const meanAgreement = Number.isFinite(Number(GLOBALSTABILITY?.metrics?.meanAgreement))
      ? `${(Number(GLOBALSTABILITY.metrics.meanAgreement) * 100).toFixed(1)}%`
      : "-";
    const flipRate = Number.isFinite(Number(GLOBALSTABILITY?.metrics?.flipRate))
      ? `${(Number(GLOBALSTABILITY.metrics.flipRate) * 100).toFixed(1)}%`
      : "-";
    await safeShowMessage({
      title: pass ? "Stability Gate Passed" : "Stability Gate Needs Review",
      icon: pass ? "check" : "warning",
      message: `Auto-consensus applied from ${STABILITY_GATE_CONFIG.runCount} runs.
Mean agreement: ${meanAgreement}
Flip rate: ${flipRate}`,
      buttons: [{ text: "OK", class: pass ? "btn-success" : "btn-warning" }]
    });
  } catch (e) {
    if (isAbortError(e)) {
      await safeShowMessage({
        title: "Step 4 Stopped",
        icon: "warning",
        message: "Step 4 stability gate was stopped before completion.",
        buttons: [{ text: "OK", class: "btn-warning" }]
      });
    } else {
      console.error(e);
      safeShowMessage({
        title: "Stability Gate Error",
        icon: "error",
        message: e.message || "Failed to run stability gate.",
        buttons: [{ text: "OK", class: "btn-danger" }]
      });
    }
  } finally {
    finishAbortableStep("step4grade", controller);
    stopRunningTimer();
    refreshTimingUI();
    if (btnGate) {
      btnGate.disabled = false;
      updateStep4ConsensusButtonLabel();
    }
    if (btnGrade) {
      btnGrade.disabled = false;
      btnGrade.innerHTML = `<i class="bi bi-play-circle-fill me-1"></i> Calculate Score`;
    }
    updateStepLocks();
  }
}

