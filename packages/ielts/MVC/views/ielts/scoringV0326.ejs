              </div>
              ${examinerBandHtml}
              <hr/>
              <div class="row text-center g-2">
                <div class="col-3"><div class="small text-muted fw-bold">TR</div><div class="h5 m-0">${escapeHtml(GLOBALGRADING.scores?.TR)}</div></div>
                <div class="col-3"><div class="small text-muted fw-bold">CC</div><div class="h5 m-0">${escapeHtml(GLOBALGRADING.scores?.CC)}</div></div>
                <div class="col-3"><div class="small text-muted fw-bold">LR</div><div class="h5 m-0">${escapeHtml(GLOBALGRADING.scores?.LR)}</div></div>
