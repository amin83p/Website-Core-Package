<%
  // Extract data for cleaner template usage
  const isEdit = !!(sample && sample.id);
  const selectedOrgId = isEdit ? String(sample.orgId || sample.org || sample.organizationId || '').trim() : '';
  const orgChoices = Array.isArray(user?.allowedOrgs) ? user.allowedOrgs : [];
  const matchedOrg = isEdit ? orgChoices.find((org) => String(org?.orgId || '').trim() === selectedOrgId) : null;
  const selectedOrgName = String(
    matchedOrg?.name ||
    matchedOrg?.orgName ||
    ''
  ).trim();
%>

<div class="sections-page">
  
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="page-heading size-md m-0">            
      <%= isEdit ? 'Edit Sample' : 'Create New Sample' %>
    </h1>
    <% if (isEdit) { %>
      <div class="d-flex flex-column align-items-end gap-1">
        <span class="badge bg-primary border">ID: <%= sample.id %></span>
        <span class="badge bg-light text-dark border">
          Organization: <%= selectedOrgName || 'N/A' %><%= selectedOrgId ? ` (#${selectedOrgId})` : '' %>
        </span>
      </div>
    <% } else { %>
        <span class="badge bg-success border">New Entry</span>
    <% } %>
  </div>

  <div class="form-container" style="width: 100%; max-width: 100%;">
    <form id="sampleForm" action="<%= isEdit ? '/ielts/task2samples/edit/' + sample.id  : '/ielts/task2samples/new' %>" method="POST" enctype="multipart/form-data">
      
      <input type="hidden" name="actionStateId" value="<%= typeof actionStateId !== 'undefined' ? actionStateId : '' %>">
      <input type="hidden" id="currentSampleId" value="<%= sample ? sample.id : '' %>">

      <ul class="nav nav-tabs mb-4" id="sampleTabs" role="tablist">
        <li class="nav-item">
          <button class="nav-link active" id="general-tab" data-bs-toggle="tab" data-bs-target="#general" type="button">General Info</button>
        </li>
        <li class="nav-item">
          <button class="nav-link" id="content-tab" data-bs-toggle="tab" data-bs-target="#content" type="button">Sample Text</button>
        </li>
        <li class="nav-item">
          <button class="nav-link" id="feedback-tab" data-bs-toggle="tab" data-bs-target="#feedback" type="button">Feedback & Evaluation</button>
        </li>
      </ul>

      <div class="tab-content">
        
        <div class="tab-pane fade show active" id="general">
            <div class="row">
                <div class="col-md-8">
                    <div class="row">
                        <div class="col-md-4 mb-3">
                            <label class="form-label">Sample Type *</label>
                            <select name="type" class="form-select size-md" required>
                                <% 
                                   const types = ['ONLINE', 'BOOK', 'ARTICLE', 'STUDENT_SUBMISSION', 'MODEL_ANSWER', 'OTHER']; 
                                   const currentType = sample ? (sample.type || 'ONLINE') : 'ONLINE';
                                %>
                                <% types.forEach(t => { %>
                                   <option value="<%= t %>" <%= currentType === t ? 'selected' : '' %>><%= t %></option>
                                <% }) %>
                            </select>
                        </div>
                        
                        <div class="col-md-8 mb-3">
                            <label class="form-label">Reference Name (Title) *</label>
                            <input type="text" name="refName" class="form-control size-md" value="<%= sample ? sample.refName : '' %>" placeholder="e.g., Cambridge 15 Test 2 Task 2" required>
                        </div>
                    </div>
                   
                    <div class="mb-3">
                        <label class="form-label">Reference Address</label>
                        <input type="text" name="refAddress" class="form-control size-md" placeholder="URL or Page Number..." value="<%= sample ? (sample.refAddress || '') : '' %>">
                        <small class="form-text text-muted">Paste the URL link or book page reference here.</small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Essay Question / Prompt *</label>
                        <textarea name="question" class="form-control size-md bg-light" rows="3" placeholder="Enter the full question topic here..." required><%= sample ? sample.question : '' %></textarea>
                    </div>

                </div>
                
                <div class="col-md-4">
                    <div class="card bg-light border-0 mb-3">
                        <div class="card-body">
                            <h6 class="fw-bold text-primary mb-3">Scoring & Files</h6>
                            
                            <div class="mb-3">
                                <label class="form-label small fw-bold">Band Score (0-9)</label>
                                <input type="number" name="bandScore" class="form-control size-sm" value="<%= sample ? sample.bandScore : '' %>" step="0.5" min="0" max="9" placeholder="-">
                            </div>

                            <div class="mb-2">
                                <label class="form-label small fw-bold">Attachment (Image/File)</label>
                                <input type="file" name="attachment" class="form-control form-control-sm">
                                <% if (sample && sample.attachment) { %>
                                    <div class="mt-2 p-2 bg-white border rounded d-flex align-items-center gap-2">
                                        <i class="bi bi-paperclip text-muted"></i>
                                        <a href="<%= sample.attachment.url %>" target="_blank" class="text-truncate small"><%= sample.attachment.filename %></a>
                                    </div>
                                <% } %>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="content">
            <div class="mb-3">
                <label class="form-label text-muted small text-uppercase fw-bold">Essay / Sample Content</label>
                <textarea name="text" class="form-control font-monospace" style="min-height: 400px; font-size: 0.9rem;" placeholder="Paste the essay text here..."><%= sample ? sample.text : '' %></textarea>
            </div>
        </div>

        <div class="tab-pane fade" id="feedback">
            <div class="mb-3">
                <label class="form-label text-muted small text-uppercase fw-bold">Human Feedback / Examiner Notes</label>
                <textarea name="feedback" class="form-control bg-light" style="min-height: 400px;" placeholder="Enter examiner comments here..."><%= sample ? sample.feedback : '' %></textarea>
            </div>
        </div>

    </div> 

    <div class="button-row mt-4 pt-3 border-top">
        <button type="submit" class="btn btn-filled btn-primary btn-md">Save Sample</button>
        <a href="/ielts/task2samples" class="btn btn-filled btn-secondary btn-md" id="btnCancelAction"> Cancel </a>
    </div>
    </form>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const form = document.getElementById('sampleForm');
  if (!form) return;
  const submitBtn = form ? form.querySelector('button[type="submit"]') : null;
  const cancelBtn = document.getElementById('btnCancelAction');
  let isSubmitting = false;

  function cacheButtonHtml(button) {
    if (!button) return;
    if (!button.dataset.defaultHtml) {
      button.dataset.defaultHtml = button.innerHTML;
    }
  }

  function setButtonBusy(button, label) {
    if (!button) return;
    cacheButtonHtml(button);
    button.disabled = true;
    button.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>' + (label || 'Working...');
    if (button.tagName === 'A') {
      button.classList.add('disabled');
      button.setAttribute('aria-disabled', 'true');
      button.style.pointerEvents = 'none';
    }
  }

  function restoreButton(button) {
    if (!button) return;
    if (button.dataset.defaultHtml) button.innerHTML = button.dataset.defaultHtml;
    button.disabled = false;
    if (button.tagName === 'A') {
      button.classList.remove('disabled');
      button.removeAttribute('aria-disabled');
      button.style.pointerEvents = '';
    }
  }

  cacheButtonHtml(submitBtn);
  cacheButtonHtml(cancelBtn);

  cancelBtn?.addEventListener('click', (event) => {
    if (isSubmitting) {
      event.preventDefault();
      return;
    }
    setButtonBusy(cancelBtn, 'Cancelling...');
    if (submitBtn) submitBtn.disabled = true;
  });

  // --- SUBMIT HANDLER ---
  form.addEventListener('submit', async e => {
    e.preventDefault();
    if (isSubmitting) return;
    isSubmitting = true;
    setButtonBusy(submitBtn, 'Saving...');
    if (cancelBtn) cancelBtn.disabled = true;
  
    // Use FormData for File Uploads
    const formData = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: 'POST',
        headers: { 
            // 'Content-Type': 'multipart/form-data', // ❌ DO NOT SET THIS MANUALLY with FormData
            'X-AJAX-Request': 'true' 
        },
        body: formData // ✅ Send raw FormData (Browser handles boundary)
      });

      const result = await response.json();
  
      if (result.status === 'success') {
        if(typeof showMessageModal === 'function') {
            await showMessageModal({ title: 'Success', icon: 'success', message: result.message || 'Saved successfully.', buttons: [{ text: 'OK', class: 'btn-success' }] });
        }
        // Redirect to list
        window.location.href = '/ielts/task2samples';
      } else {
        if(typeof showMessageModal === 'function') {
            await showMessageModal({ title: 'Error', icon: 'error', message: result.message || 'Failed to save.', buttons: [{ text: 'OK', class: 'btn-danger' }] });
        } else { alert(result.message); }
        isSubmitting = false;
        restoreButton(submitBtn);
        restoreButton(cancelBtn);
      }
    } catch (error) {
      console.error(error);
      alert('Unexpected error occurred.');
      isSubmitting = false;
      restoreButton(submitBtn);
      restoreButton(cancelBtn);
    }
  });
});
</script>

<style>
    .nav-tabs .nav-link { color: #495057; font-weight: 500; }
    .nav-tabs .nav-link.active { font-weight: bold; color: #0d6efd; border-top: 3px solid #0d6efd; }
</style>
