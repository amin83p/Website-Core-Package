<div class="sections-page">
  <div class="three-run-header-wrap mb-4">
    <div class="d-flex align-items-start justify-content-between flex-wrap gap-2">
      <div>
        <h2 class="page-heading size-md m-0">Step 4 Tuning Comparison</h2>
        <div class="text-muted small mt-1">Cross-session variation analysis for Step 3 and Step 4 unstable questions.</div>
      </div>
      <div class="d-flex align-items-center gap-2 flex-wrap">
        <a href="<%= ieltsSectionDashboardHref %>" class="ielts-navigator-dashboard btn btn-secondary btn-filled text-white btn-sm d-inline-flex align-items-center gap-1">
          <i class="bi bi-speedometer2"></i>
          <span>IELTS Dashboard</span>
        </a>
        <a href="/ielts/scoring/dashboard" class="btn btn-outline-secondary btn-sm d-inline-flex align-items-center gap-1">
          <i class="bi bi-graph-up-arrow"></i>
          <span>Scoring Dashboard</span>
        </a>
      </div>
    </div>
    <div class="three-run-action-row d-flex gap-2 flex-wrap mt-3">
      <a href="/ielts/scoring/history?type=step4_tuning" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-1"></i> Step 4 History
      </a>
      <a href="/ielts/scoring/tuning/step4" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-sliders me-1"></i> Open Step 4 Tuning
      </a>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-xl-3 col-md-6"><div class="metric-tile"><div class="metric-label">Selected Results</div><div id="kpiSessions" class="metric-value">-</div></div></div>
    <div class="col-xl-3 col-md-6"><div class="metric-tile"><div class="metric-label">Question Universe</div><div id="kpiQuestions" class="metric-value">-</div></div></div>
    <div class="col-xl-3 col-md-6"><div class="metric-tile"><div class="metric-label">Avg Step3 Unstable</div><div id="kpiStep3" class="metric-value">-</div></div></div>
    <div class="col-xl-3 col-md-6"><div class="metric-tile"><div class="metric-label">Avg Step4 Unstable</div><div id="kpiStep4" class="metric-value">-</div></div></div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-xl-4">
      <div class="card border-0 shadow-sm h-100 panel-card">
        <div class="card-header bg-white fw-bold small">Selected Results</div>
        <div class="card-body p-0">
          <div class="table-responsive" style="max-height: 440px;">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light sticky-top">
                <tr>
                  <th>Result</th>
                  <th class="text-center">Unstable</th>
                  <th class="text-center">Load</th>
                </tr>
              </thead>
              <tbody id="resultRows"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
    <div class="col-xl-8">
      <div class="card border-0 shadow-sm h-100 panel-card">
        <div class="card-header bg-white fw-bold small">Result Summary (Click a Result)</div>
        <div class="card-body" id="resultSummaryPanel">
          <div class="text-muted small">Select a result from the left list.</div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-12">
      <div class="card border-0 shadow-sm h-100 panel-card">
        <div class="card-header bg-white fw-bold small">Question Fluctuation Frequency (Across Selected Results)</div>
        <div class="card-body">
          <div class="chart-shell">
            <canvas id="questionFrequencyChart" height="320"></canvas>
          </div>
          <div id="questionChartLegend" class="small mt-2 text-muted"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-xl-6">
      <div class="card border-0 shadow-sm panel-card h-100">
        <div class="card-header bg-white fw-bold small">Most Fluctuating Questions</div>
        <div class="card-body p-0">
          <ul id="mostFluctuatingList" class="list-group list-group-flush small"></ul>
        </div>
      </div>
    </div>
    <div class="col-xl-6">
      <div class="card border-0 shadow-sm panel-card h-100">
        <div class="card-header bg-white fw-bold small">Most Consistent Questions</div>
        <div class="card-body p-0">
          <ul id="mostConsistentList" class="list-group list-group-flush small"></ul>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3 panel-card">
    <div class="card-header bg-white fw-bold small">Per Result: Non-Consistent Questions</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th>Result</th>
              <th class="text-center">Step3 Unstable</th>
              <th class="text-center">Step4 Unstable</th>
              <th>Non-Consistent Question Keys (Step4)</th>
            </tr>
          </thead>
          <tbody id="perResultUnstableRows"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3 panel-card">
    <div class="card-header bg-white fw-bold small">Cross-Sample Answer Consistency (Same Question Across Selected Samples)</div>
    <div class="card-body p-0">
      <div class="table-responsive" style="max-height: 56vh;">
        <table class="table table-sm align-middle mb-0">
          <thead class="table-light sticky-top" id="crossSampleHead"></thead>
          <tbody id="crossSampleRows"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm panel-card">
    <div class="card-header bg-white fw-bold small">Question Occurrence Matrix by Result (0=Stable, 1=Unstable)</div>
    <div class="card-body p-0">
      <div class="table-responsive" style="max-height: 68vh;">
        <table class="table table-sm table-bordered mb-0 align-middle">
          <thead id="questionMatrixHead" class="table-light sticky-top"></thead>
          <tbody id="questionMatrixRows"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script type="application/json" id="threeRunCompareRecords"><%- JSON.stringify(records || []) %></script>
<script type="application/json" id="threeRunCompareAnalysis"><%- JSON.stringify(analysis || {}) %></script>
<script>
(function () {
  const records = (() => {
    try { return JSON.parse(document.getElementById('threeRunCompareRecords')?.textContent || '[]'); } catch (_) { return []; }
  })();
  const analysis = (() => {
    try { return JSON.parse(document.getElementById('threeRunCompareAnalysis')?.textContent || '{}'); } catch (_) { return {}; }
  })();

  const esc = (v) => String(v ?? '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
  const toPct = (v) => Number.isFinite(Number(v)) ? `${(Number(v) * 100).toFixed(1)}%` : '-';
  const shortId = (id) => {
    const s = String(id || '').trim();
    return s.length > 14 ? `${s.slice(0, 7)}...${s.slice(-4)}` : s || '-';
  };
  const fmtDate = (value) => {
    if (!value) return '-';
    const dt = new Date(value);
    if (Number.isNaN(dt.getTime())) return '-';
    return `${dt.toLocaleDateString()} ${dt.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`;
  };
  const active = { index: records.length ? 0 : null };
  const CRITERION_COLORS = {
    TR: '#0d6efd',
    CC: '#198754',
    LR: '#fd7e14',
    GRA: '#6f42c1',
    GENERAL: '#6c757d'
  };
  const CRITERION_SHADES = {
    TR: ['#0d6efd', '#3d8bfd', '#76aaff', '#a7c8ff'],
    CC: ['#198754', '#3da26f', '#68be8c', '#97d9ae'],
    LR: ['#fd7e14', '#ff9a45', '#ffb472', '#ffd19f'],
    GRA: ['#6f42c1', '#8a63cd', '#a886da', '#c6abe6'],
    GENERAL: ['#6c757d', '#889198', '#a5abb1', '#c3c7cb']
  };

  function normalizeCriterion(raw) {
    const value = String(raw || '').trim().toUpperCase().replace(/[\s_-]+/g, '');
    if (!value) return 'GENERAL';
    if (value === 'TR' || value.includes('TASKRESPONSE')) return 'TR';
    if (value === 'CC' || value.includes('COHERENCE') || value.includes('COHESION')) return 'CC';
    if (value === 'LR' || value.includes('LEXICAL')) return 'LR';
    if (value === 'GRA' || value.includes('GRAMMATICAL')) return 'GRA';
    return 'GENERAL';
  }

  function getOccurrence(item) {
    const raw = Number(item?.totalOccurrences);
    if (Number.isFinite(raw)) return raw;
    if (Array.isArray(item?.counts)) {
      return item.counts.reduce((sum, value) => sum + (Number(value) > 0 ? Number(value) : 0), 0);
    }
    return 0;
  }

  function renderKpis() {
    document.getElementById('kpiSessions').textContent = String(analysis?.sessionCount ?? records.length ?? 0);
    document.getElementById('kpiQuestions').textContent = String(analysis?.questionCount ?? 0);
    document.getElementById('kpiStep3').textContent = String(analysis?.avgStep3Unstable ?? 0);
    document.getElementById('kpiStep4').textContent = String(analysis?.avgStep4Unstable ?? 0);
  }

  function renderResultList() {
    const rows = records.map((record, idx) => {
      const activeClass = idx === active.index ? 'table-primary' : '';
      const unstableCount = Number(record?.step4?.unstableCount || 0);
      return `
        <tr class="result-row ${activeClass}" data-index="${idx}">
          <td>
            <div class="fw-bold">${esc(record?.sampleName || 'Untitled')}</div>
            <div class="small text-muted">${esc(fmtDate(record?.savedAt))}</div>
            <div class="small text-muted font-monospace">${esc(shortId(record?.id))}</div>
          </td>
          <td class="text-center"><span class="badge bg-warning text-dark">${esc(unstableCount)}</span></td>
          <td class="text-center"><a href="${esc(record?.loadUrl || '#')}" class="btn btn-outline-primary btn-sm">Load</a></td>
        </tr>
      `;
    }).join('');
    document.getElementById('resultRows').innerHTML = rows || `<tr><td colspan="3" class="text-muted text-center py-3">No records selected.</td></tr>`;
  }

  function unstableRowsHtml(rows) {
    const list = Array.isArray(rows) ? rows : [];
    if (!list.length) return `<tr><td colspan="4" class="text-muted text-center py-2">No unstable items.</td></tr>`;
    return list.map((row) => {
      const runValues = Array.isArray(row?.runValues)
        ? row.runValues.map((v, i) => `<span class="badge bg-light text-dark border me-1">R${i + 1}: ${esc(v)}</span>`).join('')
        : '-';
      return `
        <tr>
          <td class="font-monospace">${esc(row?.key || '-')}</td>
          <td>${esc(row?.criterion || '-')}</td>
          <td>${runValues}</td>
          <td class="fw-bold">${esc(row?.consensusValue || '-')}</td>
        </tr>
      `;
    }).join('');
  }

  function renderResultSummary() {
    const panel = document.getElementById('resultSummaryPanel');
    if (active.index == null || !records[active.index]) {
      panel.innerHTML = `<div class="text-muted small">Select a result from the left list.</div>`;
      return;
    }

    const r = records[active.index];
    const step3 = r?.step3 || {};
    const step4 = r?.step4 || {};
    const inconsistentKeys = Array.isArray(step4?.unstableKeys) ? step4.unstableKeys : [];
    const delta = (Number.isFinite(Number(r?.overallBand)) && Number.isFinite(Number(r?.examinerBand)))
      ? Number((Number(r.overallBand) - Number(r.examinerBand)).toFixed(1))
      : null;

    panel.innerHTML = `
      <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
        <div>
          <div class="fw-bold">${esc(r?.sampleName || 'Untitled')}</div>
          <div class="small text-muted">${esc(fmtDate(r?.savedAt))}</div>
          <div class="small text-muted font-monospace">${esc(r?.id || '-')}</div>
        </div>
        <div class="d-flex gap-2 flex-wrap">
          <span class="badge bg-primary">Band: ${esc(r?.overallBand ?? '-')}</span>
          <span class="badge bg-light text-dark border">Examiner: ${esc(r?.examinerBand ?? '-')}</span>
          <span class="badge bg-light text-dark border">Delta: ${delta == null ? '-' : esc(delta > 0 ? `+${delta}` : `${delta}`)}</span>
        </div>
      </div>

      <div class="row g-2 mb-3">
        <div class="col-md-6">
          <div class="p-2 bg-light border rounded">
            <div class="small fw-bold">Step 3</div>
            <div class="small text-muted">Runs: <span class="fw-bold">${esc(step3?.runCount ?? '-')}</span></div>
            <div class="small text-muted">Agreement: <span class="fw-bold">${esc(toPct(step3?.meanAgreement))}</span></div>
            <div class="small text-muted">Flip: <span class="fw-bold">${esc(toPct(step3?.flipRate))}</span></div>
            <div class="small text-muted">Unstable: <span class="fw-bold">${esc(step3?.unstableCount ?? 0)} / ${esc(step3?.totalCount ?? 0)}</span></div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="p-2 bg-light border rounded">
            <div class="small fw-bold">Step 4</div>
            <div class="small text-muted">Runs: <span class="fw-bold">${esc(step4?.runCount ?? '-')}</span></div>
            <div class="small text-muted">Agreement: <span class="fw-bold">${esc(toPct(step4?.meanAgreement))}</span></div>
            <div class="small text-muted">Flip: <span class="fw-bold">${esc(toPct(step4?.flipRate))}</span></div>
            <div class="small text-muted">Unstable: <span class="fw-bold">${esc(step4?.unstableCount ?? 0)} / ${esc(step4?.totalCount ?? 0)}</span></div>
          </div>
        </div>
      </div>

      <div class="small mb-2"><span class="fw-bold">Non-consistent question count:</span> ${esc(inconsistentKeys.length)}</div>
      <div class="small mb-3">${inconsistentKeys.length ? inconsistentKeys.slice(0, 40).map((k) => `<span class="badge bg-light text-dark border me-1 mb-1">${esc(k)}</span>`).join('') : '<span class="text-muted">No unstable questions detected.</span>'}</div>

      <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-bold small">Unstable Question Details</div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light">
                <tr><th>Question</th><th>Criterion</th><th>Run Values</th><th>Consensus</th></tr>
              </thead>
              <tbody>${unstableRowsHtml(step4?.topUnstable)}</tbody>
            </table>
          </div>
        </div>
      </div>
    `;
  }

  function renderPerResultTable() {
    const rows = records.map((record) => {
      const inconsistent = Array.isArray(record?.step4?.unstableKeys) ? record.step4.unstableKeys : [];
      const badges = inconsistent.length
        ? inconsistent.slice(0, 24).map((k) => `<span class="badge bg-light text-dark border me-1 mb-1">${esc(k)}</span>`).join('')
        : `<span class="text-muted">No unstable questions</span>`;
      return `
        <tr>
          <td>
            <div class="fw-bold">${esc(record?.sampleName || 'Untitled')}</div>
            <div class="small text-muted font-monospace">${esc(shortId(record?.id))}</div>
          </td>
          <td class="text-center fw-bold">${esc(record?.step3?.unstableCount ?? 0)}</td>
          <td class="text-center fw-bold">${esc(record?.step4?.unstableCount ?? 0)}</td>
          <td>${badges}</td>
        </tr>
      `;
    }).join('');
    document.getElementById('perResultUnstableRows').innerHTML = rows || `<tr><td colspan="4" class="text-muted text-center py-3">No data.</td></tr>`;
  }

  const VALUE_COLOR_PALETTE = [
    'rgba(13, 110, 253, 0.2)', 'rgba(25, 135, 84, 0.2)', 'rgba(253, 126, 20, 0.2)', 'rgba(111, 66, 193, 0.2)',
    'rgba(214, 51, 132, 0.2)', 'rgba(32, 201, 151, 0.2)', 'rgba(102, 126, 234, 0.2)', 'rgba(253, 151, 31, 0.2)'
  ];
  function getValueColorMap(values) {
    const normalized = (values || []).map((v) => String(v ?? '').trim().toLowerCase() || '___empty___');
    const unique = [...new Set(normalized)];
    const map = {};
    unique.forEach((u, i) => { map[u] = VALUE_COLOR_PALETTE[i % VALUE_COLOR_PALETTE.length]; });
    return map;
  }
  function buildRemoveColumnUrl(excludeIndex) {
    const remaining = records.map((r, i) => (i === excludeIndex ? null : r?.id)).filter(Boolean);
    if (remaining.length < 1) return null;
    const base = window.location.pathname || '/ielts/scoring/tuning/step4/compare';
    return `${base}?ids=${remaining.join(',')}`;
  }

  function renderQuestionMatrix() {
    const matrix = Array.isArray(analysis?.matrixRows) ? analysis.matrixRows : [];
    const head = document.getElementById('questionMatrixHead');
    const body = document.getElementById('questionMatrixRows');
    const sessionHead = records.map((r, idx) => {
      const removeUrl = buildRemoveColumnUrl(idx);
      const removeBtn = removeUrl && records.length > 2
        ? `<a href="${esc(removeUrl)}" class="btn btn-outline-danger btn-sm py-0 px-1 ms-1" title="Remove this sample from comparison"><i class="bi bi-x-lg"></i></a>`
        : '';
      return `<th class="text-center"><span>${esc(shortId(r?.id))}</span>${removeBtn}</th>`;
    }).join('');
    head.innerHTML = `
      <tr>
        <th>Question Key</th>
        <th>Criterion</th>
        <th class="text-center">Total Occurrences</th>
        ${sessionHead}
      </tr>
    `;

    const rows = matrix.map((row) => {
      const counts = Array.isArray(row?.counts) ? row.counts : [];
      const valueColorMap = getValueColorMap(counts.map((c) => String(c ?? '')));
      const cells = counts
        .map((count, idx) => {
          const normKey = String(count ?? '').toLowerCase() || '___empty___';
          const bgColor = valueColorMap[normKey] || '';
          const style = bgColor ? ` style="background-color: ${bgColor};"` : '';
          const cls = Number(count) > 0 ? 'table-danger fw-bold' : 'text-muted';
          return `<td class="text-center ${cls}"${style}>${esc(count)}</td>`;
        })
        .join('');
      return `
        <tr>
          <td class="font-monospace">${esc(row?.key || '-')}</td>
          <td>${esc(row?.criterion || '-')}</td>
          <td class="text-center fw-bold">${esc(row?.totalOccurrences ?? 0)}</td>
          ${cells}
        </tr>
      `;
    }).join('');
    body.innerHTML = rows || `<tr><td colspan="${3 + records.length}" class="text-muted text-center py-3">No matrix data available.</td></tr>`;
  }

  function renderCrossSampleConsistency() {
    const rows = Array.isArray(analysis?.crossSampleRows) ? analysis.crossSampleRows : [];
    const head = document.getElementById('crossSampleHead');
    const body = document.getElementById('crossSampleRows');
    if (!head || !body) return;

    const sessionCols = records.map((r, idx) => {
      const removeUrl = buildRemoveColumnUrl(idx);
      const removeBtn = removeUrl && records.length > 2
        ? `<a href="${esc(removeUrl)}" class="btn btn-outline-danger btn-sm py-0 px-1 ms-1" title="Remove this sample from comparison"><i class="bi bi-x-lg"></i></a>`
        : '';
      return `<th class="text-center"><span>${esc(shortId(r?.id))}</span>${removeBtn}</th>`;
    }).join('');
    head.innerHTML = `
      <tr>
        <th>Question Key</th>
        <th>Criterion</th>
        <th class="text-center">Intra-Run Inconsistency</th>
        <th class="text-center">Inter-Sample Consistency</th>
        ${sessionCols}
      </tr>
    `;

    const html = rows.map((row) => {
      const values = Array.isArray(row?.values) ? row.values : [];
      const valueColorMap = getValueColorMap(values.map((v) => String(v ?? '')));
      const cellValues = values.map((value) => {
        const txt = String(value || '').trim();
        const normKey = (txt || '').toLowerCase() || '___empty___';
        const bgColor = valueColorMap[normKey] || '';
        const style = bgColor ? ` style="background-color: ${bgColor};"` : '';
        return `<td class="text-center"${style}><span class="badge ${txt ? 'bg-light text-dark border' : 'bg-secondary-subtle text-muted border'}">${esc(txt || '-')}</span></td>`;
      }).join('');
      const interSampleBadge = row?.interSampleDifferent
        ? `<span class="badge bg-danger">Different Across Samples</span>`
        : `<span class="badge bg-success">Consistent Across Samples</span>`;
      return `
        <tr>
          <td>
            <div class="font-monospace">${esc(row?.key || '-')}</div>
            <div class="small text-muted">${esc(row?.atomicQuestion || '')}</div>
          </td>
          <td>${esc(row?.criterion || '-')}</td>
          <td class="text-center fw-bold">${esc(row?.inconsistentRuns ?? 0)}</td>
          <td class="text-center">${interSampleBadge}</td>
          ${cellValues}
        </tr>
      `;
    }).join('');

    body.innerHTML = html || `<tr><td colspan="${4 + records.length}" class="text-muted text-center py-3">No comparable cross-sample question answers found.</td></tr>`;
  }

  function renderRankLists() {
    const most = Array.isArray(analysis?.mostFluctuating) ? analysis.mostFluctuating : [];
    const least = Array.isArray(analysis?.mostConsistent) ? analysis.mostConsistent : [];

    const mostHtml = most.slice(0, 12).map((item) => `
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <span class="font-monospace">${esc(item?.key || '-')}</span>
        <span class="badge bg-danger">${esc(item?.totalOccurrences ?? 0)}</span>
      </li>
    `).join('') || `<li class="list-group-item text-muted">No data</li>`;

    const leastHtml = least.slice(0, 12).map((item) => `
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <span class="font-monospace">${esc(item?.key || '-')}</span>
        <span class="badge bg-success">${esc(item?.totalOccurrences ?? 0)}</span>
      </li>
    `).join('') || `<li class="list-group-item text-muted">No data</li>`;

    document.getElementById('mostFluctuatingList').innerHTML = mostHtml;
    document.getElementById('mostConsistentList').innerHTML = leastHtml;
  }

  function renderBarChart() {
    const canvas = document.getElementById('questionFrequencyChart');
    const legendEl = document.getElementById('questionChartLegend');
    if (!canvas) return;
    const ranked = (Array.isArray(analysis?.mostFluctuating) ? analysis.mostFluctuating : [])
      .map((item) => ({
        ...item,
        _criterion: normalizeCriterion(item?.criterion),
        _occurrence: getOccurrence(item)
      }))
      .filter((item) => Number(item?._occurrence || 0) > 0)
      .sort((a, b) => Number(b?._occurrence || 0) - Number(a?._occurrence || 0));
    const top = ranked.slice(0, 30);

    const dpr = Math.max(1, Number(window.devicePixelRatio || 1));
    const containerWidth = Math.floor(canvas.parentElement?.clientWidth || canvas.clientWidth || 980);
    const barWidth = 24;
    const barGap = 12;
    const leftPad = 48;
    const rightPad = 14;
    const topPad = 14;
    const bottomPad = 88;
    const plotWidth = top.length > 0 ? (top.length * (barWidth + barGap) - barGap) : 180;
    const cssWidth = Math.max(containerWidth, leftPad + rightPad + plotWidth);
    const cssHeight = 320;

    canvas.style.width = `${cssWidth}px`;
    canvas.style.height = `${cssHeight}px`;
    canvas.width = Math.floor(cssWidth * dpr);
    canvas.height = Math.floor(cssHeight * dpr);

    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    ctx.clearRect(0, 0, cssWidth, cssHeight);

    const chartWidth = Math.max(120, cssWidth - leftPad - rightPad);
    const chartHeight = Math.max(120, cssHeight - topPad - bottomPad);

    if (!top.length) {
      ctx.fillStyle = '#6c757d';
      ctx.font = '13px system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif';
      ctx.textAlign = 'center';
      ctx.fillText('No unstable questions found in selected results.', cssWidth / 2, cssHeight / 2);
      if (legendEl) legendEl.innerHTML = `<span class="text-muted">Legend: no unstable questions to plot.</span>`;
      return;
    }

    const values = top.map((item) => Number(item?._occurrence || 0));
    const maxValue = Math.max(1, ...values);

    ctx.strokeStyle = '#dee2e6';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(leftPad, topPad);
    ctx.lineTo(leftPad, topPad + chartHeight);
    ctx.lineTo(cssWidth - rightPad, topPad + chartHeight);
    ctx.stroke();

    const tickCount = Math.min(6, Math.max(2, maxValue + 1));
    for (let i = 0; i < tickCount; i += 1) {
      const v = (maxValue / (tickCount - 1)) * i;
      const y = topPad + chartHeight - (chartHeight * (v / maxValue));
      ctx.strokeStyle = '#f1f3f5';
      ctx.beginPath();
      ctx.moveTo(leftPad, y);
      ctx.lineTo(cssWidth - rightPad, y);
      ctx.stroke();

      ctx.fillStyle = '#6c757d';
      ctx.font = '11px system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif';
      ctx.textAlign = 'right';
      ctx.fillText(String(Math.round(v)), leftPad - 8, y + 4);
    }

    ctx.font = '11px system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif';
    const stepX = top.length > 0 ? Math.min(barWidth + barGap, chartWidth / top.length) : barWidth;
    for (let i = 0; i < top.length; i += 1) {
      const row = top[i] || {};
      const value = Number(row?._occurrence || 0);
      const x = leftPad + (i * stepX);
      const barHeight = maxValue > 0 ? Math.max(1, (value / maxValue) * chartHeight) : 1;
      const y = topPad + chartHeight - barHeight;
      const label = String(row?.key || '-');
      const criterion = String(row?._criterion || 'GENERAL').toUpperCase();
      const shortLabel = label.length > 16 ? `${label.slice(0, 13)}...` : label;
      const shades = CRITERION_SHADES[criterion] || CRITERION_SHADES.GENERAL;
      const color = shades[i % shades.length];

      ctx.fillStyle = color;
      ctx.fillRect(x, y, barWidth, barHeight);

      ctx.fillStyle = '#212529';
      ctx.textAlign = 'center';
      ctx.fillText(String(value), x + (barWidth / 2), y - 4);

      ctx.save();
      ctx.translate(x + (barWidth / 2), topPad + chartHeight + 14);
      ctx.rotate(-Math.PI / 4);
      ctx.textAlign = 'right';
      ctx.fillStyle = '#343a40';
      ctx.fillText(`${shortLabel} (${criterion})`, 0, 0);
      ctx.restore();
    }

    if (legendEl) {
      const legendItems = [
        ['TR', CRITERION_COLORS.TR],
        ['CC', CRITERION_COLORS.CC],
        ['LR', CRITERION_COLORS.LR],
        ['GRA', CRITERION_COLORS.GRA],
        ['General', CRITERION_COLORS.GENERAL]
      ];
      legendEl.innerHTML = legendItems
        .map(([name, color]) => `<span class="me-3 d-inline-flex align-items-center"><span style="display:inline-block;width:10px;height:10px;border-radius:2px;background:${color};margin-right:6px;"></span>${name}</span>`)
        .join('');
    }
  }

  document.getElementById('resultRows')?.addEventListener('click', (event) => {
    const row = event.target.closest('tr.result-row');
    if (!row) return;
    const idx = Number(row.dataset.index);
    if (!Number.isInteger(idx)) return;
    active.index = idx;
    renderResultList();
    renderResultSummary();
  });

  renderKpis();
  renderResultList();
  renderResultSummary();
  renderPerResultTable();
  renderCrossSampleConsistency();
  renderQuestionMatrix();
  renderRankLists();
  renderBarChart();

  let chartResizeTimer = null;
  window.addEventListener('resize', () => {
    clearTimeout(chartResizeTimer);
    chartResizeTimer = setTimeout(() => {
      renderBarChart();
    }, 120);
  });
})();
</script>

