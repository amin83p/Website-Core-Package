<%- include('partials/tablePages-start', {
  title,
  newUrl,
  newLabel,
  user,
  tableName,
  btn_export: true,
  print,
  manageBtns: [
    '<a href="' + ieltsSectionDashboardHref + '" class="ielts-navigator-dashboard btn btn-filled btn-secondary btn-md mb-2"><i class="bi bi-speedometer2 me-1"></i> IELTS Dashboard</a>',
    '<a href="/ielts/ai-token-usage/analytics" class="btn btn-filled btn-primary btn-md mb-2"><i class="bi bi-bar-chart-line-fill me-1"></i> Usage Analytics</a>'
  ]
}) %>

<%- include('partials/tablePages-search', {
  placeholder: 'Search by user, provider, model, request label, or status...',
  fields: ['id', 'userId', 'providerId', 'providerRecordName', 'modelUsed', 'requestLabel', 'status', 'billingStatus']
}) %>

<div class="table-scroll-wrapper">
  <table class="table-responsive size-md" id="first-table">
    <thead>
      <tr>
        <th class="draggable" data-column="consumedAt">Consumed At <span class="sort-icon"></span></th>
        <th class="draggable" data-column="userId">User <span class="sort-icon"></span></th>
        <th class="draggable" data-column="providerId">Provider <span class="sort-icon"></span></th>
        <th class="draggable" data-column="modelUsed">Model <span class="sort-icon"></span></th>
        <th class="draggable" data-column="requestLabel">Request <span class="sort-icon"></span></th>
        <th class="draggable" data-column="promptTokenCount">Prompt <span class="sort-icon"></span></th>
        <th class="draggable" data-column="candidatesTokenCount">Output <span class="sort-icon"></span></th>
        <th class="draggable" data-column="totalTokenCount">Total <span class="sort-icon"></span></th>
        <th class="draggable" data-column="status">Status <span class="sort-icon"></span></th>
        <th class="draggable" data-column="billingStatus">Billing <span class="sort-icon"></span></th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% data.forEach((item) => { %>
        <tr>
          <td>
            <% if (item.consumedAt || item.createdAt) { %>
              <%= new Date(item.consumedAt || item.createdAt).toLocaleString() %>
            <% } else { %>
              -
            <% } %>
          </td>
          <td><span class="badge bg-light text-dark border"><%= item.userId || '-' %></span></td>
          <td>
            <span class="badge bg-info text-dark"><%= item.providerId || '-' %></span>
            <% if (item.providerRecordName) { %>
              <div class="small text-muted"><%= item.providerRecordName %></div>
            <% } %>
          </td>
          <td><%= item.modelUsed || '-' %></td>
          <td><%= item.requestLabel || '-' %></td>
          <td><%= item.promptTokenCount ?? '-' %></td>
          <td><%= item.candidatesTokenCount ?? '-' %></td>
          <td class="fw-semibold"><%= item.totalTokenCount ?? '-' %></td>
          <td>
            <% if (String(item.status || '').toLowerCase() === 'failed') { %>
              <span class="badge bg-danger">Failed</span>
            <% } else { %>
              <span class="badge bg-success">Success</span>
            <% } %>
          </td>
          <td>
            <% const billing = String(item.billingStatus || 'unbilled').toLowerCase(); %>
            <% if (billing === 'billed') { %>
              <span class="badge bg-primary">Billed</span>
            <% } else if (billing === 'waived') { %>
              <span class="badge bg-secondary">Waived</span>
            <% } else { %>
              <span class="badge bg-warning text-dark">Unbilled</span>
            <% } %>
          </td>
          <td class="table-actions">
            <a href="/<%= newUrl %>/edit/<%= item.id %>" class="btn btn-sm btn-filled btn-edit">View</a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('partials/pagination', {
  pagination: pagination,
  filters: filters,
  baseUrlPath: newUrl
}) %>

<%- include('partials/tablePages-end') %>
<%- include('partials/modal') %>

