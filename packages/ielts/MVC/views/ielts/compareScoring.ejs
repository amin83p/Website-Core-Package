                <% criterionOrder.forEach((criterionKey) => {
                    const criterionValues = step5CriterionLists.map((rows) => truncateForCell(getCriterionSummaryFromFeedback(rows, criterionKey), 220));
                    const criterionColorMap = getValueColorMap(criterionValues);
                %>
                    <tr>
                        <td class="sticky-col fw-bold"><%= criterionKey %> Summary</td>
                        <% criterionValues.forEach((value, i) => {
                            const normKey = normKeyForColor(value);
                            const bgColor = criterionColorMap[normKey] || '';
                            const cellClass = bgColor ? 'small text-break value-colored-cell' : 'small text-break';
                            const cellStyle = bgColor ? ` style="background-color: ${bgColor} !important;"` : '';
                            const fullValue = getCriterionSummaryFromFeedback(step5CriterionLists[i], criterionKey);
                        %>
                            <td class="<%= cellClass %>" data-column-index="<%= i %>"<%- cellStyle %> title="<%= fullValue %>"><%= value %></td>
                        <% }) %>
                    </tr>
                <% }) %>

                <tr class="table-warning">
                    <td class="sticky-col fw-bold"><i class="bi bi-stars me-2"></i>Strengths</td>
                    <% sessions.forEach((_, i) => { %><td data-column-index="<%= i %>"></td><% }) %>
                </tr>
                <% if (!maxStrengthRows) { %>
                    <tr>
                        <td class="sticky-col text-muted">No strengths generated.</td>
                        <% sessions.forEach((_, i) => { %><td class="text-muted text-center" data-column-index="<%= i %>">-</td><% }) %>
                    </tr>
                <% } %>
                <% for (let strengthIndex = 0; strengthIndex < maxStrengthRows; strengthIndex += 1) {
                    const strengthValues = step5StrengthLists.map((rows) => truncateForCell(rows[strengthIndex] || '-', 220));
                    const strengthColorMap = getValueColorMap(strengthValues);
                %>
                    <tr>
                        <td class="sticky-col fw-bold">Strength <%= strengthIndex + 1 %></td>
                        <% strengthValues.forEach((value, i) => {
                            const normKey = normKeyForColor(value);
                            const bgColor = strengthColorMap[normKey] || '';
                            const cellClass = bgColor ? 'small text-break value-colored-cell' : 'small text-break';
                            const cellStyle = bgColor ? ` style="background-color: ${bgColor} !important;"` : '';
                            const fullValue = normalizeFeedbackText(step5StrengthLists[i][strengthIndex] || '-');
                        %>
                            <td class="<%= cellClass %>" data-column-index="<%= i %>"<%- cellStyle %> title="<%= fullValue %>"><%= value %></td>
                        <% }) %>
                    </tr>
                <% } %>

                <tr class="table-warning">
                    <td class="sticky-col fw-bold"><i class="bi bi-tools me-2"></i>Improvements</td>
                    <% sessions.forEach((_, i) => { %><td data-column-index="<%= i %>"></td><% }) %>
                </tr>
                <% if (!maxImprovementRows) { %>
                    <tr>
                        <td class="sticky-col text-muted">No improvements generated.</td>
                        <% sessions.forEach((_, i) => { %><td class="text-muted text-center" data-column-index="<%= i %>">-</td><% }) %>
                    </tr>
                <% } %>
                <% for (let improvementIndex = 0; improvementIndex < maxImprovementRows; improvementIndex += 1) {
                    const improvementValues = step5ImprovementLists.map((rows) => truncateForCell(rows[improvementIndex]?.text || '-', 220));
                    const improvementColorMap = getValueColorMap(improvementValues);
                %>
