<%
const compareIdsQuery = (sessions || []).map((s) => encodeURIComponent(s?.sessionId || s?.id || '')).filter(Boolean).join(',');
function normalizePipelineModeLocal(raw) {
    const mode = String(raw || '').trim().toLowerCase();
    if (mode === 'step3_tuning') return 'step3_tuning';
    if (mode === 'step4_tuning') return 'step4_tuning';
    return 'full';
}
const currentCompareType = normalizePipelineModeLocal(
    (sessions || [])[0]?.pipelineMode ||
    (sessions || [])[0]?.researchConfig?.pipelineMode ||
    (sessions || [])[0]?.metadata?.pipelineMode
);
const VALUE_COLOR_PALETTE = ['rgba(13, 110, 253, 0.22)', 'rgba(25, 135, 84, 0.22)', 'rgba(253, 126, 20, 0.22)', 'rgba(111, 66, 193, 0.22)', 'rgba(214, 51, 132, 0.22)', 'rgba(32, 201, 151, 0.22)', 'rgba(102, 126, 234, 0.22)', 'rgba(253, 151, 31, 0.22)'];
function getValueColorMap(values) {
    const normalized = (values || []).map((v) => {
        const s = String(v ?? '').trim().toLowerCase();
        return (s === '' || s === '-') ? '___empty___' : s;
    });
    const counts = {};
    normalized.forEach((n) => { counts[n] = (counts[n] || 0) + 1; });
    const maxCount = Math.max(...Object.values(counts), 0);
    const mostFrequent = new Set(Object.keys(counts).filter((k) => counts[k] === maxCount));
    const lessFrequent = [...new Set(normalized)].filter((u) => !mostFrequent.has(u));
    const map = {};
    mostFrequent.forEach((u) => { map[u] = '#fff'; });
    lessFrequent.forEach((u, i) => { map[u] = VALUE_COLOR_PALETTE[i % VALUE_COLOR_PALETTE.length]; });
    return map;
}
function normKeyForColor(val) {
    const s = String(val ?? '').trim().toLowerCase();
    return (s === '' || s === '-') ? '___empty___' : s;
}
function allowBreakAtUnderscores(str) {
    return String(str ?? '').replace(/_/g, '_\u200B');
}
function normalizeScoringAnswerToken(value) {
    return String(value ?? '')
        .trim()
        .toLowerCase()
        .replace(/[\s-]+/g, '_');
}
function normalizeScoringAnswerList(raw) {
    let values = [];
    if (Array.isArray(raw)) values = raw;
    else if (typeof raw === 'string') {
        const trimmed = raw.trim();
        if (trimmed) {
            try {
                const parsed = JSON.parse(trimmed);
                values = Array.isArray(parsed) ? parsed : trimmed.split(/[,;\n|]+/g);
            } catch (_) {
                values = trimmed.split(/[,;\n|]+/g);
            }
        }
    } else if (raw !== undefined && raw !== null) {
        values = [raw];
    }
    const out = [];
    const seen = new Set();
    values.forEach((value) => {
        const normalized = normalizeScoringAnswerToken(value);
        if (!normalized || seen.has(normalized)) return;
        seen.add(normalized);
        out.push(normalized);
    });
    return out;
}
function getResultScoringState(row) {
    const normalizedValue = normalizeScoringAnswerToken(row?.value);
    if (!normalizedValue || normalizedValue === '-' || normalizedValue === 'error' || normalizedValue === 'n/a' || normalizedValue === 'na') {
        return 'not_evaluable';
    }
    const scoredAnswers = normalizeScoringAnswerList(row?.scoredAnswers ?? row?.scored_answers);
    const notScoredAnswers = normalizeScoringAnswerList(row?.notScoredAnswers ?? row?.not_scored_answers);
    if (scoredAnswers.length > 0 && scoredAnswers.includes(normalizedValue)) return 'scored';
    if (notScoredAnswers.length > 0 && notScoredAnswers.includes(normalizedValue)) return 'not_scored';
    if (scoredAnswers.length > 0 && notScoredAnswers.length === 0) return 'not_scored';
    if (scoredAnswers.length === 0 && notScoredAnswers.length > 0) return 'scored';
    return 'unknown';
}
function hasScoreImpactStateChange(states) {
    const relevant = new Set((states || []).filter((state) => state === 'scored' || state === 'not_scored'));
    return relevant.size > 1;
}
function getScoringStateBadgeMeta(state) {
    if (state === 'scored') return { label: 'Scored', className: 'score-contract-badge score-contract-badge-scored' };
    if (state === 'not_scored') return { label: 'Not Scored', className: 'score-contract-badge score-contract-badge-not-scored' };
    if (state === 'not_evaluable') return { label: 'Not Evaluable', className: 'score-contract-badge score-contract-badge-na' };
    return { label: 'Unmapped', className: 'score-contract-badge score-contract-badge-unknown' };
}
function getSessionModelUsed(session, preferredStep = 'step4') {
    const s = session || {};
    const m4 = s.steps?.step4grade?.response?.json?.data?.meta?.modelUsed || s.steps?.step4grade?.response?.json?.meta?.modelUsed;
    const m3 = s.steps?.step3extract?.response?.json?.data?.meta?.modelUsed || s.steps?.step3extract?.response?.json?.meta?.modelUsed;
    const m5 = s.steps?.step5feedback?.response?.json?.data?.meta?.modelUsed || s.steps?.step5feedback?.response?.json?.meta?.modelUsed;
    if (preferredStep === 'step3') return m3 || m4 || m5 || 'Unknown';
    if (preferredStep === 'step5') return m5 || m4 || m3 || 'Unknown';
    return m4 || m3 || m5 || 'Unknown';
}
function getStep5FeedbackData(session) {
    const root = session?.steps?.step5feedback?.response?.json;
    if (!root) return null;
    if (root.data && typeof root.data === 'object') return root.data;
    if (root.response?.data && typeof root.response.data === 'object') return root.response.data;
    if (root.summary || root.improvements || root.strengths || root.byCriterion) return root;
    return null;
}
function escapeHtml(value) {
    return String(value ?? '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
}
function normalizeFeedbackText(value) {
    const text = String(value ?? '').trim();
    return text || '-';
}
function truncateForCell(value, maxLen = 220) {
    const text = normalizeFeedbackText(value);
    if (text === '-' || text.length <= maxLen) return text;
    return `${text.slice(0, Math.max(0, maxLen - 1))}\u2026`;
}
%>
<div class="sections-page" id="comparePageRoot">
    <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-3">
        <div>
            <h2 class="page-heading size-md m-0">Session Comparison</h2>
            <div class="text-muted small mt-1" id="compareCountText">Comparing <%= sessions.length %> versions. Evolution flows Left → Right.</div>
        </div>
        <div class="d-flex align-items-center gap-2">
            <button type="button" class="btn btn-outline-primary btn-sm" onclick="openAddSessionPicker()">
                <i class="bi bi-plus-circle me-1"></i> Add Session
            </button>
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-toggle="modal" data-bs-target="#compareDisplayModal" title="Display settings">
                <i class="bi bi-sliders"></i> Display
            </button>
            <div class="d-flex gap-2">
            <a href="/ielts/scoring/compare/visual?ids=<%- compareIdsQuery %>" class="btn btn-success btn-sm">
                <i class="bi bi-bar-chart-line me-1"></i> Visual Page
            </a>
            <% const isStep3Tuning = (sessions || []).some(s => (s?.researchConfig?.pipelineMode || s?.metadata?.pipelineMode || 'full') === 'step3_tuning'); %>
            <% if (isStep3Tuning) { %>
            <a href="/ielts/scoring/tuning/step3/compare?ids=<%- compareIdsQuery %>" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-graph-up me-1"></i> Step 3 Analytics
            </a>
            <% } %>
            <button class="btn btn-primary btn-sm" onclick="exportComparison()">
                <i class="bi bi-download me-1"></i> Export JSON
            </button>
            <a href="/ielts/scoring/history" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Back to History
            </a>
        </div>
    </div>

    
<%
    // Build question_key -> prompt mapping per session (from meta.aiPrompts)
    // promptMaps[sessionIndex][questionKey] = fullPromptText
    const promptMaps = (sessions || []).map(s => {
        const prompts = s.steps?.step4grade?.response?.json?.data?.meta?.aiPrompts || [];
        const map = {};
        prompts.forEach(p => {
            const re = /ID:\s*([A-Z]{2}\d+-\d+)/g;
            let m;
            const ids = [];
            while ((m = re.exec(p)) !== null) {
                ids.push(m[1]);
            }
            ids.forEach(id => { map[id] = p; });
        });
        return map;
    });
%>
<script>
    window.__promptMaps = <%- JSON.stringify(promptMaps) %>;
</script>

<div class="card border-0 shadow-sm compare-table-card" style="max-height: 88vh; overflow: hidden; display: flex; flex-direction: column;">
        <div class="card-header bg-white border-bottom fw-bold py-2 h2 mb-0">
            <i class="bi bi-trophy me-2"></i>Scores & Question Results
        </div>
        <div class="small text-muted px-3 py-2 border-bottom bg-light">
            Question-row header highlight is shown only when answers shift between <strong>Scored</strong> and <strong>Not Scored</strong> status across sessions.
        </div>
        <div class="table-responsive" style="flex: 1; overflow: auto;">
            <table class="table table-bordered table-hover mb-0 align-middle compare-sync-table" style="min-width: <%= 280 + 165 * sessions.length %>px;">
                <colgroup>
                    <col class="col-param" style="width: 280px;">
                    <% sessions.forEach((_, i) => { %><col class="col-session" data-column-index="<%= i %>" style="width: 165px;"><% }) %>
                </colgroup>
                <thead class="table-light">
                    <tr>
                        <th class="sticky-col sticky-header" style="width: 280px; min-width: 280px; z-index: 20;">Parameter</th>
                        
                        <% sessions.forEach((s, i) => {
                        %>
                            <th class="text-center sticky-header compare-header-cell" style="width: 165px;" data-column-index="<%= i %>">
                                <div class="compare-header-inner">
                                    <div class="compare-header-name" title="<%= s.metadata?.sampleName %>">
                                        <%= s.metadata?.sampleName || 'Unknown Sample' %>
                                    </div>
                                    <div class="compare-header-id"><%= String(s?.sessionId || s?.id || 'Unknown').substring(0, 8) %>...</div>
                                    <div class="compare-header-time"><%= new Date(s.savedAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', second:'2-digit'}) %></div>
                                    <% if (sessions.length > 2) { %>
                                        <button type="button" class="btn btn-outline-danger btn-sm py-0 px-1 remove-column-btn mt-1" data-column-index="<%= i %>" title="Remove this sample from comparison"><i class="bi bi-x-lg"></i></button>
                                    <% } %>
                                </div>
                            </th>
                        <% }) %>
                    </tr>
                </thead>

                <tbody>
                    <tr class="table-info">
                        <td class="sticky-col fw-bold"><i class="bi bi-trophy me-2"></i>Final Results</td>
                        <% sessions.forEach((_, i) => { %> <td data-column-index="<%= i %>"></td> <% }) %>
                    </tr>
                    <tr>
                        <td class="sticky-col fw-bold">Overall Band</td>
                        <% sessions.forEach((s, si) => { 
                             const grade = s.steps?.step4grade?.response?.json?.data;
                        %>
                            <td class="text-center" data-column-index="<%= si %>">
                                <span class="badge bg-primary fs-5"><%= grade?.overallBand || '-' %></span>
                            </td>
                        <% }) %>
                    </tr>
                    <tr>
                        <td class="sticky-col fw-bold">Examiner Reference Band</td>
                        <% sessions.forEach((s, si) => {
                             const examinerRaw = s.metadata?.examinerBandScore ?? s.steps?.step1freeze?.response?.json?.meta?.sampleBandScore;
                             const examinerNum = Number.parseFloat(examinerRaw);
                             const hasExaminer = Number.isFinite(examinerNum);
                        %>
                            <td class="text-center" data-column-index="<%= si %>">
                                <% if (hasExaminer) { %>
                                    <span class="badge bg-light text-dark border fs-6"><%= examinerNum %></span>
                                <% } else { %>
                                    <span class="text-muted">-</span>
                                <% } %>
                            </td>
                        <% }) %>
                    </tr>
                    <tr>
                        <td class="sticky-col fw-bold">Delta (System - Examiner)</td>
                        <% sessions.forEach((s, si) => {
                             const grade = s.steps?.step4grade?.response?.json?.data;
                             const systemNum = Number.parseFloat(grade?.overallBand);
                             const examinerRaw = s.metadata?.examinerBandScore ?? s.steps?.step1freeze?.response?.json?.meta?.sampleBandScore;
                             const examinerNum = Number.parseFloat(examinerRaw);
                             const hasBoth = Number.isFinite(systemNum) && Number.isFinite(examinerNum);
                             const delta = hasBoth ? Number((systemNum - examinerNum).toFixed(1)) : null;
                             const deltaText = hasBoth ? `${delta > 0 ? '+' : ''}${delta}` : '-';
                             const deltaClass = hasBoth
                                ? (delta === 0 ? 'text-success fw-bold' : 'text-warning fw-bold')
                                : 'text-muted';
                        %>
                            <td class="text-center" data-column-index="<%= si %>">
                                <span class="<%= deltaClass %>"><%= deltaText %></span>
                            </td>
                        <% }) %>
                    </tr>
                    <tr>
                        <td class="sticky-col fw-bold">AI Model Used</td>
                        <% sessions.forEach((s, si) => {
                             const model = getSessionModelUsed(s, 'step4');
                        %>
                            <td class="text-center small text-muted font-monospace" data-column-index="<%= si %>"><%= model %></td>
                        <% }) %>
                    </tr>

                    <tr>
                        <td class="sticky-col fw-bold">Batch Size / Concurrency</td>
                        <% sessions.forEach((s, si) => {
                             // Prefer UI-state persisted settings; fall back to the actual Step 4 request payload.
                             const gs = s.uiState?.gradingSettings;
                             const reqOpts = s.steps?.step4grade?.request?.payload?.options;
                             const batchSize = gs?.batchSize ?? reqOpts?.batchSize ?? '-';
                             const concurrency = gs?.concurrency ?? reqOpts?.concurrency ?? '-';
                        %>
                            <td class="text-center font-monospace" data-column-index="<%= si %>"><%= batchSize %> / <%= concurrency %></td>
                        <% }) %>
                    </tr>

                    <tr>
                        <td class="sticky-col fw-bold">Stability Profile</td>
                        <% sessions.forEach((s, si) => {
                             const gs = s.uiState?.gradingSettings;
                             const sc = s.uiState?.stabilityConfig;
                             const rc = s.researchConfig;
                             const raw = sc?.profile ?? gs?.stabilityProfile ?? rc?.stabilityProfile ?? s.steps?.step3extract?.request?.payload?.stabilityProfile ?? '-';
                             const profile = String(raw).trim().toLowerCase() === 'strict' ? 'strict' : (raw && raw !== '-' ? String(raw) : 'standard');
                        %>
                            <td class="text-center" data-column-index="<%= si %>"><span class="badge bg-light text-dark border"><%= profile %></span></td>
                        <% }) %>
                    </tr>

                    <tr>
                        <td class="sticky-col fw-bold">Step 3 Run Count</td>
                        <% sessions.forEach((s, si) => {
                             const meta = s.steps?.step3stability?.response?.json?.data?.metrics ?? s.steps?.step3extract?.response?.json?.meta?.stabilityGate?.metrics;
                             const allSignals = s.steps?.step3stability?.response?.json?.data?.allSignals ?? s.steps?.step3extract?.response?.json?.meta?.stabilityGate?.allSignals;
                             const inferredRunCount = (Array.isArray(allSignals) && allSignals[0]?.runValues?.length) ? allSignals[0].runValues.length : null;
                             const runCount = meta?.runCount ?? inferredRunCount ?? s.steps?.step3extract?.request?.runCount ?? s.uiState?.stabilityConfig?.step3?.runCount ?? s.uiState?.gradingSettings?.step3RunCount ?? s.researchConfig?.step3RunCount ?? '-';
                        %>
                            <td class="text-center font-monospace" data-column-index="<%= si %>"><%= runCount %></td>
                        <% }) %>
                    </tr>

                    <tr>
                        <td class="sticky-col fw-bold">Step 4 Run Count</td>
                        <% sessions.forEach((s, si) => {
                             const meta = s.steps?.step4grade?.response?.json?.data?.meta?.stabilityGate?.metrics ?? s.steps?.step4grade?.response?.json?.meta?.stabilityGate?.metrics;
                             const runCount =
                               s.steps?.step4grade?.request?.runCount
                               ?? s.steps?.step4stability?.request?.runCount
                               ?? meta?.runCount
                               ?? s.steps?.step4grade?.response?.json?.data?.meta?.runCount
                               ?? s.steps?.step4grade?.request?.payload?.options?.runCount
                               ?? s.uiState?.stabilityConfig?.step4?.runCount
                               ?? s.uiState?.gradingSettings?.step4RunCount
                               ?? s.researchConfig?.step4RunCount
                               ?? '-';
                        %>
                            <td class="text-center font-monospace" data-column-index="<%= si %>"><%= runCount %></td>
                        <% }) %>
                    </tr>

                    <tr class="table-warning">
                        <td class="sticky-col fw-bold">
                            <i class="bi bi-stopwatch me-2"></i>Processing Time
                        </td>
                         <% sessions.forEach((_, i) => { %> <td data-column-index="<%= i %>"></td> <% }) %>
                    </tr>

                    <% 
                        function getDuration(s, stepKey) {
                            const t = s.steps?.[stepKey]?.timing;
                            if (!t || !t.startedAt || !t.endedAt) return '-';
                            return ((t.endedAt - t.startedAt) / 1000).toFixed(1) + 's';
                        }
                    %>
                    <tr>
                        <td class="sticky-col">Step 2 (Analyze)</td>
                        <% sessions.forEach((s, si) => { %> <td class="text-center font-monospace" data-column-index="<%= si %>"><%= getDuration(s, 'step2analyze') %></td> <% }) %>
                    </tr>
                    <tr>
                        <td class="sticky-col">Step 3 (Extraction)</td>
                        <% sessions.forEach((s, si) => { %> <td class="text-center font-monospace" data-column-index="<%= si %>"><%= getDuration(s, 'step3extract') %></td> <% }) %>
                    </tr>
                    <tr>
                        <td class="sticky-col">Step 4 (Grading)</td>
                        <% sessions.forEach((s, si) => { %> <td class="text-center font-monospace" data-column-index="<%= si %>"><%= getDuration(s, 'step4grade') %></td> <% }) %>
                    </tr>

                    <tr class="table-warning">
                        <td class="sticky-col fw-bold"><i class="bi bi-search me-2"></i>Inputs (Step 2 & 3)</td>
                        <% sessions.forEach((_, i) => { %> <td data-column-index="<%= i %>"></td> <% }) %>
                    </tr>
                    <tr>
                        <td class="sticky-col">Word Count</td>
                        <% sessions.forEach((s, si) => { 
                             const stats = s.steps?.step1freeze?.response?.json?.data?.stats || s.steps?.step2analyze?.response?.json?.data?.stats;
                        %>
                            <td class="text-center font-monospace" data-column-index="<%= si %>"><%= stats?.wordCount || 0 %></td>
                        <% }) %>
                    </tr>
                     <tr>
                        <td class="sticky-col">Paragraphs</td>
                        <% sessions.forEach((s, si) => { 
                             const st = s.steps?.step2analyze?.response?.json?.data?.structure;
                        %>
                            <td class="text-center font-monospace" data-column-index="<%= si %>"><%= st?.paragraphCount || 0 %></td>
                        <% }) %>
                    </tr>
                    <tr>
                        <td class="sticky-col">Cohesion Density</td>
                        <% sessions.forEach((s, si) => { 
                             const co = s.steps?.step2analyze?.response?.json?.data?.cohesion;
                             const val = parseFloat(co?.densityPer100 || 0);
                        %>
                            <td class="text-center <%= (val < 5) ? 'text-danger' : 'text-success' %>" data-column-index="<%= si %>">
                                <%= val %>%
                            </td>
                        <% }) %>
                    </tr>
                    <tr>
                        <td class="sticky-col">Stance</td>
                        <% sessions.forEach((s, si) => { 
                             const pos = s.steps?.step3extract?.response?.json?.data?.position;
                        %>
                            <td class="text-center text-uppercase small fw-bold" data-column-index="<%= si %>"><%= pos?.stance || '-' %></td>
                        <% }) %>
                    </tr>

                    <% 
                       // Collect and sort all keys
                       const allKeys = new Set();
                       sessions.forEach(s => {
                           const res = s.steps?.step4grade?.response?.json?.data?.results || [];
                           res.forEach(r => allKeys.add(r.question_key));
                       });
                       const sortedKeys = Array.from(allKeys).sort();
                       
                       const grouped = { TR: [], CC: [], LR: [], GRA: [] };
                       sortedKeys.forEach(k => {
                           const prefix = k.substring(0, 2);
                           if (grouped[prefix]) grouped[prefix].push(k);
                           else grouped.GRA.push(k); 
                       });
                    %>

                    <% Object.keys(grouped).forEach(crit => { %>
                        <tr class="table-secondary">
                            <td class="sticky-col fw-bold"><%= crit %> Criteria</td>
                            <% sessions.forEach((_, i) => { %> <td data-column-index="<%= i %>"></td> <% }) %>
                        </tr>
                        
                        <tr>
                            <td class="sticky-col fw-bold text-primary"><%= crit %> Score</td>
                             <% sessions.forEach((s, si) => { 
                                 const scores = s.steps?.step4grade?.response?.json?.data?.scores || {};
                            %>
                                <td class="text-center fw-bold text-primary" data-column-index="<%= si %>"><%= scores[crit] || 0 %></td>
                            <% }) %>
                        </tr>

                        <% grouped[crit].forEach(key => { %>
                            <% 
                                // Keep per-cell answer-difference coloring, but highlight row header
                                // only when the scoring contract state changes (Scored vs Not Scored).
                                const values = sessions.map(s => {
                                    const r = s.steps?.step4grade?.response?.json?.data?.results?.find(x => x.question_key === key);
                                    return r ? String(r.value).toLowerCase() : '-';
                                });
                                const scoreStates = sessions.map(s => {
                                    const r = s.steps?.step4grade?.response?.json?.data?.results?.find(x => x.question_key === key);
                                    return getResultScoringState(r);
                                });
                                const hasScoreImpactChange = hasScoreImpactStateChange(scoreStates);
                                const rowClass = hasScoreImpactChange ? 'score-impact-row' : '';
                            %>

                            <tr class="<%= rowClass %>">
                                <td class="sticky-col">
                                    <span class="badge bg-light text-dark border me-1"><%= key %></span>
                                    <% if (hasScoreImpactChange) { %>
                                        <span class="badge score-impact-badge">Score Impact Changed</span>
                                    <% } %>
                                    <% 
                                        let qText = "";
                                        for(let s of sessions) {
                                            const r = s.steps?.step4grade?.response?.json?.data?.results?.find(x => x.question_key === key);
                                            if(r) { qText = r.atomic_question; break; }
                                        }
                                    %>
                                    <small class="text-muted d-block mt-1" style="max-width: 100%;"><%= qText %></small>
                                </td>
                                
                                <% 
                                    const valueColorMap = getValueColorMap(values);
                                    sessions.forEach((s, si) => { 
                                    const res = s.steps?.step4grade?.response?.json?.data?.results?.find(x => x.question_key === key);
                                    let val = res ? String(res.value) : '-';
                                    let cls = "";
                                    
                                    const lowerVal = val.toLowerCase();
                                    if(lowerVal === 'yes' || lowerVal === 'true') cls = "text-success fw-bold";
                                    if(lowerVal === 'no' || lowerVal === 'false') cls = "text-danger";
                                    
                                    const normKey = normKeyForColor(val);
                                    const bgColor = valueColorMap[normKey] || '';
                                    const cellClass = bgColor ? 'text-center value-colored-cell' : 'text-center';
                                    const cellStyle = bgColor ? ` style="background-color: ${bgColor} !important;"` : '';
                                    
                                    let badge = "";
                                    if (res?.source === 'deterministic') badge = '<i class="bi bi-gear-fill text-muted ms-1" title="Rule Based"></i>';
                                    else if (res?.source === 'ai') badge = '<i class="bi bi-cpu text-primary ms-1" title="AI Generated"></i>';
                                    const scoreBadge = getScoringStateBadgeMeta(scoreStates[si]);
                                %>
                                    <td class="<%= cellClass %>" data-column-index="<%= si %>"<%- cellStyle %>>
                                        <% const p = (promptMaps?.[si] || {})[key]; %>
                                        <% if (p) { %>
                                            <button type="button"
                                                    class="answer-pill <%= cls %>"
                                                    data-session-index="<%= si %>"
                                                    data-question-key="<%= key %>"
                                                    title="Click to view the prompt that produced this answer">
                                                <%= val %>
                                            </button>
                                        <% } else { %>
                                            <span class="answer-pill-static <%= cls %>"><%= val %></span>
                                        <% } %>
                                        <%- badge %>
                                        <div>
