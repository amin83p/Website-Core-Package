<%
    function intListText(arr) {
        const list = Array.isArray(arr) ? arr.filter((n) => Number.isInteger(n)) : [];
        if (!list.length) return '-';
        return list.join(',');
    }
    function flattenStep3Signals(extraction) {
        const out = {};
        if (!extraction || typeof extraction !== 'object') return out;
        const pos = extraction.position || {};
        out['position.stance'] = String(pos.stance || 'unknown');
        out['position.stanceSentenceIndex'] = Number.isInteger(pos.stanceSentenceIndex) ? String(pos.stanceSentenceIndex) : 'null';
        out['position.contradictions'] = intListText(pos.contradictionSentenceIndices);

        const answers = extraction.answersBySubquestion && typeof extraction.answersBySubquestion === 'object'
            ? extraction.answersBySubquestion
            : (extraction.answers && typeof extraction.answers === 'object' ? extraction.answers : {});
        Object.keys(answers).sort().forEach((k) => {
            const v = answers[k];
            out[`answers.${k}`] = Array.isArray(v) ? intListText(v) : String(v ?? '-');
        });

        const body = Array.isArray(extraction.bodyParagraphs) ? extraction.bodyParagraphs : (Array.isArray(extraction.bodySupport) ? extraction.bodySupport : []);
        body.forEach((p, idx) => {
            const pNo = Number.isInteger(p?.paragraphNumber) ? p.paragraphNumber : (Number.isInteger(p?.paragraphIndex) ? p.paragraphIndex : (idx + 1));
            out[`body.P${pNo}.topic`] = Number.isInteger(p?.topicSentenceIndex) ? String(p.topicSentenceIndex) : 'null';
            out[`body.P${pNo}.evidence`] = intListText(p?.evidenceSentenceIndices);
            if (p?.hasExplanation !== undefined) out[`body.P${pNo}.hasExplanation`] = p.hasExplanation ? 'true' : 'false';
            if (p?.hasExample !== undefined) out[`body.P${pNo}.hasExample`] = p.hasExample ? 'true' : 'false';
        });
        const topicArr = Array.isArray(extraction.topicSentenceByParagraph) ? extraction.topicSentenceByParagraph : [];
        topicArr.forEach((t) => {
            const p = Number(t?.paragraphIndex);
            if (Number.isInteger(p) && p >= 0) out[`topic.P${p}`] = Number.isInteger(t?.topicSentenceIndex) ? String(t.topicSentenceIndex) : 'null';
        });
        const lq = extraction.lexicalQuality;
        if (lq && typeof lq === 'object') {
            if (lq.range != null) out['lexicalQuality.range'] = String(lq.range);
            if (lq.precision != null) out['lexicalQuality.precision'] = String(lq.precision);
            if (lq.uncommonSkill != null) out['lexicalQuality.uncommonSkill'] = String(lq.uncommonSkill);
        }
        const ep = extraction.errorProfiles;
        if (ep && typeof ep === 'object') {
            if (ep.grammar != null) out['errorProfiles.grammar'] = String(ep.grammar);
            if (ep.lexical != null) out['errorProfiles.lexical'] = String(ep.lexical);
            if (ep.punctuation != null) out['errorProfiles.punctuation'] = String(ep.punctuation);
        }
        return out;
    }

    function buildStep3MapFromSession(s) {
        const stability = s?.steps?.step3stability?.response?.json?.data || s?.steps?.step3extract?.response?.json?.meta?.stabilityGate || null;
        if (stability && Array.isArray(stability.allSignals) && stability.allSignals.length > 0) {
            const out = {};
            stability.allSignals.forEach((row) => {
                const key = String(row?.key || '').trim();
                if (key) out[key] = String(row?.consensusValue ?? row?.majorityValue ?? '-');
            });
            return out;
        }
        const extraction = s?.steps?.step3extract?.response?.json?.data || {};
        return flattenStep3Signals(extraction);
    }

    const step3Maps = (sessions || []).map((s) => buildStep3MapFromSession(s));
    const allStep3Keys = Array.from(new Set(step3Maps.flatMap((m) => Object.keys(m)))).sort();
%>

<div class="card border-0 shadow-sm mt-3 compare-table-card compare-table-card-step3" style="max-height: 88vh; overflow: hidden; display: flex; flex-direction: column;">
    <div class="card-header bg-white border-bottom fw-bold py-2 h2 mb-0">
        <i class="bi bi-diagram-3 me-2"></i>Step 3 Extraction Signals
    </div>
    <div class="table-responsive" style="flex: 1; overflow: auto;">
         <table class="table table-bordered table-hover mb-0 align-middle compare-sync-table" style="min-width: <%= 280 + 165 * sessions.length %>px;">
            <colgroup>
                <col class="col-param" style="width: 280px;">
                <% sessions.forEach((_, i) => { %><col class="col-session" data-column-index="<%= i %>" style="width: 165px;"><% }) %>
            </colgroup>
            <thead class="table-light">
                <tr>
                    <th class="sticky-col sticky-header" style="width: 280px; min-width: 280px; z-index: 20;">Step 3 Signal</th>
                    <% sessions.forEach((s, i) => {
                    %>
                        <th class="text-center sticky-header compare-header-cell" style="width: 165px;" data-column-index="<%= i %>">
