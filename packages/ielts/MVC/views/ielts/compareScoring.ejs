<%
    function toFeedbackStringList(raw) {
        if (!Array.isArray(raw)) return [];
        return raw
            .map((item) => normalizeFeedbackText(item))
            .filter((item) => item !== '-');
    }
    function toFeedbackCriterionRows(raw) {
        if (!Array.isArray(raw)) return [];
        return raw
            .map((item) => ({
                criterion: String(item?.criterion || 'General').toUpperCase(),
                summary: normalizeFeedbackText(item?.summary || item?.issue || '')
            }))
            .filter((item) => item.summary !== '-');
    }
    function toFeedbackImprovements(raw) {
        if (!Array.isArray(raw)) return [];
        return raw
            .map((item) => {
                const issue = normalizeFeedbackText(item?.issue || item?.summary || '');
                const fix = normalizeFeedbackText(item?.fix || '');
                const refs = Array.isArray(item?.evidenceRefs)
                    ? item.evidenceRefs.map((r) => String(r || '').trim()).filter(Boolean)
                    : [];
                const refsText = refs.length ? ` | Evidence: ${refs.join(', ')}` : '';
                const criterion = String(item?.criterion || 'General').toUpperCase();
                return {
                    criterion,
                    text: normalizeFeedbackText(`[${criterion}] ${issue}${fix !== '-' ? ` | Fix: ${fix}` : ''}${refsText}`)
                };
            })
            .filter((item) => item.text !== '-');
    }
    function getCriterionSummaryFromFeedback(rows, criterionKey) {
        if (!Array.isArray(rows)) return '-';
        const found = rows.find((row) => String(row?.criterion || '').toUpperCase() === criterionKey);
        return found ? normalizeFeedbackText(found.summary) : '-';
    }

    const step5Feedbacks = (sessions || []).map((s) => getStep5FeedbackData(s));
    const step5StrengthLists = step5Feedbacks.map((fb) => toFeedbackStringList(fb?.strengths));
    const step5ImprovementLists = step5Feedbacks.map((fb) => toFeedbackImprovements(fb?.improvements));
    const step5CriterionLists = step5Feedbacks.map((fb) => toFeedbackCriterionRows(fb?.byCriterion));
    const maxStrengthRows = Math.max(0, ...step5StrengthLists.map((arr) => arr.length));
    const maxImprovementRows = Math.max(0, ...step5ImprovementLists.map((arr) => arr.length));
    const criterionOrder = ['TR', 'CC', 'LR', 'GRA', 'GENERAL'];
%>
