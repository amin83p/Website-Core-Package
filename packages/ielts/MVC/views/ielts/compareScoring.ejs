      <pre id="promptModalBody" class="prompt-pre"></pre>
    </div>
    <div class="prompt-modal-footer">
      <button type="button" class="btn btn-outline-secondary btn-sm" id="copyPromptBtn">
        <i class="bi bi-clipboard me-1"></i>Copy Prompt
      </button>
      <button type="button" class="btn btn-secondary btn-sm" id="promptDismissBtn">Close</button>
    </div>
  </div>
