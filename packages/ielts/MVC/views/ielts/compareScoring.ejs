<%- include('partials/modal_GenericPicker', { user }) %>

<script type="application/json" id="comparisonData"><%- JSON.stringify(sessions) %></script>
<script>
        const DEFAULT_COMPARE_TYPE = '<%= currentCompareType %>';
        const STORAGE_KEY_FC = 'compareFirstColFontSize';
        const STORAGE_KEY_DC = 'compareDataCellFontSize';
        let comparisonRuntimeBound = false;
        let isComparisonRenderBusy = false;

        function pxToRem(px) { return (px / 100).toFixed(2) + 'rem'; }

        function initComparisonPageRuntime() {
            const mainEl = document.querySelector('main.container.my-4');
            if (mainEl) mainEl.classList.add('compare-full-width');

            const root = document.getElementById('comparePageRoot');
            if (!root) return;

            const applyFontSizes = () => {
                const fc = document.getElementById('compareFirstColFontSlider');
                const dc = document.getElementById('compareDataCellFontSlider');
                if (fc) root.style.setProperty('--compare-first-col-font-size', pxToRem(Number(fc.value)));
                if (dc) root.style.setProperty('--compare-data-cell-font-size', pxToRem(Number(dc.value)));
            };
            const updateLabels = () => {
                const fc = document.getElementById('compareFirstColFontSlider');
                const dc = document.getElementById('compareDataCellFontSlider');
                const fcVal = document.getElementById('compareFirstColFontValue');
                const dcVal = document.getElementById('compareDataCellFontValue');
                if (fc && fcVal) fcVal.textContent = pxToRem(Number(fc.value));
                if (dc && dcVal) dcVal.textContent = pxToRem(Number(dc.value));
            };

            const savedFc = localStorage.getItem(STORAGE_KEY_FC);
            const savedDc = localStorage.getItem(STORAGE_KEY_DC);
            const fcSlider = document.getElementById('compareFirstColFontSlider');
            const dcSlider = document.getElementById('compareDataCellFontSlider');
            if (fcSlider && savedFc) fcSlider.value = savedFc;
            if (dcSlider && savedDc) dcSlider.value = savedDc;
            applyFontSizes();
            updateLabels();

            fcSlider?.addEventListener('input', () => {
                applyFontSizes();
                updateLabels();
                localStorage.setItem(STORAGE_KEY_FC, fcSlider.value);
            });
            dcSlider?.addEventListener('input', () => {
                applyFontSizes();
                updateLabels();
                localStorage.setItem(STORAGE_KEY_DC, dcSlider.value);
            });

            // Synchronize horizontal scrolling between all comparison tables.
            const tableContainers = document.querySelectorAll('.compare-table-card .table-responsive');
            if (tableContainers.length >= 2) {
                let isSyncing = false;
                tableContainers.forEach((sourceTable) => {
                    sourceTable.addEventListener('scroll', () => {
                        if (isSyncing) return;
                        isSyncing = true;
                        tableContainers.forEach((targetTable) => {
                            if (targetTable !== sourceTable) {
                                targetTable.scrollLeft = sourceTable.scrollLeft;
                            }
                        });
                        isSyncing = false;
                    });
                });
            }

            if (!comparisonRuntimeBound) {
                comparisonRuntimeBound = true;
                document.addEventListener('click', (e) => {
                    const btn = e.target.closest('.remove-column-btn');
                    if (!btn || isComparisonRenderBusy) return;
                    const idx = Number(btn.getAttribute('data-column-index'));
                    if (!Number.isInteger(idx) || idx < 0) return;
                    const sessions = parseComparisonSessions();
                    if (sessions.length <= 2) return;
                    const remaining = sessions.filter((_, i) => i !== idx);
                    if (remaining.length < 2) return;
                    rerenderComparisonBySessions(remaining);
                });
            }
        }

        document.addEventListener('DOMContentLoaded', initComparisonPageRuntime);

    function parseComparisonSessions() {
        try {
            const raw = document.getElementById('comparisonData')?.textContent || '[]';
            const parsed = JSON.parse(raw);
            return Array.isArray(parsed) ? parsed : [];
        } catch (_) {
            return [];
        }
    }

    function getComparisonSessionIds() {
        return parseComparisonSessions()
            .map((s) => s?.sessionId || s?.id)
            .filter(Boolean);
    }

    function normalizePipelineMode(raw) {
        const mode = String(raw || '').trim().toLowerCase();
        if (mode === 'step3_tuning') return 'step3_tuning';
        if (mode === 'step4_tuning') return 'step4_tuning';
        return 'full';
    }

    function getCurrentComparisonType() {
        const sessions = parseComparisonSessions();
        const detected = sessions.length > 0
            ? normalizePipelineMode(sessions[0]?.pipelineMode || sessions[0]?.researchConfig?.pipelineMode || sessions[0]?.metadata?.pipelineMode)
            : normalizePipelineMode(DEFAULT_COMPARE_TYPE || 'full');
        return detected === 'step3_tuning' ? 'step3_tuning' : 'full';
    }

    function buildComparisonUrlFromIds(ids) {
        const encoded = (ids || [])
            .map((id) => encodeURIComponent(String(id || '').trim()))
            .filter(Boolean)
            .join(',');
        return `/ielts/scoring/compare?ids=${encoded}`;
    }

    function buildPromptMapsFromSessions(sessionRows) {
        if (!Array.isArray(sessionRows)) return [];
        return sessionRows.map((session) => {
            const prompts = session?.steps?.step4grade?.response?.json?.data?.meta?.aiPrompts || [];
            const map = {};
            prompts.forEach((prompt) => {
                const text = String(prompt || '');
                const re = /ID:\s*([A-Z]{2}\d+-\d+)/g;
                let match;
                while ((match = re.exec(text)) !== null) {
                    map[match[1]] = text;
                }
            });
            return map;
        });
    }

    async function rerenderComparisonByIds(ids) {
        const cleanIds = (ids || []).map((id) => String(id || '').trim()).filter(Boolean);
        if (cleanIds.length < 2) {
            await notifyMessage('Comparison Needs 2 Sessions', 'Please keep at least two sessions for comparison.', 'warning');
            return;
        }
        if (isComparisonRenderBusy) return;
        const url = buildComparisonUrlFromIds(cleanIds);
        isComparisonRenderBusy = true;
        try {
            const res = await fetch(url, {
                method: 'GET',
                credentials: 'include',
                headers: {
                    'Accept': 'text/html',
                    'X-AJAX-Request': 'true'
                }
            });
            if (!res.ok) {
                throw new Error(`Failed to load comparison view (HTTP ${res.status}).`);
            }
            const html = await res.text();
            const parser = new DOMParser();
            const doc = parser.parseFromString(html, 'text/html');
            const nextRoot = doc.getElementById('comparePageRoot');
            const nextComparisonData = doc.getElementById('comparisonData');
            if (!nextRoot || !nextComparisonData) {
                throw new Error('Unable to refresh comparison layout from server response.');
            }

            const currentRoot = document.getElementById('comparePageRoot');
            if (!currentRoot) {
                throw new Error('Current comparison container is missing.');
            }
            currentRoot.replaceWith(nextRoot);

            const currentDataNode = document.getElementById('comparisonData');
            if (currentDataNode) {
                currentDataNode.textContent = nextComparisonData.textContent || '[]';
            }

            const updatedSessions = parseComparisonSessions();
            window.__promptMaps = buildPromptMapsFromSessions(updatedSessions);
            history.replaceState(null, '', url);
            initComparisonPageRuntime();
        } catch (error) {
            await notifyMessage('Refresh Failed', error?.message || 'Could not refresh comparison page.', 'error');
        } finally {
            isComparisonRenderBusy = false;
        }
    }

    function navigateComparisonByIds(ids) {
        return rerenderComparisonByIds(ids);
    }

    function rerenderComparisonBySessions(sessions) {
        const ids = (sessions || [])
            .map((session) => String(session?.sessionId || session?.id || '').trim())
            .filter(Boolean);
        return rerenderComparisonByIds(ids);
    }

    function navigateComparisonBySessions(sessions) {
        return rerenderComparisonBySessions(sessions);
    }

    function renderSessionPickerRow(item) {
        const sampleName = String(item?.sampleName || item?.metadata?.sampleName || item?.metadata?.sampleRefName || 'Untitled Sample');
        const id = String(item?.id || item?.sessionId || '').trim();
        const pipelineMode = normalizePipelineMode(item?.pipelineMode || item?.researchConfig?.pipelineMode || item?.metadata?.pipelineMode);
        const band = item?.overallBand ?? item?.steps?.step4grade?.response?.json?.data?.overallBand ?? '-';
        const savedAt = item?.savedAt ? new Date(item.savedAt) : null;
        const safeTime = savedAt && Number.isFinite(savedAt.getTime())
            ? `${savedAt.toLocaleDateString()} ${savedAt.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}`
            : '-';
        return `
            <div class="d-flex flex-column gap-1">
                <div class="fw-bold text-dark">${escapeHtml(sampleName)}</div>
                <div class="small text-muted font-monospace">${escapeHtml(id)}</div>
                <div class="d-flex flex-wrap align-items-center gap-2 small">
                    <span class="badge bg-light text-dark border">${escapeHtml(pipelineMode === 'step3_tuning' ? 'Step 3 Tuning' : 'Full Pipeline')}</span>
                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle">Band: ${escapeHtml(band)}</span>
                    <span class="text-muted">${escapeHtml(safeTime)}</span>
                </div>
            </div>
        `;
    }

    async function openAddSessionPicker() {
        if (!window.GenericPicker || !window.GenericPickerPresets || typeof window.GenericPicker.open !== 'function') {
            await notifyMessage('Picker Unavailable', 'Session picker is not available on this page.', 'warning');
            return;
        }

        const currentType = getCurrentComparisonType();
        const currentSessions = parseComparisonSessions();
        const existingIds = new Set(
            currentSessions
                .map((s) => String(s?.sessionId || s?.id || '').trim())
                .filter(Boolean)
        );

        window.GenericPicker.open(window.GenericPickerPresets.normalizeConfig({
            title: 'Add Sessions To Comparison',
            icon: 'bi-plus-circle',
            apiEndpoint: '/ielts/scoring/history',
            placeholder: 'Search sessions (type --- to show recent sessions)...',
            searchFields: 'id,sampleName,status,pipelineMode,scoringView,overallBand,savedAt',
            multiselect: true,
            limit: 20,
            renderer: renderSessionPickerRow,
            onSelect: async (selectedItems) => {
                const selected = Array.isArray(selectedItems) ? selectedItems : [];
                if (selected.length === 0) return;

                const mergedIds = Array.from(existingIds);
                let addedCount = 0;
                let duplicateCount = 0;
                let typeMismatchCount = 0;

                selected.forEach((item) => {
                    const id = String(item?.id || item?.sessionId || '').trim();
                    if (!id) return;
                    const mode = normalizePipelineMode(item?.pipelineMode || item?.researchConfig?.pipelineMode || item?.metadata?.pipelineMode);
                    if (mode !== currentType) {
                        typeMismatchCount += 1;
                        return;
                    }
                    if (existingIds.has(id)) {
                        duplicateCount += 1;
                        return;
                    }
                    existingIds.add(id);
                    mergedIds.push(id);
                    addedCount += 1;
                });

                if (addedCount === 0) {
                    const details = typeMismatchCount > 0
                        ? 'Only sessions with the same comparison type can be added.'
                        : 'Selected sessions are already in this comparison.';
                    await notifyMessage('No New Session Added', details, 'info');
                    return;
                }

                if (duplicateCount > 0 || typeMismatchCount > 0) {
                    const notes = [];
                    if (duplicateCount > 0) notes.push(`${duplicateCount} duplicate item(s) were ignored.`);
                    if (typeMismatchCount > 0) notes.push(`${typeMismatchCount} different-type item(s) were ignored.`);
                    await notifyMessage('Session List Updated', notes.join(' '), 'info');
                }

                await rerenderComparisonByIds(mergedIds);
            }
        }));
    }

    function stampNow() {
        return new Date().toISOString().slice(0, 19).replace(/[:T]/g, '-');
    }

    function downloadJson(filename, payload) {
        const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    function escapeHtml(s) {
        return String(s ?? '')
            .replace(/&/g, '&amp;')
            .replace(/</g, '&lt;')
            .replace(/>/g, '&gt;')
            .replace(/"/g, '&quot;')
            .replace(/'/g, '&#39;');
    }

    async function notifyMessage(title, message, icon = 'info') {
        if (typeof showMessageModal === 'function') {
            return showMessageModal({
                title,
                icon,
                message,
                buttons: [{ text: 'OK', class: 'btn-primary' }]
            });
        }
        console.warn(`[${title || 'Message'}] ${message || ''}`);
        return Promise.resolve('OK');
    }

    function exportComparison() {
        try {
            const data = parseComparisonSessions();
            const filename = `comparison_export_${stampNow()}.json`;
            downloadJson(filename, data);
        } catch (e) {
            notifyMessage('Export Failed', e.message || 'Could not export comparison JSON.', 'error');
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        const mainEl = document.querySelector('main.container.my-4');
        if (mainEl) mainEl.classList.add('compare-full-width');
    });
</script>
