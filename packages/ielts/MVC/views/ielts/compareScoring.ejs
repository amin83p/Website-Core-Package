                                <% if (sessions.length > 2) { %>
                                    <button type="button" class="btn btn-outline-danger btn-sm py-0 px-1 remove-column-btn mt-1" data-column-index="<%= i %>" title="Remove this sample from comparison"><i class="bi bi-x-lg"></i></button>
