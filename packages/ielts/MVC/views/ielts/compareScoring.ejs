                    <%
                        const summaryValues = step5Feedbacks.map((fb) => truncateForCell(fb?.summary || '-', 260));
                        const summaryColorMap = getValueColorMap(summaryValues);
                    %>
                    <% summaryValues.forEach((value, i) => {
