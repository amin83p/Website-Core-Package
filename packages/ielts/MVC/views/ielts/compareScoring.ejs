                        </td>
                        <% values.forEach((v, vi) => {
                            const normKey = normKeyForColor(v);
                            const bgColor = valueColorMap[normKey] || '';
                            const cellClass = bgColor ? 'text-center font-monospace small text-break value-colored-cell' : 'text-center font-monospace small text-break';
                            const cellStyle = bgColor ? ` style="background-color: ${bgColor} !important;"` : '';
                        %>
