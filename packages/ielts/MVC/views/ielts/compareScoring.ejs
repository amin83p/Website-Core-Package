                <% if (!allStep3Keys.length) { %>
                    <tr>
                        <td class="sticky-col text-muted">No Step 3 signals found.</td>
                        <% sessions.forEach((_, i) => { %><td data-column-index="<%= i %>"></td><% }) %>
                    </tr>
                <% } %>

                <% allStep3Keys.forEach((key) => {
                    const values = step3Maps.map((m) => String((m && m[key] != null) ? m[key] : '-'));
                    const unique = new Set(values.filter((v) => v !== '-').map((v) => v.toLowerCase()));
                    const isDiff = unique.size > 1;
                    const valueColorMap = getValueColorMap(values);
                %>
                    <tr class="<%= isDiff ? 'diff-row' : '' %>">
                        <td class="sticky-col">
