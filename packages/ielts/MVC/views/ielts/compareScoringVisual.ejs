  align-items: stretch;
}
.row-equal-height .col-lg-7 .card,
.row-equal-height .col-lg-5 .card {
  display: flex;
  flex-direction: column;
}
.row-equal-height .col-lg-7 .card .card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-height: 0;
}
.chart-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem 0.75rem;
}
.legend-item {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  border: 1px solid #dee2e6;
  border-radius: 999px;
  padding: 0.2rem 0.55rem;
  background: #fff;
}
.legend-swatch {
  width: 10px;
  height: 10px;
  border-radius: 2px;
  display: inline-block;
}
.pair-run-link {
