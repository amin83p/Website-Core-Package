<% const visualIdsQuery = (ids || []).map((id) => encodeURIComponent(id)).join(','); %>

<div class="sections-page">
  <div class="d-flex align-items-center justify-content-between mb-4 flex-wrap gap-2">
    <div>
      <h2 class="page-heading size-md m-0">Visual Session Comparison</h2>
      <div class="text-muted small mt-1">Variation, drift, agreement, and answer instability across <%= sessions.length %> runs.</div>
    </div>
    <div class="d-flex gap-2 flex-wrap">
      <a href="/ielts/scoring/compare?ids=<%- visualIdsQuery %>" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-table me-1"></i> Session Comparison
      </a>
      <button class="btn btn-outline-success btn-sm" onclick="refreshVisualPage()">
        <i class="bi bi-arrow-clockwise me-1"></i> Refresh
      </button>
      <button class="btn btn-outline-primary btn-sm" onclick="exportRepeatedRunAnalysis()">
        <i class="bi bi-graph-up-arrow me-1"></i> Export Repeated-Run Analysis
      </button>
      <button class="btn btn-primary btn-sm" onclick="exportVisualPack()">
        <i class="bi bi-download me-1"></i> Export Visual Pack
      </button>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-2">
      <div id="visualStatus" class="small text-muted">Loading visual analytics...</div>
      <span id="visualGeneratedAt" class="badge bg-light text-dark border font-monospace">-</span>
    </div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-xl-2 col-md-4 col-6"><div class="p-3 border rounded bg-light"><div class="small text-muted fw-bold">Runs</div><div id="kpiRuns" class="h4 m-0">-</div></div></div>
    <div class="col-xl-2 col-md-4 col-6"><div class="p-3 border rounded bg-light"><div class="small text-muted fw-bold">Band Range</div><div id="kpiBandRange" class="h4 m-0">-</div></div></div>
    <div class="col-xl-2 col-md-4 col-6"><div class="p-3 border rounded bg-light"><div class="small text-muted fw-bold">Flip Rate</div><div id="kpiFlipRate" class="h4 m-0">-</div></div></div>
    <div class="col-xl-2 col-md-4 col-6"><div class="p-3 border rounded bg-light"><div class="small text-muted fw-bold">Drift</div><div id="kpiDrift" class="h4 m-0">-</div></div></div>
    <div class="col-xl-2 col-md-4 col-6"><div class="p-3 border rounded bg-light"><div class="small text-muted fw-bold">Agreement</div><div id="kpiAgreement" class="h4 m-0">-</div></div></div>
    <div class="col-xl-2 col-md-4 col-6"><div class="p-3 border rounded bg-light"><div class="small text-muted fw-bold">Avg Runtime</div><div id="kpiRuntime" class="h4 m-0">-</div></div></div>
  </div>

  <div class="row g-3 mb-3">
    <div class="col-lg-8">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white fw-bold small">Band Variation (Overall + TR/CC/LR/GRA)</div>
        <div class="card-body">
          <canvas id="bandCanvas" height="300"></canvas>
          <div id="bandLegend" class="chart-legend mt-3" aria-label="Band chart legend"></div>
        </div>
      </div>
    </div>
    <div class="col-lg-4">
      <div class="card border-0 shadow-sm h-100">
        <div class="card-header bg-white fw-bold small">Efficiency Notes</div>
        <div class="card-body"><ul id="insightList" class="mb-0 ps-3 small"></ul></div>
      </div>
    </div>
  </div>

  <div class="row g-3 mb-3 row-equal-height">
    <div class="col-lg-7 d-flex">
      <div class="card border-0 shadow-sm flex-grow-1 w-100">
        <div class="card-header bg-white fw-bold small">Top Question Answer Variations</div>
        <div class="card-body d-flex flex-column">
          <div class="variation-chart-container flex-grow-1" style="min-height: 500px;">
            <canvas id="variationCanvas"></canvas>
          </div>
          <div id="variationLegend" class="chart-legend mt-3" aria-label="Variation chart legend"></div>
        </div>
      </div>
    </div>
    <div class="col-lg-5 d-flex">
      <div class="card border-0 shadow-sm flex-grow-1 w-100">
        <div class="card-header bg-white fw-bold small">Pairwise Agreement</div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm mb-0 align-middle">
              <thead class="table-light"><tr><th>Pair</th><th class="text-center">Comparisons</th><th class="text-center">Agreement</th></tr></thead>
              <tbody id="agreementRows"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mb-3">
    <div class="card-header bg-white fw-bold small">Step 3 Signal Variations</div>
    <div class="card-body">
      <div class="step3-chart-container" style="min-height: 400px;">
        <canvas id="step3SignalCanvas"></canvas>
      </div>
      <div id="step3SignalLegend" class="chart-legend mt-3" aria-label="Step 3 signal legend"></div>
      <div class="mt-4">
        <div class="fw-bold small mb-2">Step 3 Signal Details</div>
        <div class="table-responsive">
          <table class="table table-sm table-hover mb-0 align-middle step3-signal-details-table">
            <thead class="table-light">
              <tr>
                <th class="step3-signal-key-col">Signal Key</th>
                <th class="text-center">Unique</th>
                <th class="text-center">Flip Rate</th>
                <th>Values by Run</th>
              </tr>
            </thead>
            <tbody id="step3SignalRows"></tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm">
    <div class="card-header bg-white fw-bold small">Answer Variation Details (Most Variable Questions First)</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>Question Key</th>
              <th>Criterion</th>
              <th class="text-center">Unique</th>
              <th class="text-center">Flip Rate</th>
              <th>Values by Run</th>
              <th>Question</th>
            </tr>
          </thead>
          <tbody id="variationRows"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mt-3">
    <div class="card-header bg-white fw-bold small">Full Step 3 Signal Matrix (All Signals x Runs)</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm table-bordered mb-0 align-middle micro-matrix-table">
          <thead id="step3MatrixHead" class="table-light"></thead>
          <tbody id="step3MatrixRows"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mt-3">
    <div class="card-header bg-white fw-bold small">Run Snapshot Matrix (Comprehensive)</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm table-hover mb-0 align-middle">
          <thead class="table-light">
            <tr>
              <th>Run</th>
              <th>Session</th>
              <th>Sample</th>
              <th class="text-center">Overall</th>
              <th class="text-center">Examiner</th>
              <th class="text-center">Delta</th>
              <th class="text-center">TR</th>
              <th class="text-center">CC</th>
              <th class="text-center">LR</th>
              <th class="text-center">GRA</th>
              <th>Model</th>
              <th class="text-center">Batch/Concurrency</th>
              <th class="text-center">Word</th>
              <th class="text-center">Paragraphs</th>
              <th class="text-center">Cohesion</th>
              <th class="text-center">Stance</th>
              <th class="text-center">Step2</th>
              <th class="text-center">Step3</th>
              <th class="text-center">Step4</th>
            </tr>
          </thead>
          <tbody id="runSnapshotRows"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card border-0 shadow-sm mt-3">
    <div class="card-header bg-white fw-bold small">Full Micro-Assessment Matrix (All Questions x Runs)</div>
    <div class="card-body p-0">
      <div class="table-responsive">
        <table class="table table-sm table-bordered mb-0 align-middle micro-matrix-table">
          <thead id="microMatrixHead" class="table-light"></thead>
          <tbody id="microMatrixRows"></tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script type="application/json" id="visualSessionData"><%- JSON.stringify(sessions || []) %></script>
<script>
(function () {
  const COLORS = ['#0d6efd', '#198754', '#f4b400', '#ab47bc', '#dc3545', '#20c997'];
  let cachedReport = null;
  let cachedVariation = [];
  let cachedStep3Variation = [];

  const esc = (v) => String(v ?? '').replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
  const toPct = (v) => Number.isFinite(Number(v)) ? `${(Number(v) * 100).toFixed(1)}%` : '-';
  const toFixed = (v, d = 2) => Number.isFinite(Number(v)) ? Number(v).toFixed(d) : '-';
  const toSec = (v) => Number.isFinite(Number(v)) ? `${Number(v).toFixed(1)}s` : '-';
  const stampNow = () => new Date().toISOString().slice(0, 19).replace(/[:T]/g, '-');
  const tailId = (id, size = 8) => {
    const raw = String(id || '').trim();
    if (!raw) return '-';
    return raw.length > size ? `...${raw.slice(-size)}` : raw;
  };

  function sessions() {
    try { return JSON.parse(document.getElementById('visualSessionData')?.textContent || '[]'); }
    catch (_) { return []; }
  }

  function ids() {
    return sessions().map((s) => s?.sessionId || s?.id).filter(Boolean);
  }

  async function showModalMessage(title, message, icon = 'info') {
    if (typeof showMessageModal === 'function') {
      return showMessageModal({ title, message, icon, buttons: [{ text: 'OK', class: 'btn-primary' }] });
    }
    console.warn(`${title}: ${message}`);
    return Promise.resolve();
  }

  function downloadJson(filename, payload) {
    const blob = new Blob([JSON.stringify(payload, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }

  function totalRuntimeSeconds(session) {
    const keys = ['step1freeze', 'step2analyze', 'step3extract', 'step4grade', 'step5feedback'];
    return keys.reduce((sum, k) => {
      const t = session?.steps?.[k]?.timing;
      if (!t?.startedAt || !t?.endedAt) return sum;
      return sum + Math.max(0, (Number(t.endedAt) - Number(t.startedAt))) / 1000;
    }, 0);
  }

  function getStepSeconds(session, key) {
    const t = session?.steps?.[key]?.timing;
    if (!t?.startedAt || !t?.endedAt) return null;
    const sec = Math.max(0, (Number(t.endedAt) - Number(t.startedAt)) / 1000);
    return Number.isFinite(sec) ? sec : null;
  }

  function buildAnswerVariations(list) {
    const map = new Map();
    const count = list.length;
    list.forEach((s, idx) => {
      const rows = s?.steps?.step4grade?.response?.json?.data?.results || [];
      rows.forEach((r) => {
        const key = String(r?.question_key || r?.baseKey || r?.instanceKey || '').trim();
        if (!key) return;
        if (!map.has(key)) map.set(key, { key, criterion: String(r?.criterion || 'General').toUpperCase(), q: String(r?.atomic_question || ''), values: Array(count).fill(null) });
        const e = map.get(key);
        if (!e.q && r?.atomic_question) e.q = String(r.atomic_question);
        e.values[idx] = r?.value == null || String(r.value).trim() === '' ? null : String(r.value).trim();
      });
    });

    const rows = Array.from(map.values()).map((e) => {
      const normalized = e.values.filter((v) => v !== null).map((v) => String(v).toLowerCase());
      const unique = new Set(normalized).size;
      let comparisons = 0; let flips = 0;
      for (let i = 1; i < e.values.length; i += 1) {
        const a = e.values[i - 1]; const b = e.values[i];
        if (a === null || b === null) continue;
        comparisons += 1;
        if (String(a).toLowerCase() !== String(b).toLowerCase()) flips += 1;
      }
      const flipRate = comparisons > 0 ? flips / comparisons : null;
      return { ...e, unique, comparisons, flips, flipRate };
    });

    rows.sort((a, b) => {
      const af = Number.isFinite(Number(a.flipRate)) ? Number(a.flipRate) : -1;
      const bf = Number.isFinite(Number(b.flipRate)) ? Number(b.flipRate) : -1;
      if (bf !== af) return bf - af;
      return b.unique - a.unique;
    });
    return rows;
  }

  function intListText(arr) {
    const list = Array.isArray(arr) ? arr.filter((n) => Number.isInteger(n)) : [];
    return list.length ? list.join(',') : '-';
  }

  function flattenStep3Signals(extraction) {
    const out = new Map();
    if (!extraction || typeof extraction !== 'object') return out;
    const data = extraction;
    const pos = data.position || {};
    out.set('position.stance', String(pos.stance || 'unknown'));
    out.set('position.stanceSentenceIndex', Number.isInteger(pos.stanceSentenceIndex) ? String(pos.stanceSentenceIndex) : 'null');
    out.set('position.contradictions', intListText(pos.contradictionSentenceIndices));

    const answers = data.answersBySubquestion && typeof data.answersBySubquestion === 'object'
      ? data.answersBySubquestion
      : (data.answers && typeof data.answers === 'object' ? data.answers : {});
    Object.keys(answers).sort().forEach((k) => {
      const v = answers[k];
      out.set(`answers.${k}`, Array.isArray(v) ? intListText(v) : String(v ?? '-'));
    });

    const body = Array.isArray(data.bodyParagraphs) ? data.bodyParagraphs : (Array.isArray(data.bodySupport) ? data.bodySupport : []);
    body.forEach((p, idx) => {
      const pNo = Number.isInteger(p?.paragraphNumber) ? p.paragraphNumber : (Number.isInteger(p?.paragraphIndex) ? p.paragraphIndex : (idx + 1));
      out.set(`body.P${pNo}.topic`, Number.isInteger(p?.topicSentenceIndex) ? String(p.topicSentenceIndex) : 'null');
      out.set(`body.P${pNo}.evidence`, intListText(p?.evidenceSentenceIndices));
      if (p?.hasExplanation !== undefined) out.set(`body.P${pNo}.hasExplanation`, p.hasExplanation ? 'true' : 'false');
      if (p?.hasExample !== undefined) out.set(`body.P${pNo}.hasExample`, p.hasExample ? 'true' : 'false');
    });
    const topicArr = Array.isArray(data.topicSentenceByParagraph) ? data.topicSentenceByParagraph : [];
    topicArr.forEach((t) => {
      const p = Number(t?.paragraphIndex);
      if (Number.isInteger(p) && p >= 0) out.set(`topic.P${p}`, Number.isInteger(t?.topicSentenceIndex) ? String(t.topicSentenceIndex) : 'null');
    });
    const lq = data.lexicalQuality;
    if (lq && typeof lq === 'object') {
      if (lq.range != null) out.set('lexicalQuality.range', String(lq.range));
      if (lq.precision != null) out.set('lexicalQuality.precision', String(lq.precision));
      if (lq.uncommonSkill != null) out.set('lexicalQuality.uncommonSkill', String(lq.uncommonSkill));
    }
    const ep = data.errorProfiles;
    if (ep && typeof ep === 'object') {
      if (ep.grammar != null) out.set('errorProfiles.grammar', String(ep.grammar));
      if (ep.lexical != null) out.set('errorProfiles.lexical', String(ep.lexical));
      if (ep.punctuation != null) out.set('errorProfiles.punctuation', String(ep.punctuation));
    }
    return out;
  }

  function buildStep3MapFromSession(s) {
    const stability = s?.steps?.step3stability?.response?.json?.data || s?.steps?.step3extract?.response?.json?.meta?.stabilityGate || null;
    if (stability && Array.isArray(stability.allSignals) && stability.allSignals.length > 0) {
      const out = new Map();
      stability.allSignals.forEach((row) => {
        const key = String(row?.key || '').trim();
        if (key) out.set(key, String(row?.consensusValue ?? row?.majorityValue ?? '-'));
      });
      return out;
    }
    const extraction = s?.steps?.step3extract?.response?.json?.data || {};
    return flattenStep3Signals(extraction);
  }

  function buildStep3SignalVariations(list) {
    const map = new Map();
    const runCount = list.length;
    list.forEach((s, idx) => {
      const flattened = buildStep3MapFromSession(s);
      flattened.forEach((value, key) => {
        if (!map.has(key)) map.set(key, { key, values: Array(runCount).fill(null) });
        map.get(key).values[idx] = String(value ?? '').trim() || '-';
      });
    });

    const rows = Array.from(map.values()).map((row) => {
      const norm = row.values.filter((v) => v != null && v !== '-').map((v) => String(v).toLowerCase());
      const unique = new Set(norm).size;
      let comparisons = 0;
      let flips = 0;
      for (let i = 1; i < row.values.length; i += 1) {
        const a = row.values[i - 1];
        const b = row.values[i];
        if (!a || !b || a === '-' || b === '-') continue;
        comparisons += 1;
        if (String(a).toLowerCase() !== String(b).toLowerCase()) flips += 1;
      }
      return {
        ...row,
        unique,
        comparisons,
        flips,
        flipRate: comparisons > 0 ? flips / comparisons : null
      };
    });

    rows.sort((a, b) => {
      const af = Number.isFinite(Number(a.flipRate)) ? Number(a.flipRate) : -1;
      const bf = Number.isFinite(Number(b.flipRate)) ? Number(b.flipRate) : -1;
      if (bf !== af) return bf - af;
      if (b.unique !== a.unique) return b.unique - a.unique;
      return String(a.key || '').localeCompare(String(b.key || ''));
    });
    return rows;
  }

  function drawLineChart(canvas, labels, series) {
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    const w = Math.max(620, Math.floor(rect.width || 620));
    const h = 300;
    canvas.width = w * dpr; canvas.height = h * dpr; ctx.setTransform(dpr, 0, 0, dpr, 0, 0); ctx.clearRect(0, 0, w, h);
    const L = 48; const R = 20; const T = 20; const B = 40; const PW = w - L - R; const PH = h - T - B;
    const x = (i) => labels.length <= 1 ? L + (PW / 2) : L + i * (PW / (labels.length - 1));
    const y = (v) => T + (1 - (Math.max(0, Math.min(9, Number(v))) / 9)) * PH;

    ctx.font = '14px system-ui, sans-serif'; ctx.strokeStyle = '#e9ecef'; ctx.fillStyle = '#6c757d';
    for (let i = 0; i <= 9; i += 1) { const yy = y(i); ctx.beginPath(); ctx.moveTo(L, yy); ctx.lineTo(L + PW, yy); ctx.stroke(); ctx.fillText(String(i), 6, yy + 4); }
    ctx.strokeStyle = '#adb5bd'; ctx.beginPath(); ctx.moveTo(L, T); ctx.lineTo(L, T + PH); ctx.lineTo(L + PW, T + PH); ctx.stroke();
    labels.forEach((lb, i) => { if (i % Math.ceil(labels.length / 10 || 1) === 0 || i === labels.length - 1) ctx.fillText(lb, x(i) - 10, T + PH + 18); });

    series.forEach((s, idx) => {
      ctx.strokeStyle = COLORS[idx % COLORS.length]; ctx.fillStyle = COLORS[idx % COLORS.length]; ctx.lineWidth = 2;
      let started = false;
      (s.values || []).forEach((v, i) => {
        if (!Number.isFinite(Number(v))) { started = false; return; }
        const xx = x(i); const yy = y(v);
        if (!started) { ctx.beginPath(); ctx.moveTo(xx, yy); started = true; } else { ctx.lineTo(xx, yy); }
      });
      if (started) ctx.stroke();
      (s.values || []).forEach((v, i) => { if (!Number.isFinite(Number(v))) return; ctx.beginPath(); ctx.arc(x(i), y(v), 2.6, 0, Math.PI * 2); ctx.fill(); });
    });
  }

  function drawVariationBars(canvas, rows) {
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const top = (rows || []).slice(0, 12);
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.closest('.variation-chart-container') || canvas.parentElement;
    const containerRect = container ? container.getBoundingClientRect() : canvas.getBoundingClientRect();
    const w = Math.max(620, Math.floor(containerRect.width || 620));
    const h = Math.max(300, Math.floor(containerRect.height || 300));
    canvas.width = w * dpr; canvas.height = h * dpr; ctx.setTransform(dpr, 0, 0, dpr, 0, 0); ctx.clearRect(0, 0, w, h);
    const L = 260; const R = 36; const rowH = 28; const gap = 12; const maxW = w - L - R;
    const topPad = 16;
    ctx.font = '14px system-ui, sans-serif';
    top.forEach((r, i) => {
      const y = topPad + i * (rowH + gap);
      const pct = Number.isFinite(Number(r.flipRate)) ? Number(r.flipRate) : 0;
      const bw = Math.max(2, Math.round(maxW * pct));
      const barH = rowH - 2;
      ctx.fillStyle = '#495057'; ctx.fillText(String(r.key || '-').slice(0, 28), 8, y + barH / 2 + 4);
      ctx.fillStyle = COLORS[i % COLORS.length]; ctx.fillRect(L, y + 1, bw, barH);
      ctx.fillStyle = '#212529'; ctx.fillText(toPct(pct), L + bw + 8, y + barH / 2 + 4);
    });
  }

  function drawStep3Bars(canvas, rows) {
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    const allRows = rows || [];
    const dpr = window.devicePixelRatio || 1;
    const container = canvas.closest('.step3-chart-container') || canvas.parentElement;
    const containerRect = container ? container.getBoundingClientRect() : canvas.getBoundingClientRect();
    const w = Math.max(620, Math.floor(containerRect.width || 620));
    const h = 420;
    canvas.width = w * dpr; canvas.height = h * dpr; ctx.setTransform(dpr, 0, 0, dpr, 0, 0); ctx.clearRect(0, 0, w, h);
    const L = 48;
    const R = 28;
    const T = 28;
    const B = 100;
    const PW = w - L - R;
    const PH = h - T - B;
    const n = allRows.length;
    if (n === 0) return;
    const barGap = 12;
    const barWidth = Math.min(26, Math.max(10, (PW - (n - 1) * barGap) / n));
    const yScale = (v) => T + (1 - Math.min(1, Math.max(0, v))) * PH;

    ctx.font = '14px system-ui, sans-serif';
    ctx.strokeStyle = '#e9ecef';
    ctx.fillStyle = '#6c757d';
    for (let i = 0; i <= 5; i += 1) {
      const v = i / 5;
      const yy = yScale(v);
      ctx.beginPath();
      ctx.moveTo(L, yy);
      ctx.lineTo(L + PW, yy);
      ctx.stroke();
      ctx.fillText(`${(v * 100).toFixed(0)}%`, 6, yy + 4);
    }
    ctx.strokeStyle = '#adb5bd';
    ctx.beginPath();
    ctx.moveTo(L, T);
    ctx.lineTo(L, T + PH);
    ctx.lineTo(L + PW, T + PH);
    ctx.stroke();

    allRows.forEach((r, i) => {
      const pct = Number.isFinite(Number(r.flipRate)) ? Number(r.flipRate) : 0;
      const x = L + i * (barWidth + barGap);
      const barH = Math.max(2, (T + PH) - yScale(pct));
      const barY = yScale(pct);
      ctx.fillStyle = COLORS[i % COLORS.length];
      ctx.fillRect(x, barY, barWidth, barH);

      const key = String(r.key || '-');
      const shortKey = key.length > 24 ? `${key.slice(0, 21)}…` : key;
      ctx.save();
      ctx.translate(x + barWidth / 2, T + PH + 18);
      ctx.rotate(-Math.PI / 4);
      ctx.textAlign = 'right';
      ctx.fillStyle = '#495057';
      ctx.font = '12px system-ui, sans-serif';
      ctx.fillText(shortKey, 0, 0);
      ctx.restore();
    });
  }

  function renderLegend(targetId, items) {
    const el = document.getElementById(targetId);
    if (!el) return;
    if (!Array.isArray(items) || !items.length) {
      el.innerHTML = '<span class="text-muted small">No legend data.</span>';
      return;
    }
    el.innerHTML = items.map((item) => {
      const color = String(item?.color || '#6c757d');
      const label = esc(item?.label || '-');
      return `<span class="legend-item"><span class="legend-swatch" style="background:${color};"></span><span class="small">${label}</span></span>`;
    }).join('');
  }

  function renderVariationRows(rows) {
    const tbody = document.getElementById('variationRows');
    if (!tbody) return;
    const html = (rows || []).slice(0, 40).map((r) => {
      const series = (r.values || []).map((v, i) => {
        const cls = v == null ? 'bg-light text-muted border' : 'bg-secondary-subtle text-dark border';
        return `<span class=\"badge ${cls} me-1 mb-1\">R${i + 1}: ${esc(v == null ? '-' : v)}</span>`;
      }).join('');
      return `<tr><td class=\"font-monospace\">${esc(r.key)}</td><td><span class=\"badge bg-light text-dark border\">${esc(r.criterion)}</span></td><td class=\"text-center fw-bold\">${esc(r.unique)}</td><td class=\"text-center\">${esc(toPct(r.flipRate))}</td><td>${series}</td><td class=\"small text-muted\">${esc(r.q || '')}</td></tr>`;
    }).join('');
    tbody.innerHTML = html || '<tr><td colspan=\"6\" class=\"text-muted small text-center py-3\">No answer variation rows.</td></tr>';
  }

  function renderStep3SignalRows(rows) {
    const tbody = document.getElementById('step3SignalRows');
    if (!tbody) return;
    const html = (rows || []).map((r) => {
      const series = (r.values || []).map((v, i) => {
        const cls = v == null || v === '-' ? 'bg-light text-muted border' : 'bg-secondary-subtle text-dark border';
        return `<span class=\"badge ${cls} me-1 mb-1\">R${i + 1}: ${esc(v == null ? '-' : v)}</span>`;
      }).join('');
      return `<tr>
        <td class="font-monospace step3-signal-key-col">${esc(r.key)}</td>
        <td class="text-center fw-bold">${esc(r.unique)}</td>
        <td class=\"text-center\">${esc(toPct(r.flipRate))}</td>
        <td>${series}</td>
      </tr>`;
    }).join('');
    tbody.innerHTML = html || '<tr><td colspan=\"4\" class=\"text-muted small text-center py-3\">No Step 3 signal variation rows.</td></tr>';
  }

  function renderFullStep3Matrix(step3Rows, list) {
    const thead = document.getElementById('step3MatrixHead');
    const tbody = document.getElementById('step3MatrixRows');
    if (!thead || !tbody) return;

    const headerCells = (list || []).map((s, i) => {
      const sid = String(s?.sessionId || s?.id || '-').slice(0, 8);
      return `<th class="text-center"><div>R${i + 1}</div><div class="small text-muted font-monospace">${esc(sid)}</div></th>`;
    }).join('');

    thead.innerHTML = `<tr>
      <th class="micro-sticky-col">Signal Key</th>
      ${headerCells}
    </tr>`;

    const rows = (step3Rows || []).slice().sort((a, b) => String(a?.key || '').localeCompare(String(b?.key || '')));
    const html = rows.map((row) => {
      const valueCells = (row.values || []).map((v) => `<td class="text-center font-monospace small">${esc(v == null ? '-' : v)}</td>`).join('');
      const contradiction = Number(row?.unique || 0) > 1 ? 'micro-contradiction-row' : '';
      return `<tr class="${contradiction}">
        <td class="micro-sticky-col"><span class="badge bg-light text-dark border font-monospace">${esc(row.key)}</span></td>
        ${valueCells}
      </tr>`;
    }).join('');

    const colCount = 1 + (list || []).length;
    tbody.innerHTML = html || `<tr><td colspan="${colCount}" class="text-muted small text-center py-3">No Step 3 signals available.</td></tr>`;
  }

  function renderAgreementRows(report, list) {
    const tbody = document.getElementById('agreementRows');
    if (!tbody) return;

    const loadIdMap = new Map();
    (list || []).forEach((s) => {
      const sid = String(s?.sessionId || '').trim();
      const id = String(s?.id || '').trim();
      const loadId = id || sid;
      if (sid) loadIdMap.set(sid, loadId);
      if (id) loadIdMap.set(id, loadId);
    });

    const runIndexMap = new Map();
    (report?.sessionMeta || []).forEach((meta, idx) => {
      const key = String(meta?.id || '').trim();
      if (key) runIndexMap.set(key, idx + 1);
    });

    const renderRunLink = (sessionRef) => {
      const raw = String(sessionRef || '').trim();
      if (!raw) return '<span class="text-muted">-</span>';
      const loadId = loadIdMap.get(raw) || raw;
      const runNo = runIndexMap.get(raw);
      const label = `${runNo ? `R${runNo}` : 'Run'} ${tailId(raw, 9)}`;
      const href = `/ielts/scoringV0225?loadId=${encodeURIComponent(loadId)}`;
      return `<a href="${href}" class="pair-run-link font-monospace" title="${esc(raw)}" target="_blank" rel="noopener noreferrer">${esc(label)}</a>`;
    };

    const rows = (report?.agreementAnalysis?.pairwise || [])
      .slice().sort((a, b) => Number(b?.agreementRate || -1) - Number(a?.agreementRate || -1))
      .slice(0, 12)
      .map((r) => `<tr><td class="small">${renderRunLink(r?.sessionA)} <span class="text-muted">vs</span> ${renderRunLink(r?.sessionB)}</td><td class=\"text-center\">${esc(r?.comparisons ?? '-')}</td><td class=\"text-center\">${esc(toPct(r?.agreementRate))}</td></tr>`)
      .join('');
    tbody.innerHTML = rows || '<tr><td colspan=\"3\" class=\"text-muted small text-center py-3\">No agreement pairs.</td></tr>';
  }

  function renderRunSnapshotRows(list) {
    const tbody = document.getElementById('runSnapshotRows');
    if (!tbody) return;
    const rows = (list || []).map((s, idx) => {
      const grade = s?.steps?.step4grade?.response?.json?.data || {};
      const scores = grade?.scores || {};
      const overallRaw = grade?.overallBand;
      const overall = Number.isFinite(Number(overallRaw)) ? Number(overallRaw).toFixed(1) : '-';

      const examinerRaw = s?.metadata?.examinerBandScore ?? s?.steps?.step1freeze?.response?.json?.meta?.sampleBandScore;
      const examinerNum = Number(examinerRaw);
      const examiner = Number.isFinite(examinerNum) ? examinerNum.toFixed(1) : '-';

      const overallNum = Number(overallRaw);
      const deltaNum = Number.isFinite(overallNum) && Number.isFinite(examinerNum)
        ? Number((overallNum - examinerNum).toFixed(1))
        : null;
      const deltaText = deltaNum == null ? '-' : `${deltaNum > 0 ? '+' : ''}${deltaNum.toFixed(1)}`;
      const deltaClass = deltaNum == null ? 'text-muted' : (deltaNum === 0 ? 'text-success fw-bold' : 'text-warning fw-bold');

      const m4 = grade?.meta?.modelUsed;
      const m3 = s?.steps?.step3extract?.response?.json?.data?.meta?.modelUsed;
      const model = m4 || m3 || '-';

      const gs = s?.uiState?.gradingSettings;
      const reqOpts = s?.steps?.step4grade?.request?.payload?.options;
      const batchSize = gs?.batchSize ?? reqOpts?.batchSize ?? '-';
      const concurrency = gs?.concurrency ?? reqOpts?.concurrency ?? '-';

      const stats = s?.steps?.step1freeze?.response?.json?.data?.stats || s?.steps?.step2analyze?.response?.json?.data?.stats || {};
      const structure = s?.steps?.step2analyze?.response?.json?.data?.structure || {};
      const cohesionRaw = s?.steps?.step2analyze?.response?.json?.data?.cohesion?.densityPer100;
      const cohesion = Number.isFinite(Number(cohesionRaw)) ? `${Number(cohesionRaw).toFixed(1)}%` : '-';
      const stance = String(s?.steps?.step3extract?.response?.json?.data?.position?.stance || '-').toUpperCase();

      return `<tr>
        <td><span class="badge bg-secondary-subtle text-dark border">R${idx + 1}</span></td>
        <td class="font-monospace">${esc(String(s?.sessionId || s?.id || '-').slice(0, 12))}</td>
        <td class="small">${esc(s?.metadata?.sampleName || '-')}</td>
        <td class="text-center fw-bold">${esc(overall)}</td>
        <td class="text-center">${esc(examiner)}</td>
        <td class="text-center ${deltaClass}">${esc(deltaText)}</td>
        <td class="text-center">${esc(scores?.TR ?? '-')}</td>
        <td class="text-center">${esc(scores?.CC ?? '-')}</td>
        <td class="text-center">${esc(scores?.LR ?? '-')}</td>
        <td class="text-center">${esc(scores?.GRA ?? '-')}</td>
        <td class="small font-monospace">${esc(model)}</td>
        <td class="text-center font-monospace">${esc(batchSize)} / ${esc(concurrency)}</td>
        <td class="text-center">${esc(stats?.wordCount ?? 0)}</td>
        <td class="text-center">${esc(structure?.paragraphCount ?? 0)}</td>
        <td class="text-center">${esc(cohesion)}</td>
        <td class="text-center">${esc(stance)}</td>
        <td class="text-center font-monospace">${esc(toSec(getStepSeconds(s, 'step2analyze')))}</td>
        <td class="text-center font-monospace">${esc(toSec(getStepSeconds(s, 'step3extract')))}</td>
        <td class="text-center font-monospace">${esc(toSec(getStepSeconds(s, 'step4grade')))}</td>
      </tr>`;
    }).join('');
    tbody.innerHTML = rows || '<tr><td colspan="19" class="text-muted small text-center py-3">No run details available.</td></tr>';
  }

  function buildFullMicroMatrix(list) {
    const map = new Map();
    const runCount = list.length;
    list.forEach((s, idx) => {
      const rows = s?.steps?.step4grade?.response?.json?.data?.results || [];
      rows.forEach((r) => {
        const key = String(r?.question_key || r?.baseKey || r?.instanceKey || '').trim();
        if (!key) return;
        if (!map.has(key)) {
          map.set(key, {
            key,
            criterion: String(r?.criterion || 'General').toUpperCase(),
            q: String(r?.atomic_question || ''),
            values: Array(runCount).fill('-')
          });
        }
        const item = map.get(key);
        if (!item.q && r?.atomic_question) item.q = String(r.atomic_question);
        item.values[idx] = r?.value == null || String(r.value).trim() === '' ? '-' : String(r.value).trim();
      });
    });

    return Array.from(map.values())
      .map((item) => {
        const normalized = item.values.filter((v) => v !== '-').map((v) => String(v).toLowerCase());
        const contradiction = new Set(normalized).size > 1;
        return { ...item, contradiction };
      })
      .sort((a, b) => {
        if (a.criterion !== b.criterion) return a.criterion.localeCompare(b.criterion);
        return a.key.localeCompare(b.key);
      });
  }

  function renderFullMicroMatrix(list) {
    const thead = document.getElementById('microMatrixHead');
    const tbody = document.getElementById('microMatrixRows');
    if (!thead || !tbody) return;

    const headerCells = list.map((s, i) => {
      const sid = String(s?.sessionId || s?.id || '-').slice(0, 8);
      return `<th class="text-center"><div>R${i + 1}</div><div class="small text-muted font-monospace">${esc(sid)}</div></th>`;
    }).join('');

    thead.innerHTML = `<tr>
      <th class="micro-sticky-col">Question Key</th>
      <th>Criterion</th>
      <th style="min-width: 320px;">Question</th>
      ${headerCells}
    </tr>`;

    const rows = buildFullMicroMatrix(list);
    const html = rows.map((row) => {
      const valueCells = row.values.map((v) => {
        const lv = String(v || '').toLowerCase();
        let cls = '';
        if (lv === 'yes' || lv === 'true') cls = 'text-success fw-bold';
        else if (lv === 'no' || lv === 'false') cls = 'text-danger';
        return `<td class="text-center ${cls}">${esc(v)}</td>`;
      }).join('');
      const rowClass = row.contradiction ? 'micro-contradiction-row' : '';
      return `<tr class="${rowClass}">
        <td class="micro-sticky-col"><span class="badge bg-light text-dark border">${esc(row.key)}</span></td>
        <td><span class="badge bg-secondary-subtle text-dark border">${esc(row.criterion)}</span></td>
        <td class="small text-muted">${esc(row.q || '')}</td>
        ${valueCells}
      </tr>`;
    }).join('');

    const colCount = 3 + list.length;
    tbody.innerHTML = html || `<tr><td colspan="${colCount}" class="text-muted small text-center py-3">No micro-assessment data available.</td></tr>`;
  }

  function render(report, vars, step3Vars, list) {
    document.getElementById('visualGeneratedAt').textContent = report?.generatedAt
      ? ((window.AppOrgDateTime && AppOrgDateTime.formatInstant) ? AppOrgDateTime.formatInstant(report.generatedAt) : report.generatedAt)
      : '-';
    document.getElementById('visualStatus').textContent = `Loaded ${report?.runCount || 0} runs.`;
    document.getElementById('visualStatus').className = 'small text-success';

    const stats = report?.bandVariation?.overall?.stats || {};
    const flip = report?.microItemFlipRate?.overall || {};
    const drift = report?.evidenceDrift?.overall || {};
    const agree = report?.agreementAnalysis?.summary || {};
    const runtimeList = list.map((s) => totalRuntimeSeconds(s)).filter((v) => Number.isFinite(v) && v > 0);
    const avgRuntime = runtimeList.length ? runtimeList.reduce((a, b) => a + b, 0) / runtimeList.length : null;
    document.getElementById('kpiRuns').textContent = String(report?.runCount || '-');
    document.getElementById('kpiBandRange').textContent = toFixed(stats?.range, 2);
    document.getElementById('kpiFlipRate').textContent = toPct(flip?.flipRate);
    document.getElementById('kpiDrift').textContent = toPct(drift?.averageDrift);
    document.getElementById('kpiAgreement').textContent = toPct(agree?.meanAgreement);
    document.getElementById('kpiRuntime').textContent = toSec(avgRuntime);

    const labels = (report?.sessionMeta || []).map((_, i) => `R${i + 1}`);
    const by = report?.bandVariation?.byCriterion || {};
    drawLineChart(document.getElementById('bandCanvas'), labels, [
      { values: report?.bandVariation?.overall?.series || [] },
      { values: by?.TR?.series || [] },
      { values: by?.CC?.series || [] },
      { values: by?.LR?.series || [] },
      { values: by?.GRA?.series || [] }
    ]);
    renderLegend('bandLegend', [
      { label: 'Overall Band', color: COLORS[0] },
      { label: 'TR', color: COLORS[1] },
      { label: 'CC', color: COLORS[2] },
      { label: 'LR', color: COLORS[3] },
      { label: 'GRA', color: COLORS[4] }
    ]);
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        drawVariationBars(document.getElementById('variationCanvas'), vars);
      });
    });
    renderLegend('variationLegend', (vars || []).slice(0, 12).map((r, i) => ({
      label: `${r?.key || '-'} (${toPct(r?.flipRate)})`,
      color: COLORS[i % COLORS.length]
    })));
    renderAgreementRows(report, list);
    renderVariationRows(vars);
    const step3ChartRows = (step3Vars || []).filter((r) => {
      const pct = Number(r?.flipRate);
      return Number.isFinite(pct) && pct > 0;
    });
    const step3Container = document.querySelector('.step3-chart-container');
    if (step3Container) {
      step3Container.style.minHeight = '480px';
    }
    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        drawStep3Bars(document.getElementById('step3SignalCanvas'), step3ChartRows);
      });
    });
    renderLegend('step3SignalLegend', step3ChartRows.map((r, i) => ({
      label: `${r?.key || '-'} (${toPct(r?.flipRate)})`,
      color: COLORS[i % COLORS.length]
    })));
    renderStep3SignalRows(step3Vars);
    renderFullStep3Matrix(step3Vars, list);
    renderRunSnapshotRows(list);
    renderFullMicroMatrix(list);

    const notes = [];
    if (Number(stats?.stdDev) > 0.35) notes.push('Overall band variation is high; keep run configs frozen.');
    if (Number(flip?.flipRate) > 0.2) notes.push('Answer flip rate is high; audit unstable micro-items first.');
    if (Number(drift?.averageDrift) > 0.25) notes.push('Evidence drift is high; tighten extraction constraints.');
    if (Number(agree?.meanAgreement) < 0.8) notes.push('Agreement is below target; review aggregation parameters.');
    if (!notes.length) notes.push('Runs are stable overall. Continue controlled single-tweak iterations.');
    document.getElementById('insightList').innerHTML = notes.map((n) => `<li class=\"mb-2\">${esc(n)}</li>`).join('');
  }

  async function fetchReport(force = false) {
    if (!force && cachedReport) return cachedReport;
    const idList = ids();
    if (idList.length < 2) throw new Error('At least 2 sessions are required.');
    const q = encodeURIComponent(idList.join(','));
    const res = await fetch(`/ielts/scoring/repeated-run/export?ids=${q}`);
    const payload = await res.json();
    if (!res.ok || payload?.status !== 'success') throw new Error(payload?.message || 'Failed to load repeated-run analysis.');
    cachedReport = payload.data;
    return cachedReport;
  }

  async function load(force = false, silent = false) {
    const list = sessions();
    if (ids().length < 2) {
      await showModalMessage('Visual Comparison', 'At least 2 sessions are required.', 'warning');
      return;
    }
    try {
      document.getElementById('visualStatus').textContent = 'Loading repeated-run analytics...';
      const report = await fetchReport(force);
      cachedVariation = buildAnswerVariations(list);
      cachedStep3Variation = buildStep3SignalVariations(list);
      render(report, cachedVariation, cachedStep3Variation, list);
      if (!silent) await showModalMessage('Visual Comparison', 'Visual analytics refreshed successfully.', 'check');
    } catch (err) {
      document.getElementById('visualStatus').textContent = 'Failed to load analytics.';
      document.getElementById('visualStatus').className = 'small text-danger';
      await showModalMessage('Load Failed', err?.message || 'Could not load visual analytics.', 'error');
    }
  }

  window.refreshVisualPage = async () => load(true, false);

  window.exportRepeatedRunAnalysis = async function () {
    try {
      const report = await fetchReport(false);
      downloadJson(`repeated_run_analysis_${stampNow()}.json`, report);
      await showModalMessage('Export Completed', 'Repeated-run analysis export is ready.', 'check');
    } catch (err) {
      await showModalMessage('Export Failed', err?.message || 'Could not export repeated-run analysis.', 'error');
    }
  };

  window.exportVisualPack = async function () {
    try {
      const list = sessions();
      const report = await fetchReport(false);
      const vars = cachedVariation.length ? cachedVariation : buildAnswerVariations(list);
      const step3Vars = cachedStep3Variation.length ? cachedStep3Variation : buildStep3SignalVariations(list);
      downloadJson(`visual_comparison_pack_${stampNow()}.json`, {
        generatedAt: new Date().toISOString(),
        sessions: list,
        repeatedRunAnalysis: report,
        answerVariation: vars,
        step3SignalVariation: step3Vars
      });
      await showModalMessage('Export Completed', 'Visual comparison pack is ready.', 'check');
    } catch (err) {
      await showModalMessage('Export Failed', err?.message || 'Could not export visual pack.', 'error');
    }
  };

  window.addEventListener('resize', () => { if (cachedReport) render(cachedReport, cachedVariation, cachedStep3Variation, sessions()); });
  document.addEventListener('DOMContentLoaded', () => load(false, true));
})();
</script>

<style>
