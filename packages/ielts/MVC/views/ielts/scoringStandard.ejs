  }));
}

function escapeHtml(s) {
  return String(s ?? "")
    .replace(/&/g, "&amp;").replace(/</g, "&lt;")
    .replace(/>/g, "&gt;").replace(/"/g, "&quot;").replace(/'/g, "&#39;");
}

function getParagraphDisplayId(paragraphIndex) {
  if (!Number.isInteger(paragraphIndex)) return "—";
  const paragraph = (GLOBALESSAYOBJECT?.paragraphs || []).find((p) => p.index === paragraphIndex);
  return paragraph?.displayParagraphId || `P${paragraphIndex + 1}`;
}

function getSentenceDisplayId(sentenceIndex) {
  if (!Number.isInteger(sentenceIndex)) return "—";
  const sentence = (GLOBALESSAYOBJECT?.sentences || []).find((s) => s.index === sentenceIndex);
  return sentence?.displaySentenceId || `S${sentenceIndex + 1}`;
}

function formatSentenceDisplayIds(indices) {
  const normalized = (Array.isArray(indices) ? indices : []).filter((n) => Number.isInteger(n));
  if (!normalized.length) return "—";
  return normalized.map((n) => getSentenceDisplayId(n)).join(", ");
}

function formatMs(ms) {
  if (ms == null || Number.isNaN(ms)) return "—";
  return `${(ms / 1000).toFixed(2)}s`;
}

function stepMs(stepKey) {
  const t = SESSION_BUNDLE?.steps?.[stepKey]?.timing;
  if (!t?.startedAt || !t?.endedAt) return null;
  return Math.max(0, t.endedAt - t.startedAt);
}

function totalMs() {
  const keys = ["step1freeze", "step2analyze", "step3extract", "step4grade", "step5feedback"];
  return keys.reduce((sum, k) => sum + (stepMs(k) ?? 0), 0);
}

