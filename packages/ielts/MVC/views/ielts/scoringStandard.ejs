        const runValues = Array.isArray(row?.runValues)
          ? row.runValues.map((v, idx) => `<span class="badge bg-light text-dark border me-1">R${idx + 1}: ${escapeHtml(String(v))}</span>`).join("")
          : "-";
        const status = row?.tie
          ? `<span class="badge bg-danger-subtle text-danger border">Tie fallback</span>`
          : (row?.changed
            ? `<span class="badge bg-warning text-dark">Consensus changed</span>`
            : `<span class="badge bg-light text-dark border">Consensus matched</span>`);
        return `
          <tr>
            <td class="font-monospace">${escapeHtml(String(row?.key || "-"))}</td>
            <td>${runValues}</td>
            <td class="text-center fw-bold">${escapeHtml(String(row?.consensusValue || "-"))}</td>
            <td class="text-center">${status}</td>
          </tr>
        `;
      }).join("")
    : `<tr><td colspan="4" class="text-muted small text-center py-2">No unstable Step 3 signals detected across 3 runs.</td></tr>`;

  const step3StabilityCardHtml = step3Stability ? `
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-bold small">Step 3 Stability + Consensus (3x)</div>
      <div class="card-body">
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="badge ${step3Stability?.metrics?.gatePassed ? "bg-success" : "bg-warning text-dark"}">${step3Stability?.metrics?.gatePassed ? "PASS" : "REVIEW"}</span>
          <span class="small text-muted">Evidence extraction variation across 3 runs.</span>
        </div>
        <div class="small text-muted mb-2">
          Agreement: <span class="fw-bold">${escapeHtml(Number.isFinite(Number(step3Stability?.metrics?.meanAgreement)) ? `${(Number(step3Stability.metrics.meanAgreement) * 100).toFixed(1)}%` : "-")}</span>
          <span class="mx-2">|</span>
          Flip rate: <span class="fw-bold">${escapeHtml(Number.isFinite(Number(step3Stability?.metrics?.flipRate)) ? `${(Number(step3Stability.metrics.flipRate) * 100).toFixed(1)}%` : "-")}</span>
          <span class="mx-2">|</span>
          Unstable: <span class="fw-bold">${escapeHtml(String(step3Stability?.metrics?.unstableCount ?? "-"))}</span> / ${escapeHtml(String(step3Stability?.metrics?.totalSignals ?? "-"))}
          <span class="mx-2">|</span>
          Runs: <span class="fw-bold">${escapeHtml(String(step3Stability?.metrics?.runCount ?? "-"))}</span>
        </div>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
              <tr>
                <th>Signal Key</th>
                <th>Run Values</th>
                <th class="text-center">Consensus</th>
                <th class="text-center">Status</th>
              </tr>
            </thead>
            <tbody>${step3UnstableTableRows}</tbody>
          </table>
        </div>
      </div>
    </div>
  ` : "";

  const step4StabilityCardHtml = step4Stability ? `
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-bold small">Stability Gate + Auto-Consensus</div>
      <div class="card-body">
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="badge ${step4Stability?.metrics?.gatePassed ? "bg-success" : "bg-warning text-dark"}">${step4Stability?.metrics?.gatePassed ? "PASS" : "REVIEW"}</span>
          <span class="small text-muted">3-run majority vote for unstable items.</span>
        </div>
        <div class="small text-muted">
          Agreement: <span class="fw-bold">${escapeHtml(Number.isFinite(Number(step4Stability?.metrics?.meanAgreement)) ? `${(Number(step4Stability.metrics.meanAgreement) * 100).toFixed(1)}%` : "-")}</span>
          <span class="mx-2">|</span>
          Flip rate: <span class="fw-bold">${escapeHtml(Number.isFinite(Number(step4Stability?.metrics?.flipRate)) ? `${(Number(step4Stability.metrics.flipRate) * 100).toFixed(1)}%` : "-")}</span>
          <span class="mx-2">|</span>
          Unstable: <span class="fw-bold">${escapeHtml(String(step4Stability?.metrics?.unstableCount ?? "-"))}</span> / ${escapeHtml(String(step4Stability?.metrics?.totalItems ?? "-"))}
        </div>
      </div>
    </div>
  ` : "";

  // Timings table
  const timingRows = [
    ["Step 1 (Freeze)", "step1freeze"],
    ["Step 2 (Analysis)", "step2analyze"],
    ["Step 3 (Extraction)", "step3extract"],
    ["Step 4 (Grading)", "step4grade"],
    ["Step 5 (Feedback)", "step5feedback"]
  ].map(([label, key]) => `
    <tr>
      <td>${escapeHtml(label)}</td>
      <td class="text-end font-monospace">${escapeHtml(formatMs(stepMs(key)))}</td>
    </tr>
  `).join("");

  const normalizeTokenUsage = (usage, fallbackCallCount = 1) => {
    if (!usage || typeof usage !== "object") return null;
    const promptTokenCount = Number(usage.promptTokenCount);
    const candidatesTokenCount = Number(usage.candidatesTokenCount);
    const totalTokenCount = Number(usage.totalTokenCount);
    const callCountRaw = Number(usage.callCount);
    const callCount = Number.isFinite(callCountRaw) && callCountRaw > 0
      ? Math.floor(callCountRaw)
      : Math.max(1, Number(fallbackCallCount) || 1);
    const hasTokenData =
      Number.isFinite(promptTokenCount) ||
      Number.isFinite(candidatesTokenCount) ||
      Number.isFinite(totalTokenCount);
    if (!hasTokenData) return null;
    return {
      callCount,
      promptTokenCount: Number.isFinite(promptTokenCount) ? promptTokenCount : 0,
      candidatesTokenCount: Number.isFinite(candidatesTokenCount) ? candidatesTokenCount : 0,
      totalTokenCount: Number.isFinite(totalTokenCount) ? totalTokenCount : 0
    };
  };

  const formatTokenCount = (value) => {
    const n = Number(value);
    if (!Number.isFinite(n)) return "0";
    return n.toLocaleString();
  };

  const step3TokenUsage = normalizeTokenUsage(
    SESSION_BUNDLE?.steps?.step3extract?.response?.json?.meta?.usage || null,
    1
  );
  const step4TokenUsage = normalizeTokenUsage(
    GLOBALGRADING?.meta?.aiUsageSummary ||
      SESSION_BUNDLE?.steps?.step4grade?.response?.json?.data?.meta?.aiUsageSummary ||
      null,
    1
  );
  const step5TokenUsage = normalizeTokenUsage(
    GLOBALFEEDBACK?.meta?.aiUsage ||
      SESSION_BUNDLE?.steps?.step5feedback?.response?.json?.data?.meta?.aiUsage ||
      null,
    1
  );

  const tokenUsageRows = [
    { label: "Step 3 (Extraction)", usage: step3TokenUsage },
    { label: "Step 4 (Grading)", usage: step4TokenUsage },
    { label: "Step 5 (Feedback)", usage: step5TokenUsage }
  ].filter((row) => row.usage);

  const tokenUsageTotals = tokenUsageRows.reduce(
    (acc, row) => {
      acc.callCount += Number(row?.usage?.callCount || 0);
      acc.promptTokenCount += Number(row?.usage?.promptTokenCount || 0);
      acc.candidatesTokenCount += Number(row?.usage?.candidatesTokenCount || 0);
      acc.totalTokenCount += Number(row?.usage?.totalTokenCount || 0);
      return acc;
    },
    { callCount: 0, promptTokenCount: 0, candidatesTokenCount: 0, totalTokenCount: 0 }
  );

  const tokenUsageTableRows = tokenUsageRows.length
    ? tokenUsageRows.map((row) => `
      <tr>
        <td>${escapeHtml(row.label)}</td>
        <td class="text-end font-monospace">${escapeHtml(formatTokenCount(row.usage.callCount))}</td>
        <td class="text-end font-monospace">${escapeHtml(formatTokenCount(row.usage.promptTokenCount))}</td>
        <td class="text-end font-monospace">${escapeHtml(formatTokenCount(row.usage.candidatesTokenCount))}</td>
        <td class="text-end font-monospace">${escapeHtml(formatTokenCount(row.usage.totalTokenCount))}</td>
      </tr>
    `).join("")
    : `<tr><td colspan="5" class="text-muted small">No token usage was captured for this session.</td></tr>`;

  const tokenUsageCardHtml = `
    <div class="card border-0 shadow-sm mb-3">
      <div class="card-header bg-white fw-bold small">AI Token Usage</div>
      <div class="card-body p-0">
        <table class="table table-sm mb-0">
          <thead class="table-light">
            <tr>
              <th>Step</th>
              <th class="text-end">Calls</th>
              <th class="text-end">Prompt Tokens</th>
              <th class="text-end">Output Tokens</th>
              <th class="text-end">Total Tokens</th>
            </tr>
          </thead>
          <tbody>
            ${tokenUsageTableRows}
            <tr class="table-light">
              <td class="fw-bold">Total</td>
              <td class="text-end fw-bold font-monospace">${escapeHtml(formatTokenCount(tokenUsageTotals.callCount))}</td>
              <td class="text-end fw-bold font-monospace">${escapeHtml(formatTokenCount(tokenUsageTotals.promptTokenCount))}</td>
              <td class="text-end fw-bold font-monospace">${escapeHtml(formatTokenCount(tokenUsageTotals.candidatesTokenCount))}</td>
              <td class="text-end fw-bold font-monospace">${escapeHtml(formatTokenCount(tokenUsageTotals.totalTokenCount))}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  `;

  // Evidence snapshot
  const stance = GLOBALEXTRACTION?.position?.stance ?? "—";
  const stanceIdx = getSentenceDisplayId(GLOBALEXTRACTION?.position?.stanceSentenceIndex);

  const evidenceRows = (GLOBALEXTRACTION?.bodySupport || []).map(p => {
    const paragraphIndex = Number.isInteger(p.paragraphIndex) ? p.paragraphIndex : null;
    const topic = (GLOBALEXTRACTION?.topicSentenceByParagraph || []).find(t => t.paragraphIndex === paragraphIndex)?.topicSentenceIndex;
    const paragraphRef = getParagraphDisplayId(paragraphIndex);
    const topicRef = getSentenceDisplayId(topic);
    const evidence = formatSentenceDisplayIds(p.evidenceSentenceIndices);
    const flags = [
      p.hasExplanation ? "Exp" : null,
      p.hasExample ? "Ex" : null
    ].filter(Boolean).join(", ") || "-";

    return `
      <tr>
        <td class="text-center fw-bold">${escapeHtml(paragraphRef)}</td>
        <td class="text-center font-monospace">${escapeHtml(topicRef)}</td>
        <td class="text-center font-monospace">${escapeHtml(evidence)}</td>
        <td>${escapeHtml(flags)}</td>
      </tr>
    `;
  }).join("");

  const criterionOrder = ["TR", "CC", "LR", "GRA", "General"];
  const normalizeFeedbackCriterion = (value) => {
    const v = String(value || "").trim().toUpperCase();
    return criterionOrder.includes(v) ? v : "General";
  };
  const normalizeFeedbackEvidenceRefs = (value) => {
    let refs = [];
    if (Array.isArray(value)) refs = value;
    else if (typeof value === "string") refs = value.split(/[,\s;]+/g);
    const joined = Array.isArray(value) ? value.join(" ") : String(value || "");
    const matches = joined.toUpperCase().match(/S\d+/g);
    if (matches) refs = refs.concat(matches);

    const out = [];
    const seen = new Set();
    for (const item of refs) {
      const ref = String(item || "").trim().toUpperCase();
      if (!/^S\d+$/.test(ref)) continue;
      if (seen.has(ref)) continue;
      seen.add(ref);
      out.push(ref);
    }
    return out.slice(0, 8);
  };
  const renderFeedbackRefBadges = (refs) => {
    const list = normalizeFeedbackEvidenceRefs(refs);
    if (!list.length) return `<span class="text-muted small">No direct evidence refs.</span>`;
    return list.map((ref) => `<span class="badge bg-light text-dark border font-monospace me-1">${escapeHtml(ref)}</span>`).join("");
  };

  // By-criterion summary
  const byCriterionCards = (Array.isArray(GLOBALFEEDBACK?.byCriterion) ? GLOBALFEEDBACK.byCriterion : [])
    .map((item) => ({
      criterion: normalizeFeedbackCriterion(item?.criterion),
      summary: String(item?.summary || item?.issue || "").trim(),
      evidenceRefs: normalizeFeedbackEvidenceRefs(item?.evidenceRefs || item?.evidence),
      fix: String(item?.fix || "").trim()
    }))
    .filter((item) => item.summary || item.fix)
    .sort((a, b) => criterionOrder.indexOf(a.criterion) - criterionOrder.indexOf(b.criterion))
    .map((item) => `
      <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
              <span class="badge bg-primary-subtle text-primary border">${escapeHtml(item.criterion)}</span>
            </div>
            <div class="small mb-2">${escapeHtml(item.summary || "No criterion summary available.")}</div>
            <div class="small mb-2">
              <span class="text-muted fw-bold">Evidence Refs:</span>
              <span class="ms-1">${renderFeedbackRefBadges(item.evidenceRefs)}</span>
            </div>
            <div class="small text-muted border-top pt-2">${escapeHtml(item.fix || "Apply focused revision for this criterion.")}</div>
          </div>
        </div>
      </div>
    `).join("");

  // Improvements
  const improvements = (Array.isArray(GLOBALFEEDBACK?.improvements) ? GLOBALFEEDBACK.improvements : [])
    .map((imp) => ({
      criterion: normalizeFeedbackCriterion(imp?.criterion),
      issue: String(imp?.issue || "").trim(),
      evidenceRefs: normalizeFeedbackEvidenceRefs(imp?.evidenceRefs || imp?.evidence),
      fix: String(imp?.fix || "").trim()
    }))
    .filter((imp) => imp.issue || imp.fix)
    .map((imp) => `
      <div class="col-md-6">
        <div class="card border-0 shadow-sm h-100">
          <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
              <span class="badge bg-warning text-dark">${escapeHtml(imp.criterion)}</span>
            </div>
            <div class="fw-bold text-danger small mb-2">${escapeHtml(imp.issue || "Issue identified for revision.")}</div>
            <div class="small mb-2">
              <span class="text-muted fw-bold">Evidence Refs:</span>
              <span class="ms-1">${renderFeedbackRefBadges(imp.evidenceRefs)}</span>
            </div>
            <div class="small text-muted border-top pt-2">${escapeHtml(imp.fix || "Apply targeted correction and verify against evidence refs.")}</div>
          </div>
        </div>
      </div>
    `).join("");

  // Strengths (compatibility)
  const strengths = (Array.isArray(GLOBALFEEDBACK?.strengths) ? GLOBALFEEDBACK.strengths : [])
    .map((s) => `<li class="list-group-item small">${escapeHtml(s)}</li>`)
    .join("") || `<li class="list-group-item small text-muted">No strengths listed.</li>`;

  // Report HTML
  c.innerHTML = `
    <div id="reportPrintable">
      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold small">Score Summary</div>
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-end">
                <div class="text-muted small">Overall Band</div>
                <div class="display-6 fw-bold text-primary">${escapeHtml(GLOBALGRADING.overallBand)}</div>
              </div>
              ${examinerBandHtml}
              <hr/>
              <div class="row text-center g-2">
                <div class="col-3"><div class="small text-muted fw-bold">TR</div><div class="h5 m-0">${escapeHtml(GLOBALGRADING.scores?.TR)}</div></div>
                <div class="col-3"><div class="small text-muted fw-bold">CC</div><div class="h5 m-0">${escapeHtml(GLOBALGRADING.scores?.CC)}</div></div>
                <div class="col-3"><div class="small text-muted fw-bold">LR</div><div class="h5 m-0">${escapeHtml(GLOBALGRADING.scores?.LR)}</div></div>
                <div class="col-3"><div class="small text-muted fw-bold">GRA</div><div class="h5 m-0">${escapeHtml(GLOBALGRADING.scores?.GRA)}</div></div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-md-6">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold small">Timing</div>
            <div class="card-body p-0">
              <table class="table table-sm mb-0">
                <tbody>
                  ${timingRows}
                  <tr class="table-light">
                    <td class="fw-bold">Total</td>
                    <td class="text-end fw-bold font-monospace">${escapeHtml(formatMs(totalMs()))}</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      ${tokenUsageCardHtml}

      ${step3StabilityCardHtml}
      ${step4StabilityCardHtml}

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold small">Step 11 Freeze Points</div>
            <div class="card-body p-0">
              <table class="table table-sm mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Freeze Key</th>
                    <th class="text-end">Captured At</th>
                  </tr>
                </thead>
                <tbody>${freezePointRows}</tbody>
              </table>
            </div>
          </div>
        </div>
        <div class="col-md-6">
          <div class="card border-0 shadow-sm">
            <div class="card-header bg-white fw-bold small">Step 11 Tweak Log (Latest 5)</div>
            <div class="card-body p-0">
              <table class="table table-sm mb-0">
                <thead class="table-light">
                  <tr>
                    <th>Action</th>
                    <th class="text-end">At</th>
                  </tr>
                </thead>
                <tbody>${tweakPreviewRows}</tbody>
              </table>
            </div>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white fw-bold small">Evidence Snapshot</div>
        <div class="card-body">
          <div class="mb-2 small text-muted">Stance: <span class="fw-bold text-dark">${escapeHtml(stance)}</span> (${escapeHtml(stanceIdx)})</div>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th class="text-center">Para</th>
                  <th class="text-center">Topic Ref</th>
                  <th class="text-center">Evidence Refs</th>
                  <th>Flags</th>
                </tr>
              </thead>
              <tbody>
                ${evidenceRows || `<tr><td colspan="4" class="text-muted small">No evidence map available.</td></tr>`}
              </tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white fw-bold small">Examiner Summary</div>
        <div class="card-body">
          <div class="text-muted">${escapeHtml(GLOBALFEEDBACK.summary || "")}</div>
        </div>
      </div>

      <div class="mb-3">
        <h6 class="fw-bold">By Criterion</h6>
        <div class="row g-3">
          ${byCriterionCards || `<div class="text-muted small">No criterion summary listed.</div>`}
        </div>
      </div>

      <div class="mb-3">
        <h6 class="fw-bold">Targeted Improvements</h6>
        <div class="row g-3">
          ${improvements || `<div class="text-muted small">No improvements listed.</div>`}
        </div>
      </div>

      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white fw-bold small">Key Strengths</div>
        <ul class="list-group list-group-flush">
          ${strengths}
        </ul>
      </div>

      <details class="card border-0 shadow-sm">
        <summary class="card-header bg-white fw-bold small" style="cursor:pointer;">Appendix: Raw JSON</summary>
        <div class="card-body">
          <div class="small text-muted mb-2">These are the saved raw step payloads (for auditing).</div>
          <pre class="small bg-dark text-success p-3 rounded" style="max-height:400px; overflow:auto;">${escapeHtml(JSON.stringify(maskModelFieldsForDisplay(SESSION_BUNDLE.steps), null, 2))}</pre>
        </div>
      </details>
    </div>
  `;
}

function printReport() {
  const printable = document.getElementById("reportPrintable");
  if (!printable) return;
  const w = window.open("", "_blank");
  w.document.write(`
    <html><head>
      <title>IELTS Report</title>
      <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    </head>
    <body class="p-3">
      ${printable.innerHTML}
    </body></html>
  `);
  w.document.close();
  w.focus();
  w.print();
}

function downloadReportHtml() {
  const printable = document.getElementById("reportPrintable");
  if (!printable) return;

  const html = `
<!doctype html>
<html>
<head>
  <meta charset="utf-8"/>
  <title>IELTS Session Report</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
</head>
<body class="p-3">
${printable.innerHTML}
</body>
</html>
  `.trim();

  const stamp = new Date().toISOString().slice(0,19).replace(/[:T]/g,"-");
  const blob = new Blob([html], { type: "text/html" });
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url;
  a.download = `scoring-report-${stamp}.html`;
  document.body.appendChild(a);
  a.click();
  a.remove();
  URL.revokeObjectURL(url);
}

/* =========================================================
   Step 1: Freeze
   ========================================================= */
async function runFreezeStep() {
  if (blockIfStepLocked("step1freeze")) return;
  syncSampleReferenceMetaFromSelection(false);
  const sampleSelectEl = document.getElementById("sampleSelect");
  GLOBALSAMPLEID = sampleSelectEl?.value;
  const btn = document.getElementById("btnFreeze");

  if (!GLOBALSAMPLEID) {
    return safeShowMessage({
      title: "Validation",
      icon: "warning",
      message: "Please select an essay first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }

  btn.disabled = true;
  btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Creating Input (1/2)...`;

  try {
    const freezeResponse = await postJsonAndRecord("step1freeze", "/ielts/scoring/step1/freeze", { sampleId: GLOBALSAMPLEID });
    if (freezeResponse.status !== "success") throw new Error(freezeResponse.message || "Freeze failed.");

    GLOBALESSAYOBJECT = freezeResponse.data;
    const responseBandScore = parseBandScoreOrNull(freezeResponse?.meta?.sampleBandScore);
    if (responseBandScore != null) GLOBALSAMPLEBANDSCORE = responseBandScore;

    // Also store metadata for exports
    SESSION_BUNDLE.metadata.sampleId = GLOBALSAMPLEID;
    SESSION_BUNDLE.metadata.sampleName = sampleSelectEl?.selectedOptions?.[0]?.text || "";
    SESSION_BUNDLE.metadata.examinerBandScore = GLOBALSAMPLEBANDSCORE;
    SESSION_BUNDLE.metadata.sampleFeedback = String(freezeResponse?.meta?.sampleFeedback || "");
    SESSION_BUNDLE.metadata.sampleType = String(freezeResponse?.meta?.type || sampleSelectEl?.selectedOptions?.[0]?.dataset?.type || "");
    SESSION_BUNDLE.metadata.sampleRefName = String(freezeResponse?.meta?.refName || sampleSelectEl?.selectedOptions?.[0]?.dataset?.refName || "");

    setFreezePoint("step1_input_frozen", {
      sampleId: GLOBALSAMPLEID,
      sampleName: SESSION_BUNDLE.metadata.sampleName || "",
      examinerBandScore: GLOBALSAMPLEBANDSCORE,
      wordCount: freezeResponse?.data?.stats?.wordCount ?? null,
      sentenceCount: freezeResponse?.data?.stats?.sentenceCount ?? null,
      paragraphCount: freezeResponse?.data?.stats?.paragraphCount ?? null
    });
    addTweakLog("step1_freeze_completed", {
      sampleId: GLOBALSAMPLEID,
      examinerBandScore: GLOBALSAMPLEBANDSCORE
    });
    updateSampleBandPreview();
    renderFreezeFromData(freezeResponse.data);

    btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Creating Input (2/2)...`;
    const analysisResponse = await postJsonAndRecord("step2analyze", "/ielts/scoring/step2/analyze", { essayObject: GLOBALESSAYOBJECT });
    if (analysisResponse.status !== "success") throw new Error(analysisResponse.message || "Analysis failed.");

    const analyzed = analysisResponse.data;
    GLOBALANALYSIS = analyzed;
    GLOBALPARAGRAPHROLES = analyzed?.structure?.paragraphRoles ?? null;
    setFreezePoint("step2_features_frozen", {
      paragraphCount: analyzed?.structure?.paragraphCount ?? null,
      hasIntro: analyzed?.structure?.hasIntro ?? null,
      hasConclusion: analyzed?.structure?.hasConclusion ?? null,
      cohesionDensity: analyzed?.cohesion?.densityPer100 ?? null
    });
    renderAnalysisFromData(analyzed);
    activateStep(3);
    safeShowMessage({
      title: "Input Ready",
      icon: "check",
      message: "Step 1 and Step 2 completed. You can continue from Step 3.",
      buttons: [{ text: "OK", class: "btn-success" }]
    });
  } catch (e) {
    console.error(e);
    safeShowMessage({
      title: "Network/Error",
      icon: "error",
      message: e.message || "Failed to create input.",
      buttons: [{ text: "OK", class: "btn-danger" }]
    });
  } finally {
    btn.disabled = false;
    btn.innerHTML = `<i class="bi bi-magic me-1"></i> Create Input (Step 1 + 2)`;
    updateStepLocks();
  }
}

/* =========================================================
   Step 2: Analysis (FIXED: sets GLOBALANALYSIS, not GLOBALGRADING)
   ========================================================= */
async function runAnalysisStep() {
  if (blockIfStepLocked("step2analyze")) return;
  if (!GLOBALESSAYOBJECT) {
    return safeShowMessage({
      title: "Step 1 Missing",
      icon: "warning",
      message: "Complete Step 1 first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }

  const btn = document.getElementById("btnAnalyze");
  btn.disabled = true;
  btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Analyzing...`;

  try {
    const r = await postJsonAndRecord("step2analyze", "/ielts/scoring/step2/analyze", { essayObject: GLOBALESSAYOBJECT });
    if (r.status !== "success") throw new Error(r.message || "Analysis failed.");

    const d = r.data;
    GLOBALANALYSIS = d; // <-- correct
    GLOBALPARAGRAPHROLES = d?.structure?.paragraphRoles ?? null;
    setFreezePoint("step2_features_frozen", {
      paragraphCount: d?.structure?.paragraphCount ?? null,
      hasIntro: d?.structure?.hasIntro ?? null,
      hasConclusion: d?.structure?.hasConclusion ?? null,
      cohesionDensity: d?.cohesion?.densityPer100 ?? null
    });

    renderAnalysisFromData(d);
  } catch (e) {
    console.error(e);
    safeShowMessage({
      title: "Analysis Error",
      icon: "error",
      message: e.message || "Failed to analyze.",
      buttons: [{ text: "OK", class: "btn-danger" }]
    });
  } finally {
    btn.disabled = false;
    btn.innerHTML = `<i class="bi bi-bar-chart-fill me-1"></i> Run Analysis`;
    updateStepLocks();
  }
}

/* =========================================================
   Step 3: Prompt Preview + Extraction
   ========================================================= */
const STEP3_MISSING = "__MISSING__";
const STEP4_MISSING = "__MISSING_STEP4__";
const STEP5_MISSING = "__MISSING_STEP5__";

function buildStep3Payload(customPrompt = "", options = null) {
  const payload = {
    sampleId: GLOBALSAMPLEID,
    essayObject: GLOBALESSAYOBJECT,
    promptSource: sanitizeStep3PromptSource(STEP3_PROMPT_SOURCE),
    promptTemplateId: String(STEP3_SELECTED_TEMPLATE?.id || "").trim()
  };
  const selectedModelId = getSelectedStep3ModelId();
  if (selectedModelId) payload.modelId = selectedModelId;
  const prompt = String(customPrompt || "").trim();
  if (prompt) payload.customPrompt = prompt;
  const mergedOptions = {
    stabilityProfile: STABILITY_PROFILE,
    ...(options && typeof options === "object" ? options : {})
  };
  if (selectedModelId) {
    mergedOptions.disableCache = true;
  }
  payload.options = mergedOptions;
  return payload;
}

function normalizeIntList(list) {
  const out = [];
  const seen = new Set();
  for (const v of (Array.isArray(list) ? list : [])) {
    const n = Number(v);
    if (!Number.isInteger(n) || n < 0) continue;
    if (seen.has(n)) continue;
    seen.add(n);
    out.push(n);
  }
  out.sort((a, b) => a - b);
  return out;
}

function parseIntListString(value) {
  const txt = String(value ?? "").trim();
  if (!txt) return [];
  return normalizeIntList(txt.split(",").map((s) => s.trim()).filter(Boolean).map((s) => Number(s)));
}

function intListToString(list) {
  return normalizeIntList(list).join(",");
}

function getBodySupportMap(extraction) {
  const map = new Map();
  for (const row of (Array.isArray(extraction?.bodySupport) ? extraction.bodySupport : [])) {
    const p = Number(row?.paragraphIndex);
    if (!Number.isInteger(p) || p < 0) continue;
    map.set(p, {
      paragraphIndex: p,
      hasExplanation: Boolean(row?.hasExplanation),
      hasExample: Boolean(row?.hasExample),
      evidenceSentenceIndices: normalizeIntList(row?.evidenceSentenceIndices)
    });
  }
  return map;
}

function getTopicMap(extraction) {
  const map = new Map();
  for (const row of (Array.isArray(extraction?.topicSentenceByParagraph) ? extraction.topicSentenceByParagraph : [])) {
    const p = Number(row?.paragraphIndex);
    const s = row?.topicSentenceIndex;
    if (!Number.isInteger(p) || p < 0) continue;
    map.set(p, Number.isInteger(s) ? s : null);
  }
  return map;
}

function buildStep3SignalMap(extraction) {
  const map = new Map();
  const pos = extraction?.position || {};
  map.set("position.stance", String(pos?.stance || "unclear"));
  map.set(
    "position.stanceSentenceIndex",
    Number.isInteger(pos?.stanceSentenceIndex) ? String(pos.stanceSentenceIndex) : "null"
  );
  map.set("position.contradictions", intListToString(pos?.contradictionSentenceIndices));

  const answers = extraction?.answersBySubquestion || {};
  Object.keys(answers).sort().forEach((key) => {
    map.set(`answers.${key}`, intListToString(answers[key]));
  });

  const bodyMap = getBodySupportMap(extraction);
  Array.from(bodyMap.keys()).sort((a, b) => a - b).forEach((p) => {
    const row = bodyMap.get(p);
    map.set(`body.P${p}.hasExplanation`, row?.hasExplanation ? "true" : "false");
    map.set(`body.P${p}.hasExample`, row?.hasExample ? "true" : "false");
    map.set(`body.P${p}.evidence`, intListToString(row?.evidenceSentenceIndices));
  });

  const topicMap = getTopicMap(extraction);
  Array.from(topicMap.keys()).sort((a, b) => a - b).forEach((p) => {
    const idx = topicMap.get(p);
    map.set(`topic.P${p}`, Number.isInteger(idx) ? String(idx) : "null");
  });

  const lq = extraction?.lexicalQuality || {};
  if (lq?.range) map.set("lexicalQuality.range", String(lq.range));
  if (lq?.precision) map.set("lexicalQuality.precision", String(lq.precision));
  if (lq?.uncommonSkill) map.set("lexicalQuality.uncommonSkill", String(lq.uncommonSkill));

  const ep = extraction?.errorProfiles || {};
  if (ep?.grammar) map.set("errorProfiles.grammar", String(ep.grammar));
  if (ep?.lexical) map.set("errorProfiles.lexical", String(ep.lexical));
  if (ep?.punctuation) map.set("errorProfiles.punctuation", String(ep.punctuation));

  return map;
}

function isStep3ListSignalKey(key) {
  return key === "position.contradictions" || key.startsWith("answers.") || /body\.P\d+\.evidence$/.test(key);
}

function voteScalarSignal(values) {
  const present = values.filter((v) => v !== STEP3_MISSING);
  const fallback = present.length ? present[0] : values[0];
  const freq = new Map();
  present.forEach((v) => freq.set(v, (freq.get(v) || 0) + 1));
  const ranked = Array.from(freq.entries()).sort((a, b) => b[1] - a[1] || String(a[0]).localeCompare(String(b[0])));
  const topCount = ranked[0]?.[1] || 0;
  const winners = ranked.filter(([, count]) => count === topCount);
  const hasMajority = topCount >= 2 && winners.length === 1;
  const selected = hasMajority ? winners[0][0] : fallback;
  const tie = !hasMajority && new Set(present).size > 1;
  return { selected, tie };
}

function voteListSignal(values) {
  const parsed = values.map((v) => (v === STEP3_MISSING ? null : parseIntListString(v)));
  const nonMissing = parsed.filter((arr) => Array.isArray(arr));
  const fallback = nonMissing.length ? nonMissing[0] : [];
  const counts = new Map();
  nonMissing.forEach((arr) => {
    arr.forEach((idx) => counts.set(idx, (counts.get(idx) || 0) + 1));
  });
  const voted = Array.from(counts.entries())
    .filter(([, count]) => count >= 2)
    .map(([idx]) => idx)
    .sort((a, b) => a - b);
  const allEmpty = nonMissing.every((arr) => arr.length === 0);
  if (voted.length || allEmpty) {
    return { selected: intListToString(voted), tie: false };
  }
  return { selected: intListToString(fallback), tie: true };
}

function computeStep3Consensus(extractions) {
  const runMaps = extractions.map((e) => buildStep3SignalMap(e));
  const allKeys = new Set();
  runMaps.forEach((m) => m.forEach((_, key) => allKeys.add(key)));
  const keys = Array.from(allKeys).sort();

  const consensusMap = new Map();
  const unstableRows = [];
  const allRows = [];
  let changedCount = 0;
  let tieCount = 0;
  let adjacentComparisons = 0;
  let adjacentFlips = 0;

  keys.forEach((key) => {
    const values = runMaps.map((m) => (m.has(key) ? m.get(key) : STEP3_MISSING));
    const presentValues = values.filter((v) => v !== STEP3_MISSING);
    if (!presentValues.length) return;

    const uniqueValues = new Set(presentValues);
    const unstable = uniqueValues.size > 1;

    for (let i = 1; i < values.length; i += 1) {
      const prev = values[i - 1];
      const curr = values[i];
      if (prev === STEP3_MISSING || curr === STEP3_MISSING) continue;
      adjacentComparisons += 1;
      if (prev !== curr) adjacentFlips += 1;
    }

    const vote = isStep3ListSignalKey(key) ? voteListSignal(values) : voteScalarSignal(values);
    const selected = vote.selected;
    consensusMap.set(key, selected);

    const baseline = values[0] === STEP3_MISSING ? presentValues[0] : values[0];
    const changed = baseline !== selected;
    if (changed) changedCount += 1;
    if (vote.tie) tieCount += 1;

    if (unstable) {
      unstableRows.push({
        key,
        runValues: values.map((v) => (v === STEP3_MISSING ? "-" : v)),
        consensusValue: selected,
        changed,
        tie: vote.tie
      });
    }
    allRows.push({
      key,
      runValues: values.map((v) => (v === STEP3_MISSING ? "-" : v)),
      consensusValue: selected,
      changed,
      tie: vote.tie
    });
  });

  const pairwise = [];
  for (let i = 0; i < runMaps.length; i += 1) {
    for (let j = i + 1; j < runMaps.length; j += 1) {
      let comparisons = 0;
      let agreements = 0;
      keys.forEach((key) => {
        const a = runMaps[i].has(key) ? runMaps[i].get(key) : STEP3_MISSING;
        const b = runMaps[j].has(key) ? runMaps[j].get(key) : STEP3_MISSING;
        if (a === STEP3_MISSING || b === STEP3_MISSING) return;
        comparisons += 1;
        if (a === b) agreements += 1;
      });
      pairwise.push({
        runA: i + 1,
        runB: j + 1,
        comparisons,
        agreements,
        agreementRate: comparisons > 0 ? agreements / comparisons : null
      });
    }
  }

  const agreementValues = pairwise.map((p) => p.agreementRate).filter((v) => Number.isFinite(v));
  const meanAgreement = agreementValues.length
    ? agreementValues.reduce((a, b) => a + b, 0) / agreementValues.length
    : null;
  const flipRate = adjacentComparisons > 0 ? adjacentFlips / adjacentComparisons : 0;
  const unstableShare = keys.length ? unstableRows.length / keys.length : 0;
  const gatePassed =
    Number.isFinite(meanAgreement) &&
    meanAgreement >= STEP3_STABILITY_CONFIG.minMeanAgreement &&
    flipRate <= STEP3_STABILITY_CONFIG.maxFlipRate &&
    unstableShare <= STEP3_STABILITY_CONFIG.maxUnstableShare;

  unstableRows.sort((a, b) => {
    if (a.tie !== b.tie) return a.tie ? -1 : 1;
    if (a.changed !== b.changed) return a.changed ? -1 : 1;
    return String(a.key).localeCompare(String(b.key));
  });

  return {
    consensusMap,
    unstableRows,
    allRows,
    metrics: {
      runCount: extractions.length,
      totalSignals: keys.length,
      unstableCount: unstableRows.length,
      unstableShare,
      changedCount,
      tieCount,
      adjacentComparisons,
      adjacentFlips,
      flipRate,
      meanAgreement,
      pairwise,
      gatePassed
    }
  };
}

function buildStep3SingleRunStability(extraction) {
  const signalMap = buildStep3SignalMap(extraction);
  const allRows = Array.from(signalMap.entries())
    .map(([key, value]) => ({
      key,
      runValues: [String(value)],
      consensusValue: String(value),
      changed: false,
      tie: false
    }))
    .sort((a, b) => String(a.key).localeCompare(String(b.key)));

  return {
    topUnstable: [],
    allSignals: allRows,
    metrics: {
      runCount: 1,
      totalSignals: allRows.length,
      unstableCount: 0,
      unstableShare: 0,
      changedCount: 0,
      tieCount: 0,
      adjacentComparisons: 0,
      adjacentFlips: 0,
      flipRate: 0,
      meanAgreement: 1,
      pairwise: [],
      gatePassed: true
    }
  };
}

function extractionFromConsensusMap(consensusMap, baseExtraction) {
  const base = deepCloneJson(baseExtraction || {});
  const out = {
    position: {
      stance: "unclear",
      stanceSentenceIndex: null,
      contradictionSentenceIndices: []
    },
    answersBySubquestion: {},
    bodySupport: [],
    topicSentenceByParagraph: []
  };

  const getSignal = (key, fallback) => (consensusMap.has(key) ? consensusMap.get(key) : fallback);

  const basePos = base?.position || {};
  out.position.stance = String(getSignal("position.stance", basePos?.stance || "unclear"));
  const stanceIdxRaw = String(getSignal(
    "position.stanceSentenceIndex",
    Number.isInteger(basePos?.stanceSentenceIndex) ? String(basePos.stanceSentenceIndex) : "null"
  ));
  out.position.stanceSentenceIndex = /^\d+$/.test(stanceIdxRaw) ? Number(stanceIdxRaw) : null;
  out.position.contradictionSentenceIndices = parseIntListString(getSignal(
    "position.contradictions",
    intListToString(basePos?.contradictionSentenceIndices)
  ));

  const answerKeys = new Set([
    ...Object.keys(base?.answersBySubquestion || {}),
    ...Array.from(consensusMap.keys())
      .filter((k) => k.startsWith("answers."))
      .map((k) => k.slice("answers.".length))
  ]);
  Array.from(answerKeys).sort().forEach((k) => {
    const fallback = intListToString(base?.answersBySubquestion?.[k]);
    out.answersBySubquestion[k] = parseIntListString(getSignal(`answers.${k}`, fallback));
  });

  const baseBody = getBodySupportMap(base);
  const bodyParagraphs = new Set([
    ...Array.from(baseBody.keys()),
    ...Array.from(consensusMap.keys())
      .map((k) => {
        const m = k.match(/^body\.P(\d+)\./);
        return m ? Number(m[1]) : null;
      })
      .filter((n) => Number.isInteger(n))
  ]);
  out.bodySupport = Array.from(bodyParagraphs).sort((a, b) => a - b).map((p) => {
    const row = baseBody.get(p);
    const hasExplanationRaw = getSignal(`body.P${p}.hasExplanation`, row?.hasExplanation ? "true" : "false");
    const hasExampleRaw = getSignal(`body.P${p}.hasExample`, row?.hasExample ? "true" : "false");
    const evidenceRaw = getSignal(`body.P${p}.evidence`, intListToString(row?.evidenceSentenceIndices));
    return {
      paragraphIndex: p,
      hasExplanation: String(hasExplanationRaw) === "true",
      hasExample: String(hasExampleRaw) === "true",
      evidenceSentenceIndices: parseIntListString(evidenceRaw)
    };
  });

  const baseTopic = getTopicMap(base);
  const topicParagraphs = new Set([
    ...Array.from(baseTopic.keys()),
    ...Array.from(bodyParagraphs),
    ...Array.from(consensusMap.keys())
      .map((k) => {
        const m = k.match(/^topic\.P(\d+)$/);
        return m ? Number(m[1]) : null;
      })
      .filter((n) => Number.isInteger(n))
  ]);
  out.topicSentenceByParagraph = Array.from(topicParagraphs).sort((a, b) => a - b).map((p) => {
    const baseValue = baseTopic.has(p) ? baseTopic.get(p) : null;
    const raw = String(getSignal(`topic.P${p}`, Number.isInteger(baseValue) ? String(baseValue) : "null"));
    return {
      paragraphIndex: p,
      topicSentenceIndex: /^\d+$/.test(raw) ? Number(raw) : null
    };
  });

  const lexical = base?.lexicalQuality || {};
  const range = getSignal("lexicalQuality.range", lexical?.range || "");
  const precision = getSignal("lexicalQuality.precision", lexical?.precision || "");
  const uncommonSkill = getSignal("lexicalQuality.uncommonSkill", lexical?.uncommonSkill || "");
  if (range || precision || uncommonSkill) {
    out.lexicalQuality = {
      range: String(range || lexical?.range || "basic"),
      precision: String(precision || lexical?.precision || "low"),
      uncommonSkill: String(uncommonSkill || lexical?.uncommonSkill || "none")
    };
  }

  const errors = base?.errorProfiles || {};
  const grammar = getSignal("errorProfiles.grammar", errors?.grammar || "");
  const lexicalErr = getSignal("errorProfiles.lexical", errors?.lexical || "");
  const punctuation = getSignal("errorProfiles.punctuation", errors?.punctuation || "");
  if (grammar || lexicalErr || punctuation) {
    out.errorProfiles = {
      grammar: String(grammar || errors?.grammar || "frequent"),
      lexical: String(lexicalErr || errors?.lexical || "frequent"),
      punctuation: String(punctuation || errors?.punctuation || "frequent")
    };
  }

  return out;
}

function renderStep3RunDiffPanel(stabilityMeta) {
  const panel = document.getElementById("step3RunDiffPanel");
  const metaEl = document.getElementById("step3RunDiffMeta");
  const headEl = document.getElementById("step3RunDiffHead");
  const bodyEl = document.getElementById("step3RunDiffRows");
  if (!panel || !metaEl || !headEl || !bodyEl) return;

  const rows = Array.isArray(stabilityMeta?.allSignals) ? stabilityMeta.allSignals : [];
  if (!rows.length) {
    panel.classList.add("d-none");
    metaEl.innerHTML = "";
    headEl.innerHTML = "";
    bodyEl.innerHTML = "";
    return;
  }

  const inferredFromRows = (rows[0] && Array.isArray(rows[0].runValues)) ? rows[0].runValues.length : 0;
  const runCount = Math.max(1, Number(stabilityMeta?.metrics?.runCount || inferredFromRows || 1));
  const changedCount = rows.filter((row) => row?.changed).length;
  const runLabel = runCount + (runCount === 1 ? " run" : " runs");
  metaEl.innerHTML = "Compared <span class=\"fw-bold\">" + rows.length + "</span> signals across <span class=\"fw-bold\">" + runLabel + "</span>. Differences detected in <span class=\"fw-bold\">" + changedCount + "</span> signals.";

  const headCols = ['<th>Signal</th>'];
  for (let i = 1; i <= runCount; i += 1) headCols.push(`<th class="text-center">R${i}</th>`);
  headCols.push('<th class="text-center">Consensus</th><th class="text-center">Status</th>');
  headEl.innerHTML = headCols.join("");

  const ordered = rows.slice().sort((a, b) => {
    if (Boolean(a?.changed) !== Boolean(b?.changed)) return a?.changed ? -1 : 1;
    return String(a?.key || "").localeCompare(String(b?.key || ""));
  });

  bodyEl.innerHTML = ordered.map((row) => {
    const runValues = Array.isArray(row?.runValues) ? row.runValues : [];
    const runCells = [];
    for (let i = 0; i < runCount; i += 1) {
      runCells.push(`<td class="text-center"><span class="font-monospace">${escapeHtml(String(runValues[i] ?? "-"))}</span></td>`);
    }
    const status = row?.changed
      ? `<span class="badge bg-warning text-dark">Different</span>`
      : `<span class="badge bg-light text-dark border">Stable</span>`;
    return `
      <tr>
        <td class="font-monospace">${escapeHtml(String(row?.key || "-"))}</td>
        ${runCells.join("")}
        <td class="text-center fw-bold">${escapeHtml(String(row?.consensusValue || "-"))}</td>
        <td class="text-center">${status}</td>
      </tr>
    `;
  }).join("");

  panel.classList.remove("d-none");
}

function renderStep3Stability(stabilityMeta) {
  const sidebar = document.getElementById("step3StabilitySidebar");
  const panel = document.getElementById("step3StabilityPanel");
  const metaEl = document.getElementById("step3StabilityMeta");
  const rowsEl = document.getElementById("step3StabilityRows");
  const thresholdSummary = formatStabilityThresholdSummary(STEP3_STABILITY_CONFIG);

  if (!stabilityMeta) {
    if (sidebar) {
      sidebar.innerHTML = `
        <div class="small text-muted"></div>
        <div class="small text-muted">Profile: <span class="fw-bold">${escapeHtml(STABILITY_PROFILE)}</span></div>
        <div class="small text-muted">${escapeHtml(thresholdSummary)}</div>
      `;
    }
    if (panel) panel.classList.add("d-none");
    if (metaEl) metaEl.innerHTML = "";
    if (rowsEl) rowsEl.innerHTML = "";
    renderStep3RunDiffPanel(null);
    return;
  }

  const m = stabilityMeta.metrics || {};
  const meanAgreement = Number.isFinite(Number(m.meanAgreement)) ? `${(Number(m.meanAgreement) * 100).toFixed(1)}%` : "-";
  const flipRate = Number.isFinite(Number(m.flipRate)) ? `${(Number(m.flipRate) * 100).toFixed(1)}%` : "-";
  const unstableShare = Number.isFinite(Number(m.unstableShare)) ? `${(Number(m.unstableShare) * 100).toFixed(1)}%` : "-";
  const gateBadge = m.gatePassed
    ? `<span class="badge bg-success">PASS</span>`
    : `<span class="badge bg-warning text-dark">REVIEW</span>`;

  if (sidebar) {
    sidebar.innerHTML = `
      <div class="d-flex align-items-center gap-2 mb-1">${gateBadge}<span class="small text-muted">Step 3 gate</span></div>
      <div class="small text-muted">Profile: <span class="fw-bold">${escapeHtml(STABILITY_PROFILE)}</span></div>
      <div class="small text-muted">${escapeHtml(thresholdSummary)}</div>
      <div class="small text-muted">Agreement: <span class="fw-bold">${escapeHtml(meanAgreement)}</span></div>
      <div class="small text-muted">Flip rate: <span class="fw-bold">${escapeHtml(flipRate)}</span></div>
      <div class="small text-muted">Unstable: <span class="fw-bold">${escapeHtml(String(m.unstableCount ?? "-"))}</span> / ${escapeHtml(String(m.totalSignals ?? "-"))}</div>
    `;
  }

  if (!panel || !metaEl || !rowsEl) return;
  panel.classList.remove("d-none");
  metaEl.innerHTML = `
    ${gateBadge}
    <span class="ms-2">Runs: <span class="fw-bold">${escapeHtml(String(m.runCount ?? "-"))}</span></span>
    <span class="ms-2">Mean agreement: <span class="fw-bold">${escapeHtml(meanAgreement)}</span></span>
    <span class="ms-2">Flip rate: <span class="fw-bold">${escapeHtml(flipRate)}</span></span>
    <span class="ms-2">Unstable share: <span class="fw-bold">${escapeHtml(unstableShare)}</span></span>
  `;

  const rows = Array.isArray(stabilityMeta.topUnstable) ? stabilityMeta.topUnstable : [];
  if (!rows.length) {
    rowsEl.innerHTML = `<tr><td colspan="4" class="text-muted small text-center py-2">No unstable Step 3 signals detected across ${escapeHtml(String(m.runCount || STEP3_STABILITY_CONFIG.runCount || 3))} runs.</td></tr>`;
  } else {
    rowsEl.innerHTML = rows.slice(0, 12).map((row) => {
      const runValues = Array.isArray(row?.runValues)
        ? row.runValues.map((v, idx) => `<span class="badge bg-light text-dark border me-1">R${idx + 1}: ${escapeHtml(String(v))}</span>`).join("")
        : "-";
      const status = row?.tie
        ? `<span class="badge bg-danger-subtle text-danger border">Tie fallback</span>`
        : (row?.changed
          ? `<span class="badge bg-warning text-dark">Consensus changed</span>`
          : `<span class="badge bg-light text-dark border">Consensus matched</span>`);
      return `
        <tr>
          <td class="font-monospace">${escapeHtml(String(row?.key || "-"))}</td>
          <td>${runValues}</td>
          <td class="text-center fw-bold">${escapeHtml(String(row?.consensusValue || "-"))}</td>
          <td class="text-center">${status}</td>
