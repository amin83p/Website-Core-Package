function updateStep4PromptSourceUi() {
  const source = sanitizeStep4PromptSource(STEP4_PROMPT_SOURCE);
  const builtInRadio = document.getElementById("step4PromptSourceBuiltIn");
  const templateRadio = document.getElementById("step4PromptSourceTemplate");
  const wrap = document.getElementById("step4TemplatePickerWrap");
  const selectedText = document.getElementById("step4TemplateSelectedText");
  const promptText = document.getElementById("step4PromptText");
  if (builtInRadio) builtInRadio.checked = source === STEP4_PROMPT_SOURCE_BUILTIN;
  if (templateRadio) templateRadio.checked = source === STEP4_PROMPT_SOURCE_TEMPLATE;
  if (wrap) wrap.classList.toggle("d-none", source !== STEP4_PROMPT_SOURCE_TEMPLATE);
  if (promptText) {
    const templateEditable = source === STEP4_PROMPT_SOURCE_TEMPLATE && !isStepLocked("step4grade") && !SESSION_READONLY;
    promptText.readOnly = !templateEditable;
    if (source === STEP4_PROMPT_SOURCE_BUILTIN) {
      promptText.placeholder = "Built-in prompt is generated dynamically. Click Preview Real Prompt to inspect it.";
    } else {
      promptText.placeholder = "Edit template text here (used only when prompt source is Template).";
    }
  }
  if (selectedText) {
    if (STEP4_SELECTED_TEMPLATE?.id) {
      const title = STEP4_SELECTED_TEMPLATE.name || STEP4_SELECTED_TEMPLATE.id;
      selectedText.innerHTML = `Selected: <span class="badge bg-light text-dark border">${escapeHtml(title)}</span> <span class="text-muted">(${escapeHtml(STEP4_SELECTED_TEMPLATE.id)})</span>`;
