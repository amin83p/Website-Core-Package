<span id="tuningModelsRef" data-models="<%= encodeURIComponent(JSON.stringify(aiModels || [])) %>" hidden></span>
<span id="sampleDetailsRef" data-samples="<%= encodeURIComponent(JSON.stringify(samples || [])) %>" hidden></span>

<script>
/* =========================================================
   Global Stores (same intent as your original)
   ========================================================= */
let GLOBALESSAYOBJECT = null;
let GLOBALSAMPLEID = null;
let GLOBALSAMPLEBANDSCORE = null;

let GLOBALEXTRACTION = null;
let GLOBALPARAGRAPHROLES = null;
let GLOBALANALYSIS = null;
let GLOBALGRADING = null;
let GLOBALFEEDBACK = null;
let GLOBALSTABILITY = null;
let GLOBALSTEP3STABILITY = null;
const PIPELINE_MODE = "<%= (pipelineMode || 'full') %>";
const MODEL_DISPLAY_NAME = "Microsoft Copilot";
function getModelDisplayName() {
  return MODEL_DISPLAY_NAME;
}
function getAutoModelDisplayLabel() {
  return `Auto (${MODEL_DISPLAY_NAME})`;
}
function maskModelFieldsForDisplay(value) {
  if (Array.isArray(value)) return value.map(maskModelFieldsForDisplay);
  if (!value || typeof value !== "object") return value;
  const masked = {};
  Object.entries(value).forEach(([key, v]) => {
    const lower = String(key || "").toLowerCase();
    if ((lower === "modelused" || lower === "modelid" || lower === "model") && v != null && String(v).trim()) {
      masked[key] = MODEL_DISPLAY_NAME;
      return;
    }
    masked[key] = maskModelFieldsForDisplay(v);
  });
  return masked;
}
const TUNING_MODEL_OPTIONS = (() => {
  try {
    const encoded = document.getElementById("tuningModelsRef")?.dataset?.models || "";
    return JSON.parse(decodeURIComponent(encoded || "%5B%5D"));
  } catch (_) {
    return [];
  }
})();
const SAMPLE_DETAILS_OPTIONS = (() => {
  try {
    const encoded = document.getElementById("sampleDetailsRef")?.dataset?.samples || "";
    return JSON.parse(decodeURIComponent(encoded || "%5B%5D"));
  } catch (_) {
    return [];
  }
})();
let ACTIVE_STEP_MODEL_CONFIG = null;
const STEP3_TUNING_MODEL_STORAGE_KEY = "ielts_step3_tuning_model_id";
const STEP4_TUNING_MODEL_STORAGE_KEY = "ielts_step4_tuning_model_id";
const STEP5_TUNING_MODEL_STORAGE_KEY = "ielts_step5_tuning_model_id";
const STEP3_PROMPT_SOURCE_BUILTIN = "builtin";
const STEP3_PROMPT_SOURCE_TEMPLATE = "template";
let STEP3_PROMPT_SOURCE = STEP3_PROMPT_SOURCE_BUILTIN;
let STEP3_SELECTED_TEMPLATE = null;
const STEP4_PROMPT_SOURCE_BUILTIN = "builtin";
const STEP4_PROMPT_SOURCE_TEMPLATE = "template";
let STEP4_PROMPT_SOURCE = STEP4_PROMPT_SOURCE_BUILTIN;
let STEP4_SELECTED_TEMPLATE = null;
const STEP5_PROMPT_SOURCE_BUILTIN = "builtin";
const STEP5_PROMPT_SOURCE_TEMPLATE = "template";
let STEP5_PROMPT_SOURCE = STEP5_PROMPT_SOURCE_BUILTIN;
let STEP5_SELECTED_TEMPLATE = null;

function getStepModelSelectId(stepNumber) {
  if (Number(stepNumber) === 3) return "step3ModelSelect";
  if (Number(stepNumber) === 4) return "step4ModelSelect";
  if (Number(stepNumber) === 5) return "step5ModelSelect";
  return null;
}

function getStepModelHandler(stepNumber) {
  if (Number(stepNumber) === 3) return onStep3ModelChange;
  if (Number(stepNumber) === 4) return onStep4ModelChange;
  if (Number(stepNumber) === 5) return onStep5ModelChange;
  return null;
}

function getStepModelTitle(stepNumber) {
  if (Number(stepNumber) === 3) return "Step 3 Model Settings";
  if (Number(stepNumber) === 4) return "Step 4 Model Settings";
  if (Number(stepNumber) === 5) return "Step 5 Model Settings";
  return "Model Settings";
}

function openStepModelConfig(stepNumber) {
  const step = Number(stepNumber);
  const lockedStepKey = step === 3 ? "step3extract" : (step === 4 ? "step4grade" : (step === 5 ? "step5feedback" : ""));
  if (lockedStepKey && isStepLocked(lockedStepKey)) {
    return safeShowMessage({
      title: SESSION_READONLY ? "Read-only Session" : "Step Locked",
      icon: "lock",
      message: SESSION_READONLY
        ? "Completed sessions are read-only. Start a new session to change model settings."
        : `Step ${step} is locked for this session.`,
      buttons: [{ text: "OK", class: "btn-secondary" }]
    });
  }
  const sourceSelectId = getStepModelSelectId(step);
  const sourceSelect = sourceSelectId ? document.getElementById(sourceSelectId) : null;
  const modalSelect = document.getElementById("stepModelConfigSelect");
  const titleEl = document.getElementById("stepModelConfigTitle");
  const hintEl = document.getElementById("stepModelConfigHint");
  const modalEl = document.getElementById("stepModelConfigModal");
  if (!sourceSelect || !modalSelect || !modalEl) return;

  ACTIVE_STEP_MODEL_CONFIG = step;
  if (titleEl) titleEl.textContent = getStepModelTitle(step);
  if (hintEl) hintEl.textContent = `Choose the model used for Step ${step}.`;

  modalSelect.innerHTML = "";
  Array.from(sourceSelect.options || []).forEach((option) => {
    const clone = option.cloneNode(true);
    modalSelect.appendChild(clone);
  });
  modalSelect.value = sourceSelect.value || "";

  const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
  modal.show();
}

function applyStepModelConfig() {
  const step = Number(ACTIVE_STEP_MODEL_CONFIG || 0);
  const sourceSelectId = getStepModelSelectId(step);
  const sourceSelect = sourceSelectId ? document.getElementById(sourceSelectId) : null;
  const modalSelect = document.getElementById("stepModelConfigSelect");
  const modalEl = document.getElementById("stepModelConfigModal");
  if (!sourceSelect || !modalSelect || !modalEl) return;

  sourceSelect.value = modalSelect.value || "";
  const handler = getStepModelHandler(step);
  if (typeof handler === "function") {
    handler(sourceSelect.value || "");
  } else {
    sourceSelect.dispatchEvent(new Event("change", { bubbles: true }));
  }
  bootstrap.Modal.getOrCreateInstance(modalEl).hide();
}

function firstString(...values) {
  for (const value of values) {
    const normalized = String(value ?? "").trim();
    if (normalized) return normalized;
  }
  return "";
}

function escapeHtmlLite(value) {
  return String(value ?? "")
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/\"/g, "&quot;")
    .replace(/'/g, "&#39;");
}

function getSelectedSampleRecord() {
  const sampleId = String(document.getElementById("sampleSelect")?.value || "").trim();
  if (!sampleId) return null;
  return (Array.isArray(SAMPLE_DETAILS_OPTIONS) ? SAMPLE_DETAILS_OPTIONS : []).find((row) => String(row?.id || "").trim() === sampleId) || null;
}

function openSampleDetailsModal() {
  const sample = getSelectedSampleRecord();
  if (!sample) {
    if (typeof safeShowMessage === "function") {
      safeShowMessage({
        title: "Select Sample",
        icon: "warning",
        message: "Select a sample first.",
        buttons: [{ text: "OK", class: "btn-warning" }]
      });
    }
    return;
  }

  const overviewBody = document.getElementById("sampleDetailsOverviewBody");
  const essayEl = document.getElementById("sampleDetailsEssayText");
  const feedbackEl = document.getElementById("sampleDetailsFeedbackText");
  const rawEl = document.getElementById("sampleDetailsRawJson");
  const questionText = firstString(sample.question, sample.prompt, sample.taskPrompt);
  const essayText = firstString(sample.text, sample.essayText, sample.essay, sample.writing, sample.normalizedText);
  const feedbackText = firstString(sample.feedback, sample.examinerFeedback, sample.comments);

  if (overviewBody) {
    const rows = [
      ["ID", sample.id],
      ["Reference Name", firstString(sample.refName, sample.title, sample.name)],
      ["Type", sample.type],
      ["Band Score", sample.bandScore],
      ["Question", questionText || "-"]
    ];
    overviewBody.innerHTML = rows.map(([k, v]) => `<tr><th class="w-25">${escapeHtmlLite(k)}</th><td>${escapeHtmlLite(v || "-")}</td></tr>`).join("");
  }
  if (essayEl) essayEl.textContent = essayText || "No essay text found for this sample.";
  if (feedbackEl) feedbackEl.textContent = feedbackText || "No feedback text found for this sample.";
  if (rawEl) rawEl.textContent = JSON.stringify(sample, null, 2);

  const modalEl = document.getElementById("sampleDetailsModal");
  if (!modalEl) return;
  const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
  modal.show();
}

// ------------------------------
// Grading (Step 4) runtime settings
// ------------------------------
const GRADING_LIMITS = {
  batchSize: { min: 1, max: 20, criticalMax: 12 },      // criticalMax: warning threshold
  concurrency: { min: 1, max: 10, criticalMax: 6 }      // criticalMax: warning threshold
};

let GRADING_SETTINGS = {
  batchSize: 5,
  concurrency: 2,
  mode: "hybrid_extension"
};

const STABILITY_PROFILES = {
  standard: {
    step3: { runCount: 3, minMeanAgreement: 0.9, maxFlipRate: 0.1, maxUnstableShare: 0.2 },
    step4: { runCount: 3, minMeanAgreement: 0.9, maxFlipRate: 0.1, maxUnstableShare: 0.2 }
  },
  strict: {
    step3: { runCount: 3, minMeanAgreement: 0.95, maxFlipRate: 0.05, maxUnstableShare: 0.1 },
    step4: { runCount: 3, minMeanAgreement: 0.95, maxFlipRate: 0.05, maxUnstableShare: 0.1 }
  }
};
let STABILITY_PROFILE = "standard";
let STABILITY_GATE_CONFIG = { ...STABILITY_PROFILES.standard.step4 };
let STEP3_STABILITY_CONFIG = { ...STABILITY_PROFILES.standard.step3 };

function normalizeStabilityProfile(profile) {
  return String(profile || "").trim().toLowerCase() === "strict" ? "strict" : "standard";
}

function applyStabilityProfile(profile, { logChange = false } = {}) {
  const normalized = normalizeStabilityProfile(profile);
  const previous = STABILITY_PROFILE;
  const currentStep3RunCount = Number(STEP3_STABILITY_CONFIG?.runCount || STABILITY_PROFILES.standard.step3.runCount || 3);
  const currentStep4RunCount = Number(STABILITY_GATE_CONFIG?.runCount || STABILITY_PROFILES.standard.step4.runCount || 3);
  STABILITY_PROFILE = normalized;

  STABILITY_GATE_CONFIG = { ...STABILITY_PROFILES[normalized].step4 };
  STEP3_STABILITY_CONFIG = { ...STABILITY_PROFILES[normalized].step3 };
  STEP3_STABILITY_CONFIG.runCount = clampInt(currentStep3RunCount, 2, 10, STEP3_STABILITY_CONFIG.runCount);
  STABILITY_GATE_CONFIG.runCount = clampInt(currentStep4RunCount, 2, 10, STABILITY_GATE_CONFIG.runCount);

  updateStabilityProfileLabels();
  renderStep3Stability(GLOBALSTEP3STABILITY);
  renderStabilityGateDisplay(GLOBALSTABILITY);
  if (logChange && previous !== normalized) {
    addTweakLog("stability_profile_changed", {
      from: previous,
      to: normalized,
      step3: { ...STEP3_STABILITY_CONFIG },
      step4: { ...STABILITY_GATE_CONFIG }
    });
  }
}

function updateStep3ConsensusButtonLabel() {
  const btn = document.getElementById("btnExtractConsensus");
  if (!btn) return;
  const runCount = Number(STEP3_STABILITY_CONFIG?.runCount || 3);
  btn.innerHTML = `<i class="bi bi-shield-check me-1"></i> Stability + Consensus (${runCount}x)`;
}

function onStep3RunCountChange(nextValue) {
  if (isStepLocked("step3extract")) {
    const input = document.getElementById("step3RunCountInput");
    if (input) input.value = String(STEP3_STABILITY_CONFIG.runCount);
    return safeShowMessage({
      title: "Step Locked",
      icon: "lock",
      message: "Step 3 is locked for this session. Start a new session to change run count.",
      buttons: [{ text: "OK", class: "btn-secondary" }]
    });
  }
  const previous = Number(STEP3_STABILITY_CONFIG.runCount || 3);
  const next = clampInt(nextValue, 2, 10, previous);
  STEP3_STABILITY_CONFIG.runCount = next;
  const input = document.getElementById("step3RunCountInput");
  if (input) input.value = String(next);
  updateStep3ConsensusButtonLabel();
  saveGradingSettings();
  if (next !== previous) {
    addTweakLog("step3_run_count_updated", { from: previous, to: next });
  }
}

function clampInt(v, min, max, fallback) {
  const n = Number.parseInt(v, 10);
  if (Number.isNaN(n)) return fallback;
  return Math.max(min, Math.min(max, n));
}

function normalizeRunMode(mode) {
  return String(mode || "").trim().toLowerCase() === "operationalized_only"
    ? "operationalized_only"
    : "hybrid_extension";
}

function parseBandScoreOrNull(value) {
  const txt = String(value ?? "").trim();
  if (!txt) return null;
  const num = Number(txt);
  if (!Number.isFinite(num)) return null;
  if (num < 0 || num > 9) return null;
  return Number(num.toFixed(1));
}

function getSelectedSampleBandScore() {
  const select = document.getElementById("sampleSelect");
  const option = select?.selectedOptions?.[0];
  return parseBandScoreOrNull(option?.dataset?.bandScore);
}

function updateSampleBandPreview() {
  const preview = document.getElementById("sampleBandPreview");
  if (!preview) return;
  const score = getSelectedSampleBandScore();
  preview.textContent = score == null ? "-" : String(score);
}

function syncSampleReferenceMetaFromSelection(logTweak = false) {
  const select = document.getElementById("sampleSelect");
  const option = select?.selectedOptions?.[0];
  if (!option || !option.value) {
    GLOBALSAMPLEBANDSCORE = null;
    updateSampleBandPreview();
    return;
  }

  const previousBand = GLOBALSAMPLEBANDSCORE;
  GLOBALSAMPLEBANDSCORE = parseBandScoreOrNull(option?.dataset?.bandScore);
  SESSION_BUNDLE.metadata = SESSION_BUNDLE.metadata || {};
  SESSION_BUNDLE.metadata.sampleId = option.value;
  SESSION_BUNDLE.metadata.sampleName = option.text || "";
  SESSION_BUNDLE.metadata.sampleRefName = option?.dataset?.refName || "";
  SESSION_BUNDLE.metadata.sampleType = option?.dataset?.type || "";
  SESSION_BUNDLE.metadata.examinerBandScore = GLOBALSAMPLEBANDSCORE;

  updateSampleBandPreview();

  if (logTweak && (previousBand !== GLOBALSAMPLEBANDSCORE)) {
    addTweakLog("sample_reference_band_changed", {
      sampleId: option.value,
      previousBandScore: previousBand,
      nextBandScore: GLOBALSAMPLEBANDSCORE
    });
  }
}

function loadGradingSettings() {
  try {
    const raw = localStorage.getItem("ielts_grading_settings");
    if (raw) {
      const parsed = JSON.parse(raw);
      GRADING_SETTINGS.batchSize = clampInt(parsed.batchSize, GRADING_LIMITS.batchSize.min, GRADING_LIMITS.batchSize.max, GRADING_SETTINGS.batchSize);
      GRADING_SETTINGS.concurrency = clampInt(parsed.concurrency, GRADING_LIMITS.concurrency.min, GRADING_LIMITS.concurrency.max, GRADING_SETTINGS.concurrency);
      GRADING_SETTINGS.mode = normalizeRunMode(parsed.mode || GRADING_SETTINGS.mode);
      applyStabilityProfile(parsed.stabilityProfile, { logChange: false });
      STEP3_STABILITY_CONFIG.runCount = clampInt(parsed.step3RunCount, 2, 10, STEP3_STABILITY_CONFIG.runCount);
      STABILITY_GATE_CONFIG.runCount = clampInt(parsed.step4RunCount, 2, 10, STABILITY_GATE_CONFIG.runCount);
    }
  } catch (_) {}
  updateGradingSettingsLabels();
}

function saveGradingSettings() {
  localStorage.setItem("ielts_grading_settings", JSON.stringify({
    ...GRADING_SETTINGS,
    stabilityProfile: STABILITY_PROFILE,
    step3RunCount: STEP3_STABILITY_CONFIG.runCount,
    step4RunCount: STABILITY_GATE_CONFIG.runCount
  }));
  updateGradingSettingsLabels();
}

function updateGradingSettingsLabels() {
  const b = document.getElementById("gradingBatchSizeLabel");
  const c = document.getElementById("gradingConcurrencyLabel");
  const m = document.getElementById("gradingModeLabel");
  const p = document.getElementById("stabilityProfileLabel");
  if (b) b.textContent = String(GRADING_SETTINGS.batchSize);
  if (c) c.textContent = String(GRADING_SETTINGS.concurrency);
  if (m) m.textContent = String(GRADING_SETTINGS.mode);
  if (p) p.textContent = STABILITY_PROFILE;
  updateStabilityProfileLabels();
  updateStep4ConsensusButtonLabel();
}

function getStabilityProfileInfoText(profile) {
  const normalized = normalizeStabilityProfile(profile);
  if (normalized === "strict") {
    return "Strict: more conservative scoring; requires stronger explicit evidence and tighter consistency thresholds (Agreement >= 95%, Flip <= 5%, Unstable share <= 10%).";
  }
  return "Standard: balanced coverage and interpretation with normal stability thresholds (Agreement >= 90%, Flip <= 10%, Unstable share <= 20%).";
}

function updateStabilityProfileInfoPreview(profile, infoElementId = "stabilityProfileInfo") {
  const info = document.getElementById(infoElementId);
  if (!info) return;
  info.textContent = getStabilityProfileInfoText(profile);
}

function getRunModeInfoText(mode) {
  const normalized = normalizeRunMode(mode);
  if (normalized === "operationalized_only") {
    return "operationalized_only: only operationalized deterministic checks are used. This is stricter and often more repeatable, but may miss nuanced coverage.";
  }
  return "hybrid_extension: combines deterministic operationalized checks with AI-extended checks for broader coverage and richer interpretation.";
}

function updateRunModeInfoPreview(mode) {
  const info = document.getElementById("gradingModeInfo");
  if (!info) return;
  info.textContent = getRunModeInfoText(mode);
}

function getSelectedStep3ModelId() {
  const select = document.getElementById("step3ModelSelect");
  return String(select?.value || "").trim();
}

function normalizeStep3TuningModelId(modelId) {
  const value = String(modelId || "").trim();
  if (!value) return "";
  const options = Array.isArray(TUNING_MODEL_OPTIONS) ? TUNING_MODEL_OPTIONS : [];
  return options.some((m) => String(m?.id || "").trim() === value) ? value : "";
}

function onStep3ModelChange(modelId) {
  const normalized = normalizeStep3TuningModelId(modelId);
  const select = document.getElementById("step3ModelSelect");
  if (select) select.value = normalized;
  localStorage.setItem(STEP3_TUNING_MODEL_STORAGE_KEY, normalized);
}

function initializeStep3TuningModelSelector() {
  const select = document.getElementById("step3ModelSelect");
  if (!select) return;
  const saved = localStorage.getItem(STEP3_TUNING_MODEL_STORAGE_KEY) || "";
  const normalized = normalizeStep3TuningModelId(saved);
  select.value = normalized;
  if (saved !== normalized) {
    localStorage.setItem(STEP3_TUNING_MODEL_STORAGE_KEY, normalized);
  }
}

function sanitizeStep3PromptSource(value) {
  return String(value || "").trim().toLowerCase() === STEP3_PROMPT_SOURCE_TEMPLATE
    ? STEP3_PROMPT_SOURCE_TEMPLATE
    : STEP3_PROMPT_SOURCE_BUILTIN;
}

function updateStep3PromptSourceUi() {
  const source = sanitizeStep3PromptSource(STEP3_PROMPT_SOURCE);
  const builtInRadio = document.getElementById("step3PromptSourceBuiltIn");
  const templateRadio = document.getElementById("step3PromptSourceTemplate");
  const wrap = document.getElementById("step3TemplatePickerWrap");
  const selectedText = document.getElementById("step3TemplateSelectedText");

  if (builtInRadio) builtInRadio.checked = source === STEP3_PROMPT_SOURCE_BUILTIN;
  if (templateRadio) templateRadio.checked = source === STEP3_PROMPT_SOURCE_TEMPLATE;
  if (wrap) wrap.classList.toggle("d-none", source !== STEP3_PROMPT_SOURCE_TEMPLATE);

  if (selectedText) {
    if (STEP3_SELECTED_TEMPLATE?.id) {
      const title = STEP3_SELECTED_TEMPLATE.name || STEP3_SELECTED_TEMPLATE.id;
      selectedText.innerHTML = `Selected: <span class="badge bg-light text-dark border">${escapeHtml(title)}</span> <span class="text-muted">(${escapeHtml(STEP3_SELECTED_TEMPLATE.id)})</span>`;
    } else {
      selectedText.textContent = "No template selected.";
    }
  }
}

function setStep3PromptSource(value, { logChange = true } = {}) {
  const next = sanitizeStep3PromptSource(value);
  const previous = STEP3_PROMPT_SOURCE;
  STEP3_PROMPT_SOURCE = next;
  updateStep3PromptSourceUi();
  if (logChange && previous !== next) {
    addTweakLog("step3_prompt_source_changed", { from: previous, to: next });
  }
}

function onStep3PromptSourceChange(value) {
  if (isStepLocked("step3extract")) {
    updateStep3PromptSourceUi();
    return safeShowMessage({
      title: "Step Locked",
      icon: "lock",
      message: "Step 3 is locked for this session. Start a new session to change prompt source.",
      buttons: [{ text: "OK", class: "btn-secondary" }]
    });
  }
  setStep3PromptSource(value, { logChange: true });
}

function clearStep3PromptTemplate({ logChange = true } = {}) {
  if (isStepLocked("step3extract")) return;
  const previousId = STEP3_SELECTED_TEMPLATE?.id || "";
  STEP3_SELECTED_TEMPLATE = null;
