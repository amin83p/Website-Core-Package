    const safeRole = escapeHtml(role);
    return `
      <div class="col border-end">
        <div class="fw-bold text-${color} text-uppercase small mb-1">${safeRole}</div>
        <div class="p-2 bg-light rounded border position-relative" style="height:60px;">
