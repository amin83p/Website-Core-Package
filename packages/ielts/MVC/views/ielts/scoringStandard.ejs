async function fetchPromptTemplateContentById(templateId) {
  const id = String(templateId || "").trim();
  if (!id) throw new Error("Template ID is required.");
  const response = await fetch(`/ielts/prompts/template/${encodeURIComponent(id)}`, {
    headers: { "X-AJAX-Request": "true" }
  });
  const json = await response.json();
  if (!response.ok || json.status !== "success") {
    throw new Error(json?.message || "Failed to load selected template.");
  }
  return String(json.content || "").trim();
}

