  if (blockIfStepLocked("step5feedback")) return;
  if (!GLOBALGRADING) {
    return safeShowMessage({
      title: "Wait",
      icon: "warning",
      message: "Complete Step 4 Grading first.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }

  const btn = document.getElementById("btnFeedback");
  btn.disabled = true;
  btn.innerHTML = `<span class="spinner-border spinner-border-sm me-2"></span>Generating...`;

  try {
    const customStep5Prompt = getStep5CustomPromptForExecution();
    if (customStep5Prompt === STEP5_MISSING) {
      throw new Error("Pick a Step 5 prompt template first, or switch to built-in prompt.");
    }
    const r = await postJsonAndRecord(
      "step5feedback",
      "/ielts/scoring/step5/feedback",
      {
        essayObject: GLOBALESSAYOBJECT,
        gradingResult: GLOBALGRADING,
        modelId: getSelectedStep5ModelId() || undefined,
        promptSource: sanitizeStep5PromptSource(STEP5_PROMPT_SOURCE),
        promptTemplateId: sanitizeStep5PromptSource(STEP5_PROMPT_SOURCE) === STEP5_PROMPT_SOURCE_TEMPLATE
          ? String(STEP5_SELECTED_TEMPLATE?.id || "").trim()
          : "",
        customPrompt: customStep5Prompt || ""
      }
    );
    if (r.status !== "success") throw new Error(r.message || "Feedback failed.");

    GLOBALFEEDBACK = r.data;
    setFreezePoint("step5_feedback_frozen", {
      schemaVersion: r?.data?.meta?.schemaVersion || "step5-feedback.v0225",
      modelUsed: r?.data?.meta?.modelUsed || "",
      improvementCount: Array.isArray(r?.data?.improvements) ? r.data.improvements.length : 0
    });
    addTweakLog("step5_feedback_completed", {
      schemaVersion: r?.data?.meta?.schemaVersion || "step5-feedback.v0225",
      fromFallback: Boolean(r?.data?.meta?.fromFallback)
    });
    renderFeedbackResults(r.data);
    renderReport();
  } catch (e) {
    console.error(e);
    safeShowMessage({
      title: "Error",
      icon: "error",
      message: e.message || "Feedback generation failed.",
      buttons: [{ text: "OK", class: "btn-danger" }]
    });
  } finally {
    btn.disabled = false;
    btn.innerHTML = `<i class="bi bi-magic me-1"></i> Generate`;
    updateStepLocks();
  }
}

/* NOTE: keep your original full implementation if present */
function renderFeedbackResults(fb) {
  const criterionOrder = ["TR", "CC", "LR", "GRA", "General"];
  const normalizeCriterion = (value) => {
    const v = String(value || "").trim().toUpperCase();
    return criterionOrder.includes(v) ? v : "General";
  };
  const normalizeEvidenceRefs = (value) => {
    let refs = [];
    if (Array.isArray(value)) refs = value;
    else if (typeof value === "string") refs = value.split(/[,\s;]+/g);
    const joined = Array.isArray(value) ? value.join(" ") : String(value || "");
    const matches = joined.toUpperCase().match(/S\d+/g);
    if (matches) refs = refs.concat(matches);
    const out = [];
    const seen = new Set();
    for (const refRaw of refs) {
      const ref = String(refRaw || "").trim().toUpperCase();
      if (!/^S\d+$/.test(ref)) continue;
      if (seen.has(ref)) continue;
      seen.add(ref);
      out.push(ref);
    }
    return out.slice(0, 8);
  };
  const renderEvidenceRefBadges = (refs) => {
    const list = normalizeEvidenceRefs(refs);
    if (!list.length) return `<span class="text-muted small">No direct evidence refs.</span>`;
    return list.map((ref) => `<span class="badge bg-light text-dark border font-monospace me-1">${escapeHtml(ref)}</span>`).join("");
  };

  const byCriterion = (Array.isArray(fb?.byCriterion) ? fb.byCriterion : [])
    .map((item) => ({
      criterion: normalizeCriterion(item?.criterion),
      summary: String(item?.summary || item?.issue || "").trim(),
      evidenceRefs: normalizeEvidenceRefs(item?.evidenceRefs || item?.evidence),
      fix: String(item?.fix || "").trim()
    }))
    .filter((item) => item.summary || item.fix)
    .sort((a, b) => criterionOrder.indexOf(a.criterion) - criterionOrder.indexOf(b.criterion));

  const improvements = (Array.isArray(fb?.improvements) ? fb.improvements : [])
    .map((item) => ({
      criterion: normalizeCriterion(item?.criterion),
      issue: String(item?.issue || "").trim(),
      evidenceRefs: normalizeEvidenceRefs(item?.evidenceRefs || item?.evidence),
      fix: String(item?.fix || "").trim()
    }))
    .filter((item) => item.issue || item.fix);

  const byCriterionHtml = byCriterion.map((item) => `
    <div class="col-md-6">
      <div class="card h-100 border-0 shadow-sm">
        <div class="card-body">
          <div class="d-flex justify-content-between mb-2">
            <span class="badge bg-primary-subtle text-primary border">${escapeHtml(item.criterion)}</span>
          </div>
          <div class="small mb-2">${escapeHtml(item.summary || "No criterion summary provided.")}</div>
          <div class="small mb-2">
            <span class="text-muted fw-bold">Evidence Refs:</span>
            <span class="ms-1">${renderEvidenceRefBadges(item.evidenceRefs)}</span>
          </div>
          <div class="small text-muted border-top pt-2 bg-light p-2 rounded">
            <i class="bi bi-wrench-adjustable me-1 text-success"></i> ${escapeHtml(item.fix || "Apply targeted revision for this criterion.")}
          </div>
        </div>
      </div>
    </div>
  `).join("");
  const improvementsHtml = improvements.map((imp) => `
    <div class="col-md-4">
      <div class="card h-100 border-0 shadow-sm bg-white">
        <div class="card-body">
          <div class="d-flex justify-content-between mb-2">
            <span class="badge bg-warning text-dark">${escapeHtml(imp.criterion)}</span>
          </div>
          <div class="fw-bold small mb-2 text-danger">
            <i class="bi bi-exclamation-circle me-1"></i> ${escapeHtml(imp.issue || "Issue identified for revision.")}
          </div>
          <div class="small mb-2">
            <span class="text-muted fw-bold">Evidence Refs:</span>
            <span class="ms-1">${renderEvidenceRefBadges(imp.evidenceRefs)}</span>
