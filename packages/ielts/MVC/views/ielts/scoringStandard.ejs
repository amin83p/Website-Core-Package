        </tr>
        <tr>
          <td colspan="7" class="bg-light-subtle">${detailsSection}</td>
        </tr>
      `;
    }).join("");

    const fallback = `
      <tr><td colspan="7" class="text-muted text-center">No grading rows found for this criterion.</td></tr>
    `;

    return `
      <div class="card border-0 shadow-sm mb-3">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
          <span class="fw-bold">${escapeHtml(criterionTrace.criterion)}</span>
          <span class="badge bg-primary-subtle text-primary border">Final: ${escapeHtml(criterionTrace.finalBand)}</span>
        </div>
        <div class="card-body p-0">
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead class="table-light">
                <tr>
                  <th>Target Band</th>
                  <th class="text-center">Items</th>
                  <th class="text-center">Passed/Total Weight</th>
                  <th class="text-center">Pass %</th>
