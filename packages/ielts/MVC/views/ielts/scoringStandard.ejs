function isSuccessfulStep(stepKey, bundle = SESSION_BUNDLE) {
  return bundle?.steps?.[stepKey]?.response?.json?.status === "success";
}

function isPipelineComplete(bundle = SESSION_BUNDLE) {
  return STEP_ORDER.every((k) => isSuccessfulStep(k, bundle));
}

function ensureCompletionMarker(bundle = SESSION_BUNDLE) {
  if (!isPipelineComplete(bundle)) return;
  if (!bundle.steps) bundle.steps = {};
  if (!bundle.steps.step6report) {
    const now = Date.now();
    bundle.steps.step6report = {
      request: { source: "client", action: "report-ready" },
      response: { contentType: "application/json", json: { status: "success" } },
      timing: { startedAt: now, endedAt: now }
    };
  }
}

