  }).join("");

  document.getElementById("structureViz").innerHTML = structHTML;

  document.getElementById("flagIntro").innerHTML = d.structure.hasIntro
    ? `<i class="bi bi-check text-success"></i> Intro`
    : `<i class="bi bi-x text-danger"></i> No Intro`;

  document.getElementById("flagConclusion").innerHTML = d.structure.hasConclusion
    ? `<i class="bi bi-check text-success"></i> Concl.`
    : `<i class="bi bi-x text-danger"></i> No Concl.`;

  // 2) Cohesion / Lexical
  document.getElementById("connDensity").textContent = d.cohesion.densityPer100;
  document.getElementById("connVariety").textContent = d.cohesion.distinctConnectors;

  const tags = Object.entries(d.cohesion.usageMap || {})
    .sort((a, b) => (b[1] || 0) - (a[1] || 0))
    .slice(0, 6)
    .map(([w, c]) => `<span class="badge bg-light text-dark border">${escapeHtml(w)} (${escapeHtml(c)})</span>`)
    .join("") || "None";

  document.getElementById("connTags").innerHTML = tags;

  document.getElementById("refDensity").textContent = d.lexical.referencingDensity;

  const repHTML = (d.lexical.topRepeatedWords || [])
    .map(r => `<li>${escapeHtml(r.word)} <span class="fw-bold">${escapeHtml(r.count)}</span></li>`)
    .join("") || `<li class="text-muted small">None</li>`;

  document.getElementById("repWordsList").innerHTML = repHTML;

  const paragraphRows = (d.perParagraphFeatures || []).map((p) => {
    const paraLabel = Number.isInteger(p.paragraphNumber) ? `P${p.paragraphNumber}` : "—";
    const role = escapeHtml(p.role || "body");
    const sentenceCount = Number.isFinite(Number(p.sentenceCount)) ? Number(p.sentenceCount) : 0;
    const connDensity = Number.isFinite(Number(p.connectorDensity)) ? Number(p.connectorDensity).toFixed(2) : "0.00";
    const connDensityExBasic = Number.isFinite(Number(p.connectorDensityExcludingBasic))
      ? Number(p.connectorDensityExcludingBasic).toFixed(2)
      : "0.00";
    const refDensity = Number.isFinite(Number(p.referencingDensity)) ? Number(p.referencingDensity).toFixed(2) : "0.00";
    const repeatedWords = (Array.isArray(p.repeatedWords) ? p.repeatedWords : [])
      .map((item) => `${escapeHtml(item.word)} (${escapeHtml(item.count)})`)
      .join(", ") || "-";
    const signpostBadge = p.hasConclusionSignpost
      ? (p.misplacedConclusionSignpost
          ? `<span class="badge bg-danger-subtle border text-danger">Misplaced</span>`
          : `<span class="badge bg-success-subtle border text-success">Yes</span>`)
      : `<span class="badge bg-secondary-subtle border text-muted">No</span>`;

    return `
      <tr>
        <td class="fw-bold">${escapeHtml(paraLabel)}</td>
        <td class="text-capitalize">${role}</td>
        <td class="text-center">${escapeHtml(sentenceCount)}</td>
