  dirty: false //if we have data on page

};
ensureStep11Scaffold(SESSION_BUNDLE);

function ensureStep11Scaffold(bundle = SESSION_BUNDLE) {
  if (!bundle || typeof bundle !== "object") return;
  if (!Array.isArray(bundle.tweakLog)) bundle.tweakLog = [];
  if (!bundle.freezePoints || typeof bundle.freezePoints !== "object" || Array.isArray(bundle.freezePoints)) {
    bundle.freezePoints = {};
  }
}

function addTweakLog(action, details = {}) {
  ensureStep11Scaffold(SESSION_BUNDLE);
  SESSION_BUNDLE.tweakLog.push({
    id: `twk_${Date.now()}_${Math.floor(Math.random() * 1000)}`,
    at: new Date().toISOString(),
    action: String(action || "unknown").trim() || "unknown",
    details: (details && typeof details === "object") ? details : { value: String(details ?? "") }
  });
  if (SESSION_BUNDLE.tweakLog.length > 500) {
    SESSION_BUNDLE.tweakLog = SESSION_BUNDLE.tweakLog.slice(-500);
  }
  SESSION_BUNDLE.dirty = true;
}

function setFreezePoint(key, payload = {}) {
  ensureStep11Scaffold(SESSION_BUNDLE);
  const freezeKey = String(key || "").trim();
  if (!freezeKey) return;
  SESSION_BUNDLE.freezePoints[freezeKey] = {
    at: new Date().toISOString(),
    ...(payload && typeof payload === "object" ? payload : {})
  };
  SESSION_BUNDLE.dirty = true;
}

