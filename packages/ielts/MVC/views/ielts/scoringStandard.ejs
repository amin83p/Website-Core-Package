<div id="gradingSettingsOverlay" class="gs-overlay d-none" role="dialog" aria-modal="true" aria-labelledby="gradingSettingsTitle">
  <div class="gs-modal">
    <div class="gs-header">
      <div>
        <div id="gradingSettingsTitle" class="fw-bold">Grading Settings</div>
        <div class="text-muted small">Controls how Step 4 batches questions and how many AI requests run in parallel.</div>
      </div>
      <button type="button" class="btn btn-sm btn-outline-secondary" onclick="closeGradingSettings()" aria-label="Close">
        <i class="bi bi-x-lg"></i>
      </button>
    </div>

    <div class="gs-body">
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-label fw-bold">Batch size (questions per prompt)</label>
          <input id="gradingBatchSizeInput" type="number" class="form-control" min="1" max="20" step="1" />
          <div class="form-text">Recommended: 4–8. Max: 20.</div>
        </div>

        <div class="col-md-6">
          <label class="form-label fw-bold">Concurrency (parallel batches)</label>
          <input id="gradingConcurrencyInput" type="number" class="form-control" min="1" max="10" step="1" />
          <div class="form-text">Recommended: 1–4. Max: 10.</div>
        </div>

        <div class="col-md-12">
          <label class="form-label fw-bold">Run mode</label>
          <select id="gradingModeInput" class="form-select">
            <option value="hybrid_extension">hybrid_extension</option>
            <option value="operationalized_only">operationalized_only</option>
          </select>
          <div id="gradingModeInfo" class="form-text">
            hybrid_extension: deterministic checks + AI-extended checks; better coverage. operationalized_only: only operationalized deterministic checks; stricter and usually more repeatable.
          </div>
        </div>

        <div class="col-md-12">
          <label class="form-label fw-bold">Stability profile</label>
          <select id="stabilityProfileInput" class="form-select">
            <option value="standard">standard</option>
            <option value="strict">strict</option>
          </select>
          <div id="stabilityProfileInfo" class="form-text">
            standard balances coverage and interpretation; strict is more conservative and requires stronger evidence.
          </div>
        </div>
      </div>

      <div id="gradingSettingsWarning" class="alert alert-warning mt-3 d-none" role="alert"></div>
    </div>

    <div class="gs-footer">
      <button type="button" class="btn btn-secondary" onclick="resetGradingSettings()">Reset</button>
      <div class="ms-auto d-flex gap-2">
        <button type="button" class="btn btn-secondary" onclick="closeGradingSettings()">Cancel</button>
        <button type="button" class="btn btn-success" onclick="applyGradingSettings()">Apply</button>
      </div>
    </div>
  </div>
</div>

