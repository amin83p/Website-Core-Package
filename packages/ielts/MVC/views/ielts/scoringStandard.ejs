async function postJsonNoRecord(url, payload) {
  const res = await fetch(url, {
    method: "POST",
    headers: { "Content-Type": "application/json" },
    body: JSON.stringify(payload)
  });
  const contentType = res.headers.get("content-type") || "";
  if (!contentType.includes("application/json")) {
    const text = await res.text().catch(() => "");
    throw new Error(`Server returned non-JSON response (HTTP ${res.status}). ${String(text || "").slice(0, 160)}`);
  }
  const json = await res.json();
  if (!res.ok || json?.status !== "success") {
    throw new Error(json?.message || `Request failed (HTTP ${res.status}).`);
  }
  return json;
}

function getStep4BaseRows(gradingData) {
  if (Array.isArray(gradingData?.aggregatedResults) && gradingData.aggregatedResults.length > 0) {
    return gradingData.aggregatedResults;
  }
  if (Array.isArray(gradingData?.results)) return gradingData.results;
  return [];
}

function getStep4RowKey(row) {
  const criterion = String(row?.criterion || "GEN").trim().toUpperCase();
  const band = Number.isFinite(Number(row?.band)) ? Number(row.band) : "";
  const baseKey = String(row?.baseKey || row?.question_key || row?.instanceKey || "").trim();
  if (baseKey) return `${criterion}::${band}::${baseKey}`;
  const atomic = String(row?.atomic_question || "").trim().toLowerCase();
  return `${criterion}::${band}::${atomic || "unknown"}`;
}

function normalizeVoteValue(value) {
  const txt = String(value ?? "").trim().toLowerCase();
  return txt || null;
}

function deepCloneJson(value) {
  return JSON.parse(JSON.stringify(value ?? null));
}

function calculateBandScoresClient(rows) {
  const criteria = ["TR", "CC", "LR", "GRA"];
  const passFeature = new Set([
    "yes", "true", "clear", "adequate", "wide", "logical", "well_managed",
    "sufficient", "skilful", "relevant", "high", "ok"
  ]);
  const passFault = new Set([
    "no", "false", "none", "rare", "rarely", "never", "few", "minimal", "minor", "ok"
  ]);

  const scores = {};
  for (const criterion of criteria) {
    const criterionRows = (rows || []).filter((r) => String(r?.criterion || "").toUpperCase() === criterion);
    if (!criterionRows.length) {
      scores[criterion] = 0;
      continue;
    }

    let currentBand = 4.0;
    for (let b = 5; b <= 9; b += 1) {
      const bandRows = criterionRows.filter((r) => Number(r?.band) === b);
      if (!bandRows.length) {
        currentBand = b;
        continue;
      }

      let totalWeight = 0;
      let passedWeight = 0;

      for (const row of bandRows) {
        const wRaw = Number(row?.weight);
        const weight = Number.isFinite(wRaw) && wRaw > 0 ? wRaw : 1;
        totalWeight += weight;

        const val = normalizeVoteValue(row?.value);
        if (!val || val === "error" || val === "n/a") continue;

        const polarity = String(row?.polarity || "FEATURE_CHECK").toUpperCase();
        let pass = false;
        if (polarity === "FAULT_CHECK") {
          pass = passFault.has(val) || val.includes("rare") || val.includes("few") || val.includes("minor");
        } else {
          pass = passFeature.has(val) || val === "yes";
        }
        if (pass) passedWeight += weight;
      }

      if (totalWeight === 0) break;
      const ratio = passedWeight / totalWeight;
      if (ratio >= 0.5) {
        currentBand = b;
      } else {
        currentBand = ratio >= 0.35 ? b - 0.5 : b - 1;
        break;
      }
    }

    scores[criterion] = Math.max(4, Math.min(9, currentBand));
  }

  const avg = (scores.TR + scores.CC + scores.LR + scores.GRA) / 4;
  return {
    overall: Math.round(avg * 2) / 2,
    criteria: scores
  };
}

function evaluateBandRowPass(row, passFeature, passFault) {
  const val = normalizeVoteValue(row?.value);
  if (!val || val === "error" || val === "n/a") {
    return { considered: false, pass: false, normalized: val || "" };
  }
  const polarity = String(row?.polarity || "FEATURE_CHECK").toUpperCase();
  let pass = false;
  if (polarity === "FAULT_CHECK") {
    pass = passFault.has(val) || val.includes("rare") || val.includes("few") || val.includes("minor");
  } else {
    pass = passFeature.has(val) || val === "yes";
  }
  return { considered: true, pass, normalized: val };
}

function buildBandCalculationTrace(rows) {
  const criteria = ["TR", "CC", "LR", "GRA"];
  const passFeature = new Set([
    "yes", "true", "clear", "adequate", "wide", "logical", "well_managed",
    "sufficient", "skilful", "relevant", "high", "ok"
  ]);
  const passFault = new Set([
    "no", "false", "none", "rare", "rarely", "never", "few", "minimal", "minor", "ok"
  ]);

  return criteria.map((criterion) => {
    const criterionRows = (rows || []).filter((r) => String(r?.criterion || "").toUpperCase() === criterion);
    const checkpoints = [];
    let currentBand = 4.0;

    if (!criterionRows.length) {
      return { criterion, finalBand: 0, checkpoints: [] };
    }

    for (let b = 5; b <= 9; b += 1) {
      const bandRows = criterionRows.filter((r) => Number(r?.band) === b);
      if (!bandRows.length) {
        currentBand = b;
        checkpoints.push({
          targetBand: b,
          rowCount: 0,
          totalWeight: 0,
          passedWeight: 0,
          passRatio: null,
          passPercent: null,
          decision: `No micro-questions at band ${b}. Proceed to next band.`,
          proceed: true,
          scoreAfterStep: currentBand,
          rows: []
        });
        continue;
      }

      let totalWeight = 0;
      let passedWeight = 0;
      const rowDetails = bandRows.map((row) => {
        const weightRaw = Number(row?.weight);
        const weight = Number.isFinite(weightRaw) && weightRaw > 0 ? weightRaw : 1;
        totalWeight += weight;

        const vote = evaluateBandRowPass(row, passFeature, passFault);
        if (vote.considered && vote.pass) passedWeight += weight;

        return {
          baseKey: String(row?.baseKey || row?.question_key || row?.instanceKey || "").trim(),
          question: String(row?.atomic_question || "").trim(),
          value: String(row?.value ?? ""),
          polarity: String(row?.polarity || "FEATURE_CHECK").toUpperCase(),
          weight,
          considered: vote.considered,
          pass: vote.pass
        };
      });

      if (totalWeight === 0) {
        checkpoints.push({
          targetBand: b,
          rowCount: rowDetails.length,
          totalWeight: 0,
          passedWeight: 0,
          passRatio: null,
          passPercent: null,
          decision: "No weighted signals were available. Stop progression.",
          proceed: false,
          scoreAfterStep: currentBand,
          rows: rowDetails
        });
        break;
      }

      const ratio = passedWeight / totalWeight;
      const proceed = ratio >= 0.5;
      if (proceed) {
        currentBand = b;
      } else {
        currentBand = ratio >= 0.35 ? (b - 0.5) : (b - 1);
      }

      checkpoints.push({
        targetBand: b,
        rowCount: rowDetails.length,
        totalWeight,
        passedWeight,
        passRatio: ratio,
        passPercent: Number((ratio * 100).toFixed(1)),
        decision: proceed
          ? `Pass threshold met at band ${b}. Proceed to next band.`
          : `Threshold not met at band ${b}. Stop here.`,
        proceed,
        scoreAfterStep: currentBand,
        rows: rowDetails
      });

      if (!proceed) break;
    }

    return {
      criterion,
      finalBand: Math.max(4, Math.min(9, currentBand)),
      checkpoints
    };
  });
}

