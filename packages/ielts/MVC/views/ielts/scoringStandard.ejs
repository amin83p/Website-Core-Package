function formatPromptPreviewList(prompts = [], label = "Prompt") {
  const list = Array.isArray(prompts) ? prompts : [];
  if (!list.length) return "";
  return list
    .map((p, i) => `===== ${label} ${i + 1}/${list.length} =====\n${String(p || "").trim()}`)
    .join("\n\n");
}

async function previewStep4PromptContent() {
  if (!GLOBALESSAYOBJECT || !GLOBALANALYSIS || !GLOBALEXTRACTION) {
    return safeShowMessage({
      title: "Data Missing",
      icon: "warning",
      message: "Complete Steps 1, 2, and 3 before previewing Step 4 prompts.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }
  const customPrompt = getStep4CustomPromptForExecution();
  if (customPrompt === STEP4_MISSING) {
    return safeShowMessage({
      title: "Template Required",
      icon: "warning",
      message: "Pick a Step 4 template first, or switch to built-in prompt.",
      buttons: [{ text: "OK", class: "btn-warning" }]
    });
  }
  try {
    const btn = document.getElementById("btnPreviewStep4Prompt");
    if (btn) {
      btn.disabled = true;
      btn.innerHTML = `<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>Preparing...`;
    }
    showPromptPreviewLoading(
      "Preparing Step 4 prompt preview...",
      "Large micro-assessment sets may take a few seconds."
    );
    const payload = buildStep4Payload({ disableCache: true });
    const response = await postJsonNoRecord("/ielts/scoring/step4/prompt/preview", payload);
    const prompts = response?.data?.prompts || [];
    if (!prompts.length) {
      hidePromptPreviewLoading();
      return safeShowMessage({
        title: "No AI Prompts",
        icon: "info",
        message: "No Step 4 AI prompts were generated for this sample.",
        buttons: [{ text: "OK", class: "btn-info" }]
      });
    }
    const previewText = formatPromptPreviewList(prompts, "Step 4 Batch Prompt");
    hidePromptPreviewLoading();
    openRealPromptPreviewModal("Step 4 Real Prompt Preview", previewText);
  } catch (error) {
    hidePromptPreviewLoading();
    safeShowMessage({
      title: "Preview Error",
      icon: "error",
      message: error.message || "Failed to preview Step 4 prompt.",
      buttons: [{ text: "OK", class: "btn-danger" }]
    });
  } finally {
    const btn = document.getElementById("btnPreviewStep4Prompt");
    if (btn) {
      btn.disabled = false;
      btn.innerHTML = `<i class="bi bi-eye me-1"></i> Preview Real Prompt`;
    }
  }
}

async function previewStep5PromptContent() {
