function activateStep(n) {
  const maxStep = PIPELINE_MODE === "step3_tuning"
    ? 3
    : (PIPELINE_MODE === "step4_tuning" ? 4 : 6);
  if (Number(n) > maxStep) {
    n = maxStep;
  }
  // OLD (problem): document.querySelectorAll('.tab-pane')...
  document.querySelectorAll('.tab-pane').forEach(p => {
    if (/^step[1-6]$/.test(p.id)) p.classList.remove('show', 'active');
  });

  document.getElementById(`step${n}`)?.classList.add('show', 'active');

  document.querySelectorAll("#pipelineStepsContent > .tab-pane").forEach(p => p.classList.remove("show", "active"));
  document.getElementById(`step${n}`)?.classList.add("show", "active");

  document.querySelectorAll(".step-item").forEach(el => {
    el.classList.remove("active", "border-primary", "bg-light");
    el.classList.add("text-muted");
    const fw = el.querySelector(".fw-bold");
    if (fw) { fw.classList.remove("text-primary"); fw.classList.add("text-muted"); }
  });

  document.querySelectorAll(".step-item").forEach(el => {
    if (parseInt(el.dataset.step) === n) {
      el.classList.add("active", "border-primary", "bg-light");
      el.classList.remove("text-muted");
      const fw = el.querySelector(".fw-bold");
      if (fw) { fw.classList.add("text-primary"); fw.classList.remove("text-muted"); }
    }
  });

  window.scrollTo({ top: 0, behavior: "smooth" });
}

function applyTuningModeUi() {
  const maxStep = PIPELINE_MODE === "step3_tuning"
    ? 3
    : (PIPELINE_MODE === "step4_tuning" ? 4 : 6);
  if (maxStep >= 6) return;
  const stepper = document.getElementById("stepperContainer");
  if (stepper) {
    stepper.querySelectorAll(".step-item").forEach((item) => {
      const n = Number(item?.dataset?.step || 0);
      if (n > maxStep) item.classList.add("d-none");
    });
  }

  ["step1", "step2", "step3", "step4", "step5", "step6"].forEach((id) => {
    const pane = document.getElementById(id);
    const stepNum = Number(String(id).replace("step", ""));
    if (pane && stepNum > maxStep) pane.classList.add("d-none");
  });

  const step3NextWrap = document.getElementById("step3NextWrap");
  if (step3NextWrap && maxStep <= 3) step3NextWrap.classList.add("d-none");
  const step4NextWrap = document.getElementById("step4NextWrap");
  if (step4NextWrap && maxStep <= 4) step4NextWrap.classList.add("d-none");

  const timerStep4 = document.getElementById("timerStep4");
  const timerStep5 = document.getElementById("timerStep5");
  if (maxStep <= 3 && timerStep4?.closest(".timing-pill")) timerStep4.closest(".timing-pill").classList.add("d-none");
  if (maxStep <= 4 && timerStep5?.closest(".timing-pill")) timerStep5.closest(".timing-pill").classList.add("d-none");
}

